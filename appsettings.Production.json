{
  "ConnectionStrings": {
    "conString": "Server=YOUR_PRODUCTION_SQL_SERVER;Database=ERP;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;Command Timeout=60;"
  },

  "RunMigrationsOnStartup": false,
  "RunSeedOnStartup": false,

  "TechnicalLogging": {
    "EnableMvcPerformance": true,
    "MvcPerformanceMinDurationMs": 400,
    "HttpRequestSlowThresholdMs": 3000
  },

  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },

  "AllowedHosts": "*"
}
