{
  "ConnectionStrings": {
    "conString": "Server=(localdb)\\mssqllocaldb;Database=ALQASWAA;Trusted_Connection=True;TrustServerCertificate=True;Max Pool Size=200;Min Pool Size=10;Connection Timeout=30;Command Timeout=60;"
  },

  "RunMigrationsOnStartup": false,
  "RunSeedOnStartup": false,

  "TechnicalLogging": {
    "EnableMvcPerformance": true,
    "MvcPerformanceMinDurationMs": 0,
    "HttpRequestSlowThresholdMs": 2000
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/erp-technical-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  "AllowedHosts": "*"
}
