<?xml version="1.0" encoding="utf-8"?>
<!-- NuGet: استخدام الكاش المحلي أولاً ثم nuget.org v3 -->
<configuration>
  <packageSources>
    <clear />
    <!-- الكاش المحلي أولاً (يعمل بدون إنترنت إذا كانت الحزم محمّلة مسبقاً) -->
    <add key="local-cache" value="%USERPROFILE%\.nuget\packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="local-cache">
      <package pattern="*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
  <config>
    <add key="http_proxy" value="" />
    <add key="https_proxy" value="" />
  </config>
</configuration>
