.vs/
*.user
*.suo

# ==========================
# فولدرات الـ Build (ما نحتاجهاش في Git)
# ==========================
bin/
obj/

# تسجيل فني (Serilog — erp-technical-*.log)
Logs/

# ==========================
# ملفات إضافية اختيارية
