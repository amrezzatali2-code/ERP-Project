@model ERP.Models.Customer

@{
    ViewData["Title"] = "تعديل بيانات عميل";
}

<div class="container mt-3" dir="rtl">
    <h2 class="mb-3">تعديل بيانات عميل</h2>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()

        @* كود العميل مخفي (مفتاح أساسي) *@
        <input type="hidden" asp-for="CustomerId" />

        @* اسم العميل *@
        <div class="mb-3">
            <label asp-for="CustomerName" class="form-label"></label>
            <input asp-for="CustomerName" class="form-control" />
            <span asp-validation-for="CustomerName" class="text-danger"></span>
        </div>

        @* هواتف وواتساب *@
        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="Phone1" class="form-label"></label>
                <input asp-for="Phone1" class="form-control" />
                <span asp-validation-for="Phone1" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Phone2" class="form-label"></label>
                <input asp-for="Phone2" class="form-control" />
                <span asp-validation-for="Phone2" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Whatsapp" class="form-label"></label>
                <input asp-for="Whatsapp" class="form-control" />
                <span asp-validation-for="Whatsapp" class="text-danger"></span>
            </div>
        </div>

        @* العنوان *@
        <div class="mb-3">
            <label asp-for="Address" class="form-label"></label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>



        @* ===== الربط الجغرافي: المحافظة / الحي / المنطقة (متسلسلة) ===== *@
        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="GovernorateId" class="form-label"></label>
                <select asp-for="GovernorateId"
                        class="form-select"
                        asp-items="ViewBag.GovernorateId"
                        id="GovernorateId">
                    <option value="">-- اختر المحافظة --</option>
                </select>
                <span asp-validation-for="GovernorateId" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="DistrictId" class="form-label"></label>
                <select asp-for="DistrictId"
                        class="form-select"
                        asp-items="ViewBag.DistrictId"
                        id="DistrictId">
                    <option value="">-- اختر الحي / المركز --</option>
                </select>
                <span asp-validation-for="DistrictId" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="AreaId" class="form-label"></label>
                <select asp-for="AreaId"
                        class="form-select"
                        asp-items="ViewBag.AreaId"
                        id="AreaId">
                    <option value="">-- اختر المنطقة --</option>
                </select>
                <span asp-validation-for="AreaId" class="text-danger"></span>
            </div>
        </div>

        @* خط السير *@
        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="RouteId" class="form-label"></label>
                <select asp-for="RouteId"
                        asp-items="ViewBag.RouteId"
                        class="form-select form-select-sm">
                    <option value="">-- لا خط سير --</option>
                </select>
            </div>
        </div>

        @* نوع الطرف (عميل / مورد / موظف / مستثمر ) / الحساب المحاسبي *@

        <div class="row">

            <div class="col-md-6 mb-3">

                <label class="form-label">نوع الطرف</label>
                <select asp-for="PartyCategory"
                        class="form-select"
                        id="PartyCategorySelect">
                    <option value=""> اختر</option>

                    @* نفس القيم التي نستخدمها في الداتا بيز والكنترولر *@
                    <option value="Customer">عميل (Customer)</option>
                    <option value="Supplier">مورد (Supplier)</option>
                    <option value="Employee">موظف (Employee)</option>
                    <option value="Investor">مستثمر (Investor)</option>
                    <option value="Bank">بنك (Bank)</option>
                    <option value="Expense">مصروف (Expense)</option>
                    <option value="Owner">مالك / شريك (Owner)</option>
                </select>
                <span asp-validation-for="PartyCategory" class="text-danger"></span>
            </div>


            @* الحساب المحاسبي *@
            <div class="col-md-6 mb-3">
                <label asp-for="AccountId" class="form-label"></label>

                <select asp-for="AccountId"
                        class="form-select"
                        asp-items="ViewBag.AccountId">
                    @* <option value="">-- بدون ربط محاسبي (مؤقتًا</option> *@
                </select>

                <span asp-validation-for="AccountId" class="text-danger"></span>
            </div>

        </div>

      



        @* سياسة العميل + المستخدم المسئول *@
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="PolicyId" class="form-label">سياسة العميل</label>
                <select asp-for="PolicyId"
                        class="form-select"
                        asp-items="ViewBag.PolicyList">
                    <option value="">-- بدون سياسة محددة --</option>
                </select>
                <span asp-validation-for="PolicyId" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="UserId" class="form-label">المستخدم المسئول (المندوب)</label>
                <select asp-for="UserId"
                        class="form-select"
                        asp-items="ViewBag.UserList">
                    <option value="">-- بدون ربط بمستخدم --</option>
                </select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>
        </div>

        @* بيانات مسئول الطلب *@
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="OrderContactName" class="form-label">اسم مسئول الطلب</label>
                <input asp-for="OrderContactName" class="form-control" />
                <span asp-validation-for="OrderContactName" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="OrderContactPhone" class="form-label">هاتف مسئول الطلب</label>
                <input asp-for="OrderContactPhone" class="form-control" />
                <span asp-validation-for="OrderContactPhone" class="text-danger"></span>
            </div>
        </div>

        @* الحد الائتماني + الحالة + مضاعفة الكوتة — تنسيق عددي ثابت (نقطة) لتفادي خطأ "must be a number" *@
        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="CreditLimit" class="form-label"></label>
                <input type="number" step="0.01" name="CreditLimit" id="CreditLimit" value="@(Model.CreditLimit.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))" class="form-control" />
                <span asp-validation-for="CreditLimit" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <div class="form-check mt-4" style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: nowrap;">
                    <label asp-for="IsActive" class="form-check-label mb-0" for="IsActive" style="order: 1;">نشط؟</label>
                    <input asp-for="IsActive" class="form-check-input flex-shrink-0" id="IsActive" style="order: 2;" />
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="form-check mt-2 mb-2">
                    <input asp-for="IsQuotaMultiplierEnabled" class="form-check-input" />
                    <label asp-for="IsQuotaMultiplierEnabled" class="form-check-label">
                        مضاعفة الكوتة؟
                    </label>
                </div>

                <label asp-for="QuotaMultiplier" class="form-label">رقم المضاعفة</label>
                <select asp-for="QuotaMultiplier" class="form-select">
                    <option value="1">1 × (بدون مضاعفة)</option>
                    <option value="2">2 ×</option>
                    <option value="3">3 ×</option>
                    <option value="4">4 ×</option>
                    <option value="5">5 ×</option>
                </select>
                <span asp-validation-for="QuotaMultiplier" class="text-danger"></span>
            </div>
        </div>

        @* ملاحظات *@
        <div class="mb-3">
            <label asp-for="Notes" class="form-label"></label>
            <textarea asp-for="Notes" class="form-control"></textarea>
            <span asp-validation-for="Notes" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">حفظ التعديلات</button>
        <a asp-action="Index" class="btn btn-secondary">رجوع للقائمة</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const partySelect = document.getElementById('PartyCategorySelect');
            const accountSelect = document.getElementById('AccountId');
            const governorateSelect = document.getElementById('GovernorateId');
            const districtSelect = document.getElementById('DistrictId');
            const areaSelect = document.getElementById('AreaId');

            // ——— ربط نوع الطرف ↔ الحساب المحاسبي (اتجاهين) ———
            if (partySelect && accountSelect) {
                // عند تغيير نوع الطرف → تحديث الحساب الافتراضي
                function setDefaultAccount(forceChange) {
                    const party = partySelect.value;
                    if (!party) return;
                    if (!forceChange && accountSelect.value) return;
                    fetch('@Url.Action("GetDefaultAccountForParty", "Customers")?partyCategory=' + encodeURIComponent(party))
                        .then(r => r.ok ? r.json() : null)
                        .then(data => {
                            if (data && data.success && data.accountId != null)
                                accountSelect.value = data.accountId.toString();
                        })
                        .catch(err => console.error('خطأ في تحميل الحساب الافتراضي:', err));
                }
                partySelect.addEventListener('change', function () { setDefaultAccount(true); });
                setDefaultAccount(false);

                // عند تغيير الحساب المحاسبي → تحديث نوع الطرف إن وُجد تطابق
                accountSelect.addEventListener('change', function () {
                    const accountId = this.value;
                    if (!accountId) return;
                    fetch('@Url.Action("GetPartyCategoryForAccount", "Customers")?accountId=' + encodeURIComponent(accountId))
                        .then(r => r.ok ? r.json() : null)
                        .then(data => {
                            if (data && data.success && data.partyCategory)
                                partySelect.value = data.partyCategory;
                        })
                        .catch(err => console.error('خطأ في جلب نوع الطرف للحساب:', err));
                });
            }

            // ——— تعبئة متسلسلة: المحافظة → الحي → المنطقة ———
            if (governorateSelect && districtSelect && areaSelect) {
                const districtPlaceholder = '-- اختر الحي / المركز --';
                const areaPlaceholder = '-- اختر المنطقة --';

                function fillDistrictOptions(govId) {
                    districtSelect.innerHTML = '<option value="">' + districtPlaceholder + '</option>';
                    areaSelect.innerHTML = '<option value="">' + areaPlaceholder + '</option>';
                    if (!govId) return;
                    fetch('@Url.Action("GetDistrictsByGovernorate", "Customers")?governorateId=' + encodeURIComponent(govId))
                        .then(r => r.ok ? r.json() : [])
                        .then(arr => {
                            (arr || []).forEach(function (d) {
                                const opt = document.createElement('option');
                                opt.value = d.id;
                                opt.textContent = d.name;
                                districtSelect.appendChild(opt);
                            });
                        })
                        .catch(err => console.error('Error loading districts:', err));
                }

                function fillAreaOptions(distId) {
                    areaSelect.innerHTML = '<option value="">' + areaPlaceholder + '</option>';
                    if (!distId) return;
                    fetch('@Url.Action("GetAreasByDistrict", "Customers")?districtId=' + encodeURIComponent(distId))
                        .then(r => r.ok ? r.json() : [])
                        .then(arr => {
                            (arr || []).forEach(function (a) {
                                const opt = document.createElement('option');
                                opt.value = a.id;
                                opt.textContent = a.name;
                                areaSelect.appendChild(opt);
                            });
                        })
                        .catch(err => console.error('Error loading areas:', err));
                }

                governorateSelect.addEventListener('change', function () {
                    fillDistrictOptions(this.value || null);
                });
                districtSelect.addEventListener('change', function () {
                    fillAreaOptions(this.value || null);
                });
            }
        });
    </script>
}
