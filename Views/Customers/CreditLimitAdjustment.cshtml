@model ERP.ViewModels.CustomerCreditLimitAdjustmentViewModel

@{
    ViewData["Title"] = "تعديل الحد الائتماني";
    var now = DateTime.Now;
    bool tempActive = Model.TemporaryIncreaseAmount > 0m
        && Model.TemporaryIncreaseUntil.HasValue
        && Model.TemporaryIncreaseUntil.Value > now;
    bool tempExpired = Model.TemporaryIncreaseAmount > 0m
        && Model.TemporaryIncreaseUntil.HasValue
        && Model.TemporaryIncreaseUntil.Value <= now;

    string PartyText(string? party) => (party ?? "").Trim().ToLowerInvariant() switch
    {
        "customer" => "عميل",
        "supplier" => "مورد",
        "employee" => "موظف",
        "investor" => "مستثمر",
        "bank" => "بنك",
        "expense" => "مصروف",
        "owner" => "مالك / شريك",
        _ => "غير محدد"
    };
}

@section Styles {
    <style>
        .credit-limit-card {
            border: 1px solid #8fd3ff !important;
            border-radius: 0.6rem;
            box-shadow: 0 0 0 1px rgba(143, 211, 255, 0.15);
            background: #fff;
        }

        .credit-limit-card > .card-header {
            background: linear-gradient(180deg, #eef8ff 0%, #e6f4ff 100%) !important;
            border-bottom: 1px solid #8fd3ff !important;
            color: #0f3554;
        }

        .credit-limit-readonly {
            background-color: #fcfeff !important;
            border-color: #c7e8ff !important;
        }
    </style>
}

<div class="container-fluid" dir="rtl">
    <h4 class="mt-3 mb-3">@ViewData["Title"]</h4>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <div class="card credit-limit-card mb-3">
        <div class="card-header"><strong>بحث عن العميل</strong></div>
        <div class="card-body">
            <form method="get" asp-action="CreditLimitAdjustment" class="row g-3 align-items-end" id="creditLimitSearchForm">
                <input type="hidden" name="customerId" id="selectedCustomerId" value="@(Model.CustomerId?.ToString() ?? "")" />

                <div class="col-12 col-md-3 col-lg-2">
                    <label class="form-label">كود العميل</label>
                    <input type="text" id="customerCodeInput" class="form-control" placeholder="كود" />
                </div>

                <div class="col-12 col-md-9 col-lg-6">
                    <label class="form-label">اسم العميل</label>
                    <input type="text" id="customerNameInput" class="form-control" list="creditCustomerNames" placeholder="اكتب اسم العميل أو ابدأ بالحروف..." />
                    <datalist id="creditCustomerNames">
                        @foreach (var c in Model.Customers)
                        {
                            <option value="@c.CustomerName" data-id="@c.CustomerId"></option>
                        }
                    </datalist>
                </div>

                <div class="col-12 col-lg-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">عرض البيانات</button>
                    <a class="btn btn-outline-secondary open-same-tab"
                       href="@Url.Action("Index", "Customers", new { frame = 1 })"
                       data-tab-id="customers-index"
                       data-tab-title="قائمة العملاء"
                       data-url="@Url.Action("Index", "Customers", new { frame = 1 })">عودة للقائمة</a>
                </div>
            </form>
        </div>
    </div>

    @if (Model.CustomerId.HasValue)
    {
        <div class="card credit-limit-card mb-3">
            <div class="card-header"><strong>بيانات الحد الائتماني الحالية</strong></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <label class="form-label text-muted">اسم العميل</label>
                        <div class="form-control credit-limit-readonly">@Model.CustomerName</div>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label text-muted">نوع الطرف</label>
                        <div class="form-control credit-limit-readonly">@PartyText(Model.PartyCategory)</div>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label text-muted">الحساب المحاسبي</label>
                        <div class="form-control credit-limit-readonly">@(!string.IsNullOrWhiteSpace(Model.AccountCode) ? $"{Model.AccountCode} - " : "")@Model.AccountName</div>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label text-muted">الحد الأساسي</label>
                        <div class="form-control credit-limit-readonly">@Model.BaseCreditLimit.ToString("N2")</div>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label text-muted">الرصيد الحالي</label>
                        <div class="form-control credit-limit-readonly">@Model.CurrentBalance.ToString("N2")</div>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label text-muted">الحد الفعّال</label>
                        <div class="form-control credit-limit-readonly">@Model.EffectiveCreditLimit.ToString("N2")</div>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label text-muted">المتبقي المتاح</label>
                        <div class="form-control credit-limit-readonly">@Model.RemainingCredit.ToString("N2")</div>
                    </div>
                </div>

                @if (tempActive)
                {
                    <div class="alert alert-info mt-3 mb-0">
                        زيادة مؤقتة سارية: <strong>@Model.TemporaryIncreaseAmount.ToString("N2")</strong>
                        حتى <strong>@Model.TemporaryIncreaseUntil?.ToString("yyyy-MM-dd HH:mm")</strong>.
                    </div>
                }
                else if (tempExpired)
                {
                    <div class="alert alert-warning mt-3 mb-0">
                        توجد زيادة مؤقتة منتهية (انتهت في @Model.TemporaryIncreaseUntil?.ToString("yyyy-MM-dd HH:mm")) ولم تعد مؤثرة على الحد.
                    </div>
                }
            </div>
        </div>

        <div class="card credit-limit-card mb-4">
            <div class="card-header"><strong>رفع الحد الائتماني المؤقت (24 ساعة)</strong></div>
            <div class="card-body">
                <form method="post" asp-action="CreditLimitAdjustment" class="row g-3 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CustomerId" value="@Model.CustomerId" />

                    <div class="col-12 col-md-4">
                        <label class="form-label">قيمة الزيادة المؤقتة</label>
                        <input type="number" name="IncreaseAmount" class="form-control" min="0" step="0.01" value="@Model.IncreaseAmount.ToString("0.##")" />
                        <div class="form-text">تُضاف على الحد الأساسي لمدة 24 ساعة، ثم تُلغى تلقائيًا.</div>
                    </div>

                    <div class="col-12 col-md-8 d-flex gap-2">
                        <button type="submit" name="submitAction" value="apply" class="btn btn-success">تطبيق الزيادة المؤقتة</button>
                        <button type="submit" name="submitAction" value="clear" class="btn btn-outline-danger">إلغاء الزيادة المؤقتة الآن</button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            const selectedIdInput = document.getElementById('selectedCustomerId');
            const codeInput = document.getElementById('customerCodeInput');
            const nameInput = document.getElementById('customerNameInput');
            if (!selectedIdInput || !codeInput || !nameInput) return;

            const customers = [
                @for (int i = 0; i < Model.Customers.Count; i++)
                {
                    var c = Model.Customers[i];
                    <text>{ id:@c.CustomerId, name:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(c.CustomerName)) }@(i < Model.Customers.Count - 1 ? "," : "")</text>
                }
            ];

            function findById(id) {
                const n = parseInt((id || '').toString(), 10);
                if (!Number.isFinite(n)) return null;
                return customers.find(c => c.id === n) || null;
            }

            function findByName(name) {
                const q = (name || '').trim().toLowerCase();
                if (!q) return null;
                return customers.find(c => (c.name || '').trim().toLowerCase() === q) || null;
            }

            function findByCode(code) {
                const q = (code || '').toString().trim();
                if (!q) return null;
                return customers.find(c => c.id.toString() === q) || null;
            }

            function syncFromCustomer(c) {
                if (!c) return;
                selectedIdInput.value = c.id;
                codeInput.value = c.id;
                nameInput.value = c.name || '';
            }

            const pre = findById(selectedIdInput.value);
            if (pre) syncFromCustomer(pre);

            codeInput.addEventListener('input', function () {
                const c = findByCode(this.value);
                if (c) syncFromCustomer(c);
            });

            nameInput.addEventListener('change', function () {
                const exact = findByName(this.value);
                if (exact) syncFromCustomer(exact);
            });

            nameInput.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    const exact = findByName(nameInput.value);
                    if (exact) syncFromCustomer(exact);
                }
            });
        })();
    </script>
}
