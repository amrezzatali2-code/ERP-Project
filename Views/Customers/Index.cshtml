@section Scripts {
    <script>
        // جعل الشريط الأفقي يفتح من جهة اليمين (بداية الجدول في RTL)
        (function () {
            var table = document.getElementById("customersTable");
            if (!table) return;
            var wrapper = table.closest(".erp-table-wrapper");
            if (!wrapper) return;
            wrapper.scrollLeft = wrapper.scrollWidth - wrapper.clientWidth;
        })();

        // =========================
        // فلتر الأعمدة بنمط Excel (ترتيب + فلترة على كل الأعمدة)
        // =========================
        (function () {
            const panel = document.getElementById("erpColumnFilterPanel");
            const titleEl = document.getElementById("erpColumnFilterTitle");
            const searchInp = document.getElementById("erpColumnFilterSearch");
            const searchRowEl = document.getElementById("erpColumnFilterSearchRow");
            const listEl = document.getElementById("erpColumnFilterList");
            const btnOk = document.getElementById("erpColumnFilterOk");
            const btnClear = document.getElementById("erpColumnFilterClear");
            const btnClose = document.getElementById("erpColumnFilterClose");

            let currentCol = null;
            let currentSortKey = null;
            let allItems = [];
            let currentSelected = new Set();
            let filterListLoading = false;
            let anchorRect = null;
            const numericColumns = ["id"];
            const columnToSearchBy = {
                name: "name", type: "type", phone: "phone", Address: "address", governorate: "all", district: "all", area: "all",
                account: "account", PolicyId: "all", credit: "all", isactive: "active", CurrentBalance: "all", ordercontact: "all",
                created: "all", updated: "all", quota: "all"
            };

            function getCurrentFilterValue(col) {
                if (numericColumns.includes(col)) {
                    var url = new URL(window.location.href);
                    return url.searchParams.get("filterCol_" + col + "Expr") || url.searchParams.get("filterCol_" + col) || "";
                }
                return new URL(window.location.href).searchParams.get("filterCol_" + col) || "";
            }
            function getCurrentSort() {
                var url = new URL(window.location.href);
                return { sort: url.searchParams.get("sort") || "name", dir: url.searchParams.get("dir") || "asc" };
            }
            function adjustPanelPosition() {
                if (!panel || !anchorRect) return;
                setTimeout(function () {
                    var panelRect = panel.getBoundingClientRect();
                    var margin = 8;
                    var top = anchorRect.bottom + 4;
                    var left = anchorRect.left;
                    if (top + panelRect.height > window.innerHeight - margin) top = Math.max(margin, window.innerHeight - margin - panelRect.height);
                    if (left + panelRect.width > window.innerWidth - margin) left = Math.max(margin, window.innerWidth - margin - panelRect.width);
                    panel.style.top = top + "px";
                    panel.style.left = left + "px";
                }, 50);
            }

            function showPanel(btn) {
                currentCol = btn.dataset.col;
                currentSortKey = btn.dataset.sortKey || currentCol;
                titleEl.textContent = "ترتيب وفلتر: " + (btn.dataset.colTitle || currentCol);
                searchInp.value = "";
                currentSelected = new Set();
                anchorRect = btn.getBoundingClientRect();
                panel.style.minWidth = Math.max(250, anchorRect.width) + "px";
                panel.classList.remove("d-none");
                var currentSort = getCurrentSort();
                var isCurrent = currentSort.sort.toLowerCase() === currentSortKey.toLowerCase();
                var currentDir = isCurrent ? currentSort.dir : "asc";
                document.querySelectorAll("#erpColumnFilterPanel .erp-sort-btn").forEach(function (sortBtn) {
                    if (isCurrent && sortBtn.dataset.sortDir === currentDir) {
                        sortBtn.classList.add("active", "btn-primary");
                        sortBtn.classList.remove("btn-outline-secondary");
                    } else {
                        sortBtn.classList.remove("active", "btn-primary");
                        sortBtn.classList.add("btn-outline-secondary");
                    }
                });
                adjustPanelPosition();

                if (numericColumns.includes(currentCol)) {
                    if (searchRowEl) searchRowEl.style.display = "none";
                    var currentExpr = getCurrentFilterValue(currentCol);
                    listEl.innerHTML = '<div class="mb-2"><label class="form-label small mb-1">بحث رقمي:</label><input type="text" id="erpNumericExpr" class="form-control form-control-sm" placeholder="مثال: 10 أو &lt;100 أو 10:200" value="' + (currentExpr || "").replace(/</g, "&lt;").replace(/>/g, "&gt;") + '"></div>';
                    adjustPanelPosition();
                    setTimeout(function () {
                        var exprInput = document.getElementById("erpNumericExpr");
                        if (exprInput) {
                            exprInput.onkeydown = function (e) { if (e.key === "Enter") { e.preventDefault(); applyFilter(); } };
                            exprInput.focus();
                        }
                    }, 100);
                    return;
                }
                if (searchRowEl) searchRowEl.style.display = "";
                listEl.innerHTML = '<div class="text-muted text-center py-3">جاري التحميل...</div>';
                currentSelected = new Set((getCurrentFilterValue(currentCol) || "").split("|").filter(Boolean));
                var url = "/Customers/GetColumnValues?column=" + encodeURIComponent(currentCol);
                var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                if (searchVal) url += "&search=" + encodeURIComponent(searchVal);
                fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                    allItems = items;
                    renderList("");
                }).catch(function () { listEl.innerHTML = '<div class="text-danger text-center py-2">فشل التحميل</div>'; });
            }

            function renderList(search) {
                var term = (search || "").toLowerCase();
                var filtered = term ? allItems.filter(function (x) { return (x.display || x.value || "").toLowerCase().includes(term); }) : allItems;
                var allChecked = filtered.length > 0 && filtered.every(function (x) { return currentSelected.has(String(x.value)); });
                listEl.innerHTML = '<div class="form-check mb-1"><input type="checkbox" class="form-check-input" id="erpFilterSelectAll" ' + (allChecked ? "checked" : "") + '><label class="form-check-label small" for="erpFilterSelectAll">(تحديد الكل)</label></div><div class="erp-filter-items" style="max-height:200px;overflow-y:auto;">' + filtered.map(function (x) {
                    var v = String(x.value);
                    var checked = currentSelected.has(v);
                    return '<div class="form-check"><input type="checkbox" class="form-check-input erp-filter-item" value="' + v.replace(/"/g, "&quot;") + '" ' + (checked ? "checked" : "") + '><label class="form-check-label small">' + (x.display || v).replace(/</g, "&lt;") + '</label></div>';
                }).join("") + "</div>";
                var selectAllCb = listEl.querySelector("#erpFilterSelectAll");
                if (selectAllCb) {
                    selectAllCb.indeterminate = filtered.some(function (x) { return currentSelected.has(String(x.value)); }) && !allChecked;
                    selectAllCb.onchange = function () {
                        filtered.forEach(function (x) {
                            if (this.checked) currentSelected.add(String(x.value)); else currentSelected.delete(String(x.value));
                        }.bind(this));
                        renderList(searchInp.value);
                    };
                }
                listEl.querySelectorAll(".erp-filter-item").forEach(function (cb) {
                    cb.onchange = function () {
                        if (this.checked) currentSelected.add(this.value); else currentSelected.delete(this.value);
                        renderList(searchInp.value);
                    };
                });
                adjustPanelPosition();
            }

            function applyFilter(applySort, sortDir) {
                if (!currentCol) return;
                var url = new URL(window.location.href);
                // تحديث فلتر العمود الحالي فقط — إبقاء فلاتر الأعمدة الأخرى (AND)
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.delete("filterCol_" + currentCol + "Expr");
                if (applySort !== undefined && applySort !== null && sortDir !== undefined && sortDir !== null) {
                    url.searchParams.set("sort", applySort);
                    url.searchParams.set("dir", sortDir);
                } else if (currentSortKey) {
                    var cur = getCurrentSort();
                    url.searchParams.set("sort", cur.sort);
                    url.searchParams.set("dir", cur.dir);
                }
                if (numericColumns.includes(currentCol)) {
                    var exprInput = document.getElementById("erpNumericExpr");
                    var expr = exprInput ? String(exprInput.value || "").trim() : "";
                    if (expr) url.searchParams.set("filterCol_" + currentCol + "Expr", expr);
                } else {
                    // أولوية القيم المحددة (تشيك بوكسات): فلتر عمود فقط — لا نستخدم بوكس البحث داخل اللوحة كـ search عام
                    var val = Array.from(currentSelected).filter(Boolean).join("|");
                    if (val) {
                        url.searchParams.set("filterCol_" + currentCol, val);
                        url.searchParams.delete("search");
                        url.searchParams.delete("searchBy");
                    } else {
                        var filterBoxText = (searchInp && searchInp.value) ? String(searchInp.value).trim() : "";
                        if (filterBoxText) {
                            url.searchParams.set("search", filterBoxText);
                            url.searchParams.set("searchBy", columnToSearchBy[currentCol] || "all");
                        }
                    }
                }
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }
            function clearFilter() {
                if (!currentCol) return;
                var url = new URL(window.location.href);
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.delete("filterCol_" + currentCol + "Expr");
                var searchByVal = url.searchParams.get("searchBy") || "";
                if (columnToSearchBy[currentCol] && searchByVal === columnToSearchBy[currentCol]) {
                    url.searchParams.delete("search");
                    url.searchParams.delete("searchBy");
                }
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }

            document.querySelectorAll(".erp-col-filter-btn").forEach(function (btn) {
                btn.addEventListener("click", function (e) { e.stopPropagation(); showPanel(this); });
            });
            document.addEventListener("click", function (e) {
                if (e.target.closest(".erp-sort-btn")) {
                    var sortBtn = e.target.closest(".erp-sort-btn");
                    if (currentSortKey) applyFilter(currentSortKey, sortBtn.dataset.sortDir);
                }
            });
            var fetchDebounce = null;
            searchInp && searchInp.addEventListener("input", function () {
                if (numericColumns.includes(currentCol)) return;
                renderList(this.value);
                if (fetchDebounce) clearTimeout(fetchDebounce);
                fetchDebounce = setTimeout(function () {
                    fetchDebounce = null;
                    if (!currentCol) return;
                    var url = "/Customers/GetColumnValues?column=" + encodeURIComponent(currentCol);
                    var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                    if (searchVal) url += "&search=" + encodeURIComponent(searchVal);
                    fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                        allItems = items;
                        renderList(searchInp ? searchInp.value : "");
                    }).catch(function () { });
                }, 400);
            });
            searchInp && searchInp.addEventListener("keydown", function (e) { if (e.key === "Enter") { e.preventDefault(); applyFilter(); } });
            btnOk && btnOk.addEventListener("click", function (e) { e.preventDefault(); e.stopPropagation(); applyFilter(); });
            btnClear && btnClear.addEventListener("click", clearFilter);
            btnClose && btnClose.addEventListener("click", function () { panel.classList.add("d-none"); });
            document.addEventListener("click", function (e) {
                if (panel && !panel.classList.contains("d-none") && !panel.contains(e.target) && !e.target.closest(".erp-col-filter-btn"))
                    panel.classList.add("d-none");
            });
        })();

        // طباعة
        document.getElementById("btnPrintCustomers")?.addEventListener("click", function () {
            window.print();
        });

        // تحديد الكل + الحذف الجماعي + حذف الجميع
        (function () {
            const table = document.getElementById("customersTable");
            if (!table) return;

            const selectAll = document.getElementById("selectAll");
            const bulkBtn = document.getElementById("btnBulkDelete");
            const bulkForm = document.getElementById("formBulkDelete");
            const deleteAllBtn = document.getElementById("btnDeleteAll");
            const formDeleteAll = document.getElementById("formDeleteAll");
            const bulkDeleteIdsInput = document.getElementById("bulkDeleteIdsInput");

            function getRowCheckboxes() {
                return Array.from(table.querySelectorAll("tbody .row-select"));
            }

            selectAll?.addEventListener("change", function () {
                const checked = this.checked;
                getRowCheckboxes().forEach(cb => cb.checked = checked);
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select") && !target.checked && selectAll) {
                    selectAll.checked = false;
                }
            });

            bulkBtn?.addEventListener("click", function () {
                const checks = getRowCheckboxes().filter(cb => cb.checked);
                if (checks.length === 0) {
                    alert("من فضلك اختر على الأقل عميل واحد للحذف.");
                    return;
                }
                if (!confirm("هل أنت متأكد من حذف العملاء المحددين؟")) return;
                if (bulkDeleteIdsInput) bulkDeleteIdsInput.value = checks.map(cb => cb.value).join(",");
                bulkForm?.submit();
            });

            deleteAllBtn?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع العملاء. هل أنت متأكد؟")) return;
                formDeleteAll?.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها فى localStorage
        // =========================
        (function () {
            const table = document.getElementById("customersTable");
            if (!table) return;

            const storageKey = "customers-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            // قراءة الأعمدة المخفية من localStorage
            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            // بناء قائمة الأعمدة داخل المودال
            const listContainer = document.getElementById("columnsListCustomers");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsCustomers")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalCustomers");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر الكود من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");   // نرجع لأول صفحة
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
