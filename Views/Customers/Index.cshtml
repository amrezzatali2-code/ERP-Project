@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<Customer>

@{
    ViewData["Title"] = "العملاء ";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "Customers";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var searchMode = ((string?)ViewBag.SearchMode ?? "contains").ToLowerInvariant();
    if (searchMode != "starts" && searchMode != "ends") searchMode = "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "name";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = (int?)ViewBag.PageSize ?? Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = Model.StartIndex;
    int end = Model.EndIndex;

    var n2 = System.Globalization.CultureInfo.InvariantCulture;

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلتر الكود من/إلى (لأكواد العملاء)
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    // فلترة التاريخ/الوقت (تاريخ إنشاء العميل)
    bool useDateRange = Model.UseDateRange;
    var fromDate = Model.FromDate;
    var toDate = Model.ToDate;

    var dateField = (string?)ViewBag.DateField ?? "created";   // للاستخدام فى اللينكات لو حبيت توسّع لاحقاً

    // فلاتر أعمدة بنمط Excel (من ViewBag أو من الطلب)
    string? filterCol_id = ViewBag.FilterCol_Id as string ?? Context.Request.Query["filterCol_id"].ToString();
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string ?? Context.Request.Query["filterCol_idExpr"].ToString();
    string? filterCol_name = ViewBag.FilterCol_Name as string ?? Context.Request.Query["filterCol_name"].ToString();
    string? filterCol_type = ViewBag.FilterCol_Type as string ?? Context.Request.Query["filterCol_type"].ToString();
    string? filterCol_phone = ViewBag.FilterCol_Phone as string ?? Context.Request.Query["filterCol_phone"].ToString();
    string? filterCol_Address = ViewBag.FilterCol_Address as string ?? Context.Request.Query["filterCol_Address"].ToString();
    string? filterCol_governorate = ViewBag.FilterCol_Governorate as string ?? Context.Request.Query["filterCol_governorate"].ToString();
    string? filterCol_district = ViewBag.FilterCol_District as string ?? Context.Request.Query["filterCol_district"].ToString();
    string? filterCol_area = ViewBag.FilterCol_Area as string ?? Context.Request.Query["filterCol_area"].ToString();
    string? filterCol_account = ViewBag.FilterCol_Account as string ?? Context.Request.Query["filterCol_account"].ToString();
    string? filterCol_PolicyId = ViewBag.FilterCol_PolicyId as string ?? Context.Request.Query["filterCol_PolicyId"].ToString();
    string? filterCol_credit = ViewBag.FilterCol_Credit as string ?? Context.Request.Query["filterCol_credit"].ToString();
    string? filterCol_isactive = ViewBag.FilterCol_IsActive as string ?? Context.Request.Query["filterCol_isactive"].ToString();
    string? filterCol_ordercontact = ViewBag.FilterCol_OrderContact as string ?? Context.Request.Query["filterCol_ordercontact"].ToString();
    string? filterCol_created = ViewBag.FilterCol_Created as string ?? Context.Request.Query["filterCol_created"].ToString();
    string? filterCol_updated = ViewBag.FilterCol_Updated as string ?? Context.Request.Query["filterCol_updated"].ToString();
    string? filterCol_quota = ViewBag.FilterCol_Quota as string ?? Context.Request.Query["filterCol_quota"].ToString();
    string? filterCol_taxid = ViewBag.FilterCol_TaxId as string ?? Context.Request.Query["filterCol_taxid"].ToString();
    string? filterCol_recordnumber = ViewBag.FilterCol_RecordNumber as string ?? Context.Request.Query["filterCol_recordnumber"].ToString();
    string? filterCol_licensenumber = ViewBag.FilterCol_LicenseNumber as string ?? Context.Request.Query["filterCol_licensenumber"].ToString();
    string? filterCol_segment = ViewBag.FilterCol_Segment as string ?? Context.Request.Query["filterCol_segment"].ToString();

    // دالة توليد لينكات الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        fromCode,
        toCode,
        dateField,
        filterCol_id, filterCol_idExpr, filterCol_name, filterCol_type, filterCol_phone, filterCol_Address,
        filterCol_governorate, filterCol_district, filterCol_area, filterCol_account, filterCol_PolicyId,
        filterCol_credit, filterCol_isactive, filterCol_ordercontact,
        filterCol_created, filterCol_updated, filterCol_quota,
        filterCol_taxid, filterCol_recordnumber, filterCol_licensenumber, filterCol_segment
    })!;

    var printUrl = Url.Action("Print", "Customers", new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        useDateRange,
        fromDate,
        toDate,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_idExpr,
        filterCol_name,
        filterCol_type,
        filterCol_phone,
        filterCol_Address,
        filterCol_governorate,
        filterCol_district,
        filterCol_area,
        filterCol_account,
        filterCol_PolicyId,
        filterCol_credit,
        filterCol_isactive,
        filterCol_ordercontact,
        filterCol_created,
        filterCol_updated,
        filterCol_quota,
        filterCol_taxid,
        filterCol_recordnumber,
        filterCol_licensenumber,
        filterCol_segment
    }) ?? "#";

    // دالة عمود قابل للفلترة (بنمط Excel — ترتيب + فلترة)
    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        var currentFilter = colKey == "id" ? (filterCol_id ?? filterCol_idExpr) : colKey == "name" ? filterCol_name :
            colKey == "type" ? filterCol_type : colKey == "phone" ? filterCol_phone : colKey == "Address" ? filterCol_Address :
            colKey == "governorate" ? filterCol_governorate : colKey == "district" ? filterCol_district : colKey == "area" ? filterCol_area :
            colKey == "account" ? filterCol_account : colKey == "PolicyId" ? filterCol_PolicyId : colKey == "credit" ? filterCol_credit :
            colKey == "isactive" ? filterCol_isactive : colKey == "ordercontact" ? filterCol_ordercontact :
            colKey == "created" ? filterCol_created : colKey == "updated" ? filterCol_updated : colKey == "quota" ? filterCol_quota :
            colKey == "taxid" ? filterCol_taxid : colKey == "recordnumber" ? filterCol_recordnumber :
            colKey == "licensenumber" ? filterCol_licensenumber : colKey == "segment" ? filterCol_segment : null;
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    @* ===== شريط الفلاتر الموحد ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" id="customersSearchForm" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في العملاء</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100" style="overflow-x:auto;">
                        <select name="searchMode" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:110px;min-width:100px">
                            <option value="starts"@Html.Raw(searchMode == "starts" ? " selected" : "")>يبدأ بـ</option>
                            <option value="contains"@Html.Raw(searchMode == "contains" || string.IsNullOrEmpty(searchMode) ? " selected" : "")>يحتوي</option>
                            <option value="ends"@Html.Raw(searchMode == "ends" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                        <input type="text" id="customersSearchText" class="form-control erp-filter-input flex-shrink-1" placeholder="نص أو رقم..." value="@search" style="min-width:100px;max-width:200px;width:180px;" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:160px;min-width:130px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>البحث في الكل</option>
                            <option value="name"@Html.Raw(searchBy == "name" ? " selected" : "")>الاسم</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>كود العميل</option>
                            <option value="phone"@Html.Raw(searchBy == "phone" ? " selected" : "")>الهاتف</option>
                            <option value="address"@Html.Raw(searchBy == "address" ? " selected" : "")>العنوان</option>
                            <option value="type"@Html.Raw(searchBy == "type" ? " selected" : "")>نوع حساب العميل</option>
                            <option value="account"@Html.Raw(searchBy == "account" ? " selected" : "")>الحساب المحاسبي</option>
                            <option value="active"@Html.Raw(searchBy == "active" ? " selected" : "")>نشط/موقوف</option>
                        </select>
                    </div>
                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-2 w-100">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="search" id="customersSearchApplied" value="@search" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    <input type="hidden" name="dateField" value="@dateField" />
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_type)) { <input type="hidden" name="filterCol_type" value="@filterCol_type" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_phone)) { <input type="hidden" name="filterCol_phone" value="@filterCol_phone" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_Address)) { <input type="hidden" name="filterCol_Address" value="@filterCol_Address" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_governorate)) { <input type="hidden" name="filterCol_governorate" value="@filterCol_governorate" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_district)) { <input type="hidden" name="filterCol_district" value="@filterCol_district" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_area)) { <input type="hidden" name="filterCol_area" value="@filterCol_area" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_account)) { <input type="hidden" name="filterCol_account" value="@filterCol_account" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_PolicyId)) { <input type="hidden" name="filterCol_PolicyId" value="@filterCol_PolicyId" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_credit)) { <input type="hidden" name="filterCol_credit" value="@filterCol_credit" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_isactive)) { <input type="hidden" name="filterCol_isactive" value="@filterCol_isactive" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_ordercontact)) { <input type="hidden" name="filterCol_ordercontact" value="@filterCol_ordercontact" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_quota)) { <input type="hidden" name="filterCol_quota" value="@filterCol_quota" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_taxid)) { <input type="hidden" name="filterCol_taxid" value="@filterCol_taxid" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_recordnumber)) { <input type="hidden" name="filterCol_recordnumber" value="@filterCol_recordnumber" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_licensenumber)) { <input type="hidden" name="filterCol_licensenumber" value="@filterCol_licensenumber" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_segment)) { <input type="hidden" name="filterCol_segment" value="@filterCol_segment" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر الكود --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر الكود</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم (صفّان مثل المناطق) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    @* الصف 1: إضافة + فلاتر + اختيار الأعمدة + طباعة *@
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <a class="btn btn-erp btn-erp-success btn-erp-sm open-tab"
                           asp-action="Create"
                           data-tab-id="customer-create-tab"
                           data-tab-title="إضافة عميل">إضافة عميل</a>
                        @if (ViewBag.CanEdit == true)
                        {
                            <a class="btn btn-erp btn-erp-secondary btn-erp-sm open-same-tab"
                               href="@Url.Action("CreditLimitAdjustment", "Customers", new { frame = 1 })"
                               data-tab-id="customers-credit-limit-adjustment"
                               data-tab-title="تعديل الحد الائتماني"
                               data-url="@Url.Action("CreditLimitAdjustment", "Customers", new { frame = 1 })">تعديل الحد الائتماني</a>
                        }
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalCustomers">اختيار الأعمدة</button>
                        <button type="button" id="btnPrintCustomers" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                    </div>
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center" dir="rtl">
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnBulkDelete">حذف المحدد</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف الجميع</button></li>
                            </ul>
                        </div>
                        @if (ViewBag.CanShowEngagement == true)
                        {
                            <button type="button" id="btnCustomerEngagement" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="انقر على صف في الجدول (اختيار السطر) لفتح حجم التعامل">حجم التعامل</button>
                        }
                        @if (ViewBag.CanEdit == true)
                        {
                            <button type="button" id="btnEditCustomer" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="تعديل العميل المحدد بالنقر على الصف">تعديل</button>
                        }
                        <form method="get" asp-action="Export" asp-controller="Customers" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="searchMode" value="@searchMode" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_type)) { <input type="hidden" name="filterCol_type" value="@filterCol_type" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_phone)) { <input type="hidden" name="filterCol_phone" value="@filterCol_phone" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_Address)) { <input type="hidden" name="filterCol_Address" value="@filterCol_Address" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_governorate)) { <input type="hidden" name="filterCol_governorate" value="@filterCol_governorate" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_district)) { <input type="hidden" name="filterCol_district" value="@filterCol_district" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_area)) { <input type="hidden" name="filterCol_area" value="@filterCol_area" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_account)) { <input type="hidden" name="filterCol_account" value="@filterCol_account" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_PolicyId)) { <input type="hidden" name="filterCol_PolicyId" value="@filterCol_PolicyId" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_credit)) { <input type="hidden" name="filterCol_credit" value="@filterCol_credit" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_isactive)) { <input type="hidden" name="filterCol_isactive" value="@filterCol_isactive" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_ordercontact)) { <input type="hidden" name="filterCol_ordercontact" value="@filterCol_ordercontact" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_quota)) { <input type="hidden" name="filterCol_quota" value="@filterCol_quota" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_taxid)) { <input type="hidden" name="filterCol_taxid" value="@filterCol_taxid" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_recordnumber)) { <input type="hidden" name="filterCol_recordnumber" value="@filterCol_recordnumber" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_licensenumber)) { <input type="hidden" name="filterCol_licensenumber" value="@filterCol_licensenumber" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_segment)) { <input type="hidden" name="filterCol_segment" value="@filterCol_segment" /> }
                            <input type="hidden" name="visibleCols" value="" />
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                    <form id="formBulkDelete" asp-action="BulkDelete" asp-controller="Customers" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="selectedIds" id="bulkDeleteIdsInput" />
                    </form>
                    <form id="formDeleteAll" asp-action="DeleteAll" asp-controller="Customers" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>

        </div>
    </div>

    @* كارت إجمالي العدد (بعد الفلترة) *@
    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row mt-2" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي العدد</div>
                    <div class="h4 mb-0 text-primary fw-bold">@total.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
    </div>

    @* ===== جدول العملاء (هو اللى يتطبع) ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area erp-list-table-after-summary">
        <table id="customersTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    @* اختيار الصف *@
                    <th class="text-center no-print"
                        style="width:40px;"
                        data-col="select"
                        data-col-fixed="true">
                        <input type="checkbox" id="selectAll" class="form-check-input" />
                    </th>

                    <th style="width:100px;" data-col="id">@filterableCol("id", "id", "كود العميل")</th>
                    <th data-col="name">@filterableCol("name", "name", "اسم العميل")</th>
                    <th data-col="type">@filterableCol("type", "type", "نوع حساب العميل")</th>
                    <th data-col="phone">@filterableCol("phone", "name", "هاتف")</th>
                    <th data-col="Address">@filterableCol("Address", "name", "العنوان")</th>

                    <th data-col="governorate">@filterableCol("governorate", "governorate", "المحافظة")</th>
                    <th data-col="district">@filterableCol("district", "district", "الحي")</th>
                    <th data-col="area">@filterableCol("area", "area", "المنطقة")</th>

                    <th data-col="taxid">@filterableCol("taxid", "taxid", "الرقم الضريبي/القومي")</th>
                    <th data-col="recordnumber">@filterableCol("recordnumber", "recordnumber", "رقم السجل")</th>
                    <th data-col="licensenumber">@filterableCol("licensenumber", "licensenumber", "رقم الرخصة")</th>
                    <th data-col="segment">@filterableCol("segment", "segment", "الشريحة")</th>

                    <th data-col="account">@filterableCol("account", "account", "الحساب المحاسبي")</th>
                    <th data-col="PolicyId">@filterableCol("PolicyId", "name", "سياسة العميل")</th>
                    <th data-col="credit">@filterableCol("credit", "name", "الحد الائتماني")</th>
                    <th data-col="isactive">@filterableCol("isactive", "isactive", "الحالة")</th>
                    <th data-col="ordercontact">@filterableCol("ordercontact", "name", "مسئول الطلب")</th>
                    <th style="width:140px;" data-col="created">@filterableCol("created", "created", "تاريخ الإنشاء")</th>
                    <th style="width:140px;" data-col="updated">@filterableCol("updated", "updated", "آخر تعديل")</th>
                    <th data-col="quota">@filterableCol("quota", "name", "الكوتة")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="21" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var c in Model.Items)
                    {
                        var editUrlCust = Url.Action("Edit", "Customers", new { id = c.CustomerId }) + "?frame=1";
                        var showEngUrl = ViewBag.CanShowEngagement == true
                            ? Url.Action("Show", "Customers", new { id = c.CustomerId, frame = 1 })
                            : "";
                        <tr class="erp-list-selectable-row"
                            data-customer-id="@c.CustomerId"
                            data-edit-url="@(ViewBag.CanEdit == true ? editUrlCust : "")"
                            data-edit-tab-title="تعديل بيانات العميل"
                            data-movement-url="@showEngUrl">
                            <td class="text-center no-print" data-col="select" data-col-fixed="true">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@c.CustomerId" />
                            </td>

                            <td data-col="id">@c.CustomerId</td>
                            <td data-col="name">@c.CustomerName</td>
                            <td data-col="type">@{
                                var _typeNames = ViewBag.PartyCategoryDisplayNames as IReadOnlyDictionary<string, string>;
                                var _typeText = _typeNames != null && !string.IsNullOrEmpty(c.PartyCategory) && _typeNames.TryGetValue(c.PartyCategory, out var _t) ? _t : (c.PartyCategory ?? "");
                            }@_typeText</td>
                            <td data-col="phone">@(c.Phone1 ?? c.Phone2 ?? c.Whatsapp)</td>
                            <td data-col="Address">@c.Address</td>
                            <td data-col="governorate">
                                @* المحافظة *@
                                @(c.Governorate?.GovernorateName ?? "")
                            </td>

                            <td data-col="district">
                                @* الحي / المركز *@
                                @(c.District?.DistrictName ?? "")
                            </td>

                            <td data-col="area">
                                @* المنطقة: من جدول المناطق (Area) أو النص المستورد (RegionName) *@
                                @(c.RegionName ?? c.Area?.AreaName ?? "")
                            </td>

                            <td data-col="taxid">@(c.TaxIdOrNationalId ?? "")</td>
                            <td data-col="recordnumber">@(c.RecordNumber ?? "")</td>
                            <td data-col="licensenumber">@(c.LicenseNumber ?? "")</td>
                            <td data-col="segment">@(c.Segment ?? "")</td>

                            <td data-col="account">
                                @if (c.Account != null)
                                {
                                    @($"{c.Account.AccountCode} — {c.Account.AccountName}")
                                }</td>
                    <td data-col="PolicyId">@c.PolicyId</td>
                    <td data-col="credit" class="text-end">
                        @c.CreditLimit.ToString("0.00")
                    </td>
                    <td data-col="isactive">@((c.IsActive) ? "نشط" : "موقوف")</td>
                    <td data-col="ordercontact">@c.OrderContactName</td>
                    <td data-col="created">@c.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td data-col="updated">@c.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td data-col="quota">
                        @(c.IsQuotaMultiplierEnabled
                                                ? $"مفعّلة ×{c.QuotaMultiplier}"
                                                : "غير مفعّلة")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @* ===== الشريط السفلى: عرض + حجم الصفحة — نفس المحافظات/المناطق ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print w-100" dir="rtl">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="searchMode" value="@searchMode" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
            }
            @if (toDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }
            <input type="hidden" name="filterCol_id" value="@filterCol_id" />
            <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" />
            <input type="hidden" name="filterCol_name" value="@filterCol_name" />
            <input type="hidden" name="filterCol_type" value="@filterCol_type" />
            <input type="hidden" name="filterCol_phone" value="@filterCol_phone" />
            <input type="hidden" name="filterCol_Address" value="@filterCol_Address" />
            <input type="hidden" name="filterCol_governorate" value="@filterCol_governorate" />
            <input type="hidden" name="filterCol_district" value="@filterCol_district" />
            <input type="hidden" name="filterCol_area" value="@filterCol_area" />
            <input type="hidden" name="filterCol_account" value="@filterCol_account" />
            <input type="hidden" name="filterCol_PolicyId" value="@filterCol_PolicyId" />
            <input type="hidden" name="filterCol_credit" value="@filterCol_credit" />
            <input type="hidden" name="filterCol_isactive" value="@filterCol_isactive" />
            <input type="hidden" name="filterCol_ordercontact" value="@filterCol_ordercontact" />
            <input type="hidden" name="filterCol_created" value="@filterCol_created" />
            <input type="hidden" name="filterCol_updated" value="@filterCol_updated" />
            <input type="hidden" name="filterCol_quota" value="@filterCol_quota" />
            <input type="hidden" name="filterCol_taxid" value="@filterCol_taxid" />
            <input type="hidden" name="filterCol_recordnumber" value="@filterCol_recordnumber" />
            <input type="hidden" name="filterCol_licensenumber" value="@filterCol_licensenumber" />
            <input type="hidden" name="filterCol_segment" value="@filterCol_segment" />

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
            </select>
        </form>
        <script>
            (function () {
                var sel = document.querySelector('form select[name="pageSize"]');
                if (!sel) return;
                var params = new URLSearchParams(window.location.search);
                var all = params.getAll("pageSize");
                if (all.length > 0) sel.value = all[all.length - 1];
            })();
        </script>
    </div>

    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

