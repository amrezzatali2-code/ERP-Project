@section Scripts {
    <script src="~/js/erp-list-print.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        (function () {
            const searchForm = document.getElementById("customersSearchForm");
            const searchText = document.getElementById("customersSearchText");
            const appliedSearch = document.getElementById("customersSearchApplied");
            if (!searchForm || !searchText || !appliedSearch) return;

            searchForm.addEventListener("submit", function () {
                const typedValue = (searchText.value || "").trim();
                if (typedValue) {
                    appliedSearch.value = typedValue;
                }
            });
        })();

        // جعل الشريط الأفقي يفتح من جهة اليمين (بداية الجدول في RTL)
        (function () {
            var table = document.getElementById("customersTable");
            if (!table) return;
            var wrapper = table.closest(".erp-table-wrapper");
            if (!wrapper) return;
            wrapper.scrollLeft = wrapper.scrollWidth - wrapper.clientWidth;
        })();

        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanel',
            tableId: 'customersTable',
            wrapperId: null,
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "Customers")',
            defaultSort: 'name',
            defaultDir: 'asc',
            numericColumns: ['id']
        });

        // طباعة: صفحة Print + printCols (انظر ~/js/erp-list-print.js لتعميمها على قوائم أخرى)
        (function () {
            var printUrlBase = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(printUrl));
            document.getElementById("btnPrintCustomers")?.addEventListener("click", function () {
                if (!printUrlBase || printUrlBase === "#") return;
                if (window.ERP && typeof ERP.openListPrint === "function")
                    ERP.openListPrint(printUrlBase, { tableId: "customersTable", storageKey: "customers-columns-visibility" });
                else
                    window.open(printUrlBase, "_blank", "noopener,noreferrer");
            });
        })();

        // تحديد الكل + الحذف الجماعي + اختيار السطر (لون ثابت) + تعديل / حجم التعامل (تشيك واحد أو نقر صف فقط)
        (function () {
            const table = document.getElementById("customersTable");
            if (!table) return;
            const tbody = table.querySelector("tbody");
            if (!tbody) return;

            const selectAll = document.getElementById("selectAll");
            const bulkBtn = document.getElementById("btnBulkDelete");
            const bulkForm = document.getElementById("formBulkDelete");
            const deleteAllBtn = document.getElementById("btnDeleteAll");
            const formDeleteAll = document.getElementById("formDeleteAll");
            const bulkDeleteIdsInput = document.getElementById("bulkDeleteIdsInput");
            const eng = document.getElementById("btnCustomerEngagement");
            const ed = document.getElementById("btnEditCustomer");

            /** آخر صف اختير بالنقر (بدون الاعتماد على تشيكات متعددة للحذف) */
            var rowClickSelectedTr = null;

            function getRowCheckboxes() {
                return Array.from(table.querySelectorAll("tbody .row-select"));
            }

            function countChecked() {
                return table.querySelectorAll("tbody input.row-select:checked").length;
            }

            function primaryRowForToolbar() {
                var n = countChecked();
                if (n > 1) return null;
                if (n === 1) {
                    var cb = table.querySelector("tbody input.row-select:checked");
                    return cb ? cb.closest("tr.erp-list-selectable-row") : null;
                }
                if (rowClickSelectedTr && table.contains(rowClickSelectedTr)) return rowClickSelectedTr;
                return null;
            }

            function refreshVisualAndToolbar() {
                var n = countChecked();
                table.querySelectorAll("tbody tr.erp-list-selectable-row").forEach(function (r) {
                    r.classList.remove("selected");
                });
                var highlight = null;
                if (n === 1) {
                    var cb = table.querySelector("tbody input.row-select:checked");
                    highlight = cb ? cb.closest("tr.erp-list-selectable-row") : null;
                } else if (n === 0 && rowClickSelectedTr && table.contains(rowClickSelectedTr)) {
                    highlight = rowClickSelectedTr;
                }
                if (highlight) highlight.classList.add("selected");

                var tr = primaryRowForToolbar();
                var mov = tr ? (tr.getAttribute("data-movement-url") || "").trim() : "";
                var eurl = tr ? (tr.getAttribute("data-edit-url") || "").trim() : "";
                if (eng) eng.disabled = !mov;
                if (ed) ed.disabled = !eurl;
            }

            function onBulkCheckboxChanged() {
                var n = countChecked();
                if (n > 1) rowClickSelectedTr = null;
                else if (n === 1) {
                    var cb = table.querySelector("tbody input.row-select:checked");
                    rowClickSelectedTr = cb ? cb.closest("tr.erp-list-selectable-row") : null;
                }
                refreshVisualAndToolbar();
            }

            function openInTab(tabId, url, title) {
                if (!url) return;
                var inFrame = (window.top !== window);
                try {
                    if (inFrame) {
                        window.top.postMessage({ type: "erp-open-tab", tabId: tabId, url: url, title: title || "تبويب" }, "*");
                        return;
                    }
                    if (window.erpTabs && typeof window.erpTabs.openTab === "function") {
                        window.erpTabs.openTab(tabId, url, title || "تبويب");
                    } else {
                        window.location.href = url;
                    }
                } catch (e) {
                    if (!inFrame) window.location.href = url;
                }
            }

            tbody.addEventListener("click", function (e) {
                if (e.target.closest("input.row-select")) return;
                var tr = e.target.closest("tr.erp-list-selectable-row");
                if (!tr) return;
                if (e.target.closest("a, button, textarea, select, label")) return;
                rowClickSelectedTr = tr;
                refreshVisualAndToolbar();
            });

            selectAll?.addEventListener("change", function () {
                var checked = this.checked;
                getRowCheckboxes().forEach(function (cb) { cb.checked = checked; });
                onBulkCheckboxChanged();
            });

            table.addEventListener("change", function (e) {
                var target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && selectAll) selectAll.checked = false;
                    onBulkCheckboxChanged();
                }
            });

            if (ed) {
                ed.addEventListener("click", function (e) {
                    e.preventDefault();
                    var tr = primaryRowForToolbar();
                    if (!tr) return;
                    var url = (tr.getAttribute("data-edit-url") || "").trim();
                    if (!url) return;
                    var id = tr.getAttribute("data-customer-id") || "";
                    var title = (tr.getAttribute("data-edit-tab-title") || "").trim() || "تعديل";
                    openInTab("customer-edit-tab", url, title);
                });
            }
            if (eng) {
                eng.addEventListener("click", function (e) {
                    e.preventDefault();
                    var tr = primaryRowForToolbar();
                    if (!tr) return;
                    var url = (tr.getAttribute("data-movement-url") || "").trim();
                    if (!url) return;
                    var id = tr.getAttribute("data-customer-id") || "";
                    openInTab("list-movement-" + id, url, "حجم تعامل عميل");
                });
            }

            bulkBtn?.addEventListener("click", async function () {
                var checks = getRowCheckboxes().filter(function (cb) { return cb.checked; });
                if (checks.length === 0) {
                    if (window.ERP && typeof ERP.showAlertModal === "function") {
                        await ERP.showAlertModal({
                            title: "تنبيه",
                            message: "من فضلك اختر على الأقل عميل واحد للحذف.",
                            okText: "حسناً"
                        });
                    } else {
                        alert("من فضلك اختر على الأقل عميل واحد للحذف.");
                    }
                    return;
                }
                var confirmedBulkDelete = false;
                if (window.ERP && typeof ERP.showConfirmModal === "function") {
                    confirmedBulkDelete = await ERP.showConfirmModal({
                        title: "حذف العملاء المحددين",
                        message: "هل أنت متأكد من حذف العملاء المحددين؟",
                        confirmText: "حذف",
                        cancelText: "إلغاء"
                    });
                } else {
                    confirmedBulkDelete = confirm("هل أنت متأكد من حذف العملاء المحددين؟");
                }
                if (!confirmedBulkDelete) return;
                if (bulkDeleteIdsInput) bulkDeleteIdsInput.value = checks.map(function (cb) { return cb.value; }).join(",");
                bulkForm?.submit();
            });

            deleteAllBtn?.addEventListener("click", async function () {
                var confirmedDeleteAll = false;
                if (window.ERP && typeof ERP.showConfirmModal === "function") {
                    confirmedDeleteAll = await ERP.showConfirmModal({
                        title: "حذف جميع العملاء",
                        message: "تحذير: سيتم حذف جميع العملاء. هل أنت متأكد؟",
                        confirmText: "حذف الجميع",
                        cancelText: "إلغاء"
                    });
                } else {
                    confirmedDeleteAll = confirm("تحذير: سيتم حذف جميع العملاء. هل أنت متأكد؟");
                }
                if (!confirmedDeleteAll) return;
                formDeleteAll?.submit();
            });

            refreshVisualAndToolbar();
        })();

        // =========================
        // اختيار الأعمدة + حفظها فى localStorage
        // =========================
        (function () {
            const table = document.getElementById("customersTable");
            if (!table) return;

            const storageKey = "customers-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => {
                    const titleEl = th.querySelector(".erp-col-title");
                    const title = (titleEl ? titleEl.textContent : th.innerText).trim();
                    return {
                        key: th.getAttribute("data-col"),
                        title: title || th.getAttribute("data-col") || ""
                    };
                });

            if (columns.length === 0) return;

            // قراءة الأعمدة المخفية من localStorage
            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            // بناء قائمة الأعمدة داخل المودال
            const listContainer = document.getElementById("columnsListCustomers");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsCustomers")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalCustomers");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });

            function getVisibleColsInTableOrder() {
                // نفس ترتيب رؤوس الجدول (بدون الأعمدة الثابتة مثل select)
                const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
                const ordered = headerCells
                    .filter(th => !th.hasAttribute("data-col-fixed"))
                    .map(th => th.getAttribute("data-col"))
                    .filter(Boolean);

                // hidden من localStorage
                let hiddenCols = [];
                try {
                    const saved = localStorage.getItem(storageKey);
                    if (saved) hiddenCols = JSON.parse(saved) || [];
                } catch { hiddenCols = []; }

                const hiddenSet = new Set(hiddenCols.map(x => String(x)));
                return ordered.filter(k => !hiddenSet.has(String(k)));
            }

            // قبل التصدير: أرسل الأعمدة الظاهرة فقط
            document.querySelectorAll("form.erp-export-form").forEach(function (form) {
                form.addEventListener("submit", function () {
                    const inp = form.querySelector("input[name='visibleCols']");
                    if (!inp) return;
                    inp.value = getVisibleColsInTableOrder().join(",");
                });
            });
        })();

        // =========================
        // فلتر الكود من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");   // نرجع لأول صفحة
                const psSel = document.querySelector('form select[name="pageSize"]');
                while (url.searchParams.has("pageSize")) url.searchParams.delete("pageSize");
                if (psSel) url.searchParams.set("pageSize", psSel.value);
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
