@section Scripts {
    <script>
        (function () {

            // ================================
            // 0) تحميل بيانات العملاء من السيرفر مرة واحدة (بدلاً من SearchCustomers)
            // ================================
            // متغير: مصفوفة بها كل العملاء (كود + اسم + تليفون)
            var customersData = @Html.Raw(customersJson);

            // ================================
            // 1) أوتوكومبليت لاختيار العميل
            // ================================
            var input    = document.getElementById('partySearchInput');   // متغير: تكست بوكس البحث
            var hiddenId = document.getElementById('partySearchId');      // متغير: كود العميل المخفى
            var list     = document.getElementById('partySuggestions');   // متغير: قائمة النتائج (buttons)
            var form     = document.getElementById('customerSearchForm'); // متغير: فورم البحث

            var activeIndex = -1;   // متغير: العنصر المحدد حالياً فى القائمة
            var lastTerm    = "";   // متغير: آخر نص تم البحث عنه (للاستخدام لو حبيت فيما بعد)

            if (input && hiddenId && list && form) {

                // عند الكتابة فى التكست بوكس
                input.addEventListener('input', function () {
                    // متغير: النص المكتوب
                    var term = input.value.trim();
                    // نلغى أى اختيار قديم
                    hiddenId.value = "";
                    activeIndex = -1;

                    // لو الحروف قليلة جداً → نخفي القائمة
                    if (term.length < 1) {
                        list.style.display = 'none';
                        list.innerHTML = '';
                        return;
                    }

                    // متغير: نفس الكلمة بحروف صغيرة للمقارنة
                    var termLower = term.toLowerCase();

                    // فلترة قائمة العملاء فى الميمورى (بدون أى Fetch)
                    // نبحث بالكود أو الاسم
                    var results = customersData.filter(function (item) {
                        // مقارنة الكود كـ نص
                        var codeMatch = item.code && item.code.indexOf(term) !== -1;
                        // مقارنة الاسم كـ حروف صغيرة
                        var nameMatch = item.name && item.name.toLowerCase().indexOf(termLower) !== -1;
                        return codeMatch || nameMatch;
                    });

                    list.innerHTML = '';

                    if (!results || results.length === 0) {
                        list.style.display = 'none';
                        return;
                    }

                    // نعرض أول 30 نتيجة فقط علشان الأداء
                    results.slice(0, 30).forEach(function (item, index) {
                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'list-group-item list-group-item-action';
                        btn.dataset.id = item.id;   // متغير: كود العميل
                        // نص الزر: الكود — الاسم (التليفون اختيارى)
                        btn.textContent = item.code + ' — ' + item.name +
                            (item.phone ? ' (' + item.phone + ')' : '');

                        // عند الضغط على أى اختيار
                        btn.addEventListener('click', function () {
                            hiddenId.value = item.id;                         // حفظ الكود فى الهيدن
                            input.value    = item.code + ' — ' + item.name;  // عرض الكود + الاسم فى البوكس
                            list.style.display = 'none';                     // إخفاء القائمة
                        });

                        list.appendChild(btn);
                    });

                    list.style.display = 'block';
                });

                // الأسهم + Enter داخل قائمة الاقتراحات
                input.addEventListener('keydown', function (e) {
                    var items = list.querySelectorAll('button');
                    if (list.style.display !== 'block' || items.length === 0) return;

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        activeIndex = (activeIndex + 1) % items.length;
                        setActive(items, activeIndex);
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        activeIndex = (activeIndex - 1 + items.length) % items.length;
                        setActive(items, activeIndex);
                    } else if (e.key === 'Enter') {
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            e.preventDefault();
                            items[activeIndex].click();   // نختار العنصر المحدد
                        }
                    } else if (e.key === 'Escape') {
                        list.style.display = 'none';
                    }
                });

                // دالة: تمييز العنصر النشط فى القائمة + سحب السكرول إليه
                function setActive(items, index) {
                    items.forEach(function (el) { el.classList.remove('active'); });
                    if (index >= 0 && index < items.length) {
                        var el = items[index];
                        el.classList.add('active');
                        el.scrollIntoView({ block: 'nearest' });
                    }
                }

                // إخفاء القائمة عند الضغط خارجها
                document.addEventListener('click', function (e) {
                    if (!list.contains(e.target) && e.target !== input) {
                        list.style.display = 'none';
                    }
                });

                // تأمين الفورم: لازم يكون فيه ID قبل الإرسال
                form.addEventListener('submit', function (e) {
                    if (!hiddenId.value) {
                        var txt = input.value.trim();

                        // لو المستخدم كتب كود رقمى بس → نعتبره كود عميل مباشرة
                        if (/^\d+$/.test(txt)) {
                            hiddenId.value = txt;
                        }
                    }

                    // لو بعد كل ده مفيش كود → نمنع الإرسال
                    if (!hiddenId.value) {
                        e.preventDefault();
                        alert('من فضلك اختر عميل من القائمة أو أدخل كوده الرقمى ثم اضغط عرض.');
                    }
                });
            }

            // ================================
            // 2) أزرار تفعيل تابات الجداول
            // ================================
            var tabButtons = document.querySelectorAll('.js-open-movement-tab');
            tabButtons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var targetSelector = btn.getAttribute('data-target');
                    if (!targetSelector) return;

                    var trigger = document.querySelector(
                        '#customerMovementTabs button[data-bs-target="' + targetSelector + '"]'
                    );
                    if (trigger && window.bootstrap && bootstrap.Tab) {
                        var tab = new bootstrap.Tab(trigger);
                        tab.show();

                        var card = document.getElementById('customerMovementCard');
                        if (card) {
                            card.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        }
                    }
                });
            });

            // ================================
            // 3) زر الرجوع لقائمة العملاء مع نظام التابات
            // ================================
            var backLinks = document.querySelectorAll('.js-back-to-customers');
            backLinks.forEach(function (lnk) {
                lnk.addEventListener('click', function (e) {
                    try {
                        if (window.parent && window.parent !== window && window.parent.erpTabs) {
                            e.preventDefault();

                            var customersUrl = '@Url.Action("Index", "Customers")';
                            // فتح تاب قائمة العملاء
                            window.parent.erpTabs.openTab('customers', customersUrl, 'قائمة العملاء');
                            // غلق تاب حجم التعامل الحالى
                            window.parent.erpTabs.closeTab('customer-engagement');
                        }
                    } catch (err) {
                        // لو حصل خطأ نسيب اللينك يشتغل عادى
                    }
                });
            });

        })();
    </script>
}
