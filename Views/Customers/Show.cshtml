@section Scripts {
    <script>
        (function () {
            var customersData = @Html.Raw(customersJson);
            var input = document.getElementById('partySearchInput');
            var hiddenId = document.getElementById('partySearchId');
            var list = document.getElementById('partySuggestions');
            var form = document.getElementById('customerSearchForm');
            var activeIndex = -1;

            if (input && hiddenId && list && form) {
                input.addEventListener('input', function () {
                    var term = input.value.trim();
                    hiddenId.value = "";
                    activeIndex = -1;

                    if (term.length < 1) {
                        list.style.display = 'none';
                        list.innerHTML = '';
                        return;
                    }

                    var termLower = term.toLowerCase();
                    var results = customersData.filter(function (item) {
                        var codeMatch = item.code && item.code.indexOf(term) !== -1;
                        var nameMatch = item.name && item.name.toLowerCase().indexOf(termLower) !== -1;
                        return codeMatch || nameMatch;
                    });

                    list.innerHTML = '';

                    if (!results || results.length === 0) {
                        list.style.display = 'none';
                        return;
                    }

                    results.slice(0, 30).forEach(function (item) {
                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'list-group-item list-group-item-action';
                        btn.dataset.id = item.id;
                        btn.textContent = item.code + ' — ' + item.name + (item.phone ? ' (' + item.phone + ')' : '');

                        btn.addEventListener('click', function () {
                            hiddenId.value = item.id;
                            input.value = item.code + ' — ' + item.name;
                            list.style.display = 'none';
                        });

                        list.appendChild(btn);
                    });

                    list.style.display = 'block';
                });

                input.addEventListener('keydown', function (e) {
                    var items = list.querySelectorAll('button');
                    if (list.style.display !== 'block' || items.length === 0) return;

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        activeIndex = (activeIndex + 1) % items.length;
                        items.forEach(function (el) { el.classList.remove('active'); });
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            items[activeIndex].classList.add('active');
                            items[activeIndex].scrollIntoView({ block: 'nearest' });
                        }
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        activeIndex = (activeIndex - 1 + items.length) % items.length;
                        items.forEach(function (el) { el.classList.remove('active'); });
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            items[activeIndex].classList.add('active');
                            items[activeIndex].scrollIntoView({ block: 'nearest' });
                        }
                    } else if (e.key === 'Enter') {
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            e.preventDefault();
                            items[activeIndex].click();
                        }
                    } else if (e.key === 'Escape') {
                        list.style.display = 'none';
                    }
                });

                document.addEventListener('click', function (e) {
                    if (!list.contains(e.target) && e.target !== input) {
                        list.style.display = 'none';
                    }
                });

                form.addEventListener('submit', function (e) {
                    if (!hiddenId.value) {
                        var txt = input.value.trim();
                        
                        // ✅ محاولة 1: إذا كان كود رقمي صرف
                        if (/^\d+$/.test(txt)) {
                            hiddenId.value = txt;
                        }
                        // ✅ محاولة 2: البحث في customersData للعثور على تطابق تام
                        else if (txt.length > 0) {
                            var exactMatch = customersData.find(function(item) {
                                return item.name.toLowerCase() === txt.toLowerCase() || 
                                       item.code === txt || 
                                       (item.code + ' — ' + item.name) === txt;
                            });
                            if (exactMatch) {
                                hiddenId.value = exactMatch.id.toString();
                                input.value = exactMatch.code + ' — ' + exactMatch.name;
                            }
                            // ✅ محاولة 3: إذا كان هناك تطابق واحد فقط في القائمة
                            else {
                                var termLower = txt.toLowerCase();
                                var matches = customersData.filter(function (item) {
                                    var codeMatch = item.code && item.code.indexOf(txt) !== -1;
                                    var nameMatch = item.name && item.name.toLowerCase().indexOf(termLower) !== -1;
                                    return codeMatch || nameMatch;
                                });
                                if (matches.length === 1) {
                                    hiddenId.value = matches[0].id.toString();
                                    input.value = matches[0].code + ' — ' + matches[0].name;
                                }
                            }
                        }
                    }

                    if (!hiddenId.value) {
                        e.preventDefault();
                        alert('من فضلك اختر عميل من القائمة أو أدخل كوده الرقمى ثم اضغط عرض.');
                    }
                });
            }

            var tabButtons = document.querySelectorAll('.js-open-movement-tab');
            tabButtons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var targetSelector = btn.getAttribute('data-target');
                    if (!targetSelector) return;

                    var trigger = document.querySelector('#customerMovementTabs button[data-bs-target="' + targetSelector + '"]');
                    if (trigger && window.bootstrap && bootstrap.Tab) {
                        var tab = new bootstrap.Tab(trigger);
                        tab.show();
                    }
                });
            });

            // =========================
            // ✅ دالة تحديث للصفحة (يتم استدعاؤها من زر التحديث في الناف بار)
            // =========================
            window.__ERP_REFRESH__ = function () {
                var form = document.getElementById('customerSearchForm');
                if (form) {
                    // التحقق من وجود بيانات في الـ form قبل الـ submit
                    var hiddenId = document.getElementById('partySearchId');
                    if (hiddenId && hiddenId.value) {
                        form.submit();
                    } else {
                        // لو مفيش عميل محدد، نعيد تحميل الصفحة فقط
                        window.location.reload();
                    }
                } else {
                    // لو مفيش form، نعيد تحميل الصفحة
                    window.location.reload();
                }
            };
        })();
    </script>
}
