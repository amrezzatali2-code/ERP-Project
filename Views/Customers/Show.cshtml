                                        </tr>
                                    }
                                    else
                                    {
                                        <tr><td colspan="5" class="text-center text-muted py-2"><small>لا توجد إشعارات إضافة للعميل في الفترة.</small></td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="tab-pane fade h-100" id="tab-settlements" role="tabpanel" style="display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                        <div class="table-responsive w-100" style="flex: 1; overflow-y: auto; min-height: 0;">
                            <table class="table table-sm table-striped table-compact mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>التاريخ</th>
                                        <th>نوع التسوية</th>
                                        <th class="text-end">مدين</th>
                                        <th class="text-end">دائن</th>
                                        <th>ملاحظات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td colspan="5" class="text-center text-muted py-2"><small>لم يتم ربط التسويات بعد.</small></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            var customersData = @Html.Raw(customersJson);
            var input = document.getElementById('partySearchInput');
            var hiddenId = document.getElementById('partySearchId');
            var dropdownWrap = document.getElementById('partyDropdownWrap');
            var dropdownList = document.getElementById('partyDropdownList');
            var dropdownArrow = document.getElementById('partyDropdownArrow');
            var form = document.getElementById('customerSearchForm');

            var activeIndex = -1;
            var selectableCustomers = [];
            var isSelectingCustomer = false; // لمنع فتح الدروب أثناء/بعد اختيار العنصر مباشرة
            var PARTY_LIST_MAX = 80;

            var partySelectionTs = 0; // لتصحيح حالة ضياع الفوكس بعد الاختيار مباشرة

            function normalizePartyText(txt) {
                return (txt || '')
                    .trim()
                    .toLowerCase()
                    .replace(/^[اأإآ]/, '')
                    .replace(/\s+/g, ' ');
            }
            // تطبيع الاسم للمقارنة (توحيد ى/ي والمسافات) لئلا يفشل التطابق
            function normalizeNameForMatch(txt) {
                return (txt || '').trim().toLowerCase().replace(/\s+/g, ' ').replace(/ى/g, 'ي');
            }

            function closePartyDropdown() {
                if (dropdownList) {
                    dropdownList.setAttribute('data-open', 'false');
                    dropdownList.innerHTML = '';
                }
                activeIndex = -1;
                selectableCustomers = [];
            }

            function positionPartyDropdownList() {
                if (!dropdownList || !dropdownWrap) return;
                if (dropdownList.getAttribute('data-open') !== 'true') return;
                var r = dropdownWrap.getBoundingClientRect();
                dropdownList.style.width = r.width + 'px';
                dropdownList.style.top = r.bottom + 'px';
                dropdownList.style.left = r.left + 'px';
            }

            function setPartyDropdownHighlight(idx) {
                if (!dropdownList) return;
                if (idx < 0 || idx >= selectableCustomers.length) return;

                var children = dropdownList.querySelectorAll('.product-dropdown-item');
                children.forEach(function (el, i) {
                    el.classList.toggle('product-dropdown-item-active', i === idx);
                });
                activeIndex = idx;

                try { children[idx]?.scrollIntoView({ block: 'nearest', behavior: 'smooth' }); } catch { }
            }

            function getFilteredCustomers(search) {
                var rawTrim = (search || '').trim();
                var term = normalizePartyText(search);
                if (!term) return customersData.slice(0, PARTY_LIST_MAX);

                var words = term.split(/\s+/).filter(Boolean);
                var out = [];
                for (var i = 0; i < customersData.length && out.length < PARTY_LIST_MAX; i++) {
                    var item = customersData[i];
                    if (!item) continue;
                    var code = (item.code || '').toString();
                    var name = normalizePartyText(item.name || '');
                    if (!name && !code) continue;

                    var codeMatch = code && rawTrim && code.indexOf(rawTrim) !== -1;
                    var nameMatch = name && words.length > 0 && words.every(function (w) { return name.indexOf(w) !== -1; });
                    var idTokenMatch = code && words.length > 0 && words.some(function (w) { return code.indexOf(w) !== -1; });
                    if (codeMatch || nameMatch || idTokenMatch) out.push(item);
                }
                return out;
            }

            function openPartyDropdown() {
                if (!dropdownList || !dropdownWrap || !input) return;

                var raw = (input.value || '').trim();
                var results = getFilteredCustomers(raw);

                dropdownList.innerHTML = '';
                selectableCustomers = [];

                if (!results.length) {
                    var empty = document.createElement('div');
                    empty.className = 'product-dropdown-item text-muted small';
                    empty.textContent = raw ? 'لا توجد نتائج' : ('اكتب للبحث ثم انزل بالسهم ▼ واختر (' + PARTY_LIST_MAX + ' كحد أقصى)');
                    dropdownList.appendChild(empty);
                    activeIndex = -1;
                } else {
                    var currentRaw = raw;
                    var currentNorm = normalizePartyText(currentRaw);
                    var highlightIdx = 0;

                    for (var i = 0; i < results.length; i++) {
                        var item = results[i];
                        if (normalizePartyText(item.code || '') === currentNorm || normalizePartyText(item.name || '') === currentNorm) {
                            highlightIdx = i;
                            break;
                        }
                    }

                    results.forEach(function (item, idx) {
                        var el = document.createElement('div');
                        el.className = 'product-dropdown-item' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                        el.setAttribute('role', 'option');
                        var partyId = (item.id != null && item.id !== 0) ? String(item.id) : String(item.code || '');
                        var partyName = (item.name || '').trim();
                        el.setAttribute('data-party-id', partyId);
                        el.setAttribute('data-party-name', partyName);
                        el.textContent = item.name + (item.phone ? ' (' + item.phone + ')' : '');
                        // نفس الفاتورة: بدون منع mousedown حتى يُسجَّل النقر ويُحدَّث الاسم فعلياً
                        el.addEventListener('mouseenter', function () {
                            activeIndex = idx;
                            setPartyDropdownHighlight(idx);
                        });
                        el.addEventListener('click', function (e) {
                            e.preventDefault();
                            e.stopPropagation();
                            isSelectingCustomer = true;
                            partySelectionTs = Date.now();
                            // القراءة من العنصر المُنقَر عليه مباشرة لضمان تطابق الاسم المعروض مع المختار
                            var chosenId = (e.currentTarget.getAttribute('data-party-id') || '').trim();
                            var chosenName = (e.currentTarget.getAttribute('data-party-name') || '').trim();
                            hiddenId.value = chosenId;
                            input.value = chosenName;
                            closePartyDropdown();
                            setTimeout(function () {
                                try {
                                    if (input) {
                                        input.focus();
                                        input.setSelectionRange(input.value.length, input.value.length);
                                    }
                                } catch { }
                                isSelectingCustomer = false;
                            }, 80);
                        });
                        dropdownList.appendChild(el);
                        selectableCustomers.push(item);
                    });

                    activeIndex = highlightIdx;
                }

                dropdownList.setAttribute('data-open', 'true');
                positionPartyDropdownList();
            }

            // عدم فتح القائمة تلقائياً عند تحميل الصفحة (التركيز الأول برمجي)
            var skipNextFocusOpen = false;
            if (input) {
                setTimeout(function () {
                    skipNextFocusOpen = true;
                    input.focus();
                }, 150);
            }

            if (input && hiddenId && dropdownList && dropdownWrap && form) {
                // فتح القائمة عند الكتابة (ومع الحقل الفارغ نعرض أول 10 — مثل فاتورة المبيعات)
                input.addEventListener('input', function () {
                    if (isSelectingCustomer) return;
                    activeIndex = -1;
                    if (!this.value || this.value.trim().length < 1) {
                        hiddenId.value = '';
                    }
                    openPartyDropdown();
                });

                // فتح القائمة عند التركيز (النقر في الحقل) — لا نفتحها عند التركيز البرمجي الأول
                input.addEventListener('focus', function () {
                    if (isSelectingCustomer) return;
                    if (skipNextFocusOpen) {
                        skipNextFocusOpen = false;
                        return;
                    }
                    openPartyDropdown();
                });

                if (dropdownArrow) {
                    dropdownArrow.addEventListener('click', function (ev) {
                        ev.preventDefault();
                        input?.focus();
                        openPartyDropdown();
                    });
                }

                input.addEventListener('keydown', function (e) {
                    var isOpen = dropdownList && dropdownList.getAttribute('data-open') === 'true';
                    var len = selectableCustomers.length || 0;

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        if (!isOpen) openPartyDropdown();
                        if (!len) return;
                        var next = activeIndex < 0 ? 0 : Math.min(activeIndex + 1, len - 1);
                        setPartyDropdownHighlight(next);
                        return;
                    }

                    if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        if (!isOpen) openPartyDropdown();
                        if (!len) return;
                        var prev = activeIndex < 0 ? 0 : Math.max(activeIndex - 1, 0);
                        setPartyDropdownHighlight(prev);
                        return;
                    }

                    if (e.key === 'Enter') {
                        if (isOpen && len > 0) {
                            e.preventDefault();
                            var txt = (input.value || '').trim();
                            var txtNorm = normalizeNameForMatch(txt);
                            // إن كان النص في الحقل يطابق أحد العملاء في القائمة نستخدمه (لا نرجع لعميل فتح الصفحة)
                            var selected = null;
                            if (txtNorm) {
                                for (var i = 0; i < len; i++) {
                                    var c = selectableCustomers[i];
                                    if (c && normalizeNameForMatch(c.name || '') === txtNorm) {
                                        selected = c;
                                        break;
                                    }
                                }
                            }
                            if (!selected) selected = activeIndex >= 0 && activeIndex < len ? selectableCustomers[activeIndex] : selectableCustomers[0];
                            if (!selected) return;
                            isSelectingCustomer = true;
                            partySelectionTs = Date.now();
                            var chosenId = (selected.id != null && selected.id !== 0) ? String(selected.id) : String(selected.code || '');
                            hiddenId.value = chosenId;
                            input.value = (selected.name || '').trim();
                            closePartyDropdown();
                            setTimeout(function () {
                                try {
                                    if (input) {
                                        input.focus();
                                        input.setSelectionRange(input.value.length, input.value.length);
                                    }
                                } catch { }
                                isSelectingCustomer = false;
                            }, 80);
                            return;
                        }
                        // لو الدروب مقفول: اترك Enter يمشي مع submit
                        return;
                    }

                    if (e.key === 'Escape') {
                        closePartyDropdown();
                    }
                });

                document.addEventListener('click', function (e) {
                    if (!dropdownWrap) return;
                    if (!dropdownWrap.contains(e.target)) closePartyDropdown();
                });

                // تصحيح فوكس/فتح الدروب عند الضغط على الأسهم بعد اختيار العميل (حتى لو سرق المتصفح الفوكس)
                document.addEventListener('keydown', function (e) {
                    if (!input) return;
                    if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
                    // خلال فترة قصيرة بعد الاختيار: لو الفوكس مش على input رجّعه وافتح القائمة
                    var justSelected = Date.now() - partySelectionTs < 1500;
                    if (justSelected && document.activeElement !== input) {
                        e.preventDefault();
                        input.focus();
                        openPartyDropdown();
                        setPartyDropdownHighlight(activeIndex < 0 ? 0 : activeIndex);
                    }
                }, true);

                form.addEventListener('submit', function (e) {
                    var txt = (input.value || '').trim();
                    var currentId = (hiddenId.value || '').trim();
                    var currentName = '';
                    if (currentId && customersData.length) {
                        var cur = customersData.find(function (item) { return (item.id + '') === currentId || (item.code + '') === currentId; });
                        if (cur) currentName = (cur.name || '').trim();
                    }
                    var txtNorm = normalizeNameForMatch(txt);
                    var currentNorm = normalizeNameForMatch(currentName);
                    // إذا النص المُدخل يختلف عن اسم العميل الحالي (الذي فتحت به الصفحة أو المحدد) → نحدّث من النص
                    var needResolve = !txt ? false : (currentNorm !== txtNorm);

                    if (needResolve && txt.length > 0) {
                        if (/^\d+$/.test(txt)) {
                            hiddenId.value = txt;
                        } else {
                            var exactMatch = customersData.find(function (item) {
                                var nameNorm = normalizeNameForMatch(item.name || '');
                                return nameNorm === txtNorm ||
                                    (item.code + '') === txt ||
                                    normalizeNameForMatch((item.code + '') + ' — ' + (item.name || '')) === txtNorm;
                            });
                            if (exactMatch) {
                                hiddenId.value = (exactMatch.id || exactMatch.code) + '';
                                input.value = (exactMatch.name || '').trim();
                            } else {
                                var matches = customersData.filter(function (item) {
                                    var code = (item.code || '').toString();
                                    var nameNorm = normalizeNameForMatch(item.name || '');
                                    return (code && code.indexOf(txt) !== -1) || (nameNorm && nameNorm.indexOf(txtNorm) !== -1);
                                });
                                if (matches.length === 1) {
                                    hiddenId.value = (matches[0].id || matches[0].code) + '';
                                    input.value = (matches[0].name || '').trim();
                                }
                            }
                        }
                    } else if (!hiddenId.value && txt.length > 0) {
                        if (/^\d+$/.test(txt)) {
                            hiddenId.value = txt;
                        } else {
                            var exactMatch = customersData.find(function (item) {
                                return normalizeNameForMatch(item.name || '') === txtNorm || (item.code + '') === txt;
                            });
                            if (exactMatch) {
                                hiddenId.value = (exactMatch.id || exactMatch.code) + '';
                                input.value = (exactMatch.name || '').trim();
                            } else {
                                var matches = customersData.filter(function (item) {
                                    var nameNorm = normalizeNameForMatch(item.name || '');
                                    return nameNorm.indexOf(txtNorm) !== -1;
                                });
                                if (matches.length === 1) {
                                    hiddenId.value = (matches[0].id || matches[0].code) + '';
                                    input.value = (matches[0].name || '').trim();
                                }
                            }
                        }
                    }

                    if (!hiddenId.value) {
                        e.preventDefault();
                        alert('من فضلك اختر عميل من القائمة أو أدخل كوده الرقمى ثم اضغط عرض.');
                    }
                });
            }

            var tabButtons = document.querySelectorAll('.js-open-movement-tab');
            tabButtons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var targetSelector = btn.getAttribute('data-target');
                    if (!targetSelector) return;

                    var trigger = document.querySelector('#customerMovementTabs button[data-bs-target="' + targetSelector + '"]');
                    if (trigger && window.bootstrap && bootstrap.Tab) {
                        var tab = new bootstrap.Tab(trigger);
                        tab.show();
                    }
                });
            });

            // =========================
            // ✅ دالة تحديث للصفحة (يتم استدعاؤها من زر التحديث في الناف بار)
            // =========================
            window.__ERP_REFRESH__ = function () {
                var form = document.getElementById('customerSearchForm');
                if (form) {
                    // التحقق من وجود بيانات في الـ form قبل الـ submit
                    var hiddenId = document.getElementById('partySearchId');
                    if (hiddenId && hiddenId.value) {
                        form.submit();
                    } else {
                        // لو مفيش عميل محدد، نعيد تحميل الصفحة فقط
                        window.location.reload();
                    }
                } else {
                    // لو مفيش form، نعيد تحميل الصفحة
                    window.location.reload();
                }
            };
        })();
    </script>
}
