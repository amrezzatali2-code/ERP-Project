                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            // نمط فاتورة المبيعات: datalist + قائمة مخصّصة + تطبيع أرقام/ألف + كلمات AND + ترتيب
            var custDataList = document.getElementById('customerVolumeList');
            var input = document.getElementById('partySearchInput');
            var hiddenId = document.getElementById('partySearchId');
            var dropdownWrap = document.getElementById('partyDropdownWrap');
            var dropdownList = document.getElementById('partyDropdownList');
            var dropdownArrow = document.getElementById('partyDropdownArrow');
            var form = document.getElementById('customerSearchForm');

            var activeIndex = -1;
            var selectableCustomers = [];
            var isSelectingCustomer = false;
            var CUSTOMER_LIST_MAX = 80;
            var partySelectionTs = 0;

            var allCustomers = [];
            if (custDataList && custDataList.options) {
                allCustomers = Array.from(custDataList.options).map(function (opt) {
                    return {
                        id: (opt.getAttribute('data-id') || '').toString(),
                        name: (opt.value || '').toString(),
                        isActive: (opt.getAttribute('data-is-active') || '1').toString(),
                        phone: (opt.getAttribute('data-phone') || '').toString()
                    };
                });
            }

            function normalizeDigits(s) {
                if (!s) return '';
                var map = { '\u0660': '0', '\u0661': '1', '\u0662': '2', '\u0663': '3', '\u0664': '4',
                    '\u0665': '5', '\u0666': '6', '\u0667': '7', '\u0668': '8', '\u0669': '9' };
                var out = '';
                for (var i = 0; i < s.length; i++) {
                    var c = s[i];
                    out += map[c] !== undefined ? map[c] : c;
                }
                return out;
            }

            function normalizeWord(w) {
                return normalizeDigits((w || '').trim().toLowerCase()).replace(/^[اأإآ]/u, '');
            }

            function normalizeText(txt) {
                return (txt || '')
                    .trim()
                    .toLowerCase()
                    .split(/\s+/)
                    .filter(Boolean)
                    .map(function (w) { return normalizeWord(w); })
                    .filter(Boolean)
                    .join(' ')
                    .replace(/\s+/g, ' ');
            }

            function wordMatchesQueryWord(nameWord, queryWord) {
                var nw0 = normalizeDigits((nameWord || '').trim().toLowerCase());
                var qw0 = normalizeDigits((queryWord || '').trim().toLowerCase());
                var nw = nw0.replace(/^[اأإآ]/u, '');
                var qw = qw0.replace(/^[اأإآ]/u, '');
                if (!qw) return true;
                return nw === qw || nw.startsWith(qw);
            }

            function customerNameMatchesSearch(customerName, rawSearch) {
                var raw = (rawSearch || '').trim();
                if (!raw) return true;
                var qWords = raw.split(/\s+/).filter(Boolean);
                var nWords = (customerName || '').trim().split(/\s+/).filter(Boolean);
                if (qWords.length === 0) return true;
                return qWords.every(function (qw) {
                    return nWords.some(function (nw) { return wordMatchesQueryWord(nw, qw); });
                });
            }

            function customerSearchRank(name, rawSearch) {
                var raw = (rawSearch || '').trim();
                var nm = (name || '').trim();
                if (!raw) return 50;
                if (nm === raw) return 0;
                if (nm.startsWith(raw)) return 1;
                var rawWords = raw.split(/\s+/).filter(Boolean);
                var firstQ = rawWords[0] || '';
                var nmWords = nm.split(/\s+/).filter(Boolean);
                if (firstQ && nmWords.length) {
                    if (nmWords[0].startsWith(firstQ)) return 2;
                    var nw0 = normalizeDigits(nmWords[0].toLowerCase());
                    var qw0 = normalizeDigits(firstQ.toLowerCase());
                    var nw = nw0.replace(/^[اأإآ]/u, '');
                    var qw = qw0.replace(/^[اأإآ]/u, '');
                    if (qw && (nw === qw || nw.startsWith(qw))) return 3;
                }
                return 4;
            }

            function normalizeNameForMatch(txt) {
                return (txt || '').trim().toLowerCase().replace(/\s+/g, ' ').replace(/ى/g, 'ي');
            }

            function findByName(name) {
                var raw = (name || '').trim();
                var search = normalizeText(raw);
                if (!search) return null;
                for (var i = 0; i < allCustomers.length; i++) {
                    if (normalizeText(allCustomers[i].name) === search) return allCustomers[i];
                }
                for (var i = 0; i < allCustomers.length; i++) {
                    if ((allCustomers[i].name || '').trim() === raw) return allCustomers[i];
                }
                return null;
            }

            function findByCode(code) {
                var search = (code || '').toString().trim();
                if (!search) return null;
                for (var i = 0; i < allCustomers.length; i++) {
                    if ((allCustomers[i].id || '').toString() === search) return allCustomers[i];
                }
                return null;
            }

            function fillFromParty(opt) {
                if (!opt) {
                    if (hiddenId) hiddenId.value = '';
                    if (input) input.value = '';
                    return;
                }
                if (hiddenId) hiddenId.value = (opt.id || '').toString();
                if (input) input.value = (opt.name || '').trim();
            }

            function getFilteredCustomerOptions(search, max) {
                if (!allCustomers || !allCustomers.length) return [];
                var limit = max || CUSTOMER_LIST_MAX;
                var rawTrim = (search || '').trim();
                if (!rawTrim) return allCustomers.slice(0, limit);

                var qNorm = normalizeText(rawTrim);
                var words = rawTrim.split(/\s+/).filter(Boolean);
                var matched = [];
                for (var i = 0; i < allCustomers.length; i++) {
                    var c = allCustomers[i];
                    var idStr = (c.id || '').toString().trim();
                    var nameOk = qNorm ? customerNameMatchesSearch(c.name || '', rawTrim) : true;
                    var idOk = words.length > 0 && words.some(function (w) { return idStr.indexOf(w) !== -1; });
                    var codeRawOk = idStr && idStr.indexOf(rawTrim) !== -1;
                    if (nameOk || idOk || codeRawOk) matched.push(c);
                }
                matched.sort(function (a, b) {
                    var ra = customerSearchRank(a.name || '', rawTrim);
                    var rb = customerSearchRank(b.name || '', rawTrim);
                    if (ra !== rb) return ra - rb;
                    return (a.name || '').localeCompare(b.name || '', 'ar');
                });
                return matched.slice(0, limit);
            }

            function closePartyDropdown() {
                if (dropdownList) {
                    dropdownList.setAttribute('data-open', 'false');
                    dropdownList.innerHTML = '';
                }
                activeIndex = -1;
                selectableCustomers = [];
            }

            function positionPartyDropdownList() {
                if (!dropdownList || !dropdownWrap) return;
                if (dropdownList.getAttribute('data-open') !== 'true') return;
                var r = dropdownWrap.getBoundingClientRect();
                dropdownList.style.width = r.width + 'px';
                dropdownList.style.top = r.bottom + 'px';
                dropdownList.style.left = r.left + 'px';
            }

            function setPartyDropdownHighlight(idx) {
                if (!dropdownList) return;
                if (idx < 0 || idx >= selectableCustomers.length) return;
                var children = dropdownList.querySelectorAll('.product-dropdown-item');
                children.forEach(function (el, i) {
                    el.classList.toggle('product-dropdown-item-active', i === idx);
                });
                activeIndex = idx;
                try { children[idx]?.scrollIntoView({ block: 'nearest', behavior: 'smooth' }); } catch { }
            }

            function selectHighlightedParty() {
                if (activeIndex < 0 || activeIndex >= selectableCustomers.length) return false;
                var selected = selectableCustomers[activeIndex];
                if (!selected) return false;
                isSelectingCustomer = true;
                partySelectionTs = Date.now();
                fillFromParty(selected);
                closePartyDropdown();
                setTimeout(function () {
                    try {
                        if (input) {
                            input.focus();
                            input.setSelectionRange(input.value.length, input.value.length);
                        }
                    } catch { }
                    isSelectingCustomer = false;
                }, 80);
                return true;
            }

            function openPartyDropdown() {
                if (!dropdownList || !dropdownWrap || !input) return;
                var raw = (input.value || '').trim();
                var list = getFilteredCustomerOptions(raw, CUSTOMER_LIST_MAX);

                dropdownList.innerHTML = '';
                selectableCustomers = [];

                var highlightIdx = 0;
                if (list.length > 0) {
                    for (var i = 0; i < list.length; i++) {
                        if (normalizeText(list[i].name || '').trim() === normalizeText(raw)) {
                            highlightIdx = i;
                            break;
                        }
                    }
                }

                if (list.length === 0) {
                    var empty = document.createElement('div');
                    empty.className = 'product-dropdown-item text-muted py-2 px-3 small';
                    empty.textContent = raw ? 'لا توجد نتائج' : ('اكتب للبحث ثم انزل بالسهم ▼ واختر (' + CUSTOMER_LIST_MAX + ' كحد أقصى)');
                    dropdownList.appendChild(empty);
                    activeIndex = -1;
                } else {
                    list.forEach(function (c, idx) {
                        var it = document.createElement('div');
                        it.className = 'product-dropdown-item py-2 px-3' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                        it.setAttribute('role', 'option');
                        var label = (c.name || '').trim() + (c.phone ? ' (' + c.phone + ')' : '');
                        if (c.isActive === '0') label += ' (موقوف)';
                        it.textContent = label;
                        it.addEventListener('mouseenter', function () {
                            activeIndex = idx;
                            setPartyDropdownHighlight(idx);
                        });
                        it.addEventListener('click', function (e) {
                            e.preventDefault();
                            e.stopPropagation();
                            isSelectingCustomer = true;
                            partySelectionTs = Date.now();
                            fillFromParty(c);
                            closePartyDropdown();
                            setTimeout(function () {
                                try {
                                    if (input) {
                                        input.focus();
                                        input.setSelectionRange(input.value.length, input.value.length);
                                    }
                                } catch { }
                                isSelectingCustomer = false;
                            }, 80);
                        });
                        dropdownList.appendChild(it);
                        selectableCustomers.push(c);
                    });
                    activeIndex = highlightIdx;
                }

                dropdownList.setAttribute('data-open', 'true');
                positionPartyDropdownList();
            }

            if (input) {
                setTimeout(function () { input.focus(); }, 150);
            }

            if (custDataList && input && hiddenId && dropdownList && dropdownWrap && form) {
                if (dropdownWrap && !dropdownWrap.dataset.boundPartyDropdownClick) {
                    dropdownWrap.dataset.boundPartyDropdownClick = '1';
                    dropdownWrap.addEventListener('click', function (ev) {
                        if (ev.target && ev.target.closest('#partyDropdownList')) return;
                    });
                }

                input.addEventListener('input', function () {
                    if (isSelectingCustomer) return;
                    activeIndex = -1;
                    if (!this.value || this.value.trim().length < 1) hiddenId.value = '';
                    openPartyDropdown();
                });

                if (dropdownArrow) {
                    dropdownArrow.addEventListener('click', function (ev) {
                        ev.preventDefault();
                        if (input) input.focus();
                        openPartyDropdown();
                    });
                }

                input.addEventListener('keydown', function (e) {
                    var isOpen = dropdownList && dropdownList.getAttribute('data-open') === 'true';
                    var len = selectableCustomers.length || 0;

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        if (!isOpen) openPartyDropdown();
                        if (!len) return;
                        var next = activeIndex < 0 ? 0 : Math.min(activeIndex + 1, len - 1);
                        setPartyDropdownHighlight(next);
                        return;
                    }
                    if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        if (!isOpen) openPartyDropdown();
                        if (!len) return;
                        var prev = activeIndex < 0 ? 0 : Math.max(activeIndex - 1, 0);
                        setPartyDropdownHighlight(prev);
                        return;
                    }
                    if (e.key === 'Enter') {
                        if (isOpen && len > 0) {
                            e.preventDefault();
                            // أولوية للعنصر المميز بالأسهم/الماوس — لا نطابق نص الحقل أولاً (مثلاً «احمد» يطابق أول عميل اسمه احمد فقط ويخطئ احمد 2)
                            var selected = null;
                            if (activeIndex >= 0 && activeIndex < len) {
                                selected = selectableCustomers[activeIndex];
                            } else {
                                var txt = (input.value || '').trim();
                                var txtNorm = normalizeNameForMatch(txt);
                                if (txtNorm) {
                                    for (var j = 0; j < len; j++) {
                                        var cc = selectableCustomers[j];
                                        if (cc && normalizeNameForMatch(cc.name || '') === txtNorm) {
                                            selected = cc;
                                            break;
                                        }
                                    }
                                }
                                if (!selected) selected = selectableCustomers[0];
                            }
                            if (selected) {
                                isSelectingCustomer = true;
                                partySelectionTs = Date.now();
                                fillFromParty(selected);
                                closePartyDropdown();
                                setTimeout(function () {
                                    try {
                                        if (input) {
                                            input.focus();
                                            input.setSelectionRange(input.value.length, input.value.length);
                                        }
                                    } catch { }
                                    isSelectingCustomer = false;
                                }, 80);
                            }
                            return;
                        }
                        return;
                    }
                    if (e.key === 'Escape') closePartyDropdown();
                });

                document.addEventListener('click', function (e) {
                    if (!dropdownWrap) return;
                    if (!dropdownWrap.contains(e.target)) closePartyDropdown();
                });

                document.addEventListener('keydown', function (e) {
                    if (!input) return;
                    if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
                    var justSelected = Date.now() - partySelectionTs < 1500;
                    if (justSelected && document.activeElement !== input) {
                        e.preventDefault();
                        input.focus();
                        openPartyDropdown();
                        setPartyDropdownHighlight(activeIndex < 0 ? 0 : activeIndex);
                    }
                }, true);

                if (hiddenId && hiddenId.value) {
                    fillFromParty(findByCode(hiddenId.value));
                }

                form.addEventListener('submit', function (e) {
                    var txt = (input.value || '').trim();
                    var currentId = (hiddenId.value || '').trim();
                    var currentName = '';
                    if (currentId && allCustomers.length) {
                        var cur = allCustomers.find(function (item) { return (item.id + '') === currentId; });
                        if (cur) currentName = (cur.name || '').trim();
                    }
                    var txtNorm = normalizeNameForMatch(txt);
                    var currentNorm = normalizeNameForMatch(currentName);
                    var needResolve = !txt ? false : (currentNorm !== txtNorm);

                    function tryResolve() {
                        if (!txt) return;
                        if (/^\d+$/.test(txt)) {
                            var byId = findByCode(txt);
                            if (byId) {
                                fillFromParty(byId);
                                return;
                            }
                            hiddenId.value = txt;
                            return;
                        }
                        var exact = findByName(txt);
                        if (exact) {
                            fillFromParty(exact);
                            return;
                        }
                        var cand = getFilteredCustomerOptions(txt, CUSTOMER_LIST_MAX);
                        if (cand.length === 1) fillFromParty(cand[0]);
                    }

                    if (needResolve && txt.length > 0) tryResolve();
                    else if (!hiddenId.value && txt.length > 0) tryResolve();

                    if (!hiddenId.value) {
                        e.preventDefault();
                        alert('من فضلك اختر عميل من القائمة أو أدخل كوده الرقمى ثم اضغط عرض.');
                    }
                });
            }

            var tabButtons = document.querySelectorAll('.js-open-movement-tab');
            tabButtons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var targetSelector = btn.getAttribute('data-target');
                    if (!targetSelector) return;

                    var trigger = document.querySelector('#customerMovementTabs button[data-bs-target="' + targetSelector + '"]');
                    if (trigger && window.bootstrap && bootstrap.Tab) {
                        var tab = new bootstrap.Tab(trigger);
                        tab.show();
                    }
                });
            });
        })();

        (function () {
            function openCvDocInTab(tabId, url, title) {
                if (!url) return;
                try {
                    if (window.top !== window) {
                        window.top.postMessage({ type: 'erp-open-tab', tabId: tabId, url: url, title: title || 'تبويب' }, '*');
                        return;
                    }
                    if (window.erpTabs && typeof window.erpTabs.openTab === 'function') {
                        window.erpTabs.openTab(tabId, url, title || 'تبويب');
                    } else {
                        window.location.href = url;
                    }
                } catch (e) {
                    window.location.href = url;
                }
            }
            var btnView = document.getElementById('customerVolumeBtnView');
            var container = document.getElementById('customerMovementTabsContent');
            if (!btnView || !container) return;
            function clearCvSelection() {
                container.querySelectorAll('.erp-list-selectable-row.selected').forEach(function (r) { r.classList.remove('selected'); });
                btnView.disabled = true;
            }
            container.addEventListener('click', function (e) {
                var row = e.target.closest('.erp-list-selectable-row');
                if (!row || !container.contains(row)) return;
                if (e.target.closest('a')) return;
                container.querySelectorAll('.erp-list-selectable-row').forEach(function (r) { r.classList.remove('selected'); });
                row.classList.add('selected');
                btnView.disabled = !row.getAttribute('data-show-url');
            });
            btnView.addEventListener('click', function () {
                var row = container.querySelector('.erp-list-selectable-row.selected');
                if (!row) return;
                var url = row.getAttribute('data-show-url');
                if (!url) return;
                var tabId = row.getAttribute('data-tab-id') || 'doc-show-tab';
                var title = row.getAttribute('data-tab-title') || 'عرض';
                openCvDocInTab(tabId, url, title);
            });
            document.querySelectorAll('#customerMovementTabs button[data-bs-toggle="tab"]').forEach(function (b) {
                b.addEventListener('shown.bs.tab', function () { clearCvSelection(); });
            });
        })();

        (function () {

            // =========================
            // ✅ دالة تحديث للصفحة (يتم استدعاؤها من زر التحديث في الناف بار)
            // =========================
            window.__ERP_REFRESH__ = function () {
                var form = document.getElementById('customerSearchForm');
                if (form) {
                    // التحقق من وجود بيانات في الـ form قبل الـ submit
                    var hiddenId = document.getElementById('partySearchId');
                    if (hiddenId && hiddenId.value) {
                        form.submit();
                    } else {
                        // لو مفيش عميل محدد، نعيد تحميل الصفحة فقط
                        window.location.reload();
                    }
                } else {
                    // لو مفيش form، نعيد تحميل الصفحة
                    window.location.reload();
                }
            };
        })();
    </script>
}
