                                                <td>@DateTime.Today.Add(invoice.SITime).ToString("HH:mm:ss")</td>
                                                <td>@(warehouses.TryGetValue(invoice.WarehouseId, out var warehouseName) ? warehouseName : invoice.WarehouseId.ToString())</td>
                                                <td class="text-end">@invoice.NetTotal.ToString("N2")</td>
                                            </tr>
