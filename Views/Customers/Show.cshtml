@model ERP.Models.Customer?
@using System.Text.Json
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "حجم تعامل عميل";

    // قائمة العملاء للأوتوكومبليت
    var customersList = ViewBag.CustomersList as IEnumerable<SelectListItem>
                        ?? Enumerable.Empty<SelectListItem>();

    // تجهيز بيانات العملاء فى شكل JSON للجافاسكربت
    var customersJsModel = customersList.Select(c => new
    {
        id = int.TryParse(c.Value, out var tmpId) ? tmpId : 0,
        code = c.Value,
        name = c.Text,
        phone = ""
    });

    var customersJson = JsonSerializer.Serialize(customersJsModel);

    // متغيرات: فترة البحث
    DateTime? fromDate = ViewBag.FromDate as DateTime?;
    DateTime? toDate = ViewBag.ToDate as DateTime?;

    // متغيرات: ملخص حجم التعامل
    decimal totalSales = ViewBag.TotalSales as decimal? ?? 0m;
    decimal totalSalesReturns = ViewBag.TotalSalesReturns as decimal? ?? 0m;
    decimal totalPurchaseReturns = ViewBag.TotalPurchaseReturns as decimal? ?? 0m;
    decimal totalPurchases = ViewBag.TotalPurchases as decimal? ?? 0m;
    int invoiceCount = ViewBag.InvoiceCount as int? ?? 0;
    DateTime? lastTransDate = ViewBag.LastTransactionDate as DateTime?;
    
    // متغيرات: قوائم الفواتير والمخازن (للعرض في التبويبات)
    var salesInvoices = ViewBag.SalesInvoicesList as IEnumerable<ERP.Models.SalesInvoice> ?? Enumerable.Empty<ERP.Models.SalesInvoice>();
    var purchaseInvoices = ViewBag.PurchaseInvoicesList as IEnumerable<ERP.Models.PurchaseInvoice> ?? Enumerable.Empty<ERP.Models.PurchaseInvoice>();
    var salesReturns = ViewBag.SalesReturnsList as IEnumerable<ERP.Models.SalesReturn> ?? Enumerable.Empty<ERP.Models.SalesReturn>();
    var purchaseReturns = ViewBag.PurchaseReturnsList as IEnumerable<ERP.Models.PurchaseReturn> ?? Enumerable.Empty<ERP.Models.PurchaseReturn>();
    var cashReceipts = ViewBag.CashReceiptsList as IEnumerable<ERP.Models.CashReceipt> ?? Enumerable.Empty<ERP.Models.CashReceipt>();
    var cashPayments = ViewBag.CashPaymentsList as IEnumerable<ERP.Models.CashPayment> ?? Enumerable.Empty<ERP.Models.CashPayment>();
    var debitNotes = ViewBag.DebitNotesList as IEnumerable<ERP.Models.DebitNote> ?? Enumerable.Empty<ERP.Models.DebitNote>();
    var creditNotes = ViewBag.CreditNotesList as IEnumerable<ERP.Models.CreditNote> ?? Enumerable.Empty<ERP.Models.CreditNote>();
    var warehouses = ViewBag.Warehouses as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<style>
    /* تحسينات التصميم: استغلال المساحة وتصميم موحد */
    .customer-dashboard {
        min-height: calc(100vh - 120px);
        display: flex;
        flex-direction: column;
    }
    
    .dashboard-header {
        flex-shrink: 0;
        padding: 0.5rem 0;
    }
    
    .dashboard-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }
    
    .compact-card {
        padding: 0.75rem;
        margin-bottom: 0.5rem;
    }
    
    .compact-stat {
        font-size: 1.1rem;
        font-weight: 600;
        line-height: 1.2;
    }
    
    .compact-label {
        font-size: 0.75rem;
        margin-bottom: 0.25rem;
    }
    
    .action-btn-compact {
        padding: 0.25rem 0.5rem;
        font-size: 0.8rem;
        line-height: 1.3;
    }
    
    .customer-info-compact {
        font-size: 0.85rem;
    }
    
    .table-compact {
        font-size: 0.85rem;
    }
    
    .table-compact th,
    .table-compact td {
        padding: 0.35rem 0.5rem;
    }
    
    .nav-tabs-compact {
        font-size: 0.8rem;
        padding: 0.25rem 0.5rem;
    }

    /* أزرار حجم التعامل: خلفية بيضاء وحدود ملونة لكل الأزرار */
    .customer-dashboard .erp-list-filter-bar .customer-volume-btn {
        background-color: #fff !important;
        border-width: 1.5px !important;
        border-style: solid !important;
    }
    .customer-dashboard .erp-list-filter-bar .customer-volume-btn.btn-outline-primary {
        color: #0d6efd !important;
        border-color: #0d6efd !important;
    }
    .customer-dashboard .erp-list-filter-bar .customer-volume-btn.btn-outline-primary:hover {
        background-color: #0d6efd !important;
        color: #fff !important;
        border-color: #0d6efd !important;
    }
    .customer-dashboard .erp-list-filter-bar .customer-volume-btn.btn-outline-secondary {
        color: #6c757d !important;
        border-color: #6c757d !important;
    }
    .customer-dashboard .erp-list-filter-bar .customer-volume-btn.btn-outline-secondary:hover {
        background-color: #6c757d !important;
        color: #fff !important;
        border-color: #6c757d !important;
    }
    .customer-dashboard .erp-list-filter-bar .customer-volume-btn.btn-outline-success {
        color: #198754 !important;
        border-color: #198754 !important;
    }
    .customer-dashboard .erp-list-filter-bar .customer-volume-btn.btn-outline-success:hover {
        background-color: #198754 !important;
        color: #fff !important;
        border-color: #198754 !important;
    }
    .customer-dashboard .erp-list-filter-bar .customer-volume-btn.btn-outline-danger {
        color: #dc3545 !important;
        border-color: #dc3545 !important;
    }
    .customer-dashboard .erp-list-filter-bar .customer-volume-btn.btn-outline-danger:hover {
        background-color: #dc3545 !important;
        color: #fff !important;
        border-color: #dc3545 !important;
    }
    .customer-dashboard .erp-list-filter-bar .customer-volume-btn.btn-outline-warning {
        color: #ffc107 !important;
        border-color: #ffc107 !important;
    }
    .customer-dashboard .erp-list-filter-bar .customer-volume-btn.btn-outline-warning:hover {
        background-color: #ffc107 !important;
        color: #000 !important;
        border-color: #ffc107 !important;
    }

    /* بطاقات الملخص: في منتصف الشاشة، كلها نفس المقاس */
    .customer-summary-cards {
        display: flex;
        flex-wrap: nowrap;
        justify-content: center;
        align-items: stretch;
        direction: rtl;
        gap: 0.5rem;
    }
    .customer-summary-cards .customer-stat-card {
        flex: 0 0 130px;
        min-width: 130px;
        max-width: 130px;
    }
    .customer-summary-cards .customer-stat-card .card {
        width: 100%;
        min-width: 130px;
    }
    .customer-summary-cards .compact-label { font-size: 0.75rem !important; }
    .customer-summary-cards .compact-stat { font-size: 1.05rem !important; }

    /* بطاقة الرصيد الحالي: حدود مميزة وأرقام واضحة */
    .customer-balance-card {
        border: 2px solid #0d6efd !important;
        box-shadow: 0 2px 8px rgba(13, 110, 253, 0.25) !important;
        background: linear-gradient(to bottom, #f8fafc 0%, #fff 100%) !important;
    }
    .customer-balance-value {
        font-size: 1.15rem !important;
        font-weight: 700 !important;
        letter-spacing: 0.02em;
    }
    .customer-balance-label {
        font-size: 0.8rem !important;
        font-weight: 600 !important;
    }
    
    /* ✅ إصلاح عرض التبويبات مع Flexbox */
    #customerMovementTabsContent.tab-content {
        position: relative;
        min-height: 0;
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    
    #customerMovementTabsContent .tab-pane {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        min-height: 0;
        display: none !important;
    }
    
    /* ✅ Bootstrap tabs يعيد display: block للـ .tab-pane.active، لذا نستخدم !important */
    #customerMovementTabsContent .tab-pane:not(.active):not(.show) {
        display: none !important;
        visibility: hidden;
    }
    
    #customerMovementTabsContent .tab-pane.active,
    #customerMovementTabsContent .tab-pane.active.show {
        display: flex !important;
        flex-direction: column;
        visibility: visible;
        position: relative;
    }
</style>

<div class="container-fluid customer-dashboard" dir="rtl">

    @* =====================================================
       1) شريط اختيار العميل + فترة التاريخ (تصميم موحد مثل Index)
       ===================================================== *@
    <div class="dashboard-header">
        <div class="erp-list-filter-bar d-print-none mt-2">
            <form id="customerSearchForm"
                  method="get"
                  asp-action="Show"
                  asp-controller="Customers"
                  class="row g-3 align-items-end">

                <input type="hidden" id="partySearchId" name="id" value="@(Model?.CustomerId.ToString() ?? "")" />
                @if (Context.Request.Query["frame"] == "1")
                {
                    <input type="hidden" name="frame" value="1" />
                }

                <div class="col-12 col-lg-4 erp-filter-section">
                    <label class="form-label">بحث بالكود أو الاسم</label>
                    <div class="position-relative">
                        <input id="partySearchInput"
                               type="text"
                               class="form-control erp-filter-input"
                               placeholder="اكتب جزء من اسم العميل أو الكود..."
                               value="@(Model != null ? Model.CustomerId + " — " + Model.CustomerName : "")" />
                        <div id="partySuggestions"
                             class="list-group position-absolute w-100 shadow-sm"
                             style="z-index: 1050; max-height: 200px; overflow-y: auto; display: none;">
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">من تاريخ</label>
                    <input type="date"
                           name="fromDate"
                           dir="ltr"
                           class="form-control erp-filter-input"
                           placeholder="yyyy-mm-dd"
                           title="سنة-شهر-يوم (مثال: 2026-02-21)"
                           value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>

                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date"
                           name="toDate"
                           dir="ltr"
                           class="form-control erp-filter-input"
                           placeholder="yyyy-mm-dd"
                           title="سنة-شهر-يوم (مثال: 2026-02-21)"
                           value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>

                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label d-none d-md-block" style="visibility:hidden">عرض</label>
                    <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm w-100">
                        عرض
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* =====================================================
       2) لو لم يتم اختيار عميل بعد
       ===================================================== *@
    @if (Model == null)
    {
        <div class="alert alert-light border text-muted text-center">
            برجاء اختيار عميل أو مورد من أعلى الصفحة ثم اضغط زر <strong>عرض</strong>.
        </div>
    }
    else
    {
        // متغيرات: نص يوضح حالة الرصيد (مدين / دائن)
        decimal currentBalance = Model.CurrentBalance;
        string balanceText;
        string balanceCss;

        if (currentBalance > 0)
        {
            balanceText = "مدين";
            balanceCss = "text-danger";
        }
        else if (currentBalance < 0)
        {
            balanceText = "دائن";
            balanceCss = "text-success";
        }
        else
        {
            balanceText = "صفر";
            balanceCss = "text-muted";
        }

    <div class="dashboard-content">
        @* =====================================================
           3) الاسم والأزرار فقط — الاسم أكبر، الأزرار في سطر واحد
           ===================================================== *@
        <div class="erp-list-filter-bar mb-2">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div>
                    <h4 class="mb-0 fw-bold" style="font-size: 1.4rem;">@Model.CustomerName</h4>
                    @if (Model.Route != null)
                    {
                        <small class="text-muted">خط السير: @Model.Route.Name</small>
                    }
                </div>
                <div class="d-flex flex-wrap gap-2 flex-nowrap">
                    <a asp-controller="CustomerLedger" asp-action="Index" asp-route-customerId="@Model.CustomerId" 
                       class="btn btn-erp btn-outline-primary btn-erp-sm app-menu-link customer-volume-btn"
                       data-tab-id="customer-ledger-tab"
                       data-tab-title="كشف حساب عميل">📊 كشف حساب</a>
                    <a asp-action="Edit" asp-route-id="@Model.CustomerId" 
                       class="btn btn-erp btn-outline-secondary btn-erp-sm app-menu-link customer-volume-btn"
                       data-tab-id="customer-edit-tab"
                       data-tab-title="تعديل عميل">✏️ تعديل</a>
                    <a asp-controller="CashReceipts" asp-action="Create" asp-route-customerId="@Model.CustomerId" 
                       class="btn btn-erp btn-outline-success btn-erp-sm app-menu-link customer-volume-btn"
                       data-tab-id="cash-receipt-create-tab"
                       data-tab-title="إضافة إذن استلام نقدية">💰 استلام</a>
                    <a asp-controller="CashPayments" asp-action="Create" asp-route-customerId="@Model.CustomerId" 
                       class="btn btn-erp btn-outline-danger btn-erp-sm app-menu-link customer-volume-btn"
                       data-tab-id="cash-payment-create-tab"
                       data-tab-title="إضافة إذن دفع نقدية">💸 دفع</a>
                    <a asp-controller="DebitNotes" asp-action="Create" asp-route-customerId="@Model.CustomerId" 
                       class="btn btn-erp btn-outline-warning btn-erp-sm app-menu-link customer-volume-btn"
                       data-tab-id="debit-note-create-tab"
                       data-tab-title="إشعار خصم">اشعار خصم</a>
                    <a asp-controller="CreditNotes" asp-action="Create" asp-route-customerId="@Model.CustomerId" 
                       class="btn btn-erp btn-outline-success btn-erp-sm app-menu-link customer-volume-btn"
                       data-tab-id="credit-note-create-tab"
                       data-tab-title="إشعار إضافة">اشعار اضافة</a>
                </div>
            </div>
        </div>

        @* =====================================================
           4) بطاقات الملخص: المبيعات أولاً من اليمين، الرصيد الحالي في المنتصف بنفس الحجم
           ترتيب RTL: أول عنصر في HTML = أقصى اليمين
           ===================================================== *@
        <div class="row g-1 mb-2 flex-nowrap customer-summary-cards" style="overflow-x: auto;">
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm clickable-stat-card" style="cursor: pointer;"
                     onclick="window.location.href='@Url.Action("Index", "SalesInvoices", new { searchBy = "customer", search = Model.CustomerId.ToString() })'">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">المبيعات</div>
                        <div class="compact-stat text-success" style="font-size: 0.95rem;">@totalSales.ToString("N2")</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm clickable-stat-card" style="cursor: pointer;"
                     onclick="window.location.href='@Url.Action("Index", "PurchaseInvoices", new { searchBy = "customer", search = Model.CustomerId.ToString() })'">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">المشتريات</div>
                        <div class="compact-stat text-primary" style="font-size: 0.95rem;">@totalPurchases.ToString("N2")</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm clickable-stat-card" style="cursor: pointer;"
                     onclick="window.location.href='@Url.Action("Index", "SalesReturns", new { searchBy = "customer", search = Model.CustomerId.ToString() })'">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">مرتجعات البيع</div>
                        <div class="compact-stat text-success" style="font-size: 0.95rem;">@totalSalesReturns.ToString("N2")</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm clickable-stat-card" style="cursor: pointer;"
                     onclick="window.location.href='@Url.Action("Index", "PurchaseReturns", new { searchBy = "customerId", search = Model.CustomerId.ToString() })'">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">مرتجعات الشراء</div>
                        <div class="compact-stat text-primary" style="font-size: 0.95rem;">@totalPurchaseReturns.ToString("N2")</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm customer-balance-card">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted">الرصيد الحالي</div>
                        <div class="compact-stat fw-bold @balanceCss customer-balance-value">@currentBalance.ToString("N2")</div>
                        <small class="@balanceCss fw-semibold customer-balance-label">@balanceText</small>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">عدد الفواتير</div>
                        <div class="compact-stat" style="font-size: 0.95rem;">@invoiceCount</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">آخر عملية</div>
                        <div class="compact-stat" style="font-size: 0.85rem;">@(lastTransDate?.ToString("yyyy/MM/dd") ?? "-")</div>
                    </div>
                </div>
            </div>
        </div>

        @* =====================================================
           5) التبويبات والجداول — استغلال المساحة، التبويبات تبدأ من اليمين
           ===================================================== *@
        <div class="erp-list-filter-bar mb-2 flex-grow-1 d-flex flex-column" style="min-height: 280px;">
            <div class="p-2 w-100" style="flex-shrink: 0;">
                <div class="d-flex justify-content-start align-items-center w-100" style="direction: rtl;">
                    <div class="overflow-x-auto" style="white-space: nowrap; max-width: 100%;">
                        <ul class="nav nav-pills nav-sm flex-nowrap" id="customerMovementTabs" role="tablist" style="direction: rtl;">
                            <li class="nav-item"><button class="nav-link active nav-tabs-compact" id="tab-sales-link" data-bs-toggle="tab" data-bs-target="#tab-sales">المبيعات</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-salesReturns">مرتجعات البيع</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-purchases">المشتريات</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-purchaseReturns">مرتجعات الشراء</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-orders">الأوامر</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-receipts">إيصالات استلام</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-payments">إيصالات دفع</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-debitNotes">إشعارات خصم</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-creditNotes">إشعارات إضافة</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-settlements">تسويات</button></li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="p-2 flex-grow-1" style="overflow: hidden; display: flex; flex-direction: column; min-height: 0;">
                <div class="tab-content h-100" id="customerMovementTabsContent" style="overflow: hidden; display: flex; flex-direction: column;">
                    @* --- تبويب: المبيعات (الافتراضي) --- *@
                    <div class="tab-pane fade h-100" id="tab-agg" role="tabpanel" style="display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                        <div class="table-responsive w-100" style="flex: 1; overflow-y: auto; min-height: 0;">
                            <table class="table table-sm table-striped table-compact table-hover mb-0 w-100">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>التاريخ</th>
                                        <th>نوع المستند</th>
                                        <th>رقم المستند</th>
                                        <th class="text-end">مدين</th>
                                        <th class="text-end">دائن</th>
                                        <th class="text-end">الرصيد</th>
                                        <th>ملاحظات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-2">
                                            <small>لم يتم ربط جدول الحركة المجمعة بعد.</small>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* --- باقي التبويبات (بنفس التصميم المضغوط) --- *@
                    <div class="tab-pane fade show active h-100" id="tab-sales" role="tabpanel" style="display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                        <div class="table-responsive w-100" style="flex: 1; overflow-y: auto; min-height: 0;">
                            <table class="table table-sm table-striped table-compact mb-0 w-100">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>رقم الفاتورة</th>
                                        <th>التاريخ</th>
                                        <th>الوقت</th>
                                        <th>المخزن</th>
                                        <th class="text-end">الصافي</th>
                                        <th>الحالة</th>
                                        <th>مرحل؟</th>
                                        <th>إجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (salesInvoices != null && salesInvoices.Any())
                                    {
                                        @foreach (var invoice in salesInvoices)
                                        {
                                            <tr>
