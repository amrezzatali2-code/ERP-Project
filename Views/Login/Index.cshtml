@model ERP.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "تسجيل الدخول";

    // =========================================================
    // متغير: قائمة المستخدمين القادمة من الكنترولر (ViewBag.Users)
    // شكلها: { Id, Name }
    // =========================================================
    var users = ViewBag.Users as IEnumerable<dynamic>;
}

<div class="container mt-5" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-md-5 col-sm-10 col-lg-4">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                @* =========================
                   رأس الكارت
                   ========================= *@
                <div class="card-header text-center py-3 login-header">
                    <h5 class="mb-0 fw-bold">تسجيل الدخول إلى النظام</h5>
                    <div class="small opacity-75 mt-1">اختر اسم المستخدم ثم أدخل كلمة المرور</div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Index" method="post" novalidate>
                        @Html.AntiForgeryToken()

                        @* =========================
                           ملخص الأخطاء
                           ========================= *@
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3 d-none" id="valSummary"></div>

                        @* =========================
                           اسم المستخدم — قائمة منسدلة مع فوكس كامل عند الفتح
                           ========================= *@
                        <div class="mb-3">
                            <label asp-for="UserName" class="form-label fw-semibold"></label>

                            <div class="input-group">
                                <span class="input-group-text bg-light">👤</span>

                                <select asp-for="UserName"
                                        id="UserName"
                                        class="form-select login-username-select"
                                        autofocus>
                                    <option value="">اختر اسم المستخدم...</option>
                                    @if (users != null)
                                    {
                                        foreach (var u in users)
                                        {
                                            <option value="@u.Name">@u.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        @* =========================
                           كلمة المرور
                           ========================= *@
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold"></label>

                            <div class="input-group">
                                <span class="input-group-text bg-light">🔒</span>

                                <input asp-for="Password"
                                       id="Password"
                                       class="form-control"
                                       type="password"
                                       autocomplete="current-password"
                                       placeholder="أدخل كلمة المرور..." />
                            </div>

                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        @* =========================
                           زر الدخول
                           ========================= *@
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-3">
                            دخول
                        </button>

                        @* =========================
                           رابط رجوع (لو فيه ReturnUrl)
                           - مش إلزامي: بس مفيد أثناء التنقل
                           ========================= *@
                        @if (!string.IsNullOrWhiteSpace(Model?.ReturnUrl))
                        {
                            <input type="hidden" asp-for="ReturnUrl" />
                        }
                    </form>
                </div>

                @* =========================
                   فوتر بسيط
                   ========================= *@
                <div class="card-footer text-center small text-muted py-2">
                    ERP - نظام إدارة الموارد
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // =========================================================
        // تحسين بسيط + تنقل بانتر: اسم المستخدم → كلمة المرور → دخول
        // =========================================================
        document.addEventListener('DOMContentLoaded', function () {

            const summary = document.getElementById('valSummary');
            if (summary) {
                const hasText = (summary.textContent || '').trim().length > 0;
                if (hasText) summary.classList.remove('d-none');
            }

            const userSelect = document.getElementById('UserName');
            const passwordInput = document.getElementById('Password');
            const loginForm = userSelect && userSelect.closest('form');

            if (userSelect) userSelect.focus();

            // في قائمة الاسم: انتر → الانتقال إلى كلمة المرور
            if (userSelect) {
                userSelect.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        if (passwordInput) passwordInput.focus();
                    }
                });
            }

            // في كلمة المرور: انتر يرسل النموذج (دخول)
            if (passwordInput && loginForm) {
                passwordInput.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        loginForm.submit();
                    }
                });
            }
        });
    </script>

    <style>
        .login-header {
            background: linear-gradient(90deg, #0d6efd 0%, #0dcaf0 100%);
            color: #fff;
        }
        /* قائمة اسم المستخدم: ظهور واضح للسهم وحجم مريح */
        .login-username-select {
            cursor: pointer;
            min-height: 2.5rem;
        }
        .login-username-select:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
        }
    </style>
}
