@model ERP.Models.PurchasePolicyRule
@{
    ViewData["Title"] = "تفاصيل سياسة شراء";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container-fluid mt-3" dir="rtl">
    <h4 class="mb-3">@ViewData["Title"]</h4>
    <dl class="row">
        <dt class="col-sm-3">كود</dt>
        <dd class="col-sm-9">@Model.Id</dd>
        <dt class="col-sm-3">مفعّل</dt>
        <dd class="col-sm-9">@(Model.Enabled ? "نعم" : "لا")</dd>
        <dt class="col-sm-3">نوع القاعدة</dt>
        <dd class="col-sm-9">@Model.RuleType</dd>
        <dt class="col-sm-3">مقارنة</dt>
        <dd class="col-sm-9">@Model.CompareOp</dd>
        <dt class="col-sm-3">DiffExact</dt>
        <dd class="col-sm-9">@Model.DiffExact</dd>
        <dt class="col-sm-3">TargetPercent</dt>
        <dd class="col-sm-9">@Model.TargetPercent</dd>
        <dt class="col-sm-3">StockBelowPercent</dt>
        <dd class="col-sm-9">@Model.StockBelowPercent</dd>
        <dt class="col-sm-3">Tolerance</dt>
        <dd class="col-sm-9">@Model.Tolerance</dd>
        <dt class="col-sm-3">Action</dt>
        <dd class="col-sm-9">@Model.Action</dd>
        <dt class="col-sm-3">ترتيب</dt>
        <dd class="col-sm-9">@Model.SortOrder</dd>
        <dt class="col-sm-3">تاريخ الإنشاء</dt>
        <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    </dl>
    <a asp-action="Index" class="btn btn-erp btn-erp-secondary">العودة للقائمة</a>
</div>
