@model ERP.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = Model.LevelName;
    bool hasAnyData = Model.CustomersCount > 0 || Model.ProductsCount > 0 || Model.SalesInvoicesMonthCount > 0 || Model.SalesInvoicesTodayCount > 0
        || Model.PurchaseInvoicesMonthCount > 0 || Model.RecentItems.Any();
}
<div class="container-fluid py-3" dir="rtl">
    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h3 class="mb-0">@Model.LevelName</h3>
            @if (!string.IsNullOrEmpty(Model.UserDisplayName))
            {
                <small class="text-muted">مرحباً، @Model.UserDisplayName</small>
            }
        </div>
        @if (!hasAnyData)
        {
            <div class="alert alert-info border-0 shadow-sm mt-2 mb-0" role="alert">
                <strong>مرحباً بك!</strong>
                @if (Model.Level == "sales")
                {
                    <span>أضف عملاءك، ثم أنشئ أول فاتورة مبيعات. ستظهر إحصائياتك الشخصية هنا تلقائياً.</span>
                }
                else
                {
                    <span>أضف العملاء والأصناف، ثم ابدأ بتسجيل الفواتير. ستظهر ملخصاتك وإحصائياتك هنا.</span>
                }
            </div>
        }
    </div>

    @* البطاقات الرئيسية: عدد العملاء | عدد الفواتير | مبيعات الشهر | عدد أصناف المبيعات *@
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">عدد العملاء</h6>
                            <h3 class="mb-0">@Model.CustomersCount.ToString("N0")</h3>
                        </div>
                        <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                            <span class="fw-bold text-primary">👥</span>
                        </div>
                    </div>
                    <small class="text-muted d-block mt-2">@(Model.Level == "sales" ? "عملائي" : "إجمالي العملاء النشطين")</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">عدد الفواتير</h6>
                            <h3 class="mb-0">@Model.SalesInvoicesMonthCount.ToString("N0")</h3>
                        </div>
                        <div class="rounded-circle bg-success bg-opacity-10 p-3">
                            <span class="fw-bold text-success">📄</span>
                        </div>
                    </div>
                    <small class="text-muted d-block mt-2">فواتير الشهر الحالي</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">مبيعات الشهر</h6>
                            <h3 class="mb-0">@Model.SalesInvoicesMonthTotal.ToString("N2")</h3>
                        </div>
                        <div class="rounded-circle bg-info bg-opacity-10 p-3">
                            <span class="fw-bold text-info">📈</span>
                        </div>
                    </div>
                    <small class="text-muted d-block mt-2">ج.م (مبلغ البيع)</small>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">عدد أصناف المبيعات</h6>
                            <h3 class="mb-0">@Model.SalesProductsSoldCount.ToString("N0")</h3>
                        </div>
                        <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                            <span class="fw-bold text-warning">📦</span>
                        </div>
                    </div>
                    <small class="text-muted d-block mt-2">أصناف متميزة مباعة هذا الشهر</small>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Level != "sales")
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">مشتريات الشهر</h6>
                                <h3 class="mb-0">@Model.PurchaseInvoicesMonthCount.ToString("N0")</h3>
                            </div>
                            <div class="rounded-circle bg-secondary bg-opacity-10 p-3">
                                <span class="fw-bold text-secondary">🛒</span>
                            </div>
                        </div>
                        <small class="text-muted d-block mt-2">@Model.PurchaseInvoicesMonthTotal.ToString("N2") ج.م</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">إيصالات الشهر</h6>
                                <h3 class="mb-0">@Model.CashReceiptsMonthTotal.ToString("N2")</h3>
                            </div>
                            <div class="rounded-circle bg-success bg-opacity-10 p-3">
                                <span class="fw-bold text-success">💰</span>
                            </div>
                        </div>
                        <small class="text-muted d-block mt-2">إيصالات قبض</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">مدفوعات الشهر</h6>
                                <h3 class="mb-0">@Model.CashPaymentsMonthTotal.ToString("N2")</h3>
                            </div>
                            <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                                <span class="fw-bold text-danger">💳</span>
                            </div>
                        </div>
                        <small class="text-muted d-block mt-2">أوامر دفع</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">أصناف نفدت</h6>
                                <h3 class="mb-0">@Model.LowStockProductsCount.ToString("N0")</h3>
                            </div>
                            <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                                <span class="fw-bold text-warning">⚠️</span>
                            </div>
                        </div>
                        <small class="text-muted d-block mt-2">أصناف بلا رصيد</small>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.ProfitMonth.HasValue && Model.Level == "owner")
    {
        <div class="row g-3 mb-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="text-muted mb-1">الربح التقديري للشهر (مبيعات - مشتريات)</h6>
                        <h2 class="mb-0 @(Model.ProfitMonth >= 0 ? "text-success" : "text-danger")">@Model.ProfitMonth.Value.ToString("N2") ج.م</h2>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0">
                    <h6 class="mb-0">@(Model.Level == "sales" ? "مبيعاتي الأخيرة" : "مبيعات آخر 7 أيام")</h6>
                </div>
                <div class="card-body">
                    <div class="border rounded-3 bg-light position-relative" style="height:220px;">
                        <canvas id="dashboardSalesChart" height="220"></canvas>
                        @if (!Model.ChartData.Any())
                        {
                            <div class="position-absolute top-50 start-50 translate-middle text-center text-muted">
                                <small>بعد إضافة مبيعات، سيتوفر رسم بياني لتحليل الأداء</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0">
                    <h6 class="mb-0">أحدث العمليات</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table mb-0 table-sm align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>النوع</th>
                                <th>الطرف</th>
                                <th class="text-end">المبلغ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentItems.Any())
                            {
                                @foreach (var r in Model.RecentItems.Take(8))
                                {
                                    <tr>
                                        <td>@r.Type</td>
                                        <td class="text-truncate" style="max-width:100px">@r.PartyName</td>
                                        <td class="text-end">@r.Amount.ToString("N2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-4">
                                        <div class="text-muted">
                                            <small class="d-block mb-1">لا توجد حركات حديثة</small>
                                            <small>@(Model.Level == "sales" ? "ستظهر هنا آخر فواتيرك بعد إصدارها" : "ستظهر هنا آخر الفواتير والإيصالات بعد التسجيل")</small>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-3 col-sm-6">
            <a asp-controller="Products" asp-action="Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 card-hover">
                    <div class="card-body text-center">
                        <h5 class="mb-1">قائمة الأصناف</h5>
                        <small class="text-muted d-block mb-2">إدارة الأصناف والأسعار</small>
                        <span class="badge bg-primary bg-opacity-10 text-primary border rounded-pill px-3 py-1">فتح</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a asp-controller="Customers" asp-action="Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 card-hover">
                    <div class="card-body text-center">
                        <h5 class="mb-1">العملاء</h5>
                        <small class="text-muted d-block mb-2">إدارة العملاء والموردين</small>
                        <span class="badge bg-primary bg-opacity-10 text-primary border rounded-pill px-3 py-1">فتح</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a asp-controller="SalesInvoices" asp-action="Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 card-hover">
                    <div class="card-body text-center">
                        <h5 class="mb-1">فواتير البيع</h5>
                        <small class="text-muted d-block mb-2">عرض وإنشاء فواتير</small>
                        <span class="badge bg-primary bg-opacity-10 text-primary border rounded-pill px-3 py-1">فتح</span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a asp-controller="Reports" asp-action="Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 card-hover">
                    <div class="card-body text-center">
                        <h5 class="mb-1">التقارير</h5>
                        <small class="text-muted d-block mb-2">ملخصات وإحصائيات</small>
                        <span class="badge bg-primary bg-opacity-10 text-primary border rounded-pill px-3 py-1">فتح</span>
                    </div>
                </div>
            </a>
        </div>
        @if (Model.Level == "owner" || Model.Level == "manager")
        {
            <div class="col-md-3 col-sm-6">
                <a asp-controller="Reports" asp-action="SalesPerformanceReport" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body text-center">
                            <h5 class="mb-1">تقرير أداء المبيعات</h5>
                            <small class="text-muted d-block mb-2">بالكاتب — فلاتر تاريخ ومنطقة ومحافظة وعملاء</small>
                            <span class="badge bg-success bg-opacity-10 text-success border rounded-pill px-3 py-1">فتح</span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>
<style>
    .card-hover:hover { transform: translateY(-2px); transition: transform 0.2s; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var chartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
            if (chartData && chartData.length > 0) {
                var ctx = document.getElementById('dashboardSalesChart');
                if (ctx) {
                    var labels = chartData.map(function(d) {
                        var parts = (d.date || '').split('-');
                        return parts.length >= 2 ? parts[2] + '/' + parts[1] : d.date;
                    });
                    var amounts = chartData.map(function(d) { return d.amount; });
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: 'المبيعات (ج.م)',
                                data: amounts,
                                borderColor: 'rgb(13, 110, 253)',
                                backgroundColor: 'rgba(13, 110, 253, 0.1)',
                                tension: 0.4,
                                fill: true
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: true, position: 'top' }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    ticks: { callback: function(v) { return v.toFixed(0); } }
                                }
                            }
                        }
                    });
                }
            }
        });
    </script>
}
