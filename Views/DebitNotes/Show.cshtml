@model ERP.Models.DebitNote

@{
    ViewData["Title"] = "إشعار خصم";
}

<h2 class="mb-3" dir="rtl">
    إشعار خصم — @Model.NoteNumber
</h2>

<div class="alert alert-info" dir="rtl">
    هذه صفحة مؤقتة لعرض رأس إشعار الخصم فقط.
    لاحقًا يمكن إضافة تفاصيل أخرى مثل حركة القيود المحاسبية المرتبطة بالإشعار.
</div>

<div class="row" dir="rtl">
    <div class="col-md-8">

        <table class="table table-bordered">
            <tr>
                <th>رقم الإشعار (داخلي)</th>
                <td>@Model.DebitNoteId</td>
            </tr>
            <tr>
                <th>رقم المستند</th>
                <td>@Model.NoteNumber</td>
            </tr>
            <tr>
                <th>تاريخ الإشعار</th>
                <td>@Model.NoteDate.ToString("yyyy-MM-dd")</td>
            </tr>
            <tr>
                <th>الطرف</th>
                <td>@Model.Customer?.CustomerName</td>
            </tr>
            <tr>
                <th>حساب الطرف</th>
                <td>@Model.Account?.AccountName</td>
            </tr>
            <tr>
                <th>الحساب المقابل</th>
                <td>@Model.OffsetAccount?.AccountName</td>
            </tr>
            <tr>
                <th>المبلغ</th>
                <td>@Model.Amount.ToString("N2")</td>
            </tr>
            <tr>
                <th>السبب</th>
                <td>@Model.Reason</td>
            </tr>
            <tr>
                <th>البيان</th>
                <td>@Model.Description</td>
            </tr>
        </table>

        <div class="d-flex justify-content-between mt-3">
            <a asp-action="Index" class="btn btn-secondary">رجوع للقائمة</a>
            <a asp-action="Edit" asp-route-id="@Model.DebitNoteId" class="btn btn-primary">تعديل الإشعار</a>
        </div>

    </div>
</div>
