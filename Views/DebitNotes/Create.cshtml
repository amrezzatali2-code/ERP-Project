@model ERP.Models.DebitNote

@{
    ViewData["Title"] = "إضافة إشعار خصم";
    bool lockCustomer = ViewBag.LockCustomer is bool b && b;
}

<div class="container" dir="rtl">
    <h2 class="mb-3">إشعار خصم</h2>

    @if (TempData["DebitNoteSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["DebitNoteSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["DebitNoteError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["DebitNoteError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <strong>يرجى تصحيح الأخطاء التالية:</strong>
            <ul class="mb-0">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="Create" method="post">
        <div class="card">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">رقم المستند</label>
                        @if (Model.DebitNoteId > 0)
                        {
                            <input type="text" class="form-control" value="@Model.DebitNoteId" readonly />
                        }
                        else
                        {
                            <input type="text" class="form-control" value="" readonly placeholder="سيتم توليده تلقائياً عند الحفظ" />
                            <small class="text-muted">رقم المستند = رقم الإشعار (ID) ويُولَّد تلقائياً عند الحفظ</small>
                        }
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NoteDate" class="form-label"></label>
                        <input asp-for="NoteDate" type="date" class="form-control" />
                        <span asp-validation-for="NoteDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">الحالة</label>
                        <input type="text" class="form-control" value="@(Model.IsPosted ? "مرحلة 1" : "غير مرحلة")" readonly />
                    </div>

                    <!-- الطرف (عند اختياره يُملأ حساب الطرف تلقائياً) -->
                    <div class="col-md-4">
                        <label asp-for="CustomerId" class="form-label"></label>
                        @if (lockCustomer)
                        {
                            <select asp-for="CustomerId" asp-items="ViewBag.CustomerId" class="form-select" id="customerSelect" disabled></select>
                            <input type="hidden" asp-for="CustomerId" />
                        }
                        else
                        {
                            <select asp-for="CustomerId" asp-items="ViewBag.CustomerId" class="form-select" id="customerSelect">
                                <option value="">-- اختر الطرف --</option>
                            </select>
                        }
                        <span asp-validation-for="CustomerId" class="text-danger"></span>
                    </div>
                    <!-- حساب الطرف (يتم تعبئته تلقائياً عند اختيار العميل) -->
                    <div class="col-md-4">
                        <label asp-for="AccountId" class="form-label"></label>
                        @if (lockCustomer)
                        {
                            <select asp-for="AccountId" asp-items="ViewBag.AccountId" class="form-select" id="accountIdSelect" disabled></select>
                            <input type="hidden" asp-for="AccountId" />
                        }
                        else
                        {
                            <select asp-for="AccountId" asp-items="ViewBag.AccountId" class="form-select" id="accountIdSelect">
                                <option value="">-- سيتم تعبئته تلقائياً --</option>
                            </select>
                        }
                        <span asp-validation-for="AccountId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Amount" class="form-label"></label>
                        <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>
                    <div class="col-md-8">
                        <label asp-for="Reason" class="form-label"></label>
                        <input asp-for="Reason" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <hr />
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">عودة للقائمة</a>
                    <button type="submit" class="btn btn-primary">حفظ وترحيل</button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function() {
            if (window.top !== window) {
                try {
                    window.top.postMessage({ type: 'erp-set-tab-title', title: 'إشعار خصم' }, '*');
                } catch (e) { /* تجاهل */ }
            }
        })();
    </script>
    <script>
        $(document).ready(function() {
            @if (Model.AccountId > 0)
            {
                <text>$('#accountIdSelect').val('@Model.AccountId');</text>
            }
            // عند اختيار الطرف، جلب حسابه وتعيين حساب الطرف تلقائياً
            $('#customerSelect').on('change', function() {
                var customerId = $(this).val();
                var accountSelect = $('#accountIdSelect');
                if (!customerId || customerId === '') {
                    accountSelect.val('');
                    return;
                }
                $.ajax({
                    url: '@Url.Action("GetCustomerAccount", "DebitNotes")',
                    type: 'GET',
                    data: { customerId: customerId },
                    success: function(response) {
                        if (response && response.success && response.accountId) {
                            accountSelect.val(response.accountId);
                        } else {
                            accountSelect.val('');
                            if (response && response.message) {
                                alert(response.message);
                            } else {
                                alert('هذا العميل غير مربوط بحساب محاسبي. يرجى ربطه بحساب أولاً.');
                            }
                        }
                    },
                    error: function() {
                        accountSelect.val('');
                        alert('حدث خطأ أثناء جلب بيانات العميل.');
                    }
                });
            });
        });
    </script>
}
