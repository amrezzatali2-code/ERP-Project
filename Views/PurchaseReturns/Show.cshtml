@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.PurchaseReturn

@{
    // عنوان التاب
    ViewData["Title"] = Model.PRetId == 0
        ? "مرتجع مشتريات جديد"
        : $"مرتجع مشتريات — رقم {Model.PRetId}";
}

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/invoice-cards.css")" />
    <style>
        /* تنسيق مرتجع الشراء — مطبّق مباشرة لضمان الظهور (حتى داخل التاب/iframe) */
        .invoice-page { background-color: #f3f6fb; min-height: 100vh; padding-bottom: 2rem; }
        div.card.invoice-side-card,
        div.card.invoice-header-card,
        div.card.invoice-product-card,
        div.card.invoice-Add-card,
        div.card.invoice-lines-card,
        div.card.invoice-totals-card {
            border: 1px solid #a5b4fc !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(59,130,246,.12) !important;
            overflow: hidden;
        }
        .invoice-header-bar {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            padding: 0.5rem 1rem;
            font-weight: 600;
        }
        .invoice-header-bar h5, .invoice-header-bar h6 { margin-bottom: 0; font-size: 1rem; color: #fff !important; }
        .invoice-details-card .card-header,
        .invoice-Add-card .card-header,
        .invoice-product-card .card-header,
        .invoice-lines-card .card-header,
        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            padding: 0.55rem 1rem;
        }
        .invoice-product-card .card-header h6,
        .invoice-side-card .card-header h6 { color: #fff !important; margin-bottom: 0; }
        .invoice-lines-header,
        .invoice-lines-header th {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #fff !important;
        }
        .invoice-lines-header th { border-color: #0b5ed7 !important; }
        .invoice-page .invoice-header-card .form-control,
        .invoice-page .invoice-header-card .form-select,
        .invoice-page .invoice-product-card .form-control,
        .invoice-page .invoice-product-card .form-select,
        .invoice-page .invoice-Add-card .form-control,
        .invoice-page .invoice-Add-card .form-select,
        .invoice-page .invoice-totals-card .form-control,
        .invoice-page .invoice-totals-card .form-select { border-color: #94a3b8 !important; }
        .return-line-field { max-width: 5.5rem; }
        .badge-status-draft { background-color: #6f42c1; }
        .badge-status-notposted { background-color: #343a40; }
    </style>
}

<div class="invoice-page" dir="rtl">
    <div class="container-fluid pt-3">

        <div class="row g-3">

            @* =========================
               العمود الرئيسي (الهيدر + المورد + الأصناف + الإجماليات)
               ========================= *@
            <div class="col-lg-10">

                @* ====================================================
                   1) كارت بيانات مرتجع المشتريات + المورد + المخزن
                   ==================================================== *@
                <div class="card shadow-sm mb-2 invoice-header-card">

                    @{
                        // متغير: هل المرتجع جديد ولا موجود فعلاً
                        bool isNewReturn = Model == null || Model.PRetId == 0;
                        bool hasReturn = !isNewReturn;

                        // متغير: نص تاريخ المرتجع
                        string returnDateText = hasReturn
                        ? Model.PRetDate.ToString("d/M/yyyy")
                        : "";

                        // متغير: وقت الإنشاء من CreatedAt
                        string returnTimeText = hasReturn
                        ? Model.CreatedAt.ToLocalTime().ToString("HH:mm")
                        : "";
                    }

                    <div class="invoice-header-bar d-flex justify-content-between align-items-center flex-wrap gap-2">
                        @* الجزء الأيسر: عنوان المرتجع + المستخدم *@
                        <div>
                            <h5 class="mb-1">
                                @if (isNewReturn)
                                {
                                    @:مرتجع مشتريات
                                }
                                else
                                {
                                    @:مرتجع مشتريات
                                    <span class="small opacity-100">رقم @Model.PRetId</span>
                                }
                            </h5>

                            @if (!isNewReturn && !string.IsNullOrWhiteSpace(Model.CreatedBy))
                            {
                                <div class="small opacity-100">
                                    أُنشئ بواسطة:
                                    <span class="fw-semibold">@Model.CreatedBy</span>
                                </div>
                            }
                        </div>

                        @* الجزء الأيمن: حالة المرتجع *@
                        <div class="text-end">
                            @if (isNewReturn)
                            {
                                <span class="text-white fw-semibold">
                                    اضغط على "مرتجع جديد".
                                </span>
                            }
                            else if (string.Equals(Model.Status, "Posted", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="text-white fw-semibold">
                                    مرتجع مرحّل
                                </span>
                            }
                            else if (string.Equals(Model.Status, "Cancelled", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="text-white fw-semibold">
                                    مرتجع ملغى
                                </span>
                            }
                            else
                            {
                                <span class="text-white fw-semibold">
                                    مرتجع مفتوح
                                </span>
                            }
                        </div>
                    </div>

                    <div class="card-body">

                        <div class="row g-3 align-items-start">

                            @* كود المورد *@
                            <div class="col-lg-2 col-md-3">
                                <label class="form-label form-label-sm">كود المورد</label>
                                <input id="CustomerCodeDisplay"
                                       class="form-control form-control-sm text-center invoice-small-input"
                                       readonly />

                                <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                                <input type="hidden" id="PRetId" value="@Model.PRetId" />
                            </div>

                            @* اسم المورد + أوتوكومبليت (نفس فكرة فاتورة المشتريات) *@
                            <div class="col-lg-5 col-md-6">
                                <label for="CustomerNameInput" class="form-label form-label-sm">اسم المورد</label>
                                <input id="CustomerNameInput"
                                       class="form-control form-control-sm"
                                       placeholder="اكتب اسم المورد أو جزء منه للبحث..."
                                       list="customersList"
                                       autocomplete="off"
                                       data-lock-posted="1" />

                                <datalist id="customersList">
                                    @* هتتملي من الكونترولر بنفس طريقة فاتورة المشتريات *@
                                    @if (ViewBag.Customers != null)
                                    {
                                        foreach (var c in ViewBag.Customers)
                                        {
                                            <option value="@c.Name"
                                                    data-id="@c.Id"
                                                    data-user="@c.UserName"
                                                    data-phone="@c.Phone"
                                                    data-address="@c.Address">
                                            </option>
                                        }
                                    }
                                </datalist>

                                <small id="CustomerSummaryText"
                                       class="text-muted customer-summary-line d-block mt-1">
                                    @* سيتم ملؤه بجملة مختصرة عن المورد *@
                                </small>
                            </div>

                           

                            @* المخزن *@
                            <div class="col-lg-2 col-md-3">
                                <label class="form-label form-label-sm" for="WarehouseId">المخزن</label>
                                <select asp-for="WarehouseId"
                                        asp-items="ViewBag.Warehouses"
                                        class="form-select form-select-sm"
                                        data-lock-posted="1">
                                    <option value="">اختر المخزن...</option>
                                </select>
                            </div>

                            @* التاريخ والوقت *@
                            <div class="col-lg-3 col-md-6">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">تاريخ المرتجع</label>
                                        <input id="ReturnDateDisplay" class="form-control form-control-sm text-center"
                                               value="@returnDateText"
                                               readonly />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">وقت الإنشاء</label>
                                        <input id="ReturnTimeDisplay" class="form-control form-control-sm text-center"
                                               value="@returnTimeText"
                                               readonly />
                                    </div>
                                </div>
                            </div>

                        </div>

                        <br />

                        <div class="row g-3">
                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">رقم المرتجع</label>
                                <input id="ReturnNumberDisplay" class="form-control form-control-sm text-center fw-semibold"
                                       value="@(Model.PRetId > 0 ? Model.PRetId.ToString() : "—")" readonly />
                            </div>
                            <div class="col-lg-3 col-md-4">
                                <label class="form-label form-label-sm">حالة المرتجع</label>
                                @{
                                    int? stage = ViewBag.ReturnStage as int?;
                                    string statusDisplayValue = Model.Status switch
                                    {
                                        "Draft" => "غير مرحلة",
                                        "Posted" => (stage.HasValue ? $"مرحلة {stage.Value}" : "مرحّل"),
                                        "Cancelled" => "ملغى",
                                        _ => string.IsNullOrWhiteSpace(Model.Status) ? (Model.IsPosted ? (stage.HasValue ? $"مرحلة {stage.Value}" : "مرحّل") : "غير مرحلة") : Model.Status
                                    };
                                }
                                <input id="ReturnStatusDisplay" class="form-control form-control-sm text-center" value="@statusDisplayValue" readonly />
                            </div>
                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">مرحّل؟</label>
                                <input id="ReturnIsPostedDisplay" class="form-control form-control-sm text-center"
                                       value="@(Model.IsPosted ? "نعم" : "لا")" readonly />
                            </div>
                            <div class="col-lg-4 col-md-4">
                                <label class="form-label form-label-sm">رقم فاتورة الشراء</label>
                                <input type="number" id="PurchaseInvoiceIdInput" class="form-control form-control-sm text-center"
                                       value="@(Model.RefPIId?.ToString() ?? "")" placeholder="أدخل رقم الفاتورة"
                                       data-lock-posted="1" />
                                <input type="hidden" asp-for="RefPIId" id="RefPIId" />
                            </div>
                        </div>

                        <div class="row g-3 mt-2">
                            <div class="col-lg-4 col-md-4">
                                <label class="form-label form-label-sm">الهاتف</label>
                                <input id="CustomerPhone" class="form-control form-control-sm" readonly />
                            </div>
                            <div class="col-lg-4 col-md-4">
                                <label class="form-label form-label-sm">المحافظة</label>
                                <input id="CustomerGovernorate" class="form-control form-control-sm" readonly />
                            </div>
                            <div class="col-lg-8 col-md-8">
                                <label class="form-label form-label-sm">العنوان</label>
                                <input id="CustomerAddress" class="form-control form-control-sm" readonly />
                            </div>
                        </div>
                    </div>
                </div>

                @* =====================================================
                   2) كارت بيانات الصنف (مخزون + سياسة شراء) — حدود الكارت فقط مثل طلب الشراء
                   ===================================================== *@
                <div class="card shadow-sm mb-3 invoice-product-card">
                    <div class="card-body">

                        @* الصف العلوي: أرقام سريعة عن الصنف *@
                        <div class="row g-3 mb-3">
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الكمية المتاحة في هذا المخزن</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">إجمالي الكمية في كل المخازن</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الصنف عليه كوتة؟</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="بدون كوتة"
                                       readonly />
                            </div>

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الخصم المرجّح للصنف %</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>
                        </div>

                        <br />

                        <div class="row g-3 align-items-end">
                            <div class="col-md-6">
                                <label class="form-label form-label-sm d-block">فترة حركة الصنف</label>
                                <div class="d-flex gap-2">
                                    <input type="date"
                                           id="prodReportFrom"
                                           class="form-control form-control-sm" />
                                    <input type="date"
                                           id="prodReportTo"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label form-label-sm d-block text-md-end">
                                    تقارير سريعة للصنف
                                </label>

                                <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                                    <button type="button"
                                            class="btn btn-outline-secondary btn-sm"
                                            id="btnShowSalesReport">
                                        مبيعات الصنف
                                    </button>

                                    <button type="button"
                                            class="btn btn-outline-secondary btn-sm"
                                            id="btnShowPRReport">
                                        طلبات الشراء للصنف
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                @* =====================================================
                   4) كارت إدخال الصنف + جدول السطور (بدون هيدر — حدود الكارت فقط)
                   ===================================================== *@
                <div class="card shadow-sm mb-3 invoice-Add-card">
                    <div class="card-body">
                        <div class="row g-2 align-items-end mb-3">
                            <div class="col-lg-5 col-md-4">
                                <label class="form-label form-label-sm">اختر صنف من فاتورة الشراء</label>
                                <select id="InvoiceItemSelect"
                                        class="form-select form-select-sm"
                                        data-lock-posted="@((Model?.IsPosted == true) ? "1" : "0")">
                                    <option value="">-- اختر صنف من الفاتورة --</option>
                                </select>
                            </div>

                            <div class="col-auto">
                                <label class="form-label form-label-sm">الكمية المرتجعة</label>
                                <input type="number"
                                       id="ReturnQtyInput"
                                       class="form-control form-control-sm text-center return-line-field"
                                       placeholder="0"
                                       min="1"
                                       data-lock-posted="@((Model?.IsPosted == true) ? "1" : "0")" />
                            </div>

                            <div class="col-auto">
                                <label class="form-label form-label-sm">الكمية في الفاتورة</label>
                                <input type="number"
                                       id="InvoiceQtyDisplay"
                                       class="form-control form-control-sm text-center bg-light return-line-field"
                                       readonly />
                            </div>

                            <div class="col-auto">
                                <label class="form-label form-label-sm">التشغيلة</label>
                                <input type="text"
                                       id="ReturnBatchDisplay"
                                       class="form-control form-control-sm text-center bg-light return-line-field"
                                       readonly />
                            </div>

                            <div class="col-auto">
                                <label class="form-label form-label-sm">تاريخ الصلاحية</label>
                                <input type="text"
                                       id="ReturnExpiryDisplay"
                                       class="form-control form-control-sm text-center bg-light return-line-field"
                                       readonly />
                            </div>

                            <div class="col-lg-2 col-md-4 d-grid">
                                <label class="form-label form-label-sm">&nbsp;</label>
                                <button type="button"
                                        id="btnAddReturnLine"
                                        class="btn btn-primary btn-sm"
                                        data-lock-posted="@((Model?.IsPosted == true) ? "1" : "0")">
                                    إضافة
                                </button>
                            </div>
                        </div>

                        <div class="erp-table-wrapper mb-0">
                            <table class="table table-sm table-striped table-hover mb-0 erp-table">
                                <thead class="invoice-lines-header">
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">الكمية</th>
                                        <th class="text-center">تكلفة الوحدة</th>
                                        <th class="text-center">سعر الجمهور</th>
                                        <th class="text-center">قيمة السطر</th>
                                        <th class="text-center">مسح</th>
                                    </tr>
                                </thead>
                                <tbody id="PurchaseReturnLinesTableBody">
                                    @if (Model.Lines != null && Model.Lines.Any())
                                    {
                                        var _prProdNames = ViewBag.ProdNames as Dictionary<int, string>;
                                        foreach (var line in Model.Lines.OrderBy(l => l.LineNo))
                                        {
                                            var prodName = (_prProdNames != null && _prProdNames.TryGetValue(line.ProdId, out var _pn)) ? _pn : line.ProdId.ToString();
                                            <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                <td class="text-center">@line.LineNo</td>
                                                <td>@prodName</td>
                                                <td class="text-center">@line.Qty</td>
                                                <td class="text-center">@line.UnitCost.ToString("0.00")</td>
                                                <td class="text-center">@line.PriceRetail.ToString("0.00")</td>
                                                <td class="text-center">@((line.Qty * line.UnitCost).ToString("0.00"))</td>
                                                <td class="text-center">
                                                    <button type="button" class="btn btn-danger btn-sm btnRemoveReturnLine"
                                                            data-line-no="@line.LineNo" data-pret-id="@Model.PRetId"
                                                            data-lock-posted="@((Model?.IsPosted == true) ? "1" : "0")" title="مسح السطر">🗑</button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr id="PurchaseReturnLinesEmptyRow">
                                            <td colspan="7" class="text-center text-muted py-4">لا توجد سطور مسجَّلة لهذا المرتجع.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @* ====================================
                   6) ملخص المرتجع (الإجماليات)
                   ==================================== *@
                @{
                    // عدد السطور
                    int totalLines = Model.Lines?.Count ?? 0;

                    // عدد الأصناف المميزة
                    int totalItems = 0;
                    if (Model.Lines != null)
                    {
                        var prodIds = new HashSet<int>();
                        foreach (var line in Model.Lines)
                        {
                            var propProd = line.GetType().GetProperty("ProdId");
                            if (propProd != null)
                            {
                                var val = propProd.GetValue(line);
                                if (val is int pid)
                                    prodIds.Add(pid);
                            }
                        }
                        totalItems = prodIds.Count;
                    }

                    // إجمالي الكمية (Qty أو QtyRequested)
                    int totalQty = 0;
                    if (Model.Lines != null)
                    {
                        foreach (var line in Model.Lines)
                        {
                            var pQty = line.GetType().GetProperty("Qty")
                            ?? line.GetType().GetProperty("QtyRequested");

                            if (pQty != null)
                            {
                                var val = pQty.GetValue(line);
                                if (val is int q)
                                    totalQty += q;
                            }
                        }
                    }

                    // إجماليات من الهيدر
                    decimal totalRetail = Model.ItemsTotal;                // إجمالي قبل الخصم
                    decimal totalAfterDiscount = Model.ItemsTotal - Model.DiscountTotal;
                    decimal taxAmount = Model.TaxTotal;
                    decimal totalAfterDiscountAndTax = totalAfterDiscount + taxAmount;
                    decimal netTotal = Model.NetTotal;                     // صافي المرتجع
                }

                <div class="card shadow-sm invoice-totals-card">
                    <div class="card-body">

                        <div class="row g-3 align-items-center mb-2">

                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">عدد السطور</span>
                                    <span class="badge bg-light text-dark summary-badge">
                                        @totalLines
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">عدد الأصناف</span>
                                    <span class="badge bg-light text-dark summary-badge">
                                        @totalItems
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">إجمالي الكمية المرتجعة</span>
                                    <span class="badge bg-light text-dark summary-badge">
                                        @totalQty
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">إجمالي قبل الخصم</span>
                                    <span id="ItemsTotalBadge" class="badge bg-light text-dark summary-badge">@totalRetail.ToString("0.00")</span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">الإجمالي بعد الخصم</span>
                                    <span id="AfterDiscountBadge" class="badge bg-light text-dark summary-badge">@totalAfterDiscount.ToString("0.00")</span>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">قيمة الضريبة</span>
                                    <span id="TaxAmountBadge" class="badge bg-info text-dark summary-badge">@taxAmount.ToString("0.00")</span>
                                </div>
                            </div>
                        </div>
                        <hr class="my-3" />
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <span class="small text-muted d-block">الصافي النهائي للمرتجع</span>
                                <h3 id="NetTotalBadge" class="mb-0 text-success">@netTotal.ToString("0.00")</h3>
                            </div>

                            <div class="text-end small text-muted">
                                @if (Model.UpdatedAt.HasValue)
                                {
                                    <div>
                                        آخر تعديل:
                                        <span class="fw-semibold">
                                            @Model.UpdatedAt.Value.ToLocalTime().ToString("d/M/yyyy HH:mm")
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>  @* نهاية العمود الرئيسي *@


            @* =========================
               العمود الجانبي (أزرار الحركة) — بنفس ترتيب مرتجع البيع
               ========================= *@
            <div class="col-lg-2">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات مرتجع المشتريات</h6>
                    </div>

                    <input type="hidden" id="ReturnIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />

                    <div class="card-body">
                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">
                        @{
                            int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
                            int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
                            int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
                            int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;
                            int currentId = Model?.PRetId ?? 0;
                            bool hasAnyReturns = navFirst.HasValue && navLast.HasValue && navFirst.Value > 0 && navLast.Value > 0;
                            int? prevEffective = (currentId == 0) ? navLast : navPrev;
                            int? nextEffective = (currentId == 0) ? navFirst : navNext;
                            bool canFirst = hasAnyReturns && navFirst.HasValue && navFirst.Value > 0 && navFirst.Value != currentId;
                            bool canLast = hasAnyReturns && navLast.HasValue && navLast.Value > 0 && navLast.Value != currentId;
                            bool canPrev = hasAnyReturns && prevEffective.HasValue && prevEffective.Value > 0 && prevEffective.Value != currentId;
                            bool canNext = hasAnyReturns && nextEffective.HasValue && nextEffective.Value > 0 && nextEffective.Value != currentId;
                        }

                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button" id="btnFirstReturn" class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pr-ret-show-tab" data-tab-title="مرتجع مشتريات"
                                    data-base-url="@Url.Action("Edit", "PurchaseReturns", new { id = (navFirst ?? 0) })"
                                    data-id="@(navFirst ?? 0)" title="أول مرتجع" @(canFirst ? "" : "disabled")>⏮</button>
                            <button type="button" id="btnPrevReturn" class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pr-ret-show-tab" data-tab-title="مرتجع مشتريات"
                                    data-base-url="@Url.Action("Edit", "PurchaseReturns", new { id = (prevEffective ?? 0) })"
                                    data-id="@(prevEffective ?? 0)" title="المرتجع السابق" @(canPrev ? "" : "disabled")>◀</button>
                            <button type="button" id="btnNextReturn" class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pr-ret-show-tab" data-tab-title="مرتجع مشتريات"
                                    data-base-url="@Url.Action("Edit", "PurchaseReturns", new { id = (nextEffective ?? 0) })"
                                    data-id="@(nextEffective ?? 0)" title="المرتجع التالي" @(canNext ? "" : "disabled")>▶</button>
                            <button type="button" id="btnLastReturn" class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pr-ret-show-tab" data-tab-title="مرتجع مشتريات"
                                    data-base-url="@Url.Action("Edit", "PurchaseReturns", new { id = (navLast ?? 0) })"
                                    data-id="@(navLast ?? 0)" title="آخر مرتجع" @(canLast ? "" : "disabled")>⏭</button>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <input type="number" id="NavReturnSearchInput" class="form-control form-control-sm" placeholder="بحث برقم المرتجع" />
                            <button type="button" id="btnNavReturnSearch" class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-tab-id="pr-ret-show-tab" data-tab-title="مرتجع مشتريات"
                                    data-base-url="@Url.Action("Edit", "PurchaseReturns")">بحث</button>
                        </div>

                        <hr class="my-1" />

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           data-tab-id="pr-ret-show-tab" data-tab-title="مرتجع مشتريات"
                           data-url="@Url.Action("Create", "PurchaseReturns", new { frame = 1 })">
                            ➕ مرتجع جديد
                        </a>

                        <button type="button" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" id="btnSaveReturnHeader" data-lock-posted="1">
                            💾 حفظ المرتجع
                        </button>

                        <button type="button" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" id="btnPostReturn" data-lock-posted="1">
                            📤 ترحيل المرتجع
                        </button>

                        <div id="postReturnMsg" class="small mt-2"></div>

                        <button type="button" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" id="btnOpenReturn">
                            ⏪ فتح المرتجع
                        </button>

                        <button type="button" class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100" id="btnClearReturnLines"
                                data-pret-id="@Model.PRetId" data-lock-posted="1">
                            🗑️ مسح كل أصناف المرتجع
                        </button>

                        <button type="button" id="btnPrintReturn" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" onclick="window.print()">
                            🖨️ طباعة المرتجع
                        </button>

                        <hr class="my-1" />

                        <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" asp-action="Index">⬅️ الرجوع لقائمة مرتجعات المشتريات</a>

                        <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" id="btnEditReturn" asp-action="Edit" asp-route-id="@Model.PRetId">✏️ تعديل المرتجع</a>
                    </div>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>

@section Scripts {
    <script>
        // دالة مساعدة: تملأ الحقول من option معين في الـ datalist
        function fillCustomerFromOption(opt) {
            // متغيرات: عناصر الشاشة الخاصة بالمورد
            var idInput = document.getElementById('CustomerId');              // كود المورد (للحفظ)
            var codeDisplay = document.getElementById('CustomerCodeDisplay'); // كود المورد المعروض
            var phoneInput = document.getElementById('CustomerPhone');        // الهاتف
            var addressInput = document.getElementById('CustomerAddress');    // العنوان
            var summary = document.getElementById('CustomerSummaryText');     // سطر ملخّص صغير

            if (!opt) {
                idInput.value = '';
                codeDisplay.value = '';
                phoneInput.value = '';
                addressInput.value = '';
                summary.textContent = '';
                return;
            }

            // متغيرات: البيانات المخزنة في option داخل الـ datalist
            var id = opt.getAttribute('data-id') || '';
            var user = opt.getAttribute('data-user') || '';
            var phone = opt.getAttribute('data-phone') || '';
            var address = opt.getAttribute('data-address') || '';

            idInput.value = id;
            codeDisplay.value = id;
            phoneInput.value = phone;
            addressInput.value = address;

            var parts = [];
            if (user) parts.push('مستخدم مرتبط: ' + user);
            if (phone) parts.push('هاتف: ' + phone);
            summary.textContent = parts.join(' — ');
        }

        document.addEventListener('DOMContentLoaded', function () {

            // =========================================================
            // دوال مساعدة: إدارة حالة الترحيل (مثل مرتجع البيع)
            // =========================================================
            function isReturnPosted() {
                const flag = document.getElementById("ReturnIsPostedFlag");
                return flag && flag.value === "1";
            }
            function setReturnPosted(posted) {
                const flag = document.getElementById("ReturnIsPostedFlag");
                if (flag) flag.value = posted ? "1" : "0";
            }
            function applyPostedUiLock() {
                const posted = isReturnPosted();
                const lockables = document.querySelectorAll('[data-lock-posted="1"]');
                lockables.forEach(el => {
                    if (!el.dataset.origDisabled) el.dataset.origDisabled = el.disabled ? "1" : "0";
                    if (!el.dataset.origReadonly && (el.tagName === "INPUT" || el.tagName === "TEXTAREA" || el.tagName === "SELECT")) el.dataset.origReadonly = el.readOnly ? "1" : "0";
                    if (!el.dataset.origTabIndex) el.dataset.origTabIndex = el.getAttribute("tabindex") ?? "";
                    const tag = (el.tagName || "").toUpperCase();
                    if (tag === "BUTTON") el.disabled = posted || el.dataset.origDisabled === "1";
                    else if (tag === "SELECT" || tag === "INPUT" || tag === "TEXTAREA") {
                        const origReadonly = el.dataset.origReadonly === "1";
                        el.readOnly = posted || origReadonly;
                        if (posted && !origReadonly) el.setAttribute("tabindex", "-1");
                        else { const orig = el.dataset.origTabIndex; if (orig === "") el.removeAttribute("tabindex"); else el.setAttribute("tabindex", orig); }
                    }
                });
            }
            function getReturnStatusDisplay(status) {
                if (!status) return 'غير مرحلة';
                switch (String(status)) { case 'Draft': return 'غير مرحلة'; case 'Posted': return 'مرحّل'; case 'Cancelled': return 'ملغى'; default: return status; }
            }
            applyPostedUiLock();
            (function () {
                const posted = @Model.IsPosted.ToString().ToLower();
                if (posted === true && typeof setReturnPosted === "function") { setReturnPosted(true); if (typeof applyPostedUiLock === "function") applyPostedUiLock(); }
            })();

            // متغيرات: عناصر الأوتوكومبليت الخاصة بالمورد
            var customerInput = document.getElementById('CustomerNameInput');
            var dataList = document.getElementById('customersList');

            function findOptionByName(name) {
                if (!name) return null;
                var options = dataList.options;
                for (var i = 0; i < options.length; i++) {
                    if (options[i].value === name) return options[i];
                }
                return null;
            }

            function findOptionById(id) {
                if (!id) return null;
                var options = dataList.options;
                for (var i = 0; i < options.length; i++) {
                    if (options[i].getAttribute('data-id') == id) {
                        return options[i];
                    }
                }
                return null;
            }

            // عند اختيار اسم مورد من الأوتوكومبليت
            customerInput.addEventListener('change', function () {
                var opt = findOptionByName(customerInput.value);
                fillCustomerFromOption(opt);
            });

            // تهيئة الشاشة عند الفتح – لو في كود مورد محفوظ في المرتجع
            var initialCustomerId = '@Model.CustomerId';
            if (initialCustomerId) {
                var opt = findOptionById(initialCustomerId);
                if (opt) {
                    customerInput.value = opt.value;
                    fillCustomerFromOption(opt);
                }
            }

            // =========================================================
            // جلب أصناف فاتورة الشراء عند إدخال رقم الفاتورة
            // =========================================================
            var invoiceIdInput = document.getElementById('PurchaseInvoiceIdInput');
            var invoiceIdHidden = document.getElementById('RefPIId');
            var itemSelect = document.getElementById('InvoiceItemSelect');
            var returnQtyInput = document.getElementById('ReturnQtyInput');
            var invoiceQtyDisplay = document.getElementById('InvoiceQtyDisplay');
            var returnBatchDisplay = document.getElementById('ReturnBatchDisplay');
            var returnExpiryDisplay = document.getElementById('ReturnExpiryDisplay');
            var btnAddReturnLine = document.getElementById('btnAddReturnLine');

            var invoiceItems = []; // متغير: قائمة أصناف الفاتورة

            async function loadInvoiceByNumber() {
                var invoiceId = parseInt(invoiceIdInput.value || '0', 10);
                
                if (invoiceId <= 0) {
                    invoiceIdHidden.value = '';
                    itemSelect.innerHTML = '<option value="">-- اختر صنف من الفاتورة --</option>';
                    invoiceItems = [];
                    return;
                }

                try {
                    var response = await fetch(`/PurchaseReturns/GetInvoiceItems?invoiceId=${invoiceId}`);
                    var data = await response.json();

                    if (!data.ok) {
                        alert(data.message || 'حدث خطأ في جلب بيانات الفاتورة.');
                        return;
                    }

                    // حفظ رقم الفاتورة
                    invoiceIdHidden.value = invoiceId.toString();

                    // تحديث بيانات المورد بالكامل حسب الفاتورة (الاسم، الهاتف، العنوان، إلخ)
                    if (data.customerId) {
                        document.getElementById('CustomerId').value = data.customerId;
                        document.getElementById('CustomerCodeDisplay').value = data.customerId;
                        var opt = findOptionById(data.customerId.toString());
                        if (opt) {
                            customerInput.value = opt.value;
                            fillCustomerFromOption(opt);
                        }
                    }
                    if (data.warehouseId) {
                        document.getElementById('WarehouseId').value = data.warehouseId;
                    }

                    // إذا كان المرتجع محفوظاً، تحديث الهيدر بالمورد والمخزن من الفاتورة (حتى ينجح إضافة السطر)
                    var pretIdEl = document.getElementById('PRetId');
                    var pretId = pretIdEl ? parseInt(pretIdEl.value || '0', 10) : 0;
                    if (pretId > 0 && data.customerId && data.warehouseId) {
                        try {
                            var shRes = await fetch('@Url.Action("SaveHeader", "PurchaseReturns")', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                                body: JSON.stringify({ pretId: pretId, customerId: data.customerId, warehouseId: data.warehouseId, refPIId: invoiceId })
                            });
                            var shTxt = await shRes.text();
                            var shData = null;
                            if (shTxt) { try { shData = JSON.parse(shTxt); } catch (e) {} }
                            if (!shRes.ok || !shData || !shData.success) {
                                if (typeof console !== 'undefined' && console.warn) console.warn('SaveHeader on PI load', shRes.status, shTxt?.substring(0, 200));
                            }
                        } catch (e) { if (typeof console !== 'undefined' && console.warn) console.warn('SaveHeader on PI load', e); }
                    }

                    // تحديث قائمة الأصناف
                    invoiceItems = data.items || [];
                    itemSelect.innerHTML = '<option value="">-- اختر صنف من الفاتورة --</option>';
                    
                    invoiceItems.forEach(function(item, index) {
                        var option = document.createElement('option');
                        option.value = index.toString();
                        var remaining = (item.remaining != null) ? item.remaining : (item.qty - (item.alreadyReturned || 0));
                        option.textContent = item.prodName + ' - كمية في الفاتورة: ' + item.qty + ' - متبقي للمرتجع: ' + remaining + ' - تشغيلة: ' + (item.batchNo || 'بدون');
                        option.setAttribute('data-prodId', item.prodId);
                        option.setAttribute('data-lineNo', item.lineNo);
                        option.setAttribute('data-qty', item.qty);
                        option.setAttribute('data-remaining', remaining);
                        option.setAttribute('data-batchNo', item.batchNo || '');
                        option.setAttribute('data-expiry', item.expiry || '');
                        option.setAttribute('data-priceRetail', item.priceRetail);
                        option.setAttribute('data-unitCost', item.unitCost != null ? item.unitCost : '0');
                        option.setAttribute('data-purchaseDiscountPct', item.purchaseDiscountPct != null ? item.purchaseDiscountPct : '0');
                        itemSelect.appendChild(option);
                    });

                    // إعادة تعيين الحقول
                    returnQtyInput.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';

                } catch (error) {
                    console.error('Error loading invoice items:', error);
                    alert('حدث خطأ في جلب بيانات الفاتورة.');
                }
            }

            // عند الضغط على Enter في حقل رقم الفاتورة
            invoiceIdInput.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    loadInvoiceByNumber();
                }
            });

            // عند تغيير رقم الفاتورة (فقدان التركيز)
            invoiceIdInput.addEventListener('change', loadInvoiceByNumber);

            // عند اختيار صنف من القائمة
            itemSelect.addEventListener('change', function () {
                var selectedIndex = parseInt(itemSelect.value || '-1', 10);
                
                if (selectedIndex < 0 || selectedIndex >= invoiceItems.length) {
                    returnQtyInput.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';
                    return;
                }

                var item = invoiceItems[selectedIndex];
                var remaining = (item.remaining != null) ? item.remaining : (item.qty - (item.alreadyReturned || 0));
                invoiceQtyDisplay.value = item.qty;
                returnBatchDisplay.value = item.batchNo || '';
                returnExpiryDisplay.value = item.expiry || '';
                returnQtyInput.value = remaining > 0 ? remaining : '';
                returnQtyInput.max = remaining; // حد أقصى = المتبقي للمرتجع
            });

            // =========================================================
            // الانتقال بانتر (مثل مرتجع البيع): صنف → كمية → إضافة
            // =========================================================
            var enterFields = [itemSelect, returnQtyInput];
            enterFields.forEach(function (el) {
                if (!el) return;
                if (el.dataset.enterBound === '1') return;
                el.dataset.enterBound = '1';
                el.addEventListener('focus', function () { if (typeof this.select === 'function') setTimeout(function () { el.select(); }, 0); });
                el.addEventListener('keydown', function (e) {
                    if (e.key !== 'Enter') return;
                    e.preventDefault();
                    var idx = enterFields.indexOf(el);
                    var next = enterFields[idx + 1];
                    if (next) { next.focus(); if (next.select) next.select(); }
                    else if (btnAddReturnLine) btnAddReturnLine.focus();
                });
            });
            if (btnAddReturnLine && !btnAddReturnLine.dataset.enterClickBound) {
                btnAddReturnLine.dataset.enterClickBound = '1';
                btnAddReturnLine.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') { e.preventDefault(); btnAddReturnLine.click(); }
                });
            }

            function refreshReturnLinesAndTotals(data) {
                var tbody = document.getElementById('PurchaseReturnLinesTableBody');
                if (!tbody) return;
                var lines = (data && data.lines) ? data.lines : [];
                var totals = (data && data.totals) ? data.totals : {};
                while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
                if (lines.length === 0) {
                    var tr = document.createElement('tr');
                    tr.id = 'PurchaseReturnLinesEmptyRow';
                    tr.innerHTML = '<td colspan="7" class="text-center text-muted py-4">لا توجد سطور مسجَّلة لهذا المرتجع.</td>';
                    tbody.appendChild(tr);
                } else {
                    var pretId = parseInt(document.getElementById('PRetId').value || '0', 10);
                    var lockPosted = (typeof isReturnPosted === "function" && isReturnPosted()) ? '1' : '0';
                    lines.forEach(function(l) {
                        var tr = document.createElement('tr');
                        tr.setAttribute('data-line-no', l.lineNo);
                        tr.setAttribute('data-prodid', l.prodId);
                        var btn = '<button type="button" class="btn btn-danger btn-sm btnRemoveReturnLine" data-line-no="' + l.lineNo + '" data-pret-id="' + pretId + '" data-lock-posted="' + lockPosted + '" title="مسح السطر">\uD83D\uDDD1</button>';
                        var lv = (l.lineValue != null) ? Number(l.lineValue).toFixed(2) : (l.qty && l.unitCost != null) ? (l.qty * l.unitCost).toFixed(2) : '';
                        tr.innerHTML = '<td class="text-center">' + l.lineNo + '</td><td>' + (l.prodName || '') + '</td><td class="text-center">' + l.qty + '</td><td class="text-center">' + (l.unitCost != null ? Number(l.unitCost).toFixed(2) : '') + '</td><td class="text-center">' + (l.priceRetail != null ? Number(l.priceRetail).toFixed(2) : '') + '</td><td class="text-center">' + lv + '</td><td class="text-center">' + btn + '</td>';
                        tbody.appendChild(tr);
                    });
                }
                var b = document.getElementById('ItemsTotalBadge');
                if (b && totals.itemsTotal != null) b.textContent = Number(totals.itemsTotal).toFixed(2);
                b = document.getElementById('AfterDiscountBadge');
                if (b && totals.itemsTotal != null && totals.discountTotal != null) b.textContent = (Number(totals.itemsTotal) - Number(totals.discountTotal)).toFixed(2);
                b = document.getElementById('TaxAmountBadge');
                if (b && totals.taxTotal != null) b.textContent = Number(totals.taxTotal).toFixed(2);
                b = document.getElementById('NetTotalBadge');
                if (b && totals.netTotal != null) b.textContent = Number(totals.netTotal).toFixed(2);
            }

            // عند إضافة سطر للمرتجع
            btnAddReturnLine.addEventListener('click', async function () {
                var selectedIndex = parseInt(itemSelect.value || '-1', 10);
                var returnQty = parseInt(returnQtyInput.value || '0', 10);
                var returnId = parseInt(document.getElementById('PRetId').value || '0', 10);

                if (selectedIndex < 0 || selectedIndex >= invoiceItems.length) {
                    alert('من فضلك اختر صنف من الفاتورة.');
                    return;
                }
                if (returnQty <= 0) {
                    alert('الكمية المرتجعة يجب أن تكون أكبر من صفر.');
                    return;
                }
                var item = invoiceItems[selectedIndex];
                var remaining = (item.remaining != null) ? item.remaining : (item.qty - (item.alreadyReturned || 0));
                if (remaining <= 0) {
                    alert('تم إرجاع كامل كمية هذا السطر من الفاتورة مسبقاً. لا يمكن إضافة المزيد.');
                    return;
                }
                if (returnQty > remaining) {
                    alert('الكمية المرتجعة لا يمكن أن تتجاوز المتبقي للمرتجع (' + remaining + ').');
                    return;
                }
                if (returnId <= 0) {
                    alert('يجب حفظ المرتجع أولاً قبل إضافة الأصناف.');
                    return;
                }

                var refPIId = parseInt(document.getElementById('RefPIId').value || '0', 10) || null;
                var dto = { PRetId: returnId, ProdId: item.prodId, Qty: returnQty, BatchNo: item.batchNo || null, ExpiryText: item.expiry || null, UnitCost: item.unitCost != null ? item.unitCost : 0, PurchaseDiscountPct: item.purchaseDiscountPct != null ? item.purchaseDiscountPct : 0, PriceRetail: item.priceRetail != null ? item.priceRetail : 0, RefPIId: refPIId, RefPILineNo: item.lineNo };
                btnAddReturnLine.disabled = true;
                try {
                    var res = await fetch('@Url.Action("AddLineJson", "PurchaseReturns")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                        body: JSON.stringify(dto)
                    });
                    var txt = await res.text();
                    var data = null;
                    if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                    if (!res.ok || !data || !data.ok) {
                        if (typeof console !== 'undefined' && console.warn) console.warn('AddLineJson failed', res.status, res.statusText, (txt || '').substring(0, 400));
                        alert((data && data.message) ? data.message : 'فشل إضافة السطر.');
                        return;
                    }
                    refreshReturnLinesAndTotals(data);
                    // تحديث المتبقي للمرتجع في الصنف المضاف (للعرض عند إعادة الاختيار)
                    item.alreadyReturned = (item.alreadyReturned || 0) + returnQty;
                    item.remaining = item.qty - item.alreadyReturned;
                    if (item.remaining < 0) item.remaining = 0;
                    returnQtyInput.value = '';
                    itemSelect.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';
                } catch (e) {
                    console.error(e);
                    alert('حدث خطأ أثناء إضافة السطر.');
                } finally {
                    btnAddReturnLine.disabled = false;
                }
            });

            // تهيئة رقم الفاتورة إذا كان موجوداً
            var initialInvoiceId = '@(Model.RefPIId?.ToString() ?? "")';
            if (initialInvoiceId) {
                invoiceIdInput.value = initialInvoiceId;
                invoiceIdInput.dispatchEvent(new Event('change'));
            }

            // =========================================================
            // زر حفظ المرتجع (SaveHeader) — يحفظ الهيدر ويسجّل رقم المرتجع
            // =========================================================
            var btnSaveReturn = document.getElementById('btnSaveReturnHeader');
            var editBaseUrl = '@Url.Action("Edit", "PurchaseReturns")';
            if (btnSaveReturn) {
                btnSaveReturn.addEventListener('click', async function () {
                    var pretId = parseInt(document.getElementById('PRetId').value || '0', 10);
                    var customerId = parseInt(document.getElementById('CustomerId').value || '0', 10);
                    var warehouseId = parseInt(document.getElementById('WarehouseId').value || '0', 10);
                    var refPiInput = document.getElementById('RefPIId');
                    var refPIId = 0;
                    if (refPiInput && refPiInput.value.trim() !== '') {
                        var v = parseInt(refPiInput.value.trim(), 10);
                        if (!isNaN(v)) refPIId = v;
                    }

                    if (!customerId || !warehouseId) {
                        alert('من فضلك اختر المورد والمخزن أولاً قبل حفظ المرتجع.');
                        return;
                    }

                    var dto = { pretId: pretId, customerId: customerId, warehouseId: warehouseId, refPIId: refPIId || null };
                    btnSaveReturn.disabled = true;
                    try {
                        var response = await fetch('@Url.Action("SaveHeader", "PurchaseReturns")', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(dto)
                        });
                        var txt = await response.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!response.ok) {
                            alert((data && data.message) ? data.message : 'حدث خطأ أثناء حفظ المرتجع.');
                            return;
                        }
                        if (!data || !data.success) {
                            alert((data && data.message) ? data.message : 'تعذر حفظ المرتجع.');
                            return;
                        }
                        var newId = data.pretId || 0;
                        document.getElementById('PRetId').value = newId.toString();
                        var dateEl = document.getElementById('ReturnDateDisplay');
                        var timeEl = document.getElementById('ReturnTimeDisplay');
                        if (dateEl && data.returnDate) dateEl.value = data.returnDate;
                        if (timeEl && data.returnTime) timeEl.value = data.returnTime;
                        var editLink = document.getElementById('btnEditReturn');
                        if (editLink) editLink.href = editBaseUrl + '/' + newId;
                        var clearBtn = document.getElementById('btnClearReturnLines');
                        if (clearBtn) clearBtn.setAttribute('data-pret-id', newId.toString());
                        var numDisp = document.getElementById('ReturnNumberDisplay');
                        if (numDisp) numDisp.value = newId.toString();
                        var statusEl = document.getElementById('ReturnStatusDisplay');
                        if (statusEl && data.status !== undefined) statusEl.value = getReturnStatusDisplay(data.status);
                        // مثل مرتجع البيع: بدون رسالة تنبيه، فوكس على حقل الصنف مباشرة
                        var prodSelect = document.getElementById('InvoiceItemSelect');
                        if (prodSelect) { prodSelect.focus(); prodSelect.click(); }
                    } catch (err) {
                        console.error(err);
                        alert('تعذر الاتصال بالخادم لحفظ المرتجع.');
                    } finally {
                        btnSaveReturn.disabled = false;
                    }
                });
            }

            document.addEventListener('click', async function(ev) {
                var btn = ev.target.closest('.btnRemoveReturnLine');
                if (!btn) return;
                ev.preventDefault();
                var pretId = parseInt(btn.getAttribute('data-pret-id') || '0', 10);
                var lineNo = parseInt(btn.getAttribute('data-line-no') || '0', 10);
                if (pretId <= 0 || lineNo <= 0) return;
                if (typeof isReturnPosted === "function" && isReturnPosted()) { alert('المرتجع مترحّل ومقفول. استخدم زر (فتح المرتجع) أولاً.'); return; }
                if (!confirm('هل تريد مسح هذا السطر؟ (مسح سطر المرتجع يزيد المخزون — عكس الشراء)')) return;
                btn.disabled = true;
                try {
                    var res = await fetch('@Url.Action("RemoveLineJson", "PurchaseReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ PRetId: pretId, LineNo: lineNo }) });
                    var txt = await res.text();
                    var data = null;
                    if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                    if (!res.ok || !data || !data.ok) { alert((data && data.message) ? data.message : 'فشل مسح السطر.'); return; }
                    refreshReturnLinesAndTotals(data);
                } catch (e) { console.error(e); alert('حدث خطأ أثناء مسح السطر.'); }
                finally { btn.disabled = false; }
            });

            var btnClear = document.getElementById('btnClearReturnLines');
            if (btnClear) {
                btnClear.addEventListener('click', async function() {
                    var pretId = parseInt(document.getElementById('PRetId').value || btnClear.getAttribute('data-pret-id') || '0', 10);
                    if (pretId <= 0) { alert('يجب حفظ المرتجع أولاً.'); return; }
                    if (typeof isReturnPosted === "function" && isReturnPosted()) { alert('المرتجع مترحّل. استخدم "فتح المرتجع" أولاً.'); return; }
                    if (!confirm('هل تريد مسح كل أصناف المرتجع؟')) return;
                    btnClear.disabled = true;
                    try {
                        var res = await fetch('@Url.Action("ClearLinesJson", "PurchaseReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ PRetId: pretId }) });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) { alert((data && data.message) ? data.message : 'فشل مسح الأصناف.'); return; }
                        refreshReturnLinesAndTotals(data);
                        var isPostedEl = document.getElementById('ReturnIsPostedDisplay');
                        if (isPostedEl) isPostedEl.value = 'لا';
                    } catch (e) { console.error(e); alert('حدث خطأ.'); }
                    finally { btnClear.disabled = false; }
                });
            }

            var btnPost = document.getElementById('btnPostReturn');
            var postMsg = document.getElementById('postReturnMsg');
            var statusDisplay = document.getElementById('ReturnStatusDisplay');
            if (btnPost) {
                var serverIsPosted = @Model.IsPosted.ToString().ToLower();
                if (serverIsPosted) {
                    btnPost.disabled = true;
                    btnPost.innerHTML = "✅ تم ترحيل المرتجع";
                    if (postMsg) {
                        postMsg.textContent = "هذا المرتجع مترحّل بالفعل.";
                        postMsg.className = "small mt-2 text-muted";
                    }
                }
                btnPost.addEventListener('click', async function() {
                    var pretId = parseInt(document.getElementById('PRetId').value || '0', 10);
                    if (pretId <= 0) {
                        if (postMsg) { postMsg.textContent = "يجب حفظ المرتجع أولاً قبل الترحيل."; postMsg.className = "small mt-2 text-danger"; }
                        return;
                    }
                    if (!confirm('هل تريد ترحيل هذا المرتجع؟')) return;
                    btnPost.disabled = true;
                    var postSuccess = false;
                    try {
                        // حفظ الهيدر أولاً (لتطبيق أي تعديل مثل تغيير المورد)
                        var customerId = parseInt(document.getElementById('CustomerId').value || '0', 10);
                        var warehouseId = parseInt(document.getElementById('WarehouseId').value || '0', 10);
                        var refPiInput = document.getElementById('RefPIId');
                        var refPIId = 0;
                        if (refPiInput && refPiInput.value.trim() !== '') {
                            var v = parseInt(refPiInput.value.trim(), 10);
                            if (!isNaN(v)) refPIId = v;
                        }
                        if (customerId <= 0 || warehouseId <= 0) {
                            if (postMsg) { postMsg.textContent = "يجب اختيار المورد والمخزن قبل الترحيل."; postMsg.className = "small mt-2 text-danger"; }
                            btnPost.disabled = false;
                            return;
                        }
                        {
                            var saveRes = await fetch('@Url.Action("SaveHeader", "PurchaseReturns")', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ pretId: pretId, customerId: customerId, warehouseId: warehouseId, refPIId: refPIId || null })
                            });
                            var saveTxt = await saveRes.text();
                            var saveData = null;
                            if (saveTxt) { try { saveData = JSON.parse(saveTxt); } catch (e) {} }
                            if (!saveRes.ok || !saveData || !saveData.success) {
                                if (postMsg) { postMsg.textContent = (saveData && saveData.message) ? saveData.message : 'تعذر حفظ التعديلات قبل الترحيل.'; postMsg.className = 'small mt-2 text-danger'; }
                                btnPost.disabled = false;
                                return;
                            }
                        }
                        var res = await fetch('@Url.Action("PostReturn", "PurchaseReturns")?id=' + pretId, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) {
                            if (postMsg) { postMsg.textContent = (data && data.message) ? data.message : 'فشل الترحيل.'; postMsg.className = "small mt-2 text-danger"; }
                            return;
                        }
                        postSuccess = true;
                        if (typeof setReturnPosted === "function") setReturnPosted(true);
                        if (typeof applyPostedUiLock === "function") applyPostedUiLock();
                        if (statusDisplay)
                            statusDisplay.value = (data && data.postedLabel) ? data.postedLabel : ('مرحلة ' + (data && data.stage != null ? data.stage : 1));
                        var isPostedEl = document.getElementById('ReturnIsPostedDisplay');
                        if (isPostedEl) isPostedEl.value = 'نعم';
                        btnPost.innerHTML = "✅ تم ترحيل المرتجع";
                        btnPost.disabled = true;
                        var btnOpen = document.getElementById('btnOpenReturn');
                        if (btnOpen) btnOpen.disabled = false;
                        if (postMsg) {
                            postMsg.textContent = (data && data.message) ? data.message : 'تم ترحيل المرتجع بنجاح.';
                            postMsg.className = "small mt-2 text-success";
                        }
                    } catch (e) { console.error(e); if (postMsg) { postMsg.textContent = 'حدث خطأ أثناء الترحيل.'; postMsg.className = "small mt-2 text-danger"; } }
                    finally { if (!postSuccess) btnPost.disabled = false; }
                });
            }

            var btnOpen = document.getElementById('btnOpenReturn');
            if (btnOpen) {
                var serverIsPostedPR = @Model.IsPosted.ToString().ToLower();
                if (!serverIsPostedPR)
                    btnOpen.disabled = true;
                btnOpen.addEventListener('click', async function() {
                    if (btnOpen.disabled) return;
                    var pretId = parseInt(document.getElementById('PRetId').value || '0', 10);
                    if (pretId <= 0) {
                        if (postMsg) { postMsg.textContent = "اختر مرتجعاً أولاً."; postMsg.className = "small mt-2 text-danger"; }
                        return;
                    }
                    if (!confirm('هل تريد فتح المرتجع (إلغاء الترحيل)؟')) return;
                    btnOpen.disabled = true;
                    try {
                        var res = await fetch('@Url.Action("OpenReturn", "PurchaseReturns")?id=' + pretId, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) {
                            if (postMsg) { postMsg.textContent = (data && data.message) ? data.message : 'فشل فتح المرتجع.'; postMsg.className = "small mt-2 text-danger"; }
                            return;
                        }
                        if (typeof setReturnPosted === "function") setReturnPosted(false);
                        if (typeof applyPostedUiLock === "function") applyPostedUiLock();
                        var isPostedEl = document.getElementById('ReturnIsPostedDisplay');
                        if (isPostedEl) isPostedEl.value = 'لا';
                        if (statusDisplay) statusDisplay.value = (data && data.postedLabel) ? data.postedLabel : 'مفتوحة للتعديل';
                        var btnPost = document.getElementById('btnPostReturn');
                        if (btnPost) { btnPost.disabled = false; btnPost.innerHTML = "📤 ترحيل المرتجع"; }
                        if (postMsg) {
                            postMsg.textContent = (data && data.message) ? data.message : 'تم فتح المرتجع للتعديل.';
                            postMsg.className = "small mt-2 text-success";
                        }
                    } catch (e) { console.error(e); if (postMsg) { postMsg.textContent = 'حدث خطأ.'; postMsg.className = "small mt-2 text-danger"; } }
                    finally { btnOpen.disabled = false; }
                });
            }

            // =========================================================
            // سكربت التنقل (أول/سابق/تالي/آخر + البحث) — مثل مرتجع البيع
            // =========================================================
            const editBaseUrlPR = '@Url.Action("Edit", "PurchaseReturns")';

            function openReturnPR(id) {
                id = parseInt(id || '0', 10);
                if (!id || id <= 0) return;
                const base = editBaseUrlPR.replace(/\/$/, '');
                const url = base + '/' + encodeURIComponent(id);
                window.location.href = url;
            }

            function bindNavButtonPR(btnId) {
                const btn = document.getElementById(btnId);
                if (!btn) return;
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    if (btn.disabled) return;
                    const id = btn.getAttribute('data-id');
                    openReturnPR(id);
                });
            }

            bindNavButtonPR('btnFirstReturn');
            bindNavButtonPR('btnPrevReturn');
            bindNavButtonPR('btnNextReturn');
            bindNavButtonPR('btnLastReturn');

            const searchInputPR = document.getElementById('NavReturnSearchInput');
            const searchBtnPR = document.getElementById('btnNavReturnSearch');
            function doSearchPR() {
                const v = (searchInputPR?.value || '').trim();
                if (!v) return;
                openReturnPR(v);
            }
            searchBtnPR?.addEventListener('click', (e) => { e.preventDefault(); doSearchPR(); });
            searchInputPR?.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') { e.preventDefault(); doSearchPR(); }
            });
        });
    </script>
}
