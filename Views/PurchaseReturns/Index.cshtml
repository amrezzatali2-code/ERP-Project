@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<PurchaseReturn>

@{
    ViewData["Title"] = "قائمة مرتجعات الشراء";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "PurchaseReturns";

    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var searchMode = ((string?)ViewBag.SearchMode ?? "contains").Trim().ToLowerInvariant();
    if (searchMode == "startswith") searchMode = "starts";
    else if (searchMode == "endswith") searchMode = "ends";
    else if (searchMode != "starts" && searchMode != "ends") searchMode = "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "PRetDate";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
    int end = (ps == 0 || total == 0) ? total : Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;
    var dateField = (string?)ViewBag.DateField ?? "PRetDate";

    // فلاتر أعمدة (بنمط Excel)
    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_date = ViewBag.FilterCol_Date as string;
    string? filterCol_customerId = ViewBag.FilterCol_CustomerId as string;
    string? filterCol_customerIdExpr = ViewBag.FilterCol_CustomerIdExpr as string;
    string? filterCol_customer = ViewBag.FilterCol_Customer as string;
    string? filterCol_warehouse = ViewBag.FilterCol_Warehouse as string;
    string? filterCol_warehouseExpr = ViewBag.FilterCol_WarehouseExpr as string;
    string? filterCol_refpi = ViewBag.FilterCol_Refpi as string;
    string? filterCol_refpiExpr = ViewBag.FilterCol_RefpiExpr as string;
    string? filterCol_net = ViewBag.FilterCol_Net as string;
    string? filterCol_netExpr = ViewBag.FilterCol_NetExpr as string;
    string? filterCol_status = ViewBag.FilterCol_Status as string;
    string? filterCol_posted = ViewBag.FilterCol_Posted as string;
    string? filterCol_postedAt = ViewBag.FilterCol_PostedAt as string;
    string? filterCol_createdBy = ViewBag.FilterCol_CreatedBy as string;
    string? filterCol_createdAt = ViewBag.FilterCol_CreatedAt as string;
    string? filterCol_updatedAt = ViewBag.FilterCol_UpdatedAt as string;

    object PrRouteValues(int? pageNum = null, string? sortCol = null, string? sortDir = null) => new
    {
        search,
        searchBy,
        searchMode,
        sort = sortCol ?? sort,
        dir = sortDir ?? dir,
        page = pageNum ?? page,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        dateField,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_idExpr,
        filterCol_date,
        filterCol_customerId,
        filterCol_customerIdExpr,
        filterCol_customer,
        filterCol_warehouse,
        filterCol_warehouseExpr,
        filterCol_refpi,
        filterCol_refpiExpr,
        filterCol_net,
        filterCol_netExpr,
        filterCol_status,
        filterCol_posted,
        filterCol_postedAt,
        filterCol_createdBy,
        filterCol_createdAt,
        filterCol_updatedAt
    };

    string Link(int p) => Url.Action(action, controller, PrRouteValues(pageNum: p))!;

    string? FilterForCol(string colKey) =>
        colKey == "id" ? (!string.IsNullOrWhiteSpace(filterCol_idExpr) ? filterCol_idExpr : filterCol_id)
        : colKey == "customerId" ? (!string.IsNullOrWhiteSpace(filterCol_customerIdExpr) ? filterCol_customerIdExpr : filterCol_customerId)
        : colKey == "warehouse" ? (!string.IsNullOrWhiteSpace(filterCol_warehouseExpr) ? filterCol_warehouseExpr : filterCol_warehouse)
        : colKey == "refpi" ? (!string.IsNullOrWhiteSpace(filterCol_refpiExpr) ? filterCol_refpiExpr : filterCol_refpi)
        : colKey == "net" ? (!string.IsNullOrWhiteSpace(filterCol_netExpr) ? filterCol_netExpr : filterCol_net)
        : colKey == "date" ? filterCol_date
        : colKey == "customer" ? filterCol_customer
        : colKey == "status" ? filterCol_status
        : colKey == "posted" ? filterCol_posted
        : colKey == "postedAt" ? filterCol_postedAt
        : colKey == "createdBy" ? filterCol_createdBy
        : colKey == "createdAt" ? filterCol_createdAt
        : colKey == "updatedAt" ? filterCol_updatedAt
        : null;

    var n2 = System.Globalization.CultureInfo.InvariantCulture;
    decimal totalNetCards = ViewBag.TotalNetFiltered != null ? (decimal)ViewBag.TotalNetFiltered : 0m;

    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";
        var url = Url.Action(action, controller, PrRouteValues(pageNum: 1, sortCol: col, sortDir: newDir)) ?? "#";
        string icon = "⇅";
        if (isCurrent) icon = dir == "asc" ? "▲" : "▼";
        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0 fs-6 text-secondary">@ViewData["Title"]</h5>
    </div>

    @* ===== شريط الفلاتر الموحد (نمط قائمة فواتير المشتريات) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في مرتجعات الشراء</label>
                    <div class="d-flex flex-wrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" style="min-width:120px" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:160px;min-width:100px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>الكل</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>رقم المرتجع</option>
                            <option value="customer"@Html.Raw(searchBy == "customer" ? " selected" : "")>اسم الجهة</option>
                            <option value="status"@Html.Raw(searchBy == "status" ? " selected" : "")>الحالة</option>
                        </select>
                        <select name="searchMode" class="form-select form-select-arrow erp-filter-input order-first flex-shrink-0" style="max-width:130px;min-width:100px" title="طريقة المطابقة">
                            <option value="starts"@Html.Raw(searchMode == "starts" ? " selected" : "")>يبدأ بـ</option>
                            <option value="contains"@Html.Raw(searchMode == "contains" ? " selected" : "")>يحتوي</option>
                            <option value="ends"@Html.Raw(searchMode == "ends" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-2 justify-content-center w-100 mt-2">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_customerId)) { <input type="hidden" name="filterCol_customerId" value="@filterCol_customerId" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_customerIdExpr)) { <input type="hidden" name="filterCol_customerIdExpr" value="@filterCol_customerIdExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_customer)) { <input type="hidden" name="filterCol_customer" value="@filterCol_customer" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_warehouseExpr)) { <input type="hidden" name="filterCol_warehouseExpr" value="@filterCol_warehouseExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_refpi)) { <input type="hidden" name="filterCol_refpi" value="@filterCol_refpi" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_refpiExpr)) { <input type="hidden" name="filterCol_refpiExpr" value="@filterCol_refpiExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_net)) { <input type="hidden" name="filterCol_net" value="@filterCol_net" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_netExpr)) { <input type="hidden" name="filterCol_netExpr" value="@filterCol_netExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_status)) { <input type="hidden" name="filterCol_status" value="@filterCol_status" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_posted)) { <input type="hidden" name="filterCol_posted" value="@filterCol_posted" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_postedAt)) { <input type="hidden" name="filterCol_postedAt" value="@filterCol_postedAt" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_createdBy)) { <input type="hidden" name="filterCol_createdBy" value="@filterCol_createdBy" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_createdAt)) { <input type="hidden" name="filterCol_createdAt" value="@filterCol_createdAt" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_updatedAt)) { <input type="hidden" name="filterCol_updatedAt" value="@filterCol_updatedAt" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر رقم مرتجع من/إلى --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">من رقم مرتجع – إلى رقم مرتجع</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم (صفان مثل فواتير المشتريات) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModalPR">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalPR">اختيار الأعمدة</button>
                        <button type="button" id="btnPrintPR" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <span class="erp-list-toolbar-selected-actions d-inline-flex flex-wrap gap-2 align-items-center" role="group" aria-label="إجراءات المرتجع المحدد">
                            <button type="button" id="btnShowPR" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="عرض المرتجع">عرض</button>
                        </span>
                    </div>
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnBulkDelete">حذف المحدد</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف جميع مرتجعات الشراء</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="PurchaseReturns" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="visibleCols" value="" />
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="searchMode" value="@searchMode" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_customerId)) { <input type="hidden" name="filterCol_customerId" value="@filterCol_customerId" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_customerIdExpr)) { <input type="hidden" name="filterCol_customerIdExpr" value="@filterCol_customerIdExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_customer)) { <input type="hidden" name="filterCol_customer" value="@filterCol_customer" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_warehouseExpr)) { <input type="hidden" name="filterCol_warehouseExpr" value="@filterCol_warehouseExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_refpi)) { <input type="hidden" name="filterCol_refpi" value="@filterCol_refpi" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_refpiExpr)) { <input type="hidden" name="filterCol_refpiExpr" value="@filterCol_refpiExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_net)) { <input type="hidden" name="filterCol_net" value="@filterCol_net" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_netExpr)) { <input type="hidden" name="filterCol_netExpr" value="@filterCol_netExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_status)) { <input type="hidden" name="filterCol_status" value="@filterCol_status" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_posted)) { <input type="hidden" name="filterCol_posted" value="@filterCol_posted" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_postedAt)) { <input type="hidden" name="filterCol_postedAt" value="@filterCol_postedAt" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_createdBy)) { <input type="hidden" name="filterCol_createdBy" value="@filterCol_createdBy" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_createdAt)) { <input type="hidden" name="filterCol_createdAt" value="@filterCol_createdAt" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_updatedAt)) { <input type="hidden" name="filterCol_updatedAt" value="@filterCol_updatedAt" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;padding:0.3rem 0.5rem;" title="اختر صيغة التصدير">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                    <form id="formBulkDelete" asp-action="BulkDelete" asp-controller="PurchaseReturns" method="post" class="d-none">@Html.AntiForgeryToken()</form>
                    <form id="formDeleteAll" asp-action="DeleteAll" asp-controller="PurchaseReturns" method="post" class="d-none">@Html.AntiForgeryToken()</form>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row mt-2" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي العدد (بعد الفلترة)</div>
                    <div class="h4 mb-0 text-primary fw-bold">@total.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #15803d !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي قيمة المرتجعات</div>
                    <div class="h4 mb-0 text-success fw-bold">@totalNetCards.ToString("N2", n2)</div>
                </div>
            </div>
        </div>
    </div>

    @* ===== جدول مرتجعات الشراء (حاوية تمرير + رأس ثابت مثل فواتير المشتريات) ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0" dir="rtl">
        <div id="prTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="prTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th class="text-center no-print"
                        data-col="select"
                        data-col-fixed="true"
                        style="width:40px;">
                        <input type="checkbox"
                               id="chkAllRowsPR"
                               class="form-check-input" />
                    </th>

                    <th data-col="id">@filterableCol("id", "PRetId", "رقم المرتجع")</th>
                    <th data-col="date">@filterableCol("date", "PRetDate", "تاريخ المرتجع")</th>
                    <th data-col="customerId">@filterableCol("customerId", "CustomerId", "كود الجهة")</th>
                    <th data-col="customer">@filterableCol("customer", "Customer", "اسم الجهة")</th>
                    <th data-col="warehouse">@filterableCol("warehouse", "WarehouseId", "المخزن")</th>
                    <th data-col="refpi">@filterableCol("refpi", "RefPIId", "فاتورة الشراء المرجعية")</th>
                    <th data-col="net">@filterableCol("net", "NetTotal", "قيمة المرتجع")</th>
                    <th data-col="status">@filterableCol("status", "Status", "الحالة")</th>
                    <th data-col="posted">@filterableCol("posted", "IsPosted", "حالة الترحيل")</th>
                    <th data-col="postedAt">@filterableCol("postedAt", "PostedAt", "تاريخ الترحيل")</th>
                    <th data-col="createdBy">@filterableCol("createdBy", "CreatedBy", "أنشأه")</th>
                    <th data-col="createdAt">@filterableCol("createdAt", "CreatedAt", "تاريخ الإنشاء")</th>
                    <th data-col="updatedAt">@filterableCol("updatedAt", "UpdatedAt", "آخر تعديل")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="14" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var pr in Model.Items)
                    {
                        var showUrl = Url.Action("Edit", "PurchaseReturns", new { id = pr.PRetId, frame = 1 });
                        var whName = pr.Warehouse?.WarehouseName;
                        <tr class="erp-list-selectable-row" data-pret-id="@pr.PRetId" data-show-url="@showUrl" data-tab-title="مرتجع مشتريات">
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="form-check-input row-select"
