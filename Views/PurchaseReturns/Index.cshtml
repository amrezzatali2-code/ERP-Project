    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة (محاذاة RTL مثل فواتير المشتريات) ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print" dir="rtl">
        <small class="text-muted order-1">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2 order-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="searchMode" value="@searchMode" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
            }
            @if (toDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_customerId)) { <input type="hidden" name="filterCol_customerId" value="@filterCol_customerId" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_customerIdExpr)) { <input type="hidden" name="filterCol_customerIdExpr" value="@filterCol_customerIdExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_customer)) { <input type="hidden" name="filterCol_customer" value="@filterCol_customer" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_warehouseExpr)) { <input type="hidden" name="filterCol_warehouseExpr" value="@filterCol_warehouseExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_refpi)) { <input type="hidden" name="filterCol_refpi" value="@filterCol_refpi" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_refpiExpr)) { <input type="hidden" name="filterCol_refpiExpr" value="@filterCol_refpiExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_net)) { <input type="hidden" name="filterCol_net" value="@filterCol_net" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_netExpr)) { <input type="hidden" name="filterCol_netExpr" value="@filterCol_netExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_status)) { <input type="hidden" name="filterCol_status" value="@filterCol_status" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_posted)) { <input type="hidden" name="filterCol_posted" value="@filterCol_posted" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_postedAt)) { <input type="hidden" name="filterCol_postedAt" value="@filterCol_postedAt" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_createdBy)) { <input type="hidden" name="filterCol_createdBy" value="@filterCol_createdBy" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_createdAt)) { <input type="hidden" name="filterCol_createdAt" value="@filterCol_createdAt" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_updatedAt)) { <input type="hidden" name="filterCol_updatedAt" value="@filterCol_updatedAt" /> }
            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
            </select>
        </form>
    </div>

    @* ===== الترقيم ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

