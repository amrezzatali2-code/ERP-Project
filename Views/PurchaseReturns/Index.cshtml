@section Scripts {
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        (function () {
            function scrollToRtlStart(wrapperId) {
                const el = document.getElementById(wrapperId);
                if (!el) return;
                requestAnimationFrame(() => {
                    el.scrollLeft = el.scrollWidth - el.clientWidth;
                });
            }
            scrollToRtlStart("prTableScrollWrapper");
        })();

        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanelPR',
            tableId: 'prTable',
            wrapperId: 'prTableScrollWrapper',
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "PurchaseReturns")',
            defaultSort: 'PRetDate',
            defaultDir: 'desc',
            numericColumns: ['id', 'customerId', 'refpi', 'net']
        });

        document.getElementById("btnPrintPR")?.addEventListener("click", function () {
            window.print();
        });

        ERP.initListSelection({
            showButtonId: 'btnShowPR',
            idAttribute: 'data-pret-id',
            showUrlAttribute: 'data-show-url',
            tabTitleAttribute: 'data-tab-title',
            showTabId: 'pr-ret-show-tab',
            multiSelectCheckboxes: true
        });

        (function () {
            const table = document.getElementById("prTable");
            if (!table) return;

            const chkAll = document.getElementById("chkAllRowsPR");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const bulkBtn = document.getElementById("btnBulkDelete");
            const bulkForm = document.getElementById("formBulkDelete");

            bulkBtn?.addEventListener("click", function () {
                const checks = Array.from(rowsChk()).filter(cb => cb.checked);
                if (checks.length === 0) {
                    alert("من فضلك اختر على الأقل مرتجع واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف المرتجعات المحددة؟ سيتم حذف السطور التابعة لها أيضاً.")) {
                    return;
                }

                bulkForm.querySelectorAll("input[type='hidden'][name='ids']").forEach(h => h.remove());

                checks.forEach(cb => {
                    const input = document.createElement("input");
                    input.type = "hidden";
                    input.name = "ids";
                    input.value = cb.value;
                    bulkForm.appendChild(input);
                });

                bulkForm.submit();
            });

            const btnDeleteAll = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("formDeleteAll");
            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع مرتجعات الشراء وسطورها. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp = document.getElementById("codeFromInput");
            const toInp = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);

                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else url.searchParams.delete("fromCode");

                if (codeTo) url.searchParams.set("toCode", codeTo);
                else url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value = "";
                window.location.href = buildUrl("", "");
            });
        })();

        (function () {
            const table = document.getElementById("prTable");
            if (!table) return;

            const storageKey = "pr-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: (th.querySelector(".erp-col-title")?.textContent || th.innerText || "").trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListPR");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_pr_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsPR")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalPR");
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });

            function getVisibleColsInTableOrder() {
                const ordered = Array.from(table.querySelectorAll("thead th[data-col]"))
                    .filter(th => !th.hasAttribute("data-col-fixed"))
                    .map(th => th.getAttribute("data-col"))
                    .filter(Boolean);

                let hiddenCols = [];
                try {
                    const saved = localStorage.getItem(storageKey);
                    if (saved) hiddenCols = JSON.parse(saved) || [];
                } catch { hiddenCols = []; }

                const hiddenSet = new Set(hiddenCols.map(x => String(x)));
                return ordered.filter(k => !hiddenSet.has(String(k)));
            }

            document.querySelectorAll("form.erp-export-form").forEach(function (form) {
                form.addEventListener("submit", function () {
                    const inp = form.querySelector("input[name='visibleCols']");
                    if (!inp) return;
                    inp.value = getVisibleColsInTableOrder().join(",");
                });
            });
        })();
    </script>
}






