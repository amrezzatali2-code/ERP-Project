@model ERP.Models.CashReceipt

@{
    ViewData["Title"] = "إضافة إذن استلام نقدية";
}

<div class="container" dir="rtl">
    <h2 class="mb-3">إضافة إذن استلام نقدية</h2>

    <form asp-action="Create" method="post">
        <div class="card">
            <div class="card-body">
                <div class="row g-3">
                    <!-- رقم المستند -->
                    <div class="col-md-4">
                        <label asp-for="ReceiptNumber" class="form-label"></label>
                        <input asp-for="ReceiptNumber" class="form-control" />
                        <span asp-validation-for="ReceiptNumber" class="text-danger"></span>
                    </div>

                    <!-- التاريخ -->
                    <div class="col-md-4">
                        <label asp-for="ReceiptDate" class="form-label"></label>
                        <input asp-for="ReceiptDate" type="date" class="form-control" />
                        <span asp-validation-for="ReceiptDate" class="text-danger"></span>
                    </div>

                    <!-- الطرف (عميل) -->
                    <div class="col-md-4">
                        <label asp-for="CustomerId" class="form-label"></label>
                        <select asp-for="CustomerId" class="form-select"
                                asp-items="ViewBag.CustomerId">
                            <option value="">-- بدون طرف --</option>
                        </select>
                        <span asp-validation-for="CustomerId" class="text-danger"></span>
                    </div>

                    <!-- حساب الصندوق/البنك -->
                    <div class="col-md-6">
                        <label asp-for="CashAccountId" class="form-label"></label>
                        <select asp-for="CashAccountId" class="form-select"
                                asp-items="ViewBag.CashAccountId">
                            <option value="">-- اختر حساب الصندوق/البنك --</option>
                        </select>
                        <span asp-validation-for="CashAccountId" class="text-danger"></span>
                    </div>

                    <!-- حساب الطرف -->
                    <div class="col-md-6">
                        <label asp-for="CounterAccountId" class="form-label"></label>
                        <select asp-for="CounterAccountId" class="form-select"
                                asp-items="ViewBag.CounterAccountId">
                            <option value="">-- اختر حساب الطرف --</option>
                        </select>
                        <span asp-validation-for="CounterAccountId" class="text-danger"></span>
                    </div>

                    <!-- المبلغ -->
                    <div class="col-md-4">
                        <label asp-for="Amount" class="form-label"></label>
                        <input asp-for="Amount" class="form-control" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <!-- البيان -->
                    <div class="col-md-8">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary btn-sm">عودة للقائمة</a>
                <button type="submit" class="btn btn-primary btn-sm">حفظ</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
