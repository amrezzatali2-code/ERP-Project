@model ERP.Models.CashReceipt

@{
    ViewData["Title"] = "إضافة إذن استلام نقدية";
    bool lockCustomer = ViewBag.LockCustomer is bool b && b;
}

<div class="container" dir="rtl">
    <h2 class="mb-3">إضافة إذن استلام نقدية</h2>

    @* عرض رسائل النجاح/الخطأ *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @* عرض أخطاء التحقق من النموذج *@
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <strong>يرجى تصحيح الأخطاء التالية:</strong>
            <ul class="mb-0">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="Create" method="post" id="receiptForm">
        <div class="card">
            <div class="card-body">
                <div class="row g-3">
                    <!-- رقم المستند (CashReceiptId - تلقائي - ReadOnly) -->
                    <div class="col-md-4">
                        <label class="form-label">رقم المستند</label>
                        @if (Model.CashReceiptId > 0)
                        {
                            <input type="text" class="form-control" value="@Model.CashReceiptId" readonly />
                            <small class="text-muted">رقم المستند: @Model.CashReceiptId</small>
                        }
                        else
                        {
                            <input type="text" class="form-control" value="" readonly placeholder="سيتم توليده تلقائياً عند الحفظ" />
                            <small class="text-muted">سيتم توليد رقم المستند تلقائياً عند الحفظ (CashReceiptId)</small>
                        }
                    </div>

                    <!-- التاريخ -->
                    <div class="col-md-4">
                        <label asp-for="ReceiptDate" class="form-label"></label>
                        <input asp-for="ReceiptDate" type="date" class="form-control" />
                        <span asp-validation-for="ReceiptDate" class="text-danger"></span>
                    </div>

                    <!-- حالة الترحيل -->
                    <div class="col-md-4">
                        <label class="form-label">الحالة</label>
                        <input type="text" class="form-control" value="@(Model.Status ?? "غير مرحلة")" readonly />
                    </div>

                    <!-- الطرف (عميل) -->
                    <div class="col-md-4">
                        <label asp-for="CustomerId" class="form-label"></label>
                        @if (lockCustomer)
                        {
                            <select asp-for="CustomerId" 
                                    asp-items="ViewBag.CustomerId"
                                    class="form-select" 
                                    id="customerSelect"
                                    disabled
                                    required>
                                <option value="">-- اختر العميل --</option>
                            </select>
                            <input type="hidden" asp-for="CustomerId" />
                        }
                        else
                        {
                            <select asp-for="CustomerId" 
                                    asp-items="ViewBag.CustomerId"
                                    class="form-select" 
                                    id="customerSelect"
                                    required>
                                <option value="">-- اختر العميل --</option>
                            </select>
                        }
                        <span asp-validation-for="CustomerId" class="text-danger"></span>
                    </div>

                    <!-- حساب الصندوق/البنك (يتم تعبئته تلقائياً) -->
                    <div class="col-md-4">
                        <label asp-for="CashAccountId" class="form-label"></label>
                        @* ✅ دائماً نستخدم select عادي مع asp-for لضمان إرسال القيمة *@
                        <select asp-for="CashAccountId" asp-items="ViewBag.CashAccountId" class="form-select" id="CashAccountId" name="CashAccountId">
                            <option value="">-- اختر حساب الصندوق/البنك --</option>
                        </select>
                        @* ✅ Hidden input احتياطي لضمان إرسال القيمة *@
                        @if (Model.CashAccountId > 0)
                        {
                            <input type="hidden" name="CashAccountId" value="@Model.CashAccountId" id="CashAccountIdHidden" />
                        }
                        <small class="text-muted">سيتم اختيار حساب الخزينة تلقائياً</small>
                        <span asp-validation-for="CashAccountId" class="text-danger"></span>
                    </div>

                    <!-- حساب الطرف (يتم تعبئته تلقائياً عند اختيار العميل) -->
                    <div class="col-md-4">
                        <label asp-for="CounterAccountId" class="form-label"></label>
                        @if (lockCustomer)
                        {
                            @* ✅ العميل مقفل - نستخدم select disabled مع hidden input *@
                            <select asp-for="CounterAccountId" 
                                    asp-items="ViewBag.CounterAccountId"
                                    class="form-select" 
                                    id="counterAccountSelect"
                                    disabled>
                                <option value="">-- سيتم تعبئته تلقائياً --</option>
                            </select>
                            <input type="hidden" name="CounterAccountId" value="@Model.CounterAccountId" id="CounterAccountIdHidden" />
                        }
                        else
                        {
                            @* ✅ select عادي - القيمة ستُحدد تلقائياً من Model أو من JavaScript *@
                            <select asp-for="CounterAccountId" 
                                    asp-items="ViewBag.CounterAccountId"
                                    class="form-select" 
                                    id="counterAccountSelect"
                                    name="CounterAccountId">
                                <option value="">-- سيتم تعبئته تلقائياً --</option>
                            </select>
                            @* ✅ Hidden input احتياطي لضمان إرسال القيمة *@
                            @if (Model.CounterAccountId > 0)
                            {
                                <input type="hidden" name="CounterAccountId" value="@Model.CounterAccountId" id="CounterAccountIdHidden" />
                            }
                        }
                        <span asp-validation-for="CounterAccountId" class="text-danger"></span>
                    </div>

                    <!-- المبلغ -->
                    <div class="col-md-4">
                        <label asp-for="Amount" class="form-label"></label>
                        <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" required />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <!-- البيان -->
                    <div class="col-md-8">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary btn-sm">عودة للقائمة</a>
                <button type="submit" class="btn btn-primary btn-sm">حفظ وترحيل</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function() {
            // ✅ التأكد من تحديد القيم المحددة مسبقاً عند تحميل الصفحة
            @if (Model.CashAccountId > 0)
            {
                <text>
                var cashAccountId = '@Model.CashAccountId';
                $('#CashAccountId').val(cashAccountId);
                // تحديث hidden input أيضاً
                $('#CashAccountIdHidden').val(cashAccountId);
                </text>
            }
            
            @if (Model.CounterAccountId > 0)
            {
                <text>
                var counterAccountId = '@Model.CounterAccountId';
                $('#counterAccountSelect').val(counterAccountId);
                // تحديث hidden input أيضاً
                $('#CounterAccountIdHidden').val(counterAccountId);
                </text>
            }
            
            // ✅ عند اختيار العميل، نجلب حسابه ونملأ حساب الطرف تلقائياً
            $('#customerSelect').on('change', function() {
                var customerId = $(this).val();
                var counterAccountSelect = $('#counterAccountSelect');
                
                if (!customerId || customerId === '') {
                    counterAccountSelect.val('');
                    $('#CounterAccountIdHidden').val('');
                    return;
                }

                // جلب حساب العميل عبر AJAX
                $.ajax({
                    url: '@Url.Action("GetCustomerAccount", "CashReceipts")',
                    type: 'GET',
                    data: { customerId: customerId },
                    success: function(response) {
                        if (response && response.success && response.accountId) {
                            counterAccountSelect.val(response.accountId);
                            // تحديث hidden input أيضاً
                            $('#CounterAccountIdHidden').val(response.accountId);
                        } else {
                            counterAccountSelect.val('');
                            $('#CounterAccountIdHidden').val('');
                            if (response && response.message) {
                                alert(response.message);
                            } else {
                                alert('هذا العميل غير مربوط بحساب محاسبي. يرجى ربطه بحساب أولاً.');
                            }
                        }
                    },
                    error: function() {
                        counterAccountSelect.val('');
                        $('#CounterAccountIdHidden').val('');
                        alert('حدث خطأ أثناء جلب حساب العميل.');
                    }
                });
            });
            
            // ✅ التأكد من إرسال القيم قبل إرسال النموذج
            $('#receiptForm').on('submit', function(e) {
                var cashAccountId = $('#CashAccountId').val();
                var counterAccountId = $('#counterAccountSelect').val();
                
                // إذا كانت القيم موجودة في select لكن hidden input غير موجود أو فارغ، نضيفهما
                if (cashAccountId && cashAccountId !== '') {
                    if ($('#CashAccountIdHidden').length === 0) {
                        $('<input>').attr({
                            type: 'hidden',
                            name: 'CashAccountId',
                            value: cashAccountId,
                            id: 'CashAccountIdHidden'
                        }).appendTo('#receiptForm');
                    } else {
                        $('#CashAccountIdHidden').val(cashAccountId);
                    }
                }
                
                if (counterAccountId && counterAccountId !== '') {
                    if ($('#CounterAccountIdHidden').length === 0) {
                        $('<input>').attr({
                            type: 'hidden',
                            name: 'CounterAccountId',
                            value: counterAccountId,
                            id: 'CounterAccountIdHidden'
                        }).appendTo('#receiptForm');
                    } else {
                        $('#CounterAccountIdHidden').val(counterAccountId);
                    }
                }
            });
        });
    </script>
}
