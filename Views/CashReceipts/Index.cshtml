<div class="modal fade no-print erp-columns-modal" id="columnsModalCashReceipts" tabindex="-1" aria-labelledby="columnsModalCashReceiptsLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalCashReceiptsLabel">اختيار الأعمدة الظاهرة</h5>
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body"><div id="columnsListCashReceipts" class="erp-columns-modal-list"></div></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-erp btn-erp-secondary" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" id="btnApplyColumnsCashReceipts" class="btn btn-erp btn-erp-primary">تطبيق</button>
            </div>
