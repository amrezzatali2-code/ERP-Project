@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<CashReceipt>

@{
    ViewData["Title"] = "قائمة أذون استلام نقدية";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "CashReceipts";

    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var searchMode = (string?)ViewBag.SearchMode ?? "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "ReceiptDate";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "desc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
    int end = (ps == 0 || total == 0) ? total : System.Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;
    var dateField = (string?)ViewBag.DateField ?? "ReceiptDate";

    decimal totalAmount = ViewBag.TotalAmount is decimal d ? d : 0m;

    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_receiptNumber = ViewBag.FilterCol_ReceiptNumber as string;
    string? filterCol_date = ViewBag.FilterCol_Date as string;
    string? filterCol_customer = ViewBag.FilterCol_Customer as string;
    string? filterCol_cashAccount = ViewBag.FilterCol_CashAccount as string;
    string? filterCol_counterAccount = ViewBag.FilterCol_CounterAccount as string;
    string? filterCol_amount = ViewBag.FilterCol_Amount as string;
    string? filterCol_amountExpr = ViewBag.FilterCol_AmountExpr as string;
    string? filterCol_posted = ViewBag.FilterCol_Posted as string;
    string? filterCol_desc = ViewBag.FilterCol_Desc as string;

    string? FilterForCol(string colKey) =>
        colKey == "id" ? (!string.IsNullOrWhiteSpace(filterCol_idExpr) ? filterCol_idExpr : filterCol_id)
        : colKey == "amount" ? (!string.IsNullOrWhiteSpace(filterCol_amountExpr) ? filterCol_amountExpr : filterCol_amount)
        : colKey == "receiptNumber" ? filterCol_receiptNumber
        : colKey == "date" ? filterCol_date
        : colKey == "customer" ? filterCol_customer
        : colKey == "cashAccount" ? filterCol_cashAccount
        : colKey == "counterAccount" ? filterCol_counterAccount
        : colKey == "posted" ? filterCol_posted
        : colKey == "desc" ? filterCol_desc
        : null;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        dateField,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_idExpr,
        filterCol_receiptNumber,
        filterCol_date,
        filterCol_customer,
        filterCol_cashAccount,
        filterCol_counterAccount,
        filterCol_amount,
        filterCol_amountExpr,
        filterCol_posted,
        filterCol_desc
    })!;

    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";
        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            searchMode,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate,
            dateField,
            fromCode,
            toCode,
            filterCol_id,
            filterCol_idExpr,
            filterCol_receiptNumber,
            filterCol_date,
            filterCol_customer,
            filterCol_cashAccount,
            filterCol_counterAccount,
            filterCol_amount,
            filterCol_amountExpr,
            filterCol_posted,
            filterCol_desc
        }) ?? "#";
        string icon = isCurrent ? (dir == "asc" ? "▲" : "▼") : "⇅";
        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    @if (TempData["CashReceiptSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["CashReceiptSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["CashReceiptError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["CashReceiptError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0 fs-6 text-secondary">@ViewData["Title"]</h5>
    </div>

    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في إذون الاستلام</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100 flex-wrap">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" style="min-width:120px" />
                        <select name="searchMode" class="form-select form-select-arrow erp-filter-input" style="max-width:130px;min-width:90px" title="نمط مطابقة النص">
                            <option value="starts"@Html.Raw(searchMode == "starts" ? " selected" : "")>يبدأ بـ</option>
                            <option value="contains"@Html.Raw(searchMode == "contains" || string.IsNullOrEmpty(searchMode) ? " selected" : "")>يحتوي</option>
                            <option value="ends"@Html.Raw(searchMode == "ends" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:160px;min-width:100px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>الكل</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>رقم الإذن</option>
                            <option value="receiptNumber"@Html.Raw(searchBy == "receiptNumber" ? " selected" : "")>رقم المستند</option>
                            <option value="customer"@Html.Raw(searchBy == "customer" ? " selected" : "")>اسم الطرف</option>
                            <option value="cashAccount"@Html.Raw(searchBy == "cashAccount" ? " selected" : "")>حساب الصندوق/البنك</option>
                            <option value="counterAccount"@Html.Raw(searchBy == "counterAccount" ? " selected" : "")>حساب الطرف</option>
                            <option value="description"@Html.Raw(searchBy == "description" ? " selected" : "")>البيان</option>
                            <option value="status"@Html.Raw(searchBy == "status" ? " selected" : "")>حالة الترحيل</option>
                        </select>
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3 flex-shrink-0">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none flex-shrink-0" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_receiptNumber)) { <input type="hidden" name="filterCol_receiptNumber" value="@filterCol_receiptNumber" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_customer)) { <input type="hidden" name="filterCol_customer" value="@filterCol_customer" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_cashAccount)) { <input type="hidden" name="filterCol_cashAccount" value="@filterCol_cashAccount" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_counterAccount)) { <input type="hidden" name="filterCol_counterAccount" value="@filterCol_counterAccount" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_amount)) { <input type="hidden" name="filterCol_amount" value="@filterCol_amount" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_amountExpr)) { <input type="hidden" name="filterCol_amountExpr" value="@filterCol_amountExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_posted)) { <input type="hidden" name="filterCol_posted" value="@filterCol_posted" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_desc)) { <input type="hidden" name="filterCol_desc" value="@filterCol_desc" /> }
                </form>
            </div>

            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">من كود – إلى كود</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <a asp-action="Create" asp-controller="CashReceipts" class="btn btn-erp btn-erp-success btn-erp-sm">إذن جديد</a>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModalCashReceipts">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalCashReceipts">اختيار الأعمدة</button>
                        <button type="button" id="btnPrintCashReceipts" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <span class="erp-list-toolbar-selected-actions d-inline-flex flex-wrap gap-2 align-items-center" role="group" aria-label="إجراءات السجل المحدد">
                            <button type="button" id="btnShowCr" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="عرض">عرض</button>
                        </span>
                    </div>
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center" dir="rtl">
                        <form method="get" asp-action="Export" asp-controller="CashReceipts" class="d-inline-flex flex-nowrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="searchMode" value="@searchMode" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="dateField" value="@dateField" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_receiptNumber)) { <input type="hidden" name="filterCol_receiptNumber" value="@filterCol_receiptNumber" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_customer)) { <input type="hidden" name="filterCol_customer" value="@filterCol_customer" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_cashAccount)) { <input type="hidden" name="filterCol_cashAccount" value="@filterCol_cashAccount" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_counterAccount)) { <input type="hidden" name="filterCol_counterAccount" value="@filterCol_counterAccount" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_amount)) { <input type="hidden" name="filterCol_amount" value="@filterCol_amount" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_amountExpr)) { <input type="hidden" name="filterCol_amountExpr" value="@filterCol_amountExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_posted)) { <input type="hidden" name="filterCol_posted" value="@filterCol_posted" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_desc)) { <input type="hidden" name="filterCol_desc" value="@filterCol_desc" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @{
        var n2 = System.Globalization.CultureInfo.InvariantCulture;
    }
    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row mt-2" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="min-width: 200px; border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">عدد الإذون (بعد الفلترة)</div>
                    <div class="h4 mb-0 text-primary fw-bold">@total.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="min-width: 200px; border: 1px solid #15803d !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي المبالغ</div>
                    <div class="h4 mb-0 text-success fw-bold">@totalAmount.ToString("N2", n2)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="erp-list-table-frame erp-table-scroll-container erp-list-table-after-summary mt-3 ps-0 pe-0" dir="rtl">
        <div id="cashReceiptsTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="cashReceiptsTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th class="no-print text-center" data-col="select" data-col-fixed="true" style="width:42px; min-width:42px;"><input type="checkbox" id="selectAll" class="form-check-input" aria-label="تحديد الكل" /></th>
                    <th data-col="id">@filterableCol("id", "CashReceiptId", "رقم الإذن")</th>
                    <th data-col="receiptNumber">@filterableCol("receiptNumber", "ReceiptNumber", "رقم المستند")</th>
                    <th data-col="date">@filterableCol("date", "ReceiptDate", "تاريخ الإذن")</th>
                    <th data-col="customer">@filterableCol("customer", "CustomerName", "الطرف")</th>
                    <th data-col="cashAccount">@filterableCol("cashAccount", "CashAccount", "حساب الصندوق/البنك")</th>
                    <th data-col="counterAccount">@filterableCol("counterAccount", "CounterAccount", "حساب الطرف")</th>
                    <th data-col="amount">@filterableCol("amount", "Amount", "المبلغ")</th>
                    <th data-col="posted">@filterableCol("posted", "IsPosted", "مرحّل؟")</th>
                    <th data-col="created">@filterableCol("created", "CreatedAt", "تاريخ الإنشاء")</th>
                    <th data-col="updated">@filterableCol("updated", "UpdatedAt", "آخر تعديل")</th>
                    <th data-col="description">@filterableCol("desc", "Description", "البيان")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="12" class="text-center text-muted py-4">لا توجد بيانات.</td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model.Items)
                    {
                        var desc = r.Description ?? "";
                        var descShort = desc.Length > 80 ? desc.Substring(0, 80) + "…" : desc;
                        var showU = Url.Action("Show", "CashReceipts", new { id = r.CashReceiptId }) + "?frame=1";
                        <tr class="erp-list-selectable-row" data-row-id="@r.CashReceiptId" data-show-url="@showU" data-tab-title="إذن استلام @r.CashReceiptId">
                            <td class="no-print text-center" data-col="select"><input type="checkbox" class="form-check-input row-select" value="@r.CashReceiptId" aria-label="تحديد" /></td>
                            <td data-col="id">@r.CashReceiptId</td>
                            <td data-col="receiptNumber">@r.ReceiptNumber</td>
                            <td data-col="date">@r.ReceiptDate.ToString("yyyy-MM-dd")</td>
                            <td data-col="customer">@r.Customer?.CustomerName</td>
                            <td data-col="cashAccount">@r.CashAccount?.AccountName</td>
                            <td data-col="counterAccount">@r.CounterAccount?.AccountName</td>
                            <td data-col="amount">@r.Amount.ToString("N2")</td>
                            <td data-col="posted">@(r.IsPosted ? "مرحّل" : "مسودة")</td>
                            <td data-col="created">@(r.CreatedAt == default ? "" : r.CreatedAt.ToString("yyyy-MM-dd HH:mm"))</td>
                            <td data-col="updated">@(r.UpdatedAt.HasValue ? r.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                            <td data-col="description">@descShort</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        </div>
    </div>

    <div id="erpColumnFilterPanelCashReceipts" class="erp-column-filter-panel d-none" dir="rtl">
        <div class="erp-column-filter-header">
            <span id="erpColumnFilterTitleCashReceipts">ترتيب وفلتر</span>
            <button type="button" class="btn-close btn-sm" id="erpColumnFilterCloseCashReceipts" aria-label="إغلاق"></button>
        </div>
        <div class="erp-column-filter-body">
            <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                <div class="d-flex flex-column gap-1">
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc"><span class="erp-sort-arrow">▲</span> ترتيب تصاعدي</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc"><span class="erp-sort-arrow">▼</span> ترتيب تنازلي</button>
                </div>
            </div>
            <div class="erp-filter-section">
                <div id="erpColumnFilterSearchRowCashReceipts">
                    <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                    <input type="text" id="erpColumnFilterSearchCashReceipts" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                </div>
                <div id="erpColumnFilterListCashReceipts" class="erp-column-filter-list">
                    <div class="text-muted text-center py-3">جاري التحميل...</div>
                </div>
            </div>
            <div class="erp-column-filter-actions">
                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOkCashReceipts">تطبيق</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClearCashReceipts">مسح الفلتر</button>
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print" dir="rtl">
        <small class="text-muted text-start">عرض @start - @end من @total</small>
        <form method="get" action="@Url.Action(action, controller)" class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="searchMode" value="@searchMode" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_receiptNumber)) { <input type="hidden" name="filterCol_receiptNumber" value="@filterCol_receiptNumber" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_customer)) { <input type="hidden" name="filterCol_customer" value="@filterCol_customer" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_cashAccount)) { <input type="hidden" name="filterCol_cashAccount" value="@filterCol_cashAccount" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_counterAccount)) { <input type="hidden" name="filterCol_counterAccount" value="@filterCol_counterAccount" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_amount)) { <input type="hidden" name="filterCol_amount" value="@filterCol_amount" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_amountExpr)) { <input type="hidden" name="filterCol_amountExpr" value="@filterCol_amountExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_posted)) { <input type="hidden" name="filterCol_posted" value="@filterCol_posted" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_desc)) { <input type="hidden" name="filterCol_desc" value="@filterCol_desc" /> }
            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
            </select>
        </form>
    </div>

    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")"><a class="page-link" href="@Link(first)">الأول</a></li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")"><a class="page-link" href="@Link(prev)">السابق</a></li>
            <li class="page-item disabled"><span class="page-link">صفحة @(page) من @(pages)</span></li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")"><a class="page-link" href="@Link(next)">التالي</a></li>
            <li class="page-item @(page == last ? "disabled" : "")"><a class="page-link" href="@Link(last)">الأخير</a></li>
        </ul>
    </nav>
</div>

