@model ERP.Models.CashReceipt

@{
    ViewData["Title"] = "تعديل إذن استلام نقدية";
    bool lockCustomer = ViewBag.LockCustomer is bool b && b;
    bool isPosted = Model.IsPosted;
    string rawStatus = (Model.Status ?? "").Trim();
    bool isOpenForEdit = !isPosted && (rawStatus.Contains("مفتوح") || rawStatus.Contains("مفتوحة"));
    string statusText = isPosted ? "مرحل" : (isOpenForEdit ? "مفتوح للتعديل" : "غير مرحل");
}

<style>
    .cr-form-wrap .card {
        border: 1px solid #dbe3ef;
        border-radius: 14px;
        box-shadow: 0 6px 20px rgba(15, 23, 42, .06);
        overflow: hidden;
    }
    .cr-form-wrap .card-body {
        background: linear-gradient(180deg, #fbfdff 0%, #ffffff 100%);
    }
    .cr-form-wrap .form-label {
        color: #334155;
        font-weight: 600;
        font-size: .88rem;
        margin-bottom: .35rem;
    }
    .cr-form-wrap .form-control,
    .cr-form-wrap .form-select {
        border: 2px solid #9cb5de;
        border-radius: .6rem;
        min-height: 2.7rem;
        font-size: 1.02rem;
        color: #0f172a;
        background-color: #fff;
    }
    .cr-form-wrap .form-control:focus,
    .cr-form-wrap .form-select:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 .22rem rgba(37,99,235,.18);
    }
    .cr-form-wrap .card-footer {
        background: #f8fafc;
        border-top: 1px solid #e2e8f0;
    }
</style>

<div class="container" dir="rtl">
<div class="cr-form-wrap">
    <h2 class="mb-3">تعديل إذن استلام نقدية</h2>

    @if (isPosted)
    {
        <div class="alert alert-warning">
            <strong>تنبيه:</strong> هذا الإذن مُرحّل. يجب فتحه أولاً قبل التعديل.
            <form asp-action="Open" method="post" style="display: inline;" onsubmit="return confirm('هل تريد فتح هذا الإذن للتعديل؟');">
                <input type="hidden" name="id" value="@Model.CashReceiptId" />
                <button type="submit" class="btn btn-warning btn-sm">فتح للتعديل</button>
            </form>
        </div>
    }

    <form asp-action="Edit" method="post" id="receiptForm">
        <input type="hidden" asp-for="CashReceiptId" />

        <div class="card">
            <div class="card-body">
                <div class="row g-3">
                    <!-- رقم الإذن (CashReceiptId - ثابت - ReadOnly) -->
                    <div class="col-md-2 col-sm-4">
                        <label class="form-label">رقم الإذن</label>
                        <input type="text" class="form-control form-control-sm text-center" style="max-width:120px;" value="@Model.CashReceiptId" readonly />
                    </div>

                    <!-- التاريخ -->
                    <div class="col-md-5 col-sm-4">
                        <label asp-for="ReceiptDate" class="form-label"></label>
                        @if (isPosted)
                        {
                            <input asp-for="ReceiptDate" type="date" class="form-control" readonly />
                        }
                        else
                        {
                            <input asp-for="ReceiptDate" type="date" class="form-control" />
                        }
                        <span asp-validation-for="ReceiptDate" class="text-danger"></span>
                    </div>

                    <!-- حالة الترحيل -->
                    <div class="col-md-5 col-sm-4">
                        <label class="form-label">الحالة</label>
                        <input type="text" class="form-control" value="@statusText" readonly />
                    </div>

                    <!-- العميل -->
                    <div class="col-md-4">
                        <label asp-for="CustomerId" class="form-label">العميل</label>
                        @if (lockCustomer || isPosted)
                        {
                            <select asp-for="CustomerId" 
                                    class="form-select" 
                                    id="customerSelect"
                                    disabled
                                    required>
                                <option value="">-- اختر العميل --</option>
                                @if (ViewBag.CustomerId is SelectList customerList)
                                {
                                    @foreach (var item in customerList)
                                    {
                                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                    }
                                }
                            </select>
                            <input type="hidden" asp-for="CustomerId" />
                        }
                        else
                        {
                            <select asp-for="CustomerId" 
                                    class="form-select" 
                                    id="customerSelect"
                                    required>
                                <option value="">-- اختر العميل --</option>
                                @if (ViewBag.CustomerId is SelectList customerList)
                                {
                                    @foreach (var item in customerList)
                                    {
                                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                    }
                                }
                            </select>
                        }
                        <span asp-validation-for="CustomerId" class="text-danger"></span>
                    </div>

                    <!-- حساب الصندوق/البنك -->
                    <div class="col-md-4">
                        <label asp-for="CashAccountId" class="form-label"></label>
                        @if (isPosted)
                        {
                            <select asp-for="CashAccountId" class="form-select" disabled required>
                                <option value="">-- اختر حساب الصندوق/البنك --</option>
                                @if (ViewBag.CashAccountId is SelectList cashAccountList)
                                {
                                    @foreach (var item in cashAccountList)
                                    {
                                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                    }
                                }
                            </select>
                            <input type="hidden" asp-for="CashAccountId" />
                        }
                        else
                        {
                            <select asp-for="CashAccountId" class="form-select" required>
                                <option value="">-- اختر حساب الصندوق/البنك --</option>
                                @if (ViewBag.CashAccountId is SelectList cashAccountList)
                                {
                                    @foreach (var item in cashAccountList)
                                    {
                                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                    }
                                }
                            </select>
                        }
                        <span asp-validation-for="CashAccountId" class="text-danger"></span>
                    </div>

                    <!-- حساب العميل (يتم تعبئته تلقائياً عند اختيار العميل) -->
                    <div class="col-md-4">
                        <label asp-for="CounterAccountId" class="form-label">حساب العميل</label>
                        @if (lockCustomer || isPosted)
                        {
                            <select asp-for="CounterAccountId" 
                                    class="form-select" 
                                    id="counterAccountSelect"
                                    disabled
                                    required>
                                <option value="">-- سيتم تعبئته تلقائياً --</option>
                                @if (ViewBag.CounterAccountId is SelectList counterAccountList)
                                {
                                    @foreach (var item in counterAccountList)
                                    {
                                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                    }
                                }
                            </select>
                            <input type="hidden" asp-for="CounterAccountId" />
                        }
                        else
                        {
                            <select asp-for="CounterAccountId" 
                                    class="form-select" 
                                    id="counterAccountSelect"
                                    required>
                                <option value="">-- سيتم تعبئته تلقائياً --</option>
                                @if (ViewBag.CounterAccountId is SelectList counterAccountList)
                                {
                                    @foreach (var item in counterAccountList)
                                    {
                                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                    }
                                }
                            </select>
                        }
                        <span asp-validation-for="CounterAccountId" class="text-danger"></span>
                    </div>

                    <!-- المبلغ -->
                    <div class="col-md-4">
                        <label asp-for="Amount" class="form-label"></label>
                        @if (isPosted)
                        {
                            <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" readonly required />
                        }
                        else
                        {
                            <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" required />
                        }
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <!-- البيان -->
                    <div class="col-md-8">
                        <label asp-for="Description" class="form-label"></label>
                        @if (isPosted)
                        {
                            <input asp-for="Description" class="form-control" readonly />
                        }
                        else
                        {
                            <input asp-for="Description" class="form-control" />
                        }
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-between">
                <a class="btn btn-secondary btn-sm open-same-tab"
                   href="@Url.Action("Index", "CashReceipts", new { frame = 1 })"
                   data-tab-id="cash-receipts"
                   data-tab-title="قائمة أذون استلام نقدية"
                   data-url="@Url.Action("Index", "CashReceipts", new { frame = 1 })">عودة للقائمة</a>
                <div class="d-flex gap-2 align-items-center">
                    <a asp-action="Show"
                       asp-route-id="@Model.CashReceiptId"
                       asp-route-autoPrint="1"
                       asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                       target="_blank"
                       class="btn btn-outline-primary btn-sm">
                        🖨️ طباعة الإذن
                    </a>
                    @if (isPosted)
                    {
                        <button type="button" class="btn btn-warning btn-sm" disabled>الإذن مُرحّل - افتحه أولاً</button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-primary btn-sm">حفظ وترحيل</button>
                    }
                </div>
            </div>
        </div>
    </form>
</div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function() {
            // ✅ إزالة الصفر من خانة المبلغ عند التحميل
            var $amount = $('#Amount');
            if ($amount.length && ($amount.val() === '0' || $amount.val() === '0.00')) {
                $amount.val('');
            }

            var $customer = $('#customerSelect');
            var focusAmount = function () {
                if ($amount.length && !$amount.prop('readonly') && !$amount.prop('disabled')) {
                    $amount.trigger('focus');
                    $amount.trigger('select');
                }
            };

            setTimeout(function () {
                if ($customer.length && !$customer.prop('disabled')) {
                    $customer.trigger('focus');
                } else {
                    focusAmount();
                }
            }, 120);

            $customer.on('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    focusAmount();
                }
            });

            $amount.on('focus', function () {
                if (!$(this).prop('readonly')) $(this).trigger('select');
            });

            $amount.on('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    var form = $('#receiptForm');
                    if (form.length) {
                        form.trigger('submit');
                    }
                }
            });

            // ✅ عند اختيار العميل، نجلب حسابه ونملأ حساب الطرف تلقائياً
            $('#customerSelect').on('change', function() {
                var customerId = $(this).val();
                var counterAccountSelect = $('#counterAccountSelect');
                
                if (!customerId || customerId === '') {
                    counterAccountSelect.val('');
                    return;
                }

                // جلب حساب العميل عبر AJAX
                $.ajax({
                    url: '@Url.Action("GetCustomerAccount", "CashReceipts")',
                    type: 'GET',
                    data: { customerId: customerId },
                    success: function(response) {
                        if (response && response.success && response.accountId) {
                            counterAccountSelect.val(response.accountId);
                        } else {
                            counterAccountSelect.val('');
                            if (response && response.message) {
                                alert(response.message);
                            } else {
                                alert('هذا العميل غير مربوط بحساب محاسبي. يرجى ربطه بحساب أولاً.');
                            }
                        }
                    },
                    error: function() {
                        counterAccountSelect.val('');
                        alert('حدث خطأ أثناء جلب حساب العميل.');
                    }
                });
            });
        });
    </script>
}
