@model ERP.Models.CashReceiptBatchViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "إذن استلام مجمّع";
    var autoFocusCustomer = ViewBag.AutoFocusCustomer is bool b && b;
    var batchCustomers = ViewBag.BatchCustomers as SelectList;
    var batchCustomerItems = batchCustomers?.ToList() ?? new List<SelectListItem>();
    var batchReady = Model.AreaId.HasValue && Model.AreaId.Value > 0
                     && Model.DistributorEmployeeId.HasValue && Model.DistributorEmployeeId.Value > 0;
}

<style>
    #quickBatchForm,
    #quickBatchForm .col-12,
    #quickBatchForm .col-lg-4,
    #quickBatchForm .col-lg-6 {
        overflow: visible !important;
    }
    #batchCustomerWrap {
        border: 2px solid #4f46e5 !important;
        border-radius: 0.55rem !important;
        padding: 3px !important;
        box-shadow: none !important;
        overflow: visible !important;
        z-index: 12010;
    }
    #batchCustomerWrap:focus-within {
        border-color: #4338ca !important;
        box-shadow: none !important;
    }
    #batchCustomerWrap .product-dropdown-onebox {
        border: 0 !important;
        background: transparent !important;
        border-radius: 0.45rem !important;
    }
    .product-dropdown-onebox { position: relative; }
    .product-dropdown-arrow-inside {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #495057;
        cursor: pointer;
        user-select: none;
        font-size: 0.6rem;
        z-index: 1;
    }
    .product-dropdown-onebox .product-dropdown-input {
        width: 100%;
        border: none !important;
        background: transparent !important;
        padding-left: 2.25rem !important;
    }
    .product-dropdown-onebox .product-dropdown-input:focus {
        box-shadow: none !important;
        outline: none !important;
    }
    #quickCustomerText.customer-selected {
        color: #0d6efd !important;
        font-weight: 600;
    }
    .product-dropdown-list {
        position: fixed;
        max-height: 220px;
        min-height: 40px;
        overflow-y: auto;
        z-index: 9999;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        background: #fff;
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
    }
    .product-dropdown-list[data-open="false"] { display: none !important; }
    .product-dropdown-list[data-open="true"] { display: block !important; }
    .product-dropdown-item { cursor: pointer; border-bottom: 1px solid #f0f0f0; padding: .35rem .55rem; }
    .product-dropdown-item:last-child { border-bottom: none; }
    .product-dropdown-item:hover { background-color: #f8f9fa; }
    .product-dropdown-item-active { background-color: #0d6efd !important; color: #fff !important; }

    #quickBatchForm.quick-batch-inline {
        display: grid;
        grid-template-columns: 8rem minmax(320px, 1fr) minmax(220px, .8fr) 10rem;
        gap: 1rem;
        align-items: end;
        justify-content: stretch;
    }
    #quickBatchForm.quick-batch-inline .quick-batch-field {
        min-width: 0;
    }
    #quickBatchForm.quick-batch-inline .quick-batch-field label {
        margin-bottom: .35rem;
        font-weight: 700;
    }
    #quickBatchForm.quick-batch-inline .quick-batch-code-box {
        width: 100%;
        max-width: none;
    }
    #quickBatchForm.quick-batch-inline #quickAddBtn {
        min-height: 44px;
        border-radius: .7rem;
        font-weight: 800;
        font-size: 1rem;
        background: linear-gradient(135deg, #16a34a 0%, #15803d 100%) !important;
        border-color: #15803d !important;
        color: #fff !important;
        box-shadow: 0 .5rem 1rem rgba(21, 128, 61, .18);
    }
    #quickBatchForm.quick-batch-inline #quickAddBtn:hover,
    #quickBatchForm.quick-batch-inline #quickAddBtn:focus {
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%) !important;
        border-color: #15803d !important;
        color: #fff !important;
    }
    .quick-batch-help {
        margin-top: .65rem;
        text-align: center;
    }
    @@media (max-width: 991.98px) {
        #quickBatchForm.quick-batch-inline {
            grid-template-columns: 1fr;
            gap: .85rem;
        }
        #quickBatchForm.quick-batch-inline .quick-batch-action {
            width: 100%;
        }
    }
</style>

<div class="container-fluid" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0 fs-6 text-secondary">@ViewData["Title"]</h5>
    </div>

    @if (TempData["CashReceiptSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["CashReceiptSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["CashReceiptError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["CashReceiptError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="erp-list-filter-bar d-print-none mt-2">
        <form method="get" asp-action="BatchCreate" asp-controller="CashReceipts" class="row g-3 align-items-end justify-content-center">
            <div class="col-12 col-lg-3">
                <label class="form-label">المنطقة</label>
                <select class="form-select" name="areaId" asp-items="ViewBag.Areas">
                    <option value="">-- اختر المنطقة --</option>
                </select>
            </div>
            <div class="col-12 col-lg-3">
                <label class="form-label">الموزع</label>
                <select class="form-select" name="distributorEmployeeId" asp-items="ViewBag.Distributors">
                    <option value="">-- اختر الموزع --</option>
                </select>
            </div>
            <div class="col-6 col-lg-2">
                <label class="form-label">التاريخ</label>
                <input type="date" class="form-control" name="batchDate" value="@Model.BatchDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-6 col-lg-2">
                <label class="form-label">الوقت</label>
                <input type="time" class="form-control" name="batchTime" value="@Model.BatchTime.ToString(@"hh\:mm")" />
            </div>
            <div class="col-12 col-lg-2 d-flex gap-2">
                <button type="submit" class="btn btn-erp btn-erp-primary w-100">تطبيق</button>
            </div>
        </form>
    </div>

    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row mt-2" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="min-width: 220px; border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">الدورة الحالية</div>
                    <div class="fw-bold">@(Model.AreaName ?? "-") / @(Model.DistributorName ?? "-")</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="min-width: 220px; border: 1px solid #15803d !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">عدد الإيصالات في الدورة</div>
                    <div class="h5 mb-0 text-success fw-bold">@Model.Receipts.Count</div>
                </div>
            </div>
        </div>
    </div>

    <div class="erp-list-filter-bar d-print-none mt-3">
        <form id="quickBatchForm" method="post" asp-action="BatchCreate" asp-controller="CashReceipts" class="quick-batch-inline" autocomplete="off">
            @Html.AntiForgeryToken()
            <input type="hidden" name="areaId" value="@Model.AreaId" />
            <input type="hidden" name="distributorEmployeeId" value="@Model.DistributorEmployeeId" />
            <input type="hidden" name="batchDate" value="@Model.BatchDate.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="batchTime" value="@Model.BatchTime.ToString(@"hh\:mm")" />

            <div class="quick-batch-field">
                <label class="form-label">كود العميل</label>
                <div class="quick-batch-code-box">
                    <input id="quickCustomerCode"
                           type="text"
                           inputmode="numeric"
                           class="form-control form-control-sm erp-filter-input text-center px-1"
                           placeholder="كود"
                           dir="ltr"
                           @(batchReady ? null : "disabled") />
                </div>
            </div>

            <div class="quick-batch-field">
                <label class="form-label">اسم العميل</label>
                <div class="position-relative" id="batchCustomerWrap">
                    <div class="product-dropdown-onebox" id="batchCustomerInputGroup">
                        <span class="product-dropdown-arrow-inside" id="batchCustomerArrow" title="افتح القائمة">▼</span>
                        <input id="quickCustomerText"
                               type="text"
                               class="form-control form-control-sm erp-filter-input product-dropdown-input"
                               placeholder="بحث بالاسم..."
                               autocomplete="off"
                               autocorrect="off"
                               autocapitalize="off"
                               spellcheck="false"
                               @(batchReady ? null : "disabled") />
                    </div>
                    <input type="hidden" id="quickCustomerId" name="customerId" />
                    <select id="quickCustomerSource" class="d-none" asp-items="batchCustomers"></select>
                    <div id="batchCustomerDropdownList" class="product-dropdown-list" role="listbox" data-open="false"></div>
                </div>
            </div>

            <div class="quick-batch-field">
                <label class="form-label">المبلغ</label>
                <input id="quickAmount" type="number" class="form-control" name="amount" step="0.01" min="0.01" placeholder="اكتب المبلغ" @(batchReady ? null : "disabled") />
            </div>

            <div class="quick-batch-field quick-batch-action d-flex">
                <button id="quickAddBtn" type="submit" class="btn btn-erp btn-erp-success w-100" @(batchReady ? null : "disabled")>إضافة</button>
            </div>
        </form>

        @if (!batchReady)
        {
            <div class="small text-muted quick-batch-help">اختر المنطقة والموزع ثم اضغط تطبيق لتفعيل الإدخال السريع.</div>
        }
    </div>

    <div class="d-flex flex-wrap gap-2 mt-3 mb-2">
        <a asp-action="BatchCreate"
           asp-controller="CashReceipts"
           asp-route-frame="1"
           class="btn btn-erp btn-erp-success btn-erp-sm open-tab"
           data-tab-id="cash-receipts-batch-new"
           data-tab-title="إذن استلام مجمّع">إذن استلام مجمّع جديد</a>
        <a asp-action="Index"
           asp-controller="CashReceipts"
           asp-route-frame="1"
           class="btn btn-erp btn-erp-secondary btn-erp-sm open-tab"
           data-tab-id="cash-receipts"
           data-tab-title="قائمة أذون استلام نقدية">فتح القائمة الرئيسية</a>
    </div>

    <div class="erp-list-table-frame erp-table-scroll-container erp-list-table-after-summary mt-2 ps-0 pe-0" dir="rtl">
        <div class="erp-table-wrapper" style="max-height: 65vh; overflow-y: auto; overflow-x: auto;">
            <table class="table table-striped table-hover erp-table">
                <thead class="table-light">
                    <tr>
                        <th>رقم الإذن</th>
                        <th>رقم المستند</th>
                        <th>العميل</th>
                        <th>المنطقة</th>
                        <th>المبلغ</th>
                        <th>حالة الترحيل</th>
                        <th>فتح</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Receipts.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">لا توجد إيصالات لنفس الدورة بهذا التاريخ.</td></tr>
                    }
                    else
                    {
                        foreach (var r in Model.Receipts)
                        {
                            <tr>
                                <td>@r.CashReceiptId</td>
                                <td>@r.ReceiptNumber</td>
                                <td>@(r.Customer?.CustomerName ?? "-")</td>
                                <td>@(r.Customer?.Area?.AreaName ?? r.Customer?.RegionName ?? "-")</td>
                                <td>@r.Amount.ToString("N2")</td>
                                <td>@(r.IsPosted ? "مرحل" : "غير مرحل")</td>
                                <td>
                                    <a asp-action="Edit"
                                       asp-controller="CashReceipts"
                                       asp-route-id="@r.CashReceiptId"
                                       asp-route-frame="1"
                                       class="btn btn-erp btn-erp-secondary btn-erp-sm open-tab"
                                       data-tab-id="cash-receipt-@r.CashReceiptId"
                                       data-tab-title="إذن استلام @r.CashReceiptId">عرض</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        const customerCode = document.getElementById('quickCustomerCode');
        const customerText = document.getElementById('quickCustomerText');
        const customerId = document.getElementById('quickCustomerId');
        const customerSource = document.getElementById('quickCustomerSource');
        const customerArrow = document.getElementById('batchCustomerArrow');
        const customerWrap = document.getElementById('batchCustomerWrap');
        const customerDropdown = document.getElementById('batchCustomerDropdownList');
        const amount = document.getElementById('quickAmount');
        const addBtn = document.getElementById('quickAddBtn');
        const form = document.getElementById('quickBatchForm');
        const autoFocusCustomer = @Html.Raw(autoFocusCustomer ? "true" : "false");
        if (!form || !customerCode || !customerText || !customerId || !customerSource || !customerWrap || !customerDropdown || !amount || !addBtn) return;
        if (customerText.disabled || amount.disabled || customerCode.disabled) return;

        const hardDisableSavedInfo = function (el, seed) {
            if (!el) return;
            el.setAttribute('autocomplete', 'off');
            el.setAttribute('autocorrect', 'off');
            el.setAttribute('autocapitalize', 'off');
            el.setAttribute('spellcheck', 'false');
            el.setAttribute('data-form-type', 'other');
            const token = seed + '_' + Date.now().toString(36);
            el.setAttribute('name', token);
            el.setAttribute('readonly', 'readonly');
            el.addEventListener('focus', function unlockOnce() {
                el.removeAttribute('readonly');
                el.removeEventListener('focus', unlockOnce);
            }, { once: true });
        };
        hardDisableSavedInfo(customerText, 'batch_customer_lookup');
        hardDisableSavedInfo(customerCode, 'batch_customer_code_lookup');

        let options = Array.from(customerSource.options || [])
            .map(function (o) { return { id: (o.value || '').trim(), name: (o.text || '').trim() }; })
            .filter(function (x) { return x.id && x.name; });

        const areaInput = form.querySelector('input[name="areaId"]');
        const distInput = form.querySelector('input[name="distributorEmployeeId"]');
        const renderSourceOptions = function () {
            if (!customerSource) return;
            customerSource.innerHTML = options.map(function (x) {
                return '<option value="' + x.id + '">' + x.name + '</option>';
            }).join('');
        };
        const loadBatchCustomers = async function () {
            const areaId = (areaInput?.value || '').trim();
            if (!areaId) return;
            try {
                const url = '@Url.Action("GetBatchCustomers", "CashReceipts")'
                    + '?areaId=' + encodeURIComponent(areaId)
                    + '&distributorEmployeeId=' + encodeURIComponent((distInput?.value || '').trim());
                const resp = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!resp.ok) return;
                const data = await resp.json();
                if (!Array.isArray(data)) return;
                options = data
                    .map(function (x) { return { id: String(x.id || '').trim(), name: String(x.name || '').trim() }; })
                    .filter(function (x) { return x.id && x.name; });
                renderSourceOptions();
            } catch {
                // تجاهل خطأ الشبكة: يبقى الاعتماد على العناصر المحلية.
            }
        };

        const findExact = function (txt) {
            const v = normalize(txt);
            if (!v) return null;
            return options.find(function (x) { return normalize(x.name) === v; }) || null;
        };
        const findById = function (idText) {
            const v = (idText || '').trim();
            if (!v) return null;
            return options.find(function (x) { return x.id === v; }) || null;
        };
        const fetchByCode = async function (codeText) {
            const code = (codeText || '').trim();
            const areaId = (areaInput?.value || '').trim();
            if (!code) return null;
            try {
                const url = '@Url.Action("GetBatchCustomerByCode", "CashReceipts")'
                    + '?areaId=' + encodeURIComponent(areaId)
                    + '&code=' + encodeURIComponent(code);
                const resp = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!resp.ok) return null;
                const data = await resp.json();
                if (!data || !data.found || !data.id || !data.name) return null;
                return { id: String(data.id).trim(), name: String(data.name).trim() };
            } catch {
                return null;
            }
        };

        const findStartsWith = function (txt) {
            const v = normalize(txt);
            if (!v) return null;
            return options.find(function (x) { return normalize(x.name).startsWith(v); }) || null;
        };
        const normalize = function (s) {
            return (s || '').toString().trim().toLowerCase()
                .replace(/[\u064B-\u0652]/g, '')
                .replace(/أ|إ|آ/g, 'ا')
                .replace(/ى/g, 'ي')
                .replace(/ة/g, 'ه');
        };
        const filterByText = function (txt) {
            const raw = (txt || '').trim();
            const v = normalize(raw);
            if (!v) return options.slice(0, 50);
            return options
                .filter(function (x) {
                    const n = normalize(x.name);
                    return n.includes(v) || x.id.includes(raw);
                })
                .slice(0, 50);
        };
        let highlightedIndex = -1;
        let currentVisible = [];

        const closeDropdown = function () {
            customerDropdown.innerHTML = '';
            customerDropdown.setAttribute('data-open', 'false');
            highlightedIndex = -1;
            currentVisible = [];
        };
        const positionDropdown = function () {
            if (customerDropdown.getAttribute('data-open') !== 'true') return;
            const r = customerWrap.getBoundingClientRect();
            customerDropdown.style.width = r.width + 'px';
            customerDropdown.style.top = r.bottom + 'px';
            customerDropdown.style.left = r.left + 'px';
        };
        const openDropdown = function (items) {
            currentVisible = items || [];
            if (!currentVisible.length) {
                closeDropdown();
                return;
            }
            customerDropdown.innerHTML = currentVisible.map(function (item, idx) {
                const cls = idx === highlightedIndex ? 'product-dropdown-item py-2 px-3 product-dropdown-item-active' : 'product-dropdown-item py-2 px-3';
                return '<div class="' + cls + '" data-id="' + item.id + '" data-name="' + item.name + '" role="option">' +
                       '<span class="fw-semibold">' + item.name + '</span></div>';
            }).join('');
            customerDropdown.setAttribute('data-open', 'true');
            positionDropdown();
        };
        const selectCustomer = function (item) {
            if (!item) return false;
            customerId.value = item.id;
            customerCode.value = item.id;
            customerText.value = item.name;
            customerText.classList.add('customer-selected');
            closeDropdown();
            return true;
        };
        const selectCustomerWithTypedCode = function (item, typedCode) {
            if (!item) return false;
            customerId.value = item.id;
            customerCode.value = (typedCode || item.id || '').toString().trim();
            customerText.value = item.name;
            customerText.classList.add('customer-selected');
            closeDropdown();
            return true;
        };

        const syncCustomerId = function () {
            const exact = findExact(customerText.value);
            if (exact) {
                customerId.value = exact.id;
                customerCode.value = exact.id;
                customerText.classList.add('customer-selected');
                return true;
            }
            const byCode = findById(customerCode.value);
            if (byCode) {
                customerId.value = byCode.id;
                customerText.value = byCode.name;
                customerText.classList.add('customer-selected');
                return true;
            }
            customerText.classList.remove('customer-selected');
            customerId.value = '';
            return !!exact;
        };

        const pickFirstMatchIfAny = function () {
            if (syncCustomerId()) { closeDropdown(); return true; }

            const listFromTyped = filterByText(customerText.value);
            if (listFromTyped.length > 0) {
                return selectCustomer(listFromTyped[0]);
            }

            if (currentVisible.length > 0) {
                return selectCustomer(currentVisible[0]);
            }

            const match = findStartsWith(customerText.value);
            if (!match) return false;
            return selectCustomer(match);
        };

        const focusCustomer = function () { customerText.focus(); customerText.select(); };
        const focusAmount = function () { amount.focus(); amount.select(); };
        const submitQuickReceipt = function () {
            const amountValue = parseFloat((amount.value || '').toString());
            if (!amountValue || amountValue <= 0) {
                focusAmount();
                return;
            }
            if (!customerId.value && !pickFirstMatchIfAny()) {
                openDropdown(filterByText(customerText.value));
                focusCustomer();
                return;
            }

            addBtn.disabled = true;
            addBtn.textContent = 'جاري الإضافة...';
            form.submit();
        };

        customerCode.addEventListener('input', function () {
            const byCode = findById(customerCode.value);
            if (byCode) {
                selectCustomer(byCode);
                return;
            }
            customerId.value = '';
            customerText.value = '';
            customerText.classList.remove('customer-selected');
        });
        customerCode.addEventListener('change', async function () {
            const typedCode = (customerCode.value || '').trim();
            if (!typedCode) {
                customerId.value = '';
                customerText.value = '';
                customerText.classList.remove('customer-selected');
                return;
            }
            const byCode = findById(typedCode);
            if (byCode) {
                selectCustomerWithTypedCode(byCode, typedCode);
                return;
            }
            const remote = await fetchByCode(typedCode);
            if (remote) {
                if (!options.some(function (x) { return x.id === remote.id; })) {
                    options.push(remote);
                    renderSourceOptions();
                }
                selectCustomerWithTypedCode(remote, typedCode);
            }
        });

        customerText.addEventListener('input', function () {
            customerText.classList.remove('customer-selected');
            customerId.value = '';
            customerCode.value = '';
            highlightedIndex = -1;
            openDropdown(filterByText(customerText.value));
        });
        customerText.addEventListener('change', function () {
            syncCustomerId();
        });

        customerText.addEventListener('blur', function () {
            setTimeout(function () {
                syncCustomerId();
                closeDropdown();
            }, 120);
        });

        if (customerArrow) {
            customerArrow.addEventListener('click', function () {
                customerText.focus();
                highlightedIndex = -1;
                openDropdown(filterByText(customerText.value));
            });
        }

        customerDropdown.addEventListener('click', function (e) {
            const btn = e.target.closest('[data-id]');
            if (!btn) return;
            selectCustomer({ id: btn.getAttribute('data-id') || '', name: btn.getAttribute('data-name') || '' });
            focusAmount();
        });
        document.addEventListener('click', function (e) {
            if (!customerWrap.contains(e.target)) closeDropdown();
        });
        window.addEventListener('resize', positionDropdown);
        window.addEventListener('scroll', positionDropdown, true);

        (async function initBatchCustomers() {
            if (!options.length) {
                await loadBatchCustomers();
            }
            setTimeout(function () {
                // في شاشة الإدخال السريع نبدأ دائمًا من العميل لتسريع الدورة.
                if (autoFocusCustomer) focusCustomer();
                else focusCustomer();
            }, 120);
        })();

        customerText.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                if (!currentVisible.length) openDropdown(filterByText(customerText.value));
                if (currentVisible.length) {
                    highlightedIndex = Math.min(highlightedIndex + 1, currentVisible.length - 1);
                    openDropdown(currentVisible);
                }
                return;
            }
            if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (!currentVisible.length) openDropdown(filterByText(customerText.value));
                if (currentVisible.length) {
                    highlightedIndex = Math.max(highlightedIndex - 1, 0);
                    openDropdown(currentVisible);
                }
                return;
            }
            if (e.key === 'Enter') {
                e.preventDefault();
                if (highlightedIndex >= 0 && highlightedIndex < currentVisible.length) {
                    selectCustomer(currentVisible[highlightedIndex]);
                } else {
                    if (!pickFirstMatchIfAny()) {
                        openDropdown(filterByText(customerText.value));
                        return;
                    }
                }
                focusAmount();
                return;
            }
            if (e.key === 'Escape') {
                closeDropdown();
            }
        });

        customerCode.addEventListener('keydown', async function (e) {
            if (e.key !== 'Enter') return;
            e.preventDefault();
            const typedCode = (customerCode.value || '').trim();
            if (!typedCode) {
                focusCustomer();
                return;
            }
            let found = findById(typedCode);
            if (!found) {
                found = await fetchByCode(typedCode);
                if (found && !options.some(function (x) { return x.id === found.id; })) {
                    options.push(found);
                    renderSourceOptions();
                }
            }
            if (found) {
                selectCustomerWithTypedCode(found, typedCode);
                focusAmount();
                return;
            }
            customerId.value = '';
            customerText.value = '';
            customerText.classList.remove('customer-selected');
            focusCustomer();
            openDropdown([]);
        });

        // نفس سلوك فاتورة المبيعات: فتح القائمة بالكتابة فقط أو بالسهم ▼
        customerText.addEventListener('focus', function () {
            // لا نفتح تلقائياً عند الفوكس فقط.
        });

        amount.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                submitQuickReceipt();
            }
        });

        addBtn.addEventListener('click', function (e) {
            e.preventDefault();
            submitQuickReceipt();
        });
    })();
</script>
}
