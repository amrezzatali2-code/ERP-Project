@using ERP.Models
@model List<Batch>
@{
    ViewData["Title"] = "تشغيلات الأصناف";
}

<h2 class="mb-3">تشغيلات الأصناف</h2>

@await Html.PartialAsync("~/Views/Shared/_IndexFilters.cshtml")

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>الصنف</th>
            <th>التشغيلة</th>
            <th>الصلاحية</th>
            <th class="text-end">سعر الجمهور (تشغيلة)</th>
            <th class="text-end">تكلفة افتراضية</th>
            <th>تاريخ الإدخال</th>
            <th>العميل</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr><td colspan="7" class="text-center text-muted">لا توجد بيانات.</td></tr>
        }
        else
        {
            foreach (var x in Model)
            {
                <tr>
                    <td>@x.ProdId</td>
                    <td>@x.BatchNo</td>
                    <td>@x.Expiry.ToString("yyyy-MM")</td>
                    <td class="text-end">@((x.PriceRetailBatch ?? 0m).ToString("0.00"))</td>
                    <td class="text-end">@((x.UnitCostDefault ?? 0m).ToString("0.0000"))</td>
                    <td>@x.EntryDate.ToString("yyyy-MM-dd")</td>
                    <td>@x.CustomerId</td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="d-flex align-items-center justify-content-between mt-2">
    <div class="btn-group">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", new { page = 1, pageSize = ViewBag.PageSize, search = ViewBag.Search, searchBy = ViewBag.SearchBy, sort = ViewBag.Sort, dir = ViewBag.Dir })">الأول</a>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", new { page = Math.Max(1, (int)ViewBag.Page - 1), pageSize = ViewBag.PageSize, search = ViewBag.Search, searchBy = ViewBag.SearchBy, sort = ViewBag.Sort, dir = ViewBag.Dir })">السابق</a>
        <a class="btn btn-outline-secondary disabled">@ViewBag.Page / @ViewBag.TotalPages</a>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", new { page = Math.Min((int)ViewBag.TotalPages, (int)ViewBag.Page + 1), pageSize = ViewBag.PageSize, search = ViewBag.Search, searchBy = ViewBag.SearchBy, sort = ViewBag.Sort, dir = ViewBag.Dir })">التالي</a>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", new { page = ViewBag.TotalPages, pageSize = ViewBag.PageSize, search = ViewBag.Search, searchBy = ViewBag.SearchBy, sort = ViewBag.Sort, dir = ViewBag.Dir })">الأخير</a>
    </div>

    <form method="get" action="@Url.Action("Index", "Batches")" class="d-flex align-items-center gap-2">
        <label class="form-label mb-0">حجم الصفحة</label>
        <select name="pageSize" class="form-select" style="width:90px" onchange="this.form.submit()">
            @{
                var sz = (int)ViewBag.PageSize;
                int[] sizes = new[] { 25, 50, 100, 200 };
                foreach (var s in sizes)
                {
                    <option value="@s" selected="@(s == sz)">@s</option>
                }
            }
        </select>
        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="search" value="@ViewBag.Search" />
        <input type="hidden" name="searchBy" value="@ViewBag.SearchBy" />
        <input type="hidden" name="sort" value="@ViewBag.Sort" />
        <input type="hidden" name="dir" value="@ViewBag.Dir" />
    </form>
</div>

<div class="small text-muted mt-1">
    عرض @ViewBag.RangeStart - @ViewBag.RangeEnd من @ViewBag.TotalRows
</div>
