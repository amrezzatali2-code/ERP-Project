@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.Batch>

@{
    ViewData["Title"] = "تشغيلات الأصناف";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "Batches";

    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var searchMode = (string?)ViewBag.SearchMode ?? "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "expiry";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    // =========================
    // ✅ أمان للـ Paging (مهم جدًا)
    // المشكلة اللي كانت بتحصل: لو pageSize جه = 0
    // بيؤدي لعرض فاضي عند الترتيب أو تغيير حجم الصفحة.
    // =========================
    int ps = (int?)ViewBag.PageSize ?? Model.PageSize;
    if (ps < 0) ps = 10;

    int total = Model.TotalCount;            // متغير: إجمالي النتائج
    int page = Model.PageNumber;             // متغير: رقم الصفحة
    if (page <= 0) page = 1;                 // ثابت أمان

    int pages = Model.TotalPages;            // متغير: إجمالي الصفحات
    if (pages <= 0) pages = 1;               // ثابت أمان

    int start = total == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
    int end = (ps == 0 || total == 0) ? total : Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_prod = ViewBag.FilterCol_Prod as string;
    string? filterCol_batchno = ViewBag.FilterCol_BatchNo as string;
    string? filterCol_expiry = ViewBag.FilterCol_Expiry as string;
    string? filterCol_price = ViewBag.FilterCol_Price as string;
    string? filterCol_cost = ViewBag.FilterCol_Cost as string;
    string? filterCol_active = ViewBag.FilterCol_Active as string;
    string? filterCol_created = ViewBag.FilterCol_Created as string;
    string? filterCol_updated = ViewBag.FilterCol_Updated as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_prodExpr = ViewBag.FilterCol_ProdExpr as string;
    string? filterCol_priceExpr = ViewBag.FilterCol_PriceExpr as string;
    string? filterCol_costExpr = ViewBag.FilterCol_CostExpr as string;
    int activeCount = ViewBag.ActiveCountFiltered != null ? (int)ViewBag.ActiveCountFiltered : 0;
    decimal totalPriceRetail = ViewBag.TotalPriceRetailFiltered != null ? (decimal)ViewBag.TotalPriceRetailFiltered : 0m;
    decimal totalUnitCost = ViewBag.TotalUnitCostFiltered != null ? (decimal)ViewBag.TotalUnitCostFiltered : 0m;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_prod,
        filterCol_batchno,
        filterCol_expiry,
        filterCol_price,
        filterCol_cost,
        filterCol_active,
        filterCol_created,
        filterCol_updated,
        filterCol_idExpr,
        filterCol_prodExpr,
        filterCol_priceExpr,
        filterCol_costExpr
    })!;

    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var safePageSize = ps < 0 ? 10 : ps;

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            searchMode,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = safePageSize,
            useDateRange,
            fromDate,
            toDate,
            fromCode,
            toCode,
            filterCol_id,
            filterCol_prod,
            filterCol_batchno,
            filterCol_expiry,
            filterCol_price,
            filterCol_cost,
            filterCol_active,
            filterCol_created,
            filterCol_updated
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    string? FilterForCol(string colKey) => colKey switch
    {
        "id" => filterCol_id,
        "prod" => filterCol_prod,
        "batchno" => filterCol_batchno,
        "expiry" => filterCol_expiry,
        "price" => filterCol_price,
        "cost" => filterCol_cost,
        "active" => filterCol_active,
        "created" => filterCol_created,
        "updated" => filterCol_updated,
        _ => null
    };

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        var currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter)
            || ((colKey == "id" || colKey == "prod" || colKey == "price" || colKey == "cost")
                && !string.IsNullOrWhiteSpace(colKey == "id" ? filterCol_idExpr :
                                              colKey == "prod" ? filterCol_prodExpr :
                                              colKey == "price" ? filterCol_priceExpr :
                                              filterCol_costExpr));
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

@functions {
    // =========================================================
    // دالة مساعدة: قراءة رقم فاتورة الشراء من Batch (لو موجودة في الموديل)
    // الهدف: ما نكسرش الـ Compile لو الخاصية لسه مش مضافة عندك.
    // =========================================================
    private int? ReadBatchPurchaseInvoiceNo(object? batch)
    {
        if (batch == null) return null;

        var t = batch.GetType();

        // أسماء محتملة للخاصية حسب اللي ممكن تكون كتبته
        string[] propNames = new[]
        {
            "PurchaseInvoiceId",
            "PIId",
            "PurchaseInvoiceNo",
            "PINo",
            "PurchaseInvoiceNumber",
            "LastPurchaseInvoiceId"
        };

        foreach (var name in propNames)
        {
            var p = t.GetProperty(name);
            if (p == null) continue;

            var v = p.GetValue(batch);
            if (v == null) return null;

            if (v is int i) return i;
            if (int.TryParse(Convert.ToString(v), out var parsed))
                return parsed;
        }

        return null;
    }
}

