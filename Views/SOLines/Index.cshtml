@section Scripts {
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        // يبدأ شريط التمرير الأفقي من اليمين (RTL)
        (function () {
            function scrollToRight(id) {
                var el = document.getElementById(id);
                if (!el) return;
                requestAnimationFrame(function () {
                    el.scrollLeft = el.scrollWidth - el.clientWidth;
                });
            }
            scrollToRight("solTableScrollContainer");
            scrollToRight("solTableWrapper");
            window.addEventListener("resize", function () {
                scrollToRight("solTableScrollContainer");
                scrollToRight("solTableWrapper");
            });
        })();
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // اختيار صف + أزرار عرض / حركة الصنف (سكربت مشترك)
        // =========================
        if (typeof ERP !== "undefined" && ERP.initListSelection) {
            ERP.initListSelection({
                showButtonId: "btnShowSOLine",
                movementButtonId: "btnMovementSOLine",
                movementUrlAttribute: "data-movement-url",
                movementTabTitle: "حركة الصنف",
                movementTabId: "product-movement-tab",
                idAttribute: "data-row-id",
                showUrlAttribute: "data-show-url",
                tabTitleAttribute: "data-tab-title",
                showTabId: "so-show-tab"
            });
        }

        if (typeof ERP !== "undefined" && ERP.initListColumnFilter) {
            ERP.initListColumnFilter({
                panelId: "erpColumnFilterPanel",
                tableId: "solTable",
                wrapperId: "solTableWrapper",
                getColumnValuesUrl: "@Url.Action("GetColumnValues", "SOLines")",
                defaultSort: "SOId",
                defaultDir: "asc",
                numericColumns: ["soid", "lineno", "prod", "qty", "reqretail", "disc", "linetotal"]
            });
        }

        // =========================
        // تشيك بوكس الصفوف + تحديد الكل (نفس فكرة فواتير المبيعات)
        // =========================
        (function () {
            const table = document.getElementById("solTable");
            if (!table) return;
            const chkAll = document.getElementById("chkAllRowsSOL");
            const rowsChk = () => table.querySelectorAll("tbody .erp-list-selectable-row .row-select");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(function (cb) { cb.checked = chkAll.checked; });
            });

            table.addEventListener("change", function (e) {
                const t = e.target;
                if (t && t.classList && t.classList.contains("row-select")) {
                    if (!t.checked && chkAll) chkAll.checked = false;
                }
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("solTable");
            if (!table) return;

            const storageKey = "sol-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListSOL");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsSOL")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalSOL");
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });

            function getVisibleColsInTableOrder() {
                const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
                const ordered = headerCells
                    .filter(th => !th.hasAttribute("data-col-fixed"))
                    .map(th => th.getAttribute("data-col"))
                    .filter(Boolean);

                let hiddenCols = [];
                try {
                    const saved = localStorage.getItem(storageKey);
                    if (saved) hiddenCols = JSON.parse(saved) || [];
                } catch { hiddenCols = []; }

                const hiddenSet = new Set(hiddenCols.map(x => String(x)));
                return ordered.filter(k => !hiddenSet.has(String(k)));
            }

            document.querySelectorAll("form.erp-export-form").forEach(function (form) {
                form.addEventListener("submit", function () {
                    const inp = form.querySelector("input[name='visibleCols']");
                    if (!inp) return;
                    inp.value = getVisibleColsInTableOrder().join(",");
                });
            });
        })();

        // =========================
        // فلتر رقم السطر من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyLineFilter");
            const btnClear = document.getElementById("btnClearLineFilter");
            const fromInp = document.getElementById("lineFromInput");
            const toInp = document.getElementById("lineToInput");

            function buildUrl(lineFrom, lineTo) {
                const url = new URL(window.location.href);

                if (lineFrom) url.searchParams.set("fromCode", lineFrom);
                else url.searchParams.delete("fromCode");

                if (lineTo) url.searchParams.set("toCode", lineTo);
                else url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const lf = fromInp.value.trim();
                const lt = toInp.value.trim();
                window.location.href = buildUrl(lf, lt);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value = "";
                window.location.href = buildUrl("", "");
            });
        })();

    </script>
}
