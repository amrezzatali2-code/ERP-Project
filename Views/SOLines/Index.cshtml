@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@using System.Linq                         @* علشان نستخدم Sum و Any على القائمة *@
@model PagedResult<SOLine>

@{
    ViewData["Title"] = "أصناف أوامر البيع";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "SOLines";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "SOId";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    // بيانات الترقيم
    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلتر رقم أمر البيع (لو دخلنا من شاشة الهيدر برقم محدد)
    int? filterSOId = ViewBag.FilterSOId as int?;
    string soIdText = filterSOId?.ToString() ?? "";

    // فلتر كود من/إلى (هنا نستخدمه كـ "من رقم سطر / إلى رقم سطر")
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    // اسم حقل التاريخ المستخدم في فلترة التاريخ/الوقت (نستهدف تاريخ الهيدر SODate)
    var dateField = (string?)ViewBag.DateField ?? "SODate";

    // إجماليات الصفحة الحالية (للاستعراض فقط)
    decimal pageTotalQty = 0m;   // إجمالي الكمية في الصفحة
    decimal pageTotalValue = 0m;   // إجمالي قيمة السطور المتوقعة في الصفحة

    if (Model.Items != null && Model.Items.Any())
    {
        pageTotalQty = Model.Items.Sum(x => (decimal)x.QtyRequested);
        pageTotalValue = Model.Items.Sum(x => x.ExpectedLineTotal);
    }

    // دالة توليد لينكات الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        soId = filterSOId,
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField,
        fromCode,
        toCode
    })!;

    // دالة إنشاء لينك الترتيب في رأس الجدول + أيقونة السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            soId = filterSOId,
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange = Model.UseDateRange,
            fromDate = Model.FromDate,
            toDate = Model.ToDate,
            dateField,
            fromCode,
            toCode
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };
}

<div dir="rtl" class="container-fluid">

    <h2 class="mb-3">
        أصناف أوامر البيع
        @if (filterSOId.HasValue)
        {
            <span class="text-muted fs-6">— أمر رقم @filterSOId</span>
        }
    </h2>

    @* رسائل نجاح/خطأ *@
    @if (TempData["ok"] is string ok)
    {
        <div class="alert alert-success">@ok</div>
    }
    @if (TempData["error"] is string err)
    {
        <div class="alert alert-danger">@err</div>
    }

    @* ===== الكارت العلوي: بحث + فلتر رقم سطر + أزرار التحكم ===== *@
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* العمود الأول: البحث العام *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث</label>
                        </div>

                        <div class="col-sm-4">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-4">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                <option value="all"
                                       @Html.Raw(searchBy == "all" ? " selected" : "")>
                                    الكل
                                </option>

                                <option value="soid"
                                       @Html.Raw(searchBy == "soid" ? " selected" : "")>
                                    رقم الأمر
                                </option>

                                <option value="lineno"
                                       @Html.Raw(searchBy == "lineno" ? " selected" : "")>
                                    رقم السطر
                                </option>

                                <option value="prod"
                                       @Html.Raw(searchBy == "prod" ? " selected" : "")>
                                    كود الصنف
                                </option>

                                <option value="qty"
                                       @Html.Raw(searchBy == "qty" ? " selected" : "")>
                                    الكمية
                                </option>

                                <option value="batch"
                                       @Html.Raw(searchBy == "batch" ? " selected" : "")>
                                    التشغيلة المفضّلة
                                </option>

                                <option value="pricebasis"
                                       @Html.Raw(searchBy == "pricebasis" ? " selected" : "")>
                                    مرجع السعر
                                </option>
                            </select>
                        </div>

                        @* الحفاظ على باقي الفلاتر مع البحث *@
                        <input type="hidden" name="soId" value="@soIdText" />
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="dateField" value="@dateField" />
                        <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                        @if (Model.FromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                        }
                        @if (Model.ToDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                        }
                        @if (fromCode.HasValue)
                        {
                            <input type="hidden" name="fromCode" value="@fromCode" />
                        }
                        @if (toCode.HasValue)
                        {
                            <input type="hidden" name="toCode" value="@toCode" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">
                                بحث
                            </button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm"
                               href="@Url.Action(action, controller, new { soId = filterSOId })">
                                إلغاء
                            </a>
                        </div>
                    </form>
                </div>

                @* العمود الثاني: فلتر من رقم سطر / إلى رقم سطر *@
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-semibold">من رقم سطر</span>
                        <input id="lineFromInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(fromCode?.ToString() ?? "")" />

                        <span class="fw-semibold">إلى رقم سطر</span>
                        <input id="lineToInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(toCode?.ToString() ?? "")" />

                        <button type="button"
                                id="btnApplyLineFilter"
                                class="btn btn-erp btn-erp-primary btn-erp-sm">
                            تطبيق الفلتر
                        </button>

                        <button type="button"
                                id="btnClearLineFilter"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            مسح
                        </button>
                    </div>
                </div>

                @* العمود الثالث: أزرار الفلاتر / الحذف / الطباعة / التصدير *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        @* فلترة بالتاريخ/الوقت (تاريخ الهيدر SODate) *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#dateFilterModal">
                            فلترة بتاريخ أمر البيع
                        </button>

                        @* اختيار الأعمدة *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalSOL">
                            اختيار الأعمدة
                        </button>

                        @* حذف الأسطر المحددة *@
                        <form id="bulkDeleteForm"
                              asp-action="BulkDelete"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="selectedKeys" id="selectedKeysInput" />
                            <button type="button"
                                    id="btnDeleteSelected"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف الأسطر المحددة
                            </button>
                        </form>

                        @* طباعة (الجدول فقط) *@
                        <button type="button"
                                id="btnPrint"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        @* تصدير (لو عملت أكشن Export لاحقًا) *@
                        <form method="get"
                              asp-action="Export"
                              asp-controller="SOLines"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            <input type="hidden" name="soId" value="@soIdText" />
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                            @if (Model.FromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                            }
                            @if (Model.ToDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                            }
                            @if (fromCode.HasValue)
                            {
                                <input type="hidden" name="fromCode" value="@fromCode" />
                            }
                            @if (toCode.HasValue)
                            {
                                <input type="hidden" name="toCode" value="@toCode" />
                            }

                            <select name="format"
                                    class="form-select form-select-sm"
                                    style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm">
                                تصدير
                            </button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

    @* ===== جدول سطور أمر البيع ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="solTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    @* اختيار الصف *@
                    <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    <th data-col="soid">@sortLink("SOId", "رقم الأمر")</th>
                    <th data-col="lineno">@sortLink("LineNo", "رقم السطر")</th>
                    <th data-col="prod">@sortLink("ProdId", "كود الصنف")</th>
                    <th data-col="qty">@sortLink("Qty", "الكمية المطلوبة")</th>
                    <th data-col="reqretail">@sortLink("RequestedRetailPrice", "سعر الجمهور المطلوب")</th>
                    <th data-col="disc">@sortLink("SalesDiscountPct", "خصم المبيعات %")</th>
                    <th data-col="unitprice">@sortLink("ExpectedUnitPrice", "السعر المتوقع للوحدة")</th>
                    <th data-col="linetotal">@sortLink("ExpectedLineTotal", "قيمة السطر المتوقعة")</th>
                    <th data-col="batch">@sortLink("Batch", "التشغيلة المفضّلة")</th>
                    <th data-col="expiry">@sortLink("PreferredExpiry", "الصلاحية المفضّلة")</th>
                    <th data-col="pricebasis">@sortLink("PriceBasis", "مرجع السعر")</th>

                    <th class="text-nowrap no-print"
                        data-col="actions"
                        data-col-fixed="true"
                        style="width:140px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="13" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var line in Model.Items)
                    {
                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@($"{line.SOId}:{line.LineNo}")" />
                            </td>

                            <td data-col="soid">@line.SOId</td>
                            <td data-col="lineno">@line.LineNo</td>
                            <td data-col="prod">@line.ProdId</td>
                            <td data-col="qty">@line.QtyRequested</td>
                            <td data-col="reqretail">@line.RequestedRetailPrice.ToString("0.00")</td>
                            <td data-col="disc">@line.SalesDiscountPct.ToString("0.00")</td>
                            <td data-col="unitprice">@line.ExpectedUnitPrice.ToString("0.0000")</td>
                            <td data-col="linetotal">@line.ExpectedLineTotal.ToString("0.00")</td>
                            <td data-col="batch">@line.PreferredBatchNo</td>
                            <td data-col="expiry">@((line.PreferredExpiry?.ToString("yyyy-MM") ?? ""))</td>
                            <td data-col="pricebasis">@line.PriceBasis</td>

                            <td class="text-nowrap no-print" data-col="actions">
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-soId="@line.SOId"
                                      asp-route-lineNo="@line.LineNo"
                                      onsubmit="return confirm('حذف هذا السطر من أمر البيع؟');"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-erp btn-erp-danger btn-erp-sm">
                                        حذف
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }

                    @* صف إجمالي الصفحة الحالية *@
                    <tr class="table-secondary fw-semibold">
                        <td class="no-print" data-col="select"></td>
                        <td data-col="soid"></td>
                        <td data-col="lineno"></td>
                        <td data-col="prod" class="text-end">
                            إجمالي الصفحة الحالية:
                        </td>

                        <td data-col="qty">@pageTotalQty</td>

                        <td data-col="reqretail"></td>
                        <td data-col="disc"></td>
                        <td data-col="unitprice"></td>

                        <td data-col="linetotal">@pageTotalValue.ToString("0.00")</td>

                        <td data-col="batch"></td>
                        <td data-col="expiry"></td>
                        <td data-col="pricebasis"></td>
                        <td class="no-print" data-col="actions"></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="soId" value="@soIdText" />
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            @if (Model.FromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
            }
            @if (Model.ToDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    <div class="no-print mt-1">
        <small class="text-muted d-none d-md-inline">
            إجمالي عدد الأسطر: @total
        </small>
    </div>

    @* ===== الترقيم (Pagination) ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة التاريخ/الوقت حسب تاريخ الهيدر SODate ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة سطور أمر البيع حسب تاريخ أمر البيع
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="soId" value="@soIdText" />
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(Model.UseDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller"
                       asp-route-soId="@soIdText">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="columnsModalSOL"
     tabindex="-1"
     aria-labelledby="columnsModalSOLLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalSOLLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListSOL"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsSOL"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط
        // =========================
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف + حذف محدد
        // =========================
        (function () {
            const table = document.getElementById("solTable");
            if (!table) return;

            const chkAll = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => {
                    cb.checked = chkAll.checked;
                });
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected");
            const bulkForm = document.getElementById("bulkDeleteForm");
            const selectedInput = document.getElementById("selectedKeysInput");

            btnDeleteSelected?.addEventListener("click", function () {
                const ids = [];

                rowsChk().forEach(cb => {
                    if (cb.checked) {
                        ids.push(cb.value);   // القيمة: "SOId:LineNo"
                    }
                });

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل سطر واحد.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف الأسطر المحددة؟")) return;

                selectedInput.value = ids.join(",");
                bulkForm.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("solTable");
            if (!table) return;

            const storageKey = "sol-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListSOL");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsSOL")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalSOL");
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر رقم السطر من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyLineFilter");
            const btnClear = document.getElementById("btnClearLineFilter");
            const fromInp = document.getElementById("lineFromInput");
            const toInp = document.getElementById("lineToInput");

            function buildUrl(lineFrom, lineTo) {
                const url = new URL(window.location.href);

                if (lineFrom) url.searchParams.set("fromCode", lineFrom);
                else url.searchParams.delete("fromCode");

                if (lineTo) url.searchParams.set("toCode", lineTo);
                else url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const lf = fromInp.value.trim();
                const lt = toInp.value.trim();
                window.location.href = buildUrl(lf, lt);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
