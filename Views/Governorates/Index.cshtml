        border-radius: 0.75rem; /* حواف مستديرة بسيطة */
        border: 1px solid #e0e0e0; /* إطار خفيف */
        box-shadow: 0 2px 4px rgba(0,0,0,.04); /* ظل خفيف */
    }

    /* الهيدر البسيط للكارت */
    .gov-filter-header {
        background-color: #f8f9fa; /* رمادي فاتح بدل الجريدنت */
        border-bottom: 1px solid #e0e0e0;
        padding: .4rem .75rem;
        font-size: .9rem;
        font-weight: 600;
        color: #333;
    }

    /* تكبير بسيط للمسافة داخل الكارت */
    .gov-filter-card .card-body {
        padding: .6rem .75rem;
    }

    /* شكل زرار البحث/الإلغاء داخل كروت الفلاتر */
    .gov-filter-card .btn-erp.btn-erp-secondary {
        padding-inline: .75rem;
        padding-block: .25rem;
        font-size: .85rem;
    }

    /* حتة صغيرة علشان أيقونة العدسة تبقى مظبوطة */
    .gov-filter-card .input-group-text {
        font-size: .9rem;
    }

    /* (اختياري) تصغير الهوامش شويّة بين الكروت لتدي شكل متماسك */
    .gov-filters-row > [class*="col-xxl"],
    .gov-filters-row > [class*="col-lg"],
