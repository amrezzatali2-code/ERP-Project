@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.Governorate>

@{
    ViewData["Title"] = "المحافظات";



    // متغيرات: نسترجع قيم البحث من الـ QueryString
    var q = Context.Request.Query;

    string search1 = q["search1"];
    string searchBy1 = string.IsNullOrWhiteSpace(q["searchBy1"])
        ? "name"
        : q["searchBy1"].ToString();

    string search2 = q["search2"];
    string searchBy2 = q["searchBy2"];

    string search3 = q["search3"];
    string searchBy3 = q["searchBy3"];

    string search4 = q["search4"];
    string searchBy4 = q["searchBy4"];





    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "Governorates";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "name";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "name";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    // نطاق العرض السفلي
    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلتر كود من/إلى (يُستخدم فقط في اللينكات والهيدن)
    int? CodeFrom = ViewBag.CodeFrom as int?;
    int? CodeTo = ViewBag.CodeTo as int?;

    var dateField = (string?)ViewBag.DateField ?? "created";   // created | updated

    // دالة توليد لينكات الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField = dateField
    })!;

    // دالة لإنشاء لينك الترتيب في رأس الجدول + أيقونة السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange = Model.UseDateRange,
            fromDate = Model.FromDate,
            toDate = Model.ToDate,
            dateField = dateField,
            CodeFrom,
            CodeTo
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };
}




<style>
    /* كروت فلاتر المحافظات فقط – من غير ما نلمس باقي الكروت في الموقع */

    /* شكل الكارت نفسه */
