    @* ===== جدول المحافظات (هو الوحيد اللي يتطبع) ===== *@
    <div class="erp-table-wrapper  erp-print-area">
        <table id="govTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    @* اختيار الصف *@
                    <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    <th data-col="id">@sortLink("id", "كود المحافظة")</th>
                    <th data-col="name">@sortLink("name", "اسم المحافظة")</th>
                    <th data-col="created">@sortLink("created", "تاريخ الإنشاء")</th>
                    <th data-col="updated">@sortLink("updated", "آخر تعديل")</th>

                    <th class="text-nowrap no-print" data-col="actions" data-col-fixed="true" style="width:200px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var g in Model.Items)
                    {
                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@g.GovernorateId" />
                            </td>

                            <td data-col="id">@g.GovernorateId</td>
                            <td data-col="name">@g.GovernorateName</td>
                            <td data-col="created">
                                @(g.CreatedAt.HasValue? g.CreatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")
                            </td>
                            <td data-col="updated">
                                @(g.UpdatedAt.HasValue? g.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")
                            </td>

                            <td class="text-nowrap no-print" data-col="actions">
                                <a class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                   asp-action="Details"
                                   asp-route-id="@g.GovernorateId">
                                    تفاصيل
                                </a>
                            <a class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                   asp-action="Edit"
                                   asp-route-id="@g.GovernorateId">
                                    تعديل
                                </a>
                            <a class="bbtn btn-erp btn-erp-secondary btn-erp-sm"
                                   asp-action="Delete"
                                   asp-route-id="@g.GovernorateId">
                                    حذف
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>


 

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة + الترقيم ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>



        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            @if (Model.FromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
            }
            @if (Model.ToDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
            }
            @if (CodeFrom.HasValue)
            {
                <input type="hidden" name="CodeFrom" value="@CodeFrom" />
            }
            @if (CodeTo.HasValue)
            {
                <input type="hidden" name="CodeTo" value="@CodeTo" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25" selected="@(ps == 25 ? "selected" : null)">25</option>
                <option value="50" selected="@(ps == 50 ? "selected" : null)">50</option>
                <option value="100" selected="@(ps == 100 ? "selected" : null)">100</option>
                <option value="200" selected="@(ps == 200 ? "selected" : null)">200</option>
            </select>
        </form>
    </div>

   
    <div>

        <small class="text-muted d-none d-md-inline">
             إجمالي المحافظات: @total
        </small>
    </div>


    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة التاريخ/الوقت ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ الإنشاء)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="CodeFrom" value="@(CodeFrom?.ToString() ?? "")" />
                    <input type="hidden" name="CodeTo" value="@(CodeTo?.ToString() ?? "")" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(Model.UseDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="columnsModalGov"
     tabindex="-1"
     aria-labelledby="columnsModalGovLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalGovLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListGov"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsGov"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط (بمساعدة CSS no-print / erp-print-area)
        // =========================
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table = document.getElementById("govTable");
            if (!table) return;

            const chkAll = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected");
            const bulkForm          = document.getElementById("bulkDeleteForm");
            const selectedInput     = document.getElementById("selectedIdsInput");

            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل محافظة واحدة للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف المحافظات المحددة؟")) return;

                selectedInput.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll   = document.getElementById("btnDeleteAll");
            const deleteAllForm  = document.getElementById("deleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع المحافظات. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("govTable");
            if (!table) return;

            const storageKey = "gov-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListGov");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsGov")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                            if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalGov");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر الكود من/إلى (نستخدم نفس IDs الحالية)
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("CodeFrom", codeFrom);
                else          url.searchParams.delete("CodeFrom");

                if (codeTo)   url.searchParams.set("CodeTo", codeTo);
                else          url.searchParams.delete("CodeTo");

                // نرجع لأول صفحة مع الحفاظ على باقي الفلاتر
                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();


          // تعليق: عند تحميل الصفحة نشغّل منطق تحريك عرض الأعمدة لهذا الجدول فقط
        document.addEventListener('DOMContentLoaded', function () {

            // 1) نجيب الـ wrapper الخاص بجدول المحافظات
            var wrapper = document.querySelector('.erp-table-wrapper');
            if (!wrapper) return; // لو مش موجود نخرج بهدوء

            // 2) نجيب الجدول نفسه من داخل الـ wrapper
            var table = wrapper.querySelector('table.erp-table');
            if (!table) return;

            // 3) نجيب كل عناوين الأعمدة (th) من رأس الجدول
            var ths = table.querySelectorAll('thead th');

            ths.forEach(function (th) {

                // تعليق: نخلي الـ th position: relative عشان نقدر نحط جوّاه المقبض
                th.style.position = 'relative';

                // إنشاء عنصر المقبض
                var handle = document.createElement('div');
                handle.className = 'erp-col-resize-handle'; // الكلاس اللي في الـ CSS

                // نضيف المقبض داخل رأس العمود
                th.appendChild(handle);

                // متغيرات لحفظ نقطة البداية
                var startX;      // مكان الماوس في البداية
                var startWidth;  // عرض العمود في البداية

                // حدث الضغط بالموس على المقبض
                handle.addEventListener('mousedown', function (e) {
                    e.preventDefault(); // منع تحديد النصوص أو السحب العادي

                    // حفظ وضع البداية
                    startX = e.pageX;           // مكان الماوس على محور X
                    startWidth = th.offsetWidth; // عرض العمود الحالي

                    // دالة: تتحرك مع الماوس وتغيّر عرض العمود
                    function onMouseMove(eMove) {
                        // فرق الحركة في الاتجاه الأفقي
                        var diffX = eMove.pageX - startX;

                        // في RTL: المستخدم هيجر المقبض ناحية اليمين لتكبير العمود
                        var newWidth = startWidth + diffX;

                        // حد أدنى للعرض عشان العمود ما يختفيش
                        if (newWidth < 50) newWidth = 50;

                        // تطبيق العرض الجديد على الـ th
                        th.style.width = newWidth + 'px';
                    }

                    // دالة: عند رفع الماوس نوقف المتابعة
                    function onMouseUp() {
                        document.removeEventListener('mousemove', onMouseMove);
                        document.removeEventListener('mouseup', onMouseUp);
                    }

                    // ربط الأحداث على مستوى المستند كله
                    document.addEventListener('mousemove', onMouseMove);
                    document.addEventListener('mouseup', onMouseUp);
                });
            });
        });

    </script>
}
