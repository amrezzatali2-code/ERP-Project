@model ERP.Models.Governorate
@{
    ViewData["Title"] = "تعديل محافظة";
}
<div dir="rtl" class="container" style="max-width:720px;">
    <h2 class="mb-3">تعديل محافظة</h2>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- أرسل المعرّف مخفيًا فقط -->
        <input type="hidden" asp-for="GovernorateId" />

        <!-- عرض المعرّف للقراءة فقط (بدون asp-for حتى لا يُعتبر قابلاً للتحرير) -->
        <div class="mb-3">
            <label class="form-label">معرّف المحافظة</label>
            <span class="form-control-plaintext d-block">@Model.GovernorateId</span>
            <div class="form-text">المعرّف لا يتغير.</div>
        </div>


        <div class="mb-3">
            <label asp-for="GovernorateName" class="form-label"></label>
            <input asp-for="GovernorateName" class="form-control" />
            <span asp-validation-for="GovernorateName" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">حفظ التعديلات</button>
            <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
