@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<PurchaseReturnLine>

@{
    ViewData["Title"] = "قائمة سطور مرتجع الشراء";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "PurchaseReturnLines";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "LineNo";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    // بيانات الترقيم
    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;
    var dateField = (string?)ViewBag.DateField ?? "Expiry";

    // لو الشاشة مفتوحة على مرتجع واحد
    int? pretId = ViewBag.PRetId as int?;

    // دالة توليد لينكات الترقيم
    string Link(int p) => Url.Action(action, controller, new
    {
        pretId,
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        dateField,
        fromCode,
        toCode
    })!;

    // دالة إنشاء لينك الترتيب في رأس الجدول + أيقونة السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            pretId,
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate,
            dateField,
            fromCode,
            toCode
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };
}

<div dir="rtl" class="container-fluid">

    @* لو الشاشة لسطور مرتجع معيّن نعرض شارة *@
    @if (pretId.HasValue)
    {
        <div class="alert alert-secondary py-2 mt-2">
            عرض سطور مرتجع الشراء رقم: <strong>@pretId</strong>
        </div>
    }

    @* ===== الكارت العلوي: بحث + فلتر رقم السطر + أزرار التحكم ===== *@
    <div class="card mb-3 d-print-none mt-2">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* العمود الأول: البحث *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <input type="hidden" name="pretId" value="@(pretId?.ToString() ?? "")" />

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث</label>
                        </div>

                        <div class="col-sm-4">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-4">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                @* الكل *@
                                <option value="all"
                                       @Html.Raw(searchBy == "all" ? " selected" : "")>
                                    الكل
                                </option>

                                @* البحث برقم المرتجع *@
                                <option value="id"
                                       @Html.Raw(searchBy == "id" ? " selected" : "")>
                                    رقم المرتجع
                                </option>

                                @* البحث برقم السطر *@
                                <option value="line"
                                       @Html.Raw(searchBy == "line" ? " selected" : "")>
                                    رقم السطر
                                </option>

                                @* البحث بكود الصنف *@
                                <option value="prod"
                                       @Html.Raw(searchBy == "prod" ? " selected" : "")>
                                    كود الصنف
                                </option>

                                @* البحث بالتشغيلة *@
                                <option value="batch"
                                       @Html.Raw(searchBy == "batch" ? " selected" : "")>
                                    التشغيلة
                                </option>

                                @* البحث بالكمية *@
                                <option value="qty"
                                       @Html.Raw(searchBy == "qty" ? " selected" : "")>
                                    الكمية
                                </option>
                            </select>
                        </div>

                        @* الحفاظ على باقي الفلاتر *@
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="dateField" value="@dateField" />
                        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                        @if (fromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                        }
                        @if (toDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                        }
                        @if (fromCode.HasValue)
                        {
                            <input type="hidden" name="fromCode" value="@fromCode" />
                        }
                        @if (toCode.HasValue)
                        {
                            <input type="hidden" name="toCode" value="@toCode" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">
                                بحث
                            </button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm"
                               href="@Url.Action(action, controller, new { pretId })">
                                إلغاء
                            </a>
                        </div>
                    </form>
                </div>

                @* العمود الثاني: فلتر رقم السطر من/إلى *@
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-semibold">من رقم سطر</span>
                        <input id="codeFromInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(fromCode?.ToString() ?? "")" />

                        <span class="fw-semibold">إلى رقم سطر</span>
                        <input id="codeToInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(toCode?.ToString() ?? "")" />

                        <button type="button"
                                id="btnApplyCodeFilter"
                                class="btn btn-erp btn-erp-primary btn-erp-sm">
                            تطبيق فلتر السطر
                        </button>

                        <button type="button"
                                id="btnClearCodeFilter"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            مسح
                        </button>
                    </div>
                </div>

                @* العمود الثالث: أزرار الحذف / الفلاتر / الطباعة / التصدير *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        @* حذف السطور المحددة (BulkDelete) *@
                        <form id="formBulkDelete"
                              asp-action="BulkDelete"
                              asp-controller="PurchaseReturnLines"
                              method="post"
                              class="d-inline">
                            <button type="button"
                                    id="btnBulkDelete"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف السطور المحددة
                            </button>
                        </form>

                        @* حذف جميع سطور مرتجعات الشراء (DeleteAll) *@
                        <form id="formDeleteAll"
                              asp-action="DeleteAll"
                              asp-controller="PurchaseReturnLines"
                              method="post"
                              class="d-inline">
                            <button type="submit"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm"
                                    onclick="return confirm('هل أنت متأكد من حذف جميع سطور مرتجعات الشراء؟');">
                                حذف جميع سطور مرتجعات الشراء
                            </button>
                        </form>

                        @* فلترة بالتاريخ/الوقت (تاريخ الصلاحية) *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#dateFilterModalPRL">
                            فلترة بالتاريخ/الوقت
                        </button>

                        @* اختيار الأعمدة *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalPRL">
                            اختيار الأعمدة
                        </button>

                        @* طباعة الجدول *@
                        <button type="button"
                                id="btnPrintPRL"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        @* تصدير (Export) *@
                        <form method="get"
                              asp-action="Export"
                              asp-controller="PurchaseReturnLines"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            <input type="hidden" name="pretId" value="@(pretId?.ToString() ?? "")" />
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="dateField" value="@dateField" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                            }
                            @if (toDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                            }
                            @if (fromCode.HasValue)
                            {
                                <input type="hidden" name="fromCode" value="@fromCode" />
                            }
                            @if (toCode.HasValue)
                            {
                                <input type="hidden" name="toCode" value="@toCode" />
                            }

                            <select name="format"
                                    class="form-select form-select-sm"
                                    style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm">
                                تصدير
                            </button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

    @* ===== جدول سطور مرتجع الشراء ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="prlTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    <th class="text-center no-print"
                        data-col="actions"
                        data-col-fixed="true"
                        style="width:170px;">
                        <input type="checkbox"
                               id="selectAll"
                               class="form-check-input" />
                    </th>

                    <th data-col="pretId">@sortLink("PRetId", "رقم المرتجع")</th>
                    <th data-col="lineNo">@sortLink("LineNo", "رقم السطر")</th>
                    <th data-col="prodId">@sortLink("ProdId", "كود الصنف")</th>
                    <th data-col="qty">@sortLink("Qty", "الكمية المرتجعة")</th>
                    <th data-col="priceRetail">@sortLink("PriceRetail", "سعر الجمهور")</th>
                    <th data-col="discount">@sortLink("PurchaseDiscountPct", "خصم الشراء %")</th>
                    <th data-col="unitCost">@sortLink("UnitCost", "تكلفة الوحدة")</th>
                    <th data-col="batch">@sortLink("BatchNo", "التشغيلة")</th>
                    <th data-col="expiry">@sortLink("Expiry", "الصلاحية")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var l in Model.Items)
                    {
                        <tr>
                            <td class="text-nowrap no-print" data-col="actions">
                                @* الشيك بوكس يحمل مفتاح مركب "PRetId:LineNo" *@
                                <input type="checkbox"
                                       class="form-check-input ms-2 row-select"
                                       value="@($"{l.PRetId}:{l.LineNo}")" />

                                <a class="btn btn-erp btn-erp-secondary btn-erp-sm ms-1"
                                   asp-action="Show"
                                   asp-route-pretId="@l.PRetId"
                                   asp-route-lineNo="@l.LineNo">
                                    عرض
                                </a>
                            </td>

                            <td data-col="pretId">@l.PRetId</td>
                            <td data-col="lineNo">@l.LineNo</td>
                            <td data-col="prodId">@l.ProdId</td>
                            <td data-col="qty">@l.Qty</td>
                            <td data-col="priceRetail">@l.PriceRetail.ToString("0.00")</td>
                            <td data-col="discount">@l.PurchaseDiscountPct.ToString("0.##")</td>
                            <td data-col="unitCost">@l.UnitCost.ToString("0.####")</td>
                            <td data-col="batch">@l.BatchNo</td>
                            <td data-col="expiry">
                                @(l.Expiry.HasValue? l.Expiry.Value.ToString("yyyy-MM") : "")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="pretId" value="@(pretId?.ToString() ?? "")" />
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
            }
            @if (toDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    <div class="no-print">
        <small class="text-muted d-none d-md-inline">
            إجمالي السطور: @total
        </small>
    </div>

    @* ===== الترقيم (Pagination) ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة التاريخ/الوقت (تاريخ الصلاحية) ===== *@
<div class="modal fade no-print"
     id="dateFilterModalPRL"
     tabindex="-1"
     aria-labelledby="dateFilterModalPRLLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalPRLLabel">
                    فلترة بالتاريخ والوقت (تاريخ الصلاحية)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="pretId" value="@(pretId?.ToString() ?? "")" />
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRangePRL"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRangePRL">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller"
                       asp-route-pretId="@(pretId)">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="columnsModalPRL"
     tabindex="-1"
     aria-labelledby="columnsModalPRLLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalPRLLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListPRL"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsPRL"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط
        // =========================
        document.getElementById("btnPrintPRL")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("prlTable");
            if (!table) return;

            const storageKey = "prl-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListPRL");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_prl_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsPRL")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalPRL");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // تحديد الكل + الحذف الجماعي (BulkDelete)
        // =========================
        (function () {
            const selectAll = document.getElementById("selectAll");
            const bulkBtn   = document.getElementById("btnBulkDelete");
            const bulkForm  = document.getElementById("formBulkDelete");

            function getRowCheckboxes() {
                return Array.from(document.querySelectorAll(".row-select"));
            }

            // تحديد/إلغاء تحديد كل الصفوف
            selectAll?.addEventListener("change", function () {
                const checked = this.checked;
                getRowCheckboxes().forEach(cb => cb.checked = checked);
            });

            // الحذف الجماعي
            bulkBtn?.addEventListener("click", function () {
                const checks = getRowCheckboxes().filter(cb => cb.checked);
                if (checks.length === 0) {
                    alert("من فضلك اختر على الأقل سطر واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف السطور المحددة؟")) {
                    return;
                }

                // إزالة أى hidden قديمة
                const oldHidden = bulkForm.querySelectorAll("input[type='hidden'][name='ids']");
                oldHidden.forEach(h => h.remove());

                // إضافة hidden input لكل مفتاح مركب
                checks.forEach(cb => {
                    const input = document.createElement("input");
                    input.type  = "hidden";
                    input.name  = "ids";
                    input.value = cb.value;   // بصيغة "PRetId:LineNo"
                    bulkForm.appendChild(input);
                });

                bulkForm.submit();
            });
        })();

        // =========================
        // فلتر رقم السطر من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);

                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
