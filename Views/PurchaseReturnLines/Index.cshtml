@section Scripts {
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        (function () {
            function scrollToRtlStart(wrapperId) {
                const el = document.getElementById(wrapperId);
                if (!el) return;
                requestAnimationFrame(() => { el.scrollLeft = el.scrollWidth - el.clientWidth; });
            }
            scrollToRtlStart("prlTableScrollWrapper");
        })();

        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanelPRL',
            tableId: 'prlTable',
            wrapperId: 'prlTableScrollWrapper',
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "PurchaseReturnLines")',
            defaultSort: 'LineNo',
            defaultDir: 'asc',
            numericColumns: ['pretId', 'lineNo', 'prodId', 'qty', 'priceRetail', 'unitCost', 'discount', 'lineTotal']
        });

        document.getElementById("btnPrintPRL")?.addEventListener("click", function () { window.print(); });

        ERP.initListSelection({
            showButtonId: 'btnShowPRL',
            movementButtonId: 'btnMovementPRL',
            showUrlAttribute: 'data-show-url',
            movementUrlAttribute: 'data-movement-url',
            tabTitleAttribute: 'data-tab-title',
            showTabId: 'pr-ret-show-tab',
            movementTabId: 'product-movement-tab',
            movementTabTitle: 'حركة الصنف',
            multiSelectCheckboxes: true
        });

        (function () {
            const table = document.getElementById("prlTable");
            if (!table) return;
            const chkAll = document.getElementById("chkAllRowsPRL");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");
            chkAll?.addEventListener("change", function () { rowsChk().forEach(cb => cb.checked = chkAll.checked); });
            table.addEventListener("change", function (e) {
                const t = e.target;
                if (t && t.classList.contains("row-select") && !t.checked && chkAll) chkAll.checked = false;
            });

            const bulkBtn = document.getElementById("btnBulkDeletePRL");
            const bulkForm = document.getElementById("formBulkDeletePRL");
            bulkBtn?.addEventListener("click", function () {
                const checks = Array.from(rowsChk()).filter(cb => cb.checked);
                if (checks.length === 0) { alert("من فضلك اختر سطراً واحداً على الأقل."); return; }
                if (!confirm("هل أنت متأكد من حذف السطور المحددة؟")) return;
                bulkForm.querySelectorAll("input[type='hidden'][name='ids']").forEach(h => h.remove());
                checks.forEach(cb => {
                    const input = document.createElement("input");
                    input.type = "hidden";
                    input.name = "ids";
                    input.value = cb.value;
                    bulkForm.appendChild(input);
                });
                bulkForm.submit();
            });
        })();

        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp = document.getElementById("codeFromInput");
            const toInp = document.getElementById("codeToInput");
            function buildUrl(cf, ct) {
                const url = new URL(window.location.href);
                if (cf) url.searchParams.set("fromCode", cf); else url.searchParams.delete("fromCode");
                if (ct) url.searchParams.set("toCode", ct); else url.searchParams.delete("toCode");
                url.searchParams.set("page", "1");
                return url.toString();
            }
            btnApply?.addEventListener("click", function () { window.location.href = buildUrl(fromInp.value.trim(), toInp.value.trim()); });
            btnClear?.addEventListener("click", function () { fromInp.value = ""; toInp.value = ""; window.location.href = buildUrl("", ""); });
        })();

        (function () {
            const table = document.getElementById("prlTable");
            if (!table) return;
            const storageKey = "prl-columns-visibility";
            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells.filter(th => !th.hasAttribute("data-col-fixed")).map(th => ({
                key: th.getAttribute("data-col"),
                title: (th.querySelector(".erp-col-title")?.textContent || th.innerText || "").trim()
            }));
            if (columns.length === 0) return;
            let hidden = [];
            try { const s = localStorage.getItem(storageKey); if (s) hidden = JSON.parse(s); } catch { hidden = []; }
            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']").forEach(cell => cell.classList.toggle("d-none", isHidden));
                });
            }
            applyVisibility();
            const listContainer = document.getElementById("columnsListPRL");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_prl_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";
                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;
                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;
                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }
            document.getElementById("btnApplyColumnsPRL")?.addEventListener("click", function () {
                const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                hidden = [];
                checks.forEach(cb => { if (!cb.checked) hidden.push(cb.dataset.colKey); });
                try { localStorage.setItem(storageKey, JSON.stringify(hidden)); } catch { }
                applyVisibility();
                const modalEl = document.getElementById("columnsModalPRL");
                bootstrap.Modal.getInstance(modalEl)?.hide();
            });
        })();
    </script>
}
