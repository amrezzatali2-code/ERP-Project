@section Scripts {
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        document.getElementById("btnPrintAccounts")?.addEventListener("click", function () { window.print(); });

        (function () {
            const table = document.getElementById("accountsTable");
            if (!table) return;
            const storageKey = "accounts-columns-visibility";
            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: (th.querySelector(".erp-col-title")?.textContent || th.innerText || "").trim()
                }));
            if (columns.length === 0) return;
            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }
            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']").forEach(cell => cell.classList.toggle("d-none", isHidden));
                });
            }
            applyVisibility();
            const listContainer = document.getElementById("columnsListAccounts");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_acc_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";
                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;
                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;
                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }
            document.getElementById("btnApplyColumnsAccounts")?.addEventListener("click", function () {
                const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                hidden = [];
                checks.forEach(cb => { if (!cb.checked) hidden.push(cb.dataset.colKey); });
                try { localStorage.setItem(storageKey, JSON.stringify(hidden)); } catch { }
                applyVisibility();
                const modalEl = document.getElementById("columnsModalAccounts");
                bootstrap.Modal.getInstance(modalEl)?.hide();
            });
        })();

        (function () {
            const chkAll = document.getElementById("chkAllRowsAccounts");
            const bulkBtn = document.getElementById("btnBulkDelete");
            const bulkForm = document.getElementById("formBulkDelete");
            const rowsChk = () => document.querySelectorAll("#accountsTable tbody .row-select");
            chkAll?.addEventListener("change", function () { rowsChk().forEach(cb => cb.checked = chkAll.checked); });
            bulkBtn?.addEventListener("click", function () {
                const checks = Array.from(rowsChk()).filter(cb => cb.checked);
                if (checks.length === 0) { alert("من فضلك اختر على الأقل حساب واحد للحذف."); return; }
                if (!confirm("هل أنت متأكد من حذف الحسابات المحددة؟")) return;
                bulkForm.querySelectorAll("input[type='hidden'][name='ids']").forEach(h => h.remove());
                checks.forEach(cb => {
                    const input = document.createElement("input");
                    input.type = "hidden";
                    input.name = "ids";
                    input.value = cb.value;
                    bulkForm.appendChild(input);
                });
                bulkForm.submit();
            });
            document.getElementById("btnDeleteAll")?.addEventListener("click", function () {
                if (!confirm("هل أنت متأكد من حذف جميع الحسابات؟ يُنصح باستخدام هذا في بيئة تجريبية فقط.")) return;
                document.getElementById("formDeleteAll")?.submit();
            });
        })();

        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp = document.getElementById("codeFromInput");
            const toInp = document.getElementById("codeToInput");
            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom); else url.searchParams.delete("fromCode");
                if (codeTo) url.searchParams.set("toCode", codeTo); else url.searchParams.delete("toCode");
                url.searchParams.set("page", "1");
                return url.toString();
            }
            btnApply?.addEventListener("click", function () { window.location.href = buildUrl(fromInp.value.trim(), toInp.value.trim()); });
            btnClear?.addEventListener("click", function () { fromInp.value = ""; toInp.value = ""; window.location.href = buildUrl("", ""); });
        })();

        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanelAccounts',
            tableId: 'accountsTable',
            wrapperId: 'accountsTableScrollWrapper',
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "Accounts")',
            defaultSort: 'code',
            defaultDir: 'asc',
            numericColumns: ['id', 'level']
        });

        ERP.initListSelection({
            editButtonId: 'btnAccEdit',
            editUrlAttribute: 'data-edit-url',
            editTabId: 'acc-edit-tab',
            tabTitleAttribute: 'data-tab-title',
            multiSelectCheckboxes: true
        });
    </script>
}
