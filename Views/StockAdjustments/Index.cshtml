@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.StockAdjustment>

@{
    ViewData["Title"] = "تسويات الجرد";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "StockAdjustments";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "id";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "id";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    // بيانات الترقيم
    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    var dateField = (string?)ViewBag.DateField ?? "AdjustmentDate";

    // فلاتر الأعمدة (بنمط Excel)
    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_date = ViewBag.FilterCol_Date as string;
    string? filterCol_warehouse = ViewBag.FilterCol_Warehouse as string;
    string? filterCol_reference = ViewBag.FilterCol_Reference as string;
    string? filterCol_reason = ViewBag.FilterCol_Reason as string;
    string? filterCol_created = ViewBag.FilterCol_Created as string;

    // دالة توليد لينكات الترقيم
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField,
        fromCode,
        toCode
    })!;

    // دالة إنشاء لينك الترتيب (تستخدم عند الحاجة)
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange = Model.UseDateRange,
            fromDate = Model.FromDate,
            toDate = Model.ToDate,
            dateField,
            fromCode,
            toCode
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    // دالة مساعدة لإرجاع قيمة فلتر العمود الحالي
    string? FilterForCol(string colKey) =>
        colKey == "id" ? filterCol_id
        : colKey == "date" ? filterCol_date
        : colKey == "warehouse" ? filterCol_warehouse
        : colKey == "reference" ? filterCol_reference
        : colKey == "reason" ? filterCol_reason
        : colKey == "created" ? filterCol_created
        : null;

    // عمود قابل للفلترة (بنمط Excel)
    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    @* ===== شريط الفلاتر الموحد (نمط القوائم) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في تسويات الجرد</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text"
                               name="search"
                               class="form-control erp-filter-input"
                               placeholder="اكتب نص البحث..."
                               value="@search"
                               style="min-width:120px" />

                        <select name="searchBy"
                                class="form-select form-select-arrow erp-filter-input"
                                style="max-width:170px;min-width:120px">
                            <option value="id" @Html.Raw(searchBy == "id" ? " selected" : "")>كود التسوية</option>
                            <option value="warehouse" @Html.Raw(searchBy == "warehouse" ? " selected" : "")>كود المخزن</option>
                            <option value="reference" @Html.Raw(searchBy == "reference" ? " selected" : "")>الرقم المرجعي</option>
                            <option value="reason" @Html.Raw(searchBy == "reason" ? " selected" : "")>السبب</option>
                        </select>

                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3 flex-shrink-0">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none flex-shrink-0"
                           href="@Url.Action(action, controller)">إلغاء</a>
                    </div>

                    @* الحفاظ على باقي الفلاتر *@
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                    @if (Model.FromDate.HasValue)
                    {
                        <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                    }
                    @if (Model.ToDate.HasValue)
                    {
                        <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                    }
                    @if (fromCode.HasValue)
                    {
                        <input type="hidden" name="fromCode" value="@fromCode" />
                    }
                    @if (toCode.HasValue)
                    {
                        <input type="hidden" name="toCode" value="@toCode" />
                    }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_reference)) { <input type="hidden" name="filterCol_reference" value="@filterCol_reference" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_reason)) { <input type="hidden" name="filterCol_reason" value="@filterCol_reason" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر الكود من/إلى --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر كود التسوية</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="saCodeFromInput"
                           type="number"
                           class="form-control erp-filter-input"
                           placeholder="من"
                           value="@(ViewBag.CodeFrom?.ToString() ?? "")" />

                    <input id="saCodeToInput"
                           type="number"
                           class="form-control erp-filter-input"
                           placeholder="إلى"
                           value="@(ViewBag.CodeTo?.ToString() ?? "")" />

                    <button type="button"
                            id="btnSaApplyCodeFilter"
                            class="btn btn-erp btn-erp-primary btn-erp-sm">
                        تطبيق
                    </button>

                    <button type="button"
                            id="btnSaClearCodeFilter"
                            class="btn btn-erp btn-erp-secondary btn-erp-sm">
                        مسح
                    </button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم (تاريخ/أعمدة/إضافة/حذف/طباعة/تصدير) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#saDateFilterModal">
                            فلترة بالتاريخ/الوقت
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#saColumnsModal">
                            اختيار الأعمدة
                        </button>

                        <a asp-action="Create"
                           class="btn btn-erp btn-erp-primary btn-erp-sm">
                            إضافة تسوية جديدة
                        </a>

                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle"
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                حذف
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li>
                                    <button type="button"
                                            class="dropdown-item text-danger"
                                            id="btnSaDeleteSelected">
                                        حذف التسويات المحددة
                                    </button>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <button type="button"
                                            class="dropdown-item text-danger"
                                            id="btnSaDeleteAll">
                                        حذف كل التسويات
                                    </button>
                                </li>
                            </ul>
                        </div>

                        <form id="saBulkDeleteForm"
                              asp-action="BulkDelete"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="selectedIds" id="saSelectedIdsInput" />
                        </form>

                        <form id="saDeleteAllForm"
                              asp-action="DeleteAll"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                        </form>

                        <button type="button"
                                id="btnSaPrint"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        <form method="get"
                              asp-action="Export"
                              asp-controller="StockAdjustments"
                              class="d-flex flex-wrap gap-2 align-items-center erp-export-form">

                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                            @if (Model.FromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                            }
                            @if (Model.ToDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                            }
                            @if (ViewBag.CodeFrom != null)
                            {
                                <input type="hidden" name="codeFrom" value="@ViewBag.CodeFrom" />
                            }
                            @if (ViewBag.CodeTo != null)
                            {
                                <input type="hidden" name="codeTo" value="@ViewBag.CodeTo" />
                            }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_reference)) { <input type="hidden" name="filterCol_reference" value="@filterCol_reference" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_reason)) { <input type="hidden" name="filterCol_reason" value="@filterCol_reason" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }

                            <select name="format"
                                    class="form-select form-select-arrow erp-filter-input"
                                    style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;padding:0.3rem 0.5rem;">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit"
                                    class="btn btn-erp btn-erp-success btn-erp-sm">
                                تصدير
                            </button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

    @* ===== جدول تسويات الجرد داخل حاوية تمرير ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0">
        <div id="saTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="saTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                        <input type="checkbox" id="saChkAllRows" />
                    </th>

                    <th data-col="id">@filterableCol("id", "id", "كود التسوية")</th>
                    <th data-col="date">@filterableCol("date", "date", "تاريخ التسوية")</th>
                    <th data-col="warehouse">@filterableCol("warehouse", "warehouse", "كود المخزن")</th>
                    <th data-col="reference">@filterableCol("reference", "reference", "رقم مرجعي")</th>
                    <th data-col="reason">@filterableCol("reason", "reason", "السبب")</th>
                    <th data-col="products">اسم الصنف</th>
                    <th data-col="qtyBefore" class="text-center">الكمية قبل</th>
                    <th data-col="qtyAfter" class="text-center">الكمية بعد</th>
                    <th data-col="costBefore" class="text-end">التكلفة قبل</th>
                    <th data-col="costAfter" class="text-end">التكلفة بعد</th>
                    <th data-col="created">@filterableCol("created", "created", "تاريخ الإنشاء")</th>

                    <th class="text-nowrap no-print" data-col="actions" data-col-fixed="true" style="width:200px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="13" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var a in Model.Items)
                    {
                        var lines = a.Lines ?? Enumerable.Empty<ERP.Models.StockAdjustmentLine>();
                        var totalQtyBefore = lines.Sum(l => l.QtyBefore);
                        var totalQtyAfter = lines.Sum(l => l.QtyAfter);
                        var totalCostBefore = lines.Sum(l => l.CostPerUnit.HasValue ? l.QtyBefore * l.CostPerUnit.Value : 0);
                        var totalCostAfter = lines.Sum(l => l.CostPerUnit.HasValue ? l.QtyAfter * l.CostPerUnit.Value : 0);
                        var productNames = lines
                            .Select(l => l.Product?.ProdName ?? $"صنف #{l.ProductId}")
                            .Where(n => !string.IsNullOrEmpty(n))
                            .Distinct()
                            .ToList();
                        var productsDisplay = productNames.Count > 3
                            ? string.Join("، ", productNames.Take(2)) + $" و{productNames.Count - 2} أصناف أخرى"
                            : (productNames.Any() ? string.Join("، ", productNames) : "-");
                        <tr data-adjustment-id="@a.Id" data-is-posted="@(a.IsPosted ? "1" : "0")">
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select-sa"
                                       value="@a.Id" />
                            </td>

                            <td data-col="id">@a.Id</td>
                            <td data-col="date">@a.AdjustmentDate.ToString("yyyy-MM-dd")</td>
                            <td data-col="warehouse">@a.WarehouseId</td>
                            <td data-col="reference">@a.ReferenceNo</td>
                            <td data-col="reason">@a.Reason</td>
                            <td data-col="products" style="max-width:180px;" title="@productsDisplay">@productsDisplay</td>
                            <td data-col="qtyBefore" class="text-center">@totalQtyBefore</td>
                            <td data-col="qtyAfter" class="text-center">@totalQtyAfter</td>
                            <td data-col="costBefore" class="text-end">@totalCostBefore.ToString("N2")</td>
                            <td data-col="costAfter" class="text-end">@totalCostAfter.ToString("N2")</td>
                            <td data-col="created">@a.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                            <td class="text-nowrap no-print" data-col="actions">
                                <a class="btn btn-erp btn-erp-primary btn-erp-sm open-same-tab"
                                   href="@Url.Action("Show", "StockAdjustments", new { id = a.Id, frame = 1 })"
                                   data-tab-id="stock-adjustment-create"
                                   data-tab-title="تسوية جردية"
                                   data-url="@Url.Action("Show", "StockAdjustments", new { id = a.Id, frame = 1 })">
                                    عرض
                                </a>
                                <form asp-action="Delete"
                                      asp-controller="StockAdjustments"
                                      asp-route-id="@a.Id"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('تأكيد حذف التسوية رقم @a.Id؟');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-erp btn-erp-danger btn-erp-sm">حذف</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        </div>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print" dir="rtl">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            @if (Model.FromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
            }
            @if (Model.ToDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_reference)) { <input type="hidden" name="filterCol_reference" value="@filterCol_reference" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_reason)) { <input type="hidden" name="filterCol_reason" value="@filterCol_reason" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    <div>
        <small class="text-muted d-none d-md-inline">
            إجمالي التسويات: @total
        </small>
    </div>

    @* ===== الترقيم ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== لوحة فلتر العمود (بنمط Excel) ===== *@
<div id="erpColumnFilterPanel" class="erp-column-filter-panel d-none" dir="rtl">
    <div class="erp-column-filter-header">
        <span id="erpColumnFilterTitle">ترتيب وفلتر</span>
        <button type="button" class="btn-close btn-sm" id="erpColumnFilterClose" aria-label="إغلاق"></button>
    </div>
    <div class="erp-column-filter-body">
        <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
            <label class="form-label small mb-1 fw-bold">الترتيب:</label>
            <div class="d-flex flex-column gap-1">
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
            </div>
        </div>
        <div class="erp-filter-section">
            <div id="erpColumnFilterSearchRow">
                <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                <input type="text" id="erpColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
            </div>
            <div id="erpColumnFilterList" class="erp-column-filter-list">
                <div class="text-muted text-center py-3">جاري التحميل...</div>
            </div>
        </div>
        <div class="erp-column-filter-actions">
            <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOk">تطبيق</button>
            <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClear">مسح الفلتر</button>
        </div>
    </div>
</div>

@* ===== Modal فلترة التاريخ/الوقت ===== *@
<div class="modal fade no-print"
     id="saDateFilterModal"
     tabindex="-1"
     aria-labelledby="saDateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="saDateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ التسوية)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="saUseDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(Model.UseDateRange ? "checked" : "") />
                            <label class="form-check-label" for="saUseDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="saColumnsModal"
     tabindex="-1"
     aria-labelledby="saColumnsModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="saColumnsModalLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="saColumnsList"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnSaApplyColumns"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // الشريط الأفقي: يبدأ من أقصى اليمين (RTL)
        // =========================
        (function () {
            var wrapper = document.getElementById("saTableScrollWrapper");
            if (wrapper) {
                function scrollToRtlStart() {
                    var maxScroll = wrapper.scrollWidth - wrapper.clientWidth;
                    wrapper.scrollLeft = maxScroll > 0 ? maxScroll : 0;
                }
                scrollToRtlStart();
                window.addEventListener("load", function () { setTimeout(scrollToRtlStart, 50); });
            }
        })();

        // =========================
        // زر الطباعة
        // =========================
        document.getElementById("btnSaPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table  = document.getElementById("saTable");
            if (!table) return;

            const chkAll     = document.getElementById("saChkAllRows");
            const rowsChk    = () => table.querySelectorAll("tbody .row-select-sa");
            const bulkForm   = document.getElementById("saBulkDeleteForm");
            const selectedEl = document.getElementById("saSelectedIdsInput");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => { if (!cb.disabled) cb.checked = chkAll.checked; });
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select-sa")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnSaDeleteSelected");
            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل تسوية واحدة للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف التسويات المحددة؟")) return;

                selectedEl.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnSaDeleteAll");
            const deleteAllForm = document.getElementById("saDeleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع تسويات الجرد. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + localStorage
        // =========================
        (function () {
            const table = document.getElementById("saTable");
            if (!table) return;

            const storageKey = "sa-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("saColumnsList");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "sa_col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnSaApplyColumns")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("saColumnsModal");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر الكود من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnSaApplyCodeFilter");
            const btnClear = document.getElementById("btnSaClearCodeFilter");
            const fromInp  = document.getElementById("saCodeFromInput");
            const toInp    = document.getElementById("saCodeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();

        // =========================
        // فلتر الأعمدة بنمط Excel — StockAdjustments
        // =========================
        (function () {
            var panel = document.getElementById("erpColumnFilterPanel");
            if (!panel) return;
            var titleEl = document.getElementById("erpColumnFilterTitle");
            var searchInp = document.getElementById("erpColumnFilterSearch");
            var listEl = document.getElementById("erpColumnFilterList");
            var btnOk = document.getElementById("erpColumnFilterOk");
            var btnClear = document.getElementById("erpColumnFilterClear");
            var btnClose = document.getElementById("erpColumnFilterClose");

            var currentCol = null, currentSortKey = null, allItems = [], currentSelected = new Set(), anchorRect = null;

            function getCurrentFilterValue(col) {
                return new URL(window.location.href).searchParams.get("filterCol_" + col) || "";
            }
            function getCurrentSort() {
                var url = new URL(window.location.href);
                return { sort: url.searchParams.get("sort") || "id", dir: url.searchParams.get("dir") || "asc" };
            }
            function adjustPanelPosition() {
                if (!panel || !anchorRect) return;
                setTimeout(function () {
                    var r = panel.getBoundingClientRect();
                    var top = anchorRect.bottom + 4, left = anchorRect.left;
                    if (top + r.height > window.innerHeight - 8) top = Math.max(8, window.innerHeight - 8 - r.height);
                    if (left + r.width > window.innerWidth - 8) left = Math.max(8, window.innerWidth - 8 - r.width);
                    panel.style.top = top + "px";
                    panel.style.left = left + "px";
                }, 50);
            }

            function showPanel(btn) {
                currentCol = btn.dataset.col;
                currentSortKey = btn.dataset.sortKey || currentCol;
                titleEl.textContent = "ترتيب وفلتر: " + (btn.dataset.colTitle || currentCol);
                searchInp.value = "";
                currentSelected = new Set((getCurrentFilterValue(currentCol) || "").split(/[|,;]/).filter(Boolean));
                anchorRect = btn.getBoundingClientRect();
                panel.style.minWidth = Math.max(250, anchorRect.width) + "px";
                panel.classList.remove("d-none");

                var currentSort = getCurrentSort();
                var isCurrent = currentSort.sort.toLowerCase() === (currentSortKey || "").toLowerCase();
                var currentDir = isCurrent ? currentSort.dir : "asc";
                panel.querySelectorAll(".erp-sort-btn").forEach(function (b) {
                    if (isCurrent && b.dataset.sortDir === currentDir) {
                        b.classList.add("active", "btn-primary");
                        b.classList.remove("btn-outline-secondary");
                    } else {
                        b.classList.remove("active", "btn-primary");
                        b.classList.add("btn-outline-secondary");
                    }
                });
                adjustPanelPosition();
                document.getElementById("erpColumnFilterSearchRow").classList.remove("d-none");
                listEl.innerHTML = '<div class="text-muted text-center py-3">جاري التحميل...</div>';
                var url = "/StockAdjustments/GetColumnValues?column=" + encodeURIComponent(currentCol);
                var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                if (searchVal) url += "&search=" + encodeURIComponent(searchVal);
                fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                    allItems = items;
                    renderList(searchInp ? searchInp.value : "");
                }).catch(function () { listEl.innerHTML = '<div class="text-danger text-center py-2">فشل التحميل</div>'; });
            }

            function renderList(search) {
                var term = (search || "").toLowerCase();
                var filtered = term ? allItems.filter(function (x) { return (x.display || x.value || "").toLowerCase().indexOf(term) >= 0; }) : allItems;
                var allChecked = filtered.length > 0 && filtered.every(function (x) { return currentSelected.has(String(x.value)); });
                var someChecked = filtered.some(function (x) { return currentSelected.has(String(x.value)); });
                listEl.innerHTML = '<div class="form-check mb-1"><input type="checkbox" class="form-check-input" id="erpFilterSelectAll" ' + (allChecked ? "checked" : "") + '><label class="form-check-label small" for="erpFilterSelectAll">(تحديد الكل)</label></div><div class="erp-filter-items" style="max-height:200px;overflow-y:auto;">' + filtered.map(function (x) {
                    var v = String(x.value);
                    var checked = currentSelected.has(v);
                    return '<div class="form-check"><input type="checkbox" class="form-check-input erp-filter-item" value="' + v.replace(/"/g, "&quot;") + '" ' + (checked ? "checked" : "") + '><label class="form-check-label small">' + (x.display || v).replace(/</g, "&lt;") + '</label></div>';
                }).join("") + "</div>";
                var selectAllCb = listEl.querySelector("#erpFilterSelectAll");
                if (selectAllCb) {
                    selectAllCb.indeterminate = someChecked && !allChecked;
                    selectAllCb.onchange = function () {
                        filtered.forEach(function (x) { if (this.checked) currentSelected.add(String(x.value)); else currentSelected.delete(String(x.value)); }.bind(this));
                        renderList(searchInp.value);
                    };
                }
                listEl.querySelectorAll(".erp-filter-item").forEach(function (cb) {
                    cb.onchange = function () { if (this.checked) currentSelected.add(this.value); else currentSelected.delete(this.value); renderList(searchInp.value); };
                });
                adjustPanelPosition();
            }

            function applyFilter(applySort, sortDir) {
                if (!currentCol) return;
                var url = new URL(window.location.href);
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.delete("filterCol_" + currentCol + "Expr");
                if (applySort !== undefined && sortDir !== undefined) {
                    url.searchParams.set("sort", applySort);
                    url.searchParams.set("dir", sortDir);
                } else if (currentSortKey) {
                    var cur = getCurrentSort();
                    url.searchParams.set("sort", cur.sort);
                    url.searchParams.set("dir", cur.dir);
                }
                var val = Array.from(currentSelected).filter(Boolean).join("|");
                if (val) url.searchParams.set("filterCol_" + currentCol, val);
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }
            function clearFilter() {
                if (!currentCol) return;
                var url = new URL(window.location.href);
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }

            document.querySelectorAll(".erp-col-filter-btn").forEach(function (btn) {
                btn.addEventListener("click", function (e) { e.stopPropagation(); showPanel(this); });
            });
            document.addEventListener("click", function (e) {
                if (e.target.closest(".erp-sort-btn")) {
                    var sortBtn = e.target.closest(".erp-sort-btn");
                    if (currentSortKey) applyFilter(currentSortKey, sortBtn.dataset.sortDir);
                }
            });
            var fetchDebounce = null;
            searchInp && searchInp.addEventListener("input", function () {
                renderList(this.value);
                if (fetchDebounce) clearTimeout(fetchDebounce);
                fetchDebounce = setTimeout(function () {
                    fetchDebounce = null;
                    if (!currentCol) return;
                    var url = "/StockAdjustments/GetColumnValues?column=" + encodeURIComponent(currentCol);
                    var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                    if (searchVal) url += "&search=" + encodeURIComponent(searchVal);
                    fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                        allItems = items;
                        renderList(searchInp ? searchInp.value : "");
                    });
                }, 400);
            });
            searchInp && searchInp.addEventListener("keydown", function (e) { if (e.key === "Enter") { e.preventDefault(); applyFilter(); } });
            btnOk && btnOk.addEventListener("click", function (e) { e.preventDefault(); e.stopPropagation(); applyFilter(); });
            btnClear && btnClear.addEventListener("click", clearFilter);
            btnClose && btnClose.addEventListener("click", function () { panel.classList.add("d-none"); });
            document.addEventListener("click", function (e) {
                if (panel && !panel.classList.contains("d-none") && !panel.contains(e.target) && !e.target.closest(".erp-col-filter-btn"))
                    panel.classList.add("d-none");
            });
        })();
    </script>
}
