</div>

@section Scripts {
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script>
        // =========================
        // الشريط الأفقي: يبدأ من أقصى اليمين (RTL)
        // =========================
        (function () {
            var wrapper = document.getElementById("saTableScrollWrapper");
            if (wrapper) {
                function scrollToRtlStart() {
                    var maxScroll = wrapper.scrollWidth - wrapper.clientWidth;
                    wrapper.scrollLeft = maxScroll > 0 ? maxScroll : 0;
                }
                scrollToRtlStart();
                window.addEventListener("load", function () { setTimeout(scrollToRtlStart, 50); });
            }
        })();

        // =========================
        // زر الطباعة
        // =========================
        document.getElementById("btnSaPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table  = document.getElementById("saTable");
            if (!table) return;

            const chkAll     = document.getElementById("saChkAllRows");
            const rowsChk    = () => table.querySelectorAll("tbody .row-select");
            const bulkForm   = document.getElementById("saBulkDeleteForm");
            const selectedEl = document.getElementById("saSelectedIdsInput");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => { if (!cb.disabled) cb.checked = chkAll.checked; });
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnSaDeleteSelected");
            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل تسوية واحدة للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف التسويات المحددة؟")) return;

                selectedEl.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnSaDeleteAll");
            const deleteAllForm = document.getElementById("saDeleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع تسويات الجرد. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // =========================
        // اختيار صف + زر عرض (نمط قائمة المبيعات)
        // =========================
        if (window.ERP && typeof ERP.initListSelection === "function") {
            ERP.initListSelection({
                showButtonId: "btnShowSA",
                idAttribute: "data-adjustment-id",
                showUrlAttribute: "data-show-url",
                tabTitleAttribute: "data-tab-title",
                showTabId: "stock-adjustment-create",
                multiSelectCheckboxes: true
            });
        }

        // =========================
        // اختيار الأعمدة + localStorage (نمط قائمة المبيعات: مودال موحّد + بحث + تحديد الكل)
        // =========================
        (function () {
            const table = document.getElementById("saTable");
            if (!table) return;

            const storageKey = "sa-columns-visibility";
            const searchInput = document.getElementById("saColumnsSearch");
            const modalEl = document.getElementById("saColumnsModal");

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("saColumnsList");
            let cbSelectAll = null;

            function colCheckboxes() {
                return listContainer
                    ? listContainer.querySelectorAll("input[type='checkbox'][data-col-key]")
                    : [];
            }

            function syncSelectAllState() {
                if (!cbSelectAll) return;
                const checks = Array.from(colCheckboxes());
                if (checks.length === 0) {
                    cbSelectAll.checked = false;
                    cbSelectAll.indeterminate = false;
                    return;
                }
                const on = checks.filter(c => c.checked).length;
                cbSelectAll.checked = on === checks.length;
                cbSelectAll.indeterminate = on > 0 && on < checks.length;
            }

            function filterColumnList() {
                const q = (searchInput && searchInput.value ? searchInput.value : "").trim().toLowerCase();
                listContainer.querySelectorAll(".sa-columns-col-item").forEach(w => {
                    const t = (w.dataset.colTitle || "").toLowerCase();
                    w.classList.toggle("d-none", q.length > 0 && !t.includes(q));
                });
            }

            function buildList() {
                if (!listContainer) return;
                listContainer.innerHTML = "";

                const rowAll = document.createElement("div");
                rowAll.className = "form-check erp-columns-select-all-row";
                cbSelectAll = document.createElement("input");
                cbSelectAll.type = "checkbox";
                cbSelectAll.className = "form-check-input";
                cbSelectAll.id = "saColumnsSelectAll";
                const labelAll = document.createElement("label");
                labelAll.className = "form-check-label";
                labelAll.setAttribute("for", "saColumnsSelectAll");
                labelAll.textContent = "تحديد الكل";
                rowAll.appendChild(cbSelectAll);
                rowAll.appendChild(labelAll);
                listContainer.appendChild(rowAll);

                cbSelectAll.addEventListener("change", function () {
                    colCheckboxes().forEach(c => { c.checked = cbSelectAll.checked; });
                    syncSelectAllState();
                });

                columns.forEach(col => {
                    const id = "sa_col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check sa-columns-col-item";
                    wrapper.dataset.colKey = col.key;
                    wrapper.dataset.colTitle = col.title;

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;
                    cb.addEventListener("change", syncSelectAllState);

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });

                syncSelectAllState();
            }

            buildList();

            searchInput?.addEventListener("input", filterColumnList);

            modalEl?.addEventListener("shown.bs.modal", function () {
                if (searchInput) searchInput.value = "";
                filterColumnList();
                syncSelectAllState();
            });

            document.getElementById("btnSaApplyColumns")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر الكود من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnSaApplyCodeFilter");
            const btnClear = document.getElementById("btnSaClearCodeFilter");
            const fromInp  = document.getElementById("saCodeFromInput");
            const toInp    = document.getElementById("saCodeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                const sm = url.searchParams.get("searchMode");
                if (!sm) url.searchParams.set("searchMode", "@searchMode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();

        // فلتر الأعمدة (المشترك — أعمدة رقمية: كود التسوية، كود المخزن)
        if (window.ERP && typeof ERP.initListColumnFilter === "function") {
            ERP.initListColumnFilter({
                panelId: "erpColumnFilterPanel",
                tableId: "saTable",
                wrapperId: "saTableScrollWrapper",
                getColumnValuesUrl: "@Url.Action("GetColumnValues", "StockAdjustments")",
                defaultSort: "id",
                defaultDir: "asc",
                numericColumns: ["id", "warehouse", "qtyBefore", "qtyAfter", "costBefore", "costAfter"]
            });
        }
    </script>
}
