                                            <div class="pi-print-details-grid small w-100" role="presentation">
                                                <div>رقم التسوية: <strong id="saPrintAdjNo"></strong></div>
                                                <div>تاريخ التسوية: <strong id="saPrintAdjDate"></strong></div>
                                                <div>المخزن: <strong id="saPrintWarehouse"></strong></div>
                                                <div>الحالة: <strong id="saPrintStatus"></strong></div>
                                                <div class="pi-print-details-cell-span2" aria-hidden="true"></div>
                                                <div class="pi-print-details-span-row text-muted small" id="saPrintNow"></div>
                                            </div>
                                            <hr class="my-1 pi-print-hr-after-banner" />
