@model ERP.Models.StockAdjustment

@{
    ViewData["Title"] = Model.Id == 0
        ? "تسوية جرد جديدة"
        : $"تسوية جرد — رقم {Model.Id}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/invoice-cards.css" />
    <style>
        /* تنسيق طلب الشراء من invoice-cards.css — تسوية جردية */
        .adjustment-page { min-height: 100vh; padding-bottom: 2rem; }
        .adjustment-card-line { display: none; }
        input[type="date"],
        input[type="datetime-local"],
        input[type="time"] { direction: ltr !important; text-align: left !important; }
        input[type="date"]::-webkit-calendar-picker-indicator,
        input[type="datetime-local"]::-webkit-calendar-picker-indicator { cursor: pointer; }
    </style>
}

<div class="adjustment-page" dir="rtl">
    <div class="container-fluid pt-3">
        <form id="__AntiForgeryForm" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>

        <div class="row g-3">
            @* العمود الجانبي *@
            <div class="col-12 col-lg-2 order-1 order-lg-2">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات تسوية الجرد</h6>
                    </div>

                    <input type="hidden" id="AdjustmentId" value="@Model.Id" />
                    <input type="hidden" id="AdjustmentIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />

                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">
                        @{
                            int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
                            int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
                            int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
                            int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;

                            int currentId = Model?.Id ?? 0;
                            bool hasAny = navFirst.HasValue && navLast.HasValue && navFirst.Value > 0 && navLast.Value > 0;
                            int? prevEffective = (currentId == 0) ? navLast : navPrev;
                            int? nextEffective = (currentId == 0) ? navFirst : navNext;
                            bool canFirst = hasAny && navFirst.HasValue && navFirst.Value > 0 && navFirst.Value != currentId;
                            bool canLast = hasAny && navLast.HasValue && navLast.Value > 0 && navLast.Value != currentId;
                            bool canPrev = hasAny && prevEffective.HasValue && prevEffective.Value > 0 && prevEffective.Value != currentId;
                            bool canNext = hasAny && nextEffective.HasValue && nextEffective.Value > 0 && nextEffective.Value != currentId;
                        }

                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button"
                                    id="btnFirstAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="أول تسوية"
                                    @(canFirst ? "" : "disabled")>
                                ⏮
                            </button>

                            <button type="button"
                                    id="btnPrevAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="التسوية السابقة"
                                    @(canPrev ? "" : "disabled")>
                                ◀
                            </button>

                            <button type="button"
                                    id="btnNextAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="التسوية التالية"
                                    @(canNext ? "" : "disabled")>
                                ▶
                            </button>

                            <button type="button"
                                    id="btnLastAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="آخر تسوية"
                                    @(canLast ? "" : "disabled")>
                                ⏭
                            </button>
                        </div>

                        <hr class="my-1" />

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           href="@Url.Action("Show", "StockAdjustments", new { id = 0, frame = 1 })"
                           data-tab-id="stock-adjustment-create"
                           data-tab-title="تسوية جردية"
                           data-url="@Url.Action("Show", "StockAdjustments", new { id = 0, frame = 1 })">
                            ➕ تسوية جديدة
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnSaveAdjustmentHeader"
                                data-lock-posted="1">
                            💾 حفظ التسوية
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnPostAdjustment"
                                data-lock-posted="1">
                            📤 ترحيل التسوية
                        </button>

                        <div id="postAdjustmentMsg" class="small mt-2"></div>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnOpenAdjustment">
                            ⏪ فتح التسوية
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnClearAdjustmentLines"
                                data-lock-posted="1">
                            🗑️ مسح كل السطور
                        </button>
                    </div>
                </div>
            </div>

            @* العمود الرئيسي *@
            <div class="col-12 col-lg-10 order-2 order-lg-1">
                @* كارت بيانات التسوية *@
                <div class="card shadow-sm mb-2 adjustment-header-card">
                    <div class="adjustment-header-bar">
                        <h5 class="mb-0">تسوية جرد</h5>
                    </div>

                    <div>
                        <div class="card-body">
                            <div class="row g-3 align-items-end">
                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">رقم التسوية</label>
                                    <input id="AdjustmentNumberDisplay" class="form-control form-control-sm text-center" value="@(Model.Id > 0 ? Model.Id.ToString() : "")" readonly />
                                </div>

                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">تاريخ التسوية</label>
                                    <input id="AdjustmentDateInput" type="date" class="form-control form-control-sm" value="@Model.AdjustmentDate.ToString("yyyy-MM-dd")" data-lock-posted="1" dir="ltr" style="text-align: left;" />
                                </div>

                                <div class="col-lg-3">
                                    <label class="form-label form-label-sm">المخزن</label>
                                    <select asp-for="WarehouseId" asp-items="ViewBag.Warehouses" class="form-select form-select-sm" data-lock-posted="1">
                                        <option value="">اختر المخزن</option>
                                    </select>
                                </div>

                                <div class="col-lg-3">
                                    <label class="form-label form-label-sm">رقم مرجعي</label>
                                    <input asp-for="ReferenceNo" class="form-control form-control-sm" data-lock-posted="1" />
                                </div>

                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">الحالة</label>
                                    <input id="AdjustmentStatusDisplay" class="form-control form-control-sm text-center" value="@(string.IsNullOrWhiteSpace(Model.Status) ? "مسودة" : Model.Status)" readonly />
                                </div>
                            </div>

                            <div class="row g-3 mt-2">
                                <div class="col-12">
                                    <label class="form-label form-label-sm">السبب / ملاحظات</label>
                                    <textarea asp-for="Reason" class="form-control form-control-sm" rows="2" data-lock-posted="1"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* كارت إدخال السطر *@
                <div class="card shadow-sm mb-2 adjustment-add-card">
                    <div class="adjustment-card-line"></div>
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">كود الصنف</label>
                                <input type="number" id="ProdCodeInput" class="form-control form-control-sm text-center" placeholder="بحث بالكود..." data-lock-posted="1" />
                            </div>

                            <div class="col-lg-3">
                                <label class="form-label form-label-sm">اسم الصنف</label>
                                <input id="ProdNameInput" list="productsList" class="form-control form-control-sm" placeholder="اكتب اسم الصنف..." autocomplete="off" data-lock-posted="1" />
                                <datalist id="productsList">
                                    @if (ViewBag.ProductsAuto != null)
                                    {
                                        foreach (var p in ViewBag.ProductsAuto)
                                        {
                                            <option value="@p.Name"
                                                    data-id="@p.Id"
                                                    data-code="@p.Id"
                                                    data-generic="@p.GenericName"
                                                    data-company="@p.Company"
                                                    data-price="@p.PriceRetail"
                                                    data-hasquota="@(p.HasQuota ? "true" : "false")">
                                            </option>
                                        }
                                    }
                                </datalist>
                                <input type="hidden" id="ProdId" />
                            </div>

                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">التشغيلة</label>
                                <input type="text" id="BatchNoInput" class="form-control form-control-sm text-center" placeholder="باتش (قابل للتعديل)" data-lock-posted="1" />
                            </div>

                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">تاريخ الصلاحية</label>
                                <input type="date" id="ExpiryInput" class="form-control form-control-sm text-center" data-lock-posted="1" dir="ltr" style="text-align: left;" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الكمية قبل</label>
                                <input type="number" id="QtyBeforeInput" class="form-control form-control-sm text-center" value="0" readonly data-lock-posted="1" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الكمية بعد</label>
                                <input type="number" id="QtyAfterInput" class="form-control form-control-sm text-center" value="0" data-lock-posted="1" />
                            </div>
                        </div>

                        <div class="row g-2 mt-2">
                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">تكلفة الوحدة</label>
                                <input type="number" id="CostPerUnitInput" class="form-control form-control-sm text-center" step="0.0001" data-lock-posted="1" />
                            </div>

                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">سعر الصنف</label>
                                <input type="number" id="PriceRetailInput" class="form-control form-control-sm text-center" step="0.01" data-lock-posted="1" />
                            </div>

                            <div class="col-lg-6">
                                <label class="form-label form-label-sm">ملاحظات السطر</label>
                                <input type="text" id="LineNoteInput" class="form-control form-control-sm" data-lock-posted="1" />
                            </div>

                            <div class="col-lg-2 d-grid">
                                <label class="form-label form-label-sm">&nbsp;</label>
                                <button type="button" id="btnAddAdjustmentLine" class="btn btn-erp btn-erp-primary btn-erp-sm w-100" data-lock-posted="1">إضافة</button>
                            </div>
                        </div>
                    </div>
                </div>

                @* جدول السطور *@
                <div class="card shadow-sm mb-2 adjustment-lines-card">
                    <div class="adjustment-card-line"></div>
                    <div class="card-body p-0">
                        <div class="erp-table-wrapper">
                            <table class="table table-sm table-striped table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">التشغيلة</th>
                                        <th class="text-center">الصلاحية</th>
                                        <th class="text-center">الكمية قبل</th>
                                        <th class="text-center">الكمية بعد</th>
                                        <th class="text-center">الفرق</th>
                                        <th class="text-center">تكلفة الوحدة</th>
                                        <th class="text-center">فرق التكلفة</th>
                                        <th class="text-center no-print">مسح</th>
                                    </tr>
                                </thead>
                                <tbody id="AdjustmentLinesTbody">
                                    @if (Model.Lines != null && Model.Lines.Any())
                                    {
                                        int lineNo = 1;
                                        foreach (var line in Model.Lines.OrderBy(l => l.Id))
                                        {
                                            <tr data-line-id="@line.Id">
                                                <td class="text-center">@lineNo</td>
                                                <td>@(line.Product?.ProdName ?? $"صنف #{line.ProductId}")</td>
                                                <td class="text-center">@(line.Batch?.BatchNo ?? "-")</td>
                                                <td class="text-center">@(line.Batch?.Expiry.ToString("yyyy-MM-dd") ?? "-")</td>
                                                <td class="text-center">@line.QtyBefore</td>
                                                <td class="text-center">@line.QtyAfter</td>
                                                <td class="text-center">@line.QtyDiff</td>
                                                <td class="text-center">@(line.CostPerUnit?.ToString("0.0000") ?? "-")</td>
                                                <td class="text-center">@(line.CostDiff?.ToString("0.00") ?? "-")</td>
                                                <td class="text-center no-print">
                                                    <button type="button" class="btn btn-sm btn-danger btn-delete-line" data-line-id="@line.Id" data-lock-posted="1">🗑️</button>
                                                </td>
                                            </tr>
                                            lineNo++;
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="10" class="text-center text-muted py-4">لا توجد سطور بعد.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Anti-forgery token
        function getAntiForgeryToken() {
            const form = document.getElementById('__AntiForgeryForm');
            return form?.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        // الانتقال داخل التاب (عند فتح الصفحة في iframe) — يمنع الشاشة البيضاء
        function navigateAdjustmentTab(url) {
            try {
                if (window.top && window.top !== window.self) {
                    window.top.postMessage({ type: 'erp-update-current-tab', url: url, title: 'فاتورة تسوية جردية' }, '*');
                } else {
                    window.location.href = url;
                }
            } catch (e) { window.location.href = url; }
        }

        // =========================================================
        // قفل الأزرار والحقول عند الترحيل (مثل فاتورة المبيعات)
        // =========================================================
        function isAdjustmentPosted() {
            const flag = document.getElementById('AdjustmentIsPostedFlag');
            return flag && flag.value === '1';
        }

        function setAdjustmentPosted(posted) {
            const flag = document.getElementById('AdjustmentIsPostedFlag');
            if (flag) flag.value = posted ? '1' : '0';
        }

        function applyPostedUiLock() {
            const posted = isAdjustmentPosted();
            const lockables = document.querySelectorAll('[data-lock-posted="1"]');

            lockables.forEach(el => {
                if (el.dataset.lockInit !== '1') {
                    el.dataset.lockInit = '1';
                    el.dataset.origDisabled = el.disabled ? '1' : '0';
                    el.dataset.origReadonly = el.readOnly ? '1' : '0';
                    el.dataset.origTabIndex = el.getAttribute('tabindex') ?? '';
                }

                const tag = (el.tagName || '').toUpperCase();

                if (posted) {
                    if (tag === 'BUTTON') { el.disabled = true; return; }
                    if (tag === 'A') {
                        el.classList.add('disabled', 'pe-none');
                        el.setAttribute('aria-disabled', 'true');
                        el.setAttribute('tabindex', '-1');
                        return;
                    }
                    if (tag === 'INPUT' || tag === 'TEXTAREA') {
                        el.readOnly = true;
                        el.classList.add('bg-light', 'text-muted');
                        return;
                    }
                    if (tag === 'SELECT') { el.disabled = true; return; }
                    return;
                }

                const origDisabled = el.dataset.origDisabled === '1';
                const origReadonly = el.dataset.origReadonly === '1';
                const origTabIndex = el.dataset.origTabIndex;

                if (tag === 'BUTTON') { el.disabled = origDisabled; return; }
                if (tag === 'A') {
                    el.classList.remove('disabled', 'pe-none');
                    el.removeAttribute('aria-disabled');
                    if (origTabIndex === '') el.removeAttribute('tabindex');
                    else el.setAttribute('tabindex', origTabIndex);
                    return;
                }
                if (tag === 'INPUT' || tag === 'TEXTAREA') {
                    el.readOnly = origReadonly;
                    el.classList.remove('bg-light', 'text-muted');
                    return;
                }
                if (tag === 'SELECT') { el.disabled = origDisabled; return; }
            });

            const btnPost = document.getElementById('btnPostAdjustment');
            if (btnPost) {
                btnPost.disabled = posted;
                btnPost.innerHTML = posted ? '✅ تم ترحيل التسوية' : '📤 ترحيل التسوية';
            }

            const btnOpen = document.getElementById('btnOpenAdjustment');
            if (btnOpen) btnOpen.disabled = !posted;
        }

        // تطبيق القفل عند تحميل الصفحة إن كانت التسوية مترحلة
        (function() {
            const serverIsPosted = @Model.IsPosted.ToString().ToLower();
            if (serverIsPosted) {
                setAdjustmentPosted(true);
                applyPostedUiLock();
            }
        })();

        // تحميل بيانات الصنف تلقائياً (مثل فاتورة البيع)
        let busyLoadInfo = false;
        async function loadProductInfo() {
            const prodId = parseInt(document.getElementById('ProdId').value || '0', 10);
            const warehouseId = parseInt(document.querySelector('[name="WarehouseId"]')?.value || '0', 10);
            if (!prodId || prodId <= 0 || !warehouseId || warehouseId <= 0) return;
            if (busyLoadInfo) return;
            busyLoadInfo = true;
            const batchNo = document.getElementById('BatchNoInput').value?.trim() || '';
            const expiry = document.getElementById('ExpiryInput').value || '';
            try {
                const url = '@Url.Action("GetStockAdjustmentProductInfo", "StockAdjustments")'
                    + '?prodId=' + encodeURIComponent(prodId)
                    + '&warehouseId=' + encodeURIComponent(warehouseId)
                    + (batchNo ? '&batchNo=' + encodeURIComponent(batchNo) : '')
                    + (expiry ? '&expiry=' + encodeURIComponent(expiry) : '');
                const r = await fetch(url, { method: 'GET' });
                const data = await r.json();
                if (data && data.ok) {
                    document.getElementById('QtyBeforeInput').value = data.qtyBefore || 0;
                    document.getElementById('CostPerUnitInput').value = data.costPerUnit || '';
                    document.getElementById('PriceRetailInput').value = data.priceRetail || '';
                    if (data.firstBatchNo && !document.getElementById('BatchNoInput').value) document.getElementById('BatchNoInput').value = data.firstBatchNo;
                    if (data.firstExpiry && !document.getElementById('ExpiryInput').value) document.getElementById('ExpiryInput').value = data.firstExpiry;
                }
            } catch (e) { console.warn('GetStockAdjustmentProductInfo:', e); }
            finally { busyLoadInfo = false; }
        }

        document.getElementById('ProdNameInput')?.addEventListener('input', function() {
            const selectedOption = document.querySelector(`#productsList option[value="${this.value}"]`);
            if (selectedOption) {
                document.getElementById('ProdId').value = selectedOption.getAttribute('data-id');
                document.getElementById('ProdCodeInput').value = selectedOption.getAttribute('data-id');
                loadProductInfo();
            }
        });

        document.getElementById('ProdCodeInput')?.addEventListener('input', function() {
            const code = this.value;
            if (code && code > 0) {
                const selectedOption = document.querySelector(`#productsList option[data-id="${code}"]`);
                if (selectedOption) {
                    document.getElementById('ProdId').value = code;
                    document.getElementById('ProdNameInput').value = selectedOption.value;
                    loadProductInfo();
                }
            }
        });

        document.getElementById('BatchNoInput')?.addEventListener('blur', loadProductInfo);
        document.getElementById('ExpiryInput')?.addEventListener('change', loadProductInfo);
        document.querySelector('[name="WarehouseId"]')?.addEventListener('change', function() {
            if (document.getElementById('ProdId').value) loadProductInfo();
        });

        // دالة مسح حقول إضافة السطر وإعادة الفوكس لاسم الصنف
        function clearAddLineFormAndFocus() {
            document.getElementById('ProdId').value = '';
            document.getElementById('ProdCodeInput').value = '';
            document.getElementById('ProdNameInput').value = '';
            document.getElementById('BatchNoInput').value = '';
            document.getElementById('ExpiryInput').value = '';
            document.getElementById('QtyBeforeInput').value = '0';
            document.getElementById('QtyAfterInput').value = '0';
            document.getElementById('CostPerUnitInput').value = '';
            document.getElementById('PriceRetailInput').value = '';
            document.getElementById('LineNoteInput').value = '';
            const prodNameInput = document.getElementById('ProdNameInput');
            prodNameInput?.focus();
            prodNameInput?.select?.();
        }

        // دالة إضافة صف للجدول أو تحديثه
        function upsertAdjustmentRow(result, lineNo) {
            const tbody = document.getElementById('AdjustmentLinesTbody');
            const placeholder = tbody.querySelector('tr td[colspan="10"]');
            if (placeholder) placeholder.closest('tr').remove();

            const existingRow = tbody.querySelector(`tr[data-line-id="${result.lineId}"]`);
            const costStr = result.costPerUnit != null ? parseFloat(result.costPerUnit).toFixed(4) : '-';
            const costDiffStr = result.costDiff != null ? parseFloat(result.costDiff).toFixed(2) : '-';
            const rowHtml = `<tr data-line-id="${result.lineId}">
                <td class="text-center">${lineNo}</td>
                <td>${escapeHtml(result.productName)}</td>
                <td class="text-center">${escapeHtml(result.batchNo)}</td>
                <td class="text-center">${escapeHtml(result.expiryDisplay)}</td>
                <td class="text-center">${result.qtyBefore}</td>
                <td class="text-center">${result.qtyAfter}</td>
                <td class="text-center">${result.qtyDiff}</td>
                <td class="text-center">${costStr}</td>
                <td class="text-center">${costDiffStr}</td>
                <td class="text-center no-print">
                    <button type="button" class="btn btn-sm btn-danger btn-delete-line" data-line-id="${result.lineId}" data-lock-posted="1">🗑️</button>
                </td>
            </tr>`;

            if (existingRow) {
                existingRow.outerHTML = rowHtml;
            } else {
                tbody.insertAdjacentHTML('beforeend', rowHtml);
            }
            if (tbody.querySelectorAll('tr').length === 0) {
                tbody.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-4">لا توجد سطور بعد.</td></tr>';
            }
        }
        function escapeHtml(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

        // Add line
        async function doAddAdjustmentLine() {
            if (typeof isAdjustmentPosted === 'function' && isAdjustmentPosted()) return;
            const adjustmentId = parseInt(document.getElementById('AdjustmentId').value || '0', 10);
            if (!adjustmentId || adjustmentId <= 0) {
                alert('لا يمكن إضافة سطور قبل حفظ التسوية. اضغط "حفظ التسوية" أولاً.');
                return;
            }

            const prodId = parseInt(document.getElementById('ProdId').value || '0', 10);
            const qtyBefore = parseInt(document.getElementById('QtyBeforeInput').value || '0', 10);
            const qtyAfter = parseInt(document.getElementById('QtyAfterInput').value || '0', 10);
            const batchNo = document.getElementById('BatchNoInput').value?.trim() || '';
            const expiry = document.getElementById('ExpiryInput').value || '';
            const costPerUnit = parseFloat(document.getElementById('CostPerUnitInput').value || '0');
            const priceRetail = parseFloat(document.getElementById('PriceRetailInput').value || '0');
            const note = document.getElementById('LineNoteInput').value?.trim() || '';

            if (!prodId || prodId <= 0) {
                alert('من فضلك اختر صنفاً صحيحاً.');
                return;
            }

            if (qtyBefore < 0 || qtyAfter < 0) {
                alert('الكميات يجب أن تكون أكبر من أو تساوي صفر.');
                return;
            }

            const dto = {
                stockAdjustmentId: adjustmentId,
                productId: prodId,
                batchNo: batchNo || null,
                expiry: expiry || null,
                priceRetail: priceRetail || null,
                qtyBefore: qtyBefore,
                qtyAfter: qtyAfter,
                costPerUnit: costPerUnit || null,
                note: note
            };

            const token = getAntiForgeryToken();
            const btn = document.getElementById('btnAddAdjustmentLine');
            btn.disabled = true;

            try {
                const response = await fetch('@Url.Action("AddLineJson", "StockAdjustments")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(dto)
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    alert('حدث خطأ أثناء إضافة السطر: ' + errorText);
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    const tbody = document.getElementById('AdjustmentLinesTbody');
                    const currentRows = tbody.querySelectorAll('tr[data-line-id]');
                    let lineNo;
                    if (result.isUpdate) {
                        const existingRow = tbody.querySelector(`tr[data-line-id="${result.lineId}"]`);
                        lineNo = existingRow ? parseInt(existingRow.querySelector('td')?.textContent || '1', 10) : currentRows.length + 1;
                    } else {
                        lineNo = currentRows.length + 1;
                    }
                    upsertAdjustmentRow(result, lineNo);
                    clearAddLineFormAndFocus();
                } else {
                    alert(result.message || 'حدث خطأ أثناء إضافة السطر.');
                }
            } catch (error) {
                console.error('Error adding line:', error);
                alert('حدث خطأ أثناء إضافة السطر.');
            } finally {
                btn.disabled = false;
            }
        }

        document.getElementById('btnAddAdjustmentLine')?.addEventListener('click', doAddAdjustmentLine);

        // الانتقال بـ Enter بين الحقول وزر الإضافة
        const enterNavFields = [
            document.getElementById('ProdCodeInput'),
            document.getElementById('ProdNameInput'),
            document.getElementById('BatchNoInput'),
            document.getElementById('ExpiryInput'),
            document.getElementById('QtyAfterInput'),
            document.getElementById('CostPerUnitInput'),
            document.getElementById('PriceRetailInput'),
            document.getElementById('LineNoteInput'),
            document.getElementById('btnAddAdjustmentLine')
        ].filter(Boolean);

        enterNavFields.forEach((el, idx) => {
            if (el.dataset.boundEnterNav === '1') return;
            el.dataset.boundEnterNav = '1';
            el.addEventListener('keydown', function(e) {
                if (e.key !== 'Enter') return;
                e.preventDefault();
                if (el === document.getElementById('ProdNameInput')) {
                    const opt = document.querySelector(`#productsList option[value="${el.value}"]`);
                    if (opt) {
                        document.getElementById('ProdId').value = opt.getAttribute('data-id');
                        document.getElementById('ProdCodeInput').value = opt.getAttribute('data-id');
                        loadProductInfo();
                    }
                }
                if (el === document.getElementById('ProdCodeInput')) {
                    const code = el.value;
                    if (code) {
                        const opt = document.querySelector(`#productsList option[data-id="${code}"]`);
                        if (opt) {
                            document.getElementById('ProdId').value = code;
                            document.getElementById('ProdNameInput').value = opt.value;
                            loadProductInfo();
                        }
                    }
                }
                const next = enterNavFields[idx + 1];
                if (el === document.getElementById('btnAddAdjustmentLine')) {
                    doAddAdjustmentLine();
                } else if (el === document.getElementById('LineNoteInput')) {
                    doAddAdjustmentLine();
                } else if (next) {
                    next.focus();
                    if (typeof next.select === 'function') next.select?.();
                }
            });
        });

        // Delete line (event delegation للصفوف المضافة ديناميكياً)
        document.getElementById('AdjustmentLinesTbody')?.addEventListener('click', async function(e) {
            const btn = e.target.closest('.btn-delete-line');
            if (!btn) return;
            if (btn.disabled) return;
            const lineId = parseInt(btn.getAttribute('data-line-id') || '0', 10);
            if (!lineId || lineId <= 0) return;
            if (typeof isAdjustmentPosted === 'function' && isAdjustmentPosted()) return;

            if (!confirm('هل أنت متأكد من حذف هذا السطر؟')) return;

            const token = getAntiForgeryToken();
            btn.disabled = true;

            try {
                const response = await fetch(`@Url.Action("DeleteLineJson", "StockAdjustments")?id=${lineId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (!response.ok) {
                    alert('حدث خطأ أثناء حذف السطر.');
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    const row = btn.closest('tr');
                    if (row) row.remove();
                    const tbody = document.getElementById('AdjustmentLinesTbody');
                    if (tbody && tbody.querySelectorAll('tr[data-line-id]').length === 0) {
                        tbody.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-4">لا توجد سطور بعد.</td></tr>';
                    }
                } else {
                    alert(result.message || 'حدث خطأ أثناء حذف السطر.');
                }
            } catch (error) {
                console.error('Error deleting line:', error);
                alert('حدث خطأ أثناء حذف السطر.');
            } finally {
                btn.disabled = false;
            }
        });

        // Save header
        document.getElementById('btnSaveAdjustmentHeader')?.addEventListener('click', async function() {
            const adjustmentId = parseInt(document.getElementById('AdjustmentId').value || '0', 10);
            const adjustmentDate = document.getElementById('AdjustmentDateInput').value;
            const warehouseId = document.querySelector('[name="WarehouseId"]').value;
            const referenceNo = document.querySelector('[name="ReferenceNo"]').value;
            const reason = document.querySelector('[name="Reason"]').value;

            if (!warehouseId || warehouseId <= 0) {
                alert('من فضلك اختر مخزناً.');
                return;
            }

            const dto = {
                id: adjustmentId,
                adjustmentDate: adjustmentDate,
                warehouseId: parseInt(warehouseId, 10),
                referenceNo: referenceNo,
                reason: reason
            };

            const token = getAntiForgeryToken();
            this.disabled = true;

            try {
                const url = adjustmentId > 0 
                    ? '@Url.Action("UpdateHeaderJson", "StockAdjustments")'
                    : '@Url.Action("CreateHeaderJson", "StockAdjustments")';

                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(dto)
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    alert('حدث خطأ أثناء حفظ التسوية: ' + errorText);
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    if (result.id && result.id > 0) {
                        document.getElementById('AdjustmentId').value = result.id;
                        document.getElementById('AdjustmentNumberDisplay').value = result.id;
                        const baseUrl = '@Url.Action("Show", "StockAdjustments")';
                        const newPath = baseUrl + '/' + result.id + (window.location.search || '');
                        window.history.replaceState({}, '', newPath);
                        document.title = 'تسوية جرد — رقم ' + result.id;
                    }
                    const ProdNameInput = document.getElementById('ProdNameInput');
                    ProdNameInput?.focus();
                    ProdNameInput?.select?.();
                } else {
                    alert(result.message || 'حدث خطأ أثناء حفظ التسوية.');
                }
            } catch (error) {
                console.error('Error saving adjustment:', error);
                alert('حدث خطأ أثناء حفظ التسوية.');
            } finally {
                this.disabled = false;
            }
        });

        // Post adjustment — نفس أسلوب فاتورة البيع: تحديث الواجهة دون إعادة تحميل
        document.getElementById('btnPostAdjustment')?.addEventListener('click', async function() {
            const adjustmentId = parseInt(document.getElementById('AdjustmentId').value || '0', 10);
            if (!adjustmentId || adjustmentId <= 0) {
                alert('يجب حفظ التسوية أولاً قبل الترحيل.');
                return;
            }

            if (!confirm('هل أنت متأكد من ترحيل هذه التسوية؟')) return;

            const token = getAntiForgeryToken();
            const msgDiv = document.getElementById('postAdjustmentMsg');
            const btnPost = this;
            const oldHtml = btnPost.innerHTML;
            btnPost.disabled = true;
            btnPost.innerHTML = '⏳ جاري الترحيل...';
            if (msgDiv) { msgDiv.textContent = 'يتم حفظ التعديلات ثم الترحيل...'; msgDiv.className = 'small mt-2 text-muted'; }

            try {
                // حفظ الهيدر أولاً (لتطبيق أي تعديل)
                const adjustmentDate = document.getElementById('AdjustmentDateInput')?.value;
                const warehouseId = parseInt(document.querySelector('[name="WarehouseId"]')?.value || '0', 10);
                const referenceNo = document.querySelector('[name="ReferenceNo"]')?.value || '';
                const reason = document.querySelector('[name="Reason"]')?.value || '';
                if (warehouseId > 0) {
                    const saveDto = { id: adjustmentId, adjustmentDate: adjustmentDate, warehouseId: warehouseId, referenceNo: referenceNo, reason: reason };
                    const saveRes = await fetch('@Url.Action("UpdateHeaderJson", "StockAdjustments")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                        body: JSON.stringify(saveDto)
                    });
                    if (!saveRes.ok) {
                        const errTxt = await saveRes.text();
                        if (msgDiv) { msgDiv.textContent = 'تعذر حفظ التعديلات: ' + errTxt; msgDiv.className = 'small mt-2 text-danger'; }
                        btnPost.disabled = false; btnPost.innerHTML = oldHtml;
                        return;
                    }
                    const saveResult = await saveRes.json();
                    if (!saveResult || !saveResult.ok) {
                        if (msgDiv) { msgDiv.textContent = (saveResult && saveResult.message) ? saveResult.message : 'تعذر حفظ التعديلات قبل الترحيل.'; msgDiv.className = 'small mt-2 text-danger'; }
                        btnPost.disabled = false; btnPost.innerHTML = oldHtml;
                        return;
                    }
                }
                if (msgDiv) { msgDiv.textContent = 'جاري الترحيل...'; msgDiv.className = 'small mt-2 text-muted'; }

                const response = await fetch(`@Url.Action("PostAdjustment", "StockAdjustments")?id=${adjustmentId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    if (msgDiv) { msgDiv.textContent = 'خطأ: ' + errorText; msgDiv.className = 'small mt-2 text-danger'; }
                    btnPost.disabled = false;
                    btnPost.innerHTML = oldHtml;
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    // تحديث الواجهة دون إعادة تحميل (مثل فاتورة البيع)
                    setAdjustmentPosted(true);
                    applyPostedUiLock();

                    const statusDisplay = document.getElementById('AdjustmentStatusDisplay');
                    if (statusDisplay) statusDisplay.value = 'مترحلة';

                    const btnOpen = document.getElementById('btnOpenAdjustment');
                    if (btnOpen) btnOpen.disabled = false;

                    btnPost.innerHTML = '✅ تم ترحيل التسوية';
                    btnPost.disabled = true;

                    if (msgDiv) {
                        msgDiv.textContent = result.message || 'تم الترحيل بنجاح.';
                        msgDiv.className = 'small mt-2 text-success';
                    }
                } else {
                    if (msgDiv) {
                        msgDiv.textContent = result.message || 'حدث خطأ أثناء الترحيل.';
                        msgDiv.className = 'small mt-2 text-danger';
                    }
                    btnPost.disabled = false;
                    btnPost.innerHTML = oldHtml;
                }
            } catch (error) {
                console.error('Error posting adjustment:', error);
                if (msgDiv) {
                    msgDiv.textContent = 'حدث خطأ أثناء الترحيل.';
                    msgDiv.className = 'small mt-2 text-danger';
                }
                btnPost.disabled = false;
                btnPost.innerHTML = oldHtml;
            }
        });

        // Open adjustment
        document.getElementById('btnOpenAdjustment')?.addEventListener('click', async function() {
            const adjustmentId = parseInt(document.getElementById('AdjustmentId').value || '0', 10);
            if (!adjustmentId || adjustmentId <= 0) {
                alert('لا توجد تسوية لفتحها.');
                return;
            }

            if (!confirm('هل أنت متأكد من فتح هذه التسوية؟')) return;

            const token = getAntiForgeryToken();
            this.disabled = true;

            try {
                const response = await fetch(`@Url.Action("OpenAdjustment", "StockAdjustments")?id=${adjustmentId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (!response.ok) {
                    alert('حدث خطأ أثناء فتح التسوية.');
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    setAdjustmentPosted(false);
                    applyPostedUiLock();

                    const statusDisplay = document.getElementById('AdjustmentStatusDisplay');
                    if (statusDisplay) statusDisplay.value = 'مسودة';

                    const btnPost = document.getElementById('btnPostAdjustment');
                    if (btnPost) { btnPost.disabled = false; btnPost.innerHTML = '📤 ترحيل التسوية'; }

                    const btnOpen = document.getElementById('btnOpenAdjustment');
                    if (btnOpen) btnOpen.disabled = true;

                    alert('تم فتح التسوية بنجاح.');
                } else {
                    alert(result.message || 'حدث خطأ أثناء فتح التسوية.');
                }
            } catch (error) {
                console.error('Error opening adjustment:', error);
                alert('حدث خطأ أثناء فتح التسوية.');
            } finally {
                this.disabled = false;
            }
        });

        // Clear lines
        document.getElementById('btnClearAdjustmentLines')?.addEventListener('click', async function() {
            if (typeof isAdjustmentPosted === 'function' && isAdjustmentPosted()) return;
            const adjustmentId = parseInt(document.getElementById('AdjustmentId').value || '0', 10);
            if (!adjustmentId || adjustmentId <= 0) {
                alert('لا توجد تسوية لمسح سطورها.');
                return;
            }

            if (!confirm('هل أنت متأكد من مسح كل سطور التسوية؟')) return;

            const token = getAntiForgeryToken();
            this.disabled = true;

            try {
                const response = await fetch(`@Url.Action("ClearLinesJson", "StockAdjustments")?id=${adjustmentId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (!response.ok) {
                    alert('حدث خطأ أثناء مسح السطور.');
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    alert('تم مسح السطور بنجاح.');
                    // مسح السطور يغيّر بنية الجدول — إعادة تحميل لعرض الحالة الجديدة
                    window.location.reload();
                } else {
                    alert(result.message || 'حدث خطأ أثناء مسح السطور.');
                }
            } catch (error) {
                console.error('Error clearing lines:', error);
                alert('حدث خطأ أثناء مسح السطور.');
            } finally {
                this.disabled = false;
            }
        });

        // Navigation
        document.getElementById('btnFirstAdjustment')?.addEventListener('click', function() {
            const firstId = @(ViewBag.NavFirstId ?? 0);
            if (firstId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + firstId + '?frame=1');
        });

        document.getElementById('btnPrevAdjustment')?.addEventListener('click', function() {
            const prevId = @(ViewBag.NavPrevId ?? 0);
            if (prevId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + prevId + '?frame=1');
        });

        document.getElementById('btnNextAdjustment')?.addEventListener('click', function() {
            const nextId = @(ViewBag.NavNextId ?? 0);
            if (nextId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + nextId + '?frame=1');
        });

        document.getElementById('btnLastAdjustment')?.addEventListener('click', function() {
            const lastId = @(ViewBag.NavLastId ?? 0);
            if (lastId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + lastId + '?frame=1');
        });
    </script>
}
