            this.disabled = true;

            try {
                const response = await fetch(`@Url.Action("ClearLinesJson", "StockAdjustments")?id=${adjustmentId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (!response.ok) {
                    alert('حدث خطأ أثناء مسح السطور.');
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    showToast('تم مسح السطور بنجاح.', 'success');
                    window.location.reload();
                } else {
                    showToast(result.message || 'حدث خطأ أثناء مسح السطور.', 'danger');
                }
            } catch (error) {
                console.error('Error clearing lines:', error);
                alert('حدث خطأ أثناء مسح السطور.');
            } finally {
                this.disabled = false;
            }
        });

        // Navigation
        document.getElementById('btnFirstAdjustment')?.addEventListener('click', function() {
            const firstId = @(ViewBag.NavFirstId ?? 0);
            if (firstId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + firstId + '?frame=1');
        });

        document.getElementById('btnPrevAdjustment')?.addEventListener('click', function() {
            const prevId = @(ViewBag.NavPrevId ?? 0);
            if (prevId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + prevId + '?frame=1');
        });

        document.getElementById('btnNextAdjustment')?.addEventListener('click', function() {
            const nextId = @(ViewBag.NavNextId ?? 0);
            if (nextId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + nextId + '?frame=1');
        });

        document.getElementById('btnLastAdjustment')?.addEventListener('click', function() {
            const lastId = @(ViewBag.NavLastId ?? 0);
            if (lastId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + lastId + '?frame=1');
        });

        // حركة الصنف + تعديل الصنف (مثل فاتورة المبيعات)
        (function() {
            function getCurrentProdId() {
                var pid = document.getElementById('ProdId');
                if (pid && pid.value && pid.value.trim() !== '') return pid.value.trim();
                var code = document.getElementById('ProdCodeInput');
                if (code && code.value && code.value.trim() !== '') return code.value.trim();
                return '';
            }
            function openTabFromFrame(url, tabId, title) {
                try {
                    if (window.top && window.top !== window) {
                        window.top.postMessage({ type: 'erp-open-tab', tabId: tabId || '', title: title || '', url: url }, '*');
                        return;
                    }
                } catch (e) { console.error(e); }
                if (window.erpTabs && typeof window.erpTabs.openTab === 'function') {
                    window.erpTabs.openTab(tabId, url, title);
                } else {
                    window.location.href = url;
                }
            }
            var editBaseUrl = '@Url.Action("Edit", "Products")';
            var movementBaseUrl = '@Url.Action("Show", "Products")';
            function buildEditUrl(id) {
                var base = editBaseUrl.replace(/\/$/, '');
                return base + '/' + encodeURIComponent(id) + '?frame=1';
            }
            function buildMovementUrl(id) {
                var sep = movementBaseUrl.indexOf('?') >= 0 ? '&' : '?';
                return movementBaseUrl + sep + 'prodId=' + encodeURIComponent(id) + '&frame=1';
            }
            var btnEdit = document.getElementById('btnOpenProductEdit');
            var btnMovement = document.getElementById('btnOpenProductMovement');
            if (btnEdit && !btnEdit.dataset.boundEdit) {
                btnEdit.dataset.boundEdit = '1';
                btnEdit.addEventListener('click', function(e) {
                    e.preventDefault();
                    var id = getCurrentProdId();
                    if (!id) { showToast('من فضلك اختر صنفاً أولاً.', 'warning'); document.getElementById('ProdNameInput')?.focus(); return; }
                    openTabFromFrame(buildEditUrl(id), 'product-edit-tab', 'تعديل الصنف');
                });
            }
            if (btnMovement && !btnMovement.dataset.boundMove) {
                btnMovement.dataset.boundMove = '1';
                btnMovement.addEventListener('click', function(e) {
                    e.preventDefault();
                    var id = getCurrentProdId();
                    if (!id) { showToast('من فضلك اختر صنفاً أولاً.', 'warning'); document.getElementById('ProdNameInput')?.focus(); return; }
                    openTabFromFrame(buildMovementUrl(id), 'product-movement-tab', 'حركة الصنف');
                });
            }
        })();

        // ——— طباعة تسوية الجرد (نفس آلية فاتورة المبيعات: piPrintWrapper / print-mode / afterprint) ———
        (function () {
            var btnPrint = document.getElementById('btnPrintStockAdjustmentDropdown');
            if (!btnPrint || btnPrint.dataset.boundSaPrint) return;
            btnPrint.dataset.boundSaPrint = '1';
            var printing = false;
            var printWrapperParent = null;
            var printWrapperNext = null;

            function el(id) { return document.getElementById(id); }

            function prepareStockAdjustmentPrint() {
                if (!el('piPrintArea')) return false;
                var adjId = (el('AdjustmentId') && el('AdjustmentId').value) ? el('AdjustmentId').value.trim() : '';
                var adjDate = (el('AdjustmentDateInput') && el('AdjustmentDateInput').value) ? el('AdjustmentDateInput').value.trim() : '';
                var status = (el('AdjustmentStatusDisplay') && el('AdjustmentStatusDisplay').value) ? el('AdjustmentStatusDisplay').value.trim() : '';
                var whName = '';
                var whSel = document.querySelector('[name="WarehouseId"]');
                if (whSel && whSel.options && whSel.selectedIndex >= 0)
                    whName = (whSel.options[whSel.selectedIndex].text || '').trim();
                if (el('saPrintAdjNo')) el('saPrintAdjNo').textContent = adjId || '—';
                if (el('saPrintAdjDate')) el('saPrintAdjDate').textContent = adjDate || '—';
                if (el('saPrintWarehouse')) el('saPrintWarehouse').textContent = whName || '—';
                if (el('saPrintStatus')) el('saPrintStatus').textContent = status || '—';
                if (el('saPrintNow')) el('saPrintNow').textContent = new Date().toLocaleString();

                var destTbody = el('piPrintMasterTbody');
                if (!destTbody) return false;
                destTbody.innerHTML = '';
                var srcTbody = el('AdjustmentLinesTbody');
                if (!srcTbody) {
                    destTbody.innerHTML = '<tr><td colspan="11" class="text-center text-muted py-2">لا توجد سطور للطباعة.</td></tr>';
                } else {
                    var rows = srcTbody.querySelectorAll('tr[data-line-id]');
                    if (!rows.length) {
                        destTbody.innerHTML = '<tr><td colspan="11" class="text-center text-muted py-2">لا توجد سطور للطباعة.</td></tr>';
                    } else {
                        rows.forEach(function (tr) {
                            var c = tr.cloneNode(true);
                            c.querySelectorAll('button, a, .no-print').forEach(function (x) { x.remove(); });
                            c.querySelectorAll('th.no-print, td.no-print').forEach(function (x) { x.remove(); });
                            destTbody.appendChild(c);
                        });
                    }
                }

                var totalsWrap = el('piPrintTotalsWrap');
                if (!totalsWrap) return false;
                var totalLines = el('AdjustmentTotalLinesValue') ? el('AdjustmentTotalLinesValue').textContent.trim() : '0';
                var totalBefore = el('AdjustmentTotalQtyBeforeValue') ? el('AdjustmentTotalQtyBeforeValue').textContent.trim() : '0';
                var totalAfter = el('AdjustmentTotalQtyAfterValue') ? el('AdjustmentTotalQtyAfterValue').textContent.trim() : '0';
                var totalCostDiff = el('AdjustmentTotalCostDiffValue') ? el('AdjustmentTotalCostDiffValue').textContent.trim() : '0';
                totalsWrap.innerHTML =
                    '<div class="card shadow-sm invoice-totals-card mb-0">' +
                    '<div class="card-body py-2">' +
                    '<div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-boxes">' +
                    '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">عدد السطور</span><span class="invoice-summary-value">' + totalLines + '</span></div>' +
                    '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي الكمية قبل</span><span class="invoice-summary-value">' + totalBefore + '</span></div>' +
                    '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي الكمية بعد</span><span class="invoice-summary-value">' + totalAfter + '</span></div>' +
                    '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي فرق التكلفة</span><span class="invoice-summary-value">' + totalCostDiff + '</span></div>' +
                    '</div></div></div>';
                return true;
            }

            function doStockAdjustmentPrint(mode) {
                var id = parseInt((el('AdjustmentId') && el('AdjustmentId').value) || '0', 10) || 0;
                if (id <= 0) {
                    showToast('⚠️ احفظ التسوية أولاً ثم اطبع.', 'warning');
                    return;
                }
                if (typeof isAdjustmentPosted === 'function' && !isAdjustmentPosted()) {
                    showToast('❌ يجب ترحيل التسوية قبل الطباعة', 'danger');
                    document.getElementById('btnPostAdjustment')?.focus();
                    return;
                }
                if (printing) return;
                printing = true;
                if (!prepareStockAdjustmentPrint()) {
                    printing = false;
                    showToast('تعذر تجهيز الطباعة.', 'danger');
                    return;
                }
                var wrapper = el('piPrintWrapper');
                var printArea = el('piPrintArea');
                if (!wrapper || !printArea) { printing = false; return; }
                wrapper.classList.remove('print-mode-1', 'print-mode-2', 'print-mode-3');
                wrapper.querySelectorAll('.pi-print-copy:not(#piPrintArea)').forEach(function (c) { c.remove(); });
                if (mode === 2 || mode === 3) {
                    var copies = mode === 2 ? 2 : 3;
                    for (var i = 1; i < copies; i++) {
                        var clone = printArea.cloneNode(true);
                        clone.id = '';
                        clone.classList.add('pi-print-copy');
                        clone.querySelectorAll('[id]').forEach(function (node) { node.removeAttribute('id'); });
                        wrapper.appendChild(clone);
                    }
                    wrapper.classList.add('print-mode-' + mode);
                } else {
                    wrapper.classList.add('print-mode-1');
                }
                printWrapperParent = null;
                printWrapperNext = null;
                if (wrapper.parentNode !== document.body) {
                    printWrapperParent = wrapper.parentNode;
                    printWrapperNext = wrapper.nextSibling;
                    document.body.appendChild(wrapper);
                }
                document.body.classList.add('printing-invoice');
                setTimeout(function () { window.print(); }, 50);
            }

            document.querySelectorAll('[data-sa-print-mode]').forEach(function (item) {
                item.addEventListener('click', function (e) {
                    e.preventDefault();
                    var mode = parseInt(this.getAttribute('data-sa-print-mode') || '1', 10);
                    doStockAdjustmentPrint(mode);
                });
            });

            window.addEventListener('afterprint', function () {
                document.body.classList.remove('printing-invoice');
                printing = false;
                var wrapper = el('piPrintWrapper');
                if (wrapper) {
                    wrapper.classList.remove('print-mode-1', 'print-mode-2', 'print-mode-3');
                    wrapper.querySelectorAll('.pi-print-copy:not(#piPrintArea)').forEach(function (c) { c.remove(); });
                    if (printWrapperParent) {
                        if (printWrapperNext) printWrapperParent.insertBefore(wrapper, printWrapperNext);
                        else printWrapperParent.appendChild(wrapper);
                        printWrapperParent = null;
                        printWrapperNext = null;
                    }
                }
            });
        })();
    </script>
}
