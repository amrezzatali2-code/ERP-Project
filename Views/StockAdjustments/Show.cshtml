@model ERP.Models.StockAdjustment

@{
    ViewData["Title"] = Model.Id == 0
        ? "تسوية جرد جديدة"
        : $"تسوية جرد — رقم {Model.Id}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/invoice-cards.css" />
    <style>
        /* ===== تنسيق تسوية الجرد مثل فاتورة المبيعات ===== */
        .adjustment-page {
            background-color: #f3f6fb;
            min-height: 100vh;
            padding-bottom: 2rem;
        }
        .adjustment-page .container-fluid { padding: 0; max-width: 100%; }
        .adjustment-page .row.g-3 { align-items: flex-start !important; }
        .adjustment-page .col-lg-2.order-1.order-lg-2 {
            padding: 0.5rem 0.5rem;
            align-self: flex-start;
            position: sticky !important;
            top: 70px;
            z-index: 1020;
            height: fit-content;
            margin-top: 0 !important;
        }
        .adjustment-page .col-lg-10.order-2 { margin-top: 0 !important; padding-top: 0 !important; }
        .adjustment-page .adjustment-header-card { margin-top: 0 !important; }
        html.in-frame .adjustment-page .col-lg-2.order-1.order-lg-2 { top: 0.5rem; }

        /* كارت الإجراءات الجانبي — نفس فاتورة المبيعات */
        .adjustment-page .invoice-side-card {
            background: #ffffff !important;
            min-width: 220px;
            position: relative;
        }
        .adjustment-page .invoice-side-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            border-bottom: none;
            padding: 0.55rem 1rem;
        }
        .adjustment-page .invoice-side-card .invoice-actions-bar hr { display: none !important; }
        .adjustment-page .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
            border: 1px solid #64748b !important;
            border-radius: 8px;
        }
        .adjustment-page .invoice-side-card .btn-erp + .btn-erp,
        .adjustment-page .invoice-side-card .invoice-actions-bar > div + div { margin-top: 0.25rem; }
        .adjustment-page .invoice-actions-sticky {
            position: sticky;
            top: 58px;
            z-index: 3000;
            background: #ffffff !important;
            border: 1px solid #6366f1 !important;
            padding: 10px 10px !important;
            border-radius: 12px;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
        }
        .adjustment-page .invoice-side-card .form-control {
            background: #fff;
            border-color: #64748b;
            color: #0f172a;
        }

        /* العمود الرئيسي */
        .adjustment-page .col-lg-10.order-2 {
            background: transparent;
            padding: 0.5rem 1rem;
        }

        /* الكروت الرئيسية — خلفية بيضاء، زوايا مستديرة، حدود */
        .adjustment-header-card,
        .adjustment-add-card,
        .adjustment-lines-card,
        .adjustment-totals-card {
            border-radius: 1rem;
            overflow: hidden;
            background: #ffffff !important;
        }
        .adjustment-card-line { display: none; }
        .adjustment-header-card .card-body,
        .adjustment-add-card .card-body,
        .adjustment-totals-card .card-body { padding: 1rem 1.25rem !important; }
        .adjustment-lines-card .card-body { padding: 0 !important; }

        /* حدود وحجم حاوية جدول السطور مثل فاتورة المبيعات */
        .adjustment-page .adjustment-lines-card .erp-table-wrapper,
        .adjustment-page .adjustment-lines-table-wrap {
            border: none;
            border-radius: 0;
            max-height: 360px;
            overflow: auto;
        }
        .adjustment-page .adjustment-lines-card {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
        }
        /* جدول السطور — نفس ألوان جدول طلب الشراء (هيدر رمادي فاتح + حدود + أرضية بيضاء) */
        .adjustment-page .adjustment-lines-card .erp-table thead th {
            background-color: #e2e8f0 !important;
            color: #0f172a !important;
            font-weight: 600;
            padding: 0.5rem 0.55rem;
            border: 1px solid #cbd5e1 !important;
        }
        .adjustment-page .adjustment-lines-card .erp-table tbody tr,
        .adjustment-page .adjustment-lines-card .erp-table tbody td,
        .adjustment-page .adjustment-lines-card .erp-table tbody tr:nth-of-type(odd) td {
            background-color: #fff !important;
        }
        .adjustment-page .adjustment-lines-card .erp-table tbody tr:hover td {
            background-color: #f8fafc !important;
        }
        .adjustment-page .adjustment-lines-card .erp-table tbody td,
        .adjustment-page .adjustment-lines-card .erp-table tbody th {
            color: #0f172a !important;
            border: 1px solid #e2e8f0 !important;
        }

        /* حدود الانبوتات والتسميات مثل فاتورة المبيعات */
        .adjustment-page .adjustment-header-card .form-control,
        .adjustment-page .adjustment-header-card .form-select,
        .adjustment-page .adjustment-add-card .form-control,
        .adjustment-page .adjustment-add-card .form-select,
        .adjustment-page .adjustment-totals-card .form-control {
            border-color: #64748b !important;
            border-radius: 8px;
        }
        .adjustment-page .adjustment-header-card .card-body .form-label,
        .adjustment-page .adjustment-header-card .card-body label,
        .adjustment-page .adjustment-add-card .card-body .form-label,
        .adjustment-page .adjustment-add-card .card-body label,
        .adjustment-page .adjustment-totals-card .card-body .form-label {
            color: #0f172a !important;
            font-weight: 500;
        }
        .adjustment-page .adjustment-header-card .card-body .form-control,
        .adjustment-page .adjustment-header-card .card-body .form-select,
        .adjustment-page .adjustment-add-card .card-body .form-control,
        .adjustment-page .adjustment-add-card .card-body .form-select {
            color: #020617 !important;
        }

        /* حقول التاريخ والوقت */
        input[type="date"],
        input[type="datetime-local"],
        input[type="time"] { direction: ltr !important; text-align: left !important; }
        input[type="date"]::-webkit-calendar-picker-indicator,
        input[type="datetime-local"]::-webkit-calendar-picker-indicator { cursor: pointer; }

        /* سعر الجمهور — فتح بالضغط على اللابل */
        .adjustment-price-label-unlock { cursor: pointer; }
        .adjustment-price-label-unlock:hover { text-decoration: underline; }

        /* بوكس اسم الصنف — حد ملون واضح */
        .adjustment-page .adjustment-prod-name-input {
            border: 2px solid #6366f1 !important;
            border-radius: 8px;
            box-shadow: 0 1px 3px rgba(99, 102, 241, 0.3);
        }

        /* لوحة قائمة التشغيلات — تظهر عند النقر على حقل التشغيلة */
        #batchDropdownPanel.dropdown-menu { display: none; padding: 0; min-width: 100%; }
        #batchDropdownPanel.d-none { display: none !important; }
        #batchDropdownPanel:not(.d-none) { display: block !important; }
        #batchDropdownList .dropdown-item:hover { background-color: #e9ecef; }
        #BatchDropdownToggle { inset-inline-end: 4px; left: auto; right: auto; }

        /* كارت الإجماليات — بوكسات ملخصة مثل فاتورة المبيعات */
        .adjustment-page .adjustment-totals-card .invoice-summary-box {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 0.5rem 0.75rem;
        }
        .adjustment-page .adjustment-totals-card .invoice-summary-label {
            color: #64748b;
            font-size: 0.8rem;
        }
        .adjustment-page .adjustment-totals-card .invoice-summary-value {
            color: #0f172a;
            font-weight: 600;
        }
    </style>
}

<div class="adjustment-page" dir="rtl">
    @* حاوية رسائل الترحيل والعمليات (بوب أب خارج الكارت — مثل فاتورة المبيعات) *@
    <div id="adjustmentToastContainer" class="position-fixed top-0 start-50 translate-middle-x p-2" style="z-index: 9999; margin-top: 60px;" aria-live="polite"></div>

    <div class="container-fluid pt-3">
        <form id="__AntiForgeryForm" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>

        <div class="row g-3">
            @* العمود الجانبي *@
            <div class="col-12 col-lg-2 order-1 order-lg-2">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات تسوية الجرد</h6>
                    </div>

                    <input type="hidden" id="AdjustmentId" value="@Model.Id" />
                    <input type="hidden" id="AdjustmentIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />

                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">
                        @{
                            int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
                            int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
                            int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
                            int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;

                            int currentId = Model?.Id ?? 0;
                            bool hasAny = navFirst.HasValue && navLast.HasValue && navFirst.Value > 0 && navLast.Value > 0;
                            int? prevEffective = (currentId == 0) ? navLast : navPrev;
                            int? nextEffective = (currentId == 0) ? navFirst : navNext;
                            bool canFirst = hasAny && navFirst.HasValue && navFirst.Value > 0 && navFirst.Value != currentId;
                            bool canLast = hasAny && navLast.HasValue && navLast.Value > 0 && navLast.Value != currentId;
                            bool canPrev = hasAny && prevEffective.HasValue && prevEffective.Value > 0 && prevEffective.Value != currentId;
                            bool canNext = hasAny && nextEffective.HasValue && nextEffective.Value > 0 && nextEffective.Value != currentId;
                        }

                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button"
                                    id="btnFirstAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="أول تسوية"
                                    @(canFirst ? "" : "disabled")>
                                ⏮
                            </button>

                            <button type="button"
                                    id="btnPrevAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="التسوية السابقة"
                                    @(canPrev ? "" : "disabled")>
                                ◀
                            </button>

                            <button type="button"
                                    id="btnNextAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="التسوية التالية"
                                    @(canNext ? "" : "disabled")>
                                ▶
                            </button>

                            <button type="button"
                                    id="btnLastAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="آخر تسوية"
                                    @(canLast ? "" : "disabled")>
                                ⏭
                            </button>
                        </div>

                        <hr class="my-1" />

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           href="@Url.Action("Show", "StockAdjustments", new { id = 0, frame = 1 })"
                           data-tab-id="stock-adjustment-create"
                           data-tab-title="تسوية جردية"
                           data-url="@Url.Action("Show", "StockAdjustments", new { id = 0, frame = 1 })">
                            ➕ تسوية جديدة
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnSaveAdjustmentHeader"
                                data-lock-posted="1">
                            💾 حفظ التسوية
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnPostAdjustment"
                                data-lock-posted="1">
                            📤 ترحيل التسوية
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnOpenAdjustment">
                            ⏪ فتح التسوية
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnClearAdjustmentLines"
                                data-lock-posted="1">
                            🗑️ مسح كل السطور
                        </button>

                        <div>
                            <button type="button" id="btnOpenProductMovement" class="btn btn-erp btn-erp-outline-secondary btn-erp-sm w-100">
                                📊 حركة الصنف
                            </button>
                        </div>
                        <div>
                            <button type="button" id="btnOpenProductEdit" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100">
                                ✏️ تعديل الصنف
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            @* العمود الرئيسي *@
            <div class="col-12 col-lg-10 order-2 order-lg-1">
                @* كارت بيانات التسوية *@
                <div class="card shadow-sm mb-2 adjustment-header-card">
                    <div class="adjustment-header-bar">
                        <h5 class="mb-0">تسوية جرد</h5>
                    </div>

                    <div>
                        <div class="card-body">
                            <div class="row g-3 align-items-end">
                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">رقم التسوية</label>
                                    <input id="AdjustmentNumberDisplay" class="form-control form-control-sm text-center" value="@(Model.Id > 0 ? Model.Id.ToString() : "")" readonly />
                                </div>

                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">تاريخ التسوية</label>
                                    <input id="AdjustmentDateInput" type="date" class="form-control form-control-sm" value="@Model.AdjustmentDate.ToString("yyyy-MM-dd")" data-lock-posted="1" dir="ltr" style="text-align: left;" />
                                </div>

                                <div class="col-lg-4">
                                    <label class="form-label form-label-sm">المخزن</label>
                                    <select asp-for="WarehouseId" asp-items="ViewBag.Warehouses" class="form-select form-select-sm" data-lock-posted="1">
                                        <option value="">اختر المخزن</option>
                                    </select>
                                </div>

                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">الحالة</label>
                                    <input id="AdjustmentStatusDisplay" class="form-control form-control-sm text-center" value="@(string.IsNullOrWhiteSpace(Model.Status) ? "مسودة" : Model.Status)" readonly />
                                </div>
                            </div>
                            <input type="hidden" asp-for="ReferenceNo" id="ReferenceNoHidden" />

                            @* الملاحظات مُزالة من الواجهة — القيمة محفوظة في الهيدر عند الحفظ *@
                            <input type="hidden" name="Reason" id="ReasonHidden" value="@(Model?.Reason ?? "")" />
                        </div>
                    </div>
                </div>

                @* كارت إدخال السطر *@
                <div class="card shadow-sm mb-2 adjustment-add-card">
                    <div class="adjustment-card-line"></div>
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">كود الصنف</label>
                                <input type="number" id="ProdCodeInput" class="form-control form-control-sm text-center" placeholder="بحث بالكود..." data-lock-posted="1" />
                            </div>

                            <div class="col-lg-5">
                                <label class="form-label form-label-sm">اسم الصنف</label>
                                <input id="ProdNameInput" list="productsList" class="form-control form-control-sm adjustment-prod-name-input" placeholder="اكتب اسم الصنف..." autocomplete="off" data-lock-posted="1" />
                                <datalist id="productsList">
                                    @if (ViewBag.ProductsAuto != null)
                                    {
                                        foreach (var p in ViewBag.ProductsAuto)
                                        {
                                            <option value="@p.Name"
                                                    data-id="@p.Id"
                                                    data-code="@p.Id"
                                                    data-generic="@p.GenericName"
                                                    data-company="@p.Company"
                                                    data-price="@p.PriceRetail"
                                                    data-hasquota="@(p.HasQuota ? "true" : "false")">
                                            </option>
                                        }
                                    }
                                </datalist>
                                <input type="hidden" id="ProdId" />
                            </div>

                            <div class="col-lg-1 col-md-2 position-relative">
                                <label class="form-label form-label-sm">التشغيلة</label>
                                <div class="d-flex align-items-center position-relative">
                                    <input type="text" id="BatchNoInput" class="form-control form-control-sm text-center flex-grow-1" autocomplete="off" data-lock-posted="1" />
                                    <span id="BatchDropdownToggle" class="position-absolute px-2 text-muted" style="left: 4px; top: 50%; transform: translateY(-50%); cursor: pointer; pointer-events: none;" aria-hidden="true">▼</span>
                                </div>
                                <datalist id="batchList"></datalist>
                                <div id="batchDropdownPanel" class="dropdown-menu shadow-sm border position-absolute start-0 w-100 mt-0 d-none" style="max-height: 200px; overflow-y: auto; z-index: 1050; top: 100%;">
                                    <div id="batchDropdownList"></div>
                                </div>
                            </div>

                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">تاريخ الصلاحية</label>
                                <input type="date" id="ExpiryInput" class="form-control form-control-sm text-center" data-lock-posted="1" dir="ltr" style="text-align: left;" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">اجمالي الكمية</label>
                                <input type="number" id="TotalQtyInput" class="form-control form-control-sm text-center" value="0" readonly data-lock-posted="1" title="مجموع كميات كل التشغيلات" />
                            </div>
                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الكمية قبل</label>
                                <input type="number" id="QtyBeforeInput" class="form-control form-control-sm text-center" value="0" readonly data-lock-posted="1" title="كمية التشغيلة المختارة فقط" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الكمية بعد</label>
                                <input type="number" id="QtyAfterInput" class="form-control form-control-sm text-center" value="0" data-lock-posted="1" />
                            </div>
                        </div>

                        <div class="row g-2 mt-2">
                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">تكلفة الوحدة</label>
                                <input type="number" id="CostPerUnitInput" class="form-control form-control-sm text-center" step="0.0001" data-lock-posted="1" />
                            </div>

                            <div class="col-lg-2">
                                <label id="PriceRetailLabel" class="form-label form-label-sm adjustment-price-label-unlock" title="اضغط لفتح التعديل">سعر الجمهور</label>
                                <input type="number" id="PriceRetailInput" class="form-control form-control-sm text-center bg-light text-muted" step="0.01" data-lock-posted="1" readonly />
                            </div>

                            <div class="col-lg-6">
                                <label class="form-label form-label-sm">ملاحظات السطر</label>
                                <input type="text" id="LineNoteInput" class="form-control form-control-sm" data-lock-posted="1" />
                            </div>

                            <div class="col-lg-2 d-grid">
                                <label class="form-label form-label-sm">&nbsp;</label>
                                <button type="button" id="btnAddAdjustmentLine" class="btn btn-erp btn-erp-primary btn-erp-sm w-100" data-lock-posted="1">إضافة</button>
                            </div>
                        </div>
                    </div>
                </div>

                @* جدول السطور *@
                <div class="card shadow-sm mb-2 adjustment-lines-card">
                    <div class="adjustment-card-line"></div>
                    <div class="card-body p-0">
                        <div class="erp-table-wrapper adjustment-lines-table-wrap">
                            <table class="table table-sm table-striped table-hover mb-0 erp-table">
                                <thead>
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">التشغيلة</th>
                                        <th class="text-center">الصلاحية</th>
                                        <th class="text-center">الكمية قبل</th>
                                        <th class="text-center">الكمية بعد</th>
                                        <th class="text-center">الفرق</th>
                                        <th class="text-center">تكلفة الوحدة</th>
                                        <th class="text-center">فرق التكلفة</th>
                                        <th class="text-center no-print">مسح</th>
                                    </tr>
                                </thead>
                                <tbody id="AdjustmentLinesTbody">
                                    @if (Model.Lines != null && Model.Lines.Any())
                                    {
                                        int lineNo = 1;
                                        foreach (var line in Model.Lines.OrderBy(l => l.Id))
                                        {
                                            <tr data-line-id="@line.Id">
                                                <td class="text-center">@lineNo</td>
                                                <td>@(line.Product?.ProdName ?? $"صنف #{line.ProductId}")</td>
                                                <td class="text-center">@(line.Batch?.BatchNo ?? "-")</td>
                                                <td class="text-center">@(line.Batch?.Expiry.ToString("yyyy-MM-dd") ?? "-")</td>
                                                <td class="text-center">@line.QtyBefore</td>
                                                <td class="text-center">@line.QtyAfter</td>
                                                <td class="text-center">@line.QtyDiff</td>
                                                <td class="text-center">@(line.CostPerUnit?.ToString("0.0000") ?? "-")</td>
                                                <td class="text-center">@(line.CostDiff?.ToString("0.00") ?? "-")</td>
                                                <td class="text-center no-print">
                                                    <button type="button" class="btn btn-sm btn-danger btn-delete-line" data-line-id="@line.Id" data-lock-posted="1">🗑️</button>
                                                </td>
                                            </tr>
                                            lineNo++;
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="10" class="text-center text-muted py-4">لا توجد سطور بعد.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @* كارت إجماليات التسوية — بدون هيدر ملون (مثل فاتورة المبيعات) *@
                <div class="card shadow-sm mb-2 adjustment-totals-card">
                    <div class="card-body">
                        <div class="d-flex flex-wrap align-items-stretch gap-3 invoice-summary-row invoice-summary-row-boxes">
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">عدد السطور</span>
                                <span id="AdjustmentTotalLinesValue" class="invoice-summary-value">@(Model.Lines?.Count ?? 0)</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">إجمالي الكمية قبل</span>
                                <span id="AdjustmentTotalQtyBeforeValue" class="invoice-summary-value">@(Model.Lines?.Sum(l => l.QtyBefore) ?? 0)</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">إجمالي الكمية بعد</span>
                                <span id="AdjustmentTotalQtyAfterValue" class="invoice-summary-value">@(Model.Lines?.Sum(l => l.QtyAfter) ?? 0)</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">إجمالي فرق التكلفة</span>
                                <span id="AdjustmentTotalCostDiffValue" class="invoice-summary-value">@((Model.Lines?.Sum(l => l.CostDiff ?? 0) ?? 0).ToString("0.00"))</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Anti-forgery token
        function getAntiForgeryToken() {
            const form = document.getElementById('__AntiForgeryForm');
            return form?.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        // الانتقال داخل التاب (عند فتح الصفحة في iframe) — يمنع الشاشة البيضاء
        function navigateAdjustmentTab(url) {
            try {
                if (window.top && window.top !== window.self) {
                    window.top.postMessage({ type: 'erp-update-current-tab', url: url, title: 'فاتورة تسوية جردية' }, '*');
                } else {
                    window.location.href = url;
                }
            } catch (e) { window.location.href = url; }
        }

        // =========================================================
        // قفل الأزرار والحقول عند الترحيل (مثل فاتورة المبيعات)
        // =========================================================
        function isAdjustmentPosted() {
            const flag = document.getElementById('AdjustmentIsPostedFlag');
            return flag && flag.value === '1';
        }

        function setAdjustmentPosted(posted) {
            const flag = document.getElementById('AdjustmentIsPostedFlag');
            if (flag) flag.value = posted ? '1' : '0';
        }

        function applyPostedUiLock() {
            const posted = isAdjustmentPosted();
            const lockables = document.querySelectorAll('[data-lock-posted="1"]');

            lockables.forEach(el => {
                if (el.dataset.lockInit !== '1') {
                    el.dataset.lockInit = '1';
                    el.dataset.origDisabled = el.disabled ? '1' : '0';
                    el.dataset.origReadonly = el.readOnly ? '1' : '0';
                    el.dataset.origTabIndex = el.getAttribute('tabindex') ?? '';
                }

                const tag = (el.tagName || '').toUpperCase();

                if (posted) {
                    if (tag === 'BUTTON') { el.disabled = true; return; }
                    if (tag === 'A') {
                        el.classList.add('disabled', 'pe-none');
                        el.setAttribute('aria-disabled', 'true');
                        el.setAttribute('tabindex', '-1');
                        return;
                    }
                    if (tag === 'INPUT' || tag === 'TEXTAREA') {
                        el.readOnly = true;
                        el.classList.add('bg-light', 'text-muted');
                        return;
                    }
                    if (tag === 'SELECT') { el.disabled = true; return; }
                    return;
                }

                const origDisabled = el.dataset.origDisabled === '1';
                const origReadonly = el.dataset.origReadonly === '1';
                const origTabIndex = el.dataset.origTabIndex;

                if (tag === 'BUTTON') { el.disabled = origDisabled; return; }
                if (tag === 'A') {
                    el.classList.remove('disabled', 'pe-none');
                    el.removeAttribute('aria-disabled');
                    if (origTabIndex === '') el.removeAttribute('tabindex');
                    else el.setAttribute('tabindex', origTabIndex);
                    return;
                }
                if (tag === 'INPUT' || tag === 'TEXTAREA') {
                    el.readOnly = origReadonly;
                    el.classList.remove('bg-light', 'text-muted');
                    return;
                }
                if (tag === 'SELECT') { el.disabled = origDisabled; return; }
            });

            const btnPost = document.getElementById('btnPostAdjustment');
            if (btnPost) {
                btnPost.disabled = posted;
                btnPost.innerHTML = posted ? '✅ تم ترحيل التسوية' : '📤 ترحيل التسوية';
            }

            const btnOpen = document.getElementById('btnOpenAdjustment');
            if (btnOpen) btnOpen.disabled = !posted;
        }

        // تطبيق القفل عند تحميل الصفحة إن كانت التسوية مترحلة
        (function() {
            const serverIsPosted = @Model.IsPosted.ToString().ToLower();
            if (serverIsPosted) {
                setAdjustmentPosted(true);
                applyPostedUiLock();
            }
        })();

        // رسائل بوب أب خارج الكارت (مثل فاتورة المبيعات)
        function showToast(text, type) {
            if (!text) return;
            var container = document.getElementById('adjustmentToastContainer');
            if (!container) return;
            type = type || 'muted';
            var el = document.createElement('div');
            el.className = 'alert alert-' + (type === 'danger' ? 'danger' : type === 'success' ? 'success' : type === 'warning' ? 'warning' : 'secondary') + ' shadow-sm mb-0 py-2 px-3';
            el.style.minWidth = '220px';
            el.textContent = text;
            container.appendChild(el);
            setTimeout(function() {
                el.style.opacity = '0';
                el.style.transition = 'opacity 0.25s ease';
                setTimeout(function() {
                    if (el.parentNode) el.parentNode.removeChild(el);
                }, 250);
            }, 4000);
        }

        // تشغيلات الصنف الحالية (تُملأ عند تحميل بيانات الصنف — للاختيار من القائمة أو إدخال تشغيلة جديدة)
        let currentBatches = [];

        // تحميل بيانات الصنف تلقائياً + ملء قائمة التشغيلات
        let busyLoadInfo = false;
        async function loadProductInfo() {
            const prodId = parseInt(document.getElementById('ProdId').value || '0', 10);
            const warehouseId = parseInt(document.querySelector('[name="WarehouseId"]')?.value || '0', 10);
            if (!prodId || prodId <= 0 || !warehouseId || warehouseId <= 0) {
                currentBatches = [];
                var bl = document.getElementById('batchList');
                if (bl) bl.innerHTML = '';
                var totalEl = document.getElementById('TotalQtyInput');
                if (totalEl) totalEl.value = '0';
                var qtyBeforeEl = document.getElementById('QtyBeforeInput');
                if (qtyBeforeEl) qtyBeforeEl.value = '0';
                var batchToggle = document.getElementById('BatchDropdownToggle');
                if (batchToggle) batchToggle.style.visibility = 'hidden';
                return;
            }
            if (busyLoadInfo) return;
            busyLoadInfo = true;
            const batchNo = document.getElementById('BatchNoInput').value?.trim() || '';
            const expiry = document.getElementById('ExpiryInput').value || '';
            try {
                const url = '@Url.Action("GetStockAdjustmentProductInfo", "StockAdjustments")'
                    + '?prodId=' + encodeURIComponent(prodId)
                    + '&warehouseId=' + encodeURIComponent(warehouseId)
                    + (batchNo ? '&batchNo=' + encodeURIComponent(batchNo) : '')
                    + (expiry ? '&expiry=' + encodeURIComponent(expiry) : '');
                const r = await fetch(url, { method: 'GET' });
                const data = await r.json();
                if (data && data.ok) {
                    document.getElementById('TotalQtyInput').value = data.totalQty ?? 0;
                    document.getElementById('QtyBeforeInput').value = data.qtyBefore || 0;
                    document.getElementById('CostPerUnitInput').value = data.costPerUnit || '';
                    document.getElementById('PriceRetailInput').value = data.priceRetail || '';
                    currentBatches = data.batches || [];
                    var batchListEl = document.getElementById('batchList');
                    if (batchListEl) {
                        batchListEl.innerHTML = '';
                        currentBatches.forEach(function(b) {
                            var opt = document.createElement('option');
                            opt.value = (b.batchNo || '').trim();
                            opt.textContent = (b.batchNo || '') + (b.expiryText ? ' — ' + b.expiryText : '');
                            batchListEl.appendChild(opt);
                        });
                    }
                    // عند تحميل صنف جديد نعيّن دائماً التشغيلة وتاريخ الصلاحية لأول تشغيلة له (حتى بعد تغيير الصنف بالاسم/الكود + Enter)
                    document.getElementById('BatchNoInput').value = data.firstBatchNo ?? '';
                    document.getElementById('ExpiryInput').value = data.firstExpiry ?? '';
                    var batchToggle = document.getElementById('BatchDropdownToggle');
                    if (batchToggle) batchToggle.style.visibility = (currentBatches && currentBatches.length > 1) ? 'visible' : 'hidden';
                } else {
                    currentBatches = [];
                    var bl = document.getElementById('batchList');
                    if (bl) bl.innerHTML = '';
                }
            } catch (e) { console.warn('GetStockAdjustmentProductInfo:', e); currentBatches = []; }
            finally { busyLoadInfo = false; }
        }

        // عند اختيار أو كتابة التشغيلة: إن وافقت إحدى القائمة نملأ تاريخ الصلاحية أوتوماتيك ونحدّث الكمية قبل
        document.getElementById('BatchNoInput')?.addEventListener('input', function() {
            var v = this.value?.trim() || '';
            var found = currentBatches.find(function(b) { return (b.batchNo || '').trim() === v; });
            if (found && found.expiryText) {
                document.getElementById('ExpiryInput').value = found.expiryText;
                loadProductInfo();
            }
        });

        // لوحة قائمة التشغيلات الظاهرة عند النقر على حقل التشغيلة
        (function() {
            var batchInput = document.getElementById('BatchNoInput');
            var panel = document.getElementById('batchDropdownPanel');
            var listEl = document.getElementById('batchDropdownList');
            if (!batchInput || !panel || !listEl) return;

            function renderBatchList() {
                listEl.innerHTML = '';
                if (!currentBatches || currentBatches.length === 0) return;
                currentBatches.forEach(function(b) {
                    var batchNo = (b.batchNo || '').trim();
                    var expiryText = b.expiryText || '';
                    var label = batchNo + (expiryText ? ' — ' + expiryText : '');
                    var btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'dropdown-item text-start w-100 border-0 bg-transparent py-2 px-2 small';
                    btn.textContent = label;
                    btn.dataset.batchNo = batchNo;
                    btn.dataset.expiry = expiryText;
                    btn.addEventListener('click', function(e) {
                        e.preventDefault();
                        batchInput.value = batchNo;
                        document.getElementById('ExpiryInput').value = expiryText;
                        loadProductInfo();
                        panel.classList.add('d-none');
                    });
                    listEl.appendChild(btn);
                });
            }

            function showPanel() {
                if (!currentBatches || currentBatches.length <= 1) return;
                renderBatchList();
                panel.classList.remove('d-none');
            }

            function hidePanel() {
                panel.classList.add('d-none');
            }

            batchInput.addEventListener('focus', function() { showPanel(); });
            batchInput.addEventListener('click', function() { showPanel(); });

            document.addEventListener('click', function(e) {
                if (panel.classList.contains('d-none')) return;
                if (!panel.contains(e.target) && e.target !== batchInput) hidePanel();
            });
        })();

        // سعر الجمهور: مغلق افتراضياً — الضغط على اللابل يفتح التعديل
        (function() {
            var priceLabel = document.getElementById('PriceRetailLabel');
            var priceInput = document.getElementById('PriceRetailInput');
            if (!priceLabel || !priceInput) return;
            var priceLocked = true;
            function applyPriceLockUI() {
                priceInput.readOnly = priceLocked;
                if (priceLocked) {
                    priceInput.classList.add('bg-light', 'text-muted');
                } else {
                    priceInput.classList.remove('bg-light', 'text-muted');
                    priceInput.focus();
                    priceInput.select();
                }
            }
            priceLabel.addEventListener('click', function() {
                priceLocked = !priceLocked;
                applyPriceLockUI();
            });
        })();

        function resolveProductByName(val, exactOnly) {
            if (!(val || '').trim()) return null;
            val = (val || '').trim();
            var opt = document.querySelector('#productsList option[value="' + val.replace(/"/g, '\\"') + '"]');
            if (!opt && !exactOnly) {
                var opts = document.querySelectorAll('#productsList option');
                for (var i = 0; i < opts.length; i++) {
                    var v = (opts[i].getAttribute('value') || '').trim();
                    if (v === val || v.indexOf(val) === 0) { opt = opts[i]; break; }
                }
            }
            return opt;
        }
        document.getElementById('ProdNameInput')?.addEventListener('input', function() {
            var opt = resolveProductByName(this.value, true);
            if (opt) {
                document.getElementById('ProdId').value = opt.getAttribute('data-id');
                document.getElementById('ProdCodeInput').value = opt.getAttribute('data-id');
                document.getElementById('ProdNameInput').value = opt.getAttribute('value') || opt.value || '';
                loadProductInfo();
            }
        });
        // عند الخروج من حقل اسم الصنف: إن كان النص يطابق صنفاً (تطابق تام أو يبدأ بـ) نحمّل بياناته
        document.getElementById('ProdNameInput')?.addEventListener('blur', function() {
            var val = (this.value || '').trim();
            if (!val) return;
            var opt = resolveProductByName(val, false);
            if (opt) {
                var newId = opt.getAttribute('data-id');
                if (document.getElementById('ProdId').value !== newId) {
                    document.getElementById('ProdId').value = newId;
                    document.getElementById('ProdCodeInput').value = newId;
                    document.getElementById('ProdNameInput').value = opt.getAttribute('value') || opt.value || '';
                    loadProductInfo();
                }
            }
        });

        document.getElementById('ProdCodeInput')?.addEventListener('input', function() {
            const code = (this.value || '').trim();
            if (code) {
                const selectedOption = document.querySelector('#productsList option[data-id="' + code + '"]');
                if (selectedOption) {
                    document.getElementById('ProdId').value = code;
                    document.getElementById('ProdNameInput').value = selectedOption.getAttribute('value') || selectedOption.value || '';
                    loadProductInfo();
                }
            }
        });
        // عند الخروج من حقل كود الصنف: إن كان الكود يطابق صنفاً نحمّل بياناته
        document.getElementById('ProdCodeInput')?.addEventListener('blur', function() {
            var code = (this.value || '').trim();
            if (!code) return;
            var opt = document.querySelector('#productsList option[data-id="' + code + '"]');
            if (opt && document.getElementById('ProdId').value !== code) {
                document.getElementById('ProdId').value = code;
                document.getElementById('ProdNameInput').value = opt.getAttribute('value') || opt.value || '';
                loadProductInfo();
            }
        });

        document.getElementById('BatchNoInput')?.addEventListener('blur', loadProductInfo);
        document.getElementById('ExpiryInput')?.addEventListener('change', loadProductInfo);
        document.querySelector('[name="WarehouseId"]')?.addEventListener('change', function() {
            if (document.getElementById('ProdId').value) loadProductInfo();
        });

        // دالة مسح حقول إضافة السطر وإعادة الفوكس لاسم الصنف
        function clearAddLineFormAndFocus() {
            document.getElementById('ProdId').value = '';
            document.getElementById('ProdCodeInput').value = '';
            document.getElementById('ProdNameInput').value = '';
            document.getElementById('BatchNoInput').value = '';
            document.getElementById('ExpiryInput').value = '';
            document.getElementById('TotalQtyInput').value = '0';
            document.getElementById('QtyBeforeInput').value = '0';
            document.getElementById('QtyAfterInput').value = '0';
            document.getElementById('CostPerUnitInput').value = '';
            document.getElementById('PriceRetailInput').value = '';
            document.getElementById('LineNoteInput').value = '';
            currentBatches = [];
            var batchListEl = document.getElementById('batchList');
            if (batchListEl) batchListEl.innerHTML = '';
            var batchToggle = document.getElementById('BatchDropdownToggle');
            if (batchToggle) batchToggle.style.visibility = 'hidden';
            const prodNameInput = document.getElementById('ProdNameInput');
            prodNameInput?.focus();
            prodNameInput?.select?.();
        }

        // دالة إضافة صف للجدول أو تحديثه
        function upsertAdjustmentRow(result, lineNo) {
            const tbody = document.getElementById('AdjustmentLinesTbody');
            const placeholder = tbody.querySelector('tr td[colspan="10"]');
            if (placeholder) placeholder.closest('tr').remove();

            const existingRow = tbody.querySelector(`tr[data-line-id="${result.lineId}"]`);
            const costStr = result.costPerUnit != null ? parseFloat(result.costPerUnit).toFixed(4) : '-';
            const costDiffStr = result.costDiff != null ? parseFloat(result.costDiff).toFixed(2) : '-';
            const rowHtml = `<tr data-line-id="${result.lineId}">
                <td class="text-center">${lineNo}</td>
                <td>${escapeHtml(result.productName)}</td>
                <td class="text-center">${escapeHtml(result.batchNo)}</td>
                <td class="text-center">${escapeHtml(result.expiryDisplay)}</td>
                <td class="text-center">${result.qtyBefore}</td>
                <td class="text-center">${result.qtyAfter}</td>
                <td class="text-center">${result.qtyDiff}</td>
                <td class="text-center">${costStr}</td>
                <td class="text-center">${costDiffStr}</td>
                <td class="text-center no-print">
                    <button type="button" class="btn btn-sm btn-danger btn-delete-line" data-line-id="${result.lineId}" data-lock-posted="1">🗑️</button>
                </td>
            </tr>`;

            if (existingRow) {
                existingRow.outerHTML = rowHtml;
            } else {
                tbody.insertAdjacentHTML('beforeend', rowHtml);
            }
            if (tbody.querySelectorAll('tr').length === 0) {
                tbody.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-4">لا توجد سطور بعد.</td></tr>';
            }
        }
        function escapeHtml(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

        // تحديث كارت الإجماليات من جدول السطور
        function updateAdjustmentTotalsCard() {
            var tbody = document.getElementById('AdjustmentLinesTbody');
            var rows = tbody ? tbody.querySelectorAll('tr[data-line-id]') : [];
            var totalLines = rows.length;
            var totalQtyBefore = 0, totalQtyAfter = 0, totalCostDiff = 0;
            for (var i = 0; i < rows.length; i++) {
                var cells = rows[i].cells;
                if (cells.length >= 10) {
                    totalQtyBefore += parseInt(cells[4].textContent || '0', 10);
                    totalQtyAfter += parseInt(cells[5].textContent || '0', 10);
                    var costDiffText = (cells[8].textContent || '0').replace(',', '.');
                    totalCostDiff += parseFloat(costDiffText) || 0;
                }
            }
            var elLines = document.getElementById('AdjustmentTotalLinesValue');
            var elBefore = document.getElementById('AdjustmentTotalQtyBeforeValue');
            var elAfter = document.getElementById('AdjustmentTotalQtyAfterValue');
            var elCostDiff = document.getElementById('AdjustmentTotalCostDiffValue');
            if (elLines) elLines.textContent = totalLines;
            if (elBefore) elBefore.textContent = totalQtyBefore;
            if (elAfter) elAfter.textContent = totalQtyAfter;
            if (elCostDiff) elCostDiff.textContent = totalCostDiff.toFixed(2);
        }

        // Add line
        async function doAddAdjustmentLine() {
            if (typeof isAdjustmentPosted === 'function' && isAdjustmentPosted()) return;
            const adjustmentId = parseInt(document.getElementById('AdjustmentId').value || '0', 10);
            if (!adjustmentId || adjustmentId <= 0) {
                alert('لا يمكن إضافة سطور قبل حفظ التسوية. اضغط "حفظ التسوية" أولاً.');
                return;
            }

            const prodId = parseInt(document.getElementById('ProdId').value || '0', 10);
            const qtyBefore = parseInt(document.getElementById('QtyBeforeInput').value || '0', 10);
            const qtyAfter = parseInt(document.getElementById('QtyAfterInput').value || '0', 10);
            const batchNo = document.getElementById('BatchNoInput').value?.trim() || '';
            const expiry = document.getElementById('ExpiryInput').value || '';
            const costPerUnit = parseFloat(document.getElementById('CostPerUnitInput').value || '0');
            const priceRetail = parseFloat(document.getElementById('PriceRetailInput').value || '0');
            const note = document.getElementById('LineNoteInput').value?.trim() || '';

            if (!prodId || prodId <= 0) {
                alert('من فضلك اختر صنفاً صحيحاً.');
                return;
            }

            if (qtyBefore < 0 || qtyAfter < 0) {
                alert('الكميات يجب أن تكون أكبر من أو تساوي صفر.');
                return;
            }

            const dto = {
                stockAdjustmentId: adjustmentId,
                productId: prodId,
                batchNo: batchNo || null,
                expiry: expiry || null,
                priceRetail: priceRetail || null,
                qtyBefore: qtyBefore,
                qtyAfter: qtyAfter,
                costPerUnit: costPerUnit || null,
                note: note
            };

            const token = getAntiForgeryToken();
            const btn = document.getElementById('btnAddAdjustmentLine');
            btn.disabled = true;

            try {
                const response = await fetch('@Url.Action("AddLineJson", "StockAdjustments")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(dto)
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    alert('حدث خطأ أثناء إضافة السطر: ' + errorText);
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    const tbody = document.getElementById('AdjustmentLinesTbody');
                    const currentRows = tbody.querySelectorAll('tr[data-line-id]');
                    let lineNo;
                    if (result.isUpdate) {
                        const existingRow = tbody.querySelector(`tr[data-line-id="${result.lineId}"]`);
                        lineNo = existingRow ? parseInt(existingRow.querySelector('td')?.textContent || '1', 10) : currentRows.length + 1;
                    } else {
                        lineNo = currentRows.length + 1;
                    }
                    upsertAdjustmentRow(result, lineNo);
                    updateAdjustmentTotalsCard();
                    clearAddLineFormAndFocus();
                } else {
                    alert(result.message || 'حدث خطأ أثناء إضافة السطر.');
                }
            } catch (error) {
                console.error('Error adding line:', error);
                alert('حدث خطأ أثناء إضافة السطر.');
            } finally {
                btn.disabled = false;
            }
        }

        document.getElementById('btnAddAdjustmentLine')?.addEventListener('click', doAddAdjustmentLine);

        // الانتقال بـ Enter بين الحقول وزر الإضافة
        const enterNavFields = [
            document.getElementById('ProdCodeInput'),
            document.getElementById('ProdNameInput'),
            document.getElementById('BatchNoInput'),
            document.getElementById('ExpiryInput'),
            document.getElementById('QtyAfterInput'),
            document.getElementById('CostPerUnitInput'),
            document.getElementById('PriceRetailInput'),
            document.getElementById('LineNoteInput'),
            document.getElementById('btnAddAdjustmentLine')
        ].filter(Boolean);

        enterNavFields.forEach((el, idx) => {
            if (el.dataset.boundEnterNav === '1') return;
            el.dataset.boundEnterNav = '1';
            el.addEventListener('keydown', async function(e) {
                if (e.key !== 'Enter') return;
                e.preventDefault();
                if (el === document.getElementById('ProdNameInput')) {
                    const val = (el.value || '').trim();
                    if (val) {
                        const opt = resolveProductByName(val, false);
                        if (opt) {
                            document.getElementById('ProdId').value = opt.getAttribute('data-id');
                            document.getElementById('ProdCodeInput').value = opt.getAttribute('data-id');
                            document.getElementById('ProdNameInput').value = opt.getAttribute('value') || opt.value || val;
                            await loadProductInfo();
                        }
                    }
                }
                if (el === document.getElementById('ProdCodeInput')) {
                    const code = (el.value || '').trim();
                    if (code) {
                        let opt = document.querySelector('#productsList option[data-id="' + code + '"]');
                        if (opt) {
                            document.getElementById('ProdId').value = code;
                            document.getElementById('ProdNameInput').value = opt.getAttribute('value') || opt.value || '';
                            await loadProductInfo();
                        }
                    }
                }
                const next = enterNavFields[idx + 1];
                if (el === document.getElementById('btnAddAdjustmentLine')) {
                    doAddAdjustmentLine();
                } else if (el === document.getElementById('LineNoteInput')) {
                    doAddAdjustmentLine();
                } else if (next) {
                    next.focus();
                    if (typeof next.select === 'function') next.select?.();
                }
            });
        });

        // Delete line (event delegation للصفوف المضافة ديناميكياً)
        document.getElementById('AdjustmentLinesTbody')?.addEventListener('click', async function(e) {
            const btn = e.target.closest('.btn-delete-line');
            if (!btn) return;
            if (btn.disabled) return;
            const lineId = parseInt(btn.getAttribute('data-line-id') || '0', 10);
            if (!lineId || lineId <= 0) return;
            if (typeof isAdjustmentPosted === 'function' && isAdjustmentPosted()) return;

            if (!confirm('هل أنت متأكد من حذف هذا السطر؟')) return;

            const token = getAntiForgeryToken();
            btn.disabled = true;

            try {
                const response = await fetch(`@Url.Action("DeleteLineJson", "StockAdjustments")?id=${lineId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (!response.ok) {
                    alert('حدث خطأ أثناء حذف السطر.');
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    const row = btn.closest('tr');
                    if (row) row.remove();
                    const tbody = document.getElementById('AdjustmentLinesTbody');
                    if (tbody && tbody.querySelectorAll('tr[data-line-id]').length === 0) {
                        tbody.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-4">لا توجد سطور بعد.</td></tr>';
                    }
                    updateAdjustmentTotalsCard();
                } else {
                    alert(result.message || 'حدث خطأ أثناء حذف السطر.');
                }
            } catch (error) {
                console.error('Error deleting line:', error);
                alert('حدث خطأ أثناء حذف السطر.');
            } finally {
                btn.disabled = false;
            }
        });

        // Save header (رقم مرجعي مخفي — يُرسل من الحقل المخفي)
        document.getElementById('btnSaveAdjustmentHeader')?.addEventListener('click', async function() {
            const adjustmentId = parseInt(document.getElementById('AdjustmentId').value || '0', 10);
            const adjustmentDate = document.getElementById('AdjustmentDateInput').value;
            const warehouseId = document.querySelector('[name="WarehouseId"]').value;
            const referenceNo = document.getElementById('ReferenceNoHidden')?.value ?? '';
            const reason = document.getElementById('ReasonHidden')?.value ?? '';

            if (!warehouseId || warehouseId <= 0) {
                alert('من فضلك اختر مخزناً.');
                return;
            }

            const dto = {
                id: adjustmentId,
                adjustmentDate: adjustmentDate,
                warehouseId: parseInt(warehouseId, 10),
                referenceNo: referenceNo,
                reason: reason
            };

            const token = getAntiForgeryToken();
            this.disabled = true;

            try {
                const url = adjustmentId > 0 
                    ? '@Url.Action("UpdateHeaderJson", "StockAdjustments")'
                    : '@Url.Action("CreateHeaderJson", "StockAdjustments")';

                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(dto)
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    alert('حدث خطأ أثناء حفظ التسوية: ' + errorText);
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    if (result.id && result.id > 0) {
                        document.getElementById('AdjustmentId').value = result.id;
                        document.getElementById('AdjustmentNumberDisplay').value = result.id;
                        const baseUrl = '@Url.Action("Show", "StockAdjustments")';
                        const newPath = baseUrl + '/' + result.id + (window.location.search || '');
                        window.history.replaceState({}, '', newPath);
                        document.title = 'تسوية جرد — رقم ' + result.id;
                    }
                    const ProdNameInput = document.getElementById('ProdNameInput');
                    ProdNameInput?.focus();
                    ProdNameInput?.select?.();
                } else {
                    alert(result.message || 'حدث خطأ أثناء حفظ التسوية.');
                }
            } catch (error) {
                console.error('Error saving adjustment:', error);
                alert('حدث خطأ أثناء حفظ التسوية.');
            } finally {
                this.disabled = false;
            }
        });

        // Post adjustment — رسالة الترحيل كـ Toast خارج الكارت (مثل فاتورة المبيعات)
        document.getElementById('btnPostAdjustment')?.addEventListener('click', async function() {
            const adjustmentId = parseInt(document.getElementById('AdjustmentId').value || '0', 10);
            if (!adjustmentId || adjustmentId <= 0) {
                showToast('يجب حفظ التسوية أولاً قبل الترحيل.', 'warning');
                return;
            }

            if (!confirm('هل أنت متأكد من ترحيل هذه التسوية؟')) return;

            const token = getAntiForgeryToken();
            const btnPost = this;
            const oldHtml = btnPost.innerHTML;
            btnPost.disabled = true;
            btnPost.innerHTML = '⏳ جاري الترحيل...';
            showToast('يتم حفظ التعديلات ثم الترحيل...', 'muted');

            try {
                const adjustmentDate = document.getElementById('AdjustmentDateInput')?.value;
                const warehouseId = parseInt(document.querySelector('[name="WarehouseId"]')?.value || '0', 10);
                const referenceNo = document.getElementById('ReferenceNoHidden')?.value ?? '';
                const reason = document.getElementById('ReasonHidden')?.value ?? '';
                if (warehouseId > 0) {
                    const saveDto = { id: adjustmentId, adjustmentDate: adjustmentDate, warehouseId: warehouseId, referenceNo: referenceNo, reason: reason };
                    const saveRes = await fetch('@Url.Action("UpdateHeaderJson", "StockAdjustments")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                        body: JSON.stringify(saveDto)
                    });
                    if (!saveRes.ok) {
                        const errTxt = await saveRes.text();
                        showToast('تعذر حفظ التعديلات: ' + errTxt, 'danger');
                        btnPost.disabled = false; btnPost.innerHTML = oldHtml;
                        return;
                    }
                    const saveResult = await saveRes.json();
                    if (!saveResult || !saveResult.ok) {
                        showToast((saveResult && saveResult.message) ? saveResult.message : 'تعذر حفظ التعديلات قبل الترحيل.', 'danger');
                        btnPost.disabled = false; btnPost.innerHTML = oldHtml;
                        return;
                    }
                }
                showToast('جاري الترحيل...', 'muted');

                const response = await fetch(`@Url.Action("PostAdjustment", "StockAdjustments")?id=${adjustmentId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    showToast('خطأ: ' + errorText, 'danger');
                    btnPost.disabled = false;
                    btnPost.innerHTML = oldHtml;
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    setAdjustmentPosted(true);
                    applyPostedUiLock();
                    var statusDisplay = document.getElementById('AdjustmentStatusDisplay');
                    if (statusDisplay) statusDisplay.value = 'مترحلة';
                    var btnOpen = document.getElementById('btnOpenAdjustment');
                    if (btnOpen) btnOpen.disabled = false;
                    btnPost.innerHTML = '✅ تم ترحيل التسوية';
                    btnPost.disabled = true;
                    showToast(result.message || 'تم الترحيل بنجاح.', 'success');
                } else {
                    showToast(result.message || 'حدث خطأ أثناء الترحيل.', 'danger');
                    btnPost.disabled = false;
                    btnPost.innerHTML = oldHtml;
                }
            } catch (error) {
                console.error('Error posting adjustment:', error);
                showToast('حدث خطأ أثناء الترحيل.', 'danger');
                btnPost.disabled = false;
                btnPost.innerHTML = oldHtml;
            }
        });

        // Open adjustment
        document.getElementById('btnOpenAdjustment')?.addEventListener('click', async function() {
            const adjustmentId = parseInt(document.getElementById('AdjustmentId').value || '0', 10);
            if (!adjustmentId || adjustmentId <= 0) {
                alert('لا توجد تسوية لفتحها.');
                return;
            }

            if (!confirm('هل أنت متأكد من فتح هذه التسوية؟')) return;

            const token = getAntiForgeryToken();
            this.disabled = true;

            try {
                const response = await fetch(`@Url.Action("OpenAdjustment", "StockAdjustments")?id=${adjustmentId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (!response.ok) {
                    alert('حدث خطأ أثناء فتح التسوية.');
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    setAdjustmentPosted(false);
                    applyPostedUiLock();
                    var statusDisplay = document.getElementById('AdjustmentStatusDisplay');
                    if (statusDisplay) statusDisplay.value = 'مسودة';
                    var btnPost = document.getElementById('btnPostAdjustment');
                    if (btnPost) { btnPost.disabled = false; btnPost.innerHTML = '📤 ترحيل التسوية'; }
                    var btnOpen = document.getElementById('btnOpenAdjustment');
                    if (btnOpen) btnOpen.disabled = true;
                    showToast('تم فتح التسوية بنجاح.', 'success');
                } else {
                    showToast(result.message || 'حدث خطأ أثناء فتح التسوية.', 'danger');
                }
            } catch (error) {
                console.error('Error opening adjustment:', error);
                alert('حدث خطأ أثناء فتح التسوية.');
            } finally {
                this.disabled = false;
            }
        });

        // Clear lines
        document.getElementById('btnClearAdjustmentLines')?.addEventListener('click', async function() {
            if (typeof isAdjustmentPosted === 'function' && isAdjustmentPosted()) return;
            const adjustmentId = parseInt(document.getElementById('AdjustmentId').value || '0', 10);
            if (!adjustmentId || adjustmentId <= 0) {
                alert('لا توجد تسوية لمسح سطورها.');
                return;
            }

            if (!confirm('هل أنت متأكد من مسح كل سطور التسوية؟')) return;

            const token = getAntiForgeryToken();
            this.disabled = true;

            try {
                const response = await fetch(`@Url.Action("ClearLinesJson", "StockAdjustments")?id=${adjustmentId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (!response.ok) {
                    alert('حدث خطأ أثناء مسح السطور.');
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    showToast('تم مسح السطور بنجاح.', 'success');
                    window.location.reload();
                } else {
                    showToast(result.message || 'حدث خطأ أثناء مسح السطور.', 'danger');
                }
            } catch (error) {
                console.error('Error clearing lines:', error);
                alert('حدث خطأ أثناء مسح السطور.');
            } finally {
                this.disabled = false;
            }
        });

        // Navigation
        document.getElementById('btnFirstAdjustment')?.addEventListener('click', function() {
            const firstId = @(ViewBag.NavFirstId ?? 0);
            if (firstId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + firstId + '?frame=1');
        });

        document.getElementById('btnPrevAdjustment')?.addEventListener('click', function() {
            const prevId = @(ViewBag.NavPrevId ?? 0);
            if (prevId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + prevId + '?frame=1');
        });

        document.getElementById('btnNextAdjustment')?.addEventListener('click', function() {
            const nextId = @(ViewBag.NavNextId ?? 0);
            if (nextId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + nextId + '?frame=1');
        });

        document.getElementById('btnLastAdjustment')?.addEventListener('click', function() {
            const lastId = @(ViewBag.NavLastId ?? 0);
            if (lastId > 0) navigateAdjustmentTab('@Url.Action("Show", "StockAdjustments")/' + lastId + '?frame=1');
        });

        // حركة الصنف + تعديل الصنف (مثل فاتورة المبيعات)
        (function() {
            function getCurrentProdId() {
                var pid = document.getElementById('ProdId');
                if (pid && pid.value && pid.value.trim() !== '') return pid.value.trim();
                var code = document.getElementById('ProdCodeInput');
                if (code && code.value && code.value.trim() !== '') return code.value.trim();
                return '';
            }
            function openTabFromFrame(url, tabId, title) {
                try {
                    if (window.top && window.top !== window) {
                        window.top.postMessage({ type: 'erp-open-tab', tabId: tabId || '', title: title || '', url: url }, '*');
                        return;
                    }
                } catch (e) { console.error(e); }
                if (window.erpTabs && typeof window.erpTabs.openTab === 'function') {
                    window.erpTabs.openTab(tabId, url, title);
                } else {
                    window.location.href = url;
                }
            }
            var editBaseUrl = '@Url.Action("Edit", "Products")';
            var movementBaseUrl = '@Url.Action("Show", "Products")';
            function buildEditUrl(id) {
                var base = editBaseUrl.replace(/\/$/, '');
                return base + '/' + encodeURIComponent(id) + '?frame=1';
            }
            function buildMovementUrl(id) {
                var sep = movementBaseUrl.indexOf('?') >= 0 ? '&' : '?';
                return movementBaseUrl + sep + 'prodId=' + encodeURIComponent(id) + '&frame=1';
            }
            var btnEdit = document.getElementById('btnOpenProductEdit');
            var btnMovement = document.getElementById('btnOpenProductMovement');
            if (btnEdit && !btnEdit.dataset.boundEdit) {
                btnEdit.dataset.boundEdit = '1';
                btnEdit.addEventListener('click', function(e) {
                    e.preventDefault();
                    var id = getCurrentProdId();
                    if (!id) { showToast('من فضلك اختر صنفاً أولاً.', 'warning'); document.getElementById('ProdNameInput')?.focus(); return; }
                    openTabFromFrame(buildEditUrl(id), 'prod-edit-' + id, 'تعديل الصنف');
                });
            }
            if (btnMovement && !btnMovement.dataset.boundMove) {
                btnMovement.dataset.boundMove = '1';
                btnMovement.addEventListener('click', function(e) {
                    e.preventDefault();
                    var id = getCurrentProdId();
                    if (!id) { showToast('من فضلك اختر صنفاً أولاً.', 'warning'); document.getElementById('ProdNameInput')?.focus(); return; }
                    openTabFromFrame(buildMovementUrl(id), 'product-movement-tab', 'حركة الصنف');
                });
            }
        })();
    </script>
}
