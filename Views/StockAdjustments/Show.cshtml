@model ERP.Models.StockAdjustment

@{
    ViewData["Title"] = Model.Id == 0
        ? "تسوية جرد جديدة"
        : $"تسوية جرد — رقم {Model.Id}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/invoice-cards.css" />
    <style>
        /* ===== تنسيق تسوية الجرد مثل فاتورة المبيعات ===== */
        .adjustment-page {
            background-color: #f3f6fb;
            min-height: 100vh;
            padding-bottom: 2rem;
        }
        .adjustment-page .container-fluid { padding: 0; max-width: 100%; }
        .adjustment-page .row.g-3 { align-items: flex-start !important; }
        .adjustment-page .col-lg-2.order-1.order-lg-2 {
            padding: 0.5rem 0.5rem;
            align-self: flex-start;
            position: sticky !important;
            top: 70px;
            z-index: 1020;
            height: fit-content;
            margin-top: 0 !important;
        }
        .adjustment-page .col-lg-10.order-2 { margin-top: 0 !important; padding-top: 0 !important; }
        .adjustment-page .adjustment-header-card { margin-top: 0 !important; }
        html.in-frame .adjustment-page .col-lg-2.order-1.order-lg-2 { top: 0.5rem; }

        /* كارت الإجراءات الجانبي — نفس فاتورة المبيعات */
        .adjustment-page .invoice-side-card {
            background: #ffffff !important;
            min-width: 220px;
            position: relative;
        }
        .adjustment-page .invoice-side-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            border-bottom: none;
            padding: 0.55rem 1rem;
        }
        .adjustment-page .invoice-side-card .invoice-actions-bar hr { display: none !important; }
        .adjustment-page .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
            border: 1px solid #64748b !important;
            border-radius: 8px;
        }
        .adjustment-page .invoice-side-card .btn-erp + .btn-erp,
        .adjustment-page .invoice-side-card .invoice-actions-bar > div + div { margin-top: 0.25rem; }
        .adjustment-page .invoice-actions-sticky {
            position: sticky;
            top: 58px;
            z-index: 3000;
            background: #ffffff !important;
            border: 1px solid #6366f1 !important;
            padding: 10px 10px !important;
            border-radius: 12px;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
        }
        .adjustment-page .invoice-side-card .form-control {
            background: #fff;
            border-color: #64748b;
            color: #0f172a;
        }

        /* العمود الرئيسي */
        .adjustment-page .col-lg-10.order-2 {
            background: transparent;
            padding: 0.5rem 1rem;
        }

        /* كتلة واحدة — حاوية الجسم شفافة بدون صندوق (docs/فتح الفواتير ككتلة واحدة.md) */
        #SA_BodyHost,
        .adjustment-page div#SA_BodyHost {
            display: block !important;
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            outline: none !important;
            padding: 0 !important;
        }
        .adjustment-page .container-fluid,
        .adjustment-page .row {
            border: none !important;
            box-shadow: none !important;
        }

        /* قائمة نوع الطباعة — نفس فاتورة المبيعات */
        .adjustment-page .si-print-dropdown-menu {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 8px 28px rgba(99, 102, 241, 0.22) !important;
            padding: 0.35rem 0 !important;
            margin-top: 0.35rem !important;
            overflow: hidden;
            min-width: 100%;
        }
        .adjustment-page .si-print-dropdown-header {
            font-weight: 600;
            color: #475569 !important;
            letter-spacing: 0.02em;
        }
        .adjustment-page .si-print-dropdown-item {
            display: flex !important;
            align-items: center;
            gap: 0.65rem;
            padding: 0.55rem 1rem !important;
            font-size: 0.9rem;
            font-weight: 500;
            color: #0f172a !important;
            border-radius: 0 !important;
            transition: background-color 0.15s ease, color 0.15s ease;
        }
        .adjustment-page .si-print-dropdown-item:hover,
        .adjustment-page .si-print-dropdown-item:focus {
            background: linear-gradient(90deg, rgba(99, 102, 241, 0.12) 0%, rgba(14, 165, 233, 0.1) 100%) !important;
            color: #312e81 !important;
        }
        .adjustment-page .si-print-opt-icon {
            font-size: 1.15rem;
            line-height: 1;
            flex-shrink: 0;
            opacity: 0.92;
        }
        .adjustment-page .si-print-opt-text {
            flex: 1;
            text-align: right;
        }
        .adjustment-page .si-print-dropdown-btn.dropdown-toggle::after {
            margin-inline-start: 0.35rem;
        }

        /* الكروت الرئيسية — خلفية بيضاء، زوايا مستديرة، حدود */
        .adjustment-header-card,
        .adjustment-add-card,
        .adjustment-lines-card,
        .adjustment-totals-card {
            border-radius: 1rem;
            overflow: hidden;
            background: #ffffff !important;
        }
        .adjustment-card-line { display: none; }
        .adjustment-header-card .card-body,
        .adjustment-add-card .card-body,
        .adjustment-totals-card .card-body { padding: 1rem 1.25rem !important; }
        .adjustment-lines-card .card-body { padding: 0 !important; }

        /* حدود وحجم حاوية جدول السطور مثل فاتورة المبيعات */
        .adjustment-page .adjustment-lines-card .erp-table-wrapper,
        .adjustment-page .adjustment-lines-table-wrap {
            border: none;
            border-radius: 0;
            max-height: 360px;
            overflow: auto;
        }
        .adjustment-page .adjustment-lines-card {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
        }
        /* جدول السطور — نفس ألوان جدول طلب الشراء (هيدر رمادي فاتح + حدود + أرضية بيضاء) */
        .adjustment-page .adjustment-lines-card .erp-table thead th {
            background-color: #e2e8f0 !important;
            color: #0f172a !important;
            font-weight: 600;
            padding: 0.5rem 0.55rem;
            border: 1px solid #cbd5e1 !important;
        }
        .adjustment-page .adjustment-lines-card .erp-table tbody tr,
        .adjustment-page .adjustment-lines-card .erp-table tbody td,
        .adjustment-page .adjustment-lines-card .erp-table tbody tr:nth-of-type(odd) td {
            background-color: #fff !important;
        }
        .adjustment-page .adjustment-lines-card .erp-table tbody tr:hover td {
            background-color: #f8fafc !important;
        }
        .adjustment-page .adjustment-lines-card .erp-table tbody tr.erp-list-selectable-row {
            cursor: pointer;
        }
        .adjustment-page .adjustment-lines-card .erp-table tbody tr.erp-sa-row-selected td {
            background-color: rgba(99, 102, 241, 0.12) !important;
        }
        .adjustment-page .adjustment-lines-card .erp-table tbody td,
        .adjustment-page .adjustment-lines-card .erp-table tbody th {
            color: #0f172a !important;
            border: 1px solid #e2e8f0 !important;
        }

        /* حدود الانبوتات والتسميات مثل فاتورة المبيعات */
        .adjustment-page .adjustment-header-card .form-control,
        .adjustment-page .adjustment-header-card .form-select,
        .adjustment-page .adjustment-add-card .form-control,
        .adjustment-page .adjustment-add-card .form-select,
        .adjustment-page .adjustment-totals-card .form-control {
            border-color: #64748b !important;
            border-radius: 8px;
        }
        .adjustment-page .adjustment-header-card .card-body .form-label,
        .adjustment-page .adjustment-header-card .card-body label,
        .adjustment-page .adjustment-add-card .card-body .form-label,
        .adjustment-page .adjustment-add-card .card-body label,
        .adjustment-page .adjustment-totals-card .card-body .form-label {
            color: #0f172a !important;
            font-weight: 500;
        }
        .adjustment-page .adjustment-header-card .card-body .form-control,
        .adjustment-page .adjustment-header-card .card-body .form-select,
        .adjustment-page .adjustment-add-card .card-body .form-control,
        .adjustment-page .adjustment-add-card .card-body .form-select {
            color: #020617 !important;
        }

        /* حقول التاريخ والوقت */
        input[type="date"],
        input[type="datetime-local"],
        input[type="time"] { direction: ltr !important; text-align: left !important; }
        input[type="date"]::-webkit-calendar-picker-indicator,
        input[type="datetime-local"]::-webkit-calendar-picker-indicator { cursor: pointer; }

        /* سعر الجمهور — فتح بالضغط على اللابل */
        .adjustment-price-label-unlock { cursor: pointer; }
        .adjustment-price-label-unlock:hover { text-decoration: underline; }

        /* ===== بوكس اسم الصنف — نفس فاتورة المبيعات (wrapper + قائمة مخصصة) ===== */
        #SA_BodyHost .adjustment-add-card #ProdNameInput.pi-product-name-input,
        #SA_BodyHost .adjustment-add-card #ProdNameInput,
        #SA_BodyHost .adjustment-add-card input#ProdNameInput {
            border: 0 !important;
            border-radius: 0.55rem;
            background: transparent !important;
        }
        #SA_BodyHost .adjustment-add-card #ProdNameInput:focus,
        #SA_BodyHost .adjustment-add-card input#ProdNameInput:focus {
            border-color: #4338ca !important;
            box-shadow: none !important;
        }
        #SA_BodyHost .adjustment-add-card #productDropdownWrap {
            border: 2px solid #6366f1 !important;
            border-radius: 0.55rem !important;
            padding: 3px !important;
            box-shadow: 0 1px 3px rgba(99, 102, 241, 0.25);
        }
        #SA_BodyHost .adjustment-add-card #productDropdownWrap:focus-within {
            border-color: #4338ca !important;
            box-shadow: none !important;
        }
        #SA_BodyHost .adjustment-add-card .product-dropdown-onebox {
            border: 0 !important;
            background: transparent !important;
            border-radius: 0.45rem !important;
        }
        #SA_BodyHost .adjustment-add-card .product-dropdown-onebox:focus-within {
            box-shadow: none !important;
            border-color: transparent !important;
        }
        .adjustment-page .product-dropdown-onebox {
            position: relative;
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
            background: #fff;
        }
        .adjustment-page .product-dropdown-arrow-inside {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #495057;
            cursor: pointer;
            user-select: none;
            font-size: 0.6rem;
            z-index: 1;
        }
        .adjustment-page .product-dropdown-arrow-inside:hover {
            background-color: #e9ecef;
        }
        .adjustment-page .product-dropdown-onebox .product-dropdown-input {
            width: 100%;
            border: none !important;
            background: transparent !important;
            padding-left: 2.25rem !important;
        }
        .adjustment-page .product-dropdown-onebox .product-dropdown-input:focus {
            box-shadow: none !important;
            outline: none !important;
        }
        .adjustment-page .product-dropdown-onebox:focus-within {
            border-color: #0d6efd !important;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
        }
        .adjustment-page .product-dropdown-list {
            position: fixed;
            max-height: 220px;
            min-height: 40px;
            overflow-y: auto;
            z-index: 9999;
            margin-top: 2px;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            background: #fff;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        }
        .adjustment-page .product-dropdown-list[data-open="false"] {
            display: none !important;
        }
        .adjustment-page .product-dropdown-list[data-open="true"] {
            display: block !important;
        }
        #SA_BodyHost .adjustment-add-card .card-body {
            overflow: visible !important;
        }
        .adjustment-page .product-dropdown-item {
            cursor: pointer;
            border-bottom: 1px solid #f0f0f0;
        }
        .adjustment-page .product-dropdown-item:hover {
            background-color: #f8f9fa;
        }
        .adjustment-page .product-dropdown-item:last-child {
            border-bottom: none;
        }
        .adjustment-page .product-dropdown-item-active {
            background-color: #0d6efd !important;
            color: #fff !important;
        }

        /* لوحة قائمة التشغيلات — تظهر عند النقر على حقل التشغيلة */
        #batchDropdownPanel.dropdown-menu { display: none; padding: 0; min-width: 100%; }
        #batchDropdownPanel.d-none { display: none !important; }
        #batchDropdownPanel:not(.d-none) { display: block !important; }
        #batchDropdownList .dropdown-item:hover { background-color: #e9ecef; }
        #BatchDropdownToggle { inset-inline-end: 4px; left: auto; right: auto; }

        /* كارت الإجماليات — بوكسات ملخصة مثل فاتورة المبيعات */
        .adjustment-page .adjustment-totals-card .invoice-summary-box {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 0.5rem 0.75rem;
        }
        .adjustment-page .adjustment-totals-card .invoice-summary-label {
            color: #64748b;
            font-size: 0.8rem;
        }
        .adjustment-page .adjustment-totals-card .invoice-summary-value {
            color: #0f172a;
            font-weight: 600;
        }

        /* رسالة مركزية — أخطاء الترحيل والعمليات (بدل سكربت الخادم الطويل) */
        .erp-sa-center-modal {
            position: fixed;
            inset: 0;
            z-index: 10050;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .erp-sa-center-modal.d-none { display: none !important; }
        .erp-sa-center-modal-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(15, 23, 42, 0.55);
            backdrop-filter: blur(3px);
        }
        .erp-sa-center-modal-dialog {
            position: relative;
            z-index: 1;
            max-width: 440px;
            width: 100%;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid #6366f1;
            box-shadow: 0 16px 48px rgba(0, 0, 0, 0.22);
        }
        .erp-sa-center-modal-dialog .card-header.erp-sa-cm-h-danger {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            border: 0;
        }
        .erp-sa-center-modal-dialog .card-header.erp-sa-cm-h-success {
            background: linear-gradient(135deg, #059669, #047857);
            border: 0;
        }
        .erp-sa-center-modal-dialog .card-header.erp-sa-cm-h-warn {
            background: linear-gradient(135deg, #d97706, #b45309);
            border: 0;
        }
    </style>
}

<div class="adjustment-page" dir="rtl">
    @* حاوية رسائل الترحيل والعمليات (بوب أب خارج الكارت — مثل فاتورة المبيعات) *@
    <div id="adjustmentToastContainer" class="position-fixed top-0 start-50 translate-middle-x p-2" style="z-index: 9999; margin-top: 60px;" aria-live="polite"></div>

    @* رسالة في منتصف الشاشة (أخطاء ورسائل طويلة) *@
    <div id="erpSaCenterModal" class="erp-sa-center-modal d-none" role="alertdialog" aria-modal="true" aria-labelledby="erpSaCenterModalTitle">
        <div class="erp-sa-center-modal-backdrop" id="erpSaCenterModalBackdrop"></div>
        <div class="erp-sa-center-modal-dialog card shadow border-0">
            <div id="erpSaCenterModalHeader" class="card-header py-2 text-white text-center fw-bold erp-sa-cm-h-danger">تنبيه</div>
            <div class="card-body py-3 px-4 text-center">
                <p id="erpSaCenterModalBody" class="mb-0 text-dark" style="line-height: 1.75; font-size: 0.95rem;"></p>
            </div>
            <div class="card-footer bg-transparent border-0 text-center pb-3 pt-0">
                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm px-4" id="erpSaCenterModalBtn">حسناً</button>
            </div>
        </div>
    </div>

    <div class="container-fluid pt-0">
        <form id="__AntiForgeryForm" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>

        <div class="row g-3 align-items-start">
            @* العمود الجانبي *@
            <div class="col-12 col-lg-2 order-1 order-lg-2">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات تسوية الجرد</h6>
                    </div>

                    <input type="hidden" id="AdjustmentId" value="@Model.Id" />
                    <input type="hidden" id="AdjustmentIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />

                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">
                        @{
                            int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
                            int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
                            int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
                            int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;

                            int currentId = Model?.Id ?? 0;
                            bool hasAny = navFirst.HasValue && navLast.HasValue && navFirst.Value > 0 && navLast.Value > 0;
                            int? prevEffective = (currentId == 0) ? navLast : navPrev;
                            int? nextEffective = (currentId == 0) ? navFirst : navNext;
                            bool canFirst = hasAny && navFirst.HasValue && navFirst.Value > 0 && navFirst.Value != currentId;
                            bool canLast = hasAny && navLast.HasValue && navLast.Value > 0 && navLast.Value != currentId;
                            bool canPrev = hasAny && prevEffective.HasValue && prevEffective.Value > 0 && prevEffective.Value != currentId;
                            bool canNext = hasAny && nextEffective.HasValue && nextEffective.Value > 0 && nextEffective.Value != currentId;
                        }

                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button"
                                    id="btnFirstAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="أول تسوية"
                                    @(canFirst ? "" : "disabled")>
                                ⏮
                            </button>

                            <button type="button"
                                    id="btnPrevAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="التسوية السابقة"
                                    @(canPrev ? "" : "disabled")>
                                ◀
                            </button>

                            <button type="button"
                                    id="btnNextAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="التسوية التالية"
                                    @(canNext ? "" : "disabled")>
                                ▶
                            </button>

                            <button type="button"
                                    id="btnLastAdjustment"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    title="آخر تسوية"
                                    @(canLast ? "" : "disabled")>
                                ⏭
                            </button>
                        </div>

                        <hr class="my-1" />

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           href="@Url.Action("Show", "StockAdjustments", new { id = 0, frame = 1 })"
                           data-tab-id="stock-adjustment-create"
                           data-tab-title="تسوية جردية"
                           data-url="@Url.Action("Show", "StockAdjustments", new { id = 0, frame = 1 })">
                            ➕ تسوية جديدة
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnSaveAdjustmentHeader"
                                data-lock-posted="1">
                            💾 حفظ التسوية
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnPostAdjustment"
                                data-lock-posted="1">
                            📤 ترحيل التسوية
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnOpenAdjustment">
                            ⏪ فتح التسوية
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnClearAdjustmentLines"
                                data-lock-posted="1">
                            🗑️ مسح كل السطور
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm w-100"
                                id="btnDeleteSelectedAdjustmentLine"
                                disabled
                                title="اختر سطراً من الجدول ثم اضغط للحذف">
                            🗑️ مسح السطر المحدد
                        </button>

                        <div>
                            <button type="button" id="btnOpenProductMovement" class="btn btn-erp btn-erp-outline-secondary btn-erp-sm w-100">
                                📊 حركة الصنف
                            </button>
                        </div>
                        <div>
                            <button type="button" id="btnOpenProductEdit" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100">
                                ✏️ تعديل الصنف
                            </button>
                        </div>

                        @* طباعة — نفس نظام فاتورة المبيعات (قائمة منسدلة) *@
                        <div class="dropdown w-100 si-print-dropdown">
                            <button type="button" id="btnPrintStockAdjustmentDropdown"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100 dropdown-toggle si-print-dropdown-btn"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                🖨️ طباعة التسوية
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end w-100 si-print-dropdown-menu" aria-labelledby="btnPrintStockAdjustmentDropdown">
                                <li class="si-print-dropdown-header px-3 py-2 small text-muted border-bottom mb-0">اختر نوع الطباعة</li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-sa-print-mode="1"><span class="si-print-opt-icon" aria-hidden="true">📄</span><span class="si-print-opt-text">طباعة صفحة واحدة</span></a></li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-sa-print-mode="2"><span class="si-print-opt-icon" aria-hidden="true">📑</span><span class="si-print-opt-text">طباعة أصل وصورة</span></a></li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-sa-print-mode="3"><span class="si-print-opt-icon" aria-hidden="true">📚</span><span class="si-print-opt-text">طباعة أصل وصورتين</span></a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            @* العمود الرئيسي *@
            <div class="col-12 col-lg-10 order-2 order-lg-1">
                <div id="SA_BodyHost">
                @* كارت بيانات التسوية *@
                <div class="card shadow-sm mb-2 adjustment-header-card">
                    <div class="adjustment-header-bar">
                        <h5 class="mb-0">تسوية جرد</h5>
                    </div>

                    <div>
                        <div class="card-body">
                            <div class="row g-3 align-items-end">
                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">رقم التسوية</label>
                                    <input id="AdjustmentNumberDisplay" class="form-control form-control-sm text-center" value="@(Model.Id > 0 ? Model.Id.ToString() : "")" readonly />
                                </div>

                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">تاريخ التسوية</label>
                                    <input id="AdjustmentDateInput" type="date" class="form-control form-control-sm" value="@Model.AdjustmentDate.ToString("yyyy-MM-dd")" data-lock-posted="1" dir="ltr" style="text-align: left;" />
                                </div>

                                <div class="col-lg-4">
                                    <label class="form-label form-label-sm">المخزن</label>
                                    <select asp-for="WarehouseId" asp-items="ViewBag.Warehouses" class="form-select form-select-sm" data-lock-posted="1">
                                        <option value="">اختر المخزن</option>
                                    </select>
                                </div>

                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">الحالة</label>
                                    <input id="AdjustmentStatusDisplay" class="form-control form-control-sm text-center" value="@(string.IsNullOrWhiteSpace(Model.Status) ? "مسودة" : Model.Status)" readonly />
                                </div>
                            </div>
                            <input type="hidden" asp-for="ReferenceNo" id="ReferenceNoHidden" />

                            @* الملاحظات مُزالة من الواجهة — القيمة محفوظة في الهيدر عند الحفظ *@
                            <input type="hidden" name="Reason" id="ReasonHidden" value="@(Model?.Reason ?? "")" />
                        </div>
                    </div>
                </div>

                @* كارت إدخال السطر *@
                <div class="card shadow-sm mb-2 adjustment-add-card">
                    <div class="adjustment-card-line"></div>
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">كود الصنف</label>
                                <input type="number" id="ProdCodeInput" class="form-control form-control-sm text-center" placeholder="بحث بالكود..." data-lock-posted="1" />
                            </div>

                            <div class="col-lg-5">
                                <label class="form-label form-label-sm">اسم الصنف</label>
                                <div class="position-relative" id="productDropdownWrap">
                                    <div class="product-dropdown-onebox" id="productDropdownInputGroup">
                                        <span class="product-dropdown-arrow-inside" id="productDropdownArrow" title="افتح القائمة">▼</span>
                                        <input id="ProdNameInput"
                                               type="text"
                                               class="form-control form-control-sm pi-product-name-input product-dropdown-input"
                                               placeholder="اختر صنف..."
                                               autocomplete="off"
                                               data-lock-posted="1" />
                                    </div>
                                    <div id="productDropdownList" class="product-dropdown-list" role="listbox" data-open="false"></div>
                                </div>
                                <input type="hidden" id="ProdId" />
                            </div>

                            <div class="col-lg-1 col-md-2 position-relative">
                                <label class="form-label form-label-sm">التشغيلة</label>
                                <div class="d-flex align-items-center position-relative">
                                    <input type="text" id="BatchNoInput" class="form-control form-control-sm text-center flex-grow-1" autocomplete="off" data-lock-posted="1" />
                                    <span id="BatchDropdownToggle" class="position-absolute px-2 text-muted" style="left: 4px; top: 50%; transform: translateY(-50%); cursor: pointer; pointer-events: none;" aria-hidden="true">▼</span>
