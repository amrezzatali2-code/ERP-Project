                @* جدول السطور *@
                <div class="card shadow-sm mb-2 adjustment-lines-card">
                    <div class="adjustment-card-line"></div>
                    <div class="card-body p-0">
                        <div class="erp-table-wrapper adjustment-lines-table-wrap">
                            <table class="table table-sm table-striped table-hover mb-0 erp-table">
                                <thead>
                                    <tr>
                                        <th class="text-center no-print" style="width:2.5rem" title="تحديد">◻</th>
                                        <th class="text-center">#</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">التشغيلة</th>
                                        <th class="text-center">الصلاحية</th>
                                        <th class="text-center">الكمية قبل</th>
                                        <th class="text-center">الكمية بعد</th>
                                        <th class="text-center">الفرق</th>
                                        <th class="text-center">تكلفة الوحدة</th>
                                        <th class="text-center">الخصم المرجح %</th>
                                        <th class="text-center">سعر الجمهور</th>
                                        <th class="text-center">فرق التكلفة</th>
                                    </tr>
                                </thead>
                                <tbody id="AdjustmentLinesTbody">
                                    @if (Model.Lines != null && Model.Lines.Any())
                                    {
                                        int lineNo = 1;
                                        foreach (var line in Model.Lines.OrderBy(l => l.Id))
                                        {
                                            <tr class="erp-list-selectable-row" data-line-id="@line.Id" data-product-id="@line.ProductId">
