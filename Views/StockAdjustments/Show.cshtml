                                <span id="AdjustmentTotalQtyBeforeValue" class="invoice-summary-value">@(Model.Lines?.Sum(l => l.QtyBefore) ?? 0)</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">إجمالي الكمية بعد</span>
                                <span id="AdjustmentTotalQtyAfterValue" class="invoice-summary-value">@(Model.Lines?.Sum(l => l.QtyAfter) ?? 0)</span>
