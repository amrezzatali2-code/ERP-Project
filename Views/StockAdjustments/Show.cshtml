        // دالة إضافة صف للجدول أو تحديثه
        function upsertAdjustmentRow(result, lineNo) {
            const tbody = document.getElementById('AdjustmentLinesTbody');
            const placeholder = tbody.querySelector('tr td[colspan="12"]');
            if (placeholder) placeholder.closest('tr').remove();

            const existingRow = tbody.querySelector(`tr[data-line-id="${result.lineId}"]`);
            const costStr = result.costPerUnit != null ? parseFloat(result.costPerUnit).toFixed(4) : '-';
            const costDiffStr = result.costDiff != null ? parseFloat(result.costDiff).toFixed(2) : '-';
            const wdStr = result.weightedDiscountPct != null ? parseFloat(result.weightedDiscountPct).toFixed(2) : '-';
            const prStr = result.priceRetail != null ? parseFloat(result.priceRetail).toFixed(2) : '-';
            const rowHtml = `<tr class="erp-list-selectable-row" data-line-id="${result.lineId}" data-product-id="${result.productId != null ? result.productId : ''}">
                <td class="text-center no-print"></td>
                <td class="text-center">${lineNo}</td>
                <td>${escapeHtml(result.productName)}</td>
                <td class="text-center">${escapeHtml(result.batchNo)}</td>
                <td class="text-center">${escapeHtml(result.expiryDisplay)}</td>
                <td class="text-center">${result.qtyBefore}</td>
                <td class="text-center">${result.qtyAfter}</td>
                <td class="text-center">${result.qtyDiff}</td>
                <td class="text-center">${costStr}</td>
                <td class="text-center">${wdStr}</td>
                <td class="text-center">${prStr}</td>
                <td class="text-center">${costDiffStr}</td>
            </tr>`;

            if (existingRow) {
                existingRow.outerHTML = rowHtml;
            } else {
                tbody.insertAdjacentHTML('beforeend', rowHtml);
            }
            if (tbody.querySelectorAll('tr').length === 0) {
                tbody.innerHTML = '<tr><td colspan="12" class="text-center text-muted py-4">لا توجد سطور بعد.</td></tr>';
            }
        }
        function escapeHtml(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

        // تحديث كارت الإجماليات من جدول السطور
        function updateAdjustmentTotalsCard() {
            var tbody = document.getElementById('AdjustmentLinesTbody');
            var rows = tbody ? tbody.querySelectorAll('tr[data-line-id]') : [];
            var totalLines = rows.length;
            var totalQtyBefore = 0, totalQtyAfter = 0, totalCostDiff = 0;
            for (var i = 0; i < rows.length; i++) {
                var cells = rows[i].cells;
                if (cells.length >= 12) {
                    totalQtyBefore += parseInt(cells[5].textContent || '0', 10);
                    totalQtyAfter += parseInt(cells[6].textContent || '0', 10);
                    var costDiffText = (cells[11].textContent || '0').replace(',', '.');
                    totalCostDiff += parseFloat(costDiffText) || 0;
                }
            }
            var elLines = document.getElementById('AdjustmentTotalLinesValue');
            var elBefore = document.getElementById('AdjustmentTotalQtyBeforeValue');
            var elAfter = document.getElementById('AdjustmentTotalQtyAfterValue');
            var elCostDiff = document.getElementById('AdjustmentTotalCostDiffValue');
            if (elLines) elLines.textContent = totalLines;
            if (elBefore) elBefore.textContent = totalQtyBefore;
            if (elAfter) elAfter.textContent = totalQtyAfter;
            if (elCostDiff) elCostDiff.textContent = totalCostDiff.toFixed(2);
        }

        // Add line
        async function doAddAdjustmentLine() {
            if (typeof isAdjustmentPosted === 'function' && isAdjustmentPosted()) return;
            const adjustmentId = parseInt(document.getElementById('AdjustmentId').value || '0', 10);
            if (!adjustmentId || adjustmentId <= 0) {
                alert('لا يمكن إضافة سطور قبل حفظ التسوية. اضغط "حفظ التسوية" أولاً.');
                return;
            }

            const prodId = parseInt(document.getElementById('ProdId').value || '0', 10);
            const qtyBefore = parseInt(document.getElementById('QtyBeforeInput').value || '0', 10);
            const qtyAfter = parseInt(document.getElementById('QtyAfterInput').value || '0', 10);
            const batchNo = document.getElementById('BatchNoInput').value?.trim() || '';
            var expIn = document.getElementById('ExpiryInput');
            if (expIn && expIn.value && typeof formatExpiryWithSlash === 'function')
                expIn.value = formatExpiryWithSlash(expIn.value);
            const expiry = getExpiryForApi();
            const costPerUnit = parseFloat(document.getElementById('CostPerUnitInput').value || '0');
            const priceRetail = parseFloat(document.getElementById('PriceRetailInput').value || '0');
            const weightedDiscountPct = parseFloat(document.getElementById('WeightedDiscountInput').value || '');
            const note = document.getElementById('LineNoteInput').value?.trim() || '';

            if (!prodId || prodId <= 0) {
                alert('من فضلك اختر صنفاً صحيحاً.');
                return;
            }

            if (qtyBefore < 0 || qtyAfter < 0) {
                alert('الكميات يجب أن تكون أكبر من أو تساوي صفر.');
                return;
            }

            const dto = {
                stockAdjustmentId: adjustmentId,
                productId: prodId,
                batchNo: batchNo || null,
                expiry: expiry || null,
                priceRetail: isNaN(priceRetail) ? null : priceRetail,
                weightedDiscountPct: isNaN(weightedDiscountPct) ? null : weightedDiscountPct,
                qtyBefore: qtyBefore,
                qtyAfter: qtyAfter,
                costPerUnit: costPerUnit || null,
                note: note
            };

            const token = getAntiForgeryToken();
            const btn = document.getElementById('btnAddAdjustmentLine');
            btn.disabled = true;

            try {
                const response = await fetch('@Url.Action("AddLineJson", "StockAdjustments")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(dto)
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    alert('حدث خطأ أثناء إضافة السطر: ' + errorText);
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    const tbody = document.getElementById('AdjustmentLinesTbody');
                    const currentRows = tbody.querySelectorAll('tr[data-line-id]');
                    let lineNo;
                    if (result.isUpdate) {
                        const existingRow = tbody.querySelector(`tr[data-line-id="${result.lineId}"]`);
                        lineNo = existingRow ? parseInt(existingRow.querySelector('td')?.textContent || '1', 10) : currentRows.length + 1;
                    } else {
                        lineNo = currentRows.length + 1;
                    }
                    upsertAdjustmentRow(result, lineNo);
                    updateAdjustmentTotalsCard();
                    clearAddLineFormAndFocus();
                } else {
                    alert(result.message || 'حدث خطأ أثناء إضافة السطر.');
                }
            } catch (error) {
                console.error('Error adding line:', error);
                alert('حدث خطأ أثناء إضافة السطر.');
            } finally {
                btn.disabled = false;
            }
        }

        document.getElementById('btnAddAdjustmentLine')?.addEventListener('click', doAddAdjustmentLine);

        // الانتقال بـ Enter: من التشغيلة → … → الكمية بعد → زر إضافة (يتخطى تكلفة الوحدة وسعر الجمهور والملاحظات)
        const enterNavFields = [
            document.getElementById('BatchNoInput'),
            document.getElementById('ExpiryInput'),
            document.getElementById('QtyAfterInput'),
            document.getElementById('btnAddAdjustmentLine')
        ].filter(Boolean);

        enterNavFields.forEach((el, idx) => {
            if (el.dataset.boundEnterNav === '1') return;
            el.dataset.boundEnterNav = '1';
            el.addEventListener('keydown', async function(e) {
                if (e.key !== 'Enter') return;
                e.preventDefault();
                const next = enterNavFields[idx + 1];
                if (el === document.getElementById('btnAddAdjustmentLine')) {
                    doAddAdjustmentLine();
                } else if (next) {
                    next.focus();
                    if (typeof next.select === 'function') next.select?.();
                }
            });
        });

        ['CostPerUnitInput', 'WeightedDiscountInput', 'PriceRetailInput', 'LineNoteInput'].forEach(function (id) {
            const el = document.getElementById(id);
            if (!el || el.dataset.boundEnterAdd === '1') return;
            el.dataset.boundEnterAdd = '1';
            el.addEventListener('keydown', function (e) {
                if (e.key !== 'Enter') return;
                e.preventDefault();
                doAddAdjustmentLine();
            });
        });

        function refreshDeleteSelectedAdjustmentLineButton() {
            const btn = document.getElementById('btnDeleteSelectedAdjustmentLine');
            if (!btn) return;
            const posted = typeof isAdjustmentPosted === 'function' && isAdjustmentPosted();
            const hasSel = !!document.querySelector('#AdjustmentLinesTbody tr[data-line-id].erp-sa-row-selected');
            btn.disabled = posted || !hasSel;
        }

        /** عند اختيار سطر: تعبئة بوكس الصنف والكود مثل فاتورة المبيعات */
        function fillProductFromAdjustmentLineRow(tr) {
            if (!tr || !tr.cells || tr.cells.length < 3) return;
            var pid = tr.getAttribute('data-product-id');
            if (!pid) return;
            var nameCell = tr.cells[2];
            var name = nameCell ? (nameCell.textContent || '').trim() : '';
            var prodIdEl = document.getElementById('ProdId');
            var codeEl = document.getElementById('ProdCodeInput');
            var nameEl = document.getElementById('ProdNameInput');
            if (prodIdEl) prodIdEl.value = pid;
            if (codeEl) codeEl.value = pid;
            if (nameEl) nameEl.value = name;
            if (typeof loadProductInfo === 'function') loadProductInfo();
        }

        document.getElementById('AdjustmentLinesTbody')?.addEventListener('click', function (e) {
            const tr = e.target.closest('tr[data-line-id]');
            if (!tr) return;
            document.querySelectorAll('#AdjustmentLinesTbody tr.erp-sa-row-selected').forEach(function (r) {
                r.classList.remove('erp-sa-row-selected');
            });
            tr.classList.add('erp-sa-row-selected');
            refreshDeleteSelectedAdjustmentLineButton();
            fillProductFromAdjustmentLineRow(tr);
        });

        async function deleteAdjustmentLineById(lineId) {
            if (!lineId || lineId <= 0) return;
            if (typeof isAdjustmentPosted === 'function' && isAdjustmentPosted()) return;
            let okDel = false;
            if (typeof ERP !== 'undefined' && typeof ERP.showConfirmModal === 'function') {
                okDel = await ERP.showConfirmModal({
                    title: 'حذف سطر',
                    message: 'هل أنت متأكد من حذف هذا السطر من التسوية؟',
                    confirmText: 'حذف',
                    cancelText: 'إلغاء'
                });
            } else {
                okDel = confirm('هل أنت متأكد من حذف هذا السطر؟');
            }
            if (!okDel) return;
            const token = getAntiForgeryToken();
            const btn = document.getElementById('btnDeleteSelectedAdjustmentLine');
            if (btn) btn.disabled = true;
            try {
                const response = await fetch(`@Url.Action("DeleteLineJson", "StockAdjustments")?id=${lineId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });
                if (!response.ok) {
                    alert('حدث خطأ أثناء حذف السطر.');
                    return;
                }
                const result = await response.json();
                if (result.ok) {
                    const row = document.querySelector(`#AdjustmentLinesTbody tr[data-line-id="${lineId}"]`);
                    if (row) row.remove();
                    const tbody = document.getElementById('AdjustmentLinesTbody');
                    if (tbody && tbody.querySelectorAll('tr[data-line-id]').length === 0) {
                        tbody.innerHTML = '<tr><td colspan="12" class="text-center text-muted py-4">لا توجد سطور بعد.</td></tr>';
                    }
                    updateAdjustmentTotalsCard();
                    refreshDeleteSelectedAdjustmentLineButton();
                } else {
                    alert(result.message || 'حدث خطأ أثناء حذف السطر.');
                }
            } catch (error) {
                console.error('Error deleting line:', error);
                alert('حدث خطأ أثناء حذف السطر.');
            } finally {
                refreshDeleteSelectedAdjustmentLineButton();
            }
        }

        document.getElementById('btnDeleteSelectedAdjustmentLine')?.addEventListener('click', async function () {
            const tr = document.querySelector('#AdjustmentLinesTbody tr[data-line-id].erp-sa-row-selected');
            if (!tr) return;
            const lineId = parseInt(tr.getAttribute('data-line-id') || '0', 10);
            await deleteAdjustmentLineById(lineId);
        });

        // Save header (رقم مرجعي مخفي — يُرسل من الحقل المخفي)
