                                                <td class="text-center">@(line.Batch?.BatchNo ?? "-")</td>
                                                <td class="text-center">@(line.Batch?.Expiry.ToString("yyyy-MM-dd") ?? "-")</td>
                                                <td class="text-center">@line.QtyBefore</td>
                                                <td class="text-center">@line.QtyAfter</td>
                                                <td class="text-center">@line.QtyDiff</td>
                                                <td class="text-center">@(line.CostPerUnit?.ToString("0.0000") ?? "-")</td>
                                                <td class="text-center">@(line.WeightedDiscountPct?.ToString("0.00") ?? "-")</td>
                                                <td class="text-center">@(line.PriceRetail?.ToString("0.00") ?? "-")</td>
                                                <td class="text-center">@(line.CostDiff?.ToString("0.00") ?? "-")</td>
                                            </tr>
                                            lineNo++;
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="12" class="text-center text-muted py-4">لا توجد سطور بعد.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @* كارت إجماليات التسوية — بدون هيدر ملون (مثل فاتورة المبيعات) *@
                <div class="card shadow-sm mb-2 adjustment-totals-card">
                    <div class="card-body">
                        <div class="d-flex flex-wrap align-items-stretch gap-3 invoice-summary-row invoice-summary-row-boxes">
