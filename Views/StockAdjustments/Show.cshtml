</div>

@section Scripts {
    <script>
        // Anti-forgery token
        function getAntiForgeryToken() {
            const form = document.getElementById('__AntiForgeryForm');
            return form?.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        // الانتقال داخل التاب (عند فتح الصفحة في iframe) — يمنع الشاشة البيضاء
        function navigateAdjustmentTab(url) {
            try {
                if (window.top && window.top !== window.self) {
                    window.top.postMessage({ type: 'erp-update-current-tab', url: url, title: 'فاتورة تسوية جردية' }, '*');
                } else {
                    window.location.href = url;
                }
            } catch (e) { window.location.href = url; }
        }

        // =========================================================
        // قفل الأزرار والحقول عند الترحيل (مثل فاتورة المبيعات)
        // =========================================================
        function isAdjustmentPosted() {
            const flag = document.getElementById('AdjustmentIsPostedFlag');
            return flag && flag.value === '1';
        }

        function setAdjustmentPosted(posted) {
            const flag = document.getElementById('AdjustmentIsPostedFlag');
            if (flag) flag.value = posted ? '1' : '0';
        }

        function applyPostedUiLock() {
            const posted = isAdjustmentPosted();
            const lockables = document.querySelectorAll('[data-lock-posted="1"]');

            lockables.forEach(el => {
                if (el.dataset.lockInit !== '1') {
                    el.dataset.lockInit = '1';
                    el.dataset.origDisabled = el.disabled ? '1' : '0';
                    el.dataset.origReadonly = el.readOnly ? '1' : '0';
                    el.dataset.origTabIndex = el.getAttribute('tabindex') ?? '';
                }

                const tag = (el.tagName || '').toUpperCase();

                if (posted) {
                    if (tag === 'BUTTON') { el.disabled = true; return; }
                    if (tag === 'A') {
                        el.classList.add('disabled', 'pe-none');
                        el.setAttribute('aria-disabled', 'true');
                        el.setAttribute('tabindex', '-1');
                        return;
                    }
                    if (tag === 'INPUT' || tag === 'TEXTAREA') {
                        el.readOnly = true;
                        el.classList.add('bg-light', 'text-muted');
                        return;
                    }
                    if (tag === 'SELECT') { el.disabled = true; return; }
                    return;
                }

                const origDisabled = el.dataset.origDisabled === '1';
                const origReadonly = el.dataset.origReadonly === '1';
                const origTabIndex = el.dataset.origTabIndex;

                if (tag === 'BUTTON') { el.disabled = origDisabled; return; }
                if (tag === 'A') {
                    el.classList.remove('disabled', 'pe-none');
                    el.removeAttribute('aria-disabled');
                    if (origTabIndex === '') el.removeAttribute('tabindex');
                    else el.setAttribute('tabindex', origTabIndex);
                    return;
                }
                if (tag === 'INPUT' || tag === 'TEXTAREA') {
                    el.readOnly = origReadonly;
                    el.classList.remove('bg-light', 'text-muted');
                    return;
                }
                if (tag === 'SELECT') { el.disabled = origDisabled; return; }
            });

            const btnPost = document.getElementById('btnPostAdjustment');
            if (btnPost) {
                btnPost.disabled = posted;
                btnPost.innerHTML = posted ? '✅ تم ترحيل التسوية' : '📤 ترحيل التسوية';
            }

            const btnOpen = document.getElementById('btnOpenAdjustment');
            if (btnOpen) btnOpen.disabled = !posted;

            const btnPrintAdj = document.getElementById('btnPrintStockAdjustmentDropdown');
            if (btnPrintAdj) {
                const adjId = parseInt(document.getElementById('AdjustmentId')?.value || '0', 10);
                btnPrintAdj.disabled = !posted || adjId <= 0;
            }

            const btnDelLine = document.getElementById('btnDeleteSelectedAdjustmentLine');
            if (btnDelLine) {
                const hasSel = !!document.querySelector('#AdjustmentLinesTbody tr[data-line-id].erp-sa-row-selected');
                btnDelLine.disabled = posted || !hasSel;
            }
        }

        // تطبيق القفل عند التحميل + زر الطباعة (مرتبط بالترحيل)
        (function() {
            const serverIsPosted = @Model.IsPosted.ToString().ToLower();
            setAdjustmentPosted(!!serverIsPosted);
            applyPostedUiLock();
        })();

        // رسائل عابرة — نفس فاتورة المبيعات (ERP.showToast + مدة اختيارية للنجاح 1000ms)
        function showToast(text, type, durationMs) {
            if (!text) return;
            if (typeof ERP !== 'undefined' && typeof ERP.showToast === 'function') {
                ERP.showToast(text, type, durationMs);
                return;
            }
            var container = document.getElementById('adjustmentToastContainer');
            if (!container) return;
            type = type || 'muted';
            var ms = typeof durationMs === 'number' && durationMs >= 0 ? durationMs : 4000;
            var el = document.createElement('div');
            el.className = 'alert alert-' + (type === 'danger' ? 'danger' : type === 'success' ? 'success' : type === 'warning' ? 'warning' : 'secondary') + ' shadow-sm mb-0 py-2 px-3';
            el.style.minWidth = '220px';
            el.textContent = text;
            container.appendChild(el);
            setTimeout(function() {
                el.style.opacity = '0';
                el.style.transition = 'opacity 0.25s ease';
                setTimeout(function() {
                    if (el.parentNode) el.parentNode.removeChild(el);
                }, 250);
            }, ms);
        }

        /** رسالة في منتصف الشاشة — للأخطاء ورسائل الخادم الطويلة (بدل لصق HTML/Stack كامل) */
        function showCenterModal(message, variant) {
            variant = variant || 'danger';
            var wrap = document.getElementById('erpSaCenterModal');
            var body = document.getElementById('erpSaCenterModalBody');
            var hdr = document.getElementById('erpSaCenterModalHeader');
            if (!wrap || !body || !hdr) {
                showToast(message, variant === 'success' ? 'success' : 'danger');
                return;
            }
            body.textContent = (message || '').toString();
            hdr.classList.remove('erp-sa-cm-h-danger', 'erp-sa-cm-h-success', 'erp-sa-cm-h-warn');
            if (variant === 'success') {
                hdr.classList.add('erp-sa-cm-h-success');
                hdr.textContent = 'تم بنجاح';
            } else if (variant === 'warning') {
                hdr.classList.add('erp-sa-cm-h-warn');
                hdr.textContent = 'تنبيه';
            } else {
                hdr.classList.add('erp-sa-cm-h-danger');
                hdr.textContent = 'تنبيه';
            }
            wrap.classList.remove('d-none');
        }
        function hideCenterModal() {
            var wrap = document.getElementById('erpSaCenterModal');
            if (wrap) wrap.classList.add('d-none');
        }
        document.getElementById('erpSaCenterModalBtn')?.addEventListener('click', hideCenterModal);
        document.getElementById('erpSaCenterModalBackdrop')?.addEventListener('click', hideCenterModal);

        async function parseResponseJsonSafe(response) {
            var ct = (response.headers.get('content-type') || '').toLowerCase();
            if (ct.indexOf('application/json') >= 0) {
                try { return await response.json(); } catch (e) { return { ok: false, message: 'تعذر قراءة الرد.' }; }
            }
            var t = await response.text();
            try { return JSON.parse(t); } catch (e) {
                var shortMsg = (t || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
                if (shortMsg.length > 220) shortMsg = 'حدث خطأ في الخادم أثناء المعالجة. إن استمر الأمر، راجع الإعدادات أو أعد المحاولة.';
                return { ok: false, message: shortMsg || 'حدث خطأ غير متوقع.' };
            }
        }

        // تشغيلات الصنف الحالية (تُملأ عند تحميل بيانات الصنف — للاختيار من القائمة أو إدخال تشغيلة جديدة)
        let currentBatches = [];

        /** نفس فاتورة/طلب المشتريات: إدخال مختصر شهر+سنة بدون فواصل → يُنسَّق MM/YYYY */
        window.formatExpiryWithSlash = window.formatExpiryWithSlash || function (val) {
            var s = (val || '').toString().trim().replace(/\s/g, '');
            if (!s) return '';
            var digits = s.replace(/\D/g, '');
            if (digits.length === 3) { var m = digits[0]; var yy = digits.slice(1, 3); return ('0' + m).slice(-2) + '/' + '20' + yy; }
            if (digits.length === 4) { var mm = digits.slice(0, 2); var yy2 = digits.slice(2, 4); return mm + '/' + '20' + yy2; }
            if (digits.length === 5) { var m5 = digits[0]; var yyyy = digits.slice(1, 5); return ('0' + m5).slice(-2) + '/' + yyyy; }
            if (digits.length >= 6) { var mm6 = digits.slice(0, 2); var yyyy6 = digits.slice(2, 6); return mm6 + '/' + yyyy6; }
            return s;
        };

        /** yyyy-MM-dd → عرض MM/YYYY (مثل فاتورة المشتريات) */
        function yyyyMmDdToMmYyyy(iso) {
            if (!iso || typeof iso !== 'string') return '';
            var t = iso.trim();
            if (!t.includes('-')) return t;
            var parts = t.split('-');
            if (parts.length >= 2) return parts[1] + '/' + parts[0];
            return t;
        }

        /** للإرسال للخادم: يفضّل yyyy-MM-dd الكامل من data-iso إن وُجد؛ وإلا MM/YYYY → أول الشهر */
        function getExpiryForApi() {
            var el = document.getElementById('ExpiryInput');
            if (!el) return '';
            var iso = el.getAttribute('data-expiry-iso');
            if (iso && /^\d{4}-\d{2}-\d{2}$/.test(iso)) return iso;
            var v = (el.value || '').trim();
            if (!v) return '';
            if (typeof formatExpiryWithSlash === 'function') v = formatExpiryWithSlash(v);
            v = v.replace(/\s/g, '');
            if (/^\d{4}-\d{2}-\d{2}$/.test(v)) return v;
            var m = v.match(/^(\d{1,2})\/(\d{4})$/);
            if (m) {
                var mm = parseInt(m[1], 10);
                var yyyy = parseInt(m[2], 10);
                if (mm >= 1 && mm <= 12 && yyyy > 1900)
                    return yyyy + '-' + String(mm).padStart(2, '0') + '-01';
            }
            return v;
        }

        function setExpiryFieldFromIso(iso) {
            var el = document.getElementById('ExpiryInput');
            if (!el) return;
            if (iso && /^\d{4}-\d{2}-\d{2}$/.test(String(iso).trim())) {
                el.setAttribute('data-expiry-iso', String(iso).trim());
                el.value = yyyyMmDdToMmYyyy(String(iso).trim());
            } else {
                el.removeAttribute('data-expiry-iso');
                el.value = iso ? String(iso) : '';
            }
        }

        /** تكلفة الوحدة = سعر الجمهور × (1 - الخصم المرجح%/100) — نفس منطق عرض التكلفة من السعر والخصم */
        function recalcAdjustmentCostFromRetailDiscount() {
            var retailEl = document.getElementById('PriceRetailInput');
            var wdEl = document.getElementById('WeightedDiscountInput');
            var costEl = document.getElementById('CostPerUnitInput');
            if (!retailEl || !wdEl || !costEl) return;
            var retail = parseFloat(String(retailEl.value || '').replace(',', '.'));
            var wd = parseFloat(String(wdEl.value || '').replace(',', '.'));
            if (isNaN(retail) || isNaN(wd)) return;
            wd = Math.max(0, Math.min(100, wd));
            var cost = retail * (1 - wd / 100);
            costEl.value = cost.toFixed(4);
        }

        // تحميل بيانات الصنف تلقائياً + ملء قائمة التشغيلات
        let busyLoadInfo = false;
        async function loadProductInfo() {
            const prodId = parseInt(document.getElementById('ProdId').value || '0', 10);
            const warehouseId = parseInt(document.querySelector('[name="WarehouseId"]')?.value || '0', 10);
            if (!prodId || prodId <= 0 || !warehouseId || warehouseId <= 0) {
                currentBatches = [];
                var bl = document.getElementById('batchList');
                if (bl) bl.innerHTML = '';
                var totalEl = document.getElementById('TotalQtyInput');
                if (totalEl) totalEl.value = '0';
                var qtyBeforeEl = document.getElementById('QtyBeforeInput');
                if (qtyBeforeEl) qtyBeforeEl.value = '0';
                var batchToggle = document.getElementById('BatchDropdownToggle');
                if (batchToggle) batchToggle.style.visibility = 'hidden';
                var wdIn = document.getElementById('WeightedDiscountInput');
                if (wdIn) wdIn.value = '';
                return;
            }
            if (busyLoadInfo) return;
            busyLoadInfo = true;
            const batchNo = document.getElementById('BatchNoInput').value?.trim() || '';
            const expiry = getExpiryForApi();
            try {
                const url = '@Url.Action("GetStockAdjustmentProductInfo", "StockAdjustments")'
                    + '?prodId=' + encodeURIComponent(prodId)
                    + '&warehouseId=' + encodeURIComponent(warehouseId)
                    + (batchNo ? '&batchNo=' + encodeURIComponent(batchNo) : '')
                    + (expiry ? '&expiry=' + encodeURIComponent(expiry) : '');
                const r = await fetch(url, { method: 'GET' });
                const data = await r.json();
                if (data && data.ok) {
                    document.getElementById('TotalQtyInput').value = data.totalQty ?? 0;
                    document.getElementById('QtyBeforeInput').value = data.qtyBefore || 0;
                    document.getElementById('PriceRetailInput').value = data.priceRetail != null ? data.priceRetail : '';
                    var wdEl = document.getElementById('WeightedDiscountInput');
                    if (wdEl) wdEl.value = data.weightedDiscount != null ? data.weightedDiscount : '';
                    recalcAdjustmentCostFromRetailDiscount();
                    currentBatches = data.batches || [];
                    var batchListEl = document.getElementById('batchList');
                    if (batchListEl) {
                        batchListEl.innerHTML = '';
                        currentBatches.forEach(function(b) {
                            var opt = document.createElement('option');
                            opt.value = (b.batchNo || '').trim();
                            opt.textContent = (b.batchNo || '') + (b.expiryText ? ' — ' + b.expiryText : '');
                            batchListEl.appendChild(opt);
                        });
                    }
                    // عند تحميل صنف جديد نعيّن دائماً التشغيلة وتاريخ الصلاحية لأول تشغيلة له (حتى بعد تغيير الصنف بالاسم/الكود + Enter)
                    document.getElementById('BatchNoInput').value = data.firstBatchNo ?? '';
                    setExpiryFieldFromIso(data.firstExpiry || '');
                    var batchToggle = document.getElementById('BatchDropdownToggle');
                    if (batchToggle) batchToggle.style.visibility = (currentBatches && currentBatches.length > 1) ? 'visible' : 'hidden';
                } else {
                    currentBatches = [];
                    var bl = document.getElementById('batchList');
                    if (bl) bl.innerHTML = '';
                }
            } catch (e) { console.warn('GetStockAdjustmentProductInfo:', e); currentBatches = []; }
            finally { busyLoadInfo = false; }
        }

        // عند اختيار أو كتابة التشغيلة: إن وافقت إحدى القائمة نملأ تاريخ الصلاحية أوتوماتيك ونحدّث الكمية قبل
        document.getElementById('BatchNoInput')?.addEventListener('input', function() {
            var v = this.value?.trim() || '';
            var found = currentBatches.find(function(b) { return (b.batchNo || '').trim() === v; });
            if (found && found.expiryText) {
                setExpiryFieldFromIso(found.expiryText);
                loadProductInfo();
            }
        });

        // لوحة قائمة التشغيلات الظاهرة عند النقر على حقل التشغيلة
        (function() {
            var batchInput = document.getElementById('BatchNoInput');
            var panel = document.getElementById('batchDropdownPanel');
            var listEl = document.getElementById('batchDropdownList');
            if (!batchInput || !panel || !listEl) return;

            function renderBatchList() {
                listEl.innerHTML = '';
                if (!currentBatches || currentBatches.length === 0) return;
                currentBatches.forEach(function(b) {
                    var batchNo = (b.batchNo || '').trim();
                    var expiryText = b.expiryText || '';
                    var label = batchNo + (expiryText ? ' — ' + expiryText : '');
                    var btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'dropdown-item text-start w-100 border-0 bg-transparent py-2 px-2 small';
                    btn.textContent = label;
                    btn.dataset.batchNo = batchNo;
                    btn.dataset.expiry = expiryText;
                    btn.addEventListener('click', function(e) {
                        e.preventDefault();
                        batchInput.value = batchNo;
                        setExpiryFieldFromIso(expiryText);
                        loadProductInfo();
                        panel.classList.add('d-none');
                    });
                    listEl.appendChild(btn);
                });
            }

            function showPanel() {
                if (!currentBatches || currentBatches.length <= 1) return;
                renderBatchList();
                panel.classList.remove('d-none');
            }

            function hidePanel() {
                panel.classList.add('d-none');
            }

            batchInput.addEventListener('focus', function() { showPanel(); });
            batchInput.addEventListener('click', function() { showPanel(); });

            document.addEventListener('click', function(e) {
                if (panel.classList.contains('d-none')) return;
                if (!panel.contains(e.target) && e.target !== batchInput) hidePanel();
            });
        })();

        // سعر الجمهور: مغلق افتراضياً — الضغط على اللابل يفتح التعديل
        (function() {
            var priceLabel = document.getElementById('PriceRetailLabel');
            var priceInput = document.getElementById('PriceRetailInput');
            if (!priceLabel || !priceInput) return;
            var priceLocked = true;
            function applyPriceLockUI() {
                priceInput.readOnly = priceLocked;
                if (priceLocked) {
                    priceInput.classList.add('bg-light', 'text-muted');
                } else {
                    priceInput.classList.remove('bg-light', 'text-muted');
                    priceInput.focus();
                    priceInput.select();
                }
            }
            priceLabel.addEventListener('click', function() {
                priceLocked = !priceLocked;
                applyPriceLockUI();
            });
            priceInput.addEventListener('input', function() {
                recalcAdjustmentCostFromRetailDiscount();
            });
        })();

        document.getElementById('WeightedDiscountInput')?.addEventListener('input', recalcAdjustmentCostFromRetailDiscount);
        document.getElementById('WeightedDiscountInput')?.addEventListener('change', recalcAdjustmentCostFromRetailDiscount);

        // =========================================================
        // أوتوكومبليت اسم الصنف — نفس منطق فاتورة المبيعات (قائمة مخصصة + بحث متعدد الكلمات)
        // =========================================================
        (function () {
            const prodCodeInput = document.getElementById('ProdCodeInput');
            const prodNameInput = document.getElementById('ProdNameInput');
            const prodHiddenId = document.getElementById('ProdId');
            const prodDataList = document.getElementById('productsList');
            const batchNoInput = document.getElementById('BatchNoInput');

            if (!prodDataList) {
                console.warn('قائمة الأصناف (productsList) غير موجودة.');
                return;
            }

            function normalizeDigits(txt) {
                if (!txt) return '';
                const map = { '\u0660': '0', '\u0661': '1', '\u0662': '2', '\u0663': '3', '\u0664': '4',
                    '\u0665': '5', '\u0666': '6', '\u0667': '7', '\u0668': '8', '\u0669': '9' };
                let out = '';
                for (let i = 0; i < txt.length; i++) {
                    const c = txt[i];
                    out += map[c] !== undefined ? map[c] : c;
                }
                return out;
            }

            function normalizeWord(w) {
                return normalizeDigits((w || '').trim().toLowerCase()).replace(/^[اأإآ]/u, '');
            }

            function normalizeText(txt) {
                return (txt || '')
                    .trim()
                    .toLowerCase()
                    .split(/\s+/)
                    .filter(Boolean)
                    .map(function (w) { return normalizeWord(w); })
                    .filter(Boolean)
                    .join(' ')
                    .replace(/\s+/g, ' ');
            }

            function wordMatchesQueryWord(nameWord, queryWord) {
                const nw0 = normalizeDigits((nameWord || '').trim().toLowerCase());
                const qw0 = normalizeDigits((queryWord || '').trim().toLowerCase());
                const nw = nw0.replace(/^[اأإآ]/u, '');
                const qw = qw0.replace(/^[اأإآ]/u, '');
                if (!qw) return true;
                return nw === qw || nw.startsWith(qw);
            }

            function productNameMatchesSearch(productName, rawSearch) {
                const raw = (rawSearch || '').trim();
                if (!raw) return true;
                const qWords = raw.split(/\s+/).filter(Boolean);
                const nWords = (productName || '').trim().split(/\s+/).filter(Boolean);
                if (qWords.length === 0) return true;
                return qWords.every(function (qw) {
                    return nWords.some(function (nw) { return wordMatchesQueryWord(nw, qw); });
                });
            }

            function productSearchRank(name, rawSearch) {
                const raw = (rawSearch || '').trim();
                const nm = (name || '').trim();
                if (!raw) return 50;
                if (nm === raw) return 0;
                if (nm.startsWith(raw)) return 1;
                const rawWords = raw.split(/\s+/).filter(Boolean);
                const firstQ = rawWords[0] || '';
                const nmWords = nm.split(/\s+/).filter(Boolean);
                if (firstQ && nmWords.length) {
                    if (nmWords[0].startsWith(firstQ)) return 2;
                    const nw0 = normalizeDigits(nmWords[0].toLowerCase());
                    const qw0 = normalizeDigits(firstQ.toLowerCase());
                    const nw = nw0.replace(/^[اأإآ]/u, '');
                    const qw = qw0.replace(/^[اأإآ]/u, '');
                    if (qw && (nw === qw || nw.startsWith(qw))) return 3;
                }
                return 4;
            }

            function findProductByName(name) {
                const raw = (name || '').trim();
                const search = normalizeText(raw);
                if (!search) return null;
                const opts = prodDataList.options;
                for (let i = 0; i < opts.length; i++) {
                    if (normalizeText(opts[i].value) === search) return opts[i];
                }
                for (let i = 0; i < opts.length; i++) {
                    if ((opts[i].value || '').trim() === raw) return opts[i];
                }
                return null;
            }

            function findProductByCode(code) {
                const search = (code || '').toString().trim();
                if (!search) return null;
                const opts = prodDataList.options;
                for (let i = 0; i < opts.length; i++) {
                    const idAttr = (opts[i].getAttribute('data-id') || '').toString();
                    const codeAttr = (opts[i].getAttribute('data-code') || '').toString();
                    if (idAttr === search || codeAttr === search) return opts[i];
                }
                return null;
            }

            function getProductDropdownFilterQuery(rawTrim) {
                const raw = (rawTrim || '').trim();
                if (!raw || !prodDataList || !prodDataList.options) return raw;
                const nRaw = normalizeText(raw);
                let canonical = '';
                const opts = prodDataList.options;
                for (let i = 0; i < opts.length; i++) {
                    const v = (opts[i].value || '').trim();
                    if (!v) continue;
                    if (v === raw) { canonical = v; break; }
                    if (nRaw && normalizeText(v) === nRaw) { canonical = v; break; }
                }
                if (!canonical) return raw;
                const parts = canonical.split(/\s+/).filter(Boolean);
                return parts[0] || raw;
            }

            const PRODUCT_LIST_MAX = 15;

            function getFilteredProductOptions(search, max, pinDisplayName) {
                if (!prodDataList || !prodDataList.options) return [];
                const limit = max || PRODUCT_LIST_MAX;
                const opts = prodDataList.options;
                const rawTrim = (search || '').trim();
                if (!rawTrim) {
                    const out = [];
                    for (let i = 0; i < opts.length && out.length < limit; i++) out.push(opts[i]);
                    return out;
                }
                const qNorm = normalizeText(rawTrim);
                const words = rawTrim.split(/\s+/).filter(Boolean);
                const matched = [];
                for (let i = 0; i < opts.length; i++) {
                    const opt = opts[i];
                    const nameVal = (opt.value || '').trim();
                    const code = (opt.getAttribute('data-code') || '').toString().trim();
                    const idAttr = (opt.getAttribute('data-id') || '').toString().trim();
                    const codeOrId = code || idAttr;
                    const nameOk = qNorm ? productNameMatchesSearch(nameVal, rawTrim) : true;
                    const idOk = words.length > 0 && words.some(function (w) { return codeOrId.indexOf(w) !== -1; });
                    const codeRawOk = codeOrId && codeOrId.indexOf(rawTrim) !== -1;
                    if (nameOk || idOk || codeRawOk) matched.push(opt);
                }
                matched.sort(function (a, b) {
                    const ra = productSearchRank((a.value || '').trim(), rawTrim);
                    const rb = productSearchRank((b.value || '').trim(), rawTrim);
                    if (ra !== rb) return ra - rb;
                    return (a.value || '').localeCompare(b.value || '', 'ar');
                });
                let result = matched.slice(0, limit);
                const pinRaw = (pinDisplayName || '').trim();
                if (pinRaw) {
                    const nPin = normalizeText(pinRaw);
                    let pinOpt = null;
                    for (let j = 0; j < opts.length; j++) {
                        const v = (opts[j].value || '').trim();
                        if (v === pinRaw || (nPin && normalizeText(v) === nPin)) { pinOpt = opts[j]; break; }
                    }
                    if (pinOpt && matched.indexOf(pinOpt) >= 0) {
                        const inResult = result.some(function (o) { return o === pinOpt; });
                        if (!inResult) {
                            result = matched.slice(0, limit - 1);
                            result.push(pinOpt);
                        }
                    }
                }
                return result;
            }

            var productDropdownHighlightedIndex = -1;
            var productDropdownSelectableItems = [];
            var productDropdownPendingMoveToNext = false;

            function fillProductFromOption(opt) {
                if (!opt) {
                    if (prodHiddenId) prodHiddenId.value = '';
                    if (prodCodeInput) prodCodeInput.value = '';
                    if (prodNameInput) prodNameInput.value = '';
                    currentBatches = [];
                    var bl = document.getElementById('batchList');
                    if (bl) bl.innerHTML = '';
                    var bt = document.getElementById('BatchDropdownToggle');
                    if (bt) bt.style.visibility = 'hidden';
                    loadProductInfo();
                    return;
                }
                const id = opt.getAttribute('data-id') || '';
                const code = opt.getAttribute('data-code') || id;
                const name = opt.value || '';
                if (prodHiddenId) prodHiddenId.value = id;
                if (prodCodeInput) prodCodeInput.value = code;
                if (prodNameInput) prodNameInput.value = name;
                loadProductInfo();
            }

            function openProductDropdown() {
                const panel = document.getElementById('productDropdownList');
                const inp = document.getElementById('ProdNameInput');
                if (!panel || !inp) return;
                var searchTerm = (inp.value || '').trim();
                var filterQuery = getProductDropdownFilterQuery(searchTerm);
                const list = getFilteredProductOptions(filterQuery, PRODUCT_LIST_MAX, searchTerm);
                panel.innerHTML = '';
                productDropdownSelectableItems = [];
                var currentVal = (inp.value || '').trim();
                var highlightIdx = 0;
                if (list.length > 0) {
                    for (var i = 0; i < list.length; i++) {
                        if (normalizeText((list[i].value || '').trim()) === normalizeText(currentVal)) { highlightIdx = i; break; }
                    }
                }
                if (list.length === 0) {
                    const empty = document.createElement('div');
                    empty.className = 'product-dropdown-item text-muted py-2 px-3 small';
                    empty.textContent = inp.value ? 'لا توجد نتائج' : ('اكتب للبحث ثم انزل بالسهم ▼ واختر (' + PRODUCT_LIST_MAX + ' كحد أقصى)');
                    panel.appendChild(empty);
                } else {
                    list.forEach(function (opt, idx) {
                        const id = (opt.getAttribute('data-id') || '').toString();
                        const name = (opt.value || '').trim();
                        const it = document.createElement('div');
                        it.className = 'product-dropdown-item py-2 px-3' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                        it.setAttribute('role', 'option');
                        it.setAttribute('data-id', id);
                        it.textContent = name;
                        it.addEventListener('click', function (e) {
                            e.preventDefault();
                            const o = findProductByCode(id);
                            if (o) fillProductFromOption(o);
                            if (inp) inp.value = name;
                            closeProductDropdown();
                        });
                        panel.appendChild(it);
                        productDropdownSelectableItems.push(it);
                    });
                    productDropdownHighlightedIndex = highlightIdx;
                }
                panel.style.display = 'block';
                panel.setAttribute('data-open', 'true');
                positionProductDropdownList();
            }

            function positionProductDropdownList() {
                const panel = document.getElementById('productDropdownList');
                const wrap = document.getElementById('productDropdownWrap');
                if (!panel || !wrap || panel.getAttribute('data-open') !== 'true') return;
                const r = wrap.getBoundingClientRect();
                panel.style.width = r.width + 'px';
                panel.style.top = r.bottom + 'px';
                panel.style.left = r.left + 'px';
            }

            function closeProductDropdown() {
                const panel = document.getElementById('productDropdownList');
                if (panel) {
                    panel.style.display = 'none';
                    panel.setAttribute('data-open', 'false');
                }
                productDropdownHighlightedIndex = -1;
                productDropdownSelectableItems = [];
                productDropdownPendingMoveToNext = false;
            }

            function setProductDropdownHighlight(idx) {
                if (idx < 0 || idx >= productDropdownSelectableItems.length) return;
                productDropdownSelectableItems.forEach(function (el, i) {
                    el.classList.toggle('product-dropdown-item-active', i === idx);
                });
                productDropdownHighlightedIndex = idx;
                productDropdownSelectableItems[idx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
            }

            function selectHighlightedProduct(keepOpen) {
                if (productDropdownHighlightedIndex < 0 || productDropdownHighlightedIndex >= productDropdownSelectableItems.length) return false;
                const el = productDropdownSelectableItems[productDropdownHighlightedIndex];
                const id = el.getAttribute('data-id');
                const name = el.textContent.trim();
                const o = findProductByCode(id);
                if (o) {
                    fillProductFromOption(o);
                    const inp = document.getElementById('ProdNameInput');
                    if (inp) inp.value = name;
                }
                if (!keepOpen) closeProductDropdown();
                return true;
            }

            window.addEventListener('resize', positionProductDropdownList);

            if (prodNameInput) {
                prodNameInput.addEventListener('input', function () {
                    openProductDropdown();
                });
                prodNameInput.addEventListener('blur', function () {
                    setTimeout(function () {
                        closeProductDropdown();
                        fillProductFromOption(findProductByName(prodNameInput.value));
                    }, 180);
                });
                prodNameInput.addEventListener('keydown', function (e) {
                    const panel = document.getElementById('productDropdownList');
                    const isOpen = panel && panel.getAttribute('data-open') === 'true';
                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        productDropdownPendingMoveToNext = false;
                        if (isOpen && productDropdownSelectableItems.length > 0) {
                            const next = Math.min(productDropdownHighlightedIndex + 1, productDropdownSelectableItems.length - 1);
                            setProductDropdownHighlight(next);
                        } else {
                            openProductDropdown();
                        }
                        return;
                    }
                    if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        productDropdownPendingMoveToNext = false;
                        if (isOpen && productDropdownSelectableItems.length > 0) {
                            const prev = Math.max(productDropdownHighlightedIndex - 1, 0);
                            setProductDropdownHighlight(prev);
                        }
                        return;
                    }
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        if (productDropdownPendingMoveToNext) {
                            closeProductDropdown();
                            productDropdownPendingMoveToNext = false;
                            if (batchNoInput) { batchNoInput.focus(); batchNoInput.select?.(); }
                            return;
                        }
                        if (isOpen && productDropdownSelectableItems.length > 0) {
                            selectHighlightedProduct(false);
                            productDropdownPendingMoveToNext = true;
                            return;
                        }
                        fillProductFromOption(findProductByName(prodNameInput.value));
                        if (batchNoInput) { batchNoInput.focus(); batchNoInput.select?.(); }
                    }
                });
            }

            document.addEventListener('click', function (ev) {
                const wrap = document.getElementById('productDropdownWrap');
                if (wrap && !wrap.contains(ev.target)) closeProductDropdown();
            });

            const productDropdownWrap = document.getElementById('productDropdownWrap');
            const productDropdownArrow = document.getElementById('productDropdownArrow');
            if (productDropdownWrap) {
                productDropdownWrap.addEventListener('click', function (ev) {
                    if (!ev.target.closest('#productDropdownList')) {
                        const inp = document.getElementById('ProdNameInput');
                        if (inp) inp.focus();
                    }
                });
            }
            if (productDropdownArrow) {
                productDropdownArrow.addEventListener('click', function (ev) {
                    ev.preventDefault();
                    const inp = document.getElementById('ProdNameInput');
                    if (inp) { inp.focus(); openProductDropdown(); }
                });
            }

            if (prodCodeInput) {
                prodCodeInput.addEventListener('input', function () {
                    const code = (this.value || '').trim();
                    if (code) {
                        const o = findProductByCode(code);
                        if (o) fillProductFromOption(o);
                    } else {
                        fillProductFromOption(null);
                    }
                });
                prodCodeInput.addEventListener('blur', function () {
                    const code = (this.value || '').trim();
                    if (!code) {
                        fillProductFromOption(null);
                        return;
                    }
                    fillProductFromOption(findProductByCode(code));
                });
                prodCodeInput.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        fillProductFromOption(findProductByCode(this.value));
                        if (prodNameInput) { prodNameInput.focus(); prodNameInput.select?.(); }
                    }
                });
            }
        })();

        document.getElementById('BatchNoInput')?.addEventListener('blur', loadProductInfo);
        document.getElementById('ExpiryInput')?.addEventListener('input', function () {
            this.removeAttribute('data-expiry-iso');
        });
        document.getElementById('ExpiryInput')?.addEventListener('blur', function () {
            if (this.value && typeof formatExpiryWithSlash === 'function')
                this.value = formatExpiryWithSlash(this.value);
            loadProductInfo();
        });
        document.querySelector('[name="WarehouseId"]')?.addEventListener('change', function() {
            if (document.getElementById('ProdId').value) loadProductInfo();
        });

        // دالة مسح حقول إضافة السطر وإعادة الفوكس لاسم الصنف (بعد إعادة تفعيل زر الإضافة حتى لا ينتقل التركيز للتشغيلة)
        function clearAddLineFormAndFocus() {
            document.getElementById('ProdId').value = '';
            document.getElementById('ProdCodeInput').value = '';
            document.getElementById('ProdNameInput').value = '';
            document.getElementById('BatchNoInput').value = '';
            setExpiryFieldFromIso('');
            document.getElementById('TotalQtyInput').value = '0';
            document.getElementById('QtyBeforeInput').value = '0';
            document.getElementById('QtyAfterInput').value = '0';
            document.getElementById('CostPerUnitInput').value = '';
            var wdClear = document.getElementById('WeightedDiscountInput');
            if (wdClear) wdClear.value = '';
            document.getElementById('PriceRetailInput').value = '';
            document.getElementById('LineNoteInput').value = '';
            currentBatches = [];
            var batchListEl = document.getElementById('batchList');
            if (batchListEl) batchListEl.innerHTML = '';
            var batchToggle = document.getElementById('BatchDropdownToggle');
            if (batchToggle) batchToggle.style.visibility = 'hidden';
            setTimeout(function () {
                var prodNameInput = document.getElementById('ProdNameInput');
                if (prodNameInput) {
                    prodNameInput.focus();
                    prodNameInput.select?.();
                }
            }, 60);
