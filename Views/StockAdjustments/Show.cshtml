                                <datalist id="batchList"></datalist>
                                <div id="batchDropdownPanel" class="dropdown-menu shadow-sm border position-absolute start-0 w-100 mt-0 d-none" style="max-height: 200px; overflow-y: auto; z-index: 1050; top: 100%;">
                                    <div id="batchDropdownList"></div>
                                </div>
                            </div>

                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">تاريخ الصلاحية</label>
                                <input type="text" id="ExpiryInput" inputmode="numeric" autocomplete="off"
                                       class="form-control form-control-sm text-center pi-input"
                                       placeholder="شهر/سنة (مثال: 229 = 02/2029)" data-lock-posted="1" dir="ltr" style="text-align: left;"
                                       title="اكتب رقم الشهر ثم رقمين للسنة بدون فواصل، مثل 229 لشهر 2 سنة 2029 — مثل فاتورة المشتريات" />
