@model IList<ERP.ViewModels.RecentPurchaseItemRow>
@{
    Layout = null;
    var items = Model ?? new List<ERP.ViewModels.RecentPurchaseItemRow>();
}
<div class="recent-purchase-items-table p-2" dir="rtl">
    <p class="text-muted small mb-2">@items.Count سطر من سطور فواتير الشراء في الفترة المحددة.</p>
    <div class="table-responsive" style="max-height: 60vh; overflow-y: auto;">
        <table class="table table-sm table-striped table-hover mb-0">
            <thead class="table-light sticky-top">
                <tr>
                    <th>اسم الصنف</th>
                    <th>سعر الجمهور</th>
                    <th>الخصم المرجح %</th>
                    <th>الكمية الحالية</th>
                </tr>
            </thead>
            <tbody>
                @if (items.Count == 0)
                {
                    <tr><td colspan="4" class="text-center text-muted">لا توجد بيانات</td></tr>
                }
                else
                {
                    @foreach (var r in items)
                    {
                        <tr>
                            <td>@(r.ProdName ?? "—")</td>
                            <td>@r.PriceRetail.ToString("N2")</td>
                            <td>@r.PurchaseDiscountPct.ToString("N2")</td>
                            <td>@r.Qty</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
