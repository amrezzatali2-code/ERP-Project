                            var currentVal = (inp.value || '').trim();
                            var highlightIdx = 0;
                            if (list.length > 0) {
                                for (var i = 0; i < list.length; i++) {
                                    if (normalizeText((list[i].value || '').trim()) === normalizeText(currentVal)) { highlightIdx = i; break; }
                                }
                            }
                            if (list.length === 0) {
                                const empty = document.createElement('div');
                                empty.className = 'product-dropdown-item text-muted py-2 px-3 small';
                                empty.textContent = inp.value ? 'لا توجد نتائج' : ('اكتب للبحث ثم انزل بالسهم ▼ واختر (' + PRODUCT_LIST_MAX + ' كحد أقصى)');
                                panel.appendChild(empty);
                            } else {
                                list.forEach(function (opt, idx) {
                                    const id = (opt.getAttribute('data-id') || '').toString();
                                    const name = (opt.value || '').trim();
                                    const it = document.createElement('div');
                                    it.className = 'product-dropdown-item py-2 px-3' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                                    it.setAttribute('role', 'option');
                                    it.setAttribute('data-id', id);
                                    it.setAttribute('data-index', String(idx));
                                    it.textContent = name;
                                    it.addEventListener('click', function (e) {
                                        e.preventDefault();
                                        const o = findProductByCode(id);
                                        if (o) fillProductFromOption(o);
                                        if (inp) inp.value = name;
                                        closeProductDropdown();
                                    });
                                    panel.appendChild(it);
                                    productDropdownSelectableItems.push(it);
                                });
                                productDropdownHighlightedIndex = highlightIdx;
                            }
                            panel.style.display = 'block';
                            panel.setAttribute('data-open', 'true');
                            positionProductDropdownList();
                        }
                        function positionProductDropdownList() {
                            const panel = document.getElementById('productDropdownList');
                            const wrap = document.getElementById('productDropdownWrap');
                            if (!panel || !wrap || panel.getAttribute('data-open') !== 'true') return;
                            const r = wrap.getBoundingClientRect();
                            panel.style.width = r.width + 'px';
                            panel.style.top = r.bottom + 'px';
                            panel.style.left = r.left + 'px';
                        }
                        function closeProductDropdown() {
                            const panel = document.getElementById('productDropdownList');
                            if (panel) {
                                panel.style.display = 'none';
                                panel.setAttribute('data-open', 'false');
                            }
                            productDropdownHighlightedIndex = -1;
                            productDropdownSelectableItems = [];
                            productDropdownPendingMoveToQuantity = false;
                        }
                        function setProductDropdownHighlight(idx) {
                            if (idx < 0 || idx >= productDropdownSelectableItems.length) return;
                            productDropdownSelectableItems.forEach(function (el, i) {
                                el.classList.toggle('product-dropdown-item-active', i === idx);
                            });
                            productDropdownHighlightedIndex = idx;
                            productDropdownSelectableItems[idx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                        }
                        function selectHighlightedProduct(keepOpen) {
                            if (productDropdownHighlightedIndex < 0 || productDropdownHighlightedIndex >= productDropdownSelectableItems.length) return false;
                            const el = productDropdownSelectableItems[productDropdownHighlightedIndex];
                            const id = el.getAttribute('data-id');
                            const name = el.textContent.trim();
                            const o = findProductByCode(id);
                            if (o) {
                                fillProductFromOption(o);
                                const inp = document.getElementById('ProdNameInput');
                                if (inp) inp.value = name;
                            }
                            if (!keepOpen) closeProductDropdown();
                            return true;
                        }

                        // =========================================================
                        // تعبئة بيانات الصنف من <option>
                        // =========================================================
                        function fillProductFromOption(opt) {

                            // لو مفيش صنف مطابق → نفرّغ + إخفاء تركيزات أخرى
                            if (!opt) {
                                if (typeof refreshVariantsDropdown === 'function') refreshVariantsDropdown(null);
                                if (prodHiddenId)    prodHiddenId.value    = '';
                                if (prodCodeInput)   prodCodeInput.value   = '';
                                if (prodNameInput)   prodNameInput.value   = '';
                                if (prodPriceInput)  prodPriceInput.value  = '';

                                if (prodQuotaText)    prodQuotaText.value    = 'بدون كوتة';
                                const prodBonusText = document.getElementById('ProdBonusText');
                                if (prodBonusText)    prodBonusText.value    = 'بدون بونص';
                                if (prodWeightedDisc) prodWeightedDisc.value = '0';

                                if (prodQtyWarehouse) prodQtyWarehouse.value = '0';
                                if (prodQtyAll)       prodQtyAll.value       = '0';

                                if (prodAltSelect) {
                                    prodAltSelect.innerHTML = '<option value="">لا توجد بدائل</option>';
                                }
                                return;
                            }

                            // قراءة البيانات من data-*
                            const id       = opt.getAttribute('data-id')      || ''; // متغير: ProdId
                            const code     = opt.getAttribute('data-code')    || id; // متغير: كود ظاهر (قد يساوي id)
                            const name     = opt.value                        || ''; // متغير: اسم الصنف
                            const generic  = opt.getAttribute('data-generic') || ''; // متغير: الاسم العلمي
                            const hasQuota = (opt.getAttribute('data-hasquota') === 'true'); // متغير: هل له كوتة؟
                            const hasBonus = (opt.getAttribute('data-hasbonus') === 'true'); // متغير: هل له بونص؟
                            const bonusGroup = opt.getAttribute('data-bonusgroup') || ''; // متغير: اسم مجموعة البونص
                            let priceRaw   = opt.getAttribute('data-price')   || '0'; // متغير: السعر كنص

                            // معالجة السعر
                            priceRaw = priceRaw.toString().replace(',', '.');
                            let price = parseFloat(priceRaw);
                            if (isNaN(price)) price = 0;

                            if (prodHiddenId)  prodHiddenId.value  = id;
                            if (prodCodeInput) prodCodeInput.value = code;
                            if (prodNameInput) prodNameInput.value = name;
                                        // ✅ لا نأخذ السعر من datalist في المبيعات
            if (prodPriceInput) prodPriceInput.value = '0.00';

            // ✅ بعد تثبيت الصنف: نحمّل التشغيلات FEFO ونملأ السعر/الباتش/الصلاحية
            loadSalesProductInfo(parseInt(id || '0', 10) || 0);


                            if (prodQuotaText) {
                                prodQuotaText.value = hasQuota ? 'له كوتة' : 'بدون كوتة';
                            }
                            const prodBonusText = document.getElementById('ProdBonusText');
                            if (prodBonusText) {
                                prodBonusText.value = hasBonus && bonusGroup ? bonusGroup : 'بدون بونص';
                            }

                            // حالياً: الخصم المرجّح = 0 (هنربطه بالسياسات لاحقاً)
                            if (prodWeightedDisc) {
                                prodWeightedDisc.value = '0';
                            }

                            // بدائل الصنف حسب الاسم العلمي
                            if (prodAltSelect && generic) {
                                loadAlternativeProducts(id);
                            } else if (prodAltSelect) {
                                prodAltSelect.innerHTML = '<option value="">لا توجد بدائل</option>';
                            }

                            // عرض قائمة «تركيزات/أشكال أخرى» من الداتاليست (بدون طلب سيرفر)
                            if (typeof refreshVariantsDropdown === 'function') refreshVariantsDropdown(opt);
                        }




             // =========================================================
            // ✅ تحميل بيانات الصنف بعد اختياره (Card 2 + تعبئة Card 3 تلقائيًا)
            // - ينادي GetSalesProductInfo
            // - يملأ: الكميات + الخصم المرجح + جدول التشغيلات FEFO
            // - يملأ تلقائيًا: Batch / Expiry / PriceRetailBatch
            // =========================================================
            let busyLoadInfo = false; // متغير: يمنع تداخل استدعاءات متكررة

            async function loadSalesProductInfo(prodId) {
                if (!prodId) return;

                // متغير: رقم المخزن الحالي من الهيدر
                const warehouseId = parseInt((warehouseInput?.value || '0'), 10) || 0;
                if (!warehouseId) {
                    console.warn('⚠️ WarehouseId غير موجود/0 — لا يمكن تحميل التشغيلات FEFO.');
                    return;
                }

                         const customerId = parseInt((document.getElementById('CustomerId')?.value || '0'), 10) || 0;


                if (busyLoadInfo) return;
                busyLoadInfo = true;

                try {
                    const url = '@Url.Action("GetSalesProductInfo", "SalesInvoices")'
                        + '?prodId=' + encodeURIComponent(prodId)
                        + '&warehouseId=' + encodeURIComponent(warehouseId)
                        + '&customerId=' + encodeURIComponent(customerId);

                    const r = await fetch(url, { method: 'GET' });
                    const data = await (r.ok ? r.json() : null);

                    if (!data || !data.ok) {
                        console.warn('⚠️ GetSalesProductInfo فشل:', data?.message || 'no data');

                        // تفريغ سريع لو فشل
                        if (prodQtyWarehouse) prodQtyWarehouse.value = '0';
                        if (prodQtyAll) prodQtyAll.value = '0';
                        if (prodWeightedDisc) prodWeightedDisc.value = '0';
                        if (batchQueueBody) batchQueueBody.innerHTML = `<tr><td colspan="6" class="text-muted">لا توجد تشغيلات بعد.</td></tr>`;
                        const batchSelectInRowFail = document.getElementById('ProdBatchSelectInRow');
                        const probatchInputFail = document.getElementById('ProdBatchInput');
                        if (batchSelectInRowFail) { batchSelectInRowFail.innerHTML = '<option value="">—</option>'; batchSelectInRowFail.classList.add('d-none'); }
                        if (probatchInputFail) probatchInputFail.classList.remove('d-none');
                        return;
                    }

                    // 1) تعبئة كميات كارت 2
                    if (prodQtyWarehouse) prodQtyWarehouse.value = (data.qtyCurrentWarehouse ?? 0);
                    if (prodQtyAll)       prodQtyAll.value       = (data.qtyAllWarehouses ?? 0);

                    // 2) كوتة
                    if (prodQuotaText) prodQuotaText.value = (data.quotaText ?? 'بدون كوتة').toString();

                    // 2.1) مجموعة الصنف
                    const prodGroupText = document.getElementById('ProdGroupText');
                    if (prodGroupText) prodGroupText.value = (data.productGroupName ?? 'بدون مجموعة').toString();

                    // 2.2) سياسة المجموعة المطبقة (رقم/اسم السياسة)
                    const groupPolicyBox = document.getElementById('ProdGroupPolicyText');
                    if (groupPolicyBox) groupPolicyBox.value = (data.appliedGroupPolicyName ?? data.appliedGroupPolicyId ?? '').toString() || '—';

                    // 3) الخصم المرجّح (تحديد بين 0 و 100 وتنسيق لتجنب قيم خاطئة)
                    if (prodWeightedDisc) {
                        const wd = Number(data.weightedDiscount ?? 0);
                        prodWeightedDisc.value = (Number.isFinite(wd) && wd >= 0 && wd <= 100) ? Number(wd).toFixed(2) : '0.00';
                    }


                    // 3.1) ✅ خصم البيع (من السياسات + الخصم المرجح) — تحديد بين 0 و 100
                    if (prodDisc1Input) {
                        const sd = Number(data.saleDisc1 ?? 0);
                        prodDisc1Input.value = (Number.isFinite(sd) && sd >= 0 && sd <= 100) ? Number(sd).toFixed(2) : '0.00';
                    }


                    // 4) جدول تشغيلات FEFO (كارت 2) + دروب داون اختيار التشغيلة (تجاوز FIFO)
                    const batches = data.batches || [];
                    currentProductBatches = batches;

                    if (batchQueueBody) {
                        if (!batches.length) {
                            batchQueueBody.innerHTML = `<tr><td colspan="6" class="text-muted">لا توجد تشغيلات متاحة لهذا الصنف في هذا المخزن.</td></tr>`;
                        } else {
                            batchQueueBody.innerHTML = batches.map((b, idx) => `
                                <tr class="${idx === 0 ? 'table-success' : ''}" data-batch-index="${idx}">
                                    <td>${idx + 1}</td>
                                    <td>${b.batchNo || ''}</td>
                                    <td>${b.expiryText || ''}</td>
                                    <td>${b.qty ?? 0}</td>
                                    <td>${fmt2(b.priceRetailBatch ?? 0)}</td>
                                    <td>${fmt2(b.weightedDiscount ?? 0)}</td>
                                </tr>
                            `).join('');
                        }
                    }

                    if (prodBatchSelect) {
                        prodBatchSelect.innerHTML = '';
                        if (!batches.length) {
                            prodBatchSelect.appendChild(new Option('لا توجد تشغيلات', '', true, true));
                        } else {
                            batches.forEach((b, idx) => {
                                const label = `تشغيلة ${idx + 1}: ${b.batchNo || ''} | صلاحية ${b.expiryText || ''} | سعر ${fmt2(b.priceRetailBatch ?? 0)}`;
                                prodBatchSelect.appendChild(new Option(label, String(idx), idx === 0, idx === 0));
                            });
                        }
                    }

                    // 4.1) دروب داون الباتش في صف الإضافة — عند وجود أكثر من تشغيلة
                    const batchSelectInRow = document.getElementById('ProdBatchSelectInRow');
                    const probatchInput = document.getElementById('ProdBatchInput');
                    if (batchSelectInRow && probatchInput) {
                        if (batches.length >= 2) {
                            probatchInput.classList.add('d-none');
                            batchSelectInRow.classList.remove('d-none');
                            batchSelectInRow.innerHTML = '';
                            batches.forEach((b, idx) => {
                                const opt = document.createElement('option');
                                opt.value = String(idx);
                                opt.textContent = (b.batchNo || '').toString() || '—';
                                if (idx === 0) opt.selected = true;
                                batchSelectInRow.appendChild(opt);
                            });
                            const b0 = batches[0];
                            if (prodBatchInput)  prodBatchInput.value  = b0.batchNo || '';
                            if (prodExpiryInput) prodExpiryInput.value = b0.expiryText || '';
                            if (prodPriceInput)  prodPriceInput.value  = fmt2(b0.priceRetailBatch ?? 0);
                        } else {
                            batchSelectInRow.innerHTML = '<option value="">—</option>';
                            batchSelectInRow.classList.add('d-none');
                            probatchInput.classList.remove('d-none');
                            if (data.auto) {
                                if (prodBatchInput)  prodBatchInput.value  = data.auto.batchNo || '';
                                if (prodExpiryInput) prodExpiryInput.value = data.auto.expiryText || '';
                                if (prodPriceInput)  prodPriceInput.value  = fmt2(data.auto.priceRetailBatch ?? 0);
                            } else if (batches.length === 1 && batches[0]) {
                                const b0 = batches[0];
                                if (prodBatchInput)  prodBatchInput.value  = b0.batchNo || '';
                                if (prodExpiryInput) prodExpiryInput.value = b0.expiryText || '';
                                if (prodPriceInput)  prodPriceInput.value  = fmt2(b0.priceRetailBatch ?? 0);
                            }
                        }
                    } else if (data.auto) {
                        if (prodBatchInput)  prodBatchInput.value  = data.auto.batchNo || '';
                        if (prodExpiryInput) prodExpiryInput.value = data.auto.expiryText || '';
                        if (prodPriceInput)  prodPriceInput.value  = fmt2(data.auto.priceRetailBatch ?? 0);
                    }

                    // تحديث زر/قائمة «تركيزات أخرى» بعد اكتمال تحميل بيانات الصنف (الداتاليست قد يكون محدّثاً الآن)
                    if (typeof refreshVariantsDropdown === 'function' && prodDataList) {
                        const opt = findProductByCode(String(prodId));
                        if (opt) refreshVariantsDropdown(opt);
                    }

                    // ✅ تثبيت قفل السعر دائمًا
                    forcePriceLocked();

                } catch (err) {
                    console.error('❌ خطأ أثناء تحميل بيانات الصنف:', err);
                } finally {
                    busyLoadInfo = false;
                }
            }

            // =========================================================
            // اختيار التشغيلة يدوياً (تجاوز FIFO) — من الدروب داون تحت البدائل أو من دروب داون الباتش في صف الإضافة
            // =========================================================
            function applyBatchSelectionFromIndex(idx) {
                const b = currentProductBatches[idx];
                if (!b) return;
                if (prodBatchInput)  prodBatchInput.value  = b.batchNo || '';
                if (prodExpiryInput) prodExpiryInput.value = b.expiryText || '';
                if (prodPriceInput)  prodPriceInput.value  = fmt2(b.priceRetailBatch ?? 0);
                // الخصم المرجح وخصم البيع = خصم التشغيلة المختارة (من جدول الخصم اليدوي)
                if (prodWeightedDisc) {
                    const wd = Number(b.weightedDiscount ?? 0);
                    prodWeightedDisc.value = (Number.isFinite(wd) && wd >= 0 && wd <= 100) ? Number(wd).toFixed(2) : '0.00';
                }
                if (prodDisc1Input) {
                    const sd = Number(b.saleDisc1 ?? 0);
                    prodDisc1Input.value = (Number.isFinite(sd) && sd >= 0 && sd <= 100) ? Number(sd).toFixed(2) : '0.00';
                }
                if (batchQueueBody) {
                    batchQueueBody.querySelectorAll('tr[data-batch-index]').forEach(tr => {
                        const i = parseInt(tr.getAttribute('data-batch-index'), 10);
                        tr.classList.toggle('table-success', i === idx);
                    });
                }
            }
            if (prodBatchSelect) {
                prodBatchSelect.addEventListener('change', function () {
                    const idx = parseInt(this.value, 10);
                    if (isNaN(idx) || idx < 0 || idx >= currentProductBatches.length) return;
                    applyBatchSelectionFromIndex(idx);
                });
            }
            const prodBatchSelectInRowEl = document.getElementById('ProdBatchSelectInRow');
            if (prodBatchSelectInRowEl) {
                prodBatchSelectInRowEl.addEventListener('change', function () {
                    const idx = parseInt(this.value, 10);
                    if (isNaN(idx) || idx < 0 || idx >= currentProductBatches.length) return;
                    applyBatchSelectionFromIndex(idx);
                });
            }




                        // =========================================================
                        // تحميل البدائل من الكنترولر
                        // =========================================================
                        function loadAlternativeProducts(prodId) {
                            if (!prodId || !prodAltSelect) return;

                            const url = '@Url.Action("GetAlternativeProducts", "SalesInvoices")'
                                + '?prodId=' + encodeURIComponent(prodId);

                            prodAltSelect.innerHTML = '<option value="">... جاري تحميل البدائل</option>';

                            fetch(url)
                                .then(r => r.ok ? r.json() : [])
                                .then(data => {
                                    prodAltSelect.innerHTML = '<option value="">اختر بديلاً (للمشاهدة فقط)</option>';

                                    if (!data || !data.length) {
                                        prodAltSelect.innerHTML += '<option value="">لا توجد بدائل</option>';
                                        return;
                                    }

                                    data.forEach(p => {
                                        const op = document.createElement('option');
                                        op.value = p.id;
                                        op.textContent = `${p.name || ''} — ${p.company || ''} — ${p.price || 0}`;
                                        op.setAttribute('data-id', p.id);
                                        op.setAttribute('data-price', p.price || 0);
                                        prodAltSelect.appendChild(op);
                                    });
                                })
                                .catch(err => {
                                    console.error('❌ خطأ في تحميل بدائل الصنف:', err);
                                    prodAltSelect.innerHTML = '<option value="">خطأ في تحميل البدائل</option>';
                                });
                        }

                        // =========================================================
                        // Events: اسم الصنف — نفس نظام المستخدمين (قائمة حتى PRODUCT_LIST_MAX)
                        // =========================================================
                        if (prodNameInput) {
                            prodNameInput.addEventListener('input', function () {
                                if (suppressProductDropdownOnce) {
                                    suppressProductDropdownOnce = false;
                                    closeProductDropdown();
                                    return;
                                }
                                openProductDropdown();
                            });
                            prodNameInput.addEventListener('blur', function () {
                                setTimeout(function () {
                                    closeProductDropdown();
                                    fillProductFromOption(findProductByName(prodNameInput.value));
                                }, 180);
                            });
                            prodNameInput.addEventListener('keydown', function (e) {
                                const panel = document.getElementById('productDropdownList');
                                const isOpen = panel && panel.getAttribute('data-open') === 'true';
                                if (e.key === 'ArrowDown') {
                                    e.preventDefault();
                                    productDropdownPendingMoveToQuantity = false;
                                    if (isOpen && productDropdownSelectableItems.length > 0) {
                                        const next = Math.min(productDropdownHighlightedIndex + 1, productDropdownSelectableItems.length - 1);
                                        setProductDropdownHighlight(next);
                                    } else {
                                        openProductDropdown();
                                    }
                                    return;
                                }
                                if (e.key === 'ArrowUp') {
                                    e.preventDefault();
                                    productDropdownPendingMoveToQuantity = false;
                                    if (isOpen && productDropdownSelectableItems.length > 0) {
                                        const prev = Math.max(productDropdownHighlightedIndex - 1, 0);
                                        setProductDropdownHighlight(prev);
                                    }
                                    return;
                                }
                                if (e.key === 'Enter') {
                                    e.preventDefault();
                                    // Enter الثاني بعد اختيار الصنف: نكمل للكمية
                                    if (productDropdownPendingMoveToQuantity) {
                                        closeProductDropdown();
                                        productDropdownPendingMoveToQuantity = false;
                                        if (prodQtyInput) { prodQtyInput.focus(); prodQtyInput.select?.(); }
                                        return;
                                    }

                                    // Enter الأول داخل القائمة: اختيار الصنف ثم قفل القائمة فوراً
                                    if (isOpen && productDropdownSelectableItems.length > 0) {
                                        selectHighlightedProduct(false); // close
                                        productDropdownPendingMoveToQuantity = true;
                                        return;
                                    } else {
                                        fillProductFromOption(findProductByName(this.value));
                                        if (prodPriceInput) { prodPriceInput.focus(); prodPriceInput.select?.(); }
                                    }
                                }
                            });
                        }
                        document.addEventListener('click', function (ev) {
                            const wrap = document.getElementById('productDropdownWrap');
                            if (wrap && !wrap.contains(ev.target)) closeProductDropdown();
                        });
                        // النقر على البوكس أو السهم يفتح القائمة
                        const productDropdownWrap = document.getElementById('productDropdownWrap');
                        const productDropdownArrow = document.getElementById('productDropdownArrow');
                        if (productDropdownWrap) {
                            productDropdownWrap.addEventListener('click', function (ev) {
                                if (!ev.target.closest('#productDropdownList')) {
                                    const inp = document.getElementById('ProdNameInput');
                                    if (inp) {
                                        inp.focus();
                                        // القائمة لا تفتح هنا؛ تفتح بالكتابة أو ArrowDown أو زر ▼ فقط
                                    }
                                }
                            });
                        }
                        if (productDropdownArrow) {
                            productDropdownArrow.addEventListener('click', function (ev) {
                                ev.preventDefault();
                                const inp = document.getElementById('ProdNameInput');
                                if (inp) { inp.focus(); openProductDropdown(); }
                            });
                        }

                        if (prodCodeInput) {
                            prodCodeInput.addEventListener('change', function () {
                                fillProductFromOption(findProductByCode(this.value));
                            });

                            prodCodeInput.addEventListener('keydown', function (e) {
                                if (e.key === 'Enter') {
                                    e.preventDefault();
                                    fillProductFromOption(findProductByCode(this.value));

                                    // بعد اختيار الكود → ننتقل للاسم
                                    if (prodNameInput) {
                                        prodNameInput.focus();
                                        prodNameInput.select?.();
                                    }
                                }
                            });
                        }





             // =========================================================
            // ✅ السعر في المبيعات ليس اختياريًا
            // - السعر يأتي من التشغيلة FEFO (Batch.PriceRetailBatch)
            // - لذلك نخلي ProdPriceInput مقفول دائمًا
            // =========================================================
            const priceLabel     = document.getElementById('ProdPriceLabel');       // متغير: Label السعر
            const priceLockState = document.getElementById('ProdPriceLockState');   // متغير: (مغلق/مفتوح)

            function forcePriceLocked() {
                if (!prodPriceInput) return;

                prodPriceInput.readOnly = true; // ✅ ثابت
                prodPriceInput.classList.add('bg-light', 'text-muted'); // شكل مقفول
                if (priceLockState) priceLockState.textContent = '(مغلق)';
                if (priceLabel) priceLabel.style.cursor = 'default';
            }
            forcePriceLocked();









             // =========================================================
            // قفل / فتح خصم البيع (بالضغط على اللابل)
            // ✅ المطلوب:
            // - الخصم ييجي أوتوماتيك من السيرفيس (GetSalesProductInfo) ويتكتب في البوكس
            // - افتراضيًا يكون "مقفول" (ReadOnly)
            // - لو المستخدم ضغط على كلمة "الخصم" → يفتح/يقفل
            // - عند الفتح: يعمل Focus + Select للبوكس
            // - كل مرة يتغير القفل: ننادي rebuildEnterNav() علشان Enter يتخطى المقفول
            // =========================================================
            const disc1Label     = document.getElementById('ProdDisc1Label');      // متغير: Label الخصم
            const disc1LockState = document.getElementById('ProdDisc1LockState');  // متغير: (مغلق/مفتوح)
            let disc1Locked = true;                                                // متغير: حالة قفل الخصم (افتراضي مقفول)

            // دالة: تطبيق شكل القفل على UI
            function applyDisc1LockUI() {
                if (!prodDisc1Input) return;

                // ✅ قفل/فتح
                prodDisc1Input.readOnly = disc1Locked;

                // ✅ شكل مقفول/مفتوح
                if (disc1Locked) {
                    prodDisc1Input.classList.add('bg-light', 'text-muted');
                    prodDisc1Input.style.cursor = 'not-allowed';
                    if (disc1LockState) disc1LockState.textContent = '(مغلق)';
                } else {
                    prodDisc1Input.classList.remove('bg-light', 'text-muted');
                    prodDisc1Input.style.cursor = 'text';
                    if (disc1LockState) disc1LockState.textContent = '(مفتوح)';

                    // ✅ عند الفتح: فوكس + تحديد كامل
                    setTimeout(() => {
                        prodDisc1Input.focus();
                        if (typeof prodDisc1Input.select === 'function') prodDisc1Input.select();
                    }, 0);
                }
            }

            // ✅ تطبيق الحالة الافتراضية
            applyDisc1LockUI();

            // ✅ الضغط على اللابل يفتح/يقفل
            if (disc1Label) {
                disc1Label.style.cursor = 'pointer';

                // ملاحظة: لو السكربت بيتنفذ أكتر من مرة، ده يمنع تكرار الربط
                if (disc1Label.dataset.boundDisc1Toggle !== '1') {
                    disc1Label.dataset.boundDisc1Toggle = '1';

                    disc1Label.addEventListener('click', function () {
                        disc1Locked = !disc1Locked;  // قلب الحالة
                        applyDisc1LockUI();          // طبّق UI

                        // ✅ مهم: تحديث مسار Enter (لا يمر على المقفول)
                        if (typeof rebuildEnterNav === 'function') {
                            rebuildEnterNav();
                        }
                    });



                }
            }

                        // -------------------------
            // (2) قفل/فتح التشغيلة (Batch)
            // -------------------------
            const batchLabel     = document.getElementById('ProdBatchLabel');       // متغير: Label التشغيلة
            const batchLockState = document.getElementById('ProdBatchLockState');   // متغير: (مغلق/مفتوح)
            let batchLocked = true; // متغير: حالة قفل التشغيلة (افتراضي مغلق)

            function applyBatchLockUI() {
                if (!prodBatchInput) return;

                prodBatchInput.readOnly = batchLocked;

                if (batchLocked) {
                    prodBatchInput.classList.add('bg-light', 'text-muted');
                    if (batchLockState) batchLockState.textContent = '(مغلق)';
                } else {
                    prodBatchInput.classList.remove('bg-light', 'text-muted');
                    if (batchLockState) batchLockState.textContent = '(مفتوح)';
                }
            }
            applyBatchLockUI();

            if (batchLabel) {
                batchLabel.style.cursor = 'pointer';
                batchLabel.addEventListener('click', function () {
                    batchLocked = !batchLocked;
                    applyBatchLockUI();
                    if (typeof rebuildEnterNav === 'function') rebuildEnterNav(); // ✅ مهم
                    if (!batchLocked && prodBatchInput) {
                        prodBatchInput.focus();
                        prodBatchInput.select?.();
                    }
                });
            }

                        // -------------------------
            // (3) قفل/فتح الصلاحية (Expiry)
            // -------------------------
            const expiryLabel     = document.getElementById('ProdExpiryLabel');       // متغير: Label الصلاحية
            const expiryLockState = document.getElementById('ProdExpiryLockState');   // متغير: (مغلق/مفتوح)
            let expiryLocked = true; // متغير: حالة قفل الصلاحية (افتراضي مغلق)

            function applyExpiryLockUI() {
                if (!prodExpiryInput) return;

                prodExpiryInput.readOnly = expiryLocked;

                if (expiryLocked) {
                    prodExpiryInput.classList.add('bg-light', 'text-muted');
                    if (expiryLockState) expiryLockState.textContent = '(مغلق)';
                } else {
                    prodExpiryInput.classList.remove('bg-light', 'text-muted');
                    if (expiryLockState) expiryLockState.textContent = '(مفتوح)';
                }
            }
            applyExpiryLockUI();

            if (expiryLabel) {
                expiryLabel.style.cursor = 'pointer';
                expiryLabel.addEventListener('click', function () {
                    expiryLocked = !expiryLocked;
                    applyExpiryLockUI();
                    if (typeof rebuildEnterNav === 'function') rebuildEnterNav(); // ✅ مهم
                    if (!expiryLocked && prodExpiryInput) {
                        prodExpiryInput.focus();
                        prodExpiryInput.select?.();
                    }
                });
            }




            // =========================================================
            // ✅ غلق/فتح الحقول + تنقل Enter ذكي
            // المطلوب:
            // - السعر/الباتش/الصلاحية/الكود: مقفولين دائمًا (ReadOnly)
            // - الخصم: افتراضيًا مقفول، ويتفتح/يتقفل بالضغط على اللابل
            // - Enter: يمر فقط على الحقول "المفتوحة" (مش ReadOnly ومش Disabled)
            // =========================================================

            // =========================
            // (1) غلق دائم لبعض الحقول
            // =========================
            function forceAlwaysLockedFields() {
                // ✅ الكود (مقفول)
                if (prodCodeInput) {
                    prodCodeInput.readOnly = true;
                    prodCodeInput.classList.add('bg-light', 'text-muted');
                    prodCodeInput.style.cursor = 'not-allowed';
                }

                // ✅ السعر (مقفول دائمًا)
                if (prodPriceInput) {
                    prodPriceInput.readOnly = true;
                    prodPriceInput.classList.add('bg-light', 'text-muted');
                    prodPriceInput.style.cursor = 'not-allowed';
                }

                // ✅ الباتش (مقفول)
                if (prodBatchInput) {
                    prodBatchInput.readOnly = true;
                    prodBatchInput.classList.add('bg-light', 'text-muted');
                    prodBatchInput.style.cursor = 'not-allowed';
                }

                // ✅ الصلاحية (مقفولة)
                if (prodExpiryInput) {
                    prodExpiryInput.readOnly = true;
                    prodExpiryInput.classList.add('bg-light', 'text-muted');
                    prodExpiryInput.style.cursor = 'not-allowed';
                }
            }

            // نفّذ الغلق فورًا عند تحميل الصفحة
            forceAlwaysLockedFields();

            // =========================
            // (2) تحديد هل الحقل ينفع يدخل في مسار Enter أم لا
            // =========================
            function isEnterEligible(el) {
                if (!el) return false;

                // لو مخفي أو مش ظاهر
                if (el.offsetParent === null) return false;

                // لو Disabled
                if (el.disabled) return false;

                // ✅ أهم شرط: لو ReadOnly يبقى يتشال من مسار Enter
                // (عشان مايروحش للسعر وهو مقفول)
                if (el.readOnly) return false;

                return true;
            }

            // =========================
            // (3) بناء مسار Enter ديناميكي
            // =========================
            let enterInputs = []; // متغير: قائمة الحقول اللي Enter يتحرك عليها

            function rebuildEnterNav() {
                // ✅ تأكد إن الحقول المقفولة مقفولة فعلًا
                forceAlwaysLockedFields();

                // ✅ ابنِ المسار فقط من الحقول "المفتوحة"
                // ملاحظة: اسم الصنف عادةً مفتوح (للبحث)
                // والكمية مفتوحة
                // والخصم يعتمد على disc1Locked
                enterInputs = [
                    prodNameInput,   // متغير: البحث بالاسم
                    prodQtyInput,    // متغير: الكمية
                    prodDisc1Input   // متغير: الخصم (يدخل فقط لو مفتوح)
                ].filter(isEnterEligible);
            }

            // ابنِ المسار أول مرة
            rebuildEnterNav();

            // =========================
            // (4) ربط Enter على الحقول (مرة واحدة بدون تكرار)
            // =========================
            function bindEnterNavigationOnce(el) {
                if (!el) return;
                if (el.dataset.boundEnterNav === '1') return; // يمنع التكرار
                el.dataset.boundEnterNav = '1';

                // عند الفوكس: تحديد النص
                el.addEventListener('focus', function () {
                    if (typeof this.select === 'function') {
                        setTimeout(() => this.select(), 0);
                    }
                });

                // Enter: يروح للي بعده حسب enterInputs الحالي
                el.addEventListener('keydown', function (e) {
                    if (e.key !== 'Enter') return;

                    e.preventDefault();

                    // لو داخل اسم الصنف: ثبت الاختيار
                    if (el === prodNameInput) {
                        fillProductFromOption(findProductByName(prodNameInput.value));
                    }

                    // ابحث عن موقع الحقل الحالي في المسار
                    const idx = enterInputs.indexOf(el);
                    const next = (idx >= 0) ? enterInputs[idx + 1] : null;

                    if (next) {
                        next.focus();
                        next.select?.();
                    } else if (btnAddLine) {
                        btnAddLine.focus();
                    }
                });
            }

            // اربط على العناصر الأساسية
            bindEnterNavigationOnce(prodNameInput);
            bindEnterNavigationOnce(prodQtyInput);
            bindEnterNavigationOnce(prodDisc1Input);

            // زر الإضافة: Enter يعمل Click
            if (btnAddLine && btnAddLine.dataset.boundEnterClick !== '1') {
                btnAddLine.dataset.boundEnterClick = '1';
                btnAddLine.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        btnAddLine.click();
                    }
                });
            }

            // =========================
            // (5) ✅ تعديل قفل/فتح الخصم بحيث يعيد بناء مسار Enter
            // =========================
            function setDisc1LockState(isLocked) {
                disc1Locked = !!isLocked;

                if (!prodDisc1Input) return;

                prodDisc1Input.readOnly = disc1Locked;

                if (disc1Locked) {
                    prodDisc1Input.classList.add('bg-light', 'text-muted');
                    if (disc1LockState) disc1LockState.textContent = '(مغلق)';
                } else {
                    prodDisc1Input.classList.remove('bg-light', 'text-muted');
                    if (disc1LockState) disc1LockState.textContent = '(مفتوح)';
                    setTimeout(() => {
                        prodDisc1Input.focus();
                        prodDisc1Input.select?.();
                    }, 0);
                }

                // ✅ مهم: تحديث Enter
                rebuildEnterNav();
            }









                    // ===============================
                    // رسم جدول السطور (هجين)
                    // - مسح السطر من كارت الإجراءات (زر «مسح السطر المحدد») بعد تحديد صف في الجدول
                    // ===============================
                    function renderGroupedLines(lines) {

                        if (typeof window.__siLinesSortReset === 'function') window.__siLinesSortReset();

                        // متغير: tbody الخاص بجدول السطور
                        const tbody = document.getElementById('PILinesTbody');
                        if (!tbody) return;

                        // تفريغ الجدول قبل الرسم
                        tbody.innerHTML = '';

                        // لو مفيش بيانات
                        if (!Array.isArray(lines) || lines.length === 0) {
                            tbody.innerHTML = `<tr><td colspan="9" class="text-center text-muted py-3">لا توجد سطور</td></tr>`;
                            return;
                        }

                        // ===============================
                        // 1) تجميع السطور حسب prodId + prodName
                        // ===============================
                        const map = new Map(); // متغير: Map لتجميع السطور

                        lines.forEach(l => {
                            const prodId = Number(l.prodId || 0); // متغير: كود الصنف
                            const prodName = (l.prodName || (`صنف #${prodId}`)).toString(); // متغير: اسم الصنف
                            const key = `${prodId}||${prodName}`; // متغير: مفتاح التجميع

                            if (!map.has(key)) {
                                map.set(key, { prodId, prodName, lines: [] });
                            }
                            map.get(key).lines.push(l);
                        });

                        // ترتيب المجموعات بالاسم
                        const groups = Array.from(map.values())
                            .sort((a, b) => (a.prodName || '').localeCompare(b.prodName || '', 'ar'));

                        // ===============================
                        // 2) رسم كل مجموعة حسب عدد التشغيلات
                        // ===============================
                        groups.forEach(g => {

                            // ترتيب تشغيلات الصنف حسب lineNo
                            const sortedLines = (g.lines || [])
                                .slice()
                                .sort((x, y) => (Number(x.lineNo || 0) - Number(y.lineNo || 0)));

                            const isMultiBatch = sortedLines.length > 1; // متغير: هل الصنف له أكثر من تشغيلة؟

                            // =========================================================
                            // الحالة (1): الصنف غير مكرر => سطر واحد فقط
                            // =========================================================
                            if (!isMultiBatch) {

                                const line = sortedLines[0];

                                const lineNo = line.lineNo ?? ''; // متغير: رقم السطر
                                const batchNo = line.batchNo ?? ''; // متغير: التشغيلة

                                const expiryText = line.expiryText
                                    ? line.expiryText
                                    : (line.expiry ? formatDateYMD(line.expiry) : ''); // متغير: الصلاحية

                                const qty = Number(line.qty || 0); // متغير: الكمية
                                const priceRetail = Number(line.priceRetail || 0); // متغير: سعر الجمهور

                                const discPct = (line.purchaseDiscountPct != null)
                                    ? Number(line.purchaseDiscountPct)
                                    : Number(line.discPct || 0); // متغير: الخصم %

                                const lineValue = (line.lineValue != null)
                                    ? Number(line.lineValue)
                                    : (qty * priceRetail * (1 - (discPct / 100))); // متغير: قيمة السطر

                                const locRaw = (line.location != null) ? String(line.location).trim() : '';
                                const locCell = locRaw ? escapeHtml(locRaw) : '—';

                                const tr = document.createElement('tr');
                                tr.className = 'erp-list-selectable-row';
                                tr.setAttribute('data-line-no', lineNo);
                                tr.setAttribute('data-prodid', g.prodId);

                                tr.innerHTML = `
                                    <td class="text-center">${lineNo}</td>
                                    <td class="text-center text-muted small">${locCell}</td>
                                    <td>
                                        <strong>${escapeHtml(g.prodName)}</strong>
                                        <span class="text-muted small"> | كود: ${g.prodId}</span>
                                    </td>

                                    <td class="text-center">${escapeHtml(batchNo)}</td>
                                    <td class="text-center">${escapeHtml(expiryText)}</td>
                                    <td class="text-center">${qty}</td>
                                    <td class="text-center">${fmt2(priceRetail)}</td>
                                    <td class="text-center">${fmt2(discPct)}</td>

                                    <td class="text-center">${fmt2(lineValue)}</td>
                                `;

                                tbody.appendChild(tr);
                                return;
                            }

                            // =========================================================
                            // الحالة (2): الصنف مكرر => سطر عنوان للصنف + سطور تشغيلات تحته
                            // =========================================================

                            // (أ) سطر عنوان الصنف فقط
                            const grpLocRaw = (sortedLines[0].location != null) ? String(sortedLines[0].location).trim() : '';
                            const grpLocCell = grpLocRaw ? escapeHtml(grpLocRaw) : '—';

                            const grpRow = document.createElement('tr');
                            grpRow.className = 'table-light pi-group-row erp-list-selectable-row';
                            grpRow.setAttribute('data-prodid', g.prodId);

                            grpRow.innerHTML = `
                                <td class="text-center">—</td>
                                <td class="text-center text-muted small">${grpLocCell}</td>
                                <td>
                                    <strong>${escapeHtml(g.prodName)}</strong>
                                    <span class="text-muted small"> | كود: ${g.prodId}</span>
                                </td>

                                <td class="text-center text-muted small">تشغيلات: ${sortedLines.length}</td>
                                <td class="text-center"></td>
                                <td class="text-center"></td>
                                <td class="text-center"></td>
                                <td class="text-center"></td>
                                <td class="text-center"></td>
                            `;

                            tbody.appendChild(grpRow);

                            // (ب) سطور التشغيلات
                            sortedLines.forEach(line => {

                                const lineNo = line.lineNo ?? ''; // متغير: رقم السطر
                                const batchNo = line.batchNo ?? ''; // متغير: التشغيلة

                                const expiryText = line.expiryText
                                    ? line.expiryText
                                    : (line.expiry ? formatDateYMD(line.expiry) : ''); // متغير: الصلاحية

                                const qty = Number(line.qty || 0); // متغير: الكمية
                                const priceRetail = Number(line.priceRetail || 0); // متغير: سعر الجمهور

                                const discPct = (line.purchaseDiscountPct != null)
                                    ? Number(line.purchaseDiscountPct)
                                    : Number(line.discPct || 0); // متغير: الخصم %

                                const lineValue = (line.lineValue != null)
                                    ? Number(line.lineValue)
                                    : (qty * priceRetail * (1 - (discPct / 100))); // متغير: قيمة السطر

                                const dLocRaw = (line.location != null) ? String(line.location).trim() : '';
                                const dLocCell = dLocRaw ? escapeHtml(dLocRaw) : '—';

                                const tr = document.createElement('tr');
                                tr.className = 'erp-list-selectable-row';
                                tr.setAttribute('data-line-no', lineNo);
                                tr.setAttribute('data-prodid', g.prodId);

                                tr.innerHTML = `
                                    <td class="text-center">${lineNo}</td>
                                    <td class="text-center text-muted small">${dLocCell}</td>
                                    <td class="text-muted small">↳</td>

                                    <td class="text-center">${escapeHtml(batchNo)}</td>
                                    <td class="text-center">${escapeHtml(expiryText)}</td>
                                    <td class="text-center">${qty}</td>
                                    <td class="text-center">${fmt2(priceRetail)}</td>
                                    <td class="text-center">${fmt2(discPct)}</td>

                                    <td class="text-center">${fmt2(lineValue)}</td>
                                `;

                                tbody.appendChild(tr);
                            });
                        });
                    }

                    window.renderGroupedLines = renderGroupedLines;

                    // ===============================
                    // ترتيب جدول السطور (عميلي): كتل = سطر واحد أو (سطر مجموعة + سطور ↳)
                    // ===============================
                    (function siLinesTableSortInit() {
                        var activeCol = null;
                        var activeDir = 1;

                        function parseSiLineNum(txt) {
                            if (txt == null || txt === '') return 0;
                            var s = String(txt).trim().replace(/\s/g, '').replace(',', '.');
                            var n = parseFloat(s);
                            return isNaN(n) ? 0 : n;
                        }

                        function parseSiLineDate(txt) {
                            var s = (txt || '').trim();
                            var m = /^(\d{4})-(\d{2})-(\d{2})/.exec(s);
                            if (!m) return 0;
                            return new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3])).getTime();
                        }

                        function pilGetRowBlocks(tbody) {
                            if (!tbody) return [];
                            var rows = Array.prototype.slice.call(tbody.querySelectorAll(':scope > tr'));
                            var blocks = [];
                            var i = 0;
                            while (i < rows.length) {
                                var tr = rows[i];
                                if (!tr.cells || !tr.cells.length) { i++; continue; }
                                if (tr.cells.length === 1 && tr.cells[0].colSpan > 1) return [];
                                if (tr.classList.contains('pi-group-row')) {
                                    var block = [tr];
                                    i++;
                                    while (i < rows.length) {
                                        var r = rows[i];
                                        if (r.classList.contains('pi-group-row')) break;
                                        if (r.cells.length >= 9 && r.cells[2] && r.cells[2].textContent.trim() === '↳') {
                                            block.push(r);
                                            i++;
                                        } else break;
                                    }
                                    blocks.push(block);
                                } else {
                                    blocks.push([tr]);
                                    i++;
                                }
                            }
                            return blocks;
                        }

                        function blockSortKey(block, col) {
                            var first = block[0];
                            var isGroup = first.classList.contains('pi-group-row');
                            var details = isGroup ? block.slice(1) : block;
                            var firstDetail = details[0];
                            var r;
                            if (col === 0) {
                                var nos = block.map(function (row) {
                                    var v = parseInt(row.getAttribute('data-line-no'), 10);
                                    return isNaN(v) ? null : v;
                                }).filter(function (n) { return n != null && n > 0; });
                                return nos.length ? Math.min.apply(null, nos) : 0;
                            }
                            if (col === 1) {
                                r = firstDetail || first;
                                return ((r.cells[1] && r.cells[1].textContent) || '').replace(/\s+/g, ' ').trim();
                            }
                            if (col === 2) {
                                var cell = first.cells[2];
                                var st = cell && cell.querySelector('strong');
                                return ((st && st.textContent) || (cell && cell.textContent) || '').replace(/\s+/g, ' ').trim();
                            }
                            if (col === 3) {
                                r = firstDetail || first;
                                return ((r.cells[3] && r.cells[3].textContent) || '').trim();
                            }
                            if (col === 4) {
                                r = firstDetail || first;
                                return parseSiLineDate(r.cells[4] && r.cells[4].textContent);
                            }
                            if (col === 5) {
                                if (isGroup && details.length) {
                                    return details.reduce(function (s, row) {
                                        return s + parseSiLineNum(row.cells[5] && row.cells[5].textContent);
                                    }, 0);
                                }
                                return parseSiLineNum(first.cells[5] && first.cells[5].textContent);
                            }
                            if (col === 6 || col === 7) {
                                r = firstDetail || first;
                                return parseSiLineNum(r.cells[col] && r.cells[col].textContent);
                            }
                            if (col === 8) {
                                if (isGroup && details.length) {
                                    return details.reduce(function (s, row) {
                                        return s + parseSiLineNum(row.cells[8] && row.cells[8].textContent);
                                    }, 0);
                                }
                                return parseSiLineNum(first.cells[8] && first.cells[8].textContent);
                            }
                            return 0;
                        }

                        function resetSiLinesSortUi() {
                            activeCol = null;
                            activeDir = 1;
                            document.querySelectorAll('#PILinesTable .si-lines-sort-ic').forEach(function (sp) { sp.textContent = ''; });
                        }

                        function setSiLinesSortIcons(col, dir) {
                            document.querySelectorAll('#PILinesTable .si-lines-sort-ic').forEach(function (sp) { sp.textContent = ''; });
                            var ic = document.querySelector('#PILinesTable .si-lines-sort[data-si-col="' + col + '"] .si-lines-sort-ic');
                            if (ic) ic.textContent = dir > 0 ? '▲' : '▼';
                        }

                        function sortPilinesTable(col, kind, dir) {
                            var tbody = document.getElementById('PILinesTbody');
                            if (!tbody) return;
                            var blocks = pilGetRowBlocks(tbody);
                            if (blocks.length <= 1) return;

                            blocks.sort(function (a, b) {
                                var ka = blockSortKey(a, col);
                                var kb = blockSortKey(b, col);
                                var c = 0;
                                if (kind === 'str') {
                                    c = String(ka).localeCompare(String(kb), 'ar', { sensitivity: 'base' });
                                } else {
                                    c = (Number(ka) || 0) - (Number(kb) || 0);
                                }
                                if (c !== 0) return dir * c;
                                var na = blockSortKey(a, 0);
                                var nb = blockSortKey(b, 0);
                                return (Number(na) || 0) - (Number(nb) || 0);
                            });

                            blocks.forEach(function (block) {
                                block.forEach(function (tr) { tbody.appendChild(tr); });
                            });
                        }

                        window.__siLinesSortReset = resetSiLinesSortUi;

                        document.addEventListener('click', function (e) {
                            var btn = e.target && e.target.closest && e.target.closest('.si-lines-sort');
                            if (!btn) return;
                            var table = document.getElementById('PILinesTable');
                            if (!table || !table.contains(btn)) return;
                            e.preventDefault();
                            var col = parseInt(btn.getAttribute('data-si-col'), 10);
                            var kind = btn.getAttribute('data-si-kind') || 'str';
                            if (isNaN(col)) return;
                            if (activeCol === col) activeDir = -activeDir;
                            else { activeCol = col; activeDir = 1; }
                            sortPilinesTable(col, kind, activeDir);
                            setSiLinesSortIcons(activeCol, activeDir);
                        });
                    })();

