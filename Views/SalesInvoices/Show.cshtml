                        // =========================
                        // تحميل Body فقط وتبديل المحتوى
                        // =========================
                        async function loadInvoiceBody(url) {

                            const host = document.getElementById('PI_BodyHost');
                            if (!host) return;

                            url = setOrReplaceParam(url, 'frag', 'body');
                            url = setOrReplaceParam(url, 'ts', Date.now());

                            if (host.dataset.loading === "1") return;
                            host.dataset.loading = "1";

                            try {
                                const res = await fetch(url, {
                                    method: 'GET',
                                    credentials: 'same-origin',
                                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                                });

                                const html = await res.text();

                                const parser = new DOMParser();
                                const doc = parser.parseFromString(html, 'text/html');
                                const newHost = doc.getElementById('PI_BodyHost');

                                if (newHost) {
                                    host.innerHTML = newHost.innerHTML;
                                } else {
                                    host.innerHTML = html;
                                }

                                // ✅ بعد تبديل الـ body: حدّث الشريط الجانبي (حالة الفاتورة + زر المرتجع)
                                const bodyIsPosted = document.getElementById("BodyHostIsPosted")?.value === "1";
                                const bodyStatus = (document.getElementById("BodyHostInvoiceStatus")?.value || "").trim();
                                const bodyInvoiceId = parseInt((document.getElementById("NavCurrentId")?.value || "0"), 10) || 0;
                                const invIdEl = document.getElementById("InvoiceId");
                                if (invIdEl) invIdEl.value = bodyInvoiceId;
                                const invFlagEl = document.getElementById("InvoiceIsPostedFlag");
                                if (invFlagEl) invFlagEl.value = bodyIsPosted ? "1" : "0";
                                const fullRetWrap = document.getElementById("fullReturnBtnWrapper");
                                if (fullRetWrap) {
                                    const canShow = bodyInvoiceId > 0 && (bodyIsPosted || bodyStatus === "مفتوحة للتعديل" || (bodyStatus && bodyStatus.startsWith("مرحلة")));
                                    if (canShow) fullRetWrap.classList.remove("d-none");
                                    else fullRetWrap.classList.add("d-none");
                                }
                                if (typeof setInvoicePosted === "function") setInvoicePosted(bodyIsPosted);
                                if (typeof applyPostedUiLock === "function") applyPostedUiLock();
                                const isPostedDisplay = document.getElementById("InvoiceIsPostedDisplay");
                                if (isPostedDisplay && bodyStatus) isPostedDisplay.value = bodyStatus;
                                const statusHidden = document.getElementById("InvoiceStatusHidden");
                                if (statusHidden && bodyStatus) statusHidden.value = bodyStatus;
                                const btnPost = document.getElementById("btnPostInvoice");
                                if (btnPost) {
                                    btnPost.innerHTML = bodyIsPosted ? "✅ تم ترحيل الفاتورة" : "📤 ترحيل الفاتورة";
                                    btnPost.disabled = !!bodyIsPosted;
                                }
                                const btnOpen = document.getElementById("btnOpenInvoice");
                                if (btnOpen) btnOpen.disabled = !bodyIsPosted;

                                // ✅ بعد تبديل الـ body: حدّث أزرار السايد بار
                                refreshSideNavButtons();

                                // ✅ بعد التبديل: أعد تهيئة tooltips للأسهم مرة واحدة وبشكل سليم
                                setupTooltips();

                                            // ✅ نظام ثابت: بعد تبديل الـ Body لازم نعيد تهيئة الصفحة
                        if (typeof window.__ERP_INIT__ === 'function') {
                            window.__ERP_INIT__();
                        }


                            } catch (e) {
                                console.error(e);
                                alert('حدث خطأ أثناء تحميل الفاتورة.');
                            } finally {
                                host.dataset.loading = "0";
                            }
                        }

                        // ✅ زر التحديث في الناف بار: تحديث الفاتورة الحالية فقط (بدون فتح فاتورة جديدة)
                        window.__ERP_REFRESH__ = function () {
                            const currentId = parseInt((document.getElementById('NavCurrentId')?.value || '0'), 10) || 0;
                            const baseUrl = document.getElementById('btnNavInvoiceSearch')?.getAttribute('data-base-url') || '@Url.Action("Show", "SalesInvoices", new { frame = 1 })';
                            if (currentId > 0 && typeof loadInvoiceBody === 'function') {
                                try {
                                    const u = new URL(baseUrl, window.location.origin);
                                    u.searchParams.set('id', currentId);
                                    const chk = document.getElementById('chkIncludeZeroQty');
                                    if (chk && chk.checked) u.searchParams.set('includeZeroQty', 'true');
                                    loadInvoiceBody(u.toString());
                                } catch (e) { console.warn('__ERP_REFRESH__:', e); }
                            }
                            // لو فاتورة جديدة (currentId=0): لا نعيد التحميل حتى لا نفقد البيانات المدخلة
                        };





                        // =========================
                        // اعتراض الضغط على الأسهم/بحث الفاتورة على مستوى document (Capture)
                        // =========================
                        async function docCaptureHandler(ev) {

                            // متغير: العنصر الذي تم الضغط عليه
                            const t = ev.target;

                            // حماية: لو target مش Element (نادرًا) نخرج
                            if (!(t instanceof Element)) return;




                            // =========================
                            // (1) الأسهم + البحث
                            // =========================
                            const btn = t.closest('#btnFirstInvoice, #btnPrevInvoice, #btnNextInvoice, #btnLastInvoice, #btnNavInvoiceSearch');
                            if (!btn) return;

                            if (btn.hasAttribute('disabled')) return;

                            // ✅ امنع أي نظام تابات/لينكات
                            ev.preventDefault();
                            ev.stopPropagation();
                            ev.stopImmediatePropagation();

                            // ✅ مهم: اقفل Tooltip + شيل فوكس بعد الضغط
                            hideTooltipAndBlur(btn);

                            if (btn.id === 'btnNavInvoiceSearch') {
                                const input = document.getElementById('NavInvoiceSearchInput');
                                const val = input ? parseInt(input.value || '0', 10) : 0;
                                if (!val || val <= 0) return;

                                const baseUrl = btn.getAttribute('data-base-url');
                                if (!baseUrl) return;

                                const url = setOrReplaceParam(baseUrl, 'id', val);
                                loadInvoiceBody(url);
                                return;
                            }

                            // ✅ للأزرار: نستخدم data-url (يحتوي على URL كامل مع id)
                            // ✅ مهم: نحدث data-url فوراً قبل الاستخدام (لضمان القيم الصحيحة)
                            refreshSideNavButtons();
                            
                            let url = btn.getAttribute('data-url');
                            
                            // ✅ لو data-url غير موجود أو فارغ، نبني URL من data-base-url و data-id
                            if (!url || !url.trim()) {
                                const baseUrl = btn.getAttribute('data-base-url');
                                const btnId = btn.getAttribute('data-id');
                                if (baseUrl && btnId) {
                                    url = setOrReplaceParam(baseUrl, 'id', parseInt(btnId || '0', 10));
                                }
                            }
                            
                            if (!url || !url.trim()) return;

                            loadInvoiceBody(url);
                        }








                        // =========================================================
            // ERP — زر طباعة الفاتورة (قائمة منسدلة: صفحة واحدة / أصل وصورة / أصل وصورتين)
            // =========================================================
            document.addEventListener("DOMContentLoaded", function () {

                const btnPrint = document.getElementById("btnPrintInvoiceDropdown");

                if (!btnPrint) return;

                if (btnPrint.dataset.boundPrint) return;
                btnPrint.dataset.boundPrint = "1";

                if (typeof isInvoicePosted === "function" && !isInvoicePosted()) {
                    btnPrint.disabled = true;
                }

                let printing = false;
                let printWrapperParent = null;
                let printWrapperNext = null;

                function prepareSalesInvoicePrint() {
                    const printArea = document.getElementById("piPrintArea");
                    if (!printArea) return false;

                    const invoiceId = (document.getElementById("InvoiceId")?.value || "").trim();
                    const invoiceDate = (document.getElementById("InvoiceDateDisplay")?.value || document.getElementById("PIDate")?.value || "").trim();
                    const supplierName = (document.getElementById("CustomerNameInput")?.value || "").trim();
                    let warehouseName = "";
                    const whSel = document.getElementById("WarehouseId");
                    if (whSel && whSel.options && whSel.selectedIndex >= 0) {
                        warehouseName = (whSel.options[whSel.selectedIndex].text || "").trim();
                    }

                    const el = (id) => document.getElementById(id);
                    if (el("piPrintNow")) el("piPrintNow").textContent = new Date().toLocaleString();
                    if (el("piPrintInvoiceNo")) el("piPrintInvoiceNo").textContent = invoiceId || "";
                    if (el("piPrintInvoiceDate")) el("piPrintInvoiceDate").textContent = invoiceDate || "";
                    if (el("piPrintSupplier")) el("piPrintSupplier").textContent = supplierName || "";
                    if (el("piPrintWarehouse")) el("piPrintWarehouse").textContent = warehouseName || "";
                    const customerPhone = (el("CustomerPhone") && el("CustomerPhone").value) ? el("CustomerPhone").value.trim() : "";
                    if (el("piPrintCustomerPhone")) el("piPrintCustomerPhone").textContent = customerPhone || "—";
                    const customerAddress = (el("CustomerAddress") && el("CustomerAddress").value) ? el("CustomerAddress").value.trim() : "";
                    if (el("piPrintCustomerAddress")) el("piPrintCustomerAddress").textContent = customerAddress || "—";
                    const createdBy = (el("InvoiceCreatedByDisplay") && el("InvoiceCreatedByDisplay").value) ? el("InvoiceCreatedByDisplay").value.trim() : "";
                    if (el("piPrintAuthor")) el("piPrintAuthor").textContent = createdBy || "—";

                    const destTbody = el("piPrintMasterTbody");
                    if (!destTbody) return false;
                    destTbody.innerHTML = "";
                    const srcTbody = document.getElementById("PILinesTbody");
                    if (!srcTbody) {
                        destTbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-2">لا توجد سطور للطباعة.</td></tr>';
                    } else {
                        const rows = srcTbody.querySelectorAll("tr");
                        if (!rows.length) {
                            destTbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-2">لا توجد سطور للطباعة.</td></tr>';
                        } else {
                            rows.forEach(function (tr) {
                                const c = tr.cloneNode(true);
                                c.querySelectorAll("button, a, .no-print").forEach(x => x.remove());
                                c.querySelectorAll("th.no-print, td.no-print").forEach(x => x.remove());
                                destTbody.appendChild(c);
                            });
                        }
                    }

                    const totalsWrap = el("piPrintTotalsWrap");
                    if (!totalsWrap) return false;
                    const totalLines = el("TotalLinesValue")?.textContent?.trim() || "0";
                    const totalItems = el("TotalItemsValue")?.textContent?.trim() || "0";
                    const totalQty = el("TotalQtyValue")?.textContent?.trim() || "0";
                    const totalRetail = el("TotalRetailValue")?.textContent?.trim() || "0";
                    const totalAfterDiscount = el("TotalAfterDiscountValue")?.textContent?.trim() || "0";
                    const taxPct = (el("TaxPercentInput") && el("TaxPercentInput").value) ? el("TaxPercentInput").value.trim() : "0";
                    const tax = (el("TaxAmountValue")?.textContent || "").trim() || "0";
                    const totalAfterDiscountAndTax = el("TotalAfterDiscountAndTaxValue")?.textContent?.trim() || "0";
                    const netTotal = el("NetTotalValue")?.textContent?.trim() || "0";
                    const grandWithPrev = el("GrandTotalWithPreviousValue")?.textContent?.trim() || totalAfterDiscountAndTax;
                    const prevBalance = el("CustomerPreviousBalanceValue")?.textContent?.trim() || "0";
                    const creditRemaining = el("CreditRemainingValue")?.textContent?.trim() || "0";
                    totalsWrap.innerHTML = `
<div class="card shadow-sm invoice-totals-card mb-0">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-boxes">
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">عدد السطور</span><span class="invoice-summary-value">${totalLines}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">عدد الأصناف</span><span class="invoice-summary-value">${totalItems}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي الكمية</span><span class="invoice-summary-value">${totalQty}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">الحساب السابق للعميل</span><span class="invoice-summary-value">${prevBalance}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">المبلغ المتبقى من الحد الائتماني</span><span class="invoice-summary-value">${creditRemaining}</span></div>
        </div>
        <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-totals mt-2">
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي سعر الجمهور</span><span class="invoice-summary-value">${totalRetail}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي الفاتورة</span><span class="invoice-summary-value">${totalAfterDiscount}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">نسبة الضريبة %</span><span class="invoice-summary-value">${taxPct}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">قيمة الضريبة</span><span class="invoice-summary-value">${tax}</span></div>
            <div class="invoice-summary-item invoice-summary-box invoice-summary-box-main"><span class="invoice-summary-label">الإجمالي</span><span class="invoice-summary-value invoice-summary-value-main fw-bold">${grandWithPrev}</span></div>
        </div>
    </div>
</div>`;
                    return true;
                }

                function doPrint(mode) {
                    const invoiceId = parseInt((document.getElementById("InvoiceId")?.value || "0"), 10) || 0;
                    if (invoiceId <= 0) {
                        showToast("⚠️ لا يمكن طباعة فاتورة قبل حفظها.", "warning");
                        return;
                    }
                    if (typeof isInvoicePosted === "function" && !isInvoicePosted()) {
                        showToast("❌ يجب ترحيل الفاتورة قبل الطباعة", "danger");
                        document.getElementById("btnPostInvoice")?.focus();
                        return;
                    }
                    if (printing) return;
                    printing = true;

                    if (!prepareSalesInvoicePrint()) {
                        printing = false;
                        showToast("تعذر تجهيز الطباعة.", "danger");
                        return;
                    }

                    const wrapper = document.getElementById("piPrintWrapper");
                    const printArea = document.getElementById("piPrintArea");
                    if (!wrapper || !printArea) { printing = false; return; }

                    wrapper.classList.remove("print-mode-1", "print-mode-2", "print-mode-3");
                    wrapper.querySelectorAll(".pi-print-copy:not(#piPrintArea)").forEach(c => c.remove());

                    if (mode === 2 || mode === 3) {
                        const copies = mode === 2 ? 2 : 3;
                        for (let i = 1; i < copies; i++) {
                            const clone = printArea.cloneNode(true);
                            clone.id = "";
                            clone.classList.add("pi-print-copy");
                            clone.querySelectorAll("[id]").forEach(el => el.removeAttribute("id"));
                            wrapper.appendChild(clone);
                        }
                        wrapper.classList.add("print-mode-" + mode);
                    } else {
                        wrapper.classList.add("print-mode-1");
                    }

                    // نقل منطقة الطباعة إلى body حتى تظهر (بدون ذلك الأب display:none يخفيها)
                    printWrapperParent = null;
                    printWrapperNext = null;
                    if (wrapper.parentNode !== document.body) {
                        printWrapperParent = wrapper.parentNode;
                        printWrapperNext = wrapper.nextSibling;
                        document.body.appendChild(wrapper);
                    }

                    document.body.classList.add("printing-invoice");
                    setTimeout(() => window.print(), 50);
                }

                document.querySelectorAll('[data-print-mode]').forEach(item => {
                    item.addEventListener("click", function (e) {
                        e.preventDefault();
                        const mode = parseInt(this.getAttribute("data-print-mode") || "1", 10);
                        doPrint(mode);
                    });
                });

                window.addEventListener("afterprint", function () {
                    document.body.classList.remove("printing-invoice");
                    printing = false;
                    const wrapper = document.getElementById("piPrintWrapper");
                    if (wrapper) {
                        wrapper.classList.remove("print-mode-1", "print-mode-2", "print-mode-3");
                        wrapper.querySelectorAll(".pi-print-copy:not(#piPrintArea)").forEach(c => c.remove());
                        // إرجاع منطقة الطباعة لمكانها الأصلي إن كانت نُقلت
                        if (printWrapperParent) {
                            if (printWrapperNext) {
                                printWrapperParent.insertBefore(wrapper, printWrapperNext);
                            } else {
                                printWrapperParent.appendChild(wrapper);
                            }
                            printWrapperParent = null;
                            printWrapperNext = null;
                        }
                    }
                });
            });










                        // =========================
                        // تشغيل
                        // =========================
                        document.addEventListener('click', docCaptureHandler, true);

                        document.addEventListener('DOMContentLoaded', function () {

                            // ✅ أول ما الصفحة تفتح: نضبط الأزرار (فوراً)
                            refreshSideNavButtons();

                            // ✅ أول ما الصفحة تفتح: نضبط Tooltips (الأسهم فقط)
                            setupTooltips();
                            
                            // ✅ تأكد من تحديث data-url مرة أخرى بعد تأخير بسيط (لضمان التحديث)
                            setTimeout(function() {
                                refreshSideNavButtons();
                            }, 100);

                            // ✅ إزالة Tooltip من البحث نهائيًا (Placeholder فقط)
                            const input = document.getElementById('NavInvoiceSearchInput');
                            if (input) {
                                input.removeAttribute('title');
                                // تعليق: placeholder هو اللي هيوضح وظيفة البحث
                                if (!input.getAttribute('placeholder')) input.setAttribute('placeholder', 'بحث برقم الفاتورة');
                            }

                            const btn = document.getElementById('btnNavInvoiceSearch');
                            if (btn) btn.removeAttribute('title');
                        });

                    })();









        </script>
}
