                        @* <div class="card-body p-0"> *@
                        <div class="invoice-lines-container">
                        <div class="erp-table-wrapper mb-0">
                            <table id="PILinesTable" class="table table-sm table-striped table-hover mb-0 erp-table erp-table-sortable">
                                <thead class="invoice-lines-header table-light">
                                    <tr>
                                        <th class="text-center">
                                            <button type="button" class="btn btn-link btn-sm text-dark p-0 si-lines-sort text-decoration-none" data-si-col="0" data-si-kind="num" title="ترتيب حسب رقم السطر"># <span class="erp-sort-icon si-lines-sort-ic" aria-hidden="true"></span></button>
                                        </th>
                                        <th class="text-center">
                                            <button type="button" class="btn btn-link btn-sm text-dark p-0 si-lines-sort text-decoration-none" data-si-col="1" data-si-kind="str" title="ترتيب حسب موقع الصنف">الموقع <span class="erp-sort-icon si-lines-sort-ic" aria-hidden="true"></span></button>
                                        </th>
                                        <th>
                                            <button type="button" class="btn btn-link btn-sm text-dark p-0 si-lines-sort text-decoration-none" data-si-col="2" data-si-kind="str" title="ترتيب أبجدي حسب اسم الصنف">اسم الصنف <span class="erp-sort-icon si-lines-sort-ic" aria-hidden="true"></span></button>
                                        </th>
                                        <th class="text-center">
                                            <button type="button" class="btn btn-link btn-sm text-dark p-0 si-lines-sort text-decoration-none" data-si-col="3" data-si-kind="str" title="ترتيب حسب التشغيلة">التشغيلة <span class="erp-sort-icon si-lines-sort-ic" aria-hidden="true"></span></button>
                                        </th>
                                        <th class="text-center">
                                            <button type="button" class="btn btn-link btn-sm text-dark p-0 si-lines-sort text-decoration-none" data-si-col="4" data-si-kind="date" title="ترتيب حسب الصلاحية">الصلاحية <span class="erp-sort-icon si-lines-sort-ic" aria-hidden="true"></span></button>
                                        </th>
                                        <th class="text-center">
                                            <button type="button" class="btn btn-link btn-sm text-dark p-0 si-lines-sort text-decoration-none" data-si-col="5" data-si-kind="num" title="ترتيب حسب الكمية">الكمية <span class="erp-sort-icon si-lines-sort-ic" aria-hidden="true"></span></button>
                                        </th>
                                        <th class="text-center">
                                            <button type="button" class="btn btn-link btn-sm text-dark p-0 si-lines-sort text-decoration-none" data-si-col="6" data-si-kind="num" title="ترتيب حسب السعر">سعر الجمهور <span class="erp-sort-icon si-lines-sort-ic" aria-hidden="true"></span></button>
                                        </th>
                                        <th class="text-center">
                                            <button type="button" class="btn btn-link btn-sm text-dark p-0 si-lines-sort text-decoration-none" data-si-col="7" data-si-kind="num" title="ترتيب حسب الخصم">خصم البيع % <span class="erp-sort-icon si-lines-sort-ic" aria-hidden="true"></span></button>
                                        </th>
                                        <th class="text-center">
                                            <button type="button" class="btn btn-link btn-sm text-dark p-0 si-lines-sort text-decoration-none" data-si-col="8" data-si-kind="num" title="ترتيب حسب قيمة السطر">قيمة السطر <span class="erp-sort-icon si-lines-sort-ic" aria-hidden="true"></span></button>
                                        </th>
                                    </tr>
                                </thead>

                                <tbody id="PILinesTbody">
                                    @{
                                        var linesList = Model.Lines?.OrderBy(l => l.LineNo).ToList()
                                        ?? new List<ERP.Models.SalesInvoiceLine>();

                                        var groups = linesList
                                        .GroupBy(l => new
                                        {
                                            l.ProdId,
                                            ProdName = l.Product?.ProdName ?? ("صنف #" + l.ProdId)
                                        })
                                        .OrderBy(g => g.Key.ProdName);
                                    }

                                    @if (!groups.Any())
                                    {
                                        <tr>
                                            <td colspan="9" class="text-center text-muted py-3">
                                                لا يوجد سطور داخل الفاتورة حتى الآن.
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var g in groups)
                                        {
                                            int batchCount = g.Count();

                                            if (batchCount == 1)
                                            {
                                                var line = g.First();
                                                decimal lineValue = line.LineTotalAfterDiscount;
                                                var locDisp = string.IsNullOrWhiteSpace(line.Product?.Location) ? "—" : line.Product!.Location!;

                                                <tr class="erp-list-selectable-row" data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                    <td class="text-center">@line.LineNo</td>

                                                    <td class="text-center text-muted small">@locDisp</td>

                                                    <td>
                                                        <strong>@g.Key.ProdName</strong>
                                                        <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                    </td>

                                                    <td class="text-center">@line.BatchNo</td>

                                                    <td class="text-center">
                                                        @(line.Expiry.HasValue? line.Expiry.Value.ToString("yyyy-MM-dd") : "")
                                                    </td>

                                                    <td class="text-center">@line.Qty</td>

                                                    <td class="text-center">@line.PriceRetail.ToString("0.00")</td>

                                                    <td class="text-center">@line.Disc1Percent.ToString("0.##")</td>

                                                    <td class="text-center">@lineValue.ToString("0.00")</td>
                                                </tr>
                                            }
                                            else
                                            {
                                                var grpLocDisp = string.IsNullOrWhiteSpace(g.First().Product?.Location) ? "—" : g.First().Product!.Location!;
                                                <tr class="table-light pi-group-row erp-list-selectable-row" data-prodid="@g.Key.ProdId">
                                                    <td class="text-center">—</td>

                                                    <td class="text-center text-muted small">@grpLocDisp</td>

                                                    <td>
                                                        <strong>@g.Key.ProdName</strong>
                                                        <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                    </td>

                                                    <td class="text-center text-muted small">تشغيلات: @batchCount</td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                </tr>

                                                foreach (var line in g.OrderBy(x => x.LineNo))
                                                {
                                                    decimal lineValue = line.LineTotalAfterDiscount;
                                                    var lineLocDisp = string.IsNullOrWhiteSpace(line.Product?.Location) ? "—" : line.Product!.Location!;

                                                    <tr class="erp-list-selectable-row" data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                        <td class="text-center">@line.LineNo</td>
                                                        <td class="text-center text-muted small">@lineLocDisp</td>
                                                        <td class="text-muted small">↳</td>
                                                        <td class="text-center">@line.BatchNo</td>
                                                        <td class="text-center">
                                                            @(line.Expiry.HasValue? line.Expiry.Value.ToString("yyyy-MM-dd") : "")
                                                        </td>
                                                        <td class="text-center">@line.Qty</td>
                                                        <td class="text-center">@line.PriceRetail.ToString("0.00")</td>
                                                        <td class="text-center">@line.Disc1Percent.ToString("0.##")</td>
                                                        <td class="text-center">@lineValue.ToString("0.00")</td>
                                                    </tr>
                                                }
                                            }
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        </div>
                        @*     </div>
                    </div> *@

                        @* =====================================================
                       6) ملخص الفاتورة
                       ===================================================== *@
                        @{
                            var lines = Model.Lines?.ToList() ?? new List<ERP.Models.SalesInvoiceLine>();

                            int totalLines = lines.Count;
                            int totalItems = lines.Select(l => l.ProdId).Distinct().Count();
                            int totalQty = lines.Sum(l => l.Qty);

                            decimal totalRetail = lines.Sum(l => l.Qty * l.PriceRetail);
                            decimal totalAfterDiscount = Model.TotalAfterDiscountBeforeTax;
                            if (totalAfterDiscount == 0 && lines.Any())
                            {
                                totalAfterDiscount = lines.Sum(l => l.LineTotalAfterDiscount) - Model.HeaderDiscountValue;
                                if (totalAfterDiscount < 0) totalAfterDiscount = 0;
                            }

                            decimal taxAmount = Model.TaxAmount;
                            decimal totalAfterDiscountAndTax = totalAfterDiscount + taxAmount;

                            // الصافي المعروض يعتمد أساسًا على قيمة NetTotal المخزنة في الهيدر
                            // لضمان التطابق مع قائمة الفواتير وأي تقارير أخرى
                            decimal netTotal = Model.NetTotal;
                            if (netTotal == 0 && (totalAfterDiscount != 0 || taxAmount != 0))
                            {
                                netTotal = totalAfterDiscountAndTax;
                            }
                            // نسبة الضريبة المعروضة (للإدخال): من الإجمالي بعد الخصم
                            decimal taxPercentDisplay = totalAfterDiscount > 0 ? Math.Round(taxAmount * 100m / totalAfterDiscount, 2) : 0m;
                        }

                        <div class="card shadow-sm mb-2 invoice-totals-card">
                            <div class="card-body">
                                @* الصف الأول: عدد السطور، عدد الأصناف، إجمالي الكمية، الحساب السابق، المبلغ المتبقى — كلها بوكسات بحدود *@
                                <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-boxes">
                                    <div class="invoice-summary-item invoice-summary-box">
                                        <span class="invoice-summary-label">عدد السطور</span>
                                        <span id="TotalLinesValue" class="invoice-summary-value">@totalLines</span>
                                    </div>
                                    <div class="invoice-summary-item invoice-summary-box">
                                        <span class="invoice-summary-label">عدد الأصناف</span>
                                        <span id="TotalItemsValue" class="invoice-summary-value">@totalItems</span>
                                    </div>
                                    <div class="invoice-summary-item invoice-summary-box">
                                        <span class="invoice-summary-label">إجمالي الكمية</span>
                                        <span id="TotalQtyValue" class="invoice-summary-value">@totalQty</span>
                                    </div>
                                    @{
                                        var previousBalance = hideInvestorSensitive ? 0m : (Model?.SIId > 0 ? (Model?.CustomerBalanceAtSave ?? 0m) : (Model?.Customer?.CurrentBalance ?? 0m));
                                        var creditRemaining = hideInvestorSensitive ? 0m : Math.Max(0m, (Model?.Customer?.CreditLimit ?? 0m) - previousBalance - netTotal);
                                        var grandTotalWithPrevious = hideInvestorSensitive ? totalAfterDiscountAndTax : previousBalance + totalAfterDiscountAndTax;
                                    }
                                    <input type="hidden" id="CustomerPreviousBalanceStored" value="@(hideInvestorSensitive ? "0" : (Model?.CustomerBalanceAtSave ?? 0m).ToString("0.##"))" />
                                    <div class="invoice-summary-item invoice-summary-box">
                                        <span class="invoice-summary-label">الحساب السابق للعميل</span>
                                        <span id="CustomerPreviousBalanceValue" class="invoice-summary-value">@(hideInvestorSensitive ? "—" : previousBalance.ToString("0.00"))</span>
                                    </div>
                                    <div class="invoice-summary-item invoice-summary-box">
                                        <span class="invoice-summary-label">المبلغ المتبقى من الحد الائتماني</span>
                                        <span id="CreditRemainingValue" class="invoice-summary-value">@(hideInvestorSensitive ? "—" : creditRemaining.ToString("0.00"))</span>
                                    </div>
                                </div>

                                @* الصف الثاني: جمهور، إجمالي الفاتورة (بعد خصم السطور/الهيدر)، ضريبة، الإجمالي = صافي الفاتورة + الحساب السابق (قيمة صافي الفاتورة مخفية للسكربت/الطباعة) *@
                                <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-totals mt-3">
                                    <div class="invoice-summary-item invoice-summary-box">
