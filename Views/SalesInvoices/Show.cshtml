                        <a href="@(Model?.CustomerId > 0 ? Url.Action("Show", "Customers", new { id = Model.CustomerId, frame = 1 }) : "#")" id="btnCustomerVolume" class="btn btn-erp btn-erp-outline-secondary btn-erp-sm open-same-tab w-100 text-decoration-none"
                           data-tab-id="customer-engagement"
                           data-tab-title="حجم تعامل عميل"
                           data-url="@(Model?.CustomerId > 0 ? Url.Action("Show", "Customers", new { id = Model.CustomerId, frame = 1 }) : "")"
                           data-keep-active-posted="1">
                            📊 حجم تعامل
                        </a>

                        <div class="dropdown w-100">
                            <button type="button" id="btnPrintInvoiceDropdown"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100 dropdown-toggle"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                🖨️ طباعة الفاتورة
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end w-100" aria-labelledby="btnPrintInvoiceDropdown">
                                <li><a class="dropdown-item" href="#" data-print-mode="1">طباعة صفحة واحدة</a></li>
                                <li><a class="dropdown-item" href="#" data-print-mode="2">طباعة أصل وصورة</a></li>
                                <li><a class="dropdown-item" href="#" data-print-mode="3">طباعة أصل وصورتين</a></li>
