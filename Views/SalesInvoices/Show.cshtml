                        const ProdQtyEl = document.getElementById('ProdQtyInput');
                        const ProdPriceEl = document.getElementById('ProdPriceInput');
                        const ProdDiscEl = document.getElementById('ProdDisc1Input');

                        setVal(ProdIdEl, prodId);
                        setVal(ProdCodeEl, prodId);

                        let prodName = '';
                        const nameCell = row.querySelector('td:nth-child(3)');
                        if (nameCell) {
                            const strong = nameCell.querySelector('strong');
                            prodName = strong ? (strong.innerText || '').trim() : (nameCell.innerText || '').trim();
                        }
                        if (!prodName || prodName === '↳') {
                            const prev = row.previousElementSibling;
                            if (prev && prev.classList.contains('pi-group-row')) {
                                const prevName = prev.querySelector('td:nth-child(3) strong');
                                if (prevName) prodName = (prevName.innerText || '').trim();
                            }
                        }
                        suppressProductDropdownOnce = true;
                        setVal(ProdNameEl, prodName);

                        const isGroupRow = row.classList.contains('pi-group-row');
                        if (isGroupRow) {
                            setVal(ProdBatchEl, '');
                            setVal(ProdExpiryEl, '');
                            setVal(ProdQtyEl, '');
                            setVal(ProdDiscEl, '');
                            if (ProdNameEl) ProdNameEl.focus();
                            return;
                        }

                        // الأعمدة: 0 #, 1 موقع, 2 اسم/↳, 3 تشغيلة, 4 صلاحية, 5 كمية, 6 سعر, 7 خصم, 8 قيمة
                        const batchText = (row.cells[3]?.innerText || '').trim();
                        const expRaw = (row.cells[4]?.innerText || '').trim();
                        const qtyText = (row.cells[5]?.innerText || '').trim();
                        const priceText = (row.cells[6]?.innerText || '').trim();
                        const discText = (row.cells[7]?.innerText || '').trim();

                        let expMMYYYY = expRaw;
                        if (expRaw && expRaw.includes('-')) {
                            const parts = expRaw.split('-');
                            if (parts.length >= 2) expMMYYYY = parts[1] + '/' + parts[0];
                        }

                        setVal(ProdBatchEl, batchText);
                        setVal(ProdExpiryEl, expMMYYYY);
                        setVal(ProdQtyEl, qtyText);
                        setVal(ProdPriceEl, priceText);
                        setVal(ProdDiscEl, discText);

                        if (ProdNameEl) ProdNameEl.focus();
                    });

                        // =========================================================
                        // التابات: حركة الصنف + تعديل بياناته
                        // =========================================================
                        const btnProdMovement = document.getElementById('btnOpenProductMovement'); // متغير: زر حركة الصنف
                        const btnProdEdit     = document.getElementById('btnOpenProductEdit');     // متغير: زر تعديل بيانات الصنف

                        function getCurrentProdId() {
                            if (prodHiddenId && prodHiddenId.value.trim() !== '') return prodHiddenId.value.trim();
                            if (prodCodeInput && prodCodeInput.value.trim() !== '') return prodCodeInput.value.trim();
                            return '';
                        }

                        function openTabFromFrame(url, tabId, title) {
                            try {
                                if (window.top && window.top !== window) {
                                    window.top.postMessage({
                                        type: 'erp-open-tab',
                                        tabId: tabId || '',
                                        title: title || '',
                                        url: url
                                    }, '*');
                                    return;
                                }
                            } catch (e) {
                                console.error('خطأ أثناء استخدام postMessage:', e);
                            }

                            if (window.erpTabs && typeof window.erpTabs.openTab === 'function') {
                                window.erpTabs.openTab(tabId, url, title);
                            } else {
                                window.location.href = url;
                            }
                        }

                        const editBaseUrl     = '@Url.Action("Edit", "Products")'; // متغير: /Products/Edit
                        const movementBaseUrl = '@Url.Action("Show", "Products")'; // متغير: /Products/Show

                        function buildEditUrl(id) {
                            const base = editBaseUrl.replace(/\/$/, '');
                            const params = new URLSearchParams();
                            params.set('frame', '1');
                            return base + '/' + encodeURIComponent(id) + '?' + params.toString();
                        }

                        function buildMovementUrl(id) {
                            const base = movementBaseUrl;
                            const params = new URLSearchParams();
                            params.set('prodId', id);
                            params.set('frame', '1');
                            const sep = base.includes('?') ? '&' : '?';
                            return base + sep + params.toString();
                        }

                        if (btnProdEdit && !btnProdEdit.dataset.boundProdEdit) {
                            btnProdEdit.dataset.boundProdEdit = '1';
                            btnProdEdit.addEventListener('click', function (e) {
                                e.preventDefault();

                                const id = getCurrentProdId();
                                if (!id) {
                                    alert('من فضلك اختر صنفاً أولاً.');
                                    prodNameInput?.focus();
                                    prodNameInput?.select?.();
                                    return;
                                }

                                openTabFromFrame(buildEditUrl(id), 'product-edit-tab', 'تعديل الصنف');
                            });
                        }

                        if (btnProdMovement && !btnProdMovement.dataset.boundProdMove) {
                            btnProdMovement.dataset.boundProdMove = '1';
                            btnProdMovement.addEventListener('click', function (e) {
                                e.preventDefault();

                                const id = getCurrentProdId();
                                if (!id) {
                                    alert('من فضلك اختر صنفاً أولاً.');
                                    prodNameInput?.focus();
                                    prodNameInput?.select?.();
                                    return;
                                }

                                openTabFromFrame(buildMovementUrl(id), 'product-movement-tab', 'حركة الصنف');
                            });
                        }

                        const btnDeleteSelectedLine = document.getElementById('btnDeleteSelectedInvoiceLine');
                        if (btnDeleteSelectedLine && !btnDeleteSelectedLine.dataset.boundDelInvLine) {
                            btnDeleteSelectedLine.dataset.boundDelInvLine = '1';
                            btnDeleteSelectedLine.addEventListener('click', async function (e) {
                                e.preventDefault();
                                const tbody = document.getElementById('PILinesTbody');
                                const selected = tbody ? tbody.querySelector('tr.erp-list-selectable-row.selected') : null;
                                if (!selected) {
                                    alert('من فضلك اضغط على سطر التشغيلة في الجدول أولاً لتحديده ثم اضغط مسح السطر المحدد.');
                                    return;
                                }
                                const lineNo = parseInt(selected.getAttribute('data-line-no') || '0', 10);
                                if (!lineNo || lineNo <= 0) {
                                    alert('سطر المجموعة لا يُمسح من هنا — اختر سطر تشغيلة محدداً (يظهر فيه رقم السطر والكمية).');
                                    return;
                                }
                                if (typeof window.removeInvoiceLineAjax !== 'function') {
                                    alert('تعذّر مسح السطر.');
                                    return;
                                }
                                await window.removeInvoiceLineAjax(lineNo, btnDeleteSelectedLine);
                            });
                        }

                        // أصناف المشتريات الحديثة — نافذة متحركة وقابلة للتكبير/التصغير
                        (function () {
                            const btnRecentPurchaseItems = document.getElementById('btnRecentPurchaseItems');
                            const panelBody = document.getElementById('offcanvasRecentPurchaseItemsBody');
                            const panel = document.getElementById('panelRecentPurchaseItems');
                            const baseUrl = btnRecentPurchaseItems ? btnRecentPurchaseItems.getAttribute('data-base-url') : '';
                            const fromInput = document.getElementById('recentPurchaseFrom');
                            const toInput = document.getElementById('recentPurchaseTo');
                            const btnApply = document.getElementById('btnRecentPurchaseApply');
                            const header = panel ? panel.querySelector('.recent-purchase-panel-header') : null;
                            const resizeHandle = panel ? panel.querySelector('.recent-purchase-panel-resize-handle') : null;

                            function buildUrl() {
                                if (!baseUrl) return baseUrl;
                                const params = new URLSearchParams();
                                params.set('top', '500');
                                if (fromInput && fromInput.value) {
                                    try { params.set('fromDate', new Date(fromInput.value).toISOString()); } catch (e) {}
                                }
                                if (toInput && toInput.value) {
                                    try { params.set('toDate', new Date(toInput.value).toISOString()); } catch (e) {}
                                }
                                const sep = baseUrl.indexOf('?') >= 0 ? '&' : '?';
                                return baseUrl + sep + params.toString();
                            }
                            function loadRecentPurchase() {
                                if (!panelBody || !baseUrl) return;
                                panelBody.innerHTML = '<div class="text-center text-muted py-4">جاري التحميل...</div>';
                                fetch(buildUrl())
                                    .then(function (r) { return r.text(); })
                                    .then(function (html) { panelBody.innerHTML = html; })
                                    .catch(function () { panelBody.innerHTML = '<div class="alert alert-danger m-2">فشل تحميل القائمة.</div>'; });
                            }
                            function setTodayRange() {
                                if (!fromInput || !toInput) return;
                                var now = new Date();
                                var start = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 0, 0, 0);
                                var end = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59);
                                fromInput.value = start.toISOString().slice(0, 16);
                                toInput.value = end.toISOString().slice(0, 16);
                            }
                            if (btnRecentPurchaseItems && panel && panelBody && !btnRecentPurchaseItems.dataset.boundRecentPurchase) {
                                btnRecentPurchaseItems.dataset.boundRecentPurchase = '1';
                                btnRecentPurchaseItems.addEventListener('click', function () {
                                    setTodayRange();
                                    if (!panel.style.left && !panel.style.right) {
                                        panel.style.left = Math.max(20, (window.innerWidth - panel.offsetWidth) / 2) + 'px';
                                        panel.style.top = Math.max(20, (window.innerHeight - panel.offsetHeight) / 2) + 'px';
                                    }
                                    panel.classList.remove('d-none');
                                    loadRecentPurchase();
                                });
                            }
                            if (btnApply && panelBody) {
                                btnApply.addEventListener('click', loadRecentPurchase);
                            }
                            panel && panel.querySelector('.btn-recent-purchase-close') && panel.querySelector('.btn-recent-purchase-close').addEventListener('click', function () { panel.classList.add('d-none'); });
                            // سحب النافذة
                            if (panel && header) {
                                var drag = { active: false, x: 0, y: 0, left: 0, top: 0 };
                                header.addEventListener('mousedown', function (e) {
                                    if (e.target.closest('.btn-recent-purchase-close')) return;
                                    drag.active = true;
                                    drag.x = e.clientX;
                                    drag.y = e.clientY;
                                    var rect = panel.getBoundingClientRect();
                                    drag.left = rect.left;
                                    drag.top = rect.top;
                                });
                                document.addEventListener('mousemove', function (e) {
                                    if (!drag.active) return;
                                    panel.style.left = (drag.left + (e.clientX - drag.x)) + 'px';
                                    panel.style.top = (drag.top + (e.clientY - drag.y)) + 'px';
                                    panel.style.right = 'auto';
                                    panel.style.bottom = 'auto';
                                });
                                document.addEventListener('mouseup', function () { drag.active = false; });
                            }
                            // تكبير/تصغير من الزاوية
                            if (panel && resizeHandle) {
                                var res = { active: false, startW: 0, startH: 0, startX: 0, startY: 0 };
                                resizeHandle.addEventListener('mousedown', function (e) {
                                    e.preventDefault();
                                    res.active = true;
                                    res.startW = panel.offsetWidth;
                                    res.startH = panel.offsetHeight;
                                    res.startX = e.clientX;
                                    res.startY = e.clientY;
                                });
                                document.addEventListener('mousemove', function (e) {
                                    if (!res.active) return;
                                    var dw = e.clientX - res.startX;
                                    var dh = e.clientY - res.startY;
                                    var w = Math.max(380, Math.min(window.innerWidth * 0.95, res.startW + dw));
                                    var h = Math.max(280, Math.min(window.innerHeight * 0.9, res.startH + dh));
                                    panel.style.width = w + 'px';
                                    panel.style.height = h + 'px';
                                });
                                document.addEventListener('mouseup', function () { res.active = false; });
                            }
                        })();

                        // تهيئة: لو في صنف موجود بالفعل في الهيدر (نادر)
                        if (prodHiddenId && prodHiddenId.value) {
                            const opt = findProductByCode(prodHiddenId.value);
                            if (opt) fillProductFromOption(opt);
                        }

                    })(); // نهاية IIFE الأصناف






                    // =========================================================
                    // (C) فوكس + حفظ الهيدر (AJAX) — بدون تكرار
                    // =========================================================
                    document.addEventListener('DOMContentLoaded', () => {

                        // ==========================
                        // 1) فوكس على العميل لو فاتورة جديدة
                        // ==========================
                        const isNewInvoice = @(Model == null || Model.SIId == 0 ? "true" : "false"); // متغير: هل فاتورة جديدة؟
                        if (isNewInvoice) {
                            const custNameInput = document.getElementById('CustomerNameInput'); // متغير: اسم العميل
                            setTimeout(() => {
                                custNameInput?.focus();
                                custNameInput?.select?.();
                            }, 250);
                        }

                        // ==========================
                        // 2) زر حفظ الهيدر (SaveHeader)
                        // ==========================
                        const saveBtn = document.getElementById('btnSaveInvoiceHeader'); // متغير: زر حفظ الفاتورة
                        if (!saveBtn) return;

                        // ✅ ربط مرة واحدة
                        if (saveBtn.dataset.boundSaveHeader) return;
                        saveBtn.dataset.boundSaveHeader = '1';

                        saveBtn.type = 'button'; // تعليق: منع submit الافتراضي

                        let busy = false; // متغير: يمنع الضغط المتكرر

                        saveBtn.addEventListener('click', async (e) => {
                            e.preventDefault();
                            if (busy) return;
                            busy = true;
                            saveBtn.disabled = true;

                            // متغير: رقم الفاتورة الحالي (0 لو جديدة)
                            const invoiceId = parseInt((document.getElementById('InvoiceId')?.value || '0'), 10) || 0;

                            // متغير: كود العميل
                            const customerId = parseInt((document.getElementById('CustomerId')?.value || '0'), 10) || 0;

                            // متغير: كود المخزن
                            const warehouseId = parseInt((document.getElementById('WarehouseId')?.value || '0'), 10) || 0;

                            // متغير: طلب شراء مرجعي (اختياري)
                            let SOId = null;
                            const refPrInput = document.getElementById('SOId'); // متغير: حقل طلب البيع
                            if (refPrInput && refPrInput.value.trim() !== '') {
                                const parsed = parseInt(refPrInput.value.trim(), 10);
                                         if (!isNaN(parsed)) SOId = parsed;
                            }

                            // تحقق: لازم العميل والمخزن
