                            // ✅ للأزرار: نستخدم data-url (يحتوي على URL كامل مع id)
                            // ✅ مهم: نحدث data-url فوراً قبل الاستخدام (لضمان القيم الصحيحة)
                            refreshSideNavButtons();
                            
                            let url = btn.getAttribute('data-url');
                            
                            // ✅ لو data-url غير موجود أو فارغ، نبني URL من data-base-url و data-id
                            if (!url || !url.trim()) {
                                const baseUrl = btn.getAttribute('data-base-url');
                                const btnId = btn.getAttribute('data-id');
                                if (baseUrl && btnId) {
                                    url = setOrReplaceParam(baseUrl, 'id', parseInt(btnId || '0', 10));
                                }
                            }
                            
                            if (!url || !url.trim()) return;

                            loadInvoiceBody(url);
                        }








                        // =========================================================
            // ERP — زر طباعة الفاتورة (قائمة منسدلة: صفحة واحدة / أصل وصورة / أصل وصورتين)
            // =========================================================
            document.addEventListener("DOMContentLoaded", function () {

                const btnPrint = document.getElementById("btnPrintInvoiceDropdown");
                const msg = document.getElementById("postInvoiceMsg");

                if (!btnPrint) return;

                if (btnPrint.dataset.boundPrint) return;
                btnPrint.dataset.boundPrint = "1";

                if (typeof isInvoicePosted === "function" && !isInvoicePosted()) {
                    btnPrint.disabled = true;
                }

                let printing = false;
                let landscapeStyleEl = null;

                function prepareSalesInvoicePrint() {
                    const printArea = document.getElementById("piPrintArea");
                    if (!printArea) return false;

                    const invoiceId = (document.getElementById("InvoiceId")?.value || "").trim();
                    const invoiceDate = (document.getElementById("InvoiceDateDisplay")?.value || document.getElementById("PIDate")?.value || "").trim();
                    const supplierName = (document.getElementById("CustomerNameInput")?.value || "").trim();
                    let warehouseName = "";
                    const whSel = document.getElementById("WarehouseId");
                    if (whSel && whSel.options && whSel.selectedIndex >= 0) {
                        warehouseName = (whSel.options[whSel.selectedIndex].text || "").trim();
                    }

                    const el = (id) => document.getElementById(id);
                    if (el("piPrintNow")) el("piPrintNow").textContent = new Date().toLocaleString();
                    if (el("piPrintTitle")) el("piPrintTitle").textContent = `ERP — فاتورة مبيعات رقم ${invoiceId || ""}`;
                    if (el("piPrintInvoiceNo")) el("piPrintInvoiceNo").textContent = invoiceId || "";
                    if (el("piPrintInvoiceDate")) el("piPrintInvoiceDate").textContent = invoiceDate || "";
                    if (el("piPrintSupplier")) el("piPrintSupplier").textContent = supplierName || "";
                    if (el("piPrintWarehouse")) el("piPrintWarehouse").textContent = warehouseName || "";

                    const linesWrap = el("piPrintLinesWrap");
                    if (!linesWrap) return false;
                    linesWrap.innerHTML = "";
                    const tbody = document.getElementById("PILinesTbody");
                    if (!tbody) {
                        linesWrap.innerHTML = `<div class="text-muted small">لا توجد سطور للطباعة.</div>`;
                    } else {
                        const table = tbody.closest("table");
                        if (!table) {
                            linesWrap.innerHTML = `<div class="text-muted small">تعذر العثور على جدول السطور.</div>`;
                        } else {
                            const clone = table.cloneNode(true);
                            clone.querySelectorAll("button, a, .no-print").forEach(x => x.remove());
                            clone.querySelectorAll("th.no-print, td.no-print").forEach(x => x.remove());
                            linesWrap.appendChild(clone);
                        }
                    }

                    const totalsWrap = el("piPrintTotalsWrap");
                    if (!totalsWrap) return false;
                    const totalLines = el("TotalLinesValue")?.textContent?.trim() || "0";
                    const totalItems = el("TotalItemsValue")?.textContent?.trim() || "0";
                    const totalQty = el("TotalQtyValue")?.textContent?.trim() || "0";
                    const totalRetail = el("TotalRetailValue")?.textContent?.trim() || "0";
                    const totalAfterDiscount = el("TotalAfterDiscountValue")?.textContent?.trim() || "0";
                    const tax = (el("TaxAmountValue")?.textContent || "").trim() || "0";
                    const totalAfterDiscountAndTax = el("TotalAfterDiscountAndTaxValue")?.textContent?.trim() || "0";
                    const netTotal = el("NetTotalValue")?.textContent?.trim() || "0";
                    totalsWrap.innerHTML = `<table><thead><tr><th colspan="4">الإجماليات</th></tr></thead><tbody>
                        <tr><td>عدد السطور</td><td><strong>${totalLines}</strong></td><td>عدد الأصناف</td><td><strong>${totalItems}</strong></td></tr>
                        <tr><td>إجمالي الكمية</td><td><strong>${totalQty}</strong></td><td>إجمالي سعر الجمهور</td><td><strong>${totalRetail}</strong></td></tr>
                        <tr><td>الإجمالي بعد الخصم</td><td><strong>${totalAfterDiscount}</strong></td><td>قيمة الضريبة</td><td><strong>${tax}</strong></td></tr>
                        <tr><td>الإجمالي بعد الخصم والضريبة</td><td><strong>${totalAfterDiscountAndTax}</strong></td><td>الصافي النهائي</td><td><strong>${netTotal}</strong></td></tr>
                    </tbody></table>`;
                    return true;
                }

                function doPrint(mode) {
                    const invoiceId = parseInt((document.getElementById("InvoiceId")?.value || "0"), 10) || 0;
                    if (invoiceId <= 0) {
                        if (msg) { msg.textContent = "⚠️ لا يمكن طباعة فاتورة قبل حفظها."; msg.className = "small mt-2 text-warning"; }
                        return;
                    }
                    if (typeof isInvoicePosted === "function" && !isInvoicePosted()) {
                        if (msg) { msg.textContent = "❌ يجب ترحيل الفاتورة قبل الطباعة"; msg.className = "small mt-2 text-danger"; }
                        document.getElementById("btnPostInvoice")?.focus();
                        return;
                    }
                    if (printing) return;
                    printing = true;

                    if (!prepareSalesInvoicePrint()) {
                        printing = false;
                        if (msg) { msg.textContent = "تعذر تجهيز الطباعة."; msg.className = "small mt-2 text-danger"; }
                        return;
                    }

                    const wrapper = document.getElementById("piPrintWrapper");
                    const printArea = document.getElementById("piPrintArea");
                    if (!wrapper || !printArea) { printing = false; return; }

                    wrapper.classList.remove("print-mode-1", "print-mode-2", "print-mode-3");
                    wrapper.querySelectorAll(".pi-print-copy:not(#piPrintArea)").forEach(c => c.remove());

                    if (mode === 2 || mode === 3) {
                        const copies = mode === 2 ? 2 : 3;
                        for (let i = 1; i < copies; i++) {
                            const clone = printArea.cloneNode(true);
                            clone.id = "";
                            clone.classList.add("pi-print-copy");
                            wrapper.appendChild(clone);
                        }
                        wrapper.classList.add("print-mode-" + mode);
                        landscapeStyleEl = document.createElement("style");
                        landscapeStyleEl.id = "si-print-landscape";
                        landscapeStyleEl.textContent = "@@media print { @@page { size: A4 landscape; margin: 3mm; } }";
                        document.head.appendChild(landscapeStyleEl);
                    } else {
                        wrapper.classList.add("print-mode-1");
                        landscapeStyleEl = document.createElement("style");
                        landscapeStyleEl.id = "si-print-landscape";
                        landscapeStyleEl.textContent = "@@media print { @@page { size: A4 landscape; margin: 3mm; } }";
                        document.head.appendChild(landscapeStyleEl);
                    }

                    document.body.classList.add("printing-invoice");
                    setTimeout(() => window.print(), 50);
                }

                document.querySelectorAll('[data-print-mode]').forEach(item => {
                    item.addEventListener("click", function (e) {
                        e.preventDefault();
                        const mode = parseInt(this.getAttribute("data-print-mode") || "1", 10);
                        doPrint(mode);
                    });
                });

                window.addEventListener("afterprint", function () {
                    document.body.classList.remove("printing-invoice");
                    printing = false;
                    if (landscapeStyleEl && landscapeStyleEl.parentNode) {
                        landscapeStyleEl.remove();
                        landscapeStyleEl = null;
                    }
                    const wrapper = document.getElementById("piPrintWrapper");
                    if (wrapper) {
                        wrapper.classList.remove("print-mode-2", "print-mode-3");
                        wrapper.querySelectorAll(".pi-print-copy:not(#piPrintArea)").forEach(c => c.remove());
                    }
                });
            });










                        // =========================
                        // تشغيل
                        // =========================
                        document.addEventListener('click', docCaptureHandler, true);

                        document.addEventListener('DOMContentLoaded', function () {

                            // ✅ أول ما الصفحة تفتح: نضبط الأزرار (فوراً)
                            refreshSideNavButtons();

                            // ✅ أول ما الصفحة تفتح: نضبط Tooltips (الأسهم فقط)
                            setupTooltips();
                            
                            // ✅ تأكد من تحديث data-url مرة أخرى بعد تأخير بسيط (لضمان التحديث)
                            setTimeout(function() {
                                refreshSideNavButtons();
                            }, 100);

                            // ✅ إزالة Tooltip من البحث نهائيًا (Placeholder فقط)
                            const input = document.getElementById('NavInvoiceSearchInput');
                            if (input) {
                                input.removeAttribute('title');
                                // تعليق: placeholder هو اللي هيوضح وظيفة البحث
                                if (!input.getAttribute('placeholder')) input.setAttribute('placeholder', 'بحث برقم الفاتورة');
                            }

                            const btn = document.getElementById('btnNavInvoiceSearch');
                            if (btn) btn.removeAttribute('title');
                        });

                    })();









