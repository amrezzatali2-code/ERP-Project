@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.SalesInvoice

@{
    // عنوان التاب
    ViewData["Title"] = Model.SIId == 0
        ? "فاتورة مبيعات جديدة"
        : $"فاتورة مبيعات — رقم {Model.SIId}";
    // إخفاء الحساب السابق والحد الائتماني عند عميل مستثمر لمن لا يملك صلاحية رؤية المستثمرين
    var hideInvestorSensitive = ViewBag.HideInvestorSensitiveData as bool? ?? false;
}

@section Styles {
    <style>

        /* =========================================================
           إخفاء أسهم الـ Number Inputs (علشان الشكل ما يتلخبطش)
           - مهم عند فك readonly لأن الأسهم بتظهر وتغيّر شكل السطر
           ========================================================= */
        .pi-input[type="number"]::-webkit-outer-spin-button,
        .pi-input[type="number"]::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .pi-input[type="number"] {
            -moz-appearance: textfield;
        }


        /* ===== نفس تنسيق طلب الشراء: خلفية فاتحة + كروت موحدة + إلغاء الخطوط السميكة ===== */
        .invoice-page {
            background-color: #f3f6fb;
            min-height: 0;
            padding-bottom: 1rem;
        }

        .invoice-page .container-fluid {
            padding: 0;
            max-width: 100%;
        }

        .invoice-page .col-lg-2.order-1 {
            padding: 0.5rem 0.5rem;
        }

        /* حدود الكروت: لون أغمق (#6366f1) مطابق لطلب الشراء وفاتورة المشتريات */
        div.card.invoice-side-card,
        div.card.invoice-header-card,
        div.card.invoice-product-card,
        div.card.invoice-Add-card,
        div.card.invoice-lines-card,
        div.card.invoice-totals-card {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
            overflow: hidden;
        }

        .invoice-side-card {
            background: #ffffff !important;
            min-width: 220px;
        }

        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            border-bottom: none;
            padding: 0.55rem 1rem;
        }

        /* إخفاء الخطوط الفاصلة داخل كارت الإجراءات (مثل طلب الشراء) */
        .invoice-side-card .invoice-actions-bar hr { display: none !important; }

        .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
            border: 1px solid #64748b !important;
        }
        .invoice-side-card .btn-erp + .btn-erp { margin-top: 0.25rem; }

        .invoice-actions-sticky {
            position: sticky;
            top: 58px;
            z-index: 3000;
            background: #ffffff !important;
            border: 1px solid #6366f1 !important;
            padding: 10px 10px !important;
            border-radius: 12px;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
        }
        @@media (max-width: 992px) {
            .invoice-actions-sticky { top: 56px; }
        }

        .invoice-page .invoice-side-card .form-control {
            background: #fff;
            border-color: #64748b;
            color: #0f172a;
        }

        .invoice-page .invoice-side-card .form-control::placeholder {
            color: #6c757d;
        }

        /* قائمة نوع طباعة الفاتورة — نمط ERP */
        .si-print-dropdown-menu {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 8px 28px rgba(99, 102, 241, 0.22) !important;
            padding: 0.35rem 0 !important;
            margin-top: 0.35rem !important;
            overflow: hidden;
            min-width: 100%;
        }
        .si-print-dropdown-header {
            font-weight: 600;
            color: #475569 !important;
            letter-spacing: 0.02em;
        }
        .si-print-dropdown-item {
            display: flex !important;
            align-items: center;
            gap: 0.65rem;
            padding: 0.55rem 1rem !important;
            font-size: 0.9rem;
            font-weight: 500;
            color: #0f172a !important;
            border-radius: 0 !important;
            transition: background-color 0.15s ease, color 0.15s ease;
        }
        .si-print-dropdown-item:hover,
        .si-print-dropdown-item:focus {
            background: linear-gradient(90deg, rgba(99, 102, 241, 0.12) 0%, rgba(14, 165, 233, 0.1) 100%) !important;
            color: #312e81 !important;
        }
        .si-print-opt-icon {
            font-size: 1.15rem;
            line-height: 1;
            flex-shrink: 0;
            opacity: 0.92;
        }
        .si-print-opt-text {
            flex: 1;
            text-align: right;
        }
        .si-print-dropdown-btn.dropdown-toggle::after {
            margin-inline-start: 0.35rem;
        }

        /* ترتيب أعمدة سطور الفاتورة */
        #PILinesTable .si-lines-sort {
            white-space: nowrap;
            font-weight: 600;
            max-width: 100%;
        }
        #PILinesTable .si-lines-sort:focus {
            box-shadow: none;
        }
        #PILinesTable thead .si-lines-sort-ic {
            min-width: 0.65rem;
            display: inline-block;
        }

        /* كارت الإجراءات ثابت عند السكرول — العمود الجانبي نفسه يلتصق فلا يتحرك مع السكرول */
        .invoice-page .col-lg-2.order-1.order-lg-2 {
            align-self: flex-start;
            position: sticky !important;
            top: 70px;
            z-index: 1020;
            height: fit-content;
        }
        html.in-frame .invoice-page .col-lg-2.order-1.order-lg-2 {
            top: 0.5rem;
        }
        .invoice-page .invoice-side-card {
            position: relative;
        }

        /* العمود الرئيسي — بدون سكرول داخلي (سكرول الصفحة فقط) */
        .invoice-page .col-lg-10.order-2 {
            background: transparent;
            padding: 0.5rem 1rem;
        }

        /* حاوية المحتوى */
        #PI_BodyHost {
            display: block;
        }

        /* حاوية جدول السطور — حدود مطابقة لطلب الشراء (#6366f1) */
        .invoice-page .invoice-lines-container {
            display: block;
            margin-top: 0;
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
            overflow: hidden;
            background: #fff;
        }

        .invoice-page .invoice-lines-container .erp-table-wrapper {
            max-height: 360px;
            overflow: auto;
            border: none;
            border-radius: 0;
        }

        /* تمييز الصف المختار: نفس قائمة المبيعات (.erp-list-selectable-row.selected في site.css) */

        .invoice-header-card,
        .invoice-details-card,
        .invoice-lines-card,
        .invoice-totals-card,
        .invoice-Add-card,
        .invoice-product-card {
            border-radius: 1rem;
            overflow: hidden;
            background: #ffffff !important;
        }

        /* إزالة الخط الفاصل السميك بين الكروت (مثل طلب الشراء) */
        .invoice-card-line {
            display: none;
        }

        /* حدود الانبوتات أغمق (#64748b) مثل طلب الشراء */
        #PI_BodyHost .invoice-header-card .form-control,
        #PI_BodyHost .invoice-header-card .form-select,
        #PI_BodyHost .invoice-product-card .form-control,
        #PI_BodyHost .invoice-product-card .form-select,
        #PI_BodyHost .invoice-Add-card .form-control,
        #PI_BodyHost .invoice-Add-card .form-select,
        #PI_BodyHost .invoice-totals-card .form-control,
        #PI_BodyHost .invoice-totals-card .form-select {
            border-color: #64748b !important;
        }

        /* لون النص والتسميات أغمق مثل طلب الشراء */
        .invoice-header-card .card-body .form-label,
        .invoice-header-card .card-body .form-label-sm,
        .invoice-header-card .card-body label {
            color: #0f172a !important;
            font-weight: 500;
        }
        .invoice-header-card .card-body .form-control,
        .invoice-header-card .card-body .form-control-sm,
        .invoice-header-card .card-body .form-select,
        .invoice-header-card .card-body .form-select-sm {
            color: #020617 !important;
        }
        .invoice-product-card .card-body .form-label,
        .invoice-product-card .card-body .form-label-sm,
        .invoice-product-card .card-body label,
        .invoice-product-card .pr-card-field label {
            color: #0f172a !important;
            font-weight: 500;
        }
        .invoice-product-card .card-body .form-control,
        .invoice-product-card .card-body .form-control-sm,
        .invoice-product-card .card-body .form-select,
        .invoice-product-card .pr-card-field .form-control-sm,
        .invoice-product-card .pr-card-field .form-select-sm {
            color: #020617 !important;
        }
        .invoice-Add-card .card-body .form-label,
        .invoice-Add-card .card-body .form-label-sm,
        .invoice-Add-card .card-body label {
            color: #0f172a !important;
            font-weight: 500;
        }
        .invoice-Add-card .card-body .form-control,
        .invoice-Add-card .card-body .form-control-sm,
        .invoice-Add-card .card-body .form-select,
        .invoice-Add-card .card-body .form-select-sm {
            color: #020617 !important;
        }
        .invoice-totals-card .card-body .form-label,
        .invoice-totals-card .card-body label,
        .invoice-totals-card .invoice-summary-item label {
            color: #0f172a !important;
            font-weight: 500;
        }
        /* انبوتات الكارت الأول: حجم مثل الكارت الثالث (كارت الإضافة) */
        #PI_BodyHost .invoice-header-card .form-control,
        #PI_BodyHost .invoice-header-card .form-select {
            border-radius: 0.375rem;
            padding: 0.4rem 0.55rem;
            min-height: 2rem;
            font-size: 0.875rem;
        }
        /* محاذاة النص في المنتصف لكل بوكسات الكارت الأول ما عدا اسم العميل */
        #PI_BodyHost .invoice-header-card .card-body .form-control,
        #PI_BodyHost .invoice-header-card .card-body .form-select {
            text-align: center;
        }
        #PI_BodyHost .invoice-header-card #CustomerNameInput {
            text-align: right !important;
        }
        #PI_BodyHost .invoice-header-card .form-control:focus,
        #PI_BodyHost .invoice-header-card .form-select:focus {
            border-color: #4f46e5 !important;
            box-shadow: none !important;
        }

        /* ===== إبراز بوكس اسم العميل (حد فقط) — wrapper الخاص بالدروب داون ===== */
        #PI_BodyHost .invoice-header-card #customerDropdownWrap {
            border: 2px solid #4f46e5 !important;
            border-radius: 0.55rem !important;
        }
        #PI_BodyHost .invoice-header-card #customerDropdownWrap:focus-within {
            border-color: #4338ca !important;
            box-shadow: none !important;
        }
        /* نلغي تأثير product-dropdown-onebox عند التركيز (لا نريد Shadow/Blue) */
        #PI_BodyHost .invoice-header-card #customerDropdownWrap .product-dropdown-onebox:focus-within {
            box-shadow: none !important;
            border-color: transparent !important;
        }
        #PI_BodyHost .invoice-header-card #customerDropdownWrap .product-dropdown-onebox {
            border: 0 !important;
            background: transparent !important;
            border-radius: 0.45rem !important;
        }
        /* انبوتات الكارت الثاني: حجم مثل الكارت الثالث */
        #PI_BodyHost .invoice-product-card .card-body .form-control,
        #PI_BodyHost .invoice-product-card .card-body .form-control-sm,
        #PI_BodyHost .invoice-product-card .card-body .form-select,
        #PI_BodyHost .invoice-product-card .card-body .form-select-sm {
            padding: 0.4rem 0.55rem;
            min-height: 2rem;
            font-size: 0.875rem;
        }
        #PI_BodyHost .invoice-product-card .form-control,
        #PI_BodyHost .invoice-product-card .form-select,
        #PI_BodyHost .invoice-Add-card .form-control,
        #PI_BodyHost .invoice-Add-card .form-select,
        #PI_BodyHost .invoice-totals-card .form-control,
        #PI_BodyHost .invoice-totals-card .form-select {
            border-radius: 0.375rem;
        }
        #PI_BodyHost .invoice-product-card .form-control:focus,
        #PI_BodyHost .invoice-product-card .form-select:focus,
        #PI_BodyHost .invoice-Add-card .form-control:focus,
        #PI_BodyHost .invoice-Add-card .form-select:focus,
        #PI_BodyHost .invoice-totals-card .form-control:focus,
        #PI_BodyHost .invoice-totals-card .form-select:focus {
            border-color: #64748b !important;
            box-shadow: 0 0 0 0.2rem rgba(100,116,139,.2);
        }

        /* انبوت اسم الصنف: حدود مثل طلب الشراء (#4f46e5) */
        #ProdNameInput.pi-product-name-input,
        .invoice-Add-card #ProdNameInput,
        .invoice-Add-card input#ProdNameInput,
        .invoice-Add-card .pi-product-name-input {
            border: 0 !important; /* هنعتمد على حد wrapper بدلًا من حد الانبوت نفسه */
            border-radius: 0.55rem;
            background: transparent !important;
        }
        .invoice-Add-card #ProdNameInput:focus,
        .invoice-Add-card input#ProdNameInput:focus,
        .invoice-Add-card .pi-product-name-input:focus {
            border-color: #4338ca !important;
            box-shadow: none !important;
        }

        /* ===== إبراز بوكس اسم الصنف (حد wrapper فقط) ===== */
        #PI_BodyHost .invoice-Add-card #productDropdownWrap {
            border: 2px solid #4f46e5 !important;
            border-radius: 0.55rem !important;
            padding: 3px !important;
        }
        #PI_BodyHost .invoice-Add-card #productDropdownWrap:focus-within {
            border-color: #4338ca !important;
            box-shadow: none !important;
        }
        #PI_BodyHost .invoice-Add-card .product-dropdown-onebox {
            border: 0 !important;
            background: transparent !important;
            border-radius: 0.45rem !important;
        }
        #PI_BodyHost .invoice-Add-card .product-dropdown-onebox:focus-within {
            box-shadow: none !important;
            border-color: transparent !important;
        }

        /* بوكس واحد: السهم داخل البوكس على اليسار (حد واحد حول الكل) */
        .product-dropdown-onebox {
            position: relative;
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
            background: #fff;
        }
        .product-dropdown-arrow-inside {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #495057;
            cursor: pointer;
            user-select: none;
            font-size: 0.6rem;
            z-index: 1;
        }
        .product-dropdown-arrow-inside:hover {
            background-color: #e9ecef;
        }
        .product-dropdown-onebox .product-dropdown-input {
            width: 100%;
            border: none !important;
            background: transparent !important;
            padding-left: 2.25rem !important;
        }
        .product-dropdown-onebox .product-dropdown-input:focus {
            box-shadow: none !important;
            outline: none !important;
        }
        .product-dropdown-onebox:focus-within {
            border-color: #0d6efd !important;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
        }
        /* القائمة المنسدلة — تظهر تحت البوكس (position fixed لعدم القص) */
        .product-dropdown-list {
            position: fixed;
            max-height: 220px;
            min-height: 40px;
            overflow-y: auto;
            z-index: 9999;
            margin-top: 2px;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            background: #fff;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        }
        .product-dropdown-list[data-open="false"] {
            display: none !important;
        }
        .product-dropdown-list[data-open="true"] {
            display: block !important;
        }
        #productDropdownWrap {
            overflow: visible !important;
        }
        .invoice-Add-card .card-body {
            overflow: visible !important;
        }
        .product-dropdown-item {
            cursor: pointer;
            border-bottom: 1px solid #f0f0f0;
        }
        .product-dropdown-item:hover {
            background-color: #f8f9fa;
        }
        .product-dropdown-item:last-child {
            border-bottom: none;
        }
        .product-dropdown-item-active {
            background-color: #0d6efd !important;
            color: #fff !important;
        }




        /* شريط الهيدر — بحجم كلمة الأزرار + مسافة أقل */
        .invoice-header-bar {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.35rem 0.75rem;
        }
        .invoice-header-bar h6 {
            margin: 0;
            font-size: 1rem;
            font-weight: 600;
        }

        /* رؤوس الكروت — نفس لون فاتورة المشتريات */
        .invoice-details-card .card-header,
        .invoice-lines-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.55rem 1rem;
        }

        /* صف إضافة الصنف — كل الحقول في صف واحد */
        .invoice-Add-card .row.flex-nowrap {
            flex-wrap: nowrap;
        }


        /* تصغير حقلي الكمية في كارت بيانات الصنف */
        .invoice-product-card #ProdQtyCurrentWarehouse,
        .invoice-product-card #ProdQtyAllWarehouses {
            max-width: 90px;
        }

        /* صف البدائل + الجدول: محاذاة عمودية (بوكس البدائل في منتصف الجدول) + الجدول ينزل قليلاً */
        .invoice-product-card .invoice-product-alternatives-row {
            margin-top: 0.25rem;
            align-items: center;
        }
        .invoice-product-card .invoice-product-alternatives-row .invoice-alternatives-label {
            min-height: 2.1rem;
            display: flex;
            align-items: center;
            margin-bottom: 0.35rem;
        }
        .invoice-product-card .invoice-product-alternatives-row .invoice-batch-table-wrap {
            min-height: 2.5rem;
            margin-top: 0.4rem;
        }

        /* بوكس جدول التشغيلات — حدود مثل البوكسات العادية في الكارت */
        .invoice-product-card .invoice-batch-table-wrap {
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #64748b !important;
            background: #fff;
            box-shadow: 0 1px 2px rgba(0,0,0,.05);
        }
        .invoice-product-card .invoice-batch-table {
            font-size: 0.8rem;
            margin-bottom: 0 !important;
            border-collapse: collapse;
        }
        /* حدود الخلايا مثل البوكسات — لون أغمق */
        .invoice-product-card .invoice-batch-table th,
        .invoice-product-card .invoice-batch-table td {
            border: 1px solid #64748b !important;
            padding: 0.35rem 0.5rem;
        }
        /* هيدر الجدول — لون النص أغمق (#0f172a) */
        .invoice-product-card .invoice-batch-table thead th {
            background: #f1f5f9 !important;
            color: #0f172a !important;
            font-weight: 600;
        }
        .invoice-product-card .invoice-batch-table td {
            color: #0f172a;
            background: #fff;
        }
        .invoice-product-card .invoice-batch-table tbody tr:hover td {
            background-color: rgba(13, 110, 253, 0.04) !important;
        }
        .invoice-product-card .invoice-batch-table tbody tr.table-success td {
            background-color: #d1e7dd !important; /* لون الصف المحدد (FEFO) */
        }

        .invoice-status-badge {
            font-size: 0.8rem;
            padding: 0.3rem 0.7rem;
        }

        /* زر الإضافة — خلفية بيضاء وحدود زرقاء (مثل حجم التعامل) */
        #btnAddInvoiceLine {
            background-color: #fff !important;
            color: #0d6efd !important;
            border: 1.5px solid #0d6efd !important;
        }
        #btnAddInvoiceLine:hover {
            background-color: #0d6efd !important;
            color: #fff !important;
        }

        .badge-status-draft {
            background-color: #6f42c1; /* بنفسجي لمسودة */
        }

        .badge-status-notposted {
            background-color: #343a40; /* غامق لعدم الترحيل */
        }

        .form-label-sm {
            font-size: 0.85rem;
        }

        .invoice-small-input {
            max-width: 150px;
        }

        .customer-summary-line {
            font-size: 0.82rem;
        }

        /* كارت الإجراءات الجانبية: أزرار أرفع شوية */
        .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
        }

        .invoice-side-card .btn-erp + .btn-erp {
            margin-top: 0.15rem;
        }

        .invoice-page .invoice-actions-sticky.d-flex.flex-column.gap-2 {
            gap: 0.25rem !important;
        }

        /* هيدر جدول السطور — مثل قائمة المبيعات (ثابت عند التمرير) */
        .invoice-lines-container .erp-table-wrapper table thead.invoice-lines-header th {
            position: sticky;
            top: 0;
            z-index: 10;
            background-color: #e9ecef !important;
            color: #212529 !important;
            font-weight: 600;
            padding: 0.5rem 0.55rem;
            border: 1px solid #dee2e6 !important;
            box-shadow: 0 1px 0 0 #dee2e6;
        }

        .erp-table-wrapper {
            max-height: 360px;
            overflow: auto;
        }

        /* مسافة بين الكروت (أكبر قليلاً) */
        .invoice-page #PI_BodyHost .invoice-header-card,
        .invoice-page #PI_BodyHost .invoice-product-card,
        .invoice-page #PI_BodyHost .invoice-Add-card,
        .invoice-page .invoice-lines-container,
        .invoice-page #PI_BodyHost .invoice-totals-card {
            margin-bottom: 0.85rem !important;
        }
        /* كارت فاتورة المبيعات بمحاذاة كارت الإجراءات (بدون margin-top) */
        .invoice-page #PI_BodyHost .invoice-header-card {
            margin-top: 0 !important;
        }
        .invoice-page .invoice-lines-container {
            margin-top: 0.85rem;
        }
        .invoice-page .card { margin-bottom: 0.85rem; }
        .invoice-page .card-body { padding: 0.75rem 1rem; }

        /* براح داخل الكروت — تقليل المسافة بين التوب وأول صف في الكارت الأول */
        .invoice-header-card .card-body { padding: 0.45rem 1rem 0.6rem 1rem !important; }
        .invoice-product-card .card-body { padding: 0.75rem 1rem 1rem !important; }
        .invoice-Add-card .card-body { padding: 0.85rem 1rem 1rem !important; }
        .invoice-Add-card .card-body .row.g-1 {
            --bs-gutter-x: 0.6rem;
            --bs-gutter-y: 0.85rem;
        }
        /* حدود بوكسات الأصناف في كارت الإضافة مثل طلب الشراء */
        .invoice-Add-card .card-body .form-control-sm,
        .invoice-Add-card .card-body .form-select-sm {
            border-radius: 0.4rem;
            border: 1px solid #64748b !important;
            padding: 0.4rem 0.55rem;
            font-size: 0.875rem;
            background-color: #fff;
            color: #020617 !important;
        }
        .invoice-Add-card .card-body .form-control-sm:focus,
        .invoice-Add-card .card-body .form-select-sm:focus {
            border-color: #64748b !important;
            box-shadow: 0 0 0 0.2rem rgba(100,116,139,.2);
        }
        .invoice-Add-card .card-body .btn-primary {
            border-radius: 0.4rem;
            padding: 0.4rem 0.75rem;
        }
        .invoice-totals-card .card-body { padding: 0.9rem 1rem !important; }
        .invoice-header-card .card-body .row.g-3 { --bs-gutter-y: 0.6rem; }
        /* مسافة بين الصف الأول والصف الثاني في الكارت الأول */
        .invoice-header-card .card-body .row.g-2 { margin-top: 0.85rem; }
        .invoice-product-card .card-body .row { --bs-gutter-y: 0.5rem; }

        /* مسافة بين سطور جدول الفاتورة */
        .invoice-lines-container .erp-table tbody td,
        .invoice-lines-container .erp-table tbody th { padding: 0.45rem 0.55rem; }
        .invoice-lines-container .erp-table thead th { padding: 0.5rem 0.55rem; }

        .invoice-page .form-label-sm { font-size: 0.8rem; }
        .invoice-page .form-control-sm { padding: 0.2rem 0.4rem; font-size: 0.8rem; }

        .summary-badge {
            min-width: 80px;
            text-align: center;
        }

        /* كارت الإجماليات — نفس درجة طلب الشراء: حجم البوكسات والكلام وغمقان الحدود والنص */
        .invoice-summary-row {
            flex-wrap: wrap;
            gap: 0.35rem 0.5rem;
            align-items: stretch;
            justify-content: space-between;
        }
        .invoice-totals-card .invoice-summary-item.invoice-summary-box {
            flex: 1 1 0;
            min-width: 0;
            max-width: 100%;
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
            align-items: center;
            justify-content: flex-start;
            padding: 0.25rem 0.35rem;
            background: #f8fafc;
            border: 1px solid #64748b;
            border-radius: 6px;
        }
        .invoice-totals-card .invoice-summary-label {
            font-size: 0.8rem;
            line-height: 1.2;
            color: #64748b;
            margin-bottom: 0;
        }
        .invoice-totals-card .invoice-summary-value {
            font-size: 1rem;
            font-weight: 500;
            color: #0f172a;
        }
        .invoice-totals-card .invoice-summary-value-main {
            font-size: 1.05rem;
            color: #fff !important;
        }
        .invoice-summary-tax-input {
            max-width: 75px;
            font-size: 0.95rem;
            text-align: center;
            border: 1px solid #64748b;
            border-radius: 5px;
            padding: 0.25rem 0.35rem;
        }
        .invoice-summary-box-main {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%) !important;
            border-color: #0284c7 !important;
        }
        .invoice-summary-box-main .invoice-summary-label {
            color: rgba(255,255,255,.9);
        }

        /* طباعة الفاتورة: التنسيق الموحد في ~/css/erp-print.css (رأس → سطور → إجماليات؛ صفحة واحدة طولية، 2–3 عرضية) */

        /* حاوية الرسائل العابرة (نظام الرسائل الجديد — بديل postInvoiceMsg) */
        #siToastContainer {
            position: fixed;
            top: 70px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.35rem;
            pointer-events: none;
        }
        #siToastContainer .si-toast {
            padding: 0.6rem 1.2rem;
            border-radius: 8px;
            font-size: 0.9rem;
            box-shadow: 0 2px 8px rgba(0,0,0,.12);
            transition: opacity 0.25s ease;
        }
        #siToastContainer .si-toast.text-success { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
        #siToastContainer .si-toast.text-warning { background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; }
        #siToastContainer .si-toast.text-danger { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
        #siToastContainer .si-toast.text-muted { background: #f1f5f9; color: #334155; border: 1px solid #64748b; }
    </style>
}




<div class="invoice-page" dir="rtl">
    <div id="siToastContainer" aria-live="polite"></div>
    <div class="container-fluid pt-0">

        @* فورم مخفي لتوليد Anti-Forgery Token لاستخدامه في نداءات AJAX *@
        <form id="__AntiForgeryForm" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>

        <div class="row g-3 align-items-start">



            @* =========================
               العمود الجانبي (أزرار الحركة) — ثابت برا الـ BodyHost
               ========================= *@
            <div class="col-12 col-lg-2 order-1 order-lg-2">

                <div class="card shadow-sm invoice-side-card sticky-top">
                    <div class="invoice-header-bar d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h6 class="mb-0">إجراءات فاتورة المبيعات</h6>
                        </div>
                    </div>


                    <!-- =========================================================
                    ثابت: رقم الفاتورة + علم الترحيل (Flag)
                    - InvoiceId: رقم الفاتورة الحالي (0 لو جديدة)
                    - InvoiceIsPostedFlag: 1 لو مترحّلة / 0 لو مفتوحة
                    ========================================================= -->
                    <input type="hidden" id="InvoiceId" value="@Model.SIId" />
                    <input type="hidden" id="InvoiceIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />



                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">

                        @{
                            int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
                            int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
                            int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
                            int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;

                            int currentId = Model?.SIId ?? 0;

                            bool hasAnyInvoices =
                            navFirst.HasValue && navLast.HasValue &&
                            navFirst.Value > 0 && navLast.Value > 0;

                            int? prevEffective = (currentId == 0) ? navLast : navPrev;
                            int? nextEffective = (currentId == 0) ? navFirst : navNext;

                            bool canFirst = hasAnyInvoices && navFirst.HasValue && navFirst.Value > 0 && navFirst.Value != currentId;
                            bool canLast = hasAnyInvoices && navLast.HasValue && navLast.Value > 0 && navLast.Value != currentId;
                            bool canPrev = hasAnyInvoices && prevEffective.HasValue && prevEffective.Value > 0 && prevEffective.Value != currentId;
                            bool canNext = hasAnyInvoices && nextEffective.HasValue && nextEffective.Value > 0 && nextEffective.Value != currentId;
                        }

                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button"
                                    id="btnFirstInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="si-show-tab"
                                    data-tab-title="فاتورة مبيعات"
                                    data-base-url="@Url.Action("Show", "SalesInvoices", new { id = (navFirst ?? 0), frame = 1, includeZeroQty = ViewBag.IncludeZeroQty })"
                                    data-id="@(navFirst ?? 0)"
                                    title="أول فاتورة"
                                    @(canFirst ? "" : "disabled")>
                                ⏮
                            </button>

                            <button type="button"
                                    id="btnPrevInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="si-show-tab"
                                    data-tab-title="فاتورة مبيعات"
                                    data-base-url="@Url.Action("Show", "SalesInvoices", new { id = (prevEffective ?? 0), frame = 1, includeZeroQty = ViewBag.IncludeZeroQty })"
                                    data-id="@(prevEffective ?? 0)"
                                    title="الفاتورة السابقة"
                                    @(canPrev ? "" : "disabled")>
                                ◀
                            </button>

                            <button type="button"
                                    id="btnNextInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="si-show-tab"
                                    data-tab-title="فاتورة مبيعات"
                                    data-base-url="@Url.Action("Show", "SalesInvoices", new { id = (nextEffective ?? 0), frame = 1, includeZeroQty = ViewBag.IncludeZeroQty })"
                                    data-id="@(nextEffective ?? 0)"
                                    title="الفاتورة التالية"
                                    @(canNext ? "" : "disabled")>
                                ▶
                            </button>

                            <button type="button"
                                    id="btnLastInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="si-show-tab"
                                    data-tab-title="فاتورة مبيعات"
                                    data-base-url="@Url.Action("Show", "SalesInvoices", new { id = (navLast ?? 0), frame = 1, includeZeroQty = ViewBag.IncludeZeroQty })"
                                    data-id="@(navLast ?? 0)"
                                    title="آخر فاتورة"
                                    @(canLast ? "" : "disabled")>
                                ⏭
                            </button>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <input type="number"
                                   id="NavInvoiceSearchInput"
                                   class="form-control form-control-sm"
                                   placeholder="بحث برقم الفاتورة" />


                            <button type="button"
                                    id="btnNavInvoiceSearch"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-tab-id="si-show-tab"
                                    data-tab-title="فاتورة مبيعات"
                                    data-base-url="@Url.Action("Show", "SalesInvoices", new { frame = 1 })">
                                بحث
                            </button>
                        </div>

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           data-tab-id="si-show-tab"
                           data-tab-title="فاتورة مبيعات"
                           data-url="@Url.Action("Create", "SalesInvoices", new { frame = 1 })">
                            ➕ فاتورة جديدة
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnSaveInvoiceHeader"
                                data-lock-posted="1">
                            💾 حفظ الفاتورة
                        </button>

                        <button type="button" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" id="btnPostInvoice" data-lock-posted="1">
                            📤 ترحيل الفاتورة
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnOpenInvoice">
                            ⏪ فتح الفاتورة
                        </button>

                        @{
                            var canShowFullReturnBtn = Model?.SIId > 0 && (Model.IsPosted || Model.Status == "مفتوحة للتعديل" || (Model.Status != null && Model.Status.StartsWith("مرحلة")));
                        }
                        @* الزر يُعرض دائماً في DOM ليتحدّث عند التنقل (loadInvoiceBody) *@
                        <div id="fullReturnBtnWrapper" class="@(canShowFullReturnBtn ? "" : "d-none")">
                            <button type="button" class="btn btn-erp btn-erp-outline-warning btn-erp-sm w-100" id="btnCreateFullReturn" data-lock-posted="1">
                                ↩️ مرتجع فاتورة مبيعات بالكامل
                            </button>
                        </div>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnClearInvoiceLines"
                                data-invoice-id="@(Model?.SIId ?? 0)"
                                data-lock-posted="1">
                            🗑️ مسح كل أصناف الفاتورة
                        </button>

                        <div>
                            <button type="button" id="btnOpenProductMovement"
                                    class="btn btn-erp btn-erp-outline-secondary btn-erp-sm w-100">
                                📊 حركة الصنف
                            </button>
                        </div>

                        <button type="button" id="btnDeleteSelectedInvoiceLine"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                data-lock-posted="1"
                                title="يُمسح السطر المحدد في الجدول (اضغط على سطر التشغيلة أولاً)">
                            🗑️ مسح السطر المحدد
                        </button>

                        <div>
                            <button type="button" id="btnOpenProductEdit"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100">
                                ✏️ تعديل بيانات الصنف
                            </button>
                        </div>

                        <button type="button" id="btnRecentPurchaseItems"
                                class="btn btn-erp btn-erp-outline-secondary btn-erp-sm w-100"
                                data-base-url="@Url.Action("GetRecentPurchaseItems", "SalesInvoices")">
                            📋 أصناف المشتريات الحديثة
                        </button>

                        <a href="@(Model?.CustomerId > 0 ? Url.Action("Show", "Customers", new { id = Model.CustomerId, frame = 1 }) : "#")" id="btnCustomerVolume" class="btn btn-erp btn-erp-outline-secondary btn-erp-sm open-same-tab w-100 text-decoration-none"
                           data-tab-id="customer-engagement"
                           data-tab-title="حجم تعامل عميل"
                           data-base-url="@Url.Action("Show", "Customers", new { frame = 1 })"
                           data-keep-active-posted="1">
                            📊 حجم تعامل
                        </a>

                        <div class="dropdown w-100 si-print-dropdown">
                            <button type="button" id="btnPrintInvoiceDropdown"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100 dropdown-toggle si-print-dropdown-btn"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                🖨️ طباعة الفاتورة
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end w-100 si-print-dropdown-menu" aria-labelledby="btnPrintInvoiceDropdown">
                                <li class="si-print-dropdown-header px-3 py-2 small text-muted border-bottom mb-0">اختر نوع الطباعة</li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-print-mode="1"><span class="si-print-opt-icon" aria-hidden="true">📄</span><span class="si-print-opt-text">طباعة صفحة واحدة</span></a></li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-print-mode="2"><span class="si-print-opt-icon" aria-hidden="true">📑</span><span class="si-print-opt-text">طباعة أصل وصورة</span></a></li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-print-mode="3"><span class="si-print-opt-icon" aria-hidden="true">📚</span><span class="si-print-opt-text">طباعة أصل وصورتين</span></a></li>
                            </ul>
                        </div>



                    </div>
                </div>

            </div> @* نهاية العمود الجانبي *@





            @* =========================
               العمود الرئيسي (الهيدر + العميل + الأصناف + السطور + الإجماليات)
               ========================= *@
            <div class="col-12 col-lg-10 order-2 order-lg-1">

                @* ✅ ده الجزء الوحيد اللي هيتبدّل عند التنقل *@
                <div id="PI_BodyHost">

                    @* =========================
                       قيم التنقل + حالة الفاتورة (لازم تكون داخل الـ BodyHost عشان تتحدّث مع frag=body)
                       ========================= *@
                    <input type="hidden" id="BodyHostIsPosted" value="@(Model?.IsPosted == true ? "1" : "0")" />
                    <input type="hidden" id="BodyHostInvoiceStatus" value="@(Model?.Status ?? "")" />
                    <input type="hidden" id="NavFirstId" value="@(ViewBag.NavFirstId ?? 0)" />
                    <input type="hidden" id="NavLastId" value="@(ViewBag.NavLastId ?? 0)" />
                    <input type="hidden" id="NavPrevId" value="@(ViewBag.NavPrevId ?? 0)" />
                    <input type="hidden" id="NavNextId" value="@(ViewBag.NavNextId ?? 0)" />
                    <input type="hidden" id="NavCurrentId" value="@(Model?.SIId ?? 0)" />

                    @* ====================================================
                       1) كارت بيانات فاتورة المبيعات + العميل + المخزن
                       ==================================================== *@
                    <div class="card shadow-sm mb-2 invoice-header-card">

                        @{
                            bool isNewInvoice = Model == null || Model.SIId == 0;
                            bool hasInvoice = !isNewInvoice && Model != null;

                            string invoiceDateText = hasInvoice
                            ? Model!.SIDate.ToString("yyyy/MM/dd")
                            : "";

                            string invoiceTimeText = hasInvoice
                            ? Model!.CreatedAt.ToLocalTime().ToString("HH:mm")
                            : "";
                        }

                        <div class="invoice-header-bar">
                            <h6 class="mb-0">فاتورة مبيعات</h6>
                        </div>

                        <div class="card-body">

                                @* الصف الأول: العميل + رقم الفاتورة + التاريخ والوقت + المخزن + كاتب الفاتورة *@
                                <div class="row g-3 align-items-end">
                                    <div class="col-lg-1 col-md-2">
                                        <label class="form-label form-label-sm">كود العميل</label>
                                        <input id="CustomerCodeDisplay"
                                               class="form-control form-control-sm text-center invoice-small-input"
                                               type="number" data-lock-posted="1" />
                                        <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                                    </div>
                                    <div class="col-lg-4 col-md-3">
                                        <label for="CustomerNameInput" class="form-label form-label-sm">اسم العميل</label>
                                        <div class="position-relative" id="customerDropdownWrap">
                                            <div class="product-dropdown-onebox" id="customerDropdownInputGroup">
                                                <span class="product-dropdown-arrow-inside" id="customerDropdownArrow" title="افتح القائمة">▼</span>
                                                <input id="CustomerNameInput"
                                                       name="CustomerNameInput"
                                                       type="text"
                                                       class="form-control form-control-sm product-dropdown-input"
                                                       placeholder="اكتب اسم العميل"
                                                       autocomplete="off"
                                                       value="@ViewBag.SelectedCustomerName"
                                                       data-lock-posted="1" />
                                            </div>
                                            <div id="customerDropdownList" class="product-dropdown-list" role="listbox" data-open="false"></div>
                                        </div>

                                        <datalist id="customersList" hidden aria-hidden="true">
                                            @if (ViewBag.Customers != null)
                                            {
                                                foreach (var c in ViewBag.Customers)
                                                {
                                                    <option value="@c.Name"
                                                            data-id="@c.Id"
                                                            data-is-active="@(c.IsActive ? "1" : "0")"
                                                            data-phone="@c.Phone"
                                                            data-address="@c.Address"
                                                            data-gov="@c.Gov"
                                                            data-district="@c.District"
                                                            data-area="@c.Area"
                                                            data-credit="@c.Credit"
                                                            data-balance="@(c.CurrentBalance.ToString("0.##"))"
                                                            data-policy-id="@c.PolicyId"
                                                            data-policy-name="@c.PolicyName">
                                                    </option>
                                                }
                                            }
                                        </datalist>
                                        <div id="customerSuspendedMsg" class="small text-danger mt-1 d-none">⚠️ العميل موقوف — لا يمكن حفظ الفاتورة.</div>
                                    </div>
                                    <div class="col-lg-1 col-md-2">
                                        <label class="form-label form-label-sm">رقم الفاتورة</label>
                                        <input type="hidden" id="InvoiceId" value="@(Model?.SIId ?? 0)" />
                                        <input id="InvoiceNumberDisplay"
                                               class="form-control form-control-sm text-center"
                                               value="@(Model != null && Model.SIId > 0 ? Model.SIId.ToString() : "")"
                                               readonly />
                                    </div>
                                    <div class="col-lg-2 col-md-6">
                                        <div class="row g-2">
                                            <div class="col-6">
                                                <label class="form-label form-label-sm">تاريخ الفاتورة</label>
                                                <input id="InvoiceDateDisplay"
                                                       class="form-control form-control-sm text-center"
                                                       value="@invoiceDateText"
                                                       readonly />
                                            </div>
                                            <div class="col-6">
                                                <label class="form-label form-label-sm">وقت الإنشاء</label>
                                                <input id="InvoiceTimeDisplay"
                                                       class="form-control form-control-sm text-center"
                                                       value="@invoiceTimeText"
                                                       readonly />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-2 col-md-2">
                                        <label class="form-label form-label-sm" for="WarehouseId">المخزن</label>
                                        <select asp-for="WarehouseId" asp-items="ViewBag.Warehouses" data-lock-posted="1"
                                                class="form-select form-select-sm" data-is-posted="@(Model?.IsPosted == true ? "1" : "0")">
                                            <option value="">اختر المخزن</option>
                                        </select>
                                    </div>
                                    <div class="col-lg-2 col-md-2">
                                        <label class="form-label form-label-sm">كاتب الفاتورة</label>
                                        <input id="InvoiceCreatedByDisplay" class="form-control form-control-sm text-center"
                                               value="@(Model?.CreatedBy ?? "")" readonly />
                                    </div>
                                </div>

                                <input type="hidden" asp-for="Status" id="InvoiceStatusHidden" />

                                @* الصف الثاني: حالة الفاتورة + سياسة العميل + الهاتف + الحد الائتماني *@
                                <div class="row g-3 align-items-end mt-2">
                                    <div class="col-md-6 col-lg-3">
                                        <label class="form-label form-label-sm">حالة الفاتورة</label>
                                        <input id="InvoiceStatusDisplay" class="form-control form-control-sm text-center" value="@(Model?.Status ?? "غير مرحلة")" readonly />
                                    </div>
                                    <div class="col-md-6 col-lg-3">
