@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.SalesInvoice

@{
    // عنوان التاب
    ViewData["Title"] = Model.SIId == 0
        ? "فاتورة مبيعات جديدة"
        : $"فاتورة مبيعات — رقم {Model.SIId}";
}

@section Styles {
    <style>

        /* =========================================================
           إخفاء أسهم الـ Number Inputs (علشان الشكل ما يتلخبطش)
           - مهم عند فك readonly لأن الأسهم بتظهر وتغيّر شكل السطر
           ========================================================= */
        .pi-input[type="number"]::-webkit-outer-spin-button,
        .pi-input[type="number"]::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .pi-input[type="number"] {
            -moz-appearance: textfield;
        }


        /* ===== نفس تصميم فاتورة المشتريات: خلفية فاتحة + سكرول واحد للصفحة + radius ===== */
        .invoice-page {
            background-color: #f3f6fb;
            min-height: 100vh;
            padding-bottom: 2rem;
        }

        .invoice-page .container-fluid {
            padding: 0;
            max-width: 100%;
        }

        /* الشريط الجانبي — بدون سكرول داخلي (الصفحة كلها تسكرول مرة واحدة) */
        .invoice-page .col-lg-2.order-1 {
            padding: 0.5rem 0.5rem;
        }

        .invoice-side-card {
            background: #ffffff !important;
            border: 1px solid rgba(13,110,253,.12) !important;
            box-shadow: 0 10px 24px rgba(0,0,0,.05) !important;
            border-radius: 1rem;
            overflow: hidden;
        }

        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            border-bottom: none;
            padding: 0.55rem 1rem;
        }

        /* شريط الأزرار: radius مثل فاتورة المشتريات */
        .invoice-actions-sticky {
            position: sticky;
            top: 58px;
            z-index: 3000;
            background: #ffffff !important;
            border: 1px solid rgba(13,110,253,.12) !important;
            padding: 10px 10px !important;
            border-radius: 14px;
            box-shadow: 0 10px 24px rgba(0,0,0,.05) !important;
        }
        @@media (max-width: 992px) {
            .invoice-actions-sticky {
                top: 56px;
            }
        }

        .invoice-page .invoice-side-card .form-control {
            background: #fff;
            border-color: #dee2e6;
            color: #212529;
        }

        .invoice-page .invoice-side-card .form-control::placeholder {
            color: #6c757d;
        }

        .invoice-page .invoice-side-card #postInvoiceMsg {
            color: #212529;
        }

        /* العمود الرئيسي — بدون سكرول داخلي (سكرول الصفحة فقط) */
        .invoice-page .col-lg-10.order-2 {
            background: transparent;
            padding: 0.5rem 1rem;
        }

        /* حاوية المحتوى */
        #PI_BodyHost {
            display: block;
        }

        /* حاوية جدول السطور — ملاصق لكارت الإضافة بدون فاصل رمادي */
        .invoice-page .invoice-lines-container {
            display: block;
            margin-top: 0;
        }

        .invoice-page .invoice-lines-container .erp-table-wrapper {
            max-height: 360px;
            overflow: auto;
            border: none;
            border-radius: 0;
        }

        /* الكروت الرئيسية — شكل حجم التعامل: حدود خفيفة وظل ناعم */
        .invoice-header-card,
        .invoice-details-card,
        .invoice-lines-card,
        .invoice-totals-card,
        .invoice-Add-card,
        .invoice-product-card {
            border-radius: 1rem;
            overflow: hidden;
            background: #ffffff !important;
            border: 1px solid rgba(13, 110, 253, 0.12) !important;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06) !important;
        }






        /* شريط الهيدر — بحجم كلمة الأزرار + مسافة أقل */
        .invoice-header-bar {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.35rem 0.75rem;
        }
        .invoice-header-bar h6 {
            margin: 0;
            font-size: 1rem;
            font-weight: 600;
        }

        /* رؤوس الكروت — نفس لون فاتورة المشتريات */
        .invoice-details-card .card-header,
        .invoice-lines-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.55rem 1rem;
        }

        /* صف إضافة الصنف — كل الحقول في صف واحد */
        .invoice-Add-card .row.flex-nowrap {
            flex-wrap: nowrap;
        }
        /* تقليل المسافة تحت كارت الإضافة — الجدول يلاصق العنوان مباشرة */
        .invoice-Add-card .card-body {
            padding-bottom: 0.35rem;
        }

        /* خط ملون بدل عنوان الكارت (بيانات الصنف + إضافة صنف) — فاصل ضيق */
        .invoice-card-line {
            height: 4px;
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            border-radius: 2px;
            margin-bottom: 0.4rem;
        }

        /* تصغير حقلي الكمية في كارت بيانات الصنف */
        .invoice-product-card #ProdQtyCurrentWarehouse,
        .invoice-product-card #ProdQtyAllWarehouses {
            max-width: 90px;
        }

        /* جدول تشغيلات الصنف — شكل محسّن مثل حجم التعامل */
        .invoice-product-card .invoice-batch-table-wrap {
            max-width: 480px;
            border-radius: 0.5rem;
            overflow: hidden;
            border: 1px solid rgba(13, 110, 253, 0.15);
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
        }
        .invoice-product-card .invoice-batch-table {
            font-size: 0.8rem;
            margin-bottom: 0 !important;
        }
        .invoice-product-card .invoice-batch-table thead th {
            background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%) !important;
            color: #374151;
            font-weight: 600;
            padding: 0.35rem 0.5rem;
            border-bottom: 1px solid rgba(13, 110, 253, 0.2);
        }
        .invoice-product-card .invoice-batch-table td {
            padding: 0.3rem 0.5rem;
        }
        .invoice-product-card .invoice-batch-table tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.04) !important;
        }
        .invoice-product-card .invoice-batch-table tbody tr.table-success {
            background-color: #d1e7dd !important; /* لون الصف المحدد (FEFO) */
        }

        .invoice-status-badge {
            font-size: 0.8rem;
            padding: 0.3rem 0.7rem;
        }

        /* زر الإضافة — خلفية بيضاء وحدود زرقاء (مثل حجم التعامل) */
        #btnAddInvoiceLine {
            background-color: #fff !important;
            color: #0d6efd !important;
            border: 1.5px solid #0d6efd !important;
        }
        #btnAddInvoiceLine:hover {
            background-color: #0d6efd !important;
            color: #fff !important;
        }

        /* أزرار المسح داخل السطور — خلفية بيضاء وحدود حمراء */
        .btnRemoveLineFromInvoice {
            background-color: #fff !important;
            color: #dc3545 !important;
            border: 1.5px solid #dc3545 !important;
        }
        .btnRemoveLineFromInvoice:hover {
            background-color: #dc3545 !important;
            color: #fff !important;
        }

        .badge-status-draft {
            background-color: #6f42c1; /* بنفسجي لمسودة */
        }

        .badge-status-notposted {
            background-color: #343a40; /* غامق لعدم الترحيل */
        }

        .form-label-sm {
            font-size: 0.85rem;
        }

        .invoice-small-input {
            max-width: 150px;
        }

        .customer-summary-line {
            font-size: 0.82rem;
        }

        /* كارت الإجراءات الجانبية: أزرار أرفع شوية */
        .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
        }

        .invoice-side-card .btn-erp + .btn-erp {
            margin-top: 0.15rem;
        }

        .invoice-page .invoice-actions-sticky.d-flex.flex-column.gap-2 {
            gap: 0.25rem !important;
        }

        /* هيدر جدول السطور — لون واحد موحد لجميع العناوين */
        .invoice-lines-container .erp-table-wrapper thead.invoice-lines-header th {
            background-color: #374151 !important;
            color: #ffffff !important;
            border-color: rgba(255,255,255,.25) !important;
            font-weight: 600;
            box-shadow: 0 1px 0 0 rgba(255,255,255,.2);
        }

        .erp-table-wrapper {
            max-height: 360px;
            overflow: auto;
        }

        /* مسافات مناسبة مثل فاتورة المشتريات */
        .invoice-page .card { margin-bottom: 0.5rem; }
        .invoice-page .card-body { padding: 0.75rem 1rem; }
        .invoice-header-card .card-body { padding: 0.5rem 0.75rem 0.35rem 0.75rem; }
        .invoice-page .form-label-sm { font-size: 0.8rem; }
        .invoice-page .form-control-sm { padding: 0.2rem 0.4rem; font-size: 0.8rem; }

        .summary-badge {
            min-width: 80px;
            text-align: center;
        }

        /* صف الإجماليات — توزيع flex + الإجمالي بعد الخصم والضريبة في آخر السطر */
        .invoice-summary-row {
            flex-wrap: wrap;
            gap: 0.75rem 1.25rem !important;
        }
        .invoice-summary-item {
            flex: 1 1 0;
            min-width: 90px;
        }
        .invoice-summary-total {
            flex: 0 0 auto;
            margin-inline-start: auto;
        }
        .invoice-summary-badge {
            font-size: 0.95rem;
            padding: 0.4rem 0.8rem;
            min-width: 78px;
            text-align: center;
            display: inline-block;
        }
        .invoice-summary-tax {
            max-width: 95px;
            font-size: 0.95rem;
        }

        /* =========================================================
                   ERP — Print Template (Purchase Invoice)
                   محلي داخل Show فقط
                ========================================================= */

        /* مخفي في الشاشة */
        .print-only {
            display: none;
        }

        @@media print {
            /* حجم الصفحة — هوامش صغيرة جداً لتشمل الورقة كلها */
            @@page {
                size: A4 landscape;
                margin: 3mm;
            }
            /* يظهر في الطباعة فقط */
            .print-only {
                display: block !important;
            }
            /* طباعة الفاتورة: إخفاء كل شيء وإظهار منطقة الطباعة فقط */
            body.printing-invoice * {
                display: none !important;
            }
            body.printing-invoice #piPrintWrapper,
            body.printing-invoice #piPrintWrapper * {
                display: block !important;
            }
            body.printing-invoice #piPrintWrapper table,
            body.printing-invoice #piPrintWrapper thead,
            body.printing-invoice #piPrintWrapper tbody,
            body.printing-invoice #piPrintWrapper tr,
            body.printing-invoice #piPrintWrapper th,
            body.printing-invoice #piPrintWrapper td {
                display: table !important;
            }
            body.printing-invoice #piPrintWrapper thead { display: table-header-group !important; }
            body.printing-invoice #piPrintWrapper tbody { display: table-row-group !important; }
            body.printing-invoice #piPrintWrapper tr { display: table-row !important; }
            body.printing-invoice #piPrintWrapper th,
            body.printing-invoice #piPrintWrapper td { display: table-cell !important; }
            /* منطقة الطباعة: تملأ الصفحة بالكامل — fixed لتظهر فوق كل المحتوى المخفي */
            body.printing-invoice #piPrintWrapper {
                position: fixed !important;
                top: 0 !important;
                left: 0 !important;
                right: 0 !important;
                bottom: 0 !important;
                width: 100% !important;
                height: 100% !important;
                max-width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
                overflow: visible !important;
                z-index: 99999 !important;
                background: white !important;
            }
            #piPrintWrapper {
                position: relative !important;
                width: 100% !important;
                max-width: 100% !important;
                overflow: visible !important;
            }
            #piPrintArea,
            .pi-print-copy {
                width: 100% !important;
                max-width: 100% !important;
                overflow: visible !important;
            }
            /* مهم: فك أي Scroll أثناء الطباعة */
            .erp-table-wrapper {
                max-height: none !important;
                overflow: visible !important;
            }
            /* تنسيق جدول الطباعة — يملأ الصفحة بحجم أوضح */
            #piPrintArea table,
            .pi-print-copy table {
                width: 100% !important;
                max-width: 100% !important;
                border-collapse: collapse;
                font-size: 12px;
                table-layout: auto;
            }

            #piPrintArea th, #piPrintArea td,
            .pi-print-copy th, .pi-print-copy td {
                border: 1px solid #333;
                padding: 6px 8px;
                vertical-align: middle;
                white-space: normal;
                word-wrap: break-word;
                overflow-wrap: break-word;
            }

            #piPrintArea thead,
            .pi-print-copy thead {
                display: table-header-group;
            }

            #piPrintArea tr,
            .pi-print-copy tr {
                break-inside: avoid;
            }
            /* صفحة واحدة — عرضية، المحتوى يملأ الصفحة بحجم واضح */
            .print-mode-1 #piPrintArea {
                font-size: 14px !important;
                padding: 0 !important;
            }
            .print-mode-1 #piPrintArea .mb-3,
            .print-mode-1 #piPrintArea .small {
                font-size: 12px !important;
            }
            .print-mode-1 #piPrintArea table {
                font-size: 13px !important;
            }
            /* أصل وصورة: صفحة عرضية مقسومة لقسمين */
            .print-mode-2 {
                display: grid !important;
                grid-template-columns: 1fr 1fr;
                gap: 0.5rem;
                width: 100% !important;
            }
            .print-mode-2 .pi-print-copy {
                break-inside: avoid;
                min-width: 0 !important;
                max-width: 100% !important;
                overflow: hidden !important;
                transform: scale(0.9);
                transform-origin: top center;
                font-size: 9px !important;
            }
            .print-mode-2 .pi-print-copy table {
                font-size: 9px !important;
            }
            .print-mode-2 .pi-print-copy th,
            .print-mode-2 .pi-print-copy td {
                padding: 2px 4px !important;
            }
            .print-mode-2 .pi-print-copy .mb-3,
            .print-mode-2 .pi-print-copy .small {
                font-size: 8px !important;
            }
            /* أصل وصورتين: صفحة عرضية مقسومة لثلاثة أقسام */
            .print-mode-3 {
                display: grid !important;
                grid-template-columns: 1fr 1fr 1fr;
                gap: 0.25rem;
                width: 100% !important;
            }
            .print-mode-3 .pi-print-copy {
                break-inside: avoid;
                min-width: 0 !important;
                max-width: 100% !important;
                overflow: hidden !important;
                transform: scale(0.75);
                transform-origin: top center;
                font-size: 7px !important;
            }
            .print-mode-3 .pi-print-copy table {
                font-size: 7px !important;
            }
            .print-mode-3 .pi-print-copy th,
            .print-mode-3 .pi-print-copy td {
                padding: 1px 3px !important;
            }
            .print-mode-3 .pi-print-copy .mb-3,
            .print-mode-3 .pi-print-copy .small {
                font-size: 6px !important;
            }
        }

    </style>
}




<div class="invoice-page" dir="rtl">
    <div class="container-fluid pt-0">

        @* فورم مخفي لتوليد Anti-Forgery Token لاستخدامه في نداءات AJAX *@
        <form id="__AntiForgeryForm" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>

        <div class="row g-3 align-items-start">



            @* =========================
               العمود الجانبي (أزرار الحركة) — ثابت برا الـ BodyHost
               ========================= *@
            <div class="col-12 col-lg-2 order-1 order-lg-2">

                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 0;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">الأزرار</h6>
                    </div>


                    <!-- =========================================================
                    ثابت: رقم الفاتورة + علم الترحيل (Flag)
                    - InvoiceId: رقم الفاتورة الحالي (0 لو جديدة)
                    - InvoiceIsPostedFlag: 1 لو مترحّلة / 0 لو مفتوحة
                    ========================================================= -->
                    <input type="hidden" id="InvoiceId" value="@Model.SIId" />
                    <input type="hidden" id="InvoiceIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />



                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">

                        @{
                            int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
                            int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
                            int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
                            int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;

                            int currentId = Model?.SIId ?? 0;

                            bool hasAnyInvoices =
                            navFirst.HasValue && navLast.HasValue &&
                            navFirst.Value > 0 && navLast.Value > 0;

                            int? prevEffective = (currentId == 0) ? navLast : navPrev;
                            int? nextEffective = (currentId == 0) ? navFirst : navNext;

                            bool canFirst = hasAnyInvoices && navFirst.HasValue && navFirst.Value > 0 && navFirst.Value != currentId;
                            bool canLast = hasAnyInvoices && navLast.HasValue && navLast.Value > 0 && navLast.Value != currentId;
                            bool canPrev = hasAnyInvoices && prevEffective.HasValue && prevEffective.Value > 0 && prevEffective.Value != currentId;
                            bool canNext = hasAnyInvoices && nextEffective.HasValue && nextEffective.Value > 0 && nextEffective.Value != currentId;
                        }

                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button"
                                    id="btnFirstInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="si-show-tab"
                                    data-tab-title="فاتورة مبيعات"
                                    data-base-url="@Url.Action("Show", "SalesInvoices", new { id = (navFirst ?? 0), frame = 1, includeZeroQty = ViewBag.IncludeZeroQty })"
                                    data-id="@(navFirst ?? 0)"
                                    title="أول فاتورة"
                                    @(canFirst ? "" : "disabled")>
                                ⏮
                            </button>

                            <button type="button"
                                    id="btnPrevInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="si-show-tab"
                                    data-tab-title="فاتورة مبيعات"
                                    data-base-url="@Url.Action("Show", "SalesInvoices", new { id = (prevEffective ?? 0), frame = 1, includeZeroQty = ViewBag.IncludeZeroQty })"
                                    data-id="@(prevEffective ?? 0)"
                                    title="الفاتورة السابقة"
                                    @(canPrev ? "" : "disabled")>
                                ◀
                            </button>

                            <button type="button"
                                    id="btnNextInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="si-show-tab"
                                    data-tab-title="فاتورة مبيعات"
                                    data-base-url="@Url.Action("Show", "SalesInvoices", new { id = (nextEffective ?? 0), frame = 1, includeZeroQty = ViewBag.IncludeZeroQty })"
                                    data-id="@(nextEffective ?? 0)"
                                    title="الفاتورة التالية"
                                    @(canNext ? "" : "disabled")>
                                ▶
                            </button>

                            <button type="button"
                                    id="btnLastInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="si-show-tab"
                                    data-tab-title="فاتورة مبيعات"
                                    data-base-url="@Url.Action("Show", "SalesInvoices", new { id = (navLast ?? 0), frame = 1, includeZeroQty = ViewBag.IncludeZeroQty })"
                                    data-id="@(navLast ?? 0)"
                                    title="آخر فاتورة"
                                    @(canLast ? "" : "disabled")>
                                ⏭
                            </button>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <input type="number"
                                   id="NavInvoiceSearchInput"
                                   class="form-control form-control-sm"
                                   placeholder="بحث برقم الفاتورة" />


                            <button type="button"
                                    id="btnNavInvoiceSearch"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-tab-id="si-show-tab"
                                    data-tab-title="فاتورة مبيعات"
                                    data-base-url="@Url.Action("Show", "SalesInvoices", new { frame = 1 })">
                                بحث
                            </button>
                        </div>

                        <hr class="my-1" />

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           data-tab-id="si-show-tab"
                           data-tab-title="فاتورة مبيعات"
                           data-url="@Url.Action("Create", "SalesInvoices", new { frame = 1 })">
                            ➕ فاتورة جديدة
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnSaveInvoiceHeader"
                                data-lock-posted="1">
                            💾 حفظ الفاتورة
                        </button>

                        <button type="button" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" id="btnPostInvoice" data-lock-posted="1">
                            📤 ترحيل الفاتورة
                        </button>

                        <div id="postInvoiceMsg" class="small mt-2"></div>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnOpenInvoice">
                            ⏪ فتح الفاتورة
                        </button>

                        @{
                            var canShowFullReturnBtn = Model?.SIId > 0 && (Model.IsPosted || Model.Status == "مفتوحة للتعديل" || (Model.Status != null && Model.Status.StartsWith("مرحلة")));
                        }
                        @* الزر يُعرض دائماً في DOM ليتحدّث عند التنقل (loadInvoiceBody) *@
                        <div id="fullReturnBtnWrapper" class="@(canShowFullReturnBtn ? "" : "d-none")">
