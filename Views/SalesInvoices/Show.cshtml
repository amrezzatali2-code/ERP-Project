             // =========================================================
            // ✅ نظام حماية من تداخل طلبات التحديث (Race Condition)
            // - أي Refresh قديم يرجع متأخر لا يغيّر الشاشة
            // =========================================================
          let __productInfoReqSeq = 0;         // متغير: رقم تسلسلي لآخر طلب
            let __productInfoAbort = null;       // متغير: لإلغاء الطلب السابق لو شغال





            // =========================================================
            // ✅ دالة: تحديث بيانات الصنف بعد الإضافة / أو بعد اختيار الصنف
            // =========================================================
            async function refreshProductInfoAfterAddLine(prodId) {

                const pid = parseInt((prodId || '0').toString(), 10) || 0;
                if (pid <= 0) return;

                const whEl = document.getElementById('WarehouseId');
                const warehouseId = whEl ? (parseInt(whEl.value || '0', 10) || 0) : 0;
                if (warehouseId <= 0) return;

                // ✅ ارفع رقم الطلب
                const mySeq = ++__productInfoReqSeq;

                // ✅ الغي أي طلب سابق شغال
                try { if (__productInfoAbort) __productInfoAbort.abort(); } catch { }
                __productInfoAbort = new AbortController();

                // ✅ كسر الكاش + منع التخزين (مع customerId لتطبيق سياسة المجموعة الصحيحة)
                const customerId = parseInt((document.getElementById('CustomerId')?.value || '0'), 10) || 0;
                const url = `/SalesInvoices/GetSalesProductInfo?prodId=${pid}&warehouseId=${warehouseId}&customerId=${customerId}&_ts=${Date.now()}`;

                try {
                    const resp = await fetch(url, {
                        method: 'GET',
                        cache: 'no-store', // ✅ مهم جدًا
                        headers: { 'Accept': 'application/json', 'Cache-Control': 'no-cache' },
                        signal: __productInfoAbort.signal
                    });

                    if (!resp.ok) return;

                    const info = await resp.json();

                    // ✅ لو ده مش آخر طلب.. تجاهله
                    if (mySeq !== __productInfoReqSeq) return;

                    if (!info || info.ok === false) return;

                    // =========================
                    // 1) تحديث بوكسات بيانات الصنف (IDs الصحيحة عندك)
                    // =========================
                    const qtyWhBox = document.getElementById('ProdQtyCurrentWarehouse');
                    if (qtyWhBox) qtyWhBox.value = (info.qtyCurrentWarehouse ?? 0).toString();

                    const qtyAllBox = document.getElementById('ProdQtyAllWarehouses');
                    if (qtyAllBox) qtyAllBox.value = (info.qtyAllWarehouses ?? 0).toString();

                    const quotaBox = document.getElementById('ProdQuotaText');
                    if (quotaBox) quotaBox.value = (info.quotaText ?? 'بدون كوتة').toString();

                    const bonusBox = document.getElementById('ProdBonusText');
                    if (bonusBox) bonusBox.value = (info.bonusText ?? 'بدون بونص').toString();

                    const groupBox = document.getElementById('ProdGroupText');
                    if (groupBox) groupBox.value = (info.productGroupName ?? 'بدون مجموعة').toString();

                    const groupPolicyBox = document.getElementById('ProdGroupPolicyText');
                    if (groupPolicyBox) groupPolicyBox.value = (info.appliedGroupPolicyName ?? info.appliedGroupPolicyId ?? '').toString() || '—';

                    const wdBox = document.getElementById('ProdWeightedDiscount');
                    if (wdBox) {
                        const wd = Number(info.weightedDiscount ?? 0);
                        wdBox.value = (Number.isFinite(wd) && wd >= 0 && wd <= 100) ? Number(wd).toFixed(2) : '0.00';
                    }

                    // =========================
                    // 2) تحديث جدول التشغيلات (BatchQueueBody)
                    // =========================
                    const batchesTbody = document.getElementById('BatchQueueBody');
                    if (batchesTbody && Array.isArray(info.batches)) {

                        batchesTbody.innerHTML = '';

                        if (info.batches.length === 0) {
                            batchesTbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted">لا توجد تشغيلات بعد.</td></tr>`;
                        } else {
                            info.batches.forEach((b, i) => {
                                const role = (b.role != null) ? b.role : (i + 1);

                                const tr = document.createElement('tr');

                                // ✅ هنا مصدر اللون الأخضر
                                     //if (isAuto) tr.classList.add('table-success');

                                tr.innerHTML = `
                                    <td class="text-center">${role}</td>
                                    <td class="text-center">${escapeHtml(b.batchNo || '')}</td>
                                    <td class="text-center">${escapeHtml(b.expiryText || '')}</td>
                                    <td class="text-center">${Number(b.qty ?? 0)}</td>  

                                    <td class="text-center">${fmt2(b.priceRetailBatch || 0)}</td>
                                `;
                                batchesTbody.appendChild(tr);
                            });
                        }
                    }

                } catch (err) {
                    // لو اتلغى بسبب AbortController مش مشكلة
                    if (err?.name !== 'AbortError') console.error('refreshProductInfoAfterAddLine error:', err);
                }
            }



                     // =========================================================
                    // إضافة سطر (AJAX) — مع حماية من أخطاء الدوال غير المعرفة
                    // =========================================================
                    async function addLineAjax() {

                        // 1) لازم يكون عندنا رقم فاتورة محفوظ
                        const invoiceIdInput = document.getElementById('InvoiceId'); // متغير: Hidden رقم الفاتورة
                        const invoiceId = invoiceIdInput ? parseInt(invoiceIdInput.value || '0', 10) : 0;

                        if (!invoiceId || invoiceId <= 0) {
                            alert('لا يمكن إضافة أصناف قبل حفظ الفاتورة. اضغط "حفظ الفاتورة" أولاً.');
                            document.getElementById('btnSaveInvoiceHeader')?.focus(); // متغير: زر حفظ الهيدر
                            return;
                        }

                        // 2) قراءة بيانات السطر
                        const prodId = prodHiddenId ? parseInt(prodHiddenId.value || '0', 10) : 0; // متغير: ProdId
                        const qty = prodQtyInput ? parseInt(prodQtyInput.value || '0', 10) : 0;     // متغير: الكمية

                        const priceRetail = prodPriceInput ? parseDecimalSafe(prodPriceInput.value) : 0; // متغير: سعر الجمهور
                        const purchaseDiscountPct = prodDisc1Input ? parseDecimalSafe(prodDisc1Input.value) : 0; // متغير: خصم البيع %

                        const batchNo = prodBatchInput ? (prodBatchInput.value || '').trim() : '';       // متغير: التشغيلة
                        const expiryText = prodExpiryInput ? (prodExpiryInput.value || '').trim() : '';  // متغير: الصلاحية

                        // 3) تحقق قبل الإرسال
                        if (!prodId || prodId <= 0) {
                            alert('من فضلك اختر صنفاً صحيحاً من القائمة.');
                            prodNameInput?.focus();
                            prodNameInput?.select?.();
                            return;
                        }

                        if (!qty || qty <= 0) {
                            alert('الكمية يجب أن تكون أكبر من صفر.');
                            prodQtyInput?.focus();
                            prodQtyInput?.select?.();
                            return;
                        }

                        // 4) تجهيز DTO
                        const dto = {
                            id: invoiceId,
                            siId: invoiceId,
                            invoiceId: invoiceId,

                            prodId: prodId,
                            qty: qty,

                            unitCost: 0,
                            priceRetail: priceRetail,
                            purchaseDiscountPct: purchaseDiscountPct,

                            batchNo: batchNo,
                            expiryText: expiryText
                        };

                        // 5) استدعاء السيرفر
                        const token = getAntiForgeryToken();

                        if (btnAddLine) btnAddLine.disabled = true; // تعليق: منع الضغط المتكرر

                        try {

                            const resp = await fetch('@Url.Action("AddLineJson", "SalesInvoices")', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'RequestVerificationToken': token
                                },
                                body: JSON.stringify(dto)
                            });

                            // لو السيرفر رجّع خطأ HTTP (مثل 400 BadRequest)
                            if (!resp.ok) {
                                const errTxt = await resp.text().catch(() => '');
                                let errMsg = 'حدث خطأ أثناء إضافة السطر.';
                                try {
                                    const errJson = errTxt ? JSON.parse(errTxt) : null;
                                    if (errJson && (errJson.message || errJson.error))
                                        errMsg = errJson.message || errJson.error;
                                } catch (_) { }
                                alert(errMsg);
                                return;
                            }

                            // نقرأ الرد كنص ثم JSON (أكثر أماناً)
                            const raw = await resp.text();
                            const rawTrim = (raw || '').trim();

                            if (rawTrim.startsWith('<')) {
                                console.error('AddLineJson رجّع HTML بدل JSON:', rawTrim.substring(0, 300));
                                alert('السيرفر رجّع HTML بدل JSON. راجع AddLineJson في الكنترولر.');
                                return;
                            }

                            let data = null; // متغير: بيانات الرد
                            try {
                                data = rawTrim ? JSON.parse(rawTrim) : null;
                            } catch (e) {
                                console.error('فشل تحويل الرد إلى JSON:', e, rawTrim.substring(0, 300));
                                alert('الرد من السيرفر ليس JSON.');
                                return;
                            }

                            // نجاح قد يكون ok أو success حسب السيرفر
                            const isOk = !!(data && (data.ok === true || data.success === true));
                            if (!isOk) {
                                alert((data && data.message) ? data.message : 'تعذر إضافة السطر.');
                                return;
                            }

                            // =========================================================
                            // 6) تحديث الجدول + الملخص (بدون ما نكسر الكود لو دالة ناقصة)
                            // =========================================================
                            try {

                                // السيرفر عندك بيرجع lines غالباً
                                if (Array.isArray(data.lines)) {
                                    window.__piLinesCache = data.lines; // متغير: حفظ آخر سطور
                                    if (typeof renderGroupedLines === 'function') {
                                        renderGroupedLines(data.lines);
                                    } else {
                                        console.warn('renderGroupedLines غير معرفة وقت التنفيذ.');
                                    }
                                } else if (data.line) {
                                    window.__piLinesCache = window.__piLinesCache || [];
                                    window.__piLinesCache.push(data.line);
                                    if (typeof renderGroupedLines === 'function') {
                                        renderGroupedLines(window.__piLinesCache);
                                    }
                                }

                                if (data.totals && typeof updateSummaryBadges === 'function') {
                                    updateSummaryBadges(data.totals);
                                }

                                         

                            } catch (uiErr) {
                                // تعليق: لو حصل خطأ في تحديث الواجهة، ما نعتبره مشكلة سيرفر
                                console.error('UI Update Error after AddLineJson:', uiErr);
                                alert('تمت الإضافة في السيرفر، لكن حدث خطأ أثناء تحديث الجدول في الصفحة. راجع Console.');
                            }
          



             // =========================================================
            // 6.5) ✅ تحديث بيانات الصنف بعد الإضافة (منفصل عن تحديث الجدول)
            // - علشان لو renderGroupedLines غلط ما يمنعش التحديث
            // =========================================================
            try {
                await refreshProductInfoAfterAddLine(prodId); // متغير: رقم الصنف الذي تم إضافته
            } catch (e) {
                console.warn('refreshProductInfoAfterAddLine failed:', e);
            }

                            // 6.6) ✅ تحديث قائمة الأصناف في الداتاليست — عند "أصناف لها رصيد فقط" الصنف اللي رصيده خلص يختفي
                            try {
                                if (typeof refreshProductsDatalist === 'function') await refreshProductsDatalist();
                            } catch (e) {
                                console.warn('refreshProductsDatalist failed:', e);
                            }

                            // لا نغيّر الصنف المكتوب بعد الإضافة (نترك اسم الصنف كما هو، مثل طلب الشراء)

                            // =========================================================
                            // 7) تنظيف الخانات + فوكس على اسم الصنف
                            // =========================================================
                            if (prodQtyInput) prodQtyInput.value = '';
                            if (prodBatchInput) prodBatchInput.value = '';
                            if (prodExpiryInput) prodExpiryInput.value = '';

                            // فوكس على اسم الصنف (مش الكود)
                            document.getElementById('ProdNameInput')?.focus();
                            document.getElementById('ProdNameInput')?.select?.();

                        } catch (err) {
                            // ✅ هنا هنطلع السبب الحقيقي بدل رسالة عامة
                            console.error('AddLineAjax Exception:', err);
                            alert('حدث خطأ داخل الجافاسكربت أثناء الإضافة: ' + (err?.message || err));
                        } finally {
                            if (btnAddLine) btnAddLine.disabled = false;
                        }
                    }

                    // ✅ ربط زر "إضافة" مرة واحدة فقط
                    if (btnAddLine && !btnAddLine.dataset.boundAddLine) {
                        btnAddLine.dataset.boundAddLine = '1';
                        btnAddLine.type = 'button';
                        btnAddLine.addEventListener('click', function (e) {
                            e.preventDefault();
                            addLineAjax();
                        });
                    }

                    // =========================================================
                    // النقر على سطر في جدول السطور → تعبئة انبوت الأصناف (مثل طلب الشراء)
                    // =========================================================
                    document.addEventListener('click', function (e) {
                        const row = e.target.closest('#PILinesTbody tr.erp-list-selectable-row[data-prodid]');
                        if (!row) return;
                        if (e.target.closest('a')) return;

                        const prodId = (row.getAttribute('data-prodid') || '').trim();
                        if (!prodId) return;

                        const tbody = document.getElementById('PILinesTbody');
                        if (tbody) {
                            tbody.querySelectorAll('tr.erp-list-selectable-row').forEach(r => r.classList.remove('selected'));
                        }
                        row.classList.add('selected');

                        function setVal(el, value) {
                            if (!el) return;
                            el.value = value ?? '';
                            el.dispatchEvent(new Event('input', { bubbles: true }));
                            el.dispatchEvent(new Event('change', { bubbles: true }));
                        }

                        const ProdIdEl = document.getElementById('ProdId');
                        const ProdNameEl = document.getElementById('ProdNameInput');
                        const ProdCodeEl = document.getElementById('ProdCodeInput');
