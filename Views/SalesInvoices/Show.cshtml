            // الضريبة كنسبة من الإجمالي بعد الخصم — إعادة حساب العرض عند تغيير النسبة
            function recalcTaxFromPercent() {
                const percentInp = document.getElementById('TaxPercentInput');
                const totalAfterEl = document.getElementById('TotalAfterDiscountValue');
                const taxAmountEl = document.getElementById('TaxAmountValue');
                const totalAndTaxEl = document.getElementById('TotalAfterDiscountAndTaxValue');
                const netEl = document.getElementById('NetTotalValue');
                const grandEl = document.getElementById('GrandTotalWithPreviousValue');
                const prevBalanceEl = document.getElementById('CustomerPreviousBalanceValue');
                const creditRemEl = document.getElementById('CreditRemainingValue');
                const creditLimitEl = document.getElementById('CustomerCredit');

                const totalAfterDiscount = parseDecimalSafe(totalAfterEl?.textContent || 0);
                const taxPercent = parseDecimalSafe(percentInp?.value || 0);
                const taxAmount = Math.round(totalAfterDiscount * (taxPercent / 100) * 100) / 100;
                const totalAfterDiscountAndTax = Math.round((totalAfterDiscount + taxAmount) * 100) / 100;

                if (taxAmountEl) taxAmountEl.textContent = fmt2(taxAmount);
                if (totalAndTaxEl) totalAndTaxEl.textContent = fmt2(totalAfterDiscountAndTax);
                if (netEl) netEl.textContent = fmt2(totalAfterDiscountAndTax);
                if (grandEl) {
                    const prevTxt = (prevBalanceEl && prevBalanceEl.textContent) ? prevBalanceEl.textContent.trim() : '';
                    const hidePrev = prevTxt === '' || prevTxt === '—';
                    const invoiceId = parseInt(document.getElementById('InvoiceId')?.value || '0', 10);
                    const prevStoredEl = document.getElementById('CustomerPreviousBalanceStored');
                    const custBalanceEl = document.getElementById('CustomerCurrentBalance');
                    const balanceToUse = (invoiceId > 0 && prevStoredEl) ? parseDecimalSafe(prevStoredEl.value) : parseDecimalSafe(custBalanceEl?.value || '0');
                    const g = hidePrev ? totalAfterDiscountAndTax : (balanceToUse + totalAfterDiscountAndTax);
                    grandEl.textContent = fmt2(g);
                }
                if (creditRemEl && creditLimitEl) {
                    const invoiceId = parseInt(document.getElementById('InvoiceId')?.value || '0', 10);
                    const prevStoredEl = document.getElementById('CustomerPreviousBalanceStored');
                    const custBalanceEl2 = document.getElementById('CustomerCurrentBalance');
                    const balanceToUse = (invoiceId > 0 && prevStoredEl) ? parseDecimalSafe(prevStoredEl.value) : parseDecimalSafe(custBalanceEl2?.value || '0');
                    const remaining = Math.max(0, parseDecimalSafe(creditLimitEl.value) - balanceToUse - totalAfterDiscountAndTax);
                    creditRemEl.textContent = fmt2(remaining);
                }
            }

            document.getElementById('TaxPercentInput')?.addEventListener('input', recalcTaxFromPercent);
            document.getElementById('TaxPercentInput')?.addEventListener('change', recalcTaxFromPercent);

            //حفظ الضريبة (Enter أو Blur)

            async function saveTaxAjax() {

                const invoiceId = parseInt('@(Model?.SIId ?? 0)', 10);
                // لو الفاتورة لسه جديدة (بدون رقم) لا نحاول الحفظ ولا نظهر رسالة
                if (!invoiceId || invoiceId <= 0) {
                    return;
                }

                const totalAfterEl = document.getElementById('TotalAfterDiscountValue');
                const percentInp = document.getElementById('TaxPercentInput');
                const rawPercent = (percentInp?.value || '').toString().trim();
                const taxPercent = parseDecimalSafe(rawPercent);
                if (rawPercent !== '' && (isNaN(parseFloat(rawPercent.replace(',', '.'))) || taxPercent < 0 || taxPercent > 100)) {
                    alert('من فضلك أدخل نسبة صحيحة (رقم بين 0 و 100).');
                    return;
                }

                const totalAfterDiscount = parseDecimalSafe(totalAfterEl?.textContent || 0);
                const taxVal = Math.round(totalAfterDiscount * (taxPercent / 100) * 100) / 100;

                const token = getAntiForgeryToken();
                const res = await fetch('@Url.Action("SaveTaxJson", "SalesInvoices")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ SIId: invoiceId, taxTotal: taxVal })
                });

                const data = await res.json();

                if (!data.ok) {
                    alert(data.message || 'تعذر حفظ الضريبة.');
                    return;
                }

                if (data.totals) updateSummaryBadges(data.totals);
            }

            document.getElementById('TaxPercentInput')?.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    // إلغاء حفظ الضريبة بالضغط على إنتر لتفادي رسالة الحفظ المزعجة
                    e.preventDefault();
                    return;
                }
            });

            document.getElementById('TaxPercentInput')?.addEventListener('blur', function () {
                saveTaxAjax();
            });





