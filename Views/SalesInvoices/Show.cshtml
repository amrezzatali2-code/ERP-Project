                                               value="@taxPercentDisplay.ToString("0.00")" placeholder="0" data-lock-posted="1"/>
                                    </div>
                                    <div class="invoice-summary-item invoice-summary-box">
                                        <span class="invoice-summary-label">قيمة الضريبة</span>
                                        <span id="TaxAmountValue" class="invoice-summary-value">@taxAmount.ToString("0.00")</span>
                                        <span id="TaxAmountDisplay" class="visually-hidden" aria-hidden="true"></span>
                                    </div>
                                    <div class="invoice-summary-item invoice-summary-box invoice-summary-box-main">
                                        <span class="invoice-summary-label">الإجمالي</span>
                                        <span id="GrandTotalWithPreviousValue" class="invoice-summary-value invoice-summary-value-main fw-bold">@grandTotalWithPrevious.ToString("0.00")</span>
                                        <span id="TotalAfterDiscountAndTaxValue" class="visually-hidden" aria-hidden="true">@totalAfterDiscountAndTax.ToString("0.00")</span>
                                        <span id="NetTotalValue" class="visually-hidden">@netTotal.ToString("0.00")</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div> @* ✅ نهاية PI_BodyHost *@

                </div> @* نهاية العمود الرئيسي *@




            </div> @* نهاية row *@
        </div> @* نهاية container *@
