                        // =====================================
                        setText('TotalLinesValue', totalLines);
                        setText('TotalItemsValue', totalItems);
                        setText('TotalQtyValue', totalQty);

                        setText('TotalRetailValue', fmt2(totalRetail));
                        setText('TotalAfterDiscountValue', fmt2(totalAfterDiscount));
                        const taxPercentInp = document.getElementById('TaxPercentInput');
                        const taxAmountVal = document.getElementById('TaxAmountValue');
                        const totAfterDisc = parseDecimalSafe(totalAfterDiscount);
                        const taxPct = totAfterDisc > 0 ? (parseDecimalSafe(taxAmount) * 100 / totAfterDisc) : 0;
                        if (taxPercentInp) taxPercentInp.value = fmt2(taxPct);
                        if (taxAmountVal) taxAmountVal.textContent = fmt2(taxAmount);

                        setText('TotalAfterDiscountAndTaxValue', fmt2(totalAfterDiscountAndTax));
                        setText('NetTotalValue', fmt2(netTotal));

                        // ✅ تحديث الحساب السابق والمبلغ المتبقى — للفاتورة المحفوظة نستخدم القيمة المخزنة (CustomerPreviousBalanceStored)
                        const invoiceId = parseInt(document.getElementById('InvoiceId')?.value || '0', 10);
                        const prevStoredEl = document.getElementById('CustomerPreviousBalanceStored');
                        const custBalanceEl = document.getElementById('CustomerCurrentBalance');
                        const creditLimitEl = document.getElementById('CustomerCredit');
                        const prevBalanceEl = document.getElementById('CustomerPreviousBalanceValue');
                        const creditRemainingEl = document.getElementById('CreditRemainingValue');
                        let balanceToUseForGrand = 0;
                        if (creditLimitEl && prevBalanceEl && creditRemainingEl) {
                            const creditLimit = parseDecimalSafe(creditLimitEl.value);
                            balanceToUseForGrand = (invoiceId > 0 && prevStoredEl) ? parseDecimalSafe(prevStoredEl.value) : parseDecimalSafe(custBalanceEl?.value || '0');
                            prevBalanceEl.textContent = fmt2(balanceToUseForGrand);
                            const remaining = Math.max(0, creditLimit - balanceToUseForGrand - parseDecimalSafe(netTotal));
                            creditRemainingEl.textContent = fmt2(remaining);
                        } else if (prevBalanceEl) {
                            balanceToUseForGrand = (invoiceId > 0 && prevStoredEl) ? parseDecimalSafe(prevStoredEl.value) : parseDecimalSafe(custBalanceEl?.value || '0');
                            if (prevBalanceEl.textContent.trim() !== '—') {
