@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.SalesInvoice

@{
    ViewData["Title"] = $"فاتورة مبيعات — رقم {Model.SIId}";
}

@section Styles {
    <style>
        /* خلفية عامة للصفحة */
        .invoice-page {
            background-color: #f3f6fb; /* لون خفيف مريح للعين */
            min-height: 100vh;
            padding-bottom: 2rem;
        }

        /* الكروت الرئيسية (الهيدر + تفاصيل + إدخال صنف + بيانات الصنف + السطور + الإجماليات + الكارت الجانبي) */
        .invoice-header-card,
        .invoice-details-card,
        .invoice-lines-card,
        .invoice-totals-card,
        .invoice-side-card,
        .invoice-Add-card,
        .invoice-product-card {
            border-radius: 1rem;
            overflow: hidden;
        }

        /* شريط الهيدر الملون للهيدر الرئيسي للفاتورة */
        .invoice-header-bar {
            background: linear-gradient(90deg, #6f42c1 0%, #0dcaf0 100%);
            color: #ffffff;
            padding: 0.75rem 1.25rem;
        }

            .invoice-header-bar h5 {
                margin-bottom: 0.1rem;
            }

        /* نفس لون الهيدر لباقي الكروت: تفاصيل العميل + إدخال صنف + بيانات الصنف + جدول السطور + الكارت الجانبي */
        .invoice-details-card .card-header,
        .invoice-Add-card .card-header,
        .invoice-product-card .card-header,
        .invoice-lines-card .card-header,
        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #6f42c1 0%, #0dcaf0 100%);
            color: #ffffff;
            padding: 0.55rem 1rem;
        }

        .invoice-status-badge {
            font-size: 0.8rem;
            padding: 0.3rem 0.7rem;
        }

        .badge-status-draft {
            background-color: #6f42c1; /* بنفسجي لمسودة */
        }

        .badge-status-notposted {
            background-color: #343a40; /* غامق لعدم الترحيل */
        }

        .form-label-sm {
            font-size: 0.85rem;
        }

        .invoice-small-input {
            max-width: 150px;
        }

        .customer-summary-line {
            font-size: 0.82rem;
        }

        /* كارت الإجراءات الجانبية: أزرار أرفع شوية */
        .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
        }

            .invoice-side-card .btn-erp + .btn-erp {
                margin-top: 0.25rem;
            }

        /* هيدر جدول السطور (لو حابب نفس اللون فوق الجدول مباشرة) */
        .invoice-lines-header {
            background: linear-gradient(90deg, #6f42c1 0%, #0dcaf0 100%);
            color: #fff;
        }

            .invoice-lines-header th {
                border-color: #0b5ed7 !important;
            }

        .erp-table-wrapper {
            max-height: 360px;
            overflow: auto;
        }
    </style>


}

<div class="invoice-page" dir="rtl">
    <div class="container-fluid pt-3">

        <div class="row g-3">

            @* =========================
               العمود الرئيسي (الهيدر + العميل + الأصناف + الإجماليات)
               ========================= *@
            <div class="col-lg-10">

                @* ====================================================
                   1) كارت بيانات الفاتورة + العميل + المخزن + السياسة
                   ==================================================== *@
                <div class="card shadow-sm mb-2 invoice-header-card">

                    @* شريط علوي ملون *@
                    @{
                        // لو رقم الفاتورة 0 أو الموديل مش موجود يبقى لسه فاتورة جديدة لم تُحفظ
                        bool isNewInvoice = Model == null || Model.SIId == 0;
                    }

                    <div class="invoice-header-bar d-flex justify-content-between align-items-center flex-wrap gap-2">
                        @* الجزء الأيسر: عنوان الفاتورة + اسم المستخدم *@
                        <div>
                            <h5 class="mb-1">
                                @if (isNewInvoice)
                                {
                                    @:فاتورة مبيعات 
                                }
                                else
                                {
                                    @:فاتورة مبيعات
                                    <span class="small opacity-100">رقم @Model.SIId</span>
                                }
                            </h5>

                            @* نظهر اسم المنشئ فقط لو الفاتورة محفوظة وليها رقم *@
                            @if (!isNewInvoice)
                            {
                                <div class="small opacity-100">
                                    أنشئت بواسطة:
                                    <span class="fw-semibold">@Model.CreatedBy</span>
                                </div>
                            }
                        </div>

                        @* الجزء الأيمن: حالة الفاتورة *@
                        <div class="text-end">
                            @if (isNewInvoice)
                            {
                                <span class="text-white fw-semibold">
                                      اضغط على فاتورة جديدة
                                </span>
                            }
                            else if (Model.IsPosted)
                            {
                                <span class="text-white fw-semibold">
                                    فاتورة مرحلة
                                </span>
                            }
                            else
                            {
                                <span class="text-white fw-semibold">
                                    فاتورة مفتوحة
                                </span>
                            }
                        </div>
                    </div>



                    <div class="card-body">

                        <div class="row g-3 align-items-end">

                            @* اسم العميل + أوتوكومبليت *@
                            <div class="col-lg-4 col-md-6">
                                <label for="CustomerNameInput" class="form-label form-label-sm">اسم العميل</label>
                                <input id="CustomerNameInput"
                                       class="form-control form-control-sm"
                                       placeholder="اكتب اسم العميل أو جزء منه للبحث..."
                                       list="customersList"
                                       autocomplete="off" />

                                @* قائمة العملاء لأوتوكومبليت – يتم تحميلها من الكنترولر *@
                                <datalist id="customersList">
                                    @if (ViewBag.Customers != null)
                                    {
                                        foreach (var c in ViewBag.Customers)
                                        {
                                            @* 
                                               كل option يحمل:
                                               - value = اسم العميل (يظهر للمستخدم)
                                               - data-id = كود العميل
                                               - باقي البيانات لملىء كارت التفاصيل
                                             *@
                                            <option value="@c.Name"
                                                    data-id="@c.Id"
                                                    data-policy="@c.PolicyName"
                                                    data-user="@c.UserName"
                                                    data-phone="@c.Phone"
                                                    data-address="@c.Address"
                                                    data-credit="@c.CreditLimit">
                                            </option>
                                        }
                                    }
                                </datalist>

                                <small id="CustomerSummaryText"
                                       class="text-muted customer-summary-line d-block mt-1">
                                    @* سيتم ملؤه بجملة مختصرة عن العميل *@
                                </small>
                            </div>

                            @* كود العميل في بوكس مستقل *@
                            <div class="col-lg-2 col-md-3">
                                <label class="form-label form-label-sm">كود العميل</label>
                                <input id="CustomerCodeDisplay"
                                       class="form-control form-control-sm text-center invoice-small-input"
                                       readonly />

                                @* هذا هو الحقل الفعلي الذي يُحفظ في الفاتورة *@
                                <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                            </div>

                            @* المخزن (بدون كود مخزن منفصل) *@
                            <div class="col-lg-3 col-md-3">
                                <label class="form-label form-label-sm" for="WarehouseId">المخزن</label>
                                <select asp-for="WarehouseId"
                                        asp-items="ViewBag.Warehouses"
                                        class="form-select form-select-sm">
                                    <option value="">اختر المخزن...</option>
                                </select>
                            </div>



                            @* منطق بسيط لتحديد هل الفاتورة محفوظة ولا لسه جديدة *@
                            @{
                                // لو الفاتورة محفوظة في الداتا Id > 0
                                bool hasInvoice = Model.SIId > 0;

                                // نص التاريخ والوقت اللى هيتعرضوا في الخانات
                                string invoiceDateText = hasInvoice ? Model.SIDate.ToString("yyyy/MM/dd") : "";
                                string invoiceTimeText = hasInvoice ? Model.SITime.ToString(@"hh\:mm") : "";
                            }


                            @* التاريخ والوقت *@
                            <div class="col-lg-3 col-md-6">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">تاريخ الفاتورة</label>
                                        <input class="form-control form-control-sm text-center"
                                               value="@invoiceDateText" @* لو جديدة الخانة تبقى فاضية *@
                                               readonly />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">وقت الفاتورة</label>
                                        <input class="form-control form-control-sm text-center"
                                               value="@invoiceTimeText" @* لو جديدة الخانة تبقى فاضية *@
                                               readonly />
                                    </div>
                                </div>
                            </div>

                        </div>

                        <hr class="my-3" />

                        <div class="row g-3">
                            @* اسم السياسة *@
                            <div class="col-lg-6 col-md-6">
                                <label class="form-label form-label-sm">السياسة</label>
                                <input id="PolicyName"
                                       class="form-control form-control-sm"
                                       readonly />
                            </div>

                            @* المستخدم المربوط بالعميل *@
                            <div class="col-lg-6 col-md-6">
                                <label class="form-label form-label-sm">المستخدم المربوط بالعميل</label>
                                <input id="LinkedUserName"
                                       class="form-control form-control-sm"
                                       readonly />
                            </div>
                        </div>
                    </div>
                </div>

                @* ======================================
                   2) كارت تفاصيل العميل (هاتف / عنوان / حد ائتماني)
                   ====================================== *@
                <div class="card shadow-sm mb-3 invoice-details-card">
                    <div class="card-header">
                        <h6 class="mb-0">تفاصيل العميل</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-lg-4 col-md-4">
                                <label class="form-label form-label-sm">الهاتف</label>
                                <input id="CustomerPhone"
                                       class="form-control form-control-sm"
                                       readonly />
                            </div>

                            <div class="col-lg-8 col-md-8">
                                <label class="form-label form-label-sm">العنوان</label>
                                <input id="CustomerAddress"
                                       class="form-control form-control-sm"
                                       readonly />
                            </div>

                            <div class="col-lg-4 col-md-4">
                                <label class="form-label form-label-sm">الحد الائتماني</label>
                                <input id="CustomerCreditLimit"
                                       class="form-control form-control-sm text-center"
                                       readonly />
                            </div>
                        </div>
                    </div>
                </div>





                @* =====================================================
   4) كارت بيانات الصنف من المخزون والسياسات
   ===================================================== *@
                <div class="card shadow-sm mb-3 invoice-product-card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">بيانات الصنف (مخزون + خصومات + كوتة)</h6>
                        <small class="opacity-75">
                            هذه البيانات تخص الصنف الحالي في كارت "تسجيل الأصناف".
                        </small>
                    </div>

                    <div class="card-body">

                        @* الصف العلوي: أرقام سريعة عن الصنف *@
                        <div class="row g-3 mb-2">
                            @* الكمية المتاحة في المخزن الحالي *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الكمية المتاحة في هذا المخزن</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            @* إجمالي الكمية في كل المخازن *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">إجمالي الكمية في كل المخازن</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            @* كمية الكوتة المتبقية *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">كمية الكوتة المتبقية</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            @* الخصم المرجّح للصنف (من السياسات) *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الخصم المرجّح للصنف %</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>
                        </div>

                        @* جدول توزيع الكمية على المخازن (لو عندك أكثر من مخزن) *@
                        <div class="table-responsive mt-2">
                            <table class="table table-sm table-striped mb-0">
                                <thead>
                                    <tr>
                                        <th>المخزن</th>                 @* اسم المخزن *@
                                        <th class="text-center">الكمية المتاحة</th> @* إجمالي الكمية في المخزن *@
                                        <th class="text-center">محجوزة لطلبات</th> @* كمية محجوزة لأوامر بيع *@
                                        <th class="text-center">متاح للبيع</th>    @* الكمية الصافية للبيع *@
                                    </tr>
                                </thead>
                                <tbody>
                                    @* عند ربط الكارت فعليًا هنملأ هذا الجدول من قاعدة البيانات أو API *@
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>


                @* =====================================================
   3) كارت إدخال الصنف
   ===================================================== *@
                <div class="card shadow-sm mb-3 invoice-Add-card">

                    @* هيدر الكارت (اللون الأزرق) *@
                    <div class="card-header">
                        <h6 class="mb-0">تسجيل الأصناف</h6>
                    </div>

                    @* جسم الكارت: حقول إدخال بيانات الصنف *@
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            @* كود الصنف *@
                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">كود الصنف</label>
                                <input type="text"
                                       class="form-control form-control-sm"
                                       placeholder="بحث بالكود..." />
                            </div>

                            @* اسم الصنف *@
                            <div class="col-lg-4 col-md-8">
                                <label class="form-label form-label-sm">اسم الصنف</label>
                                <input type="text"
                                       class="form-control form-control-sm"
                                       placeholder="اكتب اسم الصنف أو جزء منه..." />
                            </div>

                            @* سعر الجمهور *@
                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">سعر الجمهور</label>
                                <input type="number"
                                       class="form-control form-control-sm text-center"
                                       placeholder="0.00" />
                            </div>

                            @* الكمية *@
                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">الكمية</label>
                                <input type="number"
                                       class="form-control form-control-sm text-center"
                                       placeholder="1" />
                            </div>

                            @* خصم 1 % *@
                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">خصم 1 %</label>
                                <input type="number"
                                       class="form-control form-control-sm text-center"
                                       placeholder="0" />
                            </div>
                        </div>

                        <div class="row g-2 align-items-end mt-2">
                            @* رقم الباتش *@
                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">رقم الباتش</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       placeholder="Batch No" />
                            </div>

                            @* تاريخ الصلاحية *@
                            <div class="col-lg-3 col-md-4">
                                <label class="form-label form-label-sm">تاريخ الصلاحية</label>
                                <input type="date"
                                       class="form-control form-control-sm text-center" />
                            </div>

                            @* خصم 2 % *@
                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">خصم 2 %</label>
                                <input type="number"
                                       class="form-control form-control-sm text-center"
                                       placeholder="0" />
                            </div>

                            @* زر إضافة الصنف للفاتورة فقط *@
                            <div class="col-lg-3 col-md-4">
                                <div class="d-grid gap-1 invoice-item-actions">
                                    <button type="button"
                                            class="btn btn-erp btn-erp-primary btn-erp-sm">
                                        إضافة الصنف للفاتورة
                                    </button>
                                </div>
                            </div>

                            @* عمود فارغ لموازنة الصف في الشاشات الكبيرة *@
                            <div class="col-lg-2 d-none d-lg-block"></div>
                        </div>
                    </div>
                </div>


                @* ==========================================
                   4) جدول سطور الفاتورة (عرض فقط في هذه المرحلة)
                   ========================================== *@
                <div class="card shadow-sm mb-3 invoice-lines-card">
                    <div class="card-header py-2 invoice-lines-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">
                                سطور الفاتورة
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="erp-table-wrapper mb-0">
                            <table class="table table-sm table-striped table-hover mb-0 erp-table">
                                <thead>
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">الكمية</th>
                                        <th class="text-center">سعر الجمهور</th>
                                        <th class="text-center">خصم 1 %</th>
                                        <th class="text-center">خصم 2 %</th>
                                        <th class="text-center">خصم 3 %</th>
                                        <th class="text-center">الإجمالي</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td colspan="8" class="text-center text-muted py-4">
                                            لا توجد سطور مسجَّلة لهذه الفاتورة في هذه المرحلة.
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @* ====================================
                   5) ملخص الإجماليات / الخصم / الضريبة
                   ==================================== *@
                <div class="card shadow-sm invoice-totals-card">
                    <div class="card-body">

                        <div class="row g-2 align-items-center">
                            <div class="col-md-3">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">إجمالي قبل الخصم</span>
                                    <span class="badge bg-light text-dark">
                                        @Model.TotalBeforeDiscount.ToString("0.00")
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">خصم الهيدر (قيمة)</span>
                                    <span class="badge bg-warning text-dark">
                                        @Model.HeaderDiscountValue.ToString("0.00")
                                        <span class="small">
                                            (@Model.HeaderDiscountPercent.ToString("0.##") %)
                                        </span>
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">إجمالي بعد الخصم وقبل الضريبة</span>
                                    <span class="badge bg-light text-dark">
                                        @Model.TotalAfterDiscountBeforeTax.ToString("0.00")
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">قيمة الضريبة</span>
                                    <span class="badge bg-info text-dark">
                                        @Model.TaxAmount.ToString("0.00")
                                    </span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-3" />

                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <span class="small text-muted d-block">الصافي النهائي للفاتورة</span>
                                <h3 class="mb-0 text-success">
                                    @Model.NetTotal.ToString("0.00")
                                </h3>
                            </div>

                            <div class="text-end small text-muted">
                                @if (Model.UpdatedAt.HasValue)
                                {
                                    <div>
                                        آخر تعديل:
                                        <span class="fw-semibold">
                                            @Model.UpdatedAt.Value.ToString("yyyy/MM/dd HH:mm")
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            @* =========================
               العمود الجانبي (أزرار الحركة)
               ========================= *@
            <div class="col-lg-2">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات الفاتورة</h6>
                    </div>
                    <div class="card-body d-grid">

                        @* زر إنشاء فاتورة جديدة *@
                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm"
                           asp-action="Create">
                            ➕ فاتورة جديدة
                        </a>

                        @* زر مسح كل الأصناف من سطور الفاتورة (هنوصله بالمنطق البرمجي بعدين) *@
                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm"
                                id="btnClearInvoiceLines"
                                data-invoice-id="@Model.SIId">
                            🗑️ مسح كل الأصناف
                        </button>

                        <button type="button"
