                        if (window.__PI_NAV_SCRIPT_LOADED__) return;
                        window.__PI_NAV_SCRIPT_LOADED__ = true;

                        // =========================
                        // أدوات مساعدة
                        // =========================
                        function setOrReplaceParam(url, key, value) {
                            try {
                                const u = new URL(url, window.location.origin);
                                u.searchParams.set(key, value);
                                return u.toString();
                            } catch {
                                const sep = url.includes('?') ? '&' : '?';
                                const has = new RegExp('[?&]' + key + '=').test(url);
                                if (has) return url.replace(new RegExp('([?&]' + key + '=)[^&]*'), '$1' + encodeURIComponent(value));
                                return url + sep + key + '=' + encodeURIComponent(value);
                            }
                        }

                        function getInt(id) {
                            const el = document.getElementById(id);
                            if (!el) return 0;
                            const v = parseInt(el.value || '0', 10);
                            return isNaN(v) ? 0 : v;
                        }

                        function setBtnState(btn, can) {
                            if (!btn) return;
                            if (can) btn.removeAttribute('disabled');
                            else btn.setAttribute('disabled', 'disabled');
                        }

                        // =========================================================
                        // ✅ (1) إدارة الـ Tooltips بشكل آمن
                        // - الأسهم: Hover فقط (بدون Focus)
                        // - البحث: بدون Tooltip تمامًا
                        // =========================================================
                        function setupTooltips() {

                            // ✅ لو Bootstrap Tooltip غير موجود، نخرج بدون مشاكل
                            if (!window.bootstrap || !bootstrap.Tooltip) return;

                            // ---------- 1) إزالة Tooltip من البحث ----------
                            const searchInput = document.getElementById('NavInvoiceSearchInput');
                            const searchBtn = document.getElementById('btnNavInvoiceSearch');

                            if (searchInput) {
                                // تعليق: نشيل title نهائيًا عشان Bootstrap ما يعملش Tooltip
                                searchInput.removeAttribute('title');

                                // تعليق: لو عليه Tooltip قديم، نقفله
                                try {
                                    const inst = bootstrap.Tooltip.getInstance(searchInput);
                                    if (inst) inst.dispose();
                                } catch { }
                            }

                            if (searchBtn) {
                                searchBtn.removeAttribute('title');
                                try {
                                    const inst = bootstrap.Tooltip.getInstance(searchBtn);
                                    if (inst) inst.dispose();
                                } catch { }
                            }

                            // ---------- 2) تهيئة Tooltip الأسهم (Hover فقط) ----------
                            const ids = ['btnFirstInvoice', 'btnPrevInvoice', 'btnNextInvoice', 'btnLastInvoice'];

                            ids.forEach(function (id) {
                                const el = document.getElementById(id);
                                if (!el) return;

                                // ✅ Dispose لأي Instance قديم (عشان ما تتكرر)
                                try {
                                    const oldInst = bootstrap.Tooltip.getInstance(el);
                                    if (oldInst) oldInst.dispose();
                                } catch { }

                                // ✅ إنشاء Tooltip جديد بسلوك ثابت
                                // trigger: 'hover' => يظهر على الوقوف فقط (مش بالضغط)
                                // container: 'body' => يمنع “النزول لتحت” الغريب
                                try {
                                    new bootstrap.Tooltip(el, {
                                        trigger: 'hover',
                                        container: 'body',
                                        boundary: 'viewport'
                                    });
                                } catch { }
                            });
                        }

                        // ✅ إخفاء Tooltip بسرعة + إزالة فوكس الزر بعد الضغط
                        function hideTooltipAndBlur(el) {
                            if (!el) return;

                            // 1) Blur لمنع Focus-trigger
                            try { el.blur(); } catch { }

                            // 2) Hide tooltip لو موجود
                            if (window.bootstrap && bootstrap.Tooltip) {
                                try {
                                    const inst = bootstrap.Tooltip.getInstance(el);
                                    if (inst) inst.hide();
                                } catch { }
                            }
                        }

                        // =========================
                        // تحديث أزرار السايد بار بعد تحميل body
                        // =========================
                        function refreshSideNavButtons() {

                            // القيم الجديدة داخل PI_BodyHost (تتغير مع كل فاتورة)
                            const navFirst = getInt('NavFirstId');
                            const navLast = getInt('NavLastId');
                            const navPrev = getInt('NavPrevId');
                            const navNext = getInt('NavNextId');
                            const currentId = getInt('NavCurrentId'); // 0 = فاتورة جديدة

                            const hasAny = (navFirst > 0 && navLast > 0);

                            // في الفاتورة الجديدة: السابق=آخر، التالي=أول
                            const prevEffective = (currentId === 0) ? navLast : navPrev;
                            const nextEffective = (currentId === 0) ? navFirst : navNext;

                            const canFirst = hasAny && navFirst > 0 && navFirst !== currentId;
                            const canLast = hasAny && navLast > 0 && navLast !== currentId;
                            const canPrev = hasAny && prevEffective > 0 && prevEffective !== currentId;
                            const canNext = hasAny && nextEffective > 0 && nextEffective !== currentId;

                            // الأزرار
                            const btnFirst = document.getElementById('btnFirstInvoice');
                            const btnPrev = document.getElementById('btnPrevInvoice');
                            const btnNext = document.getElementById('btnNextInvoice');
                            const btnLast = document.getElementById('btnLastInvoice');

                            // base URL للعرض (بدون id)
                            let base = document.getElementById('btnNavInvoiceSearch')?.getAttribute('data-base-url')
                                || '@Url.Action("Show", "SalesInvoices", new { frame = 1 })';
                            
                            // ✅ إزالة id من base URL إذا كان موجوداً (لضمان بناء URL صحيح)
                            try {
                                const baseUrl = new URL(base, window.location.origin);
                                baseUrl.searchParams.delete('id');
                                base = baseUrl.toString();
                            } catch {
                                // لو فشل URL parsing، نستخدم regex لإزالة id
                                base = base.replace(/[?&]id=\d+/g, '').replace(/[?&]id=[^&]*/g, '');
                                if (!base.includes('?')) {
                                    base = base.replace(/&/, '?');
                                }
                            }

                            // نجهز URLs
                            const urlFirst = setOrReplaceParam(base, 'id', navFirst);
                            const urlLast = setOrReplaceParam(base, 'id', navLast);
                            const urlPrev = setOrReplaceParam(base, 'id', prevEffective);
                            const urlNext = setOrReplaceParam(base, 'id', nextEffective);

                            // ✅ تحديث data-url و data-id للأزرار (لجميع الأزرار، حتى المعطلة)
                            if (btnFirst) { 
                                btnFirst.setAttribute('data-url', urlFirst); 
                                btnFirst.setAttribute('data-id', navFirst); 
                            }
                            if (btnLast) { 
                                btnLast.setAttribute('data-url', urlLast); 
                                btnLast.setAttribute('data-id', navLast); 
                            }
                            if (btnPrev) { 
                                btnPrev.setAttribute('data-url', urlPrev); 
                                btnPrev.setAttribute('data-id', prevEffective); 
                            }
                            if (btnNext) { 
                                btnNext.setAttribute('data-url', urlNext); 
                                btnNext.setAttribute('data-id', nextEffective); 
                            }

                            // Disabled
                            setBtnState(btnFirst, canFirst);
                            setBtnState(btnLast, canLast);
                            setBtnState(btnPrev, canPrev);
                            setBtnState(btnNext, canNext);

                            // ✅ تحديث زر حجم تعامل العميل (حسب CustomerId في الهيدر)
                            const customerId = getInt('CustomerId');
                            const btnVolume = document.getElementById('btnCustomerVolume');
                            if (btnVolume) {
                                const volumeUrl = customerId > 0 ? `/Customers/Show/${customerId}?frame=1` : '';
                                btnVolume.setAttribute('href', volumeUrl || '#');
                                btnVolume.setAttribute('data-url', volumeUrl || '');
                                btnVolume.setAttribute('aria-disabled', customerId > 0 ? 'false' : 'true');
                                btnVolume.dataset.volumeEnabled = customerId > 0 ? '1' : '0';
                                btnVolume.style.pointerEvents = customerId > 0 ? '' : 'none';
                                btnVolume.style.opacity = customerId > 0 ? '1' : '0.5';
                                btnVolume.classList.toggle('disabled', customerId <= 0);
                            }
                        }
                        window.__refreshSideNavButtons = refreshSideNavButtons;

                        // =========================
                        // تحميل Body فقط وتبديل المحتوى
                        // =========================
                        async function loadInvoiceBody(url) {

                            const host = document.getElementById('PI_BodyHost');
                            if (!host) return;

                            url = setOrReplaceParam(url, 'frag', 'body');

                            if (host.dataset.loading === "1") return;
                            host.dataset.loading = "1";

                            try {
                                const res = await fetch(url, {
                                    method: 'GET',
                                    credentials: 'same-origin',
                                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                                });

                                const html = await res.text();

                                const parser = new DOMParser();
                                const doc = parser.parseFromString(html, 'text/html');
                                const newHost = doc.getElementById('PI_BodyHost');

                                if (newHost) {
                                    host.innerHTML = newHost.innerHTML;
                                } else {
                                    host.innerHTML = html;
                                }

                                // ✅ بعد تبديل الـ body: حدّث الشريط الجانبي (حالة الفاتورة + زر المرتجع)
                                const bodyIsPosted = document.getElementById("BodyHostIsPosted")?.value === "1";
                                const bodyStatus = (document.getElementById("BodyHostInvoiceStatus")?.value || "").trim();
                                const bodyInvoiceId = parseInt((document.getElementById("NavCurrentId")?.value || "0"), 10) || 0;
                                const invIdEl = document.getElementById("InvoiceId");
                                if (invIdEl) invIdEl.value = bodyInvoiceId;
                                const invFlagEl = document.getElementById("InvoiceIsPostedFlag");
                                if (invFlagEl) invFlagEl.value = bodyIsPosted ? "1" : "0";
                                const fullRetWrap = document.getElementById("fullReturnBtnWrapper");
                                if (fullRetWrap) {
                                    const canShow = bodyInvoiceId > 0 && (bodyIsPosted || bodyStatus === "مفتوحة للتعديل" || (bodyStatus && bodyStatus.startsWith("مرحلة")));
                                    if (canShow) fullRetWrap.classList.remove("d-none");
                                    else fullRetWrap.classList.add("d-none");
                                }
                                if (typeof setInvoicePosted === "function") setInvoicePosted(bodyIsPosted);
                                if (typeof applyPostedUiLock === "function") applyPostedUiLock();
                                const isPostedDisplay = document.getElementById("InvoiceIsPostedDisplay");
                                if (isPostedDisplay && bodyStatus) isPostedDisplay.value = bodyStatus;
                                const statusHidden = document.getElementById("InvoiceStatusHidden");
                                if (statusHidden && bodyStatus) statusHidden.value = bodyStatus;
                                const btnPost = document.getElementById("btnPostInvoice");
                                if (btnPost) {
                                    btnPost.innerHTML = bodyIsPosted ? "✅ تم ترحيل الفاتورة" : "📤 ترحيل الفاتورة";
                                    btnPost.disabled = !!bodyIsPosted;
                                }
                                const btnOpen = document.getElementById("btnOpenInvoice");
                                if (btnOpen) btnOpen.disabled = !bodyIsPosted;

                                // ✅ بعد تبديل الـ body: حدّث أزرار السايد بار
                                refreshSideNavButtons();

                                // ✅ بعد التبديل: أعد تهيئة tooltips للأسهم مرة واحدة وبشكل سليم
                                setupTooltips();

                                            // ✅ نظام ثابت: بعد تبديل الـ Body لازم نعيد تهيئة الصفحة
                        if (typeof window.__ERP_INIT__ === 'function') {
                            window.__ERP_INIT__();
                        }


                            } catch (e) {
                                console.error(e);
                                alert('حدث خطأ أثناء تحميل الفاتورة.');
                            } finally {
                                host.dataset.loading = "0";
                            }
                        }

                        // ✅ زر التحديث في الناف بار: تحديث الفاتورة الحالية فقط (بدون فتح فاتورة جديدة)
