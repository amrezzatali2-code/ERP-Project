@section Scripts {
        <script>
                      // =========================================================
            // (0) دوال القفل عند الترحيل — يجب أن تكون في المستوى الأعلى لتعمل عند التحميل الأولي
            // =========================================================
            function isInvoicePosted() {
                const flag = document.getElementById("InvoiceIsPostedFlag");
                return flag && flag.value === "1";
            }
            function setInvoicePosted(posted) {
                const flag = document.getElementById("InvoiceIsPostedFlag");
                if (flag) flag.value = posted ? "1" : "0";
            }
            function applyPostedUiLock() {
                const posted = isInvoicePosted();
                const lockables = document.querySelectorAll('[data-lock-posted="1"]');
                lockables.forEach(el => {
                    if (el.getAttribute('data-keep-active-posted') === '1') return;
                    if (el.dataset.lockInit !== "1") {
                        el.dataset.lockInit = "1";
                        el.dataset.origDisabled = el.disabled ? "1" : "0";
                        el.dataset.origReadonly = el.readOnly ? "1" : "0";
                        el.dataset.origTabIndex = el.getAttribute("tabindex") ?? "";
                    }
                    const tag = (el.tagName || "").toUpperCase();
                    if (posted) {
                        if (tag === "BUTTON") { el.disabled = true; return; }
                        if (tag === "A") {
                            el.classList.add("disabled", "pe-none");
                            el.setAttribute("aria-disabled", "true");
                            el.setAttribute("tabindex", "-1");
                            return;
                        }
                        if (tag === "INPUT" || tag === "TEXTAREA") {
                            el.readOnly = true;
                            el.classList.add("bg-light", "text-muted");
                            return;
                        }
                        if (tag === "SELECT") { el.disabled = true; return; }
                        return;
                    }
                    const origDisabled = el.dataset.origDisabled === "1";
                    const origReadonly = el.dataset.origReadonly === "1";
                    const origTabIndex = el.dataset.origTabIndex;
                    if (tag === "BUTTON") { el.disabled = origDisabled; return; }
                    if (tag === "A") {
                        el.classList.remove("disabled", "pe-none");
                        el.removeAttribute("aria-disabled");
                        if (origTabIndex === "") el.removeAttribute("tabindex");
                        else el.setAttribute("tabindex", origTabIndex);
                        return;
                    }
                    if (tag === "INPUT" || tag === "TEXTAREA") {
                        el.readOnly = origReadonly;
                        el.classList.remove("bg-light", "text-muted");
                        return;
                    }
                    if (tag === "SELECT") { el.disabled = origDisabled; return; }
                });
            }
            document.addEventListener("DOMContentLoaded", applyPostedUiLock);

                      // =========================================================
            // (A) أوتوكومبليت العميل (اسم ⇐⇒ كود + بيانات + سياسة)
            // =========================================================
            (function () {

                // =========================================================
                // (0) تعريف عناصر الواجهة مرة واحدة
                // =========================================================
                const custNameInput     = document.getElementById('CustomerNameInput');    // متغير: اسم العميل
                const custCodeInput     = document.getElementById('CustomerCodeDisplay');  // متغير: كود العميل الظاهر
                const custPhoneInput    = document.getElementById('CustomerPhone');        // متغير: الهاتف
                const custGovInput      = document.getElementById('CustomerGovernorate');  // متغير: المحافظة
                const custDistrictInput = document.getElementById('CustomerDistrict');     // متغير: الحي
                const custAreaInput     = document.getElementById('CustomerArea');         // متغير: المنطقة
                const custAddressInput  = document.getElementById('CustomerAddress');      // متغير: العنوان
                const custCreditInput   = document.getElementById('CustomerCredit');       // متغير: الحد الائتماني
                const custHiddenId      = document.getElementById('CustomerId');           // متغير: CustomerId (مخفي)

                // ✅ جديد: عناصر سياسة العميل
                const policyIdBox   = document.getElementById('CustomerPolicyId');         // متغير: PolicyId (hidden)
                const policyTextBox = document.getElementById('CustomerPolicyText');       // متغير: نص السياسة

                // =========================================================
                // (1) الحصول على datalist الخاصة بالعملاء
                // =========================================================
                const custDataList = custNameInput && custNameInput.list ? custNameInput.list : null;

                if (!custDataList) {
                    console.warn('⚠️ Customer datalist not found for CustomerNameInput');
                    return;
                }

                // =========================================================
                // (2) دوال مساعدة للبحث
                // =========================================================

                // تعليق: توحيد النص (وتجاهل الألف في أول الكلمة)
                function normalizeText(txt) {
                    return (txt || '')
                        .trim()
                        .toLowerCase()
                        .replace(/^[اأإآ]/, '')
                        .replace(/\s+/g, ' ');
                }

                // تعليق: بحث بالاسم (تطابق كامل)
                function findByName(name) {
                    const search = normalizeText(name);
                    if (!search) return null;

                    const opts = custDataList.options;
                    for (let i = 0; i < opts.length; i++) {
                        if (normalizeText(opts[i].value) === search) return opts[i];
                    }
                    return null;
                }

                // تعليق: بحث بالكود (data-id)
                function findByCode(code) {
                    const search = (code || '').toString().trim();
                    if (!search) return null;

                    const opts = custDataList.options;
                    for (let i = 0; i < opts.length; i++) {
                        const optId = (opts[i].getAttribute('data-id') || '').toString();
                        if (optId === search) return opts[i];
                    }
                    return null;
                }

                // =========================================================
                // (3) دالة التعبئة من option واحد
                // =========================================================
                function fillFromOption(opt) {

                    // ---------------------------------------------
                    // (3-1) لو مفيش عميل مطابق → تفريغ كل الحقول
                    // ---------------------------------------------
                    if (!opt) {
                        if (custHiddenId)      custHiddenId.value      = '';
                        if (custCodeInput)     custCodeInput.value     = '';
                        if (custNameInput)     custNameInput.value     = '';
                        if (custPhoneInput)    custPhoneInput.value    = '';
                        if (custGovInput)      custGovInput.value      = '';
                        if (custDistrictInput) custDistrictInput.value = '';
                        if (custAreaInput)     custAreaInput.value     = '';
                        if (custAddressInput)  custAddressInput.value  = '';
                        if (custCreditInput)   custCreditInput.value   = '';

                        // ✅ تفريغ سياسة العميل
                        if (policyIdBox)   policyIdBox.value   = '';
                        if (policyTextBox) policyTextBox.value = '';

                        // إخفاء رسالة العميل الموقوف وتفعيل زر الحفظ
                        const suspendedMsg = document.getElementById('customerSuspendedMsg');
                        const saveBtn = document.getElementById('btnSaveInvoiceHeader');
                        if (suspendedMsg) suspendedMsg.classList.add('d-none');
                        if (saveBtn) saveBtn.disabled = false;

                        // ✅ تحديث زر حجم التعامل (تفعيله عند إلغاء اختيار العميل)
                        if (typeof window.__refreshSideNavButtons === 'function') {
                            window.__refreshSideNavButtons();
                        }
                        return;
                    }

                    // ---------------------------------------------
                    // (3-2) قراءة البيانات من attributes
                    // ---------------------------------------------
                    const id       = opt.getAttribute('data-id')       || ''; // متغير: CustomerId
                    const name     = opt.value                         || ''; // متغير: اسم العميل
                    const phone    = opt.getAttribute('data-phone')    || ''; // متغير: الهاتف
                    const address  = opt.getAttribute('data-address')  || ''; // متغير: العنوان
                    const gov      = opt.getAttribute('data-gov')      || ''; // متغير: المحافظة
                    const district = opt.getAttribute('data-district') || opt.getAttribute('data-District') || ''; // متغير: الحي
                    const area     = opt.getAttribute('data-area')     || opt.getAttribute('data-Area')     || ''; // متغير: المنطقة
                    const credit   = opt.getAttribute('data-credit')   || opt.getAttribute('data-Credit')   || ''; // متغير: الحد الائتماني
                    const balance  = opt.getAttribute('data-balance')  || opt.getAttribute('data-Balance')  || '0'; // متغير: الحساب السابق للعميل

                    // ✅ جديد: سياسة العميل
                    const policyId   = opt.getAttribute('data-policy-id')   || opt.getAttribute('data-PolicyId')   || '';
                    const policyName = opt.getAttribute('data-policy-name') || opt.getAttribute('data-PolicyName') || '';

                    // ---------------------------------------------
                    // (3-3) تعبئة الحقول
                    // ---------------------------------------------
                    if (custHiddenId)  custHiddenId.value  = id;
                    if (custCodeInput) custCodeInput.value = id;

                    if (custNameInput)     custNameInput.value     = name;
                    if (custPhoneInput)    custPhoneInput.value    = phone;
                    if (custGovInput)      custGovInput.value      = gov;
                    if (custDistrictInput) custDistrictInput.value = district;
                    if (custAreaInput)     custAreaInput.value     = area;
                    if (custAddressInput)  custAddressInput.value  = address;
                    if (custCreditInput)   custCreditInput.value   = credit;

                    // ✅ تحديث الحساب السابق للعميل والمبلغ المتبقى
                    const custBalanceHidden = document.getElementById('CustomerCurrentBalance');
                    if (custBalanceHidden) custBalanceHidden.value = balance;
                    if (typeof updateSummaryBadges === 'function') {
                        const netEl = document.getElementById('NetTotalValue');
                        const netTotal = netEl ? parseFloat(netEl.textContent || '0') : 0;
                        const totAfter = parseDecimalSafe(document.getElementById('TotalAfterDiscountValue')?.textContent || 0);
                        const taxPct = parseDecimalSafe(document.getElementById('TaxPercentInput')?.value || 0);
                        const taxAmt = totAfter * (taxPct / 100);
                        const totals = {
                            totalLines: document.getElementById('TotalLinesValue')?.textContent || 0,
                            totalItems: document.getElementById('TotalItemsValue')?.textContent || 0,
                            totalQty: document.getElementById('TotalQtyValue')?.textContent || 0,
                            totalRetail: document.getElementById('TotalRetailValue')?.textContent || 0,
                            totalAfterDiscount: document.getElementById('TotalAfterDiscountValue')?.textContent || 0,
                            taxAmount: taxAmt,
                            totalAfterDiscountAndTax: totAfter + taxAmt,
                            netTotal: totAfter + taxAmt
                        };
                        updateSummaryBadges(totals);
                    }

                            // ✅ تعبئة سياسة العميل (نُظهر الاسم فقط)
            if (policyIdBox) policyIdBox.value = policyId; // يظل مخفي للاستخدام لاحقاً

            if (policyTextBox) {
                policyTextBox.value = (policyName || '').trim(); // عرض اسم السياسة فقط
            }
            // ✅ تحديث زر حجم التعامل عند اختيار/تغيير العميل
            if (typeof window.__refreshSideNavButtons === 'function') {
                window.__refreshSideNavButtons();
            }

                    // ✅ العميل الموقوف: إظهار الرسالة ومنع الحفظ
                    const isActive = (opt.getAttribute('data-is-active') || '1') === '1';
                    const suspendedMsg = document.getElementById('customerSuspendedMsg');
                    const saveBtn = document.getElementById('btnSaveInvoiceHeader');
                    if (suspendedMsg) suspendedMsg.classList.toggle('d-none', isActive);
                    if (saveBtn) saveBtn.disabled = !isActive;

                }

                // =========================================================
                // (4) ربط الأحداث: اسم العميل
                // =========================================================
                if (custNameInput) {
                    custNameInput.addEventListener('change', () => {
                        fillFromOption(findByName(custNameInput.value));
                    });

                    custNameInput.addEventListener('keydown', (e) => {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            fillFromOption(findByName(custNameInput.value));
                        }
                    });
                }

                // =========================================================
                // (5) ربط الأحداث: كود العميل
                // =========================================================
                if (custCodeInput) {
                    custCodeInput.addEventListener('change', () => {
                        fillFromOption(findByCode(custCodeInput.value));
                    });

                    custCodeInput.addEventListener('keydown', (e) => {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            fillFromOption(findByCode(custCodeInput.value));
                        }
                    });
                }

                // =========================================================
                // (6) فتح فاتورة قديمة: CustomerId موجود → املأ تلقائيًا
                // =========================================================
                if (custHiddenId && custHiddenId.value) {
                    fillFromOption(findByCode(custHiddenId.value));
                }

                // =========================================================
                // (7) Enter على اسم العميل: الانتقال إلى زر الحفظ ثم الضغط عليه
                // =========================================================
                let isSaveButtonFocused = false; // متغير: هل زر الحفظ في حالة focus

                custNameInput?.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        
                        const saveBtn = document.getElementById('btnSaveInvoiceHeader');
                        if (!saveBtn) return;

                        if (!isSaveButtonFocused) {
                            // المرة الأولى: الانتقال إلى زر الحفظ
                            isSaveButtonFocused = true;
                            saveBtn.focus();
                        } else {
                            // المرة الثانية: الضغط على زر الحفظ
                            isSaveButtonFocused = false;
                            saveBtn.click();
                        }
                    } else {
                        // أي مفتاح آخر: إعادة تعيين الحالة
                        isSaveButtonFocused = false;
                    }
                });

                // إعادة تعيين الحالة عند blur من حقل اسم العميل
                custNameInput?.addEventListener('blur', function() {
                    isSaveButtonFocused = false;
                });

            })();







                    // =========================================================
                    // (B) أوتوكومبليت الصنف + كارت بياناته + التابات + إضافة سطر
                    // =========================================================
                    (function () {

                        // 1) عناصر سطر الصنف في الفاتورة
                        const prodCodeInput   = document.getElementById('ProdCodeInput');     // متغير: كود الصنف للبحث
                        const prodNameInput   = document.getElementById('ProdNameInput');     // متغير: اسم الصنف (أوتوكومبليت)
                        const prodPriceInput  = document.getElementById('ProdPriceInput');    // متغير: سعر الجمهور
                        const prodQtyInput    = document.getElementById('ProdQtyInput');      // متغير: الكمية
                        const prodDisc1Input  = document.getElementById('ProdDisc1Input');    // متغير: خصم البيع %
                        const prodBatchInput  = document.getElementById('ProdBatchInput');    // متغير: الباتش
                        const prodExpiryInput = document.getElementById('ProdExpiryInput');   // متغير: تاريخ الصلاحية
                        const prodHiddenId    = document.getElementById('ProdId');            // متغير: المعرّف الداخلي للصنف
                        const btnAddLine      = document.getElementById('btnAddInvoiceLine'); // متغير: زر إضافة السطر

                        // 2) عناصر كارت بيانات الصنف
                        const prodQtyWarehouse = document.getElementById('ProdQtyCurrentWarehouse'); // متغير: كمية هذا المخزن
                        const prodQtyAll       = document.getElementById('ProdQtyAllWarehouses');   // متغير: إجمالي الكمية
                        const prodQuotaText    = document.getElementById('ProdQuotaText');          // متغير: هل له كوتة؟
                        const prodWeightedDisc = document.getElementById('ProdWeightedDiscount');   // متغير: الخصم المرجّح
                        const prodAltSelect    = document.getElementById('AlternativeProducts');    // متغير: قائمة البدائل

                        // 3) datalist الخاصة بالأصناف
                        const prodDataList = (prodNameInput && prodNameInput.list) ? prodNameInput.list : null;

                        // 4) جدول تشغيلات FEFO داخل كارت بيانات الصنف
                        const batchQueueBody = document.getElementById('BatchQueueBody'); // متغير: جسم جدول التشغيلات (tbody)

                        // 5) مخزن الفاتورة (لازم يكون موجود في الهيدر)
                         const warehouseInput = document.getElementById('WarehouseId');    // متغير: رقم المخزن الحالي


                        if (!prodDataList) {
                            console.warn('⚠️ لم يتم العثور على قائمة الأصناف (datalist) المرتبطة بـ ProdNameInput.');
                            return;
                        }

                        // =========================================================
                        // دوال مساعدة (أرقام + توحيد نص)
                        // =========================================================

                        // دالة: توحيد النص (تجاهل الألف + إزالة مسافات مكررة)
                        function normalizeText(txt) {
                            return (txt || '')
                                .trim()
                                .toLowerCase()
                                .replace(/^[اأإآ]/, '')
                                .replace(/\s+/g, ' ');
                        }

                        // دالة: تحويل النص لرقم (decimal) بأمان
                        function parseDecimalSafe(val) {
                            const s = (val || '').toString().trim().replace(',', '.');
                            const n = parseFloat(s);
                            return isNaN(n) ? 0 : n;
                        }

                        // دالة: تنسيق رقم (رقمين عشريين)
                        function fmt2(val) {
                            return parseDecimalSafe(val).toFixed(2);
                        }

                        // =========================================================
                        // البحث عن صنف بالاسم / بالكود داخل datalist
                        // =========================================================

                        function findProductByName(name) {
                            const search = normalizeText(name);
                            if (!search) return null;

                            const opts = prodDataList.options;

                            // 1) تطابق تام
                            for (let i = 0; i < opts.length; i++) {
                                if (normalizeText(opts[i].value) === search) return opts[i];
                            }

                            // 2) يبدأ بـ (StartsWith فقط — لا Contains)
                            for (let i = 0; i < opts.length; i++) {
                                if (normalizeText(opts[i].value).startsWith(search)) return opts[i];
                            }

                            return null;
                        }

                        function findProductByCode(code) {
                            const search = (code || '').toString().trim();
                            if (!search) return null;

                            const opts = prodDataList.options;
                            for (let i = 0; i < opts.length; i++) {
                                const idAttr   = (opts[i].getAttribute('data-id')   || '').toString();
                                const codeAttr = (opts[i].getAttribute('data-code') || '').toString();
                                if (idAttr === search || codeAttr === search) return opts[i];
                            }
                            return null;
                        }

                        // =========================================================
                        // تعبئة بيانات الصنف من <option>
                        // =========================================================
                        function fillProductFromOption(opt) {

                            // لو مفيش صنف مطابق → نفرّغ
                            if (!opt) {
                                if (prodHiddenId)    prodHiddenId.value    = '';
                                if (prodCodeInput)   prodCodeInput.value   = '';
                                if (prodNameInput)   prodNameInput.value   = '';
                                if (prodPriceInput)  prodPriceInput.value  = '';

                                if (prodQuotaText)    prodQuotaText.value    = 'بدون كوتة';
                                const prodBonusText = document.getElementById('ProdBonusText');
                                if (prodBonusText)    prodBonusText.value    = 'بدون بونص';
                                if (prodWeightedDisc) prodWeightedDisc.value = '0';

                                if (prodQtyWarehouse) prodQtyWarehouse.value = '0';
                                if (prodQtyAll)       prodQtyAll.value       = '0';

                                if (prodAltSelect) {
                                    prodAltSelect.innerHTML = '<option value="">لا توجد بدائل</option>';
                                }
                                return;
                            }

                            // قراءة البيانات من data-*
                            const id       = opt.getAttribute('data-id')      || ''; // متغير: ProdId
                            const code     = opt.getAttribute('data-code')    || id; // متغير: كود ظاهر (قد يساوي id)
                            const name     = opt.value                        || ''; // متغير: اسم الصنف
                            const generic  = opt.getAttribute('data-generic') || ''; // متغير: الاسم العلمي
                            const hasQuota = (opt.getAttribute('data-hasquota') === 'true'); // متغير: هل له كوتة؟
                            const hasBonus = (opt.getAttribute('data-hasbonus') === 'true'); // متغير: هل له بونص؟
                            const bonusGroup = opt.getAttribute('data-bonusgroup') || ''; // متغير: اسم مجموعة البونص
                            let priceRaw   = opt.getAttribute('data-price')   || '0'; // متغير: السعر كنص

                            // معالجة السعر
                            priceRaw = priceRaw.toString().replace(',', '.');
                            let price = parseFloat(priceRaw);
                            if (isNaN(price)) price = 0;

                            if (prodHiddenId)  prodHiddenId.value  = id;
                            if (prodCodeInput) prodCodeInput.value = code;
                            if (prodNameInput) prodNameInput.value = name;
                                        // ✅ لا نأخذ السعر من datalist في المبيعات
            if (prodPriceInput) prodPriceInput.value = '0.00';

            // ✅ بعد تثبيت الصنف: نحمّل التشغيلات FEFO ونملأ السعر/الباتش/الصلاحية
            loadSalesProductInfo(parseInt(id || '0', 10) || 0);


                            if (prodQuotaText) {
                                prodQuotaText.value = hasQuota ? 'له كوتة' : 'بدون كوتة';
                            }
                            const prodBonusText = document.getElementById('ProdBonusText');
                            if (prodBonusText) {
                                prodBonusText.value = hasBonus && bonusGroup ? bonusGroup : 'بدون بونص';
                            }

                            // حالياً: الخصم المرجّح = 0 (هنربطه بالسياسات لاحقاً)
                            if (prodWeightedDisc) {
                                prodWeightedDisc.value = '0';
                            }

                            // بدائل الصنف حسب الاسم العلمي
                            if (prodAltSelect && generic) {
                                loadAlternativeProducts(id);
                            } else if (prodAltSelect) {
                                prodAltSelect.innerHTML = '<option value="">لا توجد بدائل</option>';
                            }
                        }




             // =========================================================
            // ✅ تحميل بيانات الصنف بعد اختياره (Card 2 + تعبئة Card 3 تلقائيًا)
            // - ينادي GetSalesProductInfo
            // - يملأ: الكميات + الخصم المرجح + جدول التشغيلات FEFO
            // - يملأ تلقائيًا: Batch / Expiry / PriceRetailBatch
            // =========================================================
            let busyLoadInfo = false; // متغير: يمنع تداخل استدعاءات متكررة

            async function loadSalesProductInfo(prodId) {
                if (!prodId) return;

                // متغير: رقم المخزن الحالي من الهيدر
                const warehouseId = parseInt((warehouseInput?.value || '0'), 10) || 0;
                if (!warehouseId) {
                    console.warn('⚠️ WarehouseId غير موجود/0 — لا يمكن تحميل التشغيلات FEFO.');
                    return;
                }

                         const customerId = parseInt((document.getElementById('CustomerId')?.value || '0'), 10) || 0;


                if (busyLoadInfo) return;
                busyLoadInfo = true;

                try {
                    const url = '@Url.Action("GetSalesProductInfo", "SalesInvoices")'
                        + '?prodId=' + encodeURIComponent(prodId)
                        + '&warehouseId=' + encodeURIComponent(warehouseId)
                        + '&customerId=' + encodeURIComponent(customerId);

                    const r = await fetch(url, { method: 'GET' });
                    const data = await (r.ok ? r.json() : null);

                    if (!data || !data.ok) {
                        console.warn('⚠️ GetSalesProductInfo فشل:', data?.message || 'no data');

                        // تفريغ سريع لو فشل
                        if (prodQtyWarehouse) prodQtyWarehouse.value = '0';
                        if (prodQtyAll) prodQtyAll.value = '0';
                        if (prodWeightedDisc) prodWeightedDisc.value = '0';
                        if (batchQueueBody) batchQueueBody.innerHTML = `<tr><td colspan="5" class="text-muted">لا توجد تشغيلات بعد.</td></tr>`;
                        return;
                    }

                    // 1) تعبئة كميات كارت 2
                    if (prodQtyWarehouse) prodQtyWarehouse.value = (data.qtyCurrentWarehouse ?? 0);
                    if (prodQtyAll)       prodQtyAll.value       = (data.qtyAllWarehouses ?? 0);

                    // 2) كوتة
                    if (prodQuotaText) prodQuotaText.value = (data.quotaText ?? 'بدون كوتة').toString();

                    // 2.1) مجموعة الصنف
                    const prodGroupText = document.getElementById('ProdGroupText');
                    if (prodGroupText) prodGroupText.value = (data.productGroupName ?? 'بدون مجموعة').toString();

                    // 2.2) سياسة المجموعة المطبقة (رقم/اسم السياسة)
                    const groupPolicyBox = document.getElementById('ProdGroupPolicyText');
                    if (groupPolicyBox) groupPolicyBox.value = (data.appliedGroupPolicyName ?? data.appliedGroupPolicyId ?? '').toString() || '—';

                    // 3) الخصم المرجّح (تحديد بين 0 و 100 وتنسيق لتجنب قيم خاطئة)
                    if (prodWeightedDisc) {
                        const wd = Number(data.weightedDiscount ?? 0);
                        prodWeightedDisc.value = (Number.isFinite(wd) && wd >= 0 && wd <= 100) ? Number(wd).toFixed(2) : '0.00';
                    }


                    // 3.1) ✅ خصم البيع (من السياسات + الخصم المرجح) — تحديد بين 0 و 100
                    if (prodDisc1Input) {
                        const sd = Number(data.saleDisc1 ?? 0);
                        prodDisc1Input.value = (Number.isFinite(sd) && sd >= 0 && sd <= 100) ? Number(sd).toFixed(2) : '0.00';
                    }


                    // 4) جدول تشغيلات FEFO (كارت 2)
                    if (batchQueueBody) {
                        const batches = data.batches || [];
                        if (!batches.length) {
                            batchQueueBody.innerHTML = `<tr><td colspan="5" class="text-muted">لا توجد تشغيلات متاحة لهذا الصنف في هذا المخزن.</td></tr>`;
                        } else {
                            batchQueueBody.innerHTML = batches.map((b, idx) => `
                                <tr class="${idx === 0 ? 'table-success' : ''}">
                                    <td>${idx + 1}</td>
                                    <td>${b.batchNo || ''}</td>
                                    <td>${b.expiryText || ''}</td>
                                    <td>${b.qty ?? 0}</td>
                                    <td>${fmt2(b.priceRetailBatch ?? 0)}</td>
                                </tr>
                            `).join('');
                        }
                    }

                    // 5) تعبئة Card 3 تلقائيًا من أول تشغيلة FEFO (Auto)
                    if (data.auto) {
                        if (prodBatchInput)  prodBatchInput.value  = data.auto.batchNo || '';
                        if (prodExpiryInput) prodExpiryInput.value = data.auto.expiryText || '';
                        if (prodPriceInput)  prodPriceInput.value  = fmt2(data.auto.priceRetailBatch ?? 0);
                    }

                    // ✅ تثبيت قفل السعر دائمًا
                    forcePriceLocked();

                } catch (err) {
                    console.error('❌ خطأ أثناء تحميل بيانات الصنف:', err);
                } finally {
                    busyLoadInfo = false;
                }
            }





                        // =========================================================
                        // تحميل البدائل من الكنترولر
                        // =========================================================
                        function loadAlternativeProducts(prodId) {
                            if (!prodId || !prodAltSelect) return;

                            const url = '@Url.Action("GetAlternativeProducts", "SalesInvoices")'
                                + '?prodId=' + encodeURIComponent(prodId);

                            prodAltSelect.innerHTML = '<option value="">... جاري تحميل البدائل</option>';

                            fetch(url)
                                .then(r => r.ok ? r.json() : [])
                                .then(data => {
                                    prodAltSelect.innerHTML = '<option value="">اختر بديلاً (للمشاهدة فقط)</option>';

                                    if (!data || !data.length) {
                                        prodAltSelect.innerHTML += '<option value="">لا توجد بدائل</option>';
                                        return;
                                    }

                                    data.forEach(p => {
                                        const op = document.createElement('option');
                                        op.value = p.id;
                                        op.textContent = `${p.name || ''} — ${p.company || ''} — ${p.price || 0}`;
                                        op.setAttribute('data-id', p.id);
                                        op.setAttribute('data-price', p.price || 0);
                                        prodAltSelect.appendChild(op);
                                    });
                                })
                                .catch(err => {
                                    console.error('❌ خطأ في تحميل بدائل الصنف:', err);
                                    prodAltSelect.innerHTML = '<option value="">خطأ في تحميل البدائل</option>';
                                });
                        }

                        // =========================================================
                        // Events: اسم الصنف / كود الصنف
                        // =========================================================
                        if (prodNameInput) {
                            prodNameInput.addEventListener('change', function () {
                                fillProductFromOption(findProductByName(this.value));
                            });

                            prodNameInput.addEventListener('keydown', function (e) {
                                if (e.key === 'Enter') {
                                    e.preventDefault();
                                    fillProductFromOption(findProductByName(this.value));

                                    // بعد اختيار الاسم → ننتقل للسعر (لو مفتوح)
                                    if (prodPriceInput) {
                                        prodPriceInput.focus();
                                        prodPriceInput.select?.();
                                    }
                                }
                            });

                            prodNameInput.addEventListener('blur', function () {
                                fillProductFromOption(findProductByName(this.value));
                            });
                        }

                        if (prodCodeInput) {
                            prodCodeInput.addEventListener('change', function () {
                                fillProductFromOption(findProductByCode(this.value));
                            });

                            prodCodeInput.addEventListener('keydown', function (e) {
                                if (e.key === 'Enter') {
                                    e.preventDefault();
                                    fillProductFromOption(findProductByCode(this.value));

                                    // بعد اختيار الكود → ننتقل للاسم
                                    if (prodNameInput) {
                                        prodNameInput.focus();
                                        prodNameInput.select?.();
                                    }
                                }
                            });
                        }





             // =========================================================
            // ✅ السعر في المبيعات ليس اختياريًا
            // - السعر يأتي من التشغيلة FEFO (Batch.PriceRetailBatch)
            // - لذلك نخلي ProdPriceInput مقفول دائمًا
            // =========================================================
            const priceLabel     = document.getElementById('ProdPriceLabel');       // متغير: Label السعر
            const priceLockState = document.getElementById('ProdPriceLockState');   // متغير: (مغلق/مفتوح)

            function forcePriceLocked() {
                if (!prodPriceInput) return;

                prodPriceInput.readOnly = true; // ✅ ثابت
                prodPriceInput.classList.add('bg-light', 'text-muted'); // شكل مقفول
                if (priceLockState) priceLockState.textContent = '(مغلق)';
                if (priceLabel) priceLabel.style.cursor = 'default';
            }
            forcePriceLocked();









             // =========================================================
            // قفل / فتح خصم البيع (بالضغط على اللابل)
            // ✅ المطلوب:
            // - الخصم ييجي أوتوماتيك من السيرفيس (GetSalesProductInfo) ويتكتب في البوكس
            // - افتراضيًا يكون "مقفول" (ReadOnly)
            // - لو المستخدم ضغط على كلمة "الخصم" → يفتح/يقفل
            // - عند الفتح: يعمل Focus + Select للبوكس
            // - كل مرة يتغير القفل: ننادي rebuildEnterNav() علشان Enter يتخطى المقفول
            // =========================================================
            const disc1Label     = document.getElementById('ProdDisc1Label');      // متغير: Label الخصم
            const disc1LockState = document.getElementById('ProdDisc1LockState');  // متغير: (مغلق/مفتوح)
            let disc1Locked = true;                                                // متغير: حالة قفل الخصم (افتراضي مقفول)

            // دالة: تطبيق شكل القفل على UI
            function applyDisc1LockUI() {
                if (!prodDisc1Input) return;

                // ✅ قفل/فتح
                prodDisc1Input.readOnly = disc1Locked;

                // ✅ شكل مقفول/مفتوح
                if (disc1Locked) {
                    prodDisc1Input.classList.add('bg-light', 'text-muted');
                    prodDisc1Input.style.cursor = 'not-allowed';
                    if (disc1LockState) disc1LockState.textContent = '(مغلق)';
                } else {
                    prodDisc1Input.classList.remove('bg-light', 'text-muted');
                    prodDisc1Input.style.cursor = 'text';
                    if (disc1LockState) disc1LockState.textContent = '(مفتوح)';

                    // ✅ عند الفتح: فوكس + تحديد كامل
                    setTimeout(() => {
                        prodDisc1Input.focus();
                        if (typeof prodDisc1Input.select === 'function') prodDisc1Input.select();
                    }, 0);
                }
            }

            // ✅ تطبيق الحالة الافتراضية
            applyDisc1LockUI();

            // ✅ الضغط على اللابل يفتح/يقفل
            if (disc1Label) {
                disc1Label.style.cursor = 'pointer';

                // ملاحظة: لو السكربت بيتنفذ أكتر من مرة، ده يمنع تكرار الربط
                if (disc1Label.dataset.boundDisc1Toggle !== '1') {
                    disc1Label.dataset.boundDisc1Toggle = '1';

                    disc1Label.addEventListener('click', function () {
                        disc1Locked = !disc1Locked;  // قلب الحالة
                        applyDisc1LockUI();          // طبّق UI

                        // ✅ مهم: تحديث مسار Enter (لا يمر على المقفول)
                        if (typeof rebuildEnterNav === 'function') {
                            rebuildEnterNav();
                        }
                    });



                }
            }

                        // -------------------------
            // (2) قفل/فتح التشغيلة (Batch)
            // -------------------------
            const batchLabel     = document.getElementById('ProdBatchLabel');       // متغير: Label التشغيلة
            const batchLockState = document.getElementById('ProdBatchLockState');   // متغير: (مغلق/مفتوح)
            let batchLocked = true; // متغير: حالة قفل التشغيلة (افتراضي مغلق)

            function applyBatchLockUI() {
                if (!prodBatchInput) return;

                prodBatchInput.readOnly = batchLocked;

                if (batchLocked) {
                    prodBatchInput.classList.add('bg-light', 'text-muted');
                    if (batchLockState) batchLockState.textContent = '(مغلق)';
                } else {
                    prodBatchInput.classList.remove('bg-light', 'text-muted');
                    if (batchLockState) batchLockState.textContent = '(مفتوح)';
                }
            }
            applyBatchLockUI();

            if (batchLabel) {
                batchLabel.style.cursor = 'pointer';
                batchLabel.addEventListener('click', function () {
                    batchLocked = !batchLocked;
                    applyBatchLockUI();
                    if (typeof rebuildEnterNav === 'function') rebuildEnterNav(); // ✅ مهم
                    if (!batchLocked && prodBatchInput) {
                        prodBatchInput.focus();
                        prodBatchInput.select?.();
                    }
                });
            }

                        // -------------------------
            // (3) قفل/فتح الصلاحية (Expiry)
            // -------------------------
            const expiryLabel     = document.getElementById('ProdExpiryLabel');       // متغير: Label الصلاحية
            const expiryLockState = document.getElementById('ProdExpiryLockState');   // متغير: (مغلق/مفتوح)
            let expiryLocked = true; // متغير: حالة قفل الصلاحية (افتراضي مغلق)

            function applyExpiryLockUI() {
                if (!prodExpiryInput) return;

                prodExpiryInput.readOnly = expiryLocked;

                if (expiryLocked) {
                    prodExpiryInput.classList.add('bg-light', 'text-muted');
                    if (expiryLockState) expiryLockState.textContent = '(مغلق)';
                } else {
                    prodExpiryInput.classList.remove('bg-light', 'text-muted');
                    if (expiryLockState) expiryLockState.textContent = '(مفتوح)';
                }
            }
            applyExpiryLockUI();

            if (expiryLabel) {
                expiryLabel.style.cursor = 'pointer';
                expiryLabel.addEventListener('click', function () {
                    expiryLocked = !expiryLocked;
                    applyExpiryLockUI();
                    if (typeof rebuildEnterNav === 'function') rebuildEnterNav(); // ✅ مهم
                    if (!expiryLocked && prodExpiryInput) {
                        prodExpiryInput.focus();
                        prodExpiryInput.select?.();
                    }
                });
            }




            // =========================================================
            // ✅ غلق/فتح الحقول + تنقل Enter ذكي
            // المطلوب:
            // - السعر/الباتش/الصلاحية/الكود: مقفولين دائمًا (ReadOnly)
            // - الخصم: افتراضيًا مقفول، ويتفتح/يتقفل بالضغط على اللابل
            // - Enter: يمر فقط على الحقول "المفتوحة" (مش ReadOnly ومش Disabled)
            // =========================================================

            // =========================
            // (1) غلق دائم لبعض الحقول
            // =========================
            function forceAlwaysLockedFields() {
                // ✅ الكود (مقفول)
                if (prodCodeInput) {
                    prodCodeInput.readOnly = true;
                    prodCodeInput.classList.add('bg-light', 'text-muted');
                    prodCodeInput.style.cursor = 'not-allowed';
                }

                // ✅ السعر (مقفول دائمًا)
                if (prodPriceInput) {
                    prodPriceInput.readOnly = true;
                    prodPriceInput.classList.add('bg-light', 'text-muted');
                    prodPriceInput.style.cursor = 'not-allowed';
                }

                // ✅ الباتش (مقفول)
                if (prodBatchInput) {
                    prodBatchInput.readOnly = true;
                    prodBatchInput.classList.add('bg-light', 'text-muted');
                    prodBatchInput.style.cursor = 'not-allowed';
                }

                // ✅ الصلاحية (مقفولة)
                if (prodExpiryInput) {
                    prodExpiryInput.readOnly = true;
                    prodExpiryInput.classList.add('bg-light', 'text-muted');
                    prodExpiryInput.style.cursor = 'not-allowed';
                }
            }

            // نفّذ الغلق فورًا عند تحميل الصفحة
            forceAlwaysLockedFields();

            // =========================
            // (2) تحديد هل الحقل ينفع يدخل في مسار Enter أم لا
            // =========================
            function isEnterEligible(el) {
                if (!el) return false;

                // لو مخفي أو مش ظاهر
                if (el.offsetParent === null) return false;

                // لو Disabled
                if (el.disabled) return false;

                // ✅ أهم شرط: لو ReadOnly يبقى يتشال من مسار Enter
                // (عشان مايروحش للسعر وهو مقفول)
                if (el.readOnly) return false;

                return true;
            }

            // =========================
            // (3) بناء مسار Enter ديناميكي
            // =========================
            let enterInputs = []; // متغير: قائمة الحقول اللي Enter يتحرك عليها

            function rebuildEnterNav() {
                // ✅ تأكد إن الحقول المقفولة مقفولة فعلًا
                forceAlwaysLockedFields();

                // ✅ ابنِ المسار فقط من الحقول "المفتوحة"
                // ملاحظة: اسم الصنف عادةً مفتوح (للبحث)
                // والكمية مفتوحة
                // والخصم يعتمد على disc1Locked
                enterInputs = [
                    prodNameInput,   // متغير: البحث بالاسم
                    prodQtyInput,    // متغير: الكمية
                    prodDisc1Input   // متغير: الخصم (يدخل فقط لو مفتوح)
                ].filter(isEnterEligible);
            }

            // ابنِ المسار أول مرة
            rebuildEnterNav();

            // =========================
            // (4) ربط Enter على الحقول (مرة واحدة بدون تكرار)
            // =========================
            function bindEnterNavigationOnce(el) {
                if (!el) return;
                if (el.dataset.boundEnterNav === '1') return; // يمنع التكرار
                el.dataset.boundEnterNav = '1';

                // عند الفوكس: تحديد النص
                el.addEventListener('focus', function () {
                    if (typeof this.select === 'function') {
                        setTimeout(() => this.select(), 0);
                    }
                });

                // Enter: يروح للي بعده حسب enterInputs الحالي
                el.addEventListener('keydown', function (e) {
                    if (e.key !== 'Enter') return;

                    e.preventDefault();

                    // لو داخل اسم الصنف: ثبت الاختيار
                    if (el === prodNameInput) {
                        fillProductFromOption(findProductByName(prodNameInput.value));
