                        // =========================
                        // اعتراض الضغط على الأسهم/بحث الفاتورة على مستوى document (Capture)
                        // =========================
                        async function docCaptureHandler(ev) {

                            // متغير: العنصر الذي تم الضغط عليه
                            const t = ev.target;

                            // حماية: لو target مش Element (نادرًا) نخرج
                            if (!(t instanceof Element)) return;

                                    // =========================
                        // (0.5) زر حجم التعامل: منع الضغط عند عدم اختيار عميل
                        // =========================
                        const volBtn = t.closest('#btnCustomerVolume');
                        if (volBtn && volBtn.dataset.volumeEnabled === '0') {
                            ev.preventDefault();
                            ev.stopPropagation();
                            return;
                        }

                                    // =========================
                        // (0) زر مسح سطر من الفاتورة
                        // =========================
                        const removeBtn = t.closest('.btnRemoveLineFromInvoice');
                        if (removeBtn) {

                            ev.preventDefault();
                            ev.stopPropagation();
                            ev.stopImmediatePropagation();

                            // متغير: رقم السطر داخل الفاتورة
                            const lineNo = parseInt(removeBtn.getAttribute('data-line-no') || '0', 10);

                            // متغير: رقم الفاتورة الحالية (موجود في hidden input داخل الـ body)
                            const siId = parseInt((document.getElementById('NavCurrentId')?.value || '0'), 10);

                            if (!siId || siId <= 0) { alert('لا يمكن مسح سطر: رقم الفاتورة غير معروف.'); return; }
                            if (!lineNo || lineNo <= 0) { alert('لا يمكن مسح سطر: رقم السطر غير صحيح.'); return; }

                            // تأكيد بسيط
                            if (!confirm(`هل تريد مسح السطر رقم (${lineNo})؟`)) return;

                            // منع الضغط المتكرر أثناء التنفيذ
                            removeBtn.disabled = true;

                            // ✅ متغير: توكن AntiForgery (من الدالة المثبتة عندك في Show)
                            const antiToken = (window.getAntiForgeryToken ? window.getAntiForgeryToken() : '');

                            // متغير: تايم آوت علشان ما يفضلش معلق
                            const controller = new AbortController();
                            const timeoutId = setTimeout(() => controller.abort(), 30000); // 30 ثانية

                            try {
                                // ✅ استدعاء الأكشن الصحيح: RemoveLineJson
                                const res = await fetch('@Url.Action("RemoveLineJson", "SalesInvoices")', {
                                    method: 'POST',
                                    credentials: 'same-origin',
                                    signal: controller.signal,
                                    headers: {
                                        'Content-Type': 'application/json',
                                        'X-Requested-With': 'XMLHttpRequest',
                                        ...(antiToken ? { 'RequestVerificationToken': antiToken } : {})
                                    },
                                    // ✅ لازم نفس أسماء الـ DTO
                                    body: JSON.stringify({ SIId: siId, LineNo: lineNo })
                                });

                                // متغير: نحاول نفهم الرد سواء JSON أو نص
                                let data = null;
                                const contentType = (res.headers.get('content-type') || '').toLowerCase();

                                if (contentType.includes('application/json')) {
                                    data = await res.json().catch(() => null);
                                } else {
                                    const txt = await res.text().catch(() => '');
                                    data = { ok: false, message: txt ? 'فشل مسح السطر (رد غير متوقع من السيرفر).' : 'فشل مسح السطر.' };
                                }

                                if (!res.ok || !data || data.ok !== true) {
                                    const msg = (data && data.message) ? data.message : 'فشل مسح السطر.';
                                    alert(msg);
                                    return;
                                }

                                // ✅ بعد المسح: تحديث الجدول والإجماليات من الردّ (دون إعادة تحميل الـ body)
                                const lines = Array.isArray(data.lines) ? data.lines : [];
                                window.__piLinesCache = lines;
                                const fnRender = window.renderGroupedLines;
                                if (typeof fnRender === 'function') {
                                    fnRender(lines);
                                } else {
                                    await loadInvoiceBody(setOrReplaceParam(
                                        document.getElementById('btnNavInvoiceSearch')?.getAttribute('data-base-url') || '@Url.Action("Show", "SalesInvoices", new { frame = 1 })',
                                        'id', siId
                                    ));
                                }
                                if (data.totals) {
                                    const fnTotals = window.updateSummaryBadges;
                                    if (typeof fnTotals === 'function') fnTotals(data.totals);
                                }

                                const prodInput = document.getElementById('ProdNameInput');
                                if (prodInput) { prodInput.focus(); prodInput.select && prodInput.select(); }

                            } catch (e) {
                                console.error(e);

                                if (e && e.name === 'AbortError') {
                                    alert('التنفيذ أخذ وقت طويل. حاول مرة أخرى.');
                                } else {
                                    alert('حدث خطأ أثناء مسح السطر.');
                                }
                            } finally {
                                clearTimeout(timeoutId);

                                if (document.contains(removeBtn)) {
                                    removeBtn.disabled = false;
                                }
                            }

                            return; // مهم: منع استمرار التعامل كأنه زر أسهم
                        }






                            // =========================
                            // (1) الأسهم + البحث
                            // =========================
                            const btn = t.closest('#btnFirstInvoice, #btnPrevInvoice, #btnNextInvoice, #btnLastInvoice, #btnNavInvoiceSearch');
                            if (!btn) return;

                            if (btn.hasAttribute('disabled')) return;

                            // ✅ امنع أي نظام تابات/لينكات
                            ev.preventDefault();
                            ev.stopPropagation();
                            ev.stopImmediatePropagation();

                            // ✅ مهم: اقفل Tooltip + شيل فوكس بعد الضغط
                            hideTooltipAndBlur(btn);

                            if (btn.id === 'btnNavInvoiceSearch') {
