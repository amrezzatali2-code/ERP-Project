                        @* =====================================================
                       5) جدول السطور
                       ===================================================== *@
                        @* <div class="card shadow-sm mb-3 invoice-lines-card"> *@
                        @* <div class="card-header py-2 invoice-lines-header">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">سطور فاتورة المبيعات</span>
                            </div>
                        </div> *@

                        @* <div class="card-body p-0"> *@
                        <div class="invoice-lines-container">
                        <div class="erp-table-wrapper mb-0">
                            <table class="table table-sm table-striped table-hover mb-0 erp-table">
                                <thead class="invoice-lines-header">
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">التشغيلة</th>
                                        <th class="text-center">الصلاحية</th>
                                        <th class="text-center">الكمية</th>
                                        <th class="text-center">سعر الجمهور</th>
                                        <th class="text-center">خصم البيع %</th>
                                        <th class="text-center">قيمة السطر</th>
                                        <th class="text-center no-print">مسح</th>
                                    </tr>
                                </thead>

                                <tbody id="PILinesTbody">
                                    @{
                                        var linesList = Model.Lines?.OrderBy(l => l.LineNo).ToList()
                                        ?? new List<ERP.Models.SalesInvoiceLine>();

                                        var groups = linesList
                                        .GroupBy(l => new
                                        {
                                            l.ProdId,
                                            ProdName = l.Product?.ProdName ?? ("صنف #" + l.ProdId)
                                        })
                                        .OrderBy(g => g.Key.ProdName);
                                    }

                                    @if (!groups.Any())
                                    {
                                        <tr>
                                            <td colspan="9" class="text-center text-muted py-3">
                                                لا يوجد سطور داخل الفاتورة حتى الآن.
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var g in groups)
                                        {
                                            int batchCount = g.Count();

                                            if (batchCount == 1)
                                            {
                                                var line = g.First();
                                                decimal lineValue = line.LineTotalAfterDiscount;

                                                <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                    <td class="text-center">@line.LineNo</td>

                                                    <td>
                                                        <strong>@g.Key.ProdName</strong>
                                                        <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                    </td>

                                                    <td class="text-center">@line.BatchNo</td>

                                                    <td class="text-center">
                                                        @(line.Expiry.HasValue? line.Expiry.Value.ToString("yyyy-MM-dd") : "")
                                                    </td>

                                                    <td class="text-center">@line.Qty</td>

                                                    <td class="text-center">@line.PriceRetail.ToString("0.00")</td>

                                                    <td class="text-center">@line.Disc1Percent.ToString("0.##")</td>

                                                    <td class="text-center">@lineValue.ToString("0.00")</td>

                                                    <td class="text-center no-print">
                                                        <button type="button"
                                                                class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                                                data-line-no="@line.LineNo" data-lock-posted="1">
                                                            مسح
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                            else
                                            {
                                                <tr class="table-light pi-group-row" data-prodid="@g.Key.ProdId">
                                                    <td class="text-center">—</td>

                                                    <td>
                                                        <strong>@g.Key.ProdName</strong>
                                                        <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                    </td>

                                                    <td class="text-center text-muted small">تشغيلات: @batchCount</td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                </tr>

                                                foreach (var line in g.OrderBy(x => x.LineNo))
                                                {
                                                    decimal lineValue = line.LineTotalAfterDiscount;

                                                    <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                        <td class="text-center">@line.LineNo</td>
                                                        <td class="text-muted small">↳</td>
                                                        <td class="text-center">@line.BatchNo</td>
                                                        <td class="text-center">
                                                            @(line.Expiry.HasValue? line.Expiry.Value.ToString("yyyy-MM-dd") : "")
                                                        </td>
                                                        <td class="text-center">@line.Qty</td>
                                                        <td class="text-center">@line.PriceRetail.ToString("0.00")</td>
                                                        <td class="text-center">@line.Disc1Percent.ToString("0.##")</td>
                                                        <td class="text-center">@lineValue.ToString("0.00")</td>
                                                        <td class="text-center no-print">
                                                            <button type="button"
                                                                    class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                                                    data-line-no="@line.LineNo">
                                                                مسح
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        </div>
                        @*     </div>
                    </div> *@

                        @* =====================================================
                       6) ملخص الفاتورة
                       ===================================================== *@
                        @{
                            var lines = Model.Lines?.ToList() ?? new List<ERP.Models.SalesInvoiceLine>();

                            int totalLines = lines.Count;
                            int totalItems = lines.Select(l => l.ProdId).Distinct().Count();
                            int totalQty = lines.Sum(l => l.Qty);

                            decimal totalRetail = lines.Sum(l => l.Qty * l.PriceRetail);
                            decimal totalAfterDiscount = Model.TotalAfterDiscountBeforeTax;
                            if (totalAfterDiscount == 0 && lines.Any())
                            {
                                totalAfterDiscount = lines.Sum(l => l.LineTotalAfterDiscount) - Model.HeaderDiscountValue;
                                if (totalAfterDiscount < 0) totalAfterDiscount = 0;
                            }

                            decimal taxAmount = Model.TaxAmount;
                            decimal totalAfterDiscountAndTax = totalAfterDiscount + taxAmount;
                            decimal netTotal = totalAfterDiscountAndTax;
                            // نسبة الضريبة المعروضة (للإدخال): من الإجمالي بعد الخصم
                            decimal taxPercentDisplay = totalAfterDiscount > 0 ? Math.Round(taxAmount * 100m / totalAfterDiscount, 2) : 0m;
                        }

                        <div class="card shadow-sm invoice-totals-card">
                            <div class="card-body">

                                <div class="d-flex flex-wrap align-items-center invoice-summary-row">
                                    <div class="invoice-summary-item">
                                        <span class="small text-muted d-block">عدد السطور</span>
                                        <span id="TotalLinesValue" class="badge bg-light text-dark invoice-summary-badge">@totalLines</span>
                                    </div>
                                    <div class="invoice-summary-item">
                                        <span class="small text-muted d-block">عدد الأصناف</span>
                                        <span id="TotalItemsValue" class="badge bg-light text-dark invoice-summary-badge">@totalItems</span>
                                    </div>
                                    <div class="invoice-summary-item">
                                        <span class="small text-muted d-block">إجمالي الكمية</span>
                                        <span id="TotalQtyValue" class="badge bg-light text-dark invoice-summary-badge">@totalQty</span>
                                    </div>
                                    <div class="invoice-summary-item">
                                        <span class="small text-muted d-block">إجمالي سعر الجمهور</span>
                                        <span id="TotalRetailValue" class="badge bg-light text-dark invoice-summary-badge">@totalRetail.ToString("0.00")</span>
                                    </div>
                                    <div class="invoice-summary-item">
                                        <span class="small text-muted d-block">الإجمالي بعد الخصم</span>
                                        <span id="TotalAfterDiscountValue" class="badge bg-light text-dark invoice-summary-badge">@totalAfterDiscount.ToString("0.00")</span>
                                    </div>
                                    <div class="invoice-summary-item">
                                        <label class="form-label form-label-sm mb-0 small">نسبة الضريبة %</label>
                                        <input type="number" step="0.01" id="TaxPercentInput"
                                               class="form-control form-control-sm text-center pi-input invoice-summary-tax"
                                               value="@taxPercentDisplay.ToString("0.00")" placeholder="0" data-lock-posted="1"/>
                                        <span id="TaxAmountDisplay" class="small text-muted d-block mt-1">قيمة الضريبة: <strong id="TaxAmountValue">@taxAmount.ToString("0.00")</strong></span>
                                    </div>
                                    <div class="invoice-summary-item invoice-summary-total">
                                        <span class="small text-muted d-block">الإجمالي بعد الخصم والضريبة</span>
                                        <span id="TotalAfterDiscountAndTaxValue" class="badge bg-primary text-white invoice-summary-badge fw-bold">@totalAfterDiscountAndTax.ToString("0.00")</span>
                                        <span id="NetTotalValue" class="visually-hidden">@netTotal.ToString("0.00")</span>
                                    </div>
                                    <div class="invoice-summary-item">
                                        <span class="small text-muted d-block">الحساب السابق للعميل</span>
                                        <span id="CustomerPreviousBalanceValue" class="badge bg-light text-dark invoice-summary-badge">@((Model?.Customer?.CurrentBalance ?? 0m).ToString("0.00"))</span>
                                    </div>
                                    <div class="invoice-summary-item">
                                        <span class="small text-muted d-block">المبلغ المتبقى من الحد الائتماني</span>
                                        <span id="CreditRemainingValue" class="badge bg-light text-dark invoice-summary-badge">@((Math.Max(0, (Model?.Customer?.CreditLimit ?? 0m) - (Model?.Customer?.CurrentBalance ?? 0m) - netTotal)).ToString("0.00"))</span>
                                    </div>
                                    @if (Model.UpdatedAt.HasValue)
                                    {
                                        <div class="small text-muted ms-auto">
                                            آخر تعديل: <span class="fw-semibold">@Model.UpdatedAt.Value.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</span>
                                        </div>
                                    }
                                </div>

                            </div>
                        </div>

                    </div> @* ✅ نهاية PI_BodyHost *@

                </div> @* نهاية العمود الرئيسي *@




            </div> @* نهاية row *@
        </div> @* نهاية container *@
    </div> @* نهاية invoice-page *@









