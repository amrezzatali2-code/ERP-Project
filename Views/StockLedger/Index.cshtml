            @if (!string.IsNullOrWhiteSpace(filterCol_qtyoutExpr)) { <input type="hidden" name="filterCol_qtyoutExpr" value="@filterCol_qtyoutExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_unitcostExpr)) { <input type="hidden" name="filterCol_unitcostExpr" value="@filterCol_unitcostExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_remExpr)) { <input type="hidden" name="filterCol_remExpr" value="@filterCol_remExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_priceretailExpr)) { <input type="hidden" name="filterCol_priceretailExpr" value="@filterCol_priceretailExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_purchasediscountExpr)) { <input type="hidden" name="filterCol_purchasediscountExpr" value="@filterCol_purchasediscountExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_totalcostExpr)) { <input type="hidden" name="filterCol_totalcostExpr" value="@filterCol_totalcostExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_warehouse_name)) { <input type="hidden" name="filterCol_warehouse_name" value="@filterCol_warehouse_name" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_branch)) { <input type="hidden" name="filterCol_branch" value="@filterCol_branch" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_createdby)) { <input type="hidden" name="filterCol_createdby" value="@filterCol_createdby" /> }
            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
            </select>
        </form>
    </div>
    <script>
        (function () {
            var params = new URLSearchParams(window.location.search);
            var psq = params.get('pageSize');
            var sel = document.querySelector('select[name="pageSize"]');
            if (sel && psq !== null && psq !== '') sel.value = psq;
        })();
    </script>

    @* ===== الترقيم (وسط الصفحة — نمط قائمة الأصناف) ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center mb-0">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">صفحة @(page) من @(pages)</span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

