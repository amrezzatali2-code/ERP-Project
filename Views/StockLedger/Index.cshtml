@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<StockLedger>

@{
    ViewData["Title"] = "دفتر الحركة المخزنية";

    // أسماء الأكشن/الكنترولر
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "StockLedger";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = Model.SearchBy ?? (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "TranDate";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "desc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلترة بالتاريخ/الوقت (تاريخ الحركة)
    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;

    // فلتر رقم القيد من/إلى (هنستخدمه في اللينكات فقط الآن)
    int? fromEntry = ViewBag.FromEntry as int?;
    int? toEntry = ViewBag.ToEntry as int?;

    // دالة توليد لينكات الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        fromEntry,
        toEntry
    })!;

    // دالة لإنشاء لينك الترتيب في رأس الجدول + أيقونة السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate,
            fromEntry,
            toEntry
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString(
            $@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>"
        );
    };
}

<div dir="rtl" class="container-fluid">

    @* العنوان وعدد القيود *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">@ViewData["Title"]</h4>

        <small class="text-muted d-none d-md-inline">
            عدد القيود الحالية: @total
        </small>
    </div>

    @* ===== الكارت العلوي: بحث + فلتر رقم القيد + أزرار التحكم ===== *@
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* العمود الأول: البحث *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث</label>
                        </div>

                        <div class="col-sm-4">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-4">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                <option value="all"
                                        selected="@(searchBy == "all" ? "selected" : null)">
                                    الكل
                                </option>

                                <option value="entry"
                                        selected="@(searchBy == "entry" ? "selected" : null)">
                                    رقم القيد
                                </option>

                                <option value="trandate"
                                        selected="@(searchBy == "trandate" ? "selected" : null)">
                                    تاريخ الحركة
                                </option>

                                <option value="warehouse"
                                        selected="@(searchBy == "warehouse" ? "selected" : null)">
                                    كود المخزن
                                </option>

                                <option value="product"
                                        selected="@(searchBy == "product" ? "selected" : null)">
                                    كود الصنف
                                </option>

                                <option value="batch"
                                        selected="@(searchBy == "batch" ? "selected" : null)">
                                    رقم التشغيلة
                                </option>

                                <option value="expiry"
                                        selected="@(searchBy == "expiry" ? "selected" : null)">
                                    تاريخ الصلاحية
                                </option>

                                <option value="qtyin"
                                        selected="@(searchBy == "qtyin" ? "selected" : null)">
                                    كمية داخلة
                                </option>

                                <option value="qtyout"
                                        selected="@(searchBy == "qtyout" ? "selected" : null)">
                                    كمية خارجة
                                </option>

                                <option value="unitcost"
                                        selected="@(searchBy == "unitcost" ? "selected" : null)">
                                    تكلفة الوحدة
                                </option>

                                <option value="rem"
                                        selected="@(searchBy == "rem" ? "selected" : null)">
                                    الكمية المتبقية من الدخلة
                                </option>

                                <option value="source"
                                        selected="@(searchBy == "source" ? "selected" : null)">
                                    نوع الحركة
                                </option>

                                <option value="sourceid"
                                        selected="@(searchBy == "sourceid" ? "selected" : null)">
                                    رقم المستند
                                </option>

                                <option value="sourceline"
                                        selected="@(searchBy == "sourceline" ? "selected" : null)">
                                    رقم سطر المستند
                                </option>

                                <option value="movementgroup"
                                        selected="@(searchBy == "movementgroup" ? "selected" : null)">
                                    رقم مجموعة الحركة
                                </option>

                                <option value="counterwh"
                                        selected="@(searchBy == "counterwh" ? "selected" : null)">
                                    المخزن المقابل
                                </option>

                                <option value="reason"
                                        selected="@(searchBy == "reason" ? "selected" : null)">
                                    سبب التسوية
                                </option>

                                <option value="note"
                                        selected="@(searchBy == "note" ? "selected" : null)">
                                    ملاحظات
                                </option>

                                <option value="user"
                                        selected="@(searchBy == "user" ? "selected" : null)">
                                    المستخدم
                                </option>

                                <option value="created"
                                        selected="@(searchBy == "created" ? "selected" : null)">
                                    تاريخ الإنشاء
                                </option>

                                <option value="updated"
                                        selected="@(searchBy == "updated" ? "selected" : null)">
                                    تاريخ آخر تعديل
                                </option>
                            </select>

                        </div>

                        @* الحفاظ على باقي الفلاتر *@
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                        @if (fromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                        }
                        @if (toDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                        }
                        @if (fromEntry.HasValue)
                        {
                            <input type="hidden" name="fromEntry" value="@fromEntry" />
                        }
                        @if (toEntry.HasValue)
                        {
                            <input type="hidden" name="toEntry" value="@toEntry" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm px-3">
                                بحث
                            </button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm"
                               href="@Url.Action(action, controller)">
                                إلغاء
                            </a>
                        </div>
                    </form>
                </div>

                @* العمود الثاني: فلتر رقم القيد من/إلى *@
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-semibold">من رقم قيد</span>
                        <input id="codeFromInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(fromEntry?.ToString() ?? "")" />

                        <span class="fw-semibold">إلى</span>
                        <input id="codeToInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(toEntry?.ToString() ?? "")" />

                        <button type="button"
                                id="btnApplyCodeFilter"
                                class="btn btn-erp btn-erp-primary btn-erp-sm">
                            تطبيق فلتر الكود
                        </button>

                        <button type="button"
                                id="btnClearCodeFilter"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            مسح
                        </button>
                    </div>
                </div>

                @* العمود الثالث: أزرار الفلاتر / الأعمدة / الطباعة / التصدير *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        @* فلترة بالتاريخ/الوقت *@
                        <button type="button"
                                class="btn btn-erp btn-erp-primary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#dateFilterModal">
                            فلترة بالتاريخ/الوقت (تاريخ الحركة)
                        </button>

                        @* اختيار الأعمدة *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalLedger">
                            اختيار الأعمدة
                        </button>

                        @* طباعة (الجدول فقط) *@
                        <button type="button"
                                id="btnPrintLedger"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        @* تصدير *@
                        <form method="get"
                              asp-action="Export"
                              asp-controller="StockLedger"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            @* الحفاظ على نفس الفلاتر الحالية وقت التصدير *@
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                            }
                            @if (toDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                            }
                            @if (fromEntry.HasValue)
                            {
                                <input type="hidden" name="fromEntry" value="@fromEntry" />
                            }
                            @if (toEntry.HasValue)
                            {
                                <input type="hidden" name="toEntry" value="@toEntry" />
                            }

                            <select name="format"
                                    class="form-select form-select-sm"
                                    style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit"
                                    class="btn btn-erp btn-erp-success btn-erp-sm">
                                تصدير
                            </button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

    @* ===== جدول دفتر الحركة (هو الذي يُطبَع) ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="ledgerTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    <th style="width:90px;" data-col="entry">@sortLink("EntryId", "رقم القيد")</th>
                    <th style="width:150px;" data-col="tran">@sortLink("TranDate", "التاريخ")</th>

                    <th data-col="warehouse">@sortLink("Warehouse", "المخزن")</th>

                    <!-- اسم الصنف -->
                    <th data-col="productname">@sortLink("ProdName", "اسم الصنف")</th>

                    <!-- كود الصنف (الموجود أصلاً لو محتاجه) -->
                    <th data-col="product">@sortLink("Product", "كود الصنف")</th>

                    <!-- التشغيلة والصلاحية -->
                    <th data-col="batch">@sortLink("BatchNo", "التشغيلة")</th>
                    <th data-col="expiry">@sortLink("Expiry", "الصلاحية")</th>

                    <!-- سعر الجمهور -->
                    <th class="text-end" data-col="priceretail">@sortLink("PriceRetail", "سعر الجمهور")</th>

                    <!-- كمية داخلة / خارجة -->
                    <th class="text-end" data-col="qtyin">@sortLink("QtyIn", "كمية داخلة")</th>
                    <th class="text-end" data-col="qtyout">@sortLink("QtyOut", "كمية خارجة")</th>

                    <!-- تكلفة وحدة (كما اتفقنا: TotalCost / QtyIn) -->
                    <th class="text-end" data-col="unitcost">@sortLink("UnitCost", "تكلفة/وحدة")</th>

                                       <!-- المتبقي فقط لعمليات الدخول -->
                    <th class="text-end" data-col="rem">@sortLink("RemainingQty", "المتبقي (للـدخول)")</th>

                    <!-- نوع المصدر / الفاتورة / السطر -->
                    <th data-col="source">@sortLink("SourceType", "نوع المصدر")</th>
                    <th data-col="sourceid">@sortLink("SourceId", "رقم الفاتورة")</th>
                    <th data-col="sourceline">@sortLink("SourceLine", "سطر")</th>

                    <th class="text-center no-print" data-col="actions">إجراءات</th>
                    
                </tr>

            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="13" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var x in Model.Items)
                    {
                        <tr>
                            <!-- رقم القيد -->
                            <td data-col="entry">@x.EntryId</td>

                            <!-- التاريخ والوقت -->
                            <td data-col="tran">@x.TranDate.ToString("dd-MM-yyyy HH:mm")</td>

                            <!-- المخزن -->
                            <td data-col="warehouse">@x.WarehouseId</td>

                            <!-- اسم الصنف -->
                            <td data-col="productname">@x.Product?.ProdName</td>

                            <!-- كود الصنف -->
                            <td data-col="product">@x.Product?.ProdId</td>

                            <!-- التشغيلة -->
                            <td data-col="batch">@x.BatchNo</td>

                            <!-- الصلاحية -->
                            <td data-col="expiry">
                                @(x.Expiry.HasValue? x.Expiry.Value.ToString("MM-yyyy") : "")
                            </td>

                            <!-- سعر الجمهور -->
                            <td class="text-end" data-col="priceretail">
                                @x.Batch?.PriceRetailBatch?.ToString("0.00")
                            </td>

                            <!-- كمية داخلة -->
                            <td class="text-end" data-col="qtyin">@x.QtyIn</td>

                            <!-- كمية خارجة -->
                            <td class="text-end" data-col="qtyout">@x.QtyOut</td>

                            <!-- تكلفة وحدة -->
                            <td class="text-end" data-col="unitcost">
                                @x.UnitCost.ToString("0.00")
                            </td>
                            <!-- المتبقي -->
                            <td class="text-end" data-col="rem">
                                @(x.RemainingQty.HasValue? x.RemainingQty.Value.ToString() : "-")
                            </td>

                            <!-- نوع المصدر -->
                            <td data-col="source">@x.SourceType</td>

                            <!-- رقم الفاتورة -->
                            <td data-col="sourceid">@x.SourceId</td>

                            <!-- رقم السطر -->
                            <td data-col="sourceline">@x.SourceLine</td>

                           

                            <!-- زر فتح الفاتورة -->
                            <td class="text-center no-print" data-col="actions">
                                @* زر فتح الفاتورة *@
                                <a class="btn btn-sm btn-primary open-tab"
                                   data-tab-id="pi-show-tab"
                                   data-tab-title="فاتورة المشتريات"
                                   href="@Url.Action("Show", "PurchaseInvoices", new { id = x.SourceId, frame = 1 })">
                                    الفاتورة
                                </a>

                            </td>
                        </tr>


                    }

                    @* صف إجمالي بعد آخر سطر *@
                    <tr class="table-secondary fw-bold">
                        <td colspan="12" class="text-end">
                            عدد القيود (حسب الفلتر الحالي):
                        </td>
                        <td class="text-end">
                            @total
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة + الترقيم ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
            }
            @if (toDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
            }
            @if (fromEntry.HasValue)
            {
                <input type="hidden" name="fromEntry" value="@fromEntry" />
            }
            @if (toEntry.HasValue)
            {
                <input type="hidden" name="toEntry" value="@toEntry" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25" selected="@(ps == 25 ? "selected" : null)">25</option>
                <option value="50" selected="@(ps == 50 ? "selected" : null)">50</option>
                <option value="100" selected="@(ps == 100 ? "selected" : null)">100</option>
                <option value="200" selected="@(ps == 200 ? "selected" : null)">200</option>
            </select>
        </form>
    </div>

    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(page > first ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(page < last ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة بالتاريخ/الوقت (تاريخ الحركة) ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ الحركة)
                </h5>

                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    @* الحفاظ على الفلاتر *@
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromEntry" value="@(fromEntry?.ToString() ?? "")" />
                    <input type="hidden" name="toEntry" value="@(toEntry?.ToString() ?? "")" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />

                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="columnsModalLedger"
     tabindex="-1"
     aria-labelledby="columnsModalLedgerLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalLedgerLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListLedger"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsLedger"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط
        // =========================
        document.getElementById("btnPrintLedger")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("ledgerTable");
            if (!table) return;

            const storageKey = "stockledger-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells.map(th => ({
                key: th.getAttribute("data-col"),
                title: th.innerText.trim()
            }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListLedger");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsLedger")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalLedger");
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر رقم القيد من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(fromEntry, toEntry) {
                const url = new URL(window.location.href);

                if (fromEntry)
                    url.searchParams.set("fromEntry", fromEntry);
                else
                    url.searchParams.delete("fromEntry");

                if (toEntry)
                    url.searchParams.set("toEntry", toEntry);
                else
                    url.searchParams.delete("toEntry");

                // نرجع لأول صفحة مع الحفاظ على باقي الفلاتر
                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const fe = fromInp.value.trim();
                const te = toInp.value.trim();
                window.location.href = buildUrl(fe, te);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
