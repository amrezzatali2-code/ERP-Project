@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<StockLedger>

@{
    ViewData["Title"] = "دفتر الحركة المخزنية";

    // أسماء الأكشن/الكنترولر
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "StockLedger";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = Model.SearchBy ?? (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "TranDate";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "desc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلترة بالتاريخ/الوقت (تاريخ الحركة)
    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;

    int? fromEntry = ViewBag.FromEntry as int?;
    int? toEntry = ViewBag.ToEntry as int?;

    string? filterCol_entry = ViewBag.FilterCol_Entry as string;
    string? filterCol_warehouse = ViewBag.FilterCol_Warehouse as string;
    string? filterCol_product = ViewBag.FilterCol_Product as string;
    string? filterCol_source = ViewBag.FilterCol_Source as string;
    string? filterCol_tran = ViewBag.FilterCol_Tran as string;
    string? filterCol_productname = ViewBag.FilterCol_Productname as string;
    string? filterCol_batch = ViewBag.FilterCol_Batch as string;
    string? filterCol_expiry = ViewBag.FilterCol_Expiry as string;
    string? filterCol_sourceid = ViewBag.FilterCol_Sourceid as string;
    string? filterCol_sourceline = ViewBag.FilterCol_Sourceline as string;
    string? filterCol_qtyin = ViewBag.FilterCol_Qtyin as string;
    string? filterCol_qtyout = ViewBag.FilterCol_Qtyout as string;
    string? filterCol_unitcost = ViewBag.FilterCol_Unitcost as string;
    string? filterCol_rem = ViewBag.FilterCol_Rem as string;
    string? filterCol_priceretail = ViewBag.FilterCol_Priceretail as string;
    string? filterCol_purchasediscount = ViewBag.FilterCol_PurchaseDiscount as string;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        fromEntry,
        toEntry,
        filterCol_entry,
        filterCol_warehouse,
        filterCol_product,
        filterCol_source,
        filterCol_tran,
        filterCol_productname,
        filterCol_batch,
        filterCol_expiry,
        filterCol_sourceid,
        filterCol_sourceline,
        filterCol_qtyin,
        filterCol_qtyout,
        filterCol_unitcost,
        filterCol_rem,
        filterCol_priceretail,
        filterCol_purchasediscount
    })!;

    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";
        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate,
            fromEntry,
            toEntry,
            filterCol_entry,
            filterCol_warehouse,
            filterCol_product,
            filterCol_source,
            filterCol_tran,
            filterCol_productname,
            filterCol_batch,
            filterCol_expiry,
            filterCol_sourceid,
            filterCol_sourceline,
            filterCol_qtyin,
            filterCol_qtyout,
            filterCol_unitcost,
            filterCol_rem,
            filterCol_priceretail,
            filterCol_purchasediscount
        }) ?? "#";
        string icon = "⇅";
        if (isCurrent) icon = dir == "asc" ? "▲" : "▼";
        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    string? FilterForCol(string colKey) => colKey == "entry" ? filterCol_entry : colKey == "warehouse" ? filterCol_warehouse : colKey == "product" ? filterCol_product : colKey == "source" ? filterCol_source : colKey == "tran" ? filterCol_tran : colKey == "productname" ? filterCol_productname : colKey == "batch" ? filterCol_batch : colKey == "expiry" ? filterCol_expiry : colKey == "sourceid" ? filterCol_sourceid : colKey == "sourceline" ? filterCol_sourceline : colKey == "qtyin" ? filterCol_qtyin : colKey == "qtyout" ? filterCol_qtyout : colKey == "unitcost" ? filterCol_unitcost : colKey == "rem" ? filterCol_rem : colKey == "priceretail" ? filterCol_priceretail : colKey == "purchasediscount" ? filterCol_purchasediscount : null;

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    @* العنوان + إجمالي القيود (مثل قائمة الأصناف/الفئات) *@
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <small class="text-muted d-none d-md-inline">إجمالي القيود: @total</small>
    </div>

    @* ===== شريط الفلاتر الموحد ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في دفتر الحركة</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" style="min-width:120px" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:160px;min-width:100px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>الكل</option>
                            <option value="entry"@Html.Raw(searchBy == "entry" ? " selected" : "")>رقم القيد</option>
                            <option value="warehouse"@Html.Raw(searchBy == "warehouse" ? " selected" : "")>كود المخزن</option>
                            <option value="product"@Html.Raw(searchBy == "product" ? " selected" : "")>كود الصنف</option>
                            <option value="batch"@Html.Raw(searchBy == "batch" ? " selected" : "")>التشغيلة</option>
                            <option value="source"@Html.Raw(searchBy == "source" ? " selected" : "")>نوع المصدر</option>
                            <option value="sourceid"@Html.Raw(searchBy == "sourceid" ? " selected" : "")>رقم المستند</option>
                            <option value="sourceline"@Html.Raw(searchBy == "sourceline" ? " selected" : "")>سطر المستند</option>
                        </select>
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3 flex-shrink-0">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none flex-shrink-0" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (fromEntry.HasValue) { <input type="hidden" name="fromEntry" value="@fromEntry" /> }
                    @if (toEntry.HasValue) { <input type="hidden" name="toEntry" value="@toEntry" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_entry)) { <input type="hidden" name="filterCol_entry" value="@filterCol_entry" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_product)) { <input type="hidden" name="filterCol_product" value="@filterCol_product" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_source)) { <input type="hidden" name="filterCol_source" value="@filterCol_source" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_tran)) { <input type="hidden" name="filterCol_tran" value="@filterCol_tran" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_productname)) { <input type="hidden" name="filterCol_productname" value="@filterCol_productname" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_batch)) { <input type="hidden" name="filterCol_batch" value="@filterCol_batch" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_expiry)) { <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_sourceid)) { <input type="hidden" name="filterCol_sourceid" value="@filterCol_sourceid" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_sourceline)) { <input type="hidden" name="filterCol_sourceline" value="@filterCol_sourceline" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyin)) { <input type="hidden" name="filterCol_qtyin" value="@filterCol_qtyin" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyout)) { <input type="hidden" name="filterCol_qtyout" value="@filterCol_qtyout" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_unitcost)) { <input type="hidden" name="filterCol_unitcost" value="@filterCol_unitcost" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_rem)) { <input type="hidden" name="filterCol_rem" value="@filterCol_rem" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_priceretail)) { <input type="hidden" name="filterCol_priceretail" value="@filterCol_priceretail" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_purchasediscount)) { <input type="hidden" name="filterCol_purchasediscount" value="@filterCol_purchasediscount" /> }
                </form>
            </div>

            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">رقم القيد من / إلى</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromEntry?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toEntry?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم (نفس ترتيب قائمة الأصناف/الفئات) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalLedger">اختيار الأعمدة</button>
                        <button type="button" id="btnPrintLedger" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <form method="get" asp-action="Export" asp-controller="StockLedger" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                        <input type="hidden" name="search" value="@search" />
                        <input type="hidden" name="searchBy" value="@searchBy" />
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                        @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                        @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                        @if (fromEntry.HasValue) { <input type="hidden" name="fromEntry" value="@fromEntry" /> }
                        @if (toEntry.HasValue) { <input type="hidden" name="toEntry" value="@toEntry" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_entry)) { <input type="hidden" name="filterCol_entry" value="@filterCol_entry" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_product)) { <input type="hidden" name="filterCol_product" value="@filterCol_product" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_source)) { <input type="hidden" name="filterCol_source" value="@filterCol_source" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_tran)) { <input type="hidden" name="filterCol_tran" value="@filterCol_tran" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_productname)) { <input type="hidden" name="filterCol_productname" value="@filterCol_productname" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_batch)) { <input type="hidden" name="filterCol_batch" value="@filterCol_batch" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_expiry)) { <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_sourceid)) { <input type="hidden" name="filterCol_sourceid" value="@filterCol_sourceid" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_sourceline)) { <input type="hidden" name="filterCol_sourceline" value="@filterCol_sourceline" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_qtyin)) { <input type="hidden" name="filterCol_qtyin" value="@filterCol_qtyin" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_qtyout)) { <input type="hidden" name="filterCol_qtyout" value="@filterCol_qtyout" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_unitcost)) { <input type="hidden" name="filterCol_unitcost" value="@filterCol_unitcost" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_rem)) { <input type="hidden" name="filterCol_rem" value="@filterCol_rem" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_priceretail)) { <input type="hidden" name="filterCol_priceretail" value="@filterCol_priceretail" /> }
                        @if (!string.IsNullOrWhiteSpace(filterCol_purchasediscount)) { <input type="hidden" name="filterCol_purchasediscount" value="@filterCol_purchasediscount" /> }
                        <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;padding:0.3rem 0.5rem;" title="اختر صيغة التصدير">
                            <option value="excel" selected>Excel</option>
                            <option value="csv">CSV</option>
                        </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <form id="ledgerSearchForm" method="get" action="@Url.Action(action, controller)" class="d-none">
        <input type="hidden" name="search" value="@search" />
        <input type="hidden" name="searchBy" value="@searchBy" />
        <input type="hidden" name="sort" value="@sort" />
        <input type="hidden" name="dir" value="@dir" />
        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="pageSize" value="@ps" />
        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
        @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
        @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
        @if (fromEntry.HasValue) { <input type="hidden" name="fromEntry" value="@fromEntry" /> }
        @if (toEntry.HasValue) { <input type="hidden" name="toEntry" value="@toEntry" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_entry)) { <input type="hidden" name="filterCol_entry" value="@filterCol_entry" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_product)) { <input type="hidden" name="filterCol_product" value="@filterCol_product" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_source)) { <input type="hidden" name="filterCol_source" value="@filterCol_source" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_tran)) { <input type="hidden" name="filterCol_tran" value="@filterCol_tran" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_productname)) { <input type="hidden" name="filterCol_productname" value="@filterCol_productname" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_batch)) { <input type="hidden" name="filterCol_batch" value="@filterCol_batch" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_expiry)) { <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_sourceid)) { <input type="hidden" name="filterCol_sourceid" value="@filterCol_sourceid" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_sourceline)) { <input type="hidden" name="filterCol_sourceline" value="@filterCol_sourceline" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_qtyin)) { <input type="hidden" name="filterCol_qtyin" value="@filterCol_qtyin" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_qtyout)) { <input type="hidden" name="filterCol_qtyout" value="@filterCol_qtyout" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_unitcost)) { <input type="hidden" name="filterCol_unitcost" value="@filterCol_unitcost" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_rem)) { <input type="hidden" name="filterCol_rem" value="@filterCol_rem" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_priceretail)) { <input type="hidden" name="filterCol_priceretail" value="@filterCol_priceretail" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_purchasediscount)) { <input type="hidden" name="filterCol_purchasediscount" value="@filterCol_purchasediscount" /> }
    </form>

    @* ===== جدول دفتر الحركة ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0" dir="rtl">
        <div id="ledgerTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="ledgerTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th style="width:90px;" data-col="entry">@filterableCol("entry", "EntryId", "رقم القيد")</th>
                    <th style="width:150px;" data-col="tran">@filterableCol("tran", "TranDate", "التاريخ")</th>
                    <th data-col="warehouse">@filterableCol("warehouse", "Warehouse", "المخزن")</th>
                    <th data-col="productname">@filterableCol("productname", "Product", "اسم الصنف")</th>
                    <th data-col="product">@filterableCol("product", "Product", "كود الصنف")</th>
                    <th data-col="batch">@filterableCol("batch", "Expiry", "التشغيلة")</th>
                    <th data-col="expiry">@filterableCol("expiry", "Expiry", "الصلاحية")</th>
                    <th class="text-end" data-col="priceretail">@filterableCol("priceretail", "UnitCost", "سعر الجمهور")</th>
                    <th class="text-end" data-col="PurchaseDiscount">@filterableCol("purchasediscount", "UnitCost", "خصم الشراء")</th>
                    <th class="text-end" data-col="qtyin">@filterableCol("qtyin", "QtyIn", "كمية داخلة")</th>
                    <th class="text-end" data-col="qtyout">@filterableCol("qtyout", "QtyOut", "كمية خارجة")</th>
                    <th class="text-end" data-col="unitcost">@filterableCol("unitcost", "UnitCost", "تكلفة/وحدة")</th>
                    <th class="text-end" data-col="rem">@filterableCol("rem", "EntryId", "المتبقي (للـدخول)")</th>
                    <th data-col="source">@filterableCol("source", "SourceType", "نوع المصدر")</th>
                    <th data-col="sourceid">@filterableCol("sourceid", "EntryId", "رقم الفاتورة")</th>
                    <th data-col="sourceline">@filterableCol("sourceline", "EntryId", "سطر")</th>
                    <th class="text-center no-print" data-col="actions">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="18" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var x in Model.Items)
                    {
                        <tr>
                            <!-- رقم القيد -->
                            <td data-col="entry">@x.EntryId</td>

                            <!-- التاريخ والوقت -->
                            <td data-col="tran">@x.TranDate.ToString("dd-MM-yyyy HH:mm")</td>

                            <!-- المخزن -->
                            <td data-col="warehouse">@x.WarehouseId</td>

                            <!-- اسم الصنف -->
                            <td data-col="productname">@x.Product?.ProdName</td>

                            <!-- كود الصنف -->
                            <td data-col="product">@x.Product?.ProdId</td>

                            <!-- التشغيلة -->
                            <td data-col="batch">@x.BatchNo</td>

                            <!-- الصلاحية -->
                            <td data-col="expiry">
                                @(x.Expiry.HasValue? x.Expiry.Value.ToString("MM-yyyy") : "")
                            </td>

                            <!-- سعر الجمهور -->
                            <td class="text-end" data-col="priceretail">
                                @x.Batch?.PriceRetailBatch?.ToString("0.00")
                            </td>

                            <td data-col="PurchaseDiscount">@x.PurchaseDiscount</td>



                            <!-- كمية داخلة -->
                            <td class="text-end" data-col="qtyin">@x.QtyIn</td>

                            <!-- كمية خارجة -->
                            <td class="text-end" data-col="qtyout">@x.QtyOut</td>

                            <!-- تكلفة وحدة -->
                            <td class="text-end" data-col="unitcost">
                                @x.UnitCost.ToString("0.00")
                            </td>
                            <!-- المتبقي -->
                            <td class="text-end" data-col="rem">
                                @(x.RemainingQty.HasValue? x.RemainingQty.Value.ToString() : "-")
                            </td>

                            <!-- نوع المصدر -->
                            <td data-col="source">@x.SourceType</td>

                            <!-- رقم الفاتورة -->
                            <td data-col="sourceid">@x.SourceId</td>

                            <!-- رقم السطر -->
                            <td data-col="sourceline">@x.SourceLine</td>

                           

                            <!-- زر عرض الفاتورة -->
                            <td class="text-center no-print" data-col="actions">
                                <a class="btn btn-erp btn-erp-primary btn-erp-sm open-tab"
                                   data-tab-id="pi-show-tab"
                                   data-tab-title="فاتورة المشتريات"
                                   href="@Url.Action("Show", "PurchaseInvoices", new { id = x.SourceId, frame = 1 })">
                                    عرض
                                </a>
                            </td>
                        </tr>


                    }

                    @* صف إجمالي بعد آخر سطر (محاذاة لـ RTL: النص من جهة اليمين) *@
                    <tr class="table-secondary fw-bold">
                        <td colspan="17" class="text-start">
                            عدد القيود (حسب الفلتر الحالي):
                        </td>
                        <td class="text-start">
                            @total
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>

    @* ===== لوحة فلتر العمود (بنمط Excel) ===== *@
    <div id="erpColumnFilterPanel" class="erp-column-filter-panel d-none" dir="rtl">
        <div class="erp-column-filter-header">
            <span id="erpColumnFilterTitle">ترتيب وفلتر</span>
            <button type="button" class="btn-close btn-sm" id="erpColumnFilterClose" aria-label="إغلاق"></button>
        </div>
        <div class="erp-column-filter-body">
            <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                <label class="form-label small mb-1 fw-bold">الترتيب:</label>
                <div class="d-flex flex-column gap-1">
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
                </div>
            </div>
            <div class="erp-filter-section">
                <div id="erpColumnFilterSearchRow">
                    <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                    <input type="text" id="erpColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                </div>
                <div id="erpColumnFilterList" class="erp-column-filter-list">
                    <div class="text-muted text-center py-3">جاري التحميل...</div>
                </div>
            </div>
            <div class="erp-column-filter-actions">
                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOk">تطبيق</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClear">مسح الفلتر</button>
            </div>
        </div>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة (اتجاه RTL: العدد يمين، النموذج يسار) ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print" dir="rtl">
        <small class="text-muted order-1">
            عرض @start - @end من @total
        </small>

        <form method="get" class="order-2"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
            @if (fromEntry.HasValue) { <input type="hidden" name="fromEntry" value="@fromEntry" /> }
            @if (toEntry.HasValue) { <input type="hidden" name="toEntry" value="@toEntry" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_entry)) { <input type="hidden" name="filterCol_entry" value="@filterCol_entry" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_product)) { <input type="hidden" name="filterCol_product" value="@filterCol_product" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_source)) { <input type="hidden" name="filterCol_source" value="@filterCol_source" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_tran)) { <input type="hidden" name="filterCol_tran" value="@filterCol_tran" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_productname)) { <input type="hidden" name="filterCol_productname" value="@filterCol_productname" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_batch)) { <input type="hidden" name="filterCol_batch" value="@filterCol_batch" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_expiry)) { <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_sourceid)) { <input type="hidden" name="filterCol_sourceid" value="@filterCol_sourceid" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_sourceline)) { <input type="hidden" name="filterCol_sourceline" value="@filterCol_sourceline" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_qtyin)) { <input type="hidden" name="filterCol_qtyin" value="@filterCol_qtyin" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_qtyout)) { <input type="hidden" name="filterCol_qtyout" value="@filterCol_qtyout" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_unitcost)) { <input type="hidden" name="filterCol_unitcost" value="@filterCol_unitcost" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_rem)) { <input type="hidden" name="filterCol_rem" value="@filterCol_rem" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_priceretail)) { <input type="hidden" name="filterCol_priceretail" value="@filterCol_priceretail" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_purchasediscount)) { <input type="hidden" name="filterCol_purchasediscount" value="@filterCol_purchasediscount" /> }
            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(page > first ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(page < last ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

