    @* ===== جدول سجل الحركات ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0" dir="rtl">
        <div id="ledgerTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="ledgerTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th style="width:90px;" data-col="entry">@filterableCol("entry", "EntryId", "رقم القيد")</th>
                    <th style="width:88px;" data-col="sourceid">@filterableCol("sourceid", "SourceId", "رقم الفاتورة")</th>
                    <th style="width:72px;" data-col="sourceline">@filterableCol("sourceline", "SourceLine", "سطر")</th>
                    <th style="width:150px;" data-col="tran">@filterableCol("tran", "TranDate", "التاريخ")</th>
                    <th data-col="warehouse_name">@filterableCol("warehouse_name", "WarehouseName", "اسم المخزن")</th>
                    <th data-col="warehouse">@filterableCol("warehouse", "Warehouse", "كود المخزن")</th>
                    <th data-col="branch">@filterableCol("branch", "BranchName", "المنطقة")</th>
                    <th data-col="createdby">@filterableCol("createdby", "CreatedBy", "الكاتب")</th>
                    <th data-col="productname">@filterableCol("productname", "Product", "اسم الصنف")</th>
                    <th data-col="product">@filterableCol("product", "Product", "كود الصنف")</th>
                    <th data-col="batch">@filterableCol("batch", "Expiry", "التشغيلة")</th>
                    <th data-col="expiry">@filterableCol("expiry", "Expiry", "الصلاحية")</th>
                    <th class="text-end" data-col="priceretail">@filterableCol("priceretail", "UnitCost", "سعر الجمهور")</th>
                    <th class="text-end" data-col="purchasediscount">@filterableCol("purchasediscount", "UnitCost", "خصم الشراء")</th>
                    <th class="text-end" data-col="qtyin">@filterableCol("qtyin", "QtyIn", "كمية داخلة")</th>
                    <th class="text-end" data-col="qtyout">@filterableCol("qtyout", "QtyOut", "كمية خارجة")</th>
                    <th class="text-end" data-col="unitcost">@filterableCol("unitcost", "UnitCost", "تكلفة/وحدة")</th>
                    <th class="text-end" data-col="totalcost">@filterableCol("totalcost", "TotalCost", "إجمالي التكلفة")</th>
                    <th class="text-end" data-col="rem">@filterableCol("rem", "EntryId", "المتبقي (للـدخول)")</th>
                    <th data-col="source">@filterableCol("source", "SourceType", "نوع المصدر")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="20" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var x in Model.Items)
                    {
                        var doc = StockLedgerSourceDocumentHelper.GetOpenDocument(Url, x);
                        var movementUrl = x.Product != null ? Url.Action("Show", "Products", new { id = x.Product.ProdId }) + "?frame=1" : "";
                        <tr class="erp-list-selectable-row"
                            data-row-id="@x.EntryId"
                            data-show-url="@doc.Url"
                            data-tab-title="@doc.Title"
                            data-erp-tab-id="@doc.TabId"
                            data-movement-url="@movementUrl">
                            <!-- رقم القيد -->
                            <td data-col="entry">@x.EntryId</td>

                            <!-- رقم الفاتورة / سطر -->
                            <td data-col="sourceid">@x.SourceId</td>
                            <td data-col="sourceline">@x.SourceLine</td>

                            <!-- التاريخ والوقت -->
                            <td data-col="tran">@x.TranDate.ToString("dd-MM-yyyy HH:mm")</td>

                            <td data-col="warehouse_name">@(x.Warehouse?.WarehouseName ?? "")</td>
                            <td data-col="warehouse">@x.WarehouseId</td>
                            <td data-col="branch">@(x.Warehouse?.Branch?.BranchName ?? "")</td>
                            <td data-col="createdby">@(x.User?.DisplayName ?? "")</td>

                            <!-- اسم الصنف -->
                            <td data-col="productname">@x.Product?.ProdName</td>

                            <!-- كود الصنف -->
                            <td data-col="product">@x.Product?.ProdId</td>

                            <!-- التشغيلة -->
                            <td data-col="batch">@x.BatchNo</td>

                            <!-- الصلاحية -->
                            <td data-col="expiry">
                                @(x.Expiry.HasValue? x.Expiry.Value.ToString("MM-yyyy") : "")
                            </td>

                            <!-- سعر الجمهور (من القيد أو من التشغيلة) -->
                            <td class="text-end" data-col="priceretail">
                                @((x.PriceRetailBatch ?? x.Batch?.PriceRetailBatch)?.ToString("0.00"))
                            </td>

                            <td class="text-end" data-col="purchasediscount">@(x.PurchaseDiscount?.ToString("0.00") ?? "")</td>



                            <!-- كمية داخلة -->
                            <td class="text-end" data-col="qtyin">@x.QtyIn</td>

                            <!-- كمية خارجة -->
                            <td class="text-end" data-col="qtyout">@x.QtyOut</td>

                            <!-- تكلفة وحدة -->
                            <td class="text-end" data-col="unitcost">
                                @x.UnitCost.ToString("0.00")
                            </td>
                            <!-- إجمالي التكلفة -->
                            <td class="text-end" data-col="totalcost">
                                @(((x.TotalCost ?? 0m) > 0 ? x.TotalCost!.Value : (x.QtyIn * x.UnitCost)).ToString("0.00"))
                            </td>
                            <!-- المتبقي -->
                            <td class="text-end" data-col="rem">
                                @(x.RemainingQty.HasValue? x.RemainingQty.Value.ToString() : "-")
                            </td>

                            <!-- نوع المصدر -->
                            <td data-col="source">@x.SourceType</td>
                        </tr>
                    }
                }
            </tbody>
            @if (total > 0)
            {
                <tfoot class="table-light border-top" style="position: sticky; bottom: 0; z-index: 9;">
                    <tr class="fw-bold">
                        <td data-col="entry" class="text-start">إجمالي</td>
                        <td data-col="sourceid"></td>
                        <td data-col="sourceline"></td>
                        <td data-col="tran"></td>
                        <td data-col="warehouse_name"></td>
                        <td data-col="warehouse"></td>
                        <td data-col="branch"></td>
                        <td data-col="createdby"></td>
                        <td data-col="productname"></td>
                        <td data-col="product"></td>
                        <td data-col="batch"></td>
                        <td data-col="expiry"></td>
                        <td class="text-end" data-col="priceretail">—</td>
                        <td class="text-end" data-col="purchasediscount">—</td>
                        <td class="text-end" data-col="qtyin">@sumQtyIn.ToString("N0")</td>
                        <td class="text-end" data-col="qtyout">@sumQtyOut.ToString("N0")</td>
                        <td class="text-end" data-col="unitcost">—</td>
                        <td class="text-end" data-col="totalcost">@sumLineCost.ToString("N2")</td>
                        <td class="text-end" data-col="rem">—</td>
                        <td data-col="source"></td>
                    </tr>
                </tfoot>
            }
        </table>
        </div>
    </div>

