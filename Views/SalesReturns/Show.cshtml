@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.SalesReturn

@{
    ViewData["Title"] = "مرتجع بيع";
}

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/invoice-cards.css")" />
    <style>
        /* تنسيق مرتجع البيع — مطبّق مباشرة لضمان الظهور (حتى داخل التاب/iframe) */
        .invoice-page { background-color: #f3f6fb; min-height: 100vh; padding-bottom: 2rem; }
        div.card.invoice-side-card,
        div.card.invoice-header-card,
        div.card.invoice-Add-card,
        div.card.invoice-lines-card,
        div.card.invoice-totals-card {
            border: 1px solid #a5b4fc !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(59,130,246,.12) !important;
            overflow: hidden;
        }
        .invoice-header-bar {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            padding: 0.5rem 1rem;
            font-weight: 600;
        }
        .invoice-header-bar h5, .invoice-header-bar h6 { margin-bottom: 0; font-size: 1rem; color: #fff !important; }
        .invoice-details-card .card-header,
        .invoice-Add-card .card-header,
        .invoice-lines-card .card-header,
        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            padding: 0.55rem 1rem;
        }
        .invoice-side-card .card-header h6 { color: #fff !important; margin-bottom: 0; }
        .invoice-page .invoice-header-card .form-control,
        .invoice-page .invoice-header-card .form-select,
        .invoice-page .invoice-Add-card .form-control,
        .invoice-page .invoice-Add-card .form-select,
        .invoice-page .invoice-totals-card .form-control,
        .invoice-page .invoice-totals-card .form-select { border-color: #94a3b8 !important; }
        .return-line-field { max-width: 5.5rem; }
        .badge-status-draft { background-color: #6f42c1; }
        .badge-status-notposted { background-color: #343a40; }

        /* كارت الإجماليات — نفس فاتورة المبيعات */
        .invoice-totals-card .invoice-summary-item.invoice-summary-box {
            flex: 1 1 0;
            min-width: 0;
            max-width: 100%;
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
            align-items: center;
            justify-content: flex-start;
            padding: 0.25rem 0.35rem;
            background: #f8fafc;
            border: 1px solid #64748b;
            border-radius: 6px;
        }
        .invoice-totals-card .invoice-summary-label {
            font-size: 0.8rem;
            line-height: 1.2;
            color: #64748b;
            margin-bottom: 0;
        }
        .invoice-totals-card .invoice-summary-value {
            font-size: 1rem;
            font-weight: 500;
            color: #0f172a;
        }
        .invoice-totals-card .invoice-summary-value-main {
            font-size: 1.05rem;
            color: #fff !important;
        }
        .invoice-summary-box-main {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%) !important;
            border-color: #0284c7 !important;
        }
        .invoice-summary-box-main .invoice-summary-label {
            color: rgba(255,255,255,.9);
        }
        .invoice-summary-row {
            flex-wrap: wrap;
            gap: 0.35rem 0.5rem;
            align-items: stretch;
            justify-content: space-between;
        }

        #srToastContainer {
            position: fixed;
            top: 70px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.35rem;
            pointer-events: none;
        }
        #srToastContainer .sr-toast {
            padding: 0.6rem 1.2rem;
            border-radius: 8px;
            font-size: 0.9rem;
            box-shadow: 0 2px 8px rgba(0,0,0,.12);
            transition: opacity 0.25s ease;
        }
        #srToastContainer .sr-toast.text-success { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
        #srToastContainer .sr-toast.text-warning { background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; }
        #srToastContainer .sr-toast.text-danger { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
        #srToastContainer .sr-toast.text-muted { background: #f1f5f9; color: #334155; border: 1px solid #64748b; }

        /* رقم فاتورة البيع: حقل ضيق أعلى يمين الهيدر */
        .sr-invoice-no-wrap { max-width: 7.5rem; }
        .sr-invoice-no-wrap .form-control { max-width: 7rem; margin-inline: auto; }
        /* كود العميل ورقم المرتجع وحقول التاريخ/الوقت — مضغوطة مثل فاتورة المبيعات */
        .sr-header-card-body .sr-hdr-compact .form-control,
        .sr-header-card-body .sr-hdr-compact .form-select {
            min-width: 0;
            padding-inline: 0.3rem;
            font-size: 0.8rem;
        }
        .sr-header-card-body .sr-hdr-compact .invoice-small-input { max-width: 100%; }

        /* قائمة أصناف المرتجع: مسافة عن السهم + عرض الاسم في منتصف البوكس */
        .invoice-page .invoice-Add-card select#InvoiceItemSelect.sr-invoice-item-select {
            padding-left: 2.85rem !important;
            padding-right: 0.55rem !important;
            text-align: center;
            text-align-last: center;
        }
        /* جدول سطور المرتجع — نفس كثافة خلايا فاتورة المبيعات */
        .invoice-page .invoice-lines-container .erp-table tbody td,
        .invoice-page .invoice-lines-container .erp-table tbody th { padding: 0.45rem 0.55rem; }
        .invoice-page .invoice-lines-container .erp-table thead th { padding: 0.5rem 0.55rem; }

        /* رأس جدول السطور: مظهر محايد (رمادي فاتح + نص داكن) مثل الجدول المرجعي */
        .invoice-page .invoice-lines-container .erp-table-wrapper .erp-table > thead.sr-return-lines-thead > tr > th {
            background: linear-gradient(180deg, #e8edf3 0%, #f1f5f9 50%, #f8fafc 100%) !important;
            color: #1e293b !important;
            font-weight: 600;
            border-top: 2px solid #64748b !important;
            border-bottom: 1px solid #cbd5e1 !important;
            border-inline-end: 1px solid #e2e8f0 !important;
            box-shadow: none !important;
        }
        .invoice-page .invoice-lines-container .erp-table-wrapper .erp-table > thead.sr-return-lines-thead > tr > th:first-child {
            border-inline-start: 1px solid #e2e8f0 !important;
        }
    </style>
}

<div class="invoice-page" dir="rtl">
    <div id="srToastContainer" aria-live="polite"></div>
    <div class="container-fluid pt-3">

        <div class="row g-3 align-items-start">

            @* كارت الإجراءات أولاً في الـ HTML مع order حتى يُرسم مع الصف دون تأخير بصري *@
            <div class="col-lg-2 order-last">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات مرتجع البيع</h6>
                    </div>

                    <input type="hidden" id="ReturnId" value="@Model.SRId" />
                    <input type="hidden" id="ReturnIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />

                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">

                        @{
                            int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
                            int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
                            int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
                            int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;

                            int currentId = Model?.SRId ?? 0;

                            bool hasAnyReturns =
                            navFirst.HasValue && navLast.HasValue &&
                            navFirst.Value > 0 && navLast.Value > 0;

                            int? prevEffective = (currentId == 0) ? navLast : navPrev;
                            int? nextEffective = (currentId == 0) ? navFirst : navNext;

                            bool canFirst = hasAnyReturns && navFirst.HasValue && navFirst.Value > 0 && navFirst.Value != currentId;
                            bool canLast = hasAnyReturns && navLast.HasValue && navLast.Value > 0 && navLast.Value != currentId;
                            bool canPrev = hasAnyReturns && prevEffective.HasValue && prevEffective.Value > 0 && prevEffective.Value != currentId;
                            bool canNext = hasAnyReturns && nextEffective.HasValue && nextEffective.Value > 0 && nextEffective.Value != currentId;
                        }

                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button"
                                    id="btnFirstReturn"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="sr-show-tab"
                                    data-tab-title="مرتجع مبيعات"
                                    data-base-url="@Url.Action("Edit", "SalesReturns", new { id = (navFirst ?? 0) })"
                                    data-id="@(navFirst ?? 0)"
                                    title="أول مرتجع"
                                    @(canFirst ? "" : "disabled")>
                                ⏮
                            </button>

                            <button type="button"
                                    id="btnPrevReturn"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="sr-show-tab"
                                    data-tab-title="مرتجع مبيعات"
                                    data-base-url="@Url.Action("Edit", "SalesReturns", new { id = (prevEffective ?? 0) })"
                                    data-id="@(prevEffective ?? 0)"
                                    title="المرتجع السابق"
                                    @(canPrev ? "" : "disabled")>
                                ◀
                            </button>

                            <button type="button"
                                    id="btnNextReturn"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="sr-show-tab"
                                    data-tab-title="مرتجع مبيعات"
                                    data-base-url="@Url.Action("Edit", "SalesReturns", new { id = (nextEffective ?? 0) })"
                                    data-id="@(nextEffective ?? 0)"
                                    title="المرتجع التالي"
                                    @(canNext ? "" : "disabled")>
                                ▶
                            </button>

                            <button type="button"
                                    id="btnLastReturn"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="sr-show-tab"
                                    data-tab-title="مرتجع مبيعات"
                                    data-base-url="@Url.Action("Edit", "SalesReturns", new { id = (navLast ?? 0) })"
                                    data-id="@(navLast ?? 0)"
                                    title="آخر مرتجع"
                                    @(canLast ? "" : "disabled")>
                                ⏭
                            </button>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <input type="number"
                                   id="NavReturnSearchInput"
                                   class="form-control form-control-sm"
                                   placeholder="بحث برقم المرتجع" />


                            <button type="button"
                                    id="btnNavReturnSearch"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-tab-id="sr-show-tab"
                                    data-tab-title="مرتجع مبيعات"
                                    data-base-url="@Url.Action("Edit", "SalesReturns")">
                                بحث
                            </button>
                        </div>

                        <hr class="my-1" />

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           data-tab-id="sr-show-tab"
                           data-tab-title="مرتجع مبيعات"
                           data-url="@Url.Action("Create", "SalesReturns", new { frame = 1 })">
                            ➕ مرتجع جديد
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnSaveReturnHeader"
                                data-lock-posted="1">
                            💾 حفظ المرتجع
                        </button>

                        <button type="button" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" id="btnPostReturn" data-lock-posted="1">
                            📤 ترحيل المرتجع
                        </button>

                        <div id="postReturnMsg" class="small mt-2"></div>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnDeleteSelectedReturnLine"
                                data-lock-posted="1"
                                title="اختر سطراً في الجدول ثم اضغط لمسحه">
                            🗑️ مسح السطر المحدد
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnOpenReturn">
                            ⏪ فتح المرتجع
                        </button>


                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnClearReturnLines"
                                data-return-id="@(Model?.SRId ?? 0)"
                                data-lock-posted="1">
                            🗑️ مسح كل أصناف المرتجع
                        </button>



                        <button type="button"
                                id="btnPrintReturn"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                onclick="window.print()">
                            🖨️ طباعة المرتجع
                        </button>



                    </div>
                </div>
            </div>

            @* =========================
               العمود الرئيسي (الهيدر + العميل + الأصناف + الإجماليات)
               ========================= *@
            <div class="col-lg-10 order-first">

                @* ====================================================
                   1) كارت بيانات مرتجع البيع + العميل + المخزن
                   ==================================================== *@
                <div class="card shadow-sm mb-2 invoice-header-card">

                    @{
                        // لو SRId = 0 يبقى لسه مرتجع جديد (لسه ما اتسجلش في الداتا)
                        bool isNewReturn = Model == null || Model.SRId == 0;

                        bool hasReturn = Model.SRId > 0;

                        // نص تاريخ/وقت المرتجع المعروضين في الكروت
                        string returnDateText = hasReturn
                        ? Model.SRDate.ToString("d/M/yyyy")
                        : "";

                        string returnTimeText = hasReturn
                        ? Model.SRTime.ToString(@"hh\:mm")
                        : "";
                    }

                    @* عنوان ثابت مثل فاتورة المبيعات — بدون رقم المرتجع أو المنشئ في الشريط *@
                    <div class="invoice-header-bar">
                        <h6 class="mb-0">مرتجع بيع</h6>
                    </div>

                    <div class="card-body sr-header-card-body">
                        @* RTL: أول عمود يمين الشاشة — رقم فاتورة البيع ثم كود العميل ثم اسم أضيق ثم باقي الحقول *@
                        <div class="row g-2 g-lg-3 align-items-end mb-2 sr-hdr-compact">
                            <div class="col-auto sr-invoice-no-wrap text-center">
                                <label for="SalesInvoiceIdInput" class="form-label form-label-sm">رقم فاتورة البيع</label>
                                <input type="number" id="SalesInvoiceIdInput" class="form-control form-control-sm text-center"
                                       value="@(Model.SalesInvoiceId?.ToString() ?? "")" placeholder="رقم" data-lock-posted="1"
                                       @(isNewReturn ? Html.Raw("autofocus") : Html.Raw("")) />
                                <input type="hidden" asp-for="SalesInvoiceId" id="SalesInvoiceId" />
                            </div>
                            <div class="col-auto" style="max-width: 5.5rem;">
                                <label class="form-label form-label-sm">كود العميل</label>
                                <input id="CustomerCodeDisplay"
                                       class="form-control form-control-sm text-center invoice-small-input"
                                       readonly />
                                <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                                <input type="hidden" id="SRId" value="@Model.SRId" />
                            </div>
                            <div class="col-lg-5 col-md-6 min-w-0">
                                <label for="CustomerNameInput" class="form-label form-label-sm">اسم العميل</label>
                                <input id="CustomerNameInput"
                                       class="form-control form-control-sm"
                                       placeholder="اكتب اسم العميل أو جزء منه للبحث..."
                                       list="customersList"
                                       autocomplete="off"
                                       data-lock-posted="1" />
                            </div>
                            <div class="col-auto" style="max-width: 5.5rem;">
                                <label class="form-label form-label-sm">رقم المرتجع</label>
                                <input id="ReturnNumberDisplay"
                                       class="form-control form-control-sm text-center fw-semibold invoice-small-input"
                                       value="@(Model.SRId > 0 ? Model.SRId.ToString() : "—")" readonly />
                            </div>
                            <div class="col-lg-2 col-md-4">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">تاريخ المرتجع</label>
                                        <input id="ReturnDateDisplay" class="form-control form-control-sm text-center"
                                               value="@returnDateText" readonly />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">وقت المرتجع</label>
                                        <input id="ReturnTimeDisplay" class="form-control form-control-sm text-center"
                                               value="@returnTimeText" readonly />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row g-3 align-items-end">
                            <div class="col-lg-2 col-md-3">
                                <label class="form-label form-label-sm">حالة المرتجع</label>
                                @{
                                    int? stage = ViewBag.ReturnStage as int?;
                                    string statusDisplayValue = Model.Status switch
                                    {
                                        "Draft" => "غير مرحلة",
                                        "Posted" => (stage.HasValue ? $"مرحلة {stage.Value}" : "مرحّل"),
                                        "Cancelled" => "ملغى",
                                        _ => string.IsNullOrWhiteSpace(Model.Status) ? (Model.IsPosted ? (stage.HasValue ? $"مرحلة {stage.Value}" : "مرحّل") : "غير مرحلة") : Model.Status
                                    };
                                }
                                <input id="ReturnStatusDisplay" class="form-control form-control-sm text-center" value="@statusDisplayValue" readonly />
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <label class="form-label form-label-sm" for="WarehouseId">المخزن</label>
                                <select asp-for="WarehouseId" asp-items="ViewBag.Warehouses" data-lock-posted="1"
                                        class="form-select form-select-sm" data-is-posted="@(Model.IsPosted ? "1" : "0")">
                                    <option value="">اختر المخزن...</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                @* =====================================================
                   كارت إدخال الصنف في المرتجع
                   ===================================================== *@
                <div class="card shadow-sm mb-3 invoice-Add-card">
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-lg-5 col-md-4">
                                <label class="form-label form-label-sm">اختر صنف من فاتورة البيع</label>
                                <select id="InvoiceItemSelect"
                                        class="form-select form-select-sm sr-invoice-item-select"
                                        data-lock-posted="@(Model.IsPosted ? "1" : "0")">
                                    <option value="">-- اختر صنف من الفاتورة --</option>
                                </select>
                            </div>

                            <div class="col-auto">
                                <label class="form-label form-label-sm">الكمية المرتجعة</label>
                                <input type="number"
                                       id="ReturnQtyInput"
                                       class="form-control form-control-sm text-center return-line-field"
                                       placeholder="0"
                                       min="1"
                                       data-lock-posted="@(Model.IsPosted ? "1" : "0")" />
                            </div>

                            <div class="col-auto">
                                <label class="form-label form-label-sm">الكمية في الفاتورة</label>
                                <input type="number"
                                       id="InvoiceQtyDisplay"
                                       class="form-control form-control-sm text-center bg-light return-line-field"
                                       readonly />
                            </div>

                            <div class="col-auto">
                                <label class="form-label form-label-sm">التشغيلة</label>
                                <input type="text"
                                       id="ReturnBatchDisplay"
                                       class="form-control form-control-sm text-center bg-light return-line-field"
                                       readonly />
                            </div>

                            <div class="col-auto">
                                <label class="form-label form-label-sm">تاريخ الصلاحية</label>
                                <input type="text"
                                       id="ReturnExpiryDisplay"
                                       class="form-control form-control-sm text-center bg-light return-line-field"
                                       readonly />
                            </div>

                            <div class="col-lg-2 col-md-4 d-grid">
                                <label class="form-label form-label-sm">&nbsp;</label>
                                <button type="button"
                                        id="btnAddReturnLine"
                                        class="btn btn-primary btn-sm w-100"
                                        data-lock-posted="@(Model.IsPosted ? "1" : "0")">
                                    إضافة
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                @* ==========================================
                   5) جدول سطور المرتجع — نفس أعمدة فاتورة المبيعات (PILinesTable)
                   ========================================== *@
                <div class="invoice-lines-container">
                    <div class="erp-table-wrapper mb-0">
                        <table id="SalesReturnLinesTable" class="table table-sm table-striped table-hover mb-0 erp-table">
                            <thead class="sr-return-lines-thead">
                                <tr>
                                    <th class="text-center">#</th>
                                    <th class="text-center">الموقع</th>
                                    <th>اسم الصنف</th>
                                    <th class="text-center">التشغيلة</th>
                                    <th class="text-center">الصلاحية</th>
                                    <th class="text-center">الكمية</th>
                                    <th class="text-center">سعر الجمهور</th>
                                    <th class="text-center">خصم البيع %</th>
                                    <th class="text-center">قيمة السطر</th>
                                </tr>
                            </thead>
                            <tbody id="SalesReturnLinesTableBody">
                                @if (Model.Lines != null && Model.Lines.Any())
                                {
                                    var _prodNames = ViewBag.ProdNames as Dictionary<int, string>;
                                    var _prodLocs = ViewBag.ProdLocations as Dictionary<int, string>;
                                    foreach (var line in Model.Lines.OrderBy(l => l.LineNo))
                                    {
                                        var prodName = (_prodNames != null && _prodNames.TryGetValue(line.ProdId, out var _pn)) ? _pn : ("صنف #" + line.ProdId);
                                        var locDisp = (_prodLocs != null && _prodLocs.TryGetValue(line.ProdId, out var _pl) && !string.IsNullOrWhiteSpace(_pl)) ? _pl : "—";
                                        <tr class="erp-list-selectable-row" data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                            <td class="text-center">@line.LineNo</td>
                                            <td class="text-center text-muted small">@locDisp</td>
                                            <td>
                                                <strong>@prodName</strong>
                                                <span class="text-muted small"> | كود: @line.ProdId</span>
                                            </td>
                                            <td class="text-center">@(line.BatchNo ?? "")</td>
                                            <td class="text-center">@(line.Expiry.HasValue ? line.Expiry.Value.ToString("yyyy-MM-dd") : "")</td>
                                            <td class="text-center">@line.Qty</td>
                                            <td class="text-center">@line.PriceRetail.ToString("0.00")</td>
                                            <td class="text-center">@line.Disc1Percent.ToString("0.##")</td>
                                            <td class="text-center">@line.LineTotalAfterDiscount.ToString("0.00")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr id="SalesReturnLinesEmptyRow">
                                        <td colspan="9" class="text-center text-muted py-4">
                                            لا توجد سطور مسجَّلة لهذا المرتجع في هذه المرحلة.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @* ====================================
                   6) ملخص إجماليات المرتجع (بنفس تنسيق فاتورة المبيعات)
                   ==================================== *@
                <div class="card shadow-sm invoice-totals-card mb-2">
                    <div class="card-body">
                        <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row mb-3">
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">إجمالي قبل الخصم</span>
                                <span id="TotalBeforeDiscountBadge" class="invoice-summary-value">@Model.TotalBeforeDiscount.ToString("0.00")</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">خصم الهيدر (قيمة)</span>
                                <span id="HeaderDiscountSummary" class="invoice-summary-value">@Model.HeaderDiscountValue.ToString("0.00") <span class="small text-muted">(@Model.HeaderDiscountPercent.ToString("0.##") %)</span></span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">بعد الخصم وقبل الضريبة</span>
                                <span id="TotalAfterDiscountBeforeTaxBadge" class="invoice-summary-value">@Model.TotalAfterDiscountBeforeTax.ToString("0.00")</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">قيمة الضريبة</span>
                                <span id="TaxAmountBadge" class="invoice-summary-value">@Model.TaxAmount.ToString("0.00")</span>
                            </div>
                        </div>
                        <div class="d-flex flex-wrap align-items-stretch justify-content-between gap-2 invoice-summary-row">
                            <div class="invoice-summary-item invoice-summary-box invoice-summary-box-main">
                                <span class="invoice-summary-label">الصافي النهائي للمرتجع</span>
                                <span id="NetTotalBadge" class="invoice-summary-value invoice-summary-value-main fw-bold">@Model.NetTotal.ToString("0.00")</span>
                            </div>
                            @if (Model.UpdatedAt.HasValue)
                            {
                                <div class="invoice-summary-item invoice-summary-box align-self-center">
                                    <span class="invoice-summary-label">آخر تعديل</span>
                                    <span class="invoice-summary-value small">@Model.UpdatedAt.Value.ToString("d/M/yyyy HH:mm")</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @* قوائم الأوتوكومبليت الثقيلة: في آخر العمود الرئيسي حتى يكتمل رسم الكروت دفعة واحدة *@
                <datalist id="customersList" hidden aria-hidden="true">
                    @if (ViewBag.Customers != null)
                    {
                        foreach (var c in ViewBag.Customers)
                        {
                            <option value="@c.Name"
                                    data-id="@c.Id"
                                    data-policy="@c.PolicyName"
                                    data-user="@c.UserName"
                                    data-phone="@c.Phone"
                                    data-address="@c.Address"
                                    data-credit="@c.CreditLimit">
                            </option>
                        }
                    }
                </datalist>

            </div>

        </div>

    </div>
</div>

@section Scripts {
    <script>
        // دالة مساعدة: تملأ الحقول من option معين في الـ datalist
        function fillCustomerFromOption(opt) {
            var idInput = document.getElementById('CustomerId');              // كود العميل (للحفظ في المرتجع)
            var codeDisplay = document.getElementById('CustomerCodeDisplay'); // كود العميل المعروض
            var policyInput = document.getElementById('PolicyName');          // اسم السياسة (مش موجود على الشاشة هنا، لكن ممكن تضيفه بعدين)
            var userInput = document.getElementById('LinkedUserName');        // المستخدم المربوط (لو أضفته)
            var phoneInput = document.getElementById('CustomerPhone');
            var addressInput = document.getElementById('CustomerAddress');
            var creditInput = document.getElementById('CustomerCreditLimit');
            var summary = document.getElementById('CustomerSummaryText');

            if (!opt) {
                idInput.value = '';
                codeDisplay.value = '';
                if (policyInput) policyInput.value = '';
                if (userInput) userInput.value = '';
                if (phoneInput) phoneInput.value = '';
                if (addressInput) addressInput.value = '';
                if (creditInput) creditInput.value = '';
                if (summary) summary.textContent = '';
                return;
            }

            var id = opt.getAttribute('data-id') || '';
            var policy = opt.getAttribute('data-policy') || '';
            var user = opt.getAttribute('data-user') || '';
            var phone = opt.getAttribute('data-phone') || '';
            var address = opt.getAttribute('data-address') || '';
            var credit = opt.getAttribute('data-credit') || '';

            idInput.value = id;
            codeDisplay.value = id;
            if (policyInput) policyInput.value = policy;
            if (userInput) userInput.value = user;
            if (phoneInput) phoneInput.value = phone;
            if (addressInput) addressInput.value = address;
            if (creditInput) creditInput.value = credit;
            if (summary) {
                var parts = [];
                if (policy) parts.push('سياسة: ' + policy);
                if (user) parts.push('مستخدم: ' + user);
                if (credit) parts.push('حد ائتماني: ' + credit);
                summary.textContent = parts.join(' — ');
            }
        }

        document.addEventListener('DOMContentLoaded', function () {

            function showToast(text, type, durationMs) {
                if (!text) return;
                if (typeof ERP !== 'undefined' && typeof ERP.showToast === 'function') {
                    ERP.showToast(text, type, durationMs);
                    return;
                }
                var container = document.getElementById('srToastContainer');
                if (!container) return;
                type = type || 'muted';
                var ms = typeof durationMs === 'number' && durationMs >= 0 ? durationMs : 4000;
                var el = document.createElement('div');
                el.className = 'sr-toast text-' + type;
                el.textContent = text;
                container.appendChild(el);
                setTimeout(function () {
                    el.style.opacity = '0';
                    el.style.transition = 'opacity 0.25s ease';
                    setTimeout(function () {
                        if (el.parentNode) el.parentNode.removeChild(el);
                    }, 250);
                }, ms);
            }

            function syncDeleteSelectedReturnLineButton() {
                var btn = document.getElementById('btnDeleteSelectedReturnLine');
                var tbody = document.getElementById('SalesReturnLinesTableBody');
                if (!btn || !tbody) return;
                if (typeof isReturnPosted === 'function' && isReturnPosted()) {
                    btn.disabled = true;
                    return;
                }
                var sel = tbody.querySelector('tr.erp-list-selectable-row.selected');
                btn.disabled = !sel;
            }

            // تحويل حالة المرتجع من السيرفر (Draft/Posted/Cancelled) إلى النص المعروض
            function getReturnStatusDisplay(status) {
                if (!status) return 'غير مرحلة';
                switch (String(status)) {
                    case 'Draft': return 'غير مرحلة';
                    case 'Posted': return 'مرحّل';
                    case 'Cancelled': return 'ملغى';
                    default: return status;
                }
            }

            // =========================================================
            // دوال مساعدة: إدارة حالة الترحيل (مثل فاتورة المبيعات)
            // =========================================================
            function isReturnPosted() {
                const flag = document.getElementById("ReturnIsPostedFlag");
                return flag && flag.value === "1";
            }

            function setReturnPosted(posted) {
                const flag = document.getElementById("ReturnIsPostedFlag");
                if (flag) flag.value = posted ? "1" : "0";
            }

            function applyPostedUiLock() {
                const posted = isReturnPosted();
                const lockables = document.querySelectorAll('[data-lock-posted="1"]');

                lockables.forEach(el => {
                    if (!el.dataset.origDisabled) {
                        el.dataset.origDisabled = el.disabled ? "1" : "0";
                    }
                    if (!el.dataset.origReadonly && (el.tagName === "INPUT" || el.tagName === "TEXTAREA" || el.tagName === "SELECT")) {
                        el.dataset.origReadonly = el.readOnly ? "1" : "0";
                    }
                    if (!el.dataset.origTabIndex) {
                        el.dataset.origTabIndex = el.getAttribute("tabindex") ?? "";
                    }

                    const tag = (el.tagName || "").toUpperCase();

                    if (tag === "BUTTON") {
                        el.disabled = posted || el.dataset.origDisabled === "1";
                    } else if (tag === "SELECT" || tag === "INPUT" || tag === "TEXTAREA") {
                        const origReadonly = el.dataset.origReadonly === "1";
                        el.readOnly = posted || origReadonly;
                        if (posted && !origReadonly) {
                            el.setAttribute("tabindex", "-1");
                        } else {
                            const origTabIndex = el.dataset.origTabIndex;
                            if (origTabIndex === "") el.removeAttribute("tabindex");
                            else el.setAttribute("tabindex", origTabIndex);
                        }
                    }
                });
                syncDeleteSelectedReturnLineButton();
            }

            // تشغيل القفل مرة عند تحميل الصفحة
            applyPostedUiLock();

            // تطبيق القفل عند فتح الصفحة
            (function () {
                const posted = @Model.IsPosted.ToString().ToLower();
                if (posted === true && typeof setReturnPosted === "function") {
                    setReturnPosted(true);
                    if (typeof applyPostedUiLock === "function") applyPostedUiLock();
                }
            })();

            var customerInput = document.getElementById('CustomerNameInput');
            var dataList = document.getElementById('customersList');

            function findOptionByName(name) {
                if (!name) return null;
                var options = dataList.options;
                for (var i = 0; i < options.length; i++) {
                    if (options[i].value === name) return options[i];
                }
                return null;
            }

            function findOptionById(id) {
                if (!id) return null;
                var options = dataList.options;
                for (var i = 0; i < options.length; i++) {
                    if (options[i].getAttribute('data-id') == id) {
                        return options[i];
                    }
                }
                return null;
            }

            // عند اختيار اسم عميل من الأوتوكومبليت
            customerInput.addEventListener('change', function () {
                var opt = findOptionByName(customerInput.value);
                fillCustomerFromOption(opt);
            });

            // تهيئة الشاشة عند الفتح – لو في كود عميل محفوظ في المرتجع
            var initialCustomerId = '@Model.CustomerId';
            if (initialCustomerId) {
                var opt = findOptionById(initialCustomerId);
                if (opt) {
                    customerInput.value = opt.value;
                    fillCustomerFromOption(opt);
                }
            }

            // =========================================================
            // جلب أصناف فاتورة البيع + بيانات العميل عند إدخال رقم الفاتورة (Enter أو تغيير الحقل)
            // =========================================================
            var invoiceIdInput = document.getElementById('SalesInvoiceIdInput');
            var invoiceIdHidden = document.getElementById('SalesInvoiceId');
            var itemSelect = document.getElementById('InvoiceItemSelect');
            var returnQtyInput = document.getElementById('ReturnQtyInput');
            var invoiceQtyDisplay = document.getElementById('InvoiceQtyDisplay');
            var returnBatchDisplay = document.getElementById('ReturnBatchDisplay');
            var returnExpiryDisplay = document.getElementById('ReturnExpiryDisplay');
            var btnAddReturnLine = document.getElementById('btnAddReturnLine');

            var invoiceItems = []; // متغير: قائمة أصناف الفاتورة

            function invoiceItemDisplayCode(item) {
                if (!item) return '';
                var ext = item.externalCode != null ? String(item.externalCode).trim() : '';
                if (ext) return ext;
                return item.prodId != null ? String(item.prodId) : '';
            }

            async function loadInvoiceByNumber() {
                var invoiceId = parseInt(invoiceIdInput.value || '0', 10);

                if (invoiceId <= 0) {
                    invoiceIdHidden.value = '';
                    itemSelect.innerHTML = '<option value="">-- اختر صنف من الفاتورة --</option>';
                    invoiceItems = [];
                    var pce = document.getElementById('InvoiceItemProdCodeDisplay');
                    if (pce) pce.value = '';
                    return false;
                }

                try {
                    var response = await fetch(`/SalesReturns/GetInvoiceItems?invoiceId=${invoiceId}`);
                    var data = await response.json();

                    if (!data.ok) {
                        alert(data.message || 'حدث خطأ في جلب بيانات الفاتورة.');
                        return false;
                    }

                    // حفظ رقم الفاتورة
                    invoiceIdHidden.value = invoiceId.toString();

                    // تحديث بيانات العميل بالكامل حسب الفاتورة (الاسم، الهاتف، العنوان، إلخ)
                    if (data.customerId) {
                        document.getElementById('CustomerId').value = data.customerId;
                        document.getElementById('CustomerCodeDisplay').value = data.customerId;
                        var opt = findOptionById(data.customerId.toString());
                        if (opt) {
                            customerInput.value = opt.value;
                            fillCustomerFromOption(opt);
                        }
                    }

                    if (data.warehouseId) {
                        document.getElementById('WarehouseId').value = data.warehouseId;
                    }

                    // تحديث قائمة الأصناف
                    invoiceItems = data.items || [];
                    itemSelect.innerHTML = '<option value="">-- اختر صنف من الفاتورة --</option>';

                    invoiceItems.forEach(function(item, index) {
                        var option = document.createElement('option');
                        option.value = index.toString();
                        var remaining = (item.remaining != null) ? item.remaining : (item.qty - (item.alreadyReturned || 0));
                        option.textContent = (item.prodName && String(item.prodName).trim()) ? String(item.prodName).trim() : ('صنف #' + item.prodId);
                        option.setAttribute('data-prodId', item.prodId);
                        option.setAttribute('data-lineNo', item.lineNo);
                        option.setAttribute('data-qty', item.qty);
                        option.setAttribute('data-remaining', remaining);
                        option.setAttribute('data-batchNo', item.batchNo || '');
                        option.setAttribute('data-expiry', item.expiry || '');
                        option.setAttribute('data-priceRetail', item.priceRetail);
                        option.setAttribute('data-prod-code', invoiceItemDisplayCode(item));
                        itemSelect.appendChild(option);
                    });

                    // إعادة تعيين الحقول
                    returnQtyInput.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';
                    var prodCodeEl = document.getElementById('InvoiceItemProdCodeDisplay');
                    if (prodCodeEl) prodCodeEl.value = '';

                    return true;
                } catch (error) {
                    console.error('Error loading invoice items:', error);
                    alert('حدث خطأ في جلب بيانات الفاتورة.');
                    return false;
                }
            }

            // Enter في حقل رقم الفاتورة: جلب البيانات ثم نقل التركيز إلى زر الحفظ (الإنتر التالي يفعّل الحفظ ثم ينتقل للأصناف كما في سكربت الحفظ)
            invoiceIdInput.addEventListener('keydown', async function (e) {
                if (e.key !== 'Enter') return;
                e.preventDefault();
                var ok = await loadInvoiceByNumber();
                if (!ok) return;
                var btnSave = document.getElementById('btnSaveReturnHeader');
                if (btnSave && !btnSave.disabled) btnSave.focus();
            });

            // عند تغيير رقم الفاتورة (فقدان التركيز)
            invoiceIdInput.addEventListener('change', loadInvoiceByNumber);

            // عند اختيار صنف من القائمة
            itemSelect.addEventListener('change', function () {
                var selectedIndex = parseInt(itemSelect.value || '-1', 10);
                var prodCodeDisplay = document.getElementById('InvoiceItemProdCodeDisplay');

                if (selectedIndex < 0 || selectedIndex >= invoiceItems.length) {
                    returnQtyInput.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';
                    if (prodCodeDisplay) prodCodeDisplay.value = '';
                    return;
                }

                var item = invoiceItems[selectedIndex];
                if (prodCodeDisplay) prodCodeDisplay.value = invoiceItemDisplayCode(item);
                var remaining = (item.remaining != null) ? item.remaining : (item.qty - (item.alreadyReturned || 0));
                invoiceQtyDisplay.value = item.qty;
                returnBatchDisplay.value = item.batchNo || '';
                returnExpiryDisplay.value = item.expiry || '';
                returnQtyInput.max = remaining; // لا يمكن إرجاع أكثر من المتبقي (بعد خصم المرتجعات السابقة)
                returnQtyInput.value = remaining > 0 ? Math.min(remaining, parseInt(returnQtyInput.value || '0', 10) || remaining) : 0;
                if (remaining <= 0) returnQtyInput.value = '0';
            });

            // =========================================================
            // الانتقال بانتر (مثل فاتورة المبيعات): صنف → كمية → إضافة
            // =========================================================
            var enterFields = [itemSelect, returnQtyInput];
            enterFields.forEach(function (el) {
                if (!el) return;
                if (el.dataset.enterBound === '1') return;
                el.dataset.enterBound = '1';
                el.addEventListener('focus', function () {
                    if (typeof this.select === 'function') setTimeout(function () { el.select(); }, 0);
                });
                el.addEventListener('keydown', function (e) {
                    if (e.key !== 'Enter') return;
                    e.preventDefault();
                    var idx = enterFields.indexOf(el);
                    var next = enterFields[idx + 1];
                    if (next) {
                        next.focus();
                        if (next.select) next.select();
                    } else if (btnAddReturnLine) {
                        btnAddReturnLine.focus();
                    }
                });
            });
            if (btnAddReturnLine && !btnAddReturnLine.dataset.enterClickBound) {
                btnAddReturnLine.dataset.enterClickBound = '1';
                btnAddReturnLine.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        btnAddReturnLine.click();
                    }
                });
            }

            function srEscapeHtml(s) {
                if (s == null || s === '') return '';
                var d = document.createElement('div');
                d.textContent = s;
                return d.innerHTML;
            }

            function refreshReturnLinesAndTotals(data) {
                var tbody = document.getElementById('SalesReturnLinesTableBody');
                if (!tbody) return;
                var lines = (data && data.lines) ? data.lines : [];
                var totals = (data && data.totals) ? data.totals : {};
                while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
                if (lines.length === 0) {
                    var trEmpty = document.createElement('tr');
                    trEmpty.id = 'SalesReturnLinesEmptyRow';
                    trEmpty.innerHTML = '<td colspan="9" class="text-center text-muted py-4">لا توجد سطور مسجَّلة لهذا المرتجع.</td>';
                    tbody.appendChild(trEmpty);
                } else {
                    lines.forEach(function(l) {
                        var tr = document.createElement('tr');
                        tr.className = 'erp-list-selectable-row';
                        tr.setAttribute('data-line-no', l.lineNo);
                        tr.setAttribute('data-prodid', l.prodId);
                        var loc = srEscapeHtml((l.location != null && String(l.location).trim() !== '') ? String(l.location).trim() : '—');
                        var pn = srEscapeHtml((l.prodName && String(l.prodName).trim()) ? String(l.prodName).trim() : ('صنف #' + l.prodId));
                        var batch = srEscapeHtml(l.batchNo != null ? String(l.batchNo) : '');
                        var exp = srEscapeHtml(l.expiry != null ? String(l.expiry) : '');
                        var lineVal = (l.lineTotalAfterDiscount != null) ? Number(l.lineTotalAfterDiscount).toFixed(2) : (l.lineNetTotal != null ? Number(l.lineNetTotal).toFixed(2) : '');
                        tr.innerHTML =
                            '<td class="text-center">' + l.lineNo + '</td>' +
                            '<td class="text-center text-muted small">' + loc + '</td>' +
                            '<td><strong>' + pn + '</strong><span class="text-muted small"> | كود: ' + l.prodId + '</span></td>' +
                            '<td class="text-center">' + batch + '</td>' +
                            '<td class="text-center">' + exp + '</td>' +
                            '<td class="text-center">' + l.qty + '</td>' +
                            '<td class="text-center">' + (l.priceRetail != null ? Number(l.priceRetail).toFixed(2) : '') + '</td>' +
                            '<td class="text-center">' + (l.disc1Percent != null ? Number(l.disc1Percent).toFixed(2) : '') + '</td>' +
                            '<td class="text-center">' + lineVal + '</td>';
                        tbody.appendChild(tr);
                    });
                }
                var bid = document.getElementById('TotalBeforeDiscountBadge');
                if (bid && totals.totalBeforeDiscount != null) bid.textContent = Number(totals.totalBeforeDiscount).toFixed(2);
                bid = document.getElementById('TotalAfterDiscountBeforeTaxBadge');
                if (bid && totals.totalAfterDiscountBeforeTax != null) bid.textContent = Number(totals.totalAfterDiscountBeforeTax).toFixed(2);
                bid = document.getElementById('TaxAmountBadge');
                if (bid && totals.taxAmount != null) bid.textContent = Number(totals.taxAmount).toFixed(2);
                bid = document.getElementById('NetTotalBadge');
                if (bid && totals.netTotal != null) bid.textContent = Number(totals.netTotal).toFixed(2);
                syncDeleteSelectedReturnLineButton();
            }

            // عند إضافة سطر للمرتجع
            btnAddReturnLine.addEventListener('click', async function () {
                var selectedIndex = parseInt(itemSelect.value || '-1', 10);
                var returnQty = parseInt(returnQtyInput.value || '0', 10);
                var returnId = parseInt(document.getElementById('SRId').value || '0', 10);

                if (selectedIndex < 0 || selectedIndex >= invoiceItems.length) {
                    alert('من فضلك اختر صنف من الفاتورة.');
                    return;
                }
                if (returnQty <= 0) {
                    alert('الكمية المرتجعة يجب أن تكون أكبر من صفر.');
                    return;
                }
                var item = invoiceItems[selectedIndex];
                var remaining = (item.remaining != null) ? item.remaining : (item.qty - (item.alreadyReturned || 0));
                if (remaining <= 0) {
                    alert('تم إرجاع كامل كمية هذا السطر من الفاتورة مسبقاً. لا يمكن إضافة المزيد.');
                    return;
                }
                if (returnQty > remaining) {
                    alert('الكمية المرتجعة تتجاوز المتبقي للمرتجع من هذا السطر (' + remaining + '). الكمية في الفاتورة: ' + item.qty + '، تم إرجاع ' + (item.alreadyReturned || 0) + ' سابقاً.');
                    return;
                }
                if (returnId <= 0) {
                    alert('يجب حفظ المرتجع أولاً قبل إضافة الأصناف.');
                    return;
                }

                var salesInvoiceId = parseInt(document.getElementById('SalesInvoiceId').value || '0', 10) || null;
                var dto = { SRId: returnId, ProdId: item.prodId, Qty: returnQty, BatchNo: item.batchNo || null, ExpiryText: item.expiry || null, PriceRetail: item.priceRetail || 0, Disc1Percent: item.disc1Percent != null ? item.disc1Percent : 0, SalesInvoiceId: salesInvoiceId, SalesInvoiceLineNo: item.lineNo };
                btnAddReturnLine.disabled = true;
                try {
                    var res = await fetch('@Url.Action("AddLineJson", "SalesReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dto) });
                    var txt = await res.text();
                    var data = null;
                    if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                    if (!res.ok || !data || !data.ok) {
                        alert((data && data.message) ? data.message : 'فشل إضافة السطر.');
                        return;
                    }
                    refreshReturnLinesAndTotals(data);
                    // تحديث المتبقي للمرتجع في الصنف المضاف (للعرض عند إعادة الاختيار)
                    item.alreadyReturned = (item.alreadyReturned || 0) + returnQty;
                    item.remaining = item.qty - item.alreadyReturned;
                    if (item.remaining < 0) item.remaining = 0;
                    returnQtyInput.value = '';
                    itemSelect.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';
                    // مثل المبيعات: فوكس على حقل اسم/اختيار الصنف بعد الإضافة
                    itemSelect.focus();
                    itemSelect.click();
                } catch (e) {
                    console.error(e);
                    alert('حدث خطأ أثناء إضافة السطر.');
                } finally {
                    btnAddReturnLine.disabled = false;
                }
            });

            // تهيئة رقم الفاتورة إذا كان موجوداً
            var initialInvoiceId = '@(Model.SalesInvoiceId?.ToString() ?? "")';
            if (initialInvoiceId) {
                invoiceIdInput.value = initialInvoiceId;
                invoiceIdInput.dispatchEvent(new Event('change'));
            }

            // =========================================================
            // زر حفظ المرتجع (SaveHeader) — يحفظ الهيدر ويسجّل رقم المرتجع
            // =========================================================
            var btnSaveReturn = document.getElementById('btnSaveReturnHeader');
            if (btnSaveReturn) {
                btnSaveReturn.addEventListener('click', async function () {
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    var customerId = parseInt(document.getElementById('CustomerId').value || '0', 10);
                    var warehouseId = parseInt(document.getElementById('WarehouseId').value || '0', 10);
                    var salesInvoiceIdInput = document.getElementById('SalesInvoiceId');
                    var salesInvoiceId = 0;
                    if (salesInvoiceIdInput && salesInvoiceIdInput.value.trim() !== '') {
                        var v = parseInt(salesInvoiceIdInput.value.trim(), 10);
                        if (!isNaN(v)) salesInvoiceId = v;
                    }

                    if (!customerId || !warehouseId) {
                        alert('من فضلك اختر العميل والمخزن أولاً قبل حفظ المرتجع.');
                        return;
                    }

                    var dto = { srId: srId, customerId: customerId, warehouseId: warehouseId, salesInvoiceId: salesInvoiceId || null };
                    btnSaveReturn.disabled = true;
                    try {
                        var response = await fetch('@Url.Action("SaveHeader", "SalesReturns")', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(dto)
                        });
                        var txt = await response.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!response.ok) {
                            alert((data && data.message) ? data.message : 'حدث خطأ أثناء حفظ المرتجع.');
                            return;
                        }
                        if (!data || !data.success) {
                            alert((data && data.message) ? data.message : 'تعذر حفظ المرتجع.');
                            return;
                        }
                        var newId = data.srId || 0;
                        document.getElementById('SRId').value = newId.toString();
                        var dateEl = document.getElementById('ReturnDateDisplay');
                        var timeEl = document.getElementById('ReturnTimeDisplay');
                        if (dateEl && data.returnDate) dateEl.value = data.returnDate;
                        if (timeEl && data.returnTime) timeEl.value = data.returnTime;
                        var clearBtn = document.getElementById('btnClearReturnLines');
                        if (clearBtn) clearBtn.setAttribute('data-return-id', newId.toString());
                        var numDisp = document.getElementById('ReturnNumberDisplay');
                        if (numDisp) numDisp.value = newId.toString();
                        // تحديث حالة المرتجع (عرض بالعربية)
                        var statusEl = document.getElementById('ReturnStatusDisplay');
                        if (statusEl && data.status !== undefined) {
                            statusEl.value = getReturnStatusDisplay(data.status);
                        }
                        // مثل فاتورة المبيعات: بدون رسالة تنبيه، فوكس على حقل الصنف مباشرة
                        var prodSelect = document.getElementById('InvoiceItemSelect');
                        if (prodSelect) {
                            prodSelect.focus();
                            prodSelect.click();
                        }
                    } catch (err) {
                        console.error(err);
                        alert('تعذر الاتصال بالخادم لحفظ المرتجع.');
                    } finally {
                        btnSaveReturn.disabled = false;
                    }
                });
            }

            var linesTableBody = document.getElementById('SalesReturnLinesTableBody');
            if (linesTableBody) {
                linesTableBody.addEventListener('click', function (ev) {
                    var tr = ev.target.closest('tr.erp-list-selectable-row');
                    if (!tr || !linesTableBody.contains(tr)) return;
                    linesTableBody.querySelectorAll('tr.erp-list-selectable-row.selected').forEach(function (r) { r.classList.remove('selected'); });
                    tr.classList.add('selected');
                    syncDeleteSelectedReturnLineButton();
                });
            }

            var btnDeleteSelectedLine = document.getElementById('btnDeleteSelectedReturnLine');
            if (btnDeleteSelectedLine) {
                btnDeleteSelectedLine.addEventListener('click', async function () {
                    if (btnDeleteSelectedLine.disabled) return;
                    var tbody = document.getElementById('SalesReturnLinesTableBody');
                    var sel = tbody && tbody.querySelector('tr.erp-list-selectable-row.selected');
                    var lineNo = sel ? parseInt(sel.getAttribute('data-line-no') || '0', 10) : 0;
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    if (srId <= 0 || lineNo <= 0) {
                        alert('اختر سطراً في الجدول أولاً.');
                        return;
                    }
                    if (typeof isReturnPosted === "function" && isReturnPosted()) {
                        alert('المرتجع مترحّل ومقفول. استخدم زر (فتح المرتجع) أولاً.');
                        return;
                    }
                    if (!confirm('هل تريد مسح هذا السطر؟ (مسح سطر المرتجع يقلّل المخزون — عكس البيع)')) return;
                    btnDeleteSelectedLine.disabled = true;
                    try {
                        var res = await fetch('@Url.Action("RemoveLineJson", "SalesReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ SRId: srId, LineNo: lineNo }) });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) { alert((data && data.message) ? data.message : 'فشل مسح السطر.'); return; }
                        refreshReturnLinesAndTotals(data);
                    } catch (e) { console.error(e); alert('حدث خطأ أثناء مسح السطر.'); }
                    finally {
                        syncDeleteSelectedReturnLineButton();
                    }
                });
            }

            // مسح كل أصناف المرتجع
            var btnClear = document.getElementById('btnClearReturnLines');
            if (btnClear) {
                btnClear.addEventListener('click', async function() {
                    var srId = parseInt(document.getElementById('SRId').value || btnClear.getAttribute('data-return-id') || '0', 10);
                    if (srId <= 0) { alert('يجب حفظ المرتجع أولاً.'); return; }
                    if (typeof isReturnPosted === "function" && isReturnPosted()) {
                        alert('المرتجع مترحّل. استخدم "فتح المرتجع" أولاً.');
                        return;
                    }
                    if (!confirm('هل تريد مسح كل أصناف المرتجع؟')) return;
                    btnClear.disabled = true;
                    try {
                        var res = await fetch('@Url.Action("ClearLinesJson", "SalesReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ SRId: srId }) });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) { alert((data && data.message) ? data.message : 'فشل مسح الأصناف.'); return; }
                        refreshReturnLinesAndTotals(data);
                    } catch (e) { console.error(e); alert('حدث خطأ.'); }
                    finally { btnClear.disabled = false; }
                });
            }

            // ترحيل المرتجع
            var btnPost = document.getElementById('btnPostReturn');
            var postMsg = document.getElementById('postReturnMsg');
            var statusDisplay = document.getElementById('ReturnStatusDisplay');
            
            if (btnPost) {
                const serverIsPosted = @Model.IsPosted.ToString().ToLower();

                // لو مترحّل من البداية: اقفل زر الترحيل وطبق القفل
                if (serverIsPosted) {
                    btnPost.disabled = true;
                    btnPost.innerHTML = "✅ تم ترحيل المرتجع";
                    if (typeof setReturnPosted === "function") setReturnPosted(true);
                    if (typeof applyPostedUiLock === "function") applyPostedUiLock();
                    if (postMsg) {
                        postMsg.textContent = "هذا المرتجع مترحّل بالفعل.";
                        postMsg.className = "small mt-2 text-muted";
                    }
                }

                // ربط حدث الترحيل دائماً (حتى بعد فتح المرتجع يعمل الزر)
                btnPost.addEventListener('click', async function() {
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    if (srId <= 0) { 
                        if (postMsg) {
                            postMsg.textContent = "يجب حفظ المرتجع أولاً قبل الترحيل.";
                            postMsg.className = "small mt-2 text-danger";
                        }
                        return; 
                    }
                    if (!confirm('هل تريد ترحيل هذا المرتجع؟')) return;
                    btnPost.disabled = true;
                    try {
                        // حفظ الهيدر أولاً (لتطبيق أي تعديل مثل تغيير العميل)
                        var customerId = parseInt(document.getElementById('CustomerId').value || '0', 10);
                        var warehouseId = parseInt(document.getElementById('WarehouseId').value || '0', 10);
                        var salesInvoiceIdInput = document.getElementById('SalesInvoiceId');
                        var salesInvoiceId = 0;
                        if (salesInvoiceIdInput && salesInvoiceIdInput.value.trim() !== '') {
                            var v = parseInt(salesInvoiceIdInput.value.trim(), 10);
                            if (!isNaN(v)) salesInvoiceId = v;
                        }
                        if (customerId <= 0 || warehouseId <= 0) {
                            if (postMsg) { postMsg.textContent = "يجب اختيار العميل والمخزن قبل الترحيل."; postMsg.className = "small mt-2 text-danger"; }
                            btnPost.disabled = false;
                            return;
                        }
                        {
                            var saveRes = await fetch('@Url.Action("SaveHeader", "SalesReturns")', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ srId: srId, customerId: customerId, warehouseId: warehouseId, salesInvoiceId: salesInvoiceId || null })
                            });
                            var saveTxt = await saveRes.text();
                            var saveData = null;
                            if (saveTxt) { try { saveData = JSON.parse(saveTxt); } catch (e) {} }
                            if (!saveRes.ok || !saveData || !saveData.success) {
                                if (postMsg) { postMsg.textContent = (saveData && saveData.message) ? saveData.message : 'تعذر حفظ التعديلات قبل الترحيل.'; postMsg.className = 'small mt-2 text-danger'; }
                                btnPost.disabled = false;
                                return;
                            }
                        }
                        var res = await fetch('@Url.Action("PostReturn", "SalesReturns")?id=' + srId, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) { 
                            if (postMsg) {
                                postMsg.textContent = (data && data.message) ? data.message : 'فشل الترحيل.';
                                postMsg.className = "small mt-2 text-danger";
                            }
                            return; 
                        }
                        
                        // تحديث الحالة (عرض "مرحلة X" مثل المبيعات)
                        if (statusDisplay) {
                            var stage = (data && data.stage != null) ? data.stage : 1;
                            statusDisplay.value = (data && data.postedLabel) ? data.postedLabel : ('مرحلة ' + stage);
                        }

                        // تحديث الفلاج + تطبيق القفل
                        if (typeof setReturnPosted === "function") setReturnPosted(true);
                        if (typeof applyPostedUiLock === "function") applyPostedUiLock();

                        // تحديث زر الترحيل
                        btnPost.innerHTML = "✅ تم ترحيل المرتجع";
                        btnPost.disabled = true;

                        // تفعيل زر الفتح
                        var btnOpen = document.getElementById('btnOpenReturn');
                        if (btnOpen) {
                            btnOpen.disabled = false;
                        }

                        if (postMsg) {
                            postMsg.textContent = '';
                            postMsg.className = 'small mt-2';
                        }
                        showToast((data && data.message) ? data.message : 'تم الترحيل.', 'success', 1000);
                    } catch (e) { 
                        console.error(e); 
                        if (postMsg) {
                            postMsg.textContent = 'حدث خطأ أثناء الترحيل.';
                            postMsg.className = "small mt-2 text-danger";
                        }
                    }
                    finally { 
                        if (typeof isReturnPosted === 'function' && !isReturnPosted()) btnPost.disabled = false;
                    }
                });
            }

            // فتح المرتجع (إلغاء الترحيل) — بنفس فكرة فاتورة المبيعات
            var btnOpen = document.getElementById('btnOpenReturn');
            if (btnOpen) {
                if (typeof isReturnPosted === "function" && !isReturnPosted()) {
                    btnOpen.disabled = true;
                }
                let busy = false;
                btnOpen.addEventListener('click', async function() {
                    if (busy) return;
                    if (btnOpen.disabled) return;
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    if (srId <= 0) {
                        if (postMsg) {
                            postMsg.textContent = "اختر مرتجعاً أولاً.";
                            postMsg.className = "small mt-2 text-danger";
                        }
                        return;
                    }
                    if (!confirm('هل تريد فتح المرتجع (إلغاء الترحيل)؟')) return;
                    busy = true;
                    var oldHtml = btnOpen.innerHTML;
                    btnOpen.disabled = true;
                    btnOpen.innerHTML = "⏳ جاري الفتح...";
                    if (postMsg) {
                        postMsg.textContent = "جاري فتح المرتجع للتعديل...";
                        postMsg.className = "small mt-2 text-muted";
                    }
                    try {
                        var res = await fetch('@Url.Action("OpenReturn", "SalesReturns")?id=' + srId, {
                            method: 'POST',
                            credentials: 'same-origin',
                            headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/json' }
                        });
                        var data = null;
                        try {
                            var txt = await res.text();
                            if (txt) data = JSON.parse(txt);
                        } catch (e) { }
                        if (!res.ok || !data || !data.ok) {
                            if (postMsg) {
                                postMsg.textContent = (data && data.message) ? data.message : 'فشل فتح المرتجع.';
                                postMsg.className = "small mt-2 text-danger";
                            }
                            btnOpen.disabled = false;
                            btnOpen.innerHTML = oldHtml;
                            busy = false;
                            return;
                        }
                        // نجاح: تحديث الفلاج + الواجهة (مثل المبيعات)
                        if (typeof setReturnPosted === "function") setReturnPosted(false);
                        if (typeof applyPostedUiLock === "function") applyPostedUiLock();
                        if (statusDisplay) {
                            statusDisplay.value = "مفتوحة للتعديل";
                        }
                        btnOpen.innerHTML = "⏪ فتح المرتجع";
                        btnOpen.disabled = true;
                        if (btnPost) {
                            btnPost.disabled = false;
                            btnPost.innerHTML = "📤 ترحيل المرتجع";
                        }
                        if (postMsg) {
                            postMsg.textContent = (data && data.message) ? data.message : 'تم فتح المرتجع للتعديل.';
                            postMsg.className = "small mt-2 text-success";
                        }
                    } catch (e) {
                        console.error(e);
                        if (postMsg) {
                            postMsg.textContent = 'حدث خطأ أثناء فتح المرتجع.';
                            postMsg.className = "small mt-2 text-danger";
                        }
                        btnOpen.disabled = false;
                        btnOpen.innerHTML = oldHtml;
                    }
                    finally {
                        busy = false;
                    }
                });
            }

            // =========================================================
            // سكربت التنقل (داخل نفس التاب)
            // =========================================================

            // ==============================
            // (1) Tooltips (Bootstrap) لو موجود
            // ==============================
            try {
                if (window.bootstrap && typeof bootstrap.Tooltip === 'function') {
                    document.querySelectorAll('[title]').forEach(el => new bootstrap.Tooltip(el));
                }
            } catch (e) { }

            // ==============================
            // (2) رابط Edit الصحيح
            // ==============================
            const editBaseUrl = '@Url.Action("Edit", "SalesReturns")'; // مثال: /SalesReturns/Edit

            function openReturn(id) {
                id = parseInt(id || '0', 10);
                if (!id || id <= 0) return;

                // ✅ مهم: Edit عندك بالمسار /Edit/{id}
                const base = editBaseUrl.replace(/\/$/, '');
                const url = base + '/' + encodeURIComponent(id);
                window.location.href = url;
            }

            function bindNavButton(btnId) {
                const btn = document.getElementById(btnId);
                if (!btn) return;

                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    if (btn.disabled) return;

                    const id = btn.getAttribute('data-id');
                    openReturn(id);
                });
            }

            bindNavButton('btnFirstReturn');
            bindNavButton('btnPrevReturn');
            bindNavButton('btnNextReturn');
            bindNavButton('btnLastReturn');

            // ==============================
            // (3) البحث برقم المرتجع
            // ==============================
            const searchInput = document.getElementById('NavReturnSearchInput');
            const searchBtn   = document.getElementById('btnNavReturnSearch');

            function doSearch() {
                const v = (searchInput?.value || '').trim();
                if (!v) return;
                openReturn(v);
            }

            searchBtn?.addEventListener('click', (e) => {
                e.preventDefault();
                doSearch();
            });

            searchInput?.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    doSearch();
                }
            });

            // زر التحديث في الناف بار: إعادة تحميل نفس المرتجع من السيرفر (سياسة عميل، حالة، إلخ)
            window.__ERP_REFRESH__ = function () {
                var rid = parseInt((document.getElementById('SRId') || document.getElementById('ReturnId'))?.value || '0', 10) || 0;
                if (rid > 0) {
                    window.location.reload();
                }
            };

        });
    </script>
}
