@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.SalesReturn

@{
    ViewData["Title"] = Model.SRId == 0
        ? "مرتجع بيع"
        : $"مرتجع بيع — رقم {Model.SRId}";
}

@section Styles {
    <style>
        /* خلفية عامة للصفحة */
        .invoice-page {
            background-color: #f3f6fb; /* لون خفيف مريح للعين */
            min-height: 100vh;
            padding-bottom: 2rem;
        }

        /* الكروت الرئيسية (الهيدر + تفاصيل + إدخال صنف + بيانات الصنف + السطور + الإجماليات + الكارت الجانبي) */
        .invoice-header-card,
        .invoice-details-card,
        .invoice-lines-card,
        .invoice-totals-card,
        .invoice-side-card,
        .invoice-Add-card,
        .invoice-product-card {
            border-radius: 1rem;
            overflow: hidden;
        }

        /* شريط الهيدر الملون للهيدر الرئيسي للمرتجع */
        .invoice-header-bar {
            background: linear-gradient(90deg, #6f42c1 0%, #0dcaf0 100%);
            color: #ffffff;
            padding: 0.75rem 1.25rem;
        }

            .invoice-header-bar h5 {
                margin-bottom: 0.1rem;
            }

        /* نفس لون الهيدر لباقي الكروت */
        .invoice-details-card .card-header,
        .invoice-Add-card .card-header,
        .invoice-product-card .card-header,
        .invoice-lines-card .card-header,
        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #6f42c1 0%, #0dcaf0 100%);
            color: #ffffff;
            padding: 0.55rem 1rem;
        }

        .invoice-status-badge {
            font-size: 0.8rem;
            padding: 0.3rem 0.7rem;
        }

        .badge-status-draft {
            background-color: #6f42c1;
        }

        .badge-status-notposted {
            background-color: #343a40;
        }

        .form-label-sm {
            font-size: 0.85rem;
        }

        .invoice-small-input {
            max-width: 150px;
        }

        .customer-summary-line {
            font-size: 0.82rem;
        }

        .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
        }

            .invoice-side-card .btn-erp + .btn-erp {
                margin-top: 0.25rem;
            }

        .invoice-lines-header {
            background: linear-gradient(90deg, #6f42c1 0%, #0dcaf0 100%);
            color: #fff;
        }

            .invoice-lines-header th {
                border-color: #0b5ed7 !important;
            }

        .erp-table-wrapper {
            max-height: 360px;
            overflow: auto;
        }

        .summary-badge {
            min-width: 80px;
            text-align: center;
        }
    </style>
}

<div class="invoice-page" dir="rtl">
    <div class="container-fluid pt-3">

        <div class="row g-3">

            @* =========================
               العمود الرئيسي (الهيدر + العميل + الأصناف + الإجماليات)
               ========================= *@
            <div class="col-lg-10">

                @* ====================================================
                   1) كارت بيانات مرتجع البيع + العميل + المخزن
                   ==================================================== *@
                <div class="card shadow-sm mb-2 invoice-header-card">

                    @{
                        // لو SRId = 0 يبقى لسه مرتجع جديد (لسه ما اتسجلش في الداتا)
                        bool isNewReturn = Model == null || Model.SRId == 0;

                        bool hasReturn = Model.SRId > 0;

                        // نص تاريخ/وقت المرتجع المعروضين في الكروت
                        string returnDateText = hasReturn
                        ? Model.SRDate.ToString("yyyy/MM/dd")
                        : "";

                        string returnTimeText = hasReturn
                        ? Model.SRTime.ToString(@"hh\:mm")
                        : "";
                    }

                    <div class="invoice-header-bar d-flex justify-content-between align-items-center flex-wrap gap-2">
                        @* الجزء الأيسر: عنوان مرتجع البيع + اسم المنشئ *@
                        <div>
                            <h5 class="mb-1">
                                @if (isNewReturn)
                                {
                                    @:مرتجع بيع
                                }
                                else
                                {
                                    @:مرتجع بيع
                                    <span class="small opacity-100">رقم @Model.SRId</span>
                                }
                            </h5>

                            @if (!isNewReturn && !string.IsNullOrWhiteSpace(Model.CreatedBy))
                            {
                                <div class="small opacity-100">
                                    أُنشئ بواسطة:
                                    <span class="fw-semibold">@Model.CreatedBy</span>
                                </div>
                            }
                        </div>

                        @* الجزء الأيمن: حالة المرتجع *@
                        <div class="text-end">
                            @if (isNewReturn)
                            {
                                <span class="text-white fw-semibold">
                                    اضغط على "مرتجع جديد".
                                </span>
                            }
                            else if (Model.IsPosted)
                            {
                                <span class="text-white fw-semibold">
                                    مرتجع مرحّل
                                </span>
                            }
                            else if (string.Equals(Model.Status, "Cancelled", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="text-white fw-semibold">
                                    مرتجع ملغى
                                </span>
                            }
                            else
                            {
                                <span class="text-white fw-semibold">
                                    مرتجع مفتوح
                                </span>
                            }
                        </div>
                    </div>

                    <div class="card-body">

                        <div class="row g-3 align-items-end">

                            @* اسم العميل + أوتوكومبليت *@
                            <div class="col-lg-4 col-md-6">
                                <label for="CustomerNameInput" class="form-label form-label-sm">اسم العميل</label>
                                <input id="CustomerNameInput"
                                       class="form-control form-control-sm"
                                       placeholder="اكتب اسم العميل أو جزء منه للبحث..."
                                       list="customersList"
                                       autocomplete="off" />

                                <datalist id="customersList">
                                    @if (ViewBag.Customers != null)
                                    {
                                        foreach (var c in ViewBag.Customers)
                                        {
                                            <option value="@c.Name"
                                                    data-id="@c.Id"
                                                    data-policy="@c.PolicyName"
                                                    data-user="@c.UserName"
                                                    data-phone="@c.Phone"
                                                    data-address="@c.Address"
                                                    data-credit="@c.CreditLimit">
                                            </option>
                                        }
                                    }
                                </datalist>

                                <small id="CustomerSummaryText"
                                       class="text-muted customer-summary-line d-block mt-1">
                                    @* سيتم ملؤه بجملة مختصرة عن العميل *@
                                </small>
                            </div>

                            @* كود العميل *@
                            <div class="col-lg-2 col-md-3">
                                <label class="form-label form-label-sm">كود العميل</label>
                                <input id="CustomerCodeDisplay"
                                       class="form-control form-control-sm text-center invoice-small-input"
                                       readonly />

                                <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                                <input type="hidden" id="SRId" value="@Model.SRId" />
                            </div>

                            @* المخزن *@
                            <div class="col-lg-3 col-md-3">
                                <label class="form-label form-label-sm" for="WarehouseId">المخزن</label>
                                <select asp-for="WarehouseId"
                                        asp-items="ViewBag.Warehouses"
                                        class="form-select form-select-sm">
                                    <option value="">اختر المخزن...</option>
                                </select>
                            </div>

                            @* التاريخ والوقت *@
                            <div class="col-lg-3 col-md-6">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">تاريخ المرتجع</label>
                                        <input id="ReturnDateDisplay" class="form-control form-control-sm text-center"
                                               value="@returnDateText"
                                               readonly />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">وقت المرتجع</label>
                                        <input id="ReturnTimeDisplay" class="form-control form-control-sm text-center"
                                               value="@returnTimeText"
                                               readonly />
                                    </div>
                                </div>
                            </div>

                        </div>

                        <hr class="my-3" />

                        <div class="row g-3">
                            <div class="col-lg-3 col-md-4">
                                <label class="form-label form-label-sm">رقم المرتجع</label>
                                <input id="ReturnNumberDisplay"
                                       class="form-control form-control-sm text-center fw-semibold"
                                       value="@(Model.SRId > 0 ? Model.SRId.ToString() : "—")"
                                       readonly />
                            </div>
                            <div class="col-lg-3 col-md-4">
                                <label class="form-label form-label-sm">حالة المرتجع</label>
                                <input id="ReturnStatusDisplay" class="form-control form-control-sm text-center"
                                       value="@Model.Status"
                                       readonly />
                            </div>
                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">مرحّل؟</label>
                                <input id="ReturnIsPostedDisplay" class="form-control form-control-sm text-center"
                                       value="@(Model.IsPosted ? "نعم" : "لا")"
                                       readonly />
                            </div>
                            <div class="col-lg-4 col-md-4">
                                <label class="form-label form-label-sm">رقم فاتورة البيع</label>
                                <input type="number" 
                                       id="SalesInvoiceIdInput"
                                       class="form-control form-control-sm text-center"
                                       value="@(Model.SalesInvoiceId?.ToString() ?? "")"
                                       placeholder="أدخل رقم الفاتورة"
                                       data-lock-posted="@(Model.IsPosted ? "1" : "0")" />
                                <input type="hidden" asp-for="SalesInvoiceId" id="SalesInvoiceId" />
                            </div>
                        </div>
                    </div>
                </div>

                @* ======================================
                   2) كارت تفاصيل العميل
                   ====================================== *@
                <div class="card shadow-sm mb-3 invoice-details-card">
                    <div class="card-header">
                        <h6 class="mb-0">تفاصيل العميل</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-lg-4 col-md-4">
                                <label class="form-label form-label-sm">الهاتف</label>
                                <input id="CustomerPhone"
                                       class="form-control form-control-sm"
                                       readonly />
                            </div>

                            <div class="col-lg-8 col-md-8">
                                <label class="form-label form-label-sm">العنوان</label>
                                <input id="CustomerAddress"
                                       class="form-control form-control-sm"
                                       readonly />
                            </div>

                            <div class="col-lg-4 col-md-4">
                                <label class="form-label form-label-sm">الحد الائتماني</label>
                                <input id="CustomerCreditLimit"
                                       class="form-control form-control-sm text-center"
                                       readonly />
                            </div>
                        </div>
                    </div>
                </div>

                @* =====================================================
                   3) كارت بيانات الصنف (مخزون + خصومات)
                   ===================================================== *@
                <div class="card shadow-sm mb-3 invoice-product-card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">بيانات الصنف (مخزون + خصومات)</h6>
                        <small class="opacity-75">
                            هذه البيانات للصنف الحالي في كارت "تسجيل الأصناف في المرتجع".
                        </small>
                    </div>

                    <div class="card-body">
                        <div class="row g-3 mb-2">
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الكمية المتاحة في هذا المخزن</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">إجمالي الكمية في كل المخازن</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">كمية الكوتة المتبقية</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الخصم المرجّح للصنف %</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>
                        </div>

                        <div class="table-responsive mt-2">
                            <table class="table table-sm table-striped mb-0">
                                <thead>
                                    <tr>
                                        <th>المخزن</th>
                                        <th class="text-center">الكمية المتاحة</th>
                                        <th class="text-center">محجوزة لطلبات</th>
                                        <th class="text-center">متاح للبيع</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @* هتملا لاحقاً من الداتا *@
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>

                @* =====================================================
                   4) كارت إدخال الصنف في المرتجع
                   ===================================================== *@
                <div class="card shadow-sm mb-3 invoice-Add-card">
                    <div class="card-header">
                        <h6 class="mb-0">تسجيل أصناف المرتجع من فاتورة البيع</h6>
                    </div>

                    <div class="card-body">
                        <div class="row g-2 align-items-end mb-3">
                            <div class="col-lg-4 col-md-6">
                                <label class="form-label form-label-sm">اختر صنف من فاتورة البيع</label>
                                <select id="InvoiceItemSelect"
                                        class="form-select form-select-sm"
                                        data-lock-posted="@(Model.IsPosted ? "1" : "0")">
                                    <option value="">-- اختر صنف من الفاتورة --</option>
                                </select>
                            </div>

                            <div class="col-lg-2 col-md-3">
                                <label class="form-label form-label-sm">الكمية المرتجعة</label>
                                <input type="number"
                                       id="ReturnQtyInput"
                                       class="form-control form-control-sm text-center"
                                       placeholder="0"
                                       min="1"
                                       data-lock-posted="@(Model.IsPosted ? "1" : "0")" />
                            </div>

                            <div class="col-lg-2 col-md-3">
                                <label class="form-label form-label-sm">الكمية في الفاتورة</label>
                                <input type="number"
                                       id="InvoiceQtyDisplay"
                                       class="form-control form-control-sm text-center"
                                       readonly />
                            </div>

                            <div class="col-lg-2 col-md-6">
                                <label class="form-label form-label-sm">التشغيلة</label>
                                <input type="text"
                                       id="ReturnBatchDisplay"
                                       class="form-control form-control-sm text-center"
                                       readonly />
                            </div>

                            <div class="col-lg-2 col-md-6">
                                <label class="form-label form-label-sm">تاريخ الصلاحية</label>
                                <input type="text"
                                       id="ReturnExpiryDisplay"
                                       class="form-control form-control-sm text-center"
                                       readonly />
                            </div>
                        </div>

                        <div class="row g-2 align-items-end">
                            <div class="col-lg-12">
                                <div class="d-grid gap-1 invoice-item-actions">
                                    <button type="button"
                                            id="btnAddReturnLine"
                                            class="btn btn-erp btn-erp-primary btn-erp-sm"
                                            data-lock-posted="@(Model.IsPosted ? "1" : "0")">
                                        إضافة الصنف للمرتجع
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* ==========================================
                   5) جدول سطور المرتجع (عرض مبدئي)
                   ========================================== *@
                <div class="card shadow-sm mb-3 invoice-lines-card">
                    <div class="card-header py-2 invoice-lines-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">
                                سطور مرتجع البيع
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="erp-table-wrapper mb-0">
                            <table class="table table-sm table-striped table-hover mb-0 erp-table">
                                <thead>
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">الكمية</th>
                                        <th class="text-center">سعر الجمهور</th>
                                        <th class="text-center">خصم 1 %</th>
                                        <th class="text-center">خصم 2 %</th>
                                        <th class="text-center">خصم 3 %</th>
                                        <th class="text-center">الإجمالي</th>
                                        <th class="text-center">مسح</th>
                                    </tr>
                                </thead>
                                <tbody id="SalesReturnLinesTableBody">
                                    @if (Model.Lines != null && Model.Lines.Any())
                                    {
                                        var _prodNames = ViewBag.ProdNames as Dictionary<int, string>;
                                        foreach (var line in Model.Lines.OrderBy(l => l.LineNo))
                                        {
                                            var prodName = (_prodNames != null && _prodNames.TryGetValue(line.ProdId, out var _pn)) ? _pn : line.ProdId.ToString();
                                            <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                <td class="text-center">@line.LineNo</td>
                                                <td>@prodName</td>
                                                <td class="text-center">@line.Qty</td>
                                                <td class="text-center">@line.PriceRetail.ToString("0.00")</td>
                                                <td class="text-center">@line.Disc1Percent.ToString("0.##")</td>
                                                <td class="text-center">@line.Disc2Percent.ToString("0.##")</td>
                                                <td class="text-center">@line.Disc3Percent.ToString("0.##")</td>
                                                <td class="text-center">@line.LineNetTotal.ToString("0.00")</td>
                                                <td class="text-center">
                                                    <button type="button" class="btn btn-danger btn-sm btnRemoveReturnLine"
                                                            data-line-no="@line.LineNo" data-sr-id="@Model.SRId"
                                                            data-lock-posted="@(Model.IsPosted ? "1" : "0")"
                                                            title="مسح السطر">🗑</button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr id="SalesReturnLinesEmptyRow">
                                            <td colspan="9" class="text-center text-muted py-4">
                                                لا توجد سطور مسجَّلة لهذا المرتجع في هذه المرحلة.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @* ====================================
                   6) ملخص إجماليات المرتجع
                   ==================================== *@
                <div class="card shadow-sm invoice-totals-card">
                    <div class="card-body">

                        <div class="row g-2 align-items-center mb-2">
                            <div class="col-md-3">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">إجمالي قبل الخصم</span>
                                    <span id="TotalBeforeDiscountBadge" class="badge bg-light text-dark summary-badge">@Model.TotalBeforeDiscount.ToString("0.00")</span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">خصم الهيدر (قيمة)</span>
                                    <span class="badge bg-warning text-dark summary-badge">@Model.HeaderDiscountValue.ToString("0.00") <span class="small">(@Model.HeaderDiscountPercent.ToString("0.##") %)</span></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">إجمالي بعد الخصم وقبل الضريبة</span>
                                    <span id="TotalAfterDiscountBeforeTaxBadge" class="badge bg-light text-dark summary-badge">@Model.TotalAfterDiscountBeforeTax.ToString("0.00")</span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">قيمة الضريبة</span>
                                    <span id="TaxAmountBadge" class="badge bg-info text-dark summary-badge">@Model.TaxAmount.ToString("0.00")</span>
                                </div>
                            </div>
                        </div>
                        <hr class="my-3" />
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <span class="small text-muted d-block">الصافي النهائي للمرتجع</span>
                                <h3 id="NetTotalBadge" class="mb-0 text-success">@Model.NetTotal.ToString("0.00")</h3>
                            </div>

                            <div class="text-end small text-muted">
                                @if (Model.UpdatedAt.HasValue)
                                {
                                    <div>
                                        آخر تعديل:
                                        <span class="fw-semibold">
                                            @Model.UpdatedAt.Value.ToString("yyyy/MM/dd HH:mm")
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            @* =========================
               العمود الجانبي (أزرار الحركة)
               ========================= *@
            <div class="col-lg-2">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات مرتجع البيع</h6>
                    </div>
                    <div class="card-body d-grid">

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm"
                           asp-action="Create">
                            ➕ مرتجع جديد
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                id="btnSaveReturnHeader">
                            💾 حفظ المرتجع
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm"
                                id="btnClearReturnLines"
                                data-return-id="@Model.SRId">
                            🗑️ مسح كل أصناف المرتجع
                        </button>

                        <input type="number" id="NavReturnSearchInput" class="form-control form-control-sm mt-2" placeholder="بحث برقم المرتجع" />
                        <button type="button" class="btn btn-erp btn-erp-outline-primary btn-erp-sm" id="btnNavReturnSearch">بحث</button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                id="btnOpenReturn">
                            ⏪ فتح المرتجع
                        </button>

                        <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                           id="btnEditReturn"
                           asp-action="Edit"
                           asp-route-id="@Model.SRId">
                            ✏️ تعديل المرتجع
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                id="btnPostReturn">
                            📤 ترحيل المرتجع
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                onclick="window.print()">
                            🖨️ طباعة المرتجع
                        </button>

                        <hr />

                        <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                           asp-action="Index">
                            ⬅️ الرجوع لقائمة مرتجعات البيع
                        </a>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>

@section Scripts {
    <script>
        // دالة مساعدة: تملأ الحقول من option معين في الـ datalist
        function fillCustomerFromOption(opt) {
            var idInput = document.getElementById('CustomerId');              // كود العميل (للحفظ في المرتجع)
            var codeDisplay = document.getElementById('CustomerCodeDisplay'); // كود العميل المعروض
            var policyInput = document.getElementById('PolicyName');          // اسم السياسة (مش موجود على الشاشة هنا، لكن ممكن تضيفه بعدين)
            var userInput = document.getElementById('LinkedUserName');        // المستخدم المربوط (لو أضفته)
            var phoneInput = document.getElementById('CustomerPhone');        // الهاتف
            var addressInput = document.getElementById('CustomerAddress');    // العنوان
            var creditInput = document.getElementById('CustomerCreditLimit'); // الحد الائتماني
            var summary = document.getElementById('CustomerSummaryText');     // سطر ملخّص صغير

            if (!opt) {
                idInput.value = '';
                codeDisplay.value = '';
                if (policyInput) policyInput.value = '';
                if (userInput) userInput.value = '';
                phoneInput.value = '';
                addressInput.value = '';
                creditInput.value = '';
                summary.textContent = '';
                return;
            }

            var id = opt.getAttribute('data-id') || '';
            var policy = opt.getAttribute('data-policy') || '';
            var user = opt.getAttribute('data-user') || '';
            var phone = opt.getAttribute('data-phone') || '';
            var address = opt.getAttribute('data-address') || '';
            var credit = opt.getAttribute('data-credit') || '';

            idInput.value = id;
            codeDisplay.value = id;
            if (policyInput) policyInput.value = policy;
            if (userInput) userInput.value = user;
            phoneInput.value = phone;
            addressInput.value = address;
            creditInput.value = credit;

            var parts = [];
            if (policy) parts.push('سياسة: ' + policy);
            if (user) parts.push('مستخدم: ' + user);
            if (credit) parts.push('حد ائتماني: ' + credit);
            summary.textContent = parts.join(' — ');
        }

        document.addEventListener('DOMContentLoaded', function () {

            var customerInput = document.getElementById('CustomerNameInput');
            var dataList = document.getElementById('customersList');

            function findOptionByName(name) {
                if (!name) return null;
                var options = dataList.options;
                for (var i = 0; i < options.length; i++) {
                    if (options[i].value === name) return options[i];
                }
                return null;
            }

            function findOptionById(id) {
                if (!id) return null;
                var options = dataList.options;
                for (var i = 0; i < options.length; i++) {
                    if (options[i].getAttribute('data-id') == id) {
                        return options[i];
                    }
                }
                return null;
            }

            // عند اختيار اسم عميل من الأوتوكومبليت
            customerInput.addEventListener('change', function () {
                var opt = findOptionByName(customerInput.value);
                fillCustomerFromOption(opt);
            });

            // تهيئة الشاشة عند الفتح – لو في كود عميل محفوظ في المرتجع
            var initialCustomerId = '@Model.CustomerId';
            if (initialCustomerId) {
                var opt = findOptionById(initialCustomerId);
                if (opt) {
                    customerInput.value = opt.value;
                    fillCustomerFromOption(opt);
                }
            }

            // =========================================================
            // جلب أصناف فاتورة البيع عند إدخال رقم الفاتورة
            // =========================================================
            var invoiceIdInput = document.getElementById('SalesInvoiceIdInput');
            var invoiceIdHidden = document.getElementById('SalesInvoiceId');
            var itemSelect = document.getElementById('InvoiceItemSelect');
            var returnQtyInput = document.getElementById('ReturnQtyInput');
            var invoiceQtyDisplay = document.getElementById('InvoiceQtyDisplay');
            var returnBatchDisplay = document.getElementById('ReturnBatchDisplay');
            var returnExpiryDisplay = document.getElementById('ReturnExpiryDisplay');
            var btnAddReturnLine = document.getElementById('btnAddReturnLine');

            var invoiceItems = []; // متغير: قائمة أصناف الفاتورة

            // عند تغيير رقم الفاتورة
            invoiceIdInput.addEventListener('change', async function () {
                var invoiceId = parseInt(invoiceIdInput.value || '0', 10);
                
                if (invoiceId <= 0) {
                    invoiceIdHidden.value = '';
                    itemSelect.innerHTML = '<option value="">-- اختر صنف من الفاتورة --</option>';
                    invoiceItems = [];
                    return;
                }

                try {
                    var response = await fetch(`/SalesReturns/GetInvoiceItems?invoiceId=${invoiceId}`);
                    var data = await response.json();

                    if (!data.ok) {
                        alert(data.message || 'حدث خطأ في جلب بيانات الفاتورة.');
                        return;
                    }

                    // حفظ رقم الفاتورة
                    invoiceIdHidden.value = invoiceId.toString();

                    // تحديث العميل والمخزن إذا كانا فارغين
                    if (data.customerId && !document.getElementById('CustomerId').value) {
                        document.getElementById('CustomerId').value = data.customerId;
                        document.getElementById('CustomerCodeDisplay').value = data.customerId;
                    }

                    if (data.warehouseId && !document.getElementById('WarehouseId').value) {
                        document.getElementById('WarehouseId').value = data.warehouseId;
                    }

                    // تحديث قائمة الأصناف
                    invoiceItems = data.items || [];
                    itemSelect.innerHTML = '<option value="">-- اختر صنف من الفاتورة --</option>';
                    
                    invoiceItems.forEach(function(item, index) {
                        var option = document.createElement('option');
                        option.value = index.toString();
                        option.textContent = item.prodName + ' - كمية: ' + item.qty + ' - تشغيلة: ' + (item.batchNo || 'بدون');
                        option.setAttribute('data-prodId', item.prodId);
                        option.setAttribute('data-lineNo', item.lineNo);
                        option.setAttribute('data-qty', item.qty);
                        option.setAttribute('data-batchNo', item.batchNo || '');
                        option.setAttribute('data-expiry', item.expiry || '');
                        option.setAttribute('data-priceRetail', item.priceRetail);
                        itemSelect.appendChild(option);
                    });

                    // إعادة تعيين الحقول
                    returnQtyInput.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';

                } catch (error) {
                    console.error('Error loading invoice items:', error);
                    alert('حدث خطأ في جلب بيانات الفاتورة.');
                }
            });

            // عند اختيار صنف من القائمة
            itemSelect.addEventListener('change', function () {
                var selectedIndex = parseInt(itemSelect.value || '-1', 10);
                
                if (selectedIndex < 0 || selectedIndex >= invoiceItems.length) {
                    returnQtyInput.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';
                    return;
                }

                var item = invoiceItems[selectedIndex];
                invoiceQtyDisplay.value = item.qty;
                returnBatchDisplay.value = item.batchNo || '';
                returnExpiryDisplay.value = item.expiry || '';
                returnQtyInput.value = item.qty; // افتراضي: نفس كمية الفاتورة
                returnQtyInput.max = item.qty; // لا يمكن إرجاع أكثر من الكمية في الفاتورة
            });

            function refreshReturnLinesAndTotals(data) {
                var tbody = document.getElementById('SalesReturnLinesTableBody');
                var emptyRow = document.getElementById('SalesReturnLinesEmptyRow');
                if (!tbody) return;
                var lines = (data && data.lines) ? data.lines : [];
                var totals = (data && data.totals) ? data.totals : {};
                while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
                if (lines.length === 0) {
                    var tr = document.createElement('tr');
                    tr.id = 'SalesReturnLinesEmptyRow';
                    tr.innerHTML = '<td colspan="9" class="text-center text-muted py-4">لا توجد سطور مسجَّلة لهذا المرتجع.</td>';
                    tbody.appendChild(tr);
                } else {
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    var isPostedEl = document.getElementById('ReturnIsPostedDisplay');
                    var lockPosted = (isPostedEl && isPostedEl.value === 'نعم') ? '1' : '0';
                    lines.forEach(function(l) {
                        var tr = document.createElement('tr');
                        tr.setAttribute('data-line-no', l.lineNo);
                        tr.setAttribute('data-prodid', l.prodId);
                        var btn = '<button type="button" class="btn btn-danger btn-sm btnRemoveReturnLine" data-line-no="' + l.lineNo + '" data-sr-id="' + srId + '" data-lock-posted="' + lockPosted + '" title="مسح السطر">\uD83D\uDDD1</button>';
                        tr.innerHTML = '<td class="text-center">' + l.lineNo + '</td><td>' + (l.prodName || '') + '</td><td class="text-center">' + l.qty + '</td><td class="text-center">' + (l.priceRetail != null ? Number(l.priceRetail).toFixed(2) : '') + '</td><td class="text-center">' + (l.disc1Percent != null ? Number(l.disc1Percent).toFixed(2) : '') + '</td><td class="text-center">0</td><td class="text-center">0</td><td class="text-center">' + (l.lineNetTotal != null ? Number(l.lineNetTotal).toFixed(2) : '') + '</td><td class="text-center">' + btn + '</td>';
                        tbody.appendChild(tr);
                    });
                }
                var bid = document.getElementById('TotalBeforeDiscountBadge');
                if (bid && totals.totalBeforeDiscount != null) bid.textContent = Number(totals.totalBeforeDiscount).toFixed(2);
                bid = document.getElementById('TotalAfterDiscountBeforeTaxBadge');
                if (bid && totals.totalAfterDiscountBeforeTax != null) bid.textContent = Number(totals.totalAfterDiscountBeforeTax).toFixed(2);
                bid = document.getElementById('TaxAmountBadge');
                if (bid && totals.taxAmount != null) bid.textContent = Number(totals.taxAmount).toFixed(2);
                bid = document.getElementById('NetTotalBadge');
                if (bid && totals.netTotal != null) bid.textContent = Number(totals.netTotal).toFixed(2);
            }

            // عند إضافة سطر للمرتجع
            btnAddReturnLine.addEventListener('click', async function () {
                var selectedIndex = parseInt(itemSelect.value || '-1', 10);
                var returnQty = parseInt(returnQtyInput.value || '0', 10);
                var returnId = parseInt(document.getElementById('SRId').value || '0', 10);

                if (selectedIndex < 0 || selectedIndex >= invoiceItems.length) {
                    alert('من فضلك اختر صنف من الفاتورة.');
                    return;
                }
                if (returnQty <= 0) {
                    alert('الكمية المرتجعة يجب أن تكون أكبر من صفر.');
                    return;
                }
                var item = invoiceItems[selectedIndex];
                if (returnQty > item.qty) {
                    alert('الكمية المرتجعة لا يمكن أن تكون أكبر من الكمية في الفاتورة (' + item.qty + ').');
                    return;
                }
                if (returnId <= 0) {
                    alert('يجب حفظ المرتجع أولاً قبل إضافة الأصناف.');
                    return;
                }

                var salesInvoiceId = parseInt(document.getElementById('SalesInvoiceId').value || '0', 10) || null;
                var dto = { SRId: returnId, ProdId: item.prodId, Qty: returnQty, BatchNo: item.batchNo || null, ExpiryText: item.expiry || null, PriceRetail: item.priceRetail || 0, Disc1Percent: item.disc1Percent != null ? item.disc1Percent : 0, SalesInvoiceId: salesInvoiceId, SalesInvoiceLineNo: item.lineNo };
                btnAddReturnLine.disabled = true;
                try {
                    var res = await fetch('@Url.Action("AddLineJson", "SalesReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dto) });
                    var txt = await res.text();
                    var data = null;
                    if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                    if (!res.ok || !data || !data.ok) {
                        alert((data && data.message) ? data.message : 'فشل إضافة السطر.');
                        return;
                    }
                    refreshReturnLinesAndTotals(data);
                    returnQtyInput.value = '';
                    itemSelect.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';
                } catch (e) {
                    console.error(e);
                    alert('حدث خطأ أثناء إضافة السطر.');
                } finally {
                    btnAddReturnLine.disabled = false;
                }
            });

            // تهيئة رقم الفاتورة إذا كان موجوداً
            var initialInvoiceId = '@(Model.SalesInvoiceId?.ToString() ?? "")';
            if (initialInvoiceId) {
                invoiceIdInput.value = initialInvoiceId;
                invoiceIdInput.dispatchEvent(new Event('change'));
            }

            // =========================================================
            // زر حفظ المرتجع (SaveHeader) — يحفظ الهيدر ويسجّل رقم المرتجع
            // =========================================================
            var btnSaveReturn = document.getElementById('btnSaveReturnHeader');
            var editBaseUrl = '@Url.Action("Edit", "SalesReturns")';
            if (btnSaveReturn) {
                btnSaveReturn.addEventListener('click', async function () {
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    var customerId = parseInt(document.getElementById('CustomerId').value || '0', 10);
                    var warehouseId = parseInt(document.getElementById('WarehouseId').value || '0', 10);
                    var salesInvoiceIdInput = document.getElementById('SalesInvoiceId');
                    var salesInvoiceId = 0;
                    if (salesInvoiceIdInput && salesInvoiceIdInput.value.trim() !== '') {
                        var v = parseInt(salesInvoiceIdInput.value.trim(), 10);
                        if (!isNaN(v)) salesInvoiceId = v;
                    }

                    if (!customerId || !warehouseId) {
                        alert('من فضلك اختر العميل والمخزن أولاً قبل حفظ المرتجع.');
                        return;
                    }

                    var dto = { srId: srId, customerId: customerId, warehouseId: warehouseId, salesInvoiceId: salesInvoiceId || null };
                    btnSaveReturn.disabled = true;
                    try {
                        var response = await fetch('@Url.Action("SaveHeader", "SalesReturns")', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(dto)
                        });
                        var txt = await response.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!response.ok) {
                            alert((data && data.message) ? data.message : 'حدث خطأ أثناء حفظ المرتجع.');
                            return;
                        }
                        if (!data || !data.success) {
                            alert((data && data.message) ? data.message : 'تعذر حفظ المرتجع.');
                            return;
                        }
                        var newId = data.srId || 0;
                        document.getElementById('SRId').value = newId.toString();
                        var dateEl = document.getElementById('ReturnDateDisplay');
                        var timeEl = document.getElementById('ReturnTimeDisplay');
                        if (dateEl && data.returnDate) dateEl.value = data.returnDate;
                        if (timeEl && data.returnTime) timeEl.value = data.returnTime;
                        var editLink = document.getElementById('btnEditReturn');
                        if (editLink) editLink.href = editBaseUrl + '/' + newId;
                        var clearBtn = document.getElementById('btnClearReturnLines');
                        if (clearBtn) clearBtn.setAttribute('data-return-id', newId.toString());
                        var numDisp = document.getElementById('ReturnNumberDisplay');
                        if (numDisp) numDisp.value = newId.toString();
                        alert('تم حفظ المرتجع بنجاح. رقم المرتجع: ' + newId);
                        var prodSelect = document.getElementById('InvoiceItemSelect');
                        if (prodSelect) { prodSelect.focus(); prodSelect.click(); }
                    } catch (err) {
                        console.error(err);
                        alert('تعذر الاتصال بالخادم لحفظ المرتجع.');
                    } finally {
                        btnSaveReturn.disabled = false;
                    }
                });
            }

            // مسح السطر
            document.addEventListener('click', async function(ev) {
                var btn = ev.target.closest('.btnRemoveReturnLine');
                if (!btn) return;
                ev.preventDefault();
                var srId = parseInt(btn.getAttribute('data-sr-id') || '0', 10);
                var lineNo = parseInt(btn.getAttribute('data-line-no') || '0', 10);
                if (srId <= 0 || lineNo <= 0) return;
                var isPostedEl = document.getElementById('ReturnIsPostedDisplay');
                if (isPostedEl && isPostedEl.value === 'نعم') { alert('المرتجع مترحّل. استخدم "فتح المرتجع" أولاً.'); return; }
                if (!confirm('هل تريد مسح هذا السطر؟')) return;
                btn.disabled = true;
                try {
                    var res = await fetch('@Url.Action("RemoveLineJson", "SalesReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ SRId: srId, LineNo: lineNo }) });
                    var txt = await res.text();
                    var data = null;
                    if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                    if (!res.ok || !data || !data.ok) { alert((data && data.message) ? data.message : 'فشل مسح السطر.'); return; }
                    refreshReturnLinesAndTotals(data);
                } catch (e) { console.error(e); alert('حدث خطأ أثناء مسح السطر.'); }
                finally { btn.disabled = false; }
            });

            // مسح كل أصناف المرتجع
            var btnClear = document.getElementById('btnClearReturnLines');
            if (btnClear) {
                btnClear.addEventListener('click', async function() {
                    var srId = parseInt(document.getElementById('SRId').value || btnClear.getAttribute('data-return-id') || '0', 10);
                    if (srId <= 0) { alert('يجب حفظ المرتجع أولاً.'); return; }
                    if (!confirm('هل تريد مسح كل أصناف المرتجع؟')) return;
                    btnClear.disabled = true;
                    try {
                        var res = await fetch('@Url.Action("ClearLinesJson", "SalesReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ SRId: srId }) });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) { alert((data && data.message) ? data.message : 'فشل مسح الأصناف.'); return; }
                        refreshReturnLinesAndTotals(data);
                        var isPostedEl = document.getElementById('ReturnIsPostedDisplay');
                        if (isPostedEl) isPostedEl.value = 'لا';
                    } catch (e) { console.error(e); alert('حدث خطأ.'); }
                    finally { btnClear.disabled = false; }
                });
            }

            // ترحيل المرتجع
            var btnPost = document.getElementById('btnPostReturn');
            if (btnPost) {
                btnPost.addEventListener('click', async function() {
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    if (srId <= 0) { alert('يجب حفظ المرتجع أولاً قبل الترحيل.'); return; }
                    if (!confirm('هل تريد ترحيل هذا المرتجع؟')) return;
                    btnPost.disabled = true;
                    try {
                        var res = await fetch('@Url.Action("PostReturn", "SalesReturns")?id=' + srId, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) { alert((data && data.message) ? data.message : 'فشل الترحيل.'); return; }
                        var isPostedEl = document.getElementById('ReturnIsPostedDisplay');
                        if (isPostedEl) isPostedEl.value = 'نعم';
                        var statusEl = document.getElementById('ReturnStatusDisplay');
                        if (statusEl) statusEl.value = 'Posted';
                        alert('تم ترحيل المرتجع بنجاح.');
                    } catch (e) { console.error(e); alert('حدث خطأ.'); }
                    finally { btnPost.disabled = false; }
                });
            }

            // فتح المرتجع (إلغاء الترحيل)
            var btnOpen = document.getElementById('btnOpenReturn');
            if (btnOpen) {
                btnOpen.addEventListener('click', async function() {
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    if (srId <= 0) { alert('اختر مرتجعاً أولاً.'); return; }
                    if (!confirm('هل تريد فتح المرتجع (إلغاء الترحيل)؟')) return;
                    btnOpen.disabled = true;
                    try {
                        var res = await fetch('@Url.Action("OpenReturn", "SalesReturns")?id=' + srId, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) { alert((data && data.message) ? data.message : 'فشل فتح المرتجع.'); return; }
                        var isPostedEl = document.getElementById('ReturnIsPostedDisplay');
                        if (isPostedEl) isPostedEl.value = 'لا';
                        var statusEl = document.getElementById('ReturnStatusDisplay');
                        if (statusEl) statusEl.value = 'Draft';
                        alert('تم فتح المرتجع للتعديل.');
                    } catch (e) { console.error(e); alert('حدث خطأ.'); }
                    finally { btnOpen.disabled = false; }
                });
            }

            // بحث برقم المرتجع
            var navSearchInput = document.getElementById('NavReturnSearchInput');
            var btnNavSearch = document.getElementById('btnNavReturnSearch');
            if (navSearchInput && btnNavSearch) {
                function doNavSearch() {
                    var v = parseInt((navSearchInput.value || '').trim(), 10);
                    if (!v || v <= 0) return;
                    window.location.href = '@Url.Action("Edit", "SalesReturns")/' + v;
                }
                btnNavSearch.addEventListener('click', doNavSearch);
                navSearchInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); doNavSearch(); } });
            }
        });
    </script>
}
