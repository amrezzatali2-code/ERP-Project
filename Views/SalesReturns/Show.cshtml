                    function findProductByName(name) {
                        var raw = (name || '').trim();
                        var search = normalizeText(raw);
                        if (!search) return null;
                        var opts = prodDataList.options;
                        for (var i = 0; i < opts.length; i++) {
                            if (normalizeText(opts[i].value) === search) return opts[i];
                        }
                        for (var j = 0; j < opts.length; j++) {
                            if ((opts[j].value || '').trim() === raw) return opts[j];
                        }
                        return null;
                    }
                    function findProductByCode(code) {
                        var search = (code || '').toString().trim();
                        if (!search) return null;
                        var opts = prodDataList.options;
                        for (var i = 0; i < opts.length; i++) {
                            var idAttr = (opts[i].getAttribute('data-id') || '').toString();
                            var codeAttr = (opts[i].getAttribute('data-code') || '').toString();
                            if (idAttr === search || codeAttr === search) return opts[i];
                        }
                        return null;
                    }
                    function getProductDropdownFilterQuery(rawTrim) {
                        var raw = (rawTrim || '').trim();
                        if (!raw || !prodDataList || !prodDataList.options) return raw;
                        var nRaw = normalizeText(raw);
                        var canonical = '';
                        var opts = prodDataList.options;
                        for (var i = 0; i < opts.length; i++) {
                            var v = (opts[i].value || '').trim();
                            if (!v) continue;
                            if (v === raw) { canonical = v; break; }
                            if (nRaw && normalizeText(v) === nRaw) { canonical = v; break; }
                        }
                        if (!canonical) return raw;
                        var parts = canonical.split(/\s+/).filter(Boolean);
                        return parts[0] || raw;
                    }
                    function getFilteredProductOptions(search, max, pinDisplayName) {
                        if (!prodDataList || !prodDataList.options) return [];
                        var limit = max || PRODUCT_LIST_MAX;
                        var opts = prodDataList.options;
                        var rawTrim = (search || '').trim();
                        if (!rawTrim) {
                            var out0 = [];
                            for (var a = 0; a < opts.length && out0.length < limit; a++) out0.push(opts[a]);
                            return out0;
                        }
                        var qNorm = normalizeText(rawTrim);
                        var words = rawTrim.split(/\s+/).filter(Boolean);
                        var matched = [];
                        for (var i = 0; i < opts.length; i++) {
                            var opt = opts[i];
                            var nameVal = (opt.value || '').trim();
                            var code = (opt.getAttribute('data-code') || '').toString().trim();
                            var idAttr = (opt.getAttribute('data-id') || '').toString().trim();
                            var barcode = normalizeDigits((opt.getAttribute('data-barcode') || '').toString().trim());
                            var codeOrId = code || idAttr;
                            var nameOk = qNorm ? productNameMatchesSearch(nameVal, rawTrim) : true;
                            var idOk = words.length > 0 && words.some(function (w) {
                                var wn = normalizeDigits(w);
                                return codeOrId.indexOf(wn) !== -1 || barcode.indexOf(wn) !== -1;
                            });
                            var codeRawOk = codeOrId && codeOrId.indexOf(rawTrim) !== -1;
                            var barRaw = barcode && (barcode.indexOf(normalizeDigits(rawTrim)) !== -1);
                            if (nameOk || idOk || codeRawOk || barRaw) matched.push(opt);
                        }
                        matched.sort(function (a, b) {
                            var ra = productSearchRank((a.value || '').trim(), rawTrim);
                            var rb = productSearchRank((b.value || '').trim(), rawTrim);
                            if (ra !== rb) return ra - rb;
                            return (a.value || '').localeCompare(b.value || '', 'ar');
                        });
                        var result = matched.slice(0, limit);
                        var pinRaw = (pinDisplayName || '').trim();
                        if (pinRaw) {
                            var nPin = normalizeText(pinRaw);
                            var pinOpt = null;
                            for (var j = 0; j < opts.length; j++) {
                                var v2 = (opts[j].value || '').trim();
                                if (v2 === pinRaw || (nPin && normalizeText(v2) === nPin)) { pinOpt = opts[j]; break; }
                            }
                            if (pinOpt && matched.indexOf(pinOpt) >= 0) {
                                var inResult = result.some(function (o) { return o === pinOpt; });
                                if (!inResult) {
                                    result = matched.slice(0, limit - 1);
                                    result.push(pinOpt);
                                }
                            }
                        }
                        return result;
                    }

                    function fillStandaloneProductFromOption(opt) {
                        if (!opt) {
                            if (prodHiddenId) prodHiddenId.value = '';
                            prodNameInput.value = '';
                            if (prodPriceEl) prodPriceEl.value = '0';
                            return;
                        }
                        var id = (opt.getAttribute('data-id') || '').toString();
                        var price = opt.getAttribute('data-price');
                        if (prodHiddenId) prodHiddenId.value = id;
                        prodNameInput.value = (opt.value || '').trim();
                        if (prodPriceEl) {
                            var n = parseFloat((price || '0').toString().replace(',', '.'));
                            prodPriceEl.value = (isNaN(n) ? 0 : n).toFixed(2);
                        }
                    }
                    function selectBestStandaloneProductFromSearch() {
                        var searchTerm = (prodNameInput.value || '').trim();
                        var filterQuery = getProductDropdownFilterQuery(searchTerm);
                        var list = getFilteredProductOptions(filterQuery, 1, searchTerm);
                        if (list && list.length > 0) {
                            fillStandaloneProductFromOption(list[0]);
                            return true;
                        }
                        return false;
                    }
                    window.__srResolveStandaloneProductSelection = function () {
                        var currentId = (prodHiddenId && prodHiddenId.value) ? prodHiddenId.value.toString().trim() : '';
                        var opt = currentId ? findProductByCode(currentId) : null;
                        if (!opt && prodNameInput) {
                            opt = findProductByName(prodNameInput.value);
                        }
                        if (opt) {
                            fillStandaloneProductFromOption(opt);
                            return true;
                        }
                        return false;
                    };
                    window.__srGetStandaloneResolvedPrice = function () {
                        var currentId = (prodHiddenId && prodHiddenId.value) ? prodHiddenId.value.toString().trim() : '';
                        var opt = currentId ? findProductByCode(currentId) : null;
                        if (!opt && prodNameInput) {
                            opt = findProductByName(prodNameInput.value);
                        }
                        if (!opt) return 0;
                        var price = opt.getAttribute('data-price');
                        var n = parseFloat((price || '0').toString().replace(',', '.'));
                        return isNaN(n) ? 0 : n;
                    };

                    var productDropdownHighlightedIndex = -1;
                    var productDropdownSelectableItems = [];

                    function positionStandaloneProductDropdownList() {
                        if (!productDropdownList || !productDropdownWrap) return;
                        if (productDropdownList.getAttribute('data-open') !== 'true') return;
                        var r = productDropdownWrap.getBoundingClientRect();
                        productDropdownList.style.width = r.width + 'px';
                        productDropdownList.style.top = r.bottom + 'px';
                        productDropdownList.style.left = r.left + 'px';
                    }
                    function closeStandaloneProductDropdown() {
                        if (productDropdownList) {
                            productDropdownList.setAttribute('data-open', 'false');
                            productDropdownList.innerHTML = '';
                        }
                        productDropdownHighlightedIndex = -1;
                        productDropdownSelectableItems = [];
                    }
                    function setStandaloneProductDropdownHighlight(idx) {
                        if (idx < 0 || idx >= productDropdownSelectableItems.length) return;
                        productDropdownSelectableItems.forEach(function (el, i) {
                            el.classList.toggle('product-dropdown-item-active', i === idx);
                        });
                        productDropdownHighlightedIndex = idx;
                        try { productDropdownSelectableItems[idx].scrollIntoView({ block: 'nearest', behavior: 'smooth' }); } catch (e2) { }
                    }
                    function openStandaloneProductDropdown() {
                        if (!productDropdownList || !productDropdownWrap || !prodNameInput) return;
                        var searchTerm = (prodNameInput.value || '').trim();
                        var filterQuery = getProductDropdownFilterQuery(searchTerm);
                        var list = getFilteredProductOptions(filterQuery, PRODUCT_LIST_MAX, searchTerm);
                        productDropdownList.innerHTML = '';
                        productDropdownSelectableItems = [];
                        var currentVal = (prodNameInput.value || '').trim();
                        var highlightIdx = 0;
                        if (list.length > 0) {
                            for (var h = 0; h < list.length; h++) {
                                if (normalizeText((list[h].value || '').trim()) === normalizeText(currentVal)) { highlightIdx = h; break; }
                            }
                        }
                        if (list.length === 0) {
                            var empty = document.createElement('div');
                            empty.className = 'product-dropdown-item text-muted py-2 px-3 small';
                            empty.textContent = prodNameInput.value ? 'لا توجد نتائج' : ('اكتب للبحث ثم انزل بالسهم ▼ واختر (' + PRODUCT_LIST_MAX + ' كحد أقصى)');
                            productDropdownList.appendChild(empty);
                        } else {
                            list.forEach(function (opt, idx) {
                                var id = (opt.getAttribute('data-id') || '').toString();
                                var name = (opt.value || '').trim();
                                var it = document.createElement('div');
                                it.className = 'product-dropdown-item py-2 px-3' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                                it.setAttribute('role', 'option');
                                it.setAttribute('data-id', id);
                                it.textContent = name;
                                it.addEventListener('click', function (e) {
                                    e.preventDefault();
                                    var o = findProductByCode(id);
                                    if (o) fillStandaloneProductFromOption(o);
                                    closeStandaloneProductDropdown();
                                    var qEl = document.getElementById('srStandaloneQtyInput');
                                    if (qEl) qEl.focus();
                                });
                                productDropdownList.appendChild(it);
                                productDropdownSelectableItems.push(it);
                            });
                            productDropdownHighlightedIndex = highlightIdx;
                        }
                        productDropdownList.setAttribute('data-open', 'true');
                        positionStandaloneProductDropdownList();
                    }
                    function selectHighlightedStandaloneProduct() {
                        if (productDropdownHighlightedIndex < 0 || productDropdownHighlightedIndex >= productDropdownSelectableItems.length) return false;
                        var el = productDropdownSelectableItems[productDropdownHighlightedIndex];
                        var id = el.getAttribute('data-id');
                        var o = findProductByCode(id);
                        if (o) fillStandaloneProductFromOption(o);
                        closeStandaloneProductDropdown();
                        var qEl2 = document.getElementById('srStandaloneQtyInput');
                        if (qEl2) qEl2.focus();
                        return true;
                    }

                    prodNameInput.addEventListener('input', function () { openStandaloneProductDropdown(); });
                    if (productDropdownWrap && !productDropdownWrap.dataset.boundSrProdDropdownClick) {
                        productDropdownWrap.dataset.boundSrProdDropdownClick = '1';
                        productDropdownWrap.addEventListener('click', function (ev) {
                            if (ev.target && ev.target.closest('#srStandaloneProductDropdownList')) return;
                        });
                    }
                    document.body.addEventListener('click', function (ev) {
                        if (!productDropdownWrap) return;
                        if (!productDropdownWrap.contains(ev.target)) closeStandaloneProductDropdown();
                    });
                    if (productDropdownArrow) {
                        productDropdownArrow.addEventListener('click', function (ev) {
                            ev.preventDefault();
                            prodNameInput.focus();
                            openStandaloneProductDropdown();
                        });
                    }
                    prodNameInput.addEventListener('keydown', function (e) {
                        var isOpen = productDropdownList && productDropdownList.getAttribute('data-open') === 'true';
                        if (e.key === 'ArrowDown') {
                            e.preventDefault();
                            if (!isOpen) openStandaloneProductDropdown();
                            if (productDropdownSelectableItems.length > 0) {
                                var next = Math.min(productDropdownHighlightedIndex + 1, productDropdownSelectableItems.length - 1);
                                setStandaloneProductDropdownHighlight(next < 0 ? 0 : next);
                            }
                            return;
                        }
                        if (e.key === 'ArrowUp') {
                            e.preventDefault();
                            if (!isOpen) openStandaloneProductDropdown();
                            if (productDropdownSelectableItems.length > 0) {
                                var prev = Math.max(productDropdownHighlightedIndex - 1, 0);
                                setStandaloneProductDropdownHighlight(prev);
                            }
                            return;
                        }
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            if (isOpen && productDropdownHighlightedIndex >= 0 && productDropdownSelectableItems.length > 0) {
                                selectHighlightedStandaloneProduct();
                                return;
                            }
                            var selected = selectBestStandaloneProductFromSearch();
                            if (!selected) {
                                var fo = findProductByName(prodNameInput.value);
                                fillStandaloneProductFromOption(fo);
                            }
                            var qInp = document.getElementById('srStandaloneQtyInput');
                            if (qInp) qInp.focus();
                        }
                    });
                    prodNameInput.addEventListener('blur', function () {
                        setTimeout(function () {
                            try {
                                closeStandaloneProductDropdown();
                                var fo2 = findProductByName(prodNameInput.value);
                                fillStandaloneProductFromOption(fo2);
                            } catch (ex2) { }
                        }, 150);
                    });

                    document.body.addEventListener('change', function (ev) {
                        var t = ev.target;
                        if (t && t.id === 'WarehouseId' && typeof window.__srRefreshStandaloneProducts === 'function') {
                            window.__srRefreshStandaloneProducts();
                        }
                    });

                    refreshSrStandaloneProductsDatalist();
                })();
            }

            function applySrModeUi() {
                if (srAllowStandalone !== true) return;
                var st = isStandaloneMode();
                var invPanel = document.getElementById('srInvoiceAddPanel');
                var stPanel = document.getElementById('srStandaloneAddPanel');
                var invInput = document.getElementById('SalesInvoiceIdInput');
                var invHid = document.getElementById('SalesInvoiceId');
                if (invPanel) invPanel.classList.toggle('d-none', st);
                if (stPanel) stPanel.classList.toggle('d-none', !st);
                if (invInput) {
                    invInput.disabled = !!st;
                    if (st) {
                        invInput.value = '';
                        if (invHid) invHid.value = '';
                    }
                }
                if (st && itemSelect) {
                    itemSelect.innerHTML = '<option value="">-- اختر صنف من الفاتورة --</option>';
                    invoiceItems = [];
                }
                if (st && returnQtyInput) returnQtyInput.removeAttribute('max');
                if (st && typeof window.__srRefreshStandaloneProducts === 'function') {
                    window.__srRefreshStandaloneProducts();
                }
            }

            var chkStandalone = document.getElementById('srChkStandalone');
            if (chkStandalone) {
                chkStandalone.addEventListener('change', function () { applySrModeUi(); });
                applySrModeUi();
            }

            function invoiceItemDisplayCode(item) {
                if (!item) return '';
                var ext = item.externalCode != null ? String(item.externalCode).trim() : '';
                if (ext) return ext;
                return item.prodId != null ? String(item.prodId) : '';
            }

            async function loadInvoiceByNumber() {
                if (isStandaloneMode()) {
                    return false;
                }

                var invoiceId = parseInt(invoiceIdInput.value || '0', 10);

                if (invoiceId <= 0) {
                    invoiceIdHidden.value = '';
                    itemSelect.innerHTML = '<option value="">-- اختر صنف من الفاتورة --</option>';
                    invoiceItems = [];
                    var pce = document.getElementById('InvoiceItemProdCodeDisplay');
                    if (pce) pce.value = '';
                    return false;
                }

                try {
                    var url = srGetInvoiceItemsUrl + '?invoiceId=' + encodeURIComponent(String(invoiceId));
                    var response = await fetch(url, { method: 'GET', credentials: 'same-origin', headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } });
                    var ct = (response.headers.get('content-type') || '').toLowerCase();
                    var raw = await response.text();
                    var data = null;
                    try {
                        data = raw ? JSON.parse(raw) : null;
                    } catch (parseErr) {
                        console.error('GetInvoiceItems: non-JSON response', parseErr, raw ? raw.substring(0, 200) : '');
                        alert('تعذر قراءة بيانات الفاتورة (الاستجابة ليست بصيغة متوقعة). تأكد من الصلاحيات أو حدّث الصفحة.');
                        return false;
                    }

                    // الخادم يُرجع PascalCase (Program.cs: PropertyNamingPolicy = null)
                    var apiOk = data && (data.ok === true || data.Ok === true);
                    var apiMsg = (data && (data.message || data.Message)) ? String(data.message || data.Message) : '';

                    if (!response.ok || !data) {
                        alert(apiMsg || ('طلب الفاتورة فشل (' + response.status + ').'));
                        return false;
                    }

                    if (!apiOk) {
                        alert(apiMsg || 'حدث خطأ في جلب بيانات الفاتورة.');
                        return false;
                    }

                    // حفظ رقم الفاتورة
                    invoiceIdHidden.value = invoiceId.toString();

                    var custId = data.customerId != null ? data.customerId : data.CustomerId;
                    var whId = data.warehouseId != null ? data.warehouseId : data.WarehouseId;
                    var itemsPayload = data.items != null ? data.items : (data.Items != null ? data.Items : []);

                    // تحديث بيانات العميل بالكامل حسب الفاتورة (الاسم، الهاتف، العنوان، إلخ)
                    if (custId) {
                        var idEl = document.getElementById('CustomerId');
                        var codeEl = document.getElementById('CustomerCodeDisplay');
                        if (idEl) idEl.value = custId;
                        if (codeEl) codeEl.value = custId;
                        var opt = findCustomerDatalistOptionById(String(custId));
                        var nameInput = document.getElementById('CustomerNameInput');
                        if (opt && nameInput) {
                            nameInput.value = opt.value;
                            fillCustomerFromOption(opt);
                        }
                    }

                    if (whId) {
                        document.getElementById('WarehouseId').value = whId;
                    }

                    // تحديث قائمة الأصناف
                    invoiceItems = itemsPayload || [];
                    if (!itemSelect) {
                        console.error('loadInvoiceByNumber: InvoiceItemSelect غير موجود');
                        return false;
                    }
                    itemSelect.innerHTML = '<option value="">-- اختر صنف من الفاتورة --</option>';

                    invoiceItems.forEach(function(item, index) {
                        var option = document.createElement('option');
                        option.value = index.toString();
                        var remaining = (item.remaining != null) ? item.remaining : (item.qty - (item.alreadyReturned || 0));
                        option.textContent = (item.prodName && String(item.prodName).trim()) ? String(item.prodName).trim() : ('صنف #' + item.prodId);
                        option.setAttribute('data-prodId', item.prodId);
                        option.setAttribute('data-lineNo', item.lineNo);
                        option.setAttribute('data-qty', item.qty);
                        option.setAttribute('data-remaining', remaining);
                        option.setAttribute('data-batchNo', item.batchNo || '');
                        option.setAttribute('data-expiry', item.expiry || '');
                        option.setAttribute('data-priceRetail', item.priceRetail);
                        option.setAttribute('data-prod-code', invoiceItemDisplayCode(item));
                        itemSelect.appendChild(option);
                    });

                    // إعادة تعيين الحقول
                    returnQtyInput.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';
                    var prodCodeEl = document.getElementById('InvoiceItemProdCodeDisplay');
                    if (prodCodeEl) prodCodeEl.value = '';

                    return true;
                } catch (error) {
                    console.error('Error loading invoice items:', error);
                    alert('حدث خطأ في جلب بيانات الفاتورة.');
                    return false;
                }
            }

            // Enter في حقل رقم الفاتورة: جلب البيانات ثم نقل التركيز إلى زر الحفظ (الإنتر التالي يفعّل الحفظ ثم ينتقل للأصناف كما في سكربت الحفظ)
            invoiceIdInput.addEventListener('keydown', async function (e) {
                if (e.key !== 'Enter') return;
                e.preventDefault();
                var ok = await loadInvoiceByNumber();
                if (!ok) return;
                var btnSave = document.getElementById('btnSaveReturnHeader');
                if (btnSave && !btnSave.disabled) btnSave.focus();
            });

            // عند تغيير رقم الفاتورة (فقدان التركيز)
            invoiceIdInput.addEventListener('change', loadInvoiceByNumber);

            // عند اختيار صنف من القائمة
            itemSelect.addEventListener('change', function () {
                var selectedIndex = parseInt(itemSelect.value || '-1', 10);
                var prodCodeDisplay = document.getElementById('InvoiceItemProdCodeDisplay');

                if (selectedIndex < 0 || selectedIndex >= invoiceItems.length) {
                    returnQtyInput.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';
                    if (prodCodeDisplay) prodCodeDisplay.value = '';
                    return;
                }

                var item = invoiceItems[selectedIndex];
                if (prodCodeDisplay) prodCodeDisplay.value = invoiceItemDisplayCode(item);
                var remaining = (item.remaining != null) ? item.remaining : (item.qty - (item.alreadyReturned || 0));
                invoiceQtyDisplay.value = item.qty;
                returnBatchDisplay.value = item.batchNo || '';
                returnExpiryDisplay.value = item.expiry || '';
                returnQtyInput.max = remaining; // لا يمكن إرجاع أكثر من المتبقي (بعد خصم المرتجعات السابقة)
                returnQtyInput.value = remaining > 0 ? Math.min(remaining, parseInt(returnQtyInput.value || '0', 10) || remaining) : 0;
                if (remaining <= 0) returnQtyInput.value = '0';
            });

            // =========================================================
            // الانتقال بانتر (مثل فاتورة المبيعات): صنف → كمية → إضافة
            // =========================================================
            var enterFields = [itemSelect, returnQtyInput];
            enterFields.forEach(function (el) {
                if (!el) return;
                if (el.dataset.enterBound === '1') return;
                el.dataset.enterBound = '1';
                el.addEventListener('focus', function () {
                    if (typeof this.select === 'function') setTimeout(function () { el.select(); }, 0);
                });
                el.addEventListener('keydown', function (e) {
                    if (e.key !== 'Enter') return;
                    e.preventDefault();
                    var idx = enterFields.indexOf(el);
                    var next = enterFields[idx + 1];
                    if (next) {
                        next.focus();
                        if (next.select) next.select();
                    } else if (btnAddReturnLine) {
                        btnAddReturnLine.focus();
                    }
                });
            });
            if (btnAddReturnLine && !btnAddReturnLine.dataset.enterClickBound) {
                btnAddReturnLine.dataset.enterClickBound = '1';
                btnAddReturnLine.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        btnAddReturnLine.click();
                    }
                });
            }

            function srEscapeHtml(s) {
                if (s == null || s === '') return '';
                var d = document.createElement('div');
                d.textContent = s;
                return d.innerHTML;
            }

            function refreshReturnLinesAndTotals(data) {
                var tbody = document.getElementById('SalesReturnLinesTableBody');
                if (!tbody) return;
                var lines = (data && data.lines) ? data.lines : [];
                var totals = (data && data.totals) ? data.totals : {};
                while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
                if (lines.length === 0) {
                    var trEmpty = document.createElement('tr');
                    trEmpty.id = 'SalesReturnLinesEmptyRow';
                    trEmpty.innerHTML = '<td colspan="9" class="text-center text-muted py-4">لا توجد سطور مسجَّلة لهذا المرتجع.</td>';
                    tbody.appendChild(trEmpty);
                } else {
                    lines.forEach(function(l) {
                        var tr = document.createElement('tr');
                        tr.className = 'erp-list-selectable-row';
                        tr.setAttribute('data-line-no', l.lineNo);
                        tr.setAttribute('data-prodid', l.prodId);
                        var loc = srEscapeHtml((l.location != null && String(l.location).trim() !== '') ? String(l.location).trim() : '—');
                        var pn = srEscapeHtml((l.prodName && String(l.prodName).trim()) ? String(l.prodName).trim() : ('صنف #' + l.prodId));
                        var batch = srEscapeHtml(l.batchNo != null ? String(l.batchNo) : '');
                        var exp = srEscapeHtml(l.expiry != null ? String(l.expiry) : '');
                        var lineVal = (l.lineTotalAfterDiscount != null) ? Number(l.lineTotalAfterDiscount).toFixed(2) : (l.lineNetTotal != null ? Number(l.lineNetTotal).toFixed(2) : '');
                        tr.innerHTML =
                            '<td class="text-center">' + l.lineNo + '</td>' +
                            '<td class="text-center text-muted small">' + loc + '</td>' +
                            '<td><strong>' + pn + '</strong><span class="text-muted small"> | كود: ' + l.prodId + '</span></td>' +
                            '<td class="text-center">' + batch + '</td>' +
                            '<td class="text-center">' + exp + '</td>' +
                            '<td class="text-center">' + l.qty + '</td>' +
                            '<td class="text-center">' + (l.priceRetail != null ? Number(l.priceRetail).toFixed(2) : '') + '</td>' +
                            '<td class="text-center">' + (l.disc1Percent != null ? Number(l.disc1Percent).toFixed(2) : '') + '</td>' +
                            '<td class="text-center">' + lineVal + '</td>';
                        tbody.appendChild(tr);
                    });
                }
                var bid = document.getElementById('TotalBeforeTaxBadge');
                if (bid && totals.totalAfterDiscountBeforeTax != null) bid.textContent = Number(totals.totalAfterDiscountBeforeTax).toFixed(2);
                bid = document.getElementById('TaxAmountBadge');
                if (bid && totals.taxAmount != null) bid.textContent = Number(totals.taxAmount).toFixed(2);
                bid = document.getElementById('NetTotalBadge');
                if (bid && totals.netTotal != null) bid.textContent = Number(totals.netTotal).toFixed(2);
                syncDeleteSelectedReturnLineButton();
            }

            // عند إضافة سطر للمرتجع (من فاتورة)
            if (btnAddReturnLine) btnAddReturnLine.addEventListener('click', async function () {
                if (isStandaloneMode()) {
                    return;
                }
                var selectedIndex = parseInt(itemSelect.value || '-1', 10);
                var returnQty = parseInt(returnQtyInput.value || '0', 10);
                var returnId = parseInt(document.getElementById('SRId').value || '0', 10);

                if (selectedIndex < 0 || selectedIndex >= invoiceItems.length) {
                    alert('من فضلك اختر صنف من الفاتورة.');
                    return;
                }
                if (returnQty <= 0) {
                    alert('الكمية المرتجعة يجب أن تكون أكبر من صفر.');
                    return;
                }
                var item = invoiceItems[selectedIndex];
                var remaining = (item.remaining != null) ? item.remaining : (item.qty - (item.alreadyReturned || 0));
                if (remaining <= 0) {
                    alert('تم إرجاع كامل كمية هذا السطر من الفاتورة مسبقاً. لا يمكن إضافة المزيد.');
                    return;
                }
                if (returnQty > remaining) {
                    alert('الكمية المرتجعة تتجاوز المتبقي للمرتجع من هذا السطر (' + remaining + '). الكمية في الفاتورة: ' + item.qty + '، تم إرجاع ' + (item.alreadyReturned || 0) + ' سابقاً.');
                    return;
                }
                if (returnId <= 0) {
                    alert('يجب حفظ المرتجع أولاً قبل إضافة الأصناف.');
                    return;
                }

                var salesInvoiceId = parseInt(document.getElementById('SalesInvoiceId').value || '0', 10) || null;
                var dto = { SRId: returnId, ProdId: item.prodId, Qty: returnQty, BatchNo: item.batchNo || null, ExpiryText: item.expiry || null, PriceRetail: item.priceRetail || 0, Disc1Percent: item.disc1Percent != null ? item.disc1Percent : 0, SalesInvoiceId: salesInvoiceId, SalesInvoiceLineNo: item.lineNo };
                btnAddReturnLine.disabled = true;
                try {
                    var res = await fetch('@Url.Action("AddLineJson", "SalesReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dto) });
                    var txt = await res.text();
                    var data = null;
                    if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                    if (!res.ok || !data || !data.ok) {
                        alert((data && data.message) ? data.message : 'فشل إضافة السطر.');
                        return;
                    }
                    refreshReturnLinesAndTotals(data);
                    // تحديث المتبقي للمرتجع في الصنف المضاف (للعرض عند إعادة الاختيار)
                    item.alreadyReturned = (item.alreadyReturned || 0) + returnQty;
                    item.remaining = item.qty - item.alreadyReturned;
                    if (item.remaining < 0) item.remaining = 0;
                    returnQtyInput.value = '';
                    itemSelect.value = '';
                    invoiceQtyDisplay.value = '';
                    returnBatchDisplay.value = '';
                    returnExpiryDisplay.value = '';
                    // مثل المبيعات: فوكس على حقل اسم/اختيار الصنف بعد الإضافة
                    itemSelect.focus();
                    itemSelect.click();
                } catch (e) {
                    console.error(e);
                    alert('حدث خطأ أثناء إضافة السطر.');
                } finally {
                    btnAddReturnLine.disabled = false;
                }
            });

            var btnAddStandaloneLine = document.getElementById('btnAddStandaloneLine');
            var srStandaloneQtyInput = document.getElementById('srStandaloneQtyInput');
            var srStandaloneBatchInput = document.getElementById('srStandaloneBatchInput');
            var srStandaloneExpiryInput = document.getElementById('srStandaloneExpiryInput');

            var standaloneEnterFields = [srStandaloneQtyInput, srStandaloneBatchInput, srStandaloneExpiryInput];
            standaloneEnterFields.forEach(function (el) {
                if (!el) return;
                if (el.dataset.enterBoundStandalone === '1') return;
                el.dataset.enterBoundStandalone = '1';
                el.addEventListener('keydown', function (e) {
                    if (e.key !== 'Enter') return;
                    e.preventDefault();
                    var idx = standaloneEnterFields.indexOf(el);
                    var next = standaloneEnterFields[idx + 1];
                    if (next) {
                        next.focus();
                        if (typeof next.select === 'function') next.select();
                    } else if (btnAddStandaloneLine) {
                        btnAddStandaloneLine.focus();
                    }
                });
            });
            if (btnAddStandaloneLine && !btnAddStandaloneLine.dataset.enterClickBoundStandalone) {
                btnAddStandaloneLine.dataset.enterClickBoundStandalone = '1';
                btnAddStandaloneLine.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        btnAddStandaloneLine.click();
                    }
                });
            }

            if (btnAddStandaloneLine) {
                btnAddStandaloneLine.addEventListener('click', async function () {
                    if (!isStandaloneMode()) return;
                    if (typeof window.__srResolveStandaloneProductSelection === 'function') {
                        window.__srResolveStandaloneProductSelection();
                    }
                    var prodId = parseInt(document.getElementById('srStandaloneProdId').value || '0', 10);
                    var returnQty = parseInt(document.getElementById('srStandaloneQtyInput').value || '0', 10);
                    var returnId = parseInt(document.getElementById('SRId').value || '0', 10);
                    var priceRetail = (typeof window.__srGetStandaloneResolvedPrice === 'function')
                        ? (window.__srGetStandaloneResolvedPrice() || 0)
                        : (parseFloat(document.getElementById('srStandalonePriceRetail').value || '0') || 0);
                    var disc1 = parseFloat(document.getElementById('srStandaloneDisc1').value || '0') || 0;
                    if (disc1 < 0) disc1 = 0;
                    if (disc1 > 100) disc1 = 100;
                    var batchNo = (document.getElementById('srStandaloneBatchInput').value || '').trim();
                    var expText = (document.getElementById('srStandaloneExpiryInput').value || '').trim();

                    if (prodId <= 0) {
                        alert('اختر صنفاً من القائمة (اسم الصنف) أولاً.');
                        return;
                    }
                    if (returnQty <= 0) {
                        alert('الكمية يجب أن تكون أكبر من صفر.');
                        return;
                    }
                    if (returnId <= 0) {
                        alert('يجب حفظ المرتجع أولاً قبل إضافة الأصناف.');
                        return;
                    }

                    var dto = {
                        SRId: returnId,
                        ProdId: prodId,
                        Qty: returnQty,
                        BatchNo: batchNo || null,
                        ExpiryText: expText || null,
                        PriceRetail: priceRetail,
                        Disc1Percent: disc1,
                        SalesInvoiceId: null,
                        SalesInvoiceLineNo: null
                    };
                    btnAddStandaloneLine.disabled = true;
                    try {
                        var res = await fetch('@Url.Action("AddLineJson", "SalesReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(dto) });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) {
                            alert((data && data.message) ? data.message : 'فشل إضافة السطر.');
                            return;
                        }
                        refreshReturnLinesAndTotals(data);
                        document.getElementById('srStandaloneProdId').value = '';
                        var sn = document.getElementById('srStandaloneProdNameInput');
                        if (sn) sn.value = '';
                        document.getElementById('srStandaloneQtyInput').value = '';
                        document.getElementById('srStandaloneBatchInput').value = '';
                        document.getElementById('srStandaloneExpiryInput').value = '';
                        if (sn) sn.focus();
                    } catch (e) {
                        console.error(e);
                        alert('حدث خطأ أثناء إضافة السطر.');
                    } finally {
                        btnAddStandaloneLine.disabled = false;
                    }
                });
            }

            // تهيئة رقم الفاتورة إذا كان موجوداً
            var initialInvoiceId = '@(Model.SalesInvoiceId?.ToString() ?? "")';
            if (initialInvoiceId) {
                invoiceIdInput.value = initialInvoiceId;
                invoiceIdInput.dispatchEvent(new Event('change'));
            }

            // =========================================================
            // زر حفظ المرتجع (SaveHeader) — يحفظ الهيدر ويسجّل رقم المرتجع
            // =========================================================
            var btnSaveReturn = document.getElementById('btnSaveReturnHeader');
            if (btnSaveReturn) {
                btnSaveReturn.addEventListener('click', async function () {
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    var customerId = parseInt(document.getElementById('CustomerId').value || '0', 10);
                    var warehouseId = parseInt(document.getElementById('WarehouseId').value || '0', 10);
                    var salesInvoiceIdInput = document.getElementById('SalesInvoiceId');
                    var salesInvoiceId = 0;
                    if (salesInvoiceIdInput && salesInvoiceIdInput.value.trim() !== '') {
                        var v = parseInt(salesInvoiceIdInput.value.trim(), 10);
                        if (!isNaN(v)) salesInvoiceId = v;
                    }

                    if (!customerId || !warehouseId) {
                        alert('من فضلك اختر العميل والمخزن أولاً قبل حفظ المرتجع.');
                        return;
                    }

                    var dto = { srId: srId, customerId: customerId, warehouseId: warehouseId, salesInvoiceId: salesInvoiceId || null };
                    btnSaveReturn.disabled = true;
                    try {
                        var response = await fetch('@Url.Action("SaveHeader", "SalesReturns")', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(dto)
                        });
                        var txt = await response.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!response.ok) {
                            alert((data && data.message) ? data.message : 'حدث خطأ أثناء حفظ المرتجع.');
                            return;
                        }
                        if (!data || !data.success) {
                            alert((data && data.message) ? data.message : 'تعذر حفظ المرتجع.');
                            return;
                        }
                        var newId = data.srId || 0;
                        document.getElementById('SRId').value = newId.toString();
                        var dateEl = document.getElementById('ReturnDateDisplay');
                        var timeEl = document.getElementById('ReturnTimeDisplay');
                        if (dateEl && data.returnDate) dateEl.value = data.returnDate;
                        if (timeEl && data.returnTime) timeEl.value = data.returnTime;
                        var clearBtn = document.getElementById('btnClearReturnLines');
                        if (clearBtn) clearBtn.setAttribute('data-return-id', newId.toString());
                        var numDisp = document.getElementById('ReturnNumberDisplay');
                        if (numDisp) numDisp.value = newId.toString();
                        // تحديث حالة المرتجع (عرض بالعربية)
                        var statusEl = document.getElementById('ReturnStatusDisplay');
                        if (statusEl && data.status !== undefined) {
                            statusEl.value = getReturnStatusDisplay(data.status);
                        }
                        // فوكس على إدخال الأصناف حسب الوضع
                        if (typeof isStandaloneMode === 'function' && isStandaloneMode()) {
                            var se = document.getElementById('srStandaloneProdNameInput');
                            if (se) se.focus();
                        } else {
                            var prodSelect = document.getElementById('InvoiceItemSelect');
                            if (prodSelect) {
                                prodSelect.focus();
                                prodSelect.click();
                            }
                        }
                    } catch (err) {
                        console.error(err);
                        alert('تعذر الاتصال بالخادم لحفظ المرتجع.');
                    } finally {
                        btnSaveReturn.disabled = false;
                    }
                });
            }

            var linesTableBody = document.getElementById('SalesReturnLinesTableBody');
            if (linesTableBody) {
                linesTableBody.addEventListener('click', function (ev) {
                    var tr = ev.target.closest('tr.erp-list-selectable-row');
                    if (!tr || !linesTableBody.contains(tr)) return;
                    linesTableBody.querySelectorAll('tr.erp-list-selectable-row.selected').forEach(function (r) { r.classList.remove('selected'); });
                    tr.classList.add('selected');
                    syncDeleteSelectedReturnLineButton();
                });
            }

            function openSrTabFromFrame(url, tabId, title) {
                try {
                    if (window.top && window.top !== window) {
                        window.top.postMessage({
                            type: 'erp-open-tab',
                            tabId: tabId || '',
                            title: title || '',
                            url: url
                        }, '*');
                        return;
                    }
                } catch (e) {
                    console.error(e);
                }
                if (window.erpTabs && typeof window.erpTabs.openTab === 'function') {
                    window.erpTabs.openTab(tabId, url, title);
                } else {
                    window.location.href = url;
                }
            }

            function getSelectedSalesReturnLineNo() {
                var tbody = document.getElementById('SalesReturnLinesTableBody');
                var sel = tbody && tbody.querySelector('tr.erp-list-selectable-row.selected');
                return sel ? (parseInt(sel.getAttribute('data-line-no') || '0', 10) || 0) : 0;
            }

            function buildSalesReturnTrackingUrl(srId, lineNo) {
                var params = new URLSearchParams();
                params.set('frame', '1');
                params.set('sourceType', 'sales-return');
                params.set('documentId', String(srId));
                params.set('lineNo', String(lineNo));
                var base = '@Url.Action("Index", "TrackTrace")';
                var sep = base.indexOf('?') >= 0 ? '&' : '?';
                return base + sep + params.toString();
            }

            var btnTrackingInfo = document.getElementById('btnOpenTrackingInfo');
            if (btnTrackingInfo && !btnTrackingInfo.dataset.boundTrackingInfo) {
                btnTrackingInfo.dataset.boundTrackingInfo = '1';
                btnTrackingInfo.addEventListener('click', function (e) {
                    e.preventDefault();
                    var srId = parseInt(document.getElementById('SRId')?.value || '0', 10) || 0;
                    if (srId <= 0) {
                        showToast('من فضلك احفظ المرتجع أولاً قبل فتح معلومات التتبع.', 'warning');
                        return;
                    }
                    var lineNo = getSelectedSalesReturnLineNo();
                    if (lineNo <= 0) {
                        showToast('من فضلك اختر سطراً من جدول المرتجع أولاً.', 'warning');
                        return;
                    }
                    openSrTabFromFrame(buildSalesReturnTrackingUrl(srId, lineNo), 'track-trace-info', 'معلومات التتبع');
                });
            }

            var btnDeleteSelectedLine = document.getElementById('btnDeleteSelectedReturnLine');

            async function executeRemoveReturnLine(srId, lineNo) {
                var delBtn = document.getElementById('btnDeleteSelectedReturnLine');
                if (delBtn) delBtn.disabled = true;
                try {
                    var res = await fetch('@Url.Action("RemoveLineJson", "SalesReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ SRId: srId, LineNo: lineNo }) });
                    var txt = await res.text();
                    var data = null;
                    if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                    if (!res.ok || !data || !data.ok) {
                        alert((data && data.message) ? data.message : 'فشل مسح السطر.');
                        return;
                    }
                    refreshReturnLinesAndTotals(data);
                    showLineDeletedSuccessFlash();
                    // إعادة جلب أصناف الفاتورة من الخادم حتى تُحدَّث alreadyReturned / المتبقي في الواجهة
                    try {
                        if (typeof loadInvoiceByNumber === 'function' && typeof isStandaloneMode === 'function' && !isStandaloneMode()) {
                            await loadInvoiceByNumber();
                        }
                    } catch (reSyncEx) { console.warn(reSyncEx); }
                } catch (e) {
                    console.error(e);
                    alert('حدث خطأ أثناء مسح السطر.');
                } finally {
                    syncDeleteSelectedReturnLineButton();
                }
            }

            // تأكيد المسح: نفس ERP.showConfirmModal المستخدم في فاتورة المبيعات (erp-ui-feedback.js)
            if (btnDeleteSelectedLine) {
                btnDeleteSelectedLine.addEventListener('click', async function () {
                    if (btnDeleteSelectedLine.disabled) return;
                    var tbody = document.getElementById('SalesReturnLinesTableBody');
                    var sel = tbody && tbody.querySelector('tr.erp-list-selectable-row.selected');
                    var lineNo = sel ? parseInt(sel.getAttribute('data-line-no') || '0', 10) : 0;
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    if (srId <= 0 || lineNo <= 0) {
                        alert('اختر سطراً في الجدول أولاً.');
                        return;
                    }
                    if (typeof isReturnPosted === "function" && isReturnPosted()) {
                        alert('المرتجع مترحّل ومقفول. استخدم زر (فتح المرتجع) أولاً.');
                        return;
                    }
                    var okDelete = false;
                    var msg = 'هل تريد مسح السطر رقم (' + lineNo + ')؟\n\nمسح سطر المرتجع يقلّل المخزون — عكس البيع';
                    if (typeof ERP !== 'undefined' && typeof ERP.showConfirmModal === 'function') {
                        okDelete = await ERP.showConfirmModal({
                            title: 'مسح سطر من المرتجع',
                            message: msg,
                            confirmText: 'مسح',
                            cancelText: 'إلغاء'
                        });
                    } else {
                        okDelete = confirm(msg.replace(/\n\n/g, ' '));
                    }
                    if (!okDelete) return;
                    await executeRemoveReturnLine(srId, lineNo);
                });
            }

            // مسح كل أصناف المرتجع
            var btnClear = document.getElementById('btnClearReturnLines');
            if (btnClear) {
                btnClear.addEventListener('click', async function() {
                    var srId = parseInt(document.getElementById('SRId').value || btnClear.getAttribute('data-return-id') || '0', 10);
                    if (srId <= 0) { alert('يجب حفظ المرتجع أولاً.'); return; }
                    if (typeof isReturnPosted === "function" && isReturnPosted()) {
                        alert('المرتجع مترحّل. استخدم "فتح المرتجع" أولاً.');
                        return;
                    }
                    if (!confirm('هل تريد مسح كل أصناف المرتجع؟')) return;
                    btnClear.disabled = true;
                    try {
                        var res = await fetch('@Url.Action("ClearLinesJson", "SalesReturns")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ SRId: srId }) });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) { alert((data && data.message) ? data.message : 'فشل مسح الأصناف.'); return; }
                        refreshReturnLinesAndTotals(data);
                        try {
                            if (typeof loadInvoiceByNumber === 'function' && typeof isStandaloneMode === 'function' && !isStandaloneMode()) {
                                await loadInvoiceByNumber();
                            }
                        } catch (reSyncEx) { console.warn(reSyncEx); }
                    } catch (e) { console.error(e); alert('حدث خطأ.'); }
                    finally { btnClear.disabled = false; }
                });
            }

            // ترحيل المرتجع
            var btnPost = document.getElementById('btnPostReturn');
            var postMsg = document.getElementById('postReturnMsg');
            var statusDisplay = document.getElementById('ReturnStatusDisplay');
            
            if (btnPost) {
                const serverIsPosted = @Model.IsPosted.ToString().ToLower();

                // لو مترحّل من البداية: اقفل زر الترحيل وطبق القفل
                if (serverIsPosted) {
                    btnPost.disabled = true;
                    btnPost.innerHTML = "✅ تم ترحيل المرتجع";
                    if (typeof setReturnPosted === "function") setReturnPosted(true);
                    if (typeof applyPostedUiLock === "function") applyPostedUiLock();
                    if (typeof syncReturnPrintButton === "function") syncReturnPrintButton();
                    if (postMsg) {
                        postMsg.textContent = "هذا المرتجع مترحّل بالفعل.";
                        postMsg.className = "small mt-2 text-muted";
                    }
                }

                // ربط حدث الترحيل دائماً (حتى بعد فتح المرتجع يعمل الزر)
                btnPost.addEventListener('click', async function() {
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    if (srId <= 0) { 
                        if (postMsg) {
                            postMsg.textContent = "يجب حفظ المرتجع أولاً قبل الترحيل.";
                            postMsg.className = "small mt-2 text-danger";
                        }
                        return; 
                    }
                    if (!confirm('هل تريد ترحيل هذا المرتجع؟')) return;
                    btnPost.disabled = true;
                    try {
                        // حفظ الهيدر أولاً (لتطبيق أي تعديل مثل تغيير العميل)
                        var customerId = parseInt(document.getElementById('CustomerId').value || '0', 10);
                        var warehouseId = parseInt(document.getElementById('WarehouseId').value || '0', 10);
                        var salesInvoiceIdInput = document.getElementById('SalesInvoiceId');
                        var salesInvoiceId = 0;
                        if (salesInvoiceIdInput && salesInvoiceIdInput.value.trim() !== '') {
                            var v = parseInt(salesInvoiceIdInput.value.trim(), 10);
                            if (!isNaN(v)) salesInvoiceId = v;
                        }
                        if (customerId <= 0 || warehouseId <= 0) {
                            if (postMsg) { postMsg.textContent = "يجب اختيار العميل والمخزن قبل الترحيل."; postMsg.className = "small mt-2 text-danger"; }
                            btnPost.disabled = false;
                            return;
                        }
                        {
                            var saveRes = await fetch('@Url.Action("SaveHeader", "SalesReturns")', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ srId: srId, customerId: customerId, warehouseId: warehouseId, salesInvoiceId: salesInvoiceId || null })
                            });
                            var saveTxt = await saveRes.text();
                            var saveData = null;
                            if (saveTxt) { try { saveData = JSON.parse(saveTxt); } catch (e) {} }
                            if (!saveRes.ok || !saveData || !saveData.success) {
                                if (postMsg) { postMsg.textContent = (saveData && saveData.message) ? saveData.message : 'تعذر حفظ التعديلات قبل الترحيل.'; postMsg.className = 'small mt-2 text-danger'; }
                                btnPost.disabled = false;
                                return;
                            }
                        }
                        var res = await fetch('@Url.Action("PostReturn", "SalesReturns")?id=' + srId, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                        var txt = await res.text();
                        var data = null;
                        if (txt) { try { data = JSON.parse(txt); } catch (e) {} }
                        if (!res.ok || !data || !data.ok) { 
                            if (postMsg) {
                                postMsg.textContent = (data && data.message) ? data.message : 'فشل الترحيل.';
                                postMsg.className = "small mt-2 text-danger";
                            }
                            return; 
                        }
                        
                        // تحديث الحالة (عرض "مرحلة X" مثل المبيعات)
                        if (statusDisplay) {
                            var stage = (data && data.stage != null) ? data.stage : 1;
                            statusDisplay.value = (data && data.postedLabel) ? data.postedLabel : ('مرحلة ' + stage);
                        }

                        // تحديث الفلاج + تطبيق القفل
                        if (typeof setReturnPosted === "function") setReturnPosted(true);
                        if (typeof applyPostedUiLock === "function") applyPostedUiLock();
                        if (typeof syncReturnPrintButton === "function") syncReturnPrintButton();

                        // تحديث زر الترحيل
                        btnPost.innerHTML = "✅ تم ترحيل المرتجع";
                        btnPost.disabled = true;

                        // تفعيل زر الفتح
                        var btnOpen = document.getElementById('btnOpenReturn');
                        if (btnOpen) {
                            btnOpen.disabled = false;
                        }

                        if (postMsg) {
                            postMsg.textContent = '';
                            postMsg.className = 'small mt-2';
                        }
                        showToast((data && data.message) ? data.message : 'تم الترحيل.', 'success', 1000);
                    } catch (e) { 
                        console.error(e); 
                        if (postMsg) {
                            postMsg.textContent = 'حدث خطأ أثناء الترحيل.';
                            postMsg.className = "small mt-2 text-danger";
                        }
                    }
                    finally { 
                        if (typeof isReturnPosted === 'function' && !isReturnPosted()) btnPost.disabled = false;
                    }
                });
            }

            // فتح المرتجع (إلغاء الترحيل) — بنفس فكرة فاتورة المبيعات
            var btnOpen = document.getElementById('btnOpenReturn');
            if (btnOpen) {
                if (typeof isReturnPosted === "function" && !isReturnPosted()) {
                    btnOpen.disabled = true;
                }
                let busy = false;
                btnOpen.addEventListener('click', async function() {
                    if (busy) return;
                    if (btnOpen.disabled) return;
                    var srId = parseInt(document.getElementById('SRId').value || '0', 10);
                    if (srId <= 0) {
                        if (postMsg) {
                            postMsg.textContent = "اختر مرتجعاً أولاً.";
                            postMsg.className = "small mt-2 text-danger";
                        }
                        return;
                    }
                    if (!confirm('هل تريد فتح المرتجع (إلغاء الترحيل)؟')) return;
                    busy = true;
                    var oldHtml = btnOpen.innerHTML;
                    btnOpen.disabled = true;
                    btnOpen.innerHTML = "⏳ جاري الفتح...";
                    if (postMsg) {
                        postMsg.textContent = "جاري فتح المرتجع للتعديل...";
                        postMsg.className = "small mt-2 text-muted";
                    }
                    try {
                        var res = await fetch('@Url.Action("OpenReturn", "SalesReturns")?id=' + srId, {
                            method: 'POST',
                            credentials: 'same-origin',
                            headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/json' }
                        });
                        var data = null;
                        try {
                            var txt = await res.text();
                            if (txt) data = JSON.parse(txt);
                        } catch (e) { }
                        if (!res.ok || !data || !data.ok) {
                            if (postMsg) {
                                postMsg.textContent = (data && data.message) ? data.message : 'فشل فتح المرتجع.';
                                postMsg.className = "small mt-2 text-danger";
                            }
                            btnOpen.disabled = false;
                            btnOpen.innerHTML = oldHtml;
                            busy = false;
                            return;
                        }
                        // نجاح: تحديث الفلاج + الواجهة (مثل المبيعات)
                        if (typeof setReturnPosted === "function") setReturnPosted(false);
                        if (typeof applyPostedUiLock === "function") applyPostedUiLock();
                        if (typeof syncReturnPrintButton === "function") syncReturnPrintButton();
                        if (statusDisplay) {
                            statusDisplay.value = "مفتوحة للتعديل";
                        }
                        btnOpen.innerHTML = "⏪ فتح المرتجع";
                        btnOpen.disabled = true;
                        if (btnPost) {
                            btnPost.disabled = false;
                            btnPost.innerHTML = "📤 ترحيل المرتجع";
                        }
                        if (postMsg) {
                            postMsg.textContent = (data && data.message) ? data.message : 'تم فتح المرتجع للتعديل.';
                            postMsg.className = "small mt-2 text-success";
                        }
                    } catch (e) {
                        console.error(e);
                        if (postMsg) {
                            postMsg.textContent = 'حدث خطأ أثناء فتح المرتجع.';
                            postMsg.className = "small mt-2 text-danger";
                        }
                        btnOpen.disabled = false;
                        btnOpen.innerHTML = oldHtml;
                    }
                    finally {
                        busy = false;
                    }
                });
            }

            // =========================================================
            // زر طباعة مرتجع البيع (نفس نمط فاتورة المبيعات)
            // =========================================================
            const btnPrintReturn = document.getElementById("btnPrintReturnDropdown");
            let srPrinting = false;
            let srPrintWrapperParent = null;
            let srPrintWrapperNext = null;

            function syncReturnPrintButton() {
                if (!btnPrintReturn) return;
                const posted = (typeof isReturnPosted === "function") ? isReturnPosted() : false;
                btnPrintReturn.disabled = !posted;
                btnPrintReturn.title = posted ? "اختر نوع الطباعة" : "يتاح بعد ترحيل المرتجع";
            }
            window.syncReturnPrintButton = syncReturnPrintButton;

            function prepareSalesReturnPrint() {
                const printArea = document.getElementById("piPrintArea");
                if (!printArea) return false;

                const el = (id) => document.getElementById(id);
                const returnId = (el("SRId")?.value || "").trim();
                const returnDate = (el("ReturnDateDisplay")?.value || "").trim();
                const customerName = (el("CustomerNameInput")?.value || "").trim();
                const warehouseSel = el("WarehouseId");
                const warehouseName = warehouseSel && warehouseSel.options && warehouseSel.selectedIndex >= 0
                    ? String(warehouseSel.options[warehouseSel.selectedIndex].text || "").trim()
                    : "";

                if (el("piPrintNow")) el("piPrintNow").textContent = new Date().toLocaleString();
                if (el("piPrintInvoiceNo")) el("piPrintInvoiceNo").textContent = returnId || "";
                if (el("piPrintInvoiceDate")) el("piPrintInvoiceDate").textContent = returnDate || "";
                if (el("piPrintSupplier")) el("piPrintSupplier").textContent = customerName || "";
                if (el("piPrintWarehouse")) el("piPrintWarehouse").textContent = warehouseName || "";
                if (el("piPrintCustomerPhone")) el("piPrintCustomerPhone").textContent = (el("CustomerPhone")?.value || "").trim() || "—";
                if (el("piPrintCustomerAddress")) el("piPrintCustomerAddress").textContent = (el("CustomerAddress")?.value || "").trim() || "—";
                if (el("piPrintAuthor")) el("piPrintAuthor").textContent = (el("ReturnCreatedByDisplay")?.value || "").trim() || "—";

                const destTbody = el("piPrintMasterTbody");
                const srcTbody = el("SalesReturnLinesTableBody");
                if (!destTbody || !srcTbody) return false;
                destTbody.innerHTML = "";

                const srcRows = Array.from(srcTbody.querySelectorAll("tr.erp-list-selectable-row"));
                if (!srcRows.length) {
                    destTbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-2">لا توجد سطور للطباعة.</td></tr>';
                } else {
                    srcRows.forEach(function (tr) {
                        const c = tr.cloneNode(true);
                        c.querySelectorAll("button, a, .no-print").forEach(x => x.remove());
                        c.querySelectorAll("th.no-print, td.no-print").forEach(x => x.remove());
                        destTbody.appendChild(c);
                    });
                }

                const parseNum = (txt) => {
                    const n = parseFloat(String(txt || "").replace(/,/g, "").trim());
                    return Number.isFinite(n) ? n : 0;
                };

                let totalLines = 0;
                let totalQty = 0;
                srcRows.forEach(function (r) {
                    totalLines += 1;
                    totalQty += parseNum(r.children?.[5]?.textContent);
                });

                const totalBeforeTax = (el("TotalBeforeTaxBadge")?.textContent || "0").trim();
                const taxAmount = (el("TaxAmountBadge")?.textContent || "0").trim();
                const netTotal = (el("NetTotalBadge")?.textContent || "0").trim();
                const totalsWrap = el("piPrintTotalsWrap");
                if (!totalsWrap) return false;
                totalsWrap.innerHTML = `
<div class="card shadow-sm invoice-totals-card mb-0">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-boxes">
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">عدد السطور</span><span class="invoice-summary-value">${totalLines}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي الكمية</span><span class="invoice-summary-value">${totalQty}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">الإجمالي قبل الضريبة</span><span class="invoice-summary-value">${totalBeforeTax}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">قيمة الضريبة</span><span class="invoice-summary-value">${taxAmount}</span></div>
            <div class="invoice-summary-item invoice-summary-box invoice-summary-box-main"><span class="invoice-summary-label">الإجمالي بعد الضريبة</span><span class="invoice-summary-value invoice-summary-value-main fw-bold">${netTotal}</span></div>
        </div>
    </div>
</div>`;
                return true;
            }

            function doSalesReturnPrint(mode) {
                const returnId = parseInt((document.getElementById("SRId")?.value || "0"), 10) || 0;
                if (returnId <= 0) {
                    showToast("⚠️ لا يمكن طباعة مرتجع قبل حفظه.", "warning");
                    return;
                }
                if (typeof isReturnPosted === "function" && !isReturnPosted()) {
                    showToast("❌ يجب ترحيل المرتجع قبل الطباعة", "danger");
                    document.getElementById("btnPostReturn")?.focus();
                    return;
                }
                if (srPrinting) return;
                srPrinting = true;

                if (!prepareSalesReturnPrint()) {
                    srPrinting = false;
                    showToast("تعذر تجهيز الطباعة.", "danger");
                    return;
                }

                const wrapper = document.getElementById("piPrintWrapper");
                const printArea = document.getElementById("piPrintArea");
                if (!wrapper || !printArea) {
                    srPrinting = false;
                    return;
                }

                wrapper.classList.remove("print-mode-1", "print-mode-2", "print-mode-3");
                wrapper.querySelectorAll(".pi-print-copy:not(#piPrintArea)").forEach(c => c.remove());

                if (mode === 2 || mode === 3) {
                    const copies = mode === 2 ? 2 : 3;
                    for (let i = 1; i < copies; i++) {
                        const clone = printArea.cloneNode(true);
                        clone.id = "";
                        clone.classList.add("pi-print-copy");
                        clone.querySelectorAll("[id]").forEach(x => x.removeAttribute("id"));
                        wrapper.appendChild(clone);
                    }
                    wrapper.classList.add("print-mode-" + mode);
                } else {
                    wrapper.classList.add("print-mode-1");
                }

                srPrintWrapperParent = null;
                srPrintWrapperNext = null;
                if (wrapper.parentNode !== document.body) {
                    srPrintWrapperParent = wrapper.parentNode;
                    srPrintWrapperNext = wrapper.nextSibling;
                    document.body.appendChild(wrapper);
                }

                document.body.classList.add("printing-invoice");
                setTimeout(() => window.print(), 50);
            }
            window.__doSalesReturnPrint = doSalesReturnPrint;

            if (btnPrintReturn) {
                syncReturnPrintButton();
            }

            if (!window.__srPrintDelegatedBound__) {
                document.addEventListener("click", function (e) {
                    const item = e.target && e.target.closest ? e.target.closest("[data-sr-print-mode]") : null;
                    if (!item) return;
                    e.preventDefault();
                    const mode = parseInt(item.getAttribute("data-sr-print-mode") || "1", 10);
                    doSalesReturnPrint(mode);
                });
                window.__srPrintDelegatedBound__ = true;
            }

            window.addEventListener("afterprint", function () {
                document.body.classList.remove("printing-invoice");
                srPrinting = false;
                const wrapper = document.getElementById("piPrintWrapper");
                if (wrapper) {
                    wrapper.classList.remove("print-mode-1", "print-mode-2", "print-mode-3");
                    wrapper.querySelectorAll(".pi-print-copy:not(#piPrintArea)").forEach(c => c.remove());
                    if (srPrintWrapperParent) {
                        if (srPrintWrapperNext) {
                            srPrintWrapperParent.insertBefore(wrapper, srPrintWrapperNext);
                        } else {
                            srPrintWrapperParent.appendChild(wrapper);
                        }
                        srPrintWrapperParent = null;
                        srPrintWrapperNext = null;
                    }
                }
            });

            // =========================================================
            // سكربت التنقل (داخل نفس التاب)
            // =========================================================

            // ==============================
            // (1) Tooltips (Bootstrap) لو موجود
            // ==============================
            try {
                if (window.bootstrap && typeof bootstrap.Tooltip === 'function') {
                    document.querySelectorAll('[title]').forEach(el => new bootstrap.Tooltip(el));
                }
            } catch (e) { }

            // ==============================
            // (2) رابط Edit الصحيح
            // ==============================
            const editBaseUrl = '@Url.Action("Edit", "SalesReturns")'; // مثال: /SalesReturns/Edit

            function openReturn(id) {
                id = parseInt(id || '0', 10);
                if (!id || id <= 0) return;

                // ✅ مهم: Edit عندك بالمسار /Edit/{id}
                const base = editBaseUrl.replace(/\/$/, '');
                const url = base + '/' + encodeURIComponent(id) + '?frame=1&_ts=' + Date.now();
                window.location.href = url;
            }

            // ==============================
            // (3) البحث برقم المرتجع
            // ==============================
            const searchInput = document.getElementById('NavReturnSearchInput');
            const searchBtn   = document.getElementById('btnNavReturnSearch');

            function doSearch() {
                const v = (searchInput?.value || '').trim();
                if (!v) return;
                openReturn(v);
            }

            searchBtn?.addEventListener('click', (e) => {
                e.preventDefault();
                doSearch();
            });

            searchInput?.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    doSearch();
                }
            });

            // زر التحديث في الناف بار: إعادة تحميل نفس المرتجع من السيرفر (سياسة عميل، حالة، إلخ)
            window.__ERP_REFRESH__ = function () {
                var rid = parseInt((document.getElementById('SRId') || document.getElementById('ReturnId'))?.value || '0', 10) || 0;
                if (rid > 0) {
                    window.location.reload();
                }
            };

        });
    </script>
    <script>
        // =========================================================
        // طباعة مرتجع البيع — نسخة مستقلة (بنفس نمط فاتورة المبيعات)
        // تعمل حتى لو حدث خطأ في سكربتات أخرى داخل الصفحة
        // =========================================================
        (function () {
            if (window.__srPrintInitV2__) return;
            window.__srPrintInitV2__ = true;

            function isPostedSafe() {
                var flag = document.getElementById("ReturnIsPostedFlag");
                return !!(flag && flag.value === "1");
            }

            function prepareSalesReturnPrintV2() {
                const wrapper = document.getElementById("piPrintWrapper");
                const printArea = document.getElementById("piPrintArea");
                if (!wrapper || !printArea) return false;

                const el = (id) => document.getElementById(id);
                const returnId = (el("SRId")?.value || "").trim();
                const returnDate = (el("ReturnDateDisplay")?.value || "").trim();
                const customerName = (el("CustomerNameInput")?.value || "").trim();

                const warehouseSel = el("WarehouseId");
                const warehouseName = warehouseSel && warehouseSel.options && warehouseSel.selectedIndex >= 0
                    ? String(warehouseSel.options[warehouseSel.selectedIndex].text || "").trim()
                    : "";

                if (el("piPrintNow")) el("piPrintNow").textContent = new Date().toLocaleString();
                if (el("piPrintInvoiceNo")) el("piPrintInvoiceNo").textContent = returnId || "";
                if (el("piPrintInvoiceDate")) el("piPrintInvoiceDate").textContent = returnDate || "";
                if (el("piPrintSupplier")) el("piPrintSupplier").textContent = customerName || "";
                if (el("piPrintWarehouse")) el("piPrintWarehouse").textContent = warehouseName || "";
                if (el("piPrintCustomerPhone")) el("piPrintCustomerPhone").textContent = (el("CustomerPhone")?.value || "").trim() || "—";
                if (el("piPrintCustomerAddress")) el("piPrintCustomerAddress").textContent = (el("CustomerAddress")?.value || "").trim() || "—";
                if (el("piPrintAuthor")) el("piPrintAuthor").textContent = (el("ReturnCreatedByDisplay")?.value || "").trim() || "—";

                const destTbody = el("piPrintMasterTbody");
                const srcTbody = el("SalesReturnLinesTableBody");
                if (!destTbody || !srcTbody) return false;
                destTbody.innerHTML = "";

                const srcRows = Array.from(srcTbody.querySelectorAll("tr.erp-list-selectable-row"));
                if (!srcRows.length) {
                    destTbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-2">لا توجد سطور للطباعة.</td></tr>';
                } else {
                    srcRows.forEach(function (tr) {
                        const c = tr.cloneNode(true);
                        c.querySelectorAll("button, a, .no-print").forEach(x => x.remove());
                        c.querySelectorAll("th.no-print, td.no-print").forEach(x => x.remove());
                        destTbody.appendChild(c);
                    });
                }

                const parseNum = (txt) => {
                    const n = parseFloat(String(txt || "").replace(/,/g, "").trim());
                    return Number.isFinite(n) ? n : 0;
                };

                let totalLines = 0;
                let totalQty = 0;
                srcRows.forEach(function (r) {
                    totalLines += 1;
                    totalQty += parseNum(r.children?.[5]?.textContent);
                });

                const totalBeforeTax = (el("TotalBeforeTaxBadge")?.textContent || "0").trim();
                const taxAmount = (el("TaxAmountBadge")?.textContent || "0").trim();
                const netTotal = (el("NetTotalBadge")?.textContent || "0").trim();
                const totalsWrap = el("piPrintTotalsWrap");
                if (!totalsWrap) return false;
                totalsWrap.innerHTML = `
<div class="card shadow-sm invoice-totals-card mb-0">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-boxes">
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">عدد السطور</span><span class="invoice-summary-value">${totalLines}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي الكمية</span><span class="invoice-summary-value">${totalQty}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">الإجمالي قبل الضريبة</span><span class="invoice-summary-value">${totalBeforeTax}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">قيمة الضريبة</span><span class="invoice-summary-value">${taxAmount}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">الإجمالي بعد الضريبة</span><span class="invoice-summary-value fw-bold">${netTotal}</span></div>
        </div>
    </div>
</div>`;
                return true;
            }

            let srPrinting = false;
            let srPrintWrapperParent = null;
            let srPrintWrapperNext = null;

            function doSalesReturnPrintV2(mode) {
                const returnId = parseInt((document.getElementById("SRId")?.value || "0"), 10) || 0;
                if (returnId <= 0) {
                    if (typeof showToast === "function") showToast("⚠️ لا يمكن طباعة مرتجع قبل حفظه.", "warning");
                    return;
                }
                if (!isPostedSafe()) {
                    if (typeof showToast === "function") showToast("❌ يجب ترحيل المرتجع قبل الطباعة", "danger");
                    document.getElementById("btnPostReturn")?.focus();
                    return;
                }
                if (srPrinting) return;
                srPrinting = true;

                if (!prepareSalesReturnPrintV2()) {
                    srPrinting = false;
                    if (typeof showToast === "function") showToast("تعذر تجهيز الطباعة.", "danger");
                    return;
                }

                const wrapper = document.getElementById("piPrintWrapper");
                const printArea = document.getElementById("piPrintArea");
                if (!wrapper || !printArea) {
                    srPrinting = false;
                    return;
                }

                wrapper.classList.remove("print-mode-1", "print-mode-2", "print-mode-3");
                wrapper.querySelectorAll(".pi-print-copy:not(#piPrintArea)").forEach(c => c.remove());

                const normalizedMode = (mode === 2 || mode === 3) ? mode : 1;
                if (normalizedMode === 2 || normalizedMode === 3) {
                    const copies = normalizedMode === 2 ? 2 : 3;
                    for (let i = 1; i < copies; i++) {
                        const clone = printArea.cloneNode(true);
                        clone.id = "";
                        clone.classList.add("pi-print-copy");
                        clone.querySelectorAll("[id]").forEach(x => x.removeAttribute("id"));
                        wrapper.appendChild(clone);
                    }
                }
                wrapper.classList.add("print-mode-" + normalizedMode);

                srPrintWrapperParent = null;
                srPrintWrapperNext = null;
                if (wrapper.parentNode !== document.body) {
                    srPrintWrapperParent = wrapper.parentNode;
                    srPrintWrapperNext = wrapper.nextSibling;
                    document.body.appendChild(wrapper);
                }

                document.body.classList.add("printing-invoice");
                setTimeout(() => window.print(), 50);
            }

            window.__doSalesReturnPrint = doSalesReturnPrintV2;

            window.addEventListener("afterprint", function () {
                document.body.classList.remove("printing-invoice");
                srPrinting = false;
                const wrapper = document.getElementById("piPrintWrapper");
                if (!wrapper) return;
                wrapper.classList.remove("print-mode-1", "print-mode-2", "print-mode-3");
                wrapper.querySelectorAll(".pi-print-copy:not(#piPrintArea)").forEach(c => c.remove());
                if (srPrintWrapperParent) {
                    if (srPrintWrapperNext) {
                        srPrintWrapperParent.insertBefore(wrapper, srPrintWrapperNext);
                    } else {
                        srPrintWrapperParent.appendChild(wrapper);
                    }
                    srPrintWrapperParent = null;
                    srPrintWrapperNext = null;
                }
            });
        })();
    </script>
}
