@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.SalesReturn

@{
    ViewData["Title"] = "مرتجع بيع";
}

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/invoice-cards.css")" />
    <style>
        /* تنسيق مرتجع البيع — مطبّق مباشرة لضمان الظهور (حتى داخل التاب/iframe) */
        .invoice-page { background-color: #f3f6fb; min-height: 100vh; padding-bottom: 2rem; }
        div.card.invoice-side-card,
        div.card.invoice-header-card,
        div.card.invoice-Add-card,
        div.card.invoice-lines-card,
        div.card.invoice-totals-card {
            border: 1px solid #a5b4fc !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(59,130,246,.12) !important;
            overflow: hidden;
        }
        .invoice-header-bar {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            padding: 0.5rem 1rem;
            font-weight: 600;
        }
        .invoice-header-bar h5, .invoice-header-bar h6 { margin-bottom: 0; font-size: 1rem; color: #fff !important; }
        .invoice-details-card .card-header,
        .invoice-Add-card .card-header,
        .invoice-lines-card .card-header,
        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            padding: 0.55rem 1rem;
        }
        .invoice-side-card .card-header h6 { color: #fff !important; margin-bottom: 0; }
        .invoice-page .invoice-header-card .form-control,
        .invoice-page .invoice-header-card .form-select,
        .invoice-page .invoice-Add-card .form-control,
        .invoice-page .invoice-Add-card .form-select,
        .invoice-page .invoice-totals-card .form-control,
        .invoice-page .invoice-totals-card .form-select { border-color: #94a3b8 !important; }
        .return-line-field { max-width: 5.5rem; }
        /* بوكس بحث عميل/صنف — نفس نمط فاتورة المبيعات (قائمة عائمة + سهم ▼) */
        .invoice-page .product-dropdown-onebox {
            position: relative;
            display: flex;
            align-items: stretch;
            border: 1px solid #94a3b8;
            border-radius: 0.375rem;
            background: #fff;
        }
        .invoice-page .product-dropdown-arrow-inside {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 0.45rem;
            cursor: pointer;
            user-select: none;
            color: #64748b;
            font-size: 0.65rem;
            border-inline-end: 1px solid #e2e8f0;
        }
        .invoice-page .product-dropdown-arrow-inside:hover { color: #0f172a; background: #f8fafc; }
        .invoice-page .product-dropdown-onebox .product-dropdown-input {
            border: none !important;
            box-shadow: none !important;
            border-radius: 0 !important;
            flex: 1;
            min-width: 0;
        }
        .invoice-page .product-dropdown-list {
            position: fixed;
            z-index: 3060;
            max-height: 260px;
            overflow-y: auto;
            background: #fff;
            border: 1px solid #94a3b8;
            border-radius: 0.375rem;
            box-shadow: 0 4px 16px rgba(15, 23, 42, 0.12);
        }
        .invoice-page .product-dropdown-list[data-open="false"] { display: none !important; }
        .invoice-page .product-dropdown-list[data-open="true"] { display: block !important; }
        .invoice-page .product-dropdown-item { cursor: pointer; font-size: 0.875rem; text-align: right; }
        .invoice-page .product-dropdown-item:hover { background: #f1f5f9; }
        .invoice-page .product-dropdown-item-active { background: #e0f2fe !important; }
        .badge-status-draft { background-color: #6f42c1; }
        .badge-status-notposted { background-color: #343a40; }

        /* كارت الإجماليات — نفس فاتورة المبيعات */
        .invoice-totals-card .invoice-summary-item.invoice-summary-box {
            flex: 1 1 0;
            min-width: 0;
            max-width: 100%;
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
            align-items: center;
            justify-content: flex-start;
            padding: 0.25rem 0.35rem;
            background: #f8fafc;
            border: 1px solid #64748b;
            border-radius: 6px;
        }
        .invoice-totals-card .invoice-summary-label {
            font-size: 0.8rem;
            line-height: 1.2;
            color: #64748b;
            margin-bottom: 0;
        }
        .invoice-totals-card .invoice-summary-value {
            font-size: 1rem;
            font-weight: 500;
            color: #0f172a;
        }
        .invoice-totals-card .invoice-summary-value-main {
            font-size: 1.05rem;
            color: #fff !important;
        }
        .invoice-summary-box-main {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%) !important;
            border-color: #0284c7 !important;
        }
        .invoice-summary-box-main .invoice-summary-label {
            color: rgba(255,255,255,.9);
        }
        .invoice-summary-row {
            flex-wrap: wrap;
            gap: 0.35rem 0.5rem;
            align-items: stretch;
            justify-content: space-between;
        }

        #srToastContainer {
            position: fixed;
            top: 70px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.35rem;
            pointer-events: none;
        }
        #srToastContainer .sr-toast {
            padding: 0.6rem 1.2rem;
            border-radius: 8px;
            font-size: 0.9rem;
            box-shadow: 0 2px 8px rgba(0,0,0,.12);
            transition: opacity 0.25s ease;
        }
        #srToastContainer .sr-toast.text-success { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
        #srToastContainer .sr-toast.text-warning { background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; }
        #srToastContainer .sr-toast.text-danger { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
        #srToastContainer .sr-toast.text-muted { background: #f1f5f9; color: #334155; border: 1px solid #64748b; }

        /* رقم فاتورة البيع: حقل ضيق أعلى يمين الهيدر */
        .sr-invoice-no-wrap { max-width: 7.5rem; }
        .sr-invoice-no-wrap .form-control { max-width: 7rem; margin-inline: auto; }
        /* كود العميل ورقم المرتجع وحقول التاريخ/الوقت — مضغوطة مثل فاتورة المبيعات */
        .sr-header-card-body .sr-hdr-compact .form-control,
        .sr-header-card-body .sr-hdr-compact .form-select {
            min-width: 0;
            padding-inline: 0.3rem;
            font-size: 0.8rem;
        }
        .sr-header-card-body .sr-hdr-compact .invoice-small-input { max-width: 100%; }

        /* قائمة أصناف المرتجع: مسافة عن السهم + عرض الاسم في منتصف البوكس */
        .invoice-page .invoice-Add-card select#InvoiceItemSelect.sr-invoice-item-select {
            padding-left: 2.85rem !important;
            padding-right: 0.55rem !important;
            text-align: center;
            text-align-last: center;
        }
        /* جدول سطور المرتجع — نفس كثافة خلايا فاتورة المبيعات */
        .invoice-page .invoice-lines-container .erp-table tbody td,
        .invoice-page .invoice-lines-container .erp-table tbody th { padding: 0.45rem 0.55rem; }
        .invoice-page .invoice-lines-container .erp-table thead th { padding: 0.5rem 0.55rem; }

        /* رأس جدول السطور: مظهر محايد (رمادي فاتح + نص داكن) مثل الجدول المرجعي */
        .invoice-page .invoice-lines-container .erp-table-wrapper .erp-table > thead.sr-return-lines-thead > tr > th {
            background: linear-gradient(180deg, #e8edf3 0%, #f1f5f9 50%, #f8fafc 100%) !important;
            color: #1e293b !important;
            font-weight: 600;
            border-top: 2px solid #64748b !important;
            border-bottom: 1px solid #cbd5e1 !important;
            border-inline-end: 1px solid #e2e8f0 !important;
            box-shadow: none !important;
        }
        .invoice-page .invoice-lines-container .erp-table-wrapper .erp-table > thead.sr-return-lines-thead > tr > th:first-child {
            border-inline-start: 1px solid #e2e8f0 !important;
        }

        /* وميض نجاح مسح السطر: وسط الشاشة، أخضر + صح */
        .sr-line-deleted-flash {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 10060;
            display: flex;
            align-items: center;
            gap: 0.65rem;
            padding: 0.9rem 1.35rem;
            background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
            color: #065f46;
            border: 1px solid #6ee7b7;
            border-radius: 14px;
            font-size: 0.95rem;
            font-weight: 600;
            box-shadow: 0 10px 38px rgba(6, 95, 70, 0.18);
            pointer-events: none;
            opacity: 1;
            transition: opacity 0.28s ease;
        }
        .sr-line-deleted-flash .sr-line-deleted-flash__icon {
            width: 1.75rem;
            height: 1.75rem;
            border-radius: 50%;
            background: #059669;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            line-height: 1;
            flex-shrink: 0;
            box-shadow: 0 2px 8px rgba(5, 150, 105, 0.35);
        }
    </style>
}

<div class="invoice-page" dir="rtl">
    <div id="srToastContainer" aria-live="polite"></div>
    <div class="container-fluid pt-3">

        <div class="row g-3 align-items-start">

            @* كارت الإجراءات أولاً في الـ HTML مع order حتى يُرسم مع الصف دون تأخير بصري *@
            <div class="col-lg-2 order-last">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات مرتجع البيع</h6>
                    </div>

                    <input type="hidden" id="ReturnId" value="@Model.SRId" />
                    <input type="hidden" id="ReturnIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />

                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">

                        @{
                            int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
                            int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
                            int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
                            int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;

                            int currentId = Model?.SRId ?? 0;

                            bool hasAnyReturns =
                            navFirst.HasValue && navLast.HasValue &&
                            navFirst.Value > 0 && navLast.Value > 0;

                            int? prevEffective = (currentId == 0) ? navLast : navPrev;
                            int? nextEffective = (currentId == 0) ? navFirst : navNext;

                            bool canFirst = hasAnyReturns && navFirst.HasValue && navFirst.Value > 0 && navFirst.Value != currentId;
                            bool canLast = hasAnyReturns && navLast.HasValue && navLast.Value > 0 && navLast.Value != currentId;
                            bool canPrev = hasAnyReturns && prevEffective.HasValue && prevEffective.Value > 0 && prevEffective.Value != currentId;
                            bool canNext = hasAnyReturns && nextEffective.HasValue && nextEffective.Value > 0 && nextEffective.Value != currentId;
                        }

                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <a id="btnFirstReturn"
                               class="btn btn-erp btn-erp-outline-primary btn-erp-sm@(canFirst ? "" : " disabled")"
                               href="@(canFirst ? Url.Action("Edit", "SalesReturns", new { id = (navFirst ?? 0), frame = 1 }) : "#")"
                               data-local-nav="1"
                               title="أول مرتجع"
                               aria-disabled="@(canFirst ? "false" : "true")"
                               tabindex="@(canFirst ? "0" : "-1")">
                                ⏮
                            </a>

                            <a id="btnPrevReturn"
                               class="btn btn-erp btn-erp-outline-primary btn-erp-sm@(canPrev ? "" : " disabled")"
                               href="@(canPrev ? Url.Action("Edit", "SalesReturns", new { id = (prevEffective ?? 0), frame = 1 }) : "#")"
                               data-local-nav="1"
                               title="المرتجع السابق"
                               aria-disabled="@(canPrev ? "false" : "true")"
                               tabindex="@(canPrev ? "0" : "-1")">
                                ◀
                            </a>

                            <a id="btnNextReturn"
                               class="btn btn-erp btn-erp-outline-primary btn-erp-sm@(canNext ? "" : " disabled")"
                               href="@(canNext ? Url.Action("Edit", "SalesReturns", new { id = (nextEffective ?? 0), frame = 1 }) : "#")"
                               data-local-nav="1"
                               title="المرتجع التالي"
                               aria-disabled="@(canNext ? "false" : "true")"
                               tabindex="@(canNext ? "0" : "-1")">
                                ▶
                            </a>

                            <a id="btnLastReturn"
                               class="btn btn-erp btn-erp-outline-primary btn-erp-sm@(canLast ? "" : " disabled")"
                               href="@(canLast ? Url.Action("Edit", "SalesReturns", new { id = (navLast ?? 0), frame = 1 }) : "#")"
                               data-local-nav="1"
                               title="آخر مرتجع"
                               aria-disabled="@(canLast ? "false" : "true")"
                               tabindex="@(canLast ? "0" : "-1")">
                                ⏭
                            </a>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <input type="number"
                                   id="NavReturnSearchInput"
                                   class="form-control form-control-sm"
                                   placeholder="بحث برقم المرتجع" />


                            <button type="button"
                                    id="btnNavReturnSearch"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-tab-id="sr-show-tab"
                                    data-tab-title="مرتجع مبيعات"
                                    data-base-url="@Url.Action("Edit", "SalesReturns")">
                                بحث
                            </button>
                        </div>

                        <hr class="my-1" />

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           data-tab-id="sr-show-tab"
                           data-tab-title="مرتجع مبيعات"
                           data-url="@Url.Action("Create", "SalesReturns", new { frame = 1 })">
                            ➕ مرتجع جديد
                        </a>
                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100 mt-1"
                           data-tab-id="sr-show-tab"
                           data-tab-title="مرتجع بدون فاتورة"
                           data-url="@Url.Action("Create", "SalesReturns", new { frame = 1, standalone = true })">
                            ➕ مرتجع بدون فاتورة
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnSaveReturnHeader"
                                data-lock-posted="1">
                            💾 حفظ المرتجع
                        </button>

                        <button type="button" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" id="btnPostReturn" data-lock-posted="1">
                            📤 ترحيل المرتجع
                        </button>

                        <div id="postReturnMsg" class="small mt-2"></div>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnDeleteSelectedReturnLine"
                                data-lock-posted="1"
                                title="اختر سطراً في الجدول ثم اضغط لمسحه">
                            🗑️ مسح السطر المحدد
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnOpenReturn">
                            ⏪ فتح المرتجع
                        </button>


                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnClearReturnLines"
                                data-return-id="@(Model?.SRId ?? 0)"
                                data-lock-posted="1">
                            🗑️ مسح كل أصناف المرتجع
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-secondary btn-erp-sm w-100"
                                id="btnOpenTrackingInfo"
                                title="يعرض العبوات المتتبعة المرتبطة بالسطر المحدد">
                            🧬 معلومات التتبع
                        </button>

                        @if (Model?.SRId > 0)
                        {
                            <a href="@Url.Action("ExportShowExcel", "SalesReturns", new { id = Model.SRId })" target="_blank" rel="noopener" class="btn btn-erp btn-erp-success btn-erp-sm w-100 text-decoration-none">📥 تصدير Excel</a>
                        }

                        <div class="dropdown w-100">
                            <button type="button"
                                    id="btnPrintReturnDropdown"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100 dropdown-toggle"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    title="اختر نوع الطباعة">
                                🖨️ طباعة المرتجع
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end w-100" aria-labelledby="btnPrintReturnDropdown">
                                <li><a class="dropdown-item" href="#" data-sr-print-mode="1" onclick="if(window.__doSalesReturnPrint){window.__doSalesReturnPrint(1);} return false;">طباعة صفحة واحدة</a></li>
                                <li><a class="dropdown-item" href="#" data-sr-print-mode="2" onclick="if(window.__doSalesReturnPrint){window.__doSalesReturnPrint(2);} return false;">طباعة أصل وصورة</a></li>
                                <li><a class="dropdown-item" href="#" data-sr-print-mode="3" onclick="if(window.__doSalesReturnPrint){window.__doSalesReturnPrint(3);} return false;">طباعة أصل وصورتين</a></li>
                            </ul>
                        </div>



                    </div>
                </div>
            </div>

            @* =========================
               العمود الرئيسي (الهيدر + العميل + الأصناف + الإجماليات)
               ========================= *@
            <div class="col-lg-10 order-first erp-print-area">

                @* ====================================================
                   1) كارت بيانات مرتجع البيع + العميل + المخزن
                   ==================================================== *@
                <div class="card shadow-sm mb-2 invoice-header-card">

                    @{
                        // لو SRId = 0 يبقى لسه مرتجع جديد (لسه ما اتسجلش في الداتا)
                        bool isNewReturn = Model.SRId == 0;

                        bool hasReturn = Model.SRId > 0;

                        // مرتجع بدون فاتورة: مسموح فقط إن لم يُربَط بهيدر بفاتورة ولم يُرحَّل
                        bool allowStandaloneMode = !Model.IsPosted && !Model.SalesInvoiceId.HasValue;
                        bool initialStandalone = (ViewBag.StandaloneReturn as bool?) == true;

                        // نص تاريخ/وقت المرتجع المعروضين في الكروت
                        string returnDateText = hasReturn
                        ? Model.SRDate.ToString("d/M/yyyy")
                        : "";

                        string returnTimeText = hasReturn
                        ? Model.SRTime.ToString(@"hh\:mm")
                        : "";
                    }

                    @* عنوان ثابت مثل فاتورة المبيعات — بدون رقم المرتجع أو المنشئ في الشريط *@
                    <div class="invoice-header-bar">
                        <h6 class="mb-0">مرتجع بيع</h6>
                    </div>

                    <div class="card-body sr-header-card-body">
                        @* RTL: أول عمود يمين الشاشة — رقم فاتورة البيع ثم كود العميل ثم اسم أضيق ثم باقي الحقول *@
                        <div class="row g-2 g-lg-3 align-items-end mb-2 sr-hdr-compact">
                            <div class="col-auto sr-invoice-no-wrap text-center">
                                <label for="SalesInvoiceIdInput" class="form-label form-label-sm">رقم فاتورة البيع</label>
                                <input type="number" id="SalesInvoiceIdInput" class="form-control form-control-sm text-center"
                                       value="@(Model.SalesInvoiceId?.ToString() ?? "")" placeholder="رقم" data-lock-posted="1"
                                       @(isNewReturn && !initialStandalone ? Html.Raw("autofocus") : Html.Raw("")) />
                                <input type="hidden" asp-for="SalesInvoiceId" id="SalesInvoiceId" />
                            </div>
                            <div class="col-auto" style="max-width: 5.5rem;">
                                <label class="form-label form-label-sm">كود العميل</label>
                                <input id="CustomerCodeDisplay"
                                       class="form-control form-control-sm text-center invoice-small-input"
                                       inputmode="numeric"
                                       placeholder="كود العميل"
                                       data-lock-posted="1" />
                                <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                                <input type="hidden" id="SRId" value="@Model.SRId" />
                                <input type="hidden" id="ReturnCreatedByDisplay" value="@Model.CreatedBy" />
                            </div>
                            <div class="col-lg-5 col-md-6 min-w-0">
                                <label for="CustomerNameInput" class="form-label form-label-sm">اسم العميل</label>
                                <div class="position-relative" id="srCustomerDropdownWrap">
                                    <div class="product-dropdown-onebox" id="srCustomerDropdownInputGroup">
                                        <span class="product-dropdown-arrow-inside" id="srCustomerDropdownArrow" title="افتح القائمة">▼</span>
                                        <input id="CustomerNameInput"
                                               type="text"
                                               name="sr_customer_search_no_autofill"
                                               class="form-control form-control-sm product-dropdown-input"
                                               placeholder="اكتب اسم العميل"
                                               autocomplete="new-password"
                                               autocorrect="off"
                                               autocapitalize="off"
                                               spellcheck="false"
                                               data-lock-posted="1" />
                                    </div>
                                    <div id="srCustomerDropdownList" class="product-dropdown-list" role="listbox" data-open="false"></div>
                                </div>
                                <div id="customerSuspendedMsg" class="small text-danger mt-1 d-none">⚠️ العميل موقوف — لا يمكن حفظ المرتجع.</div>
                            </div>
                            <div class="col-auto" style="max-width: 5.5rem;">
                                <label class="form-label form-label-sm">رقم المرتجع</label>
                                <input id="ReturnNumberDisplay"
                                       class="form-control form-control-sm text-center fw-semibold invoice-small-input"
                                       value="@(Model.SRId > 0 ? Model.SRId.ToString() : "—")" readonly />
                            </div>
                            <div class="col-lg-2 col-md-4">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">تاريخ المرتجع</label>
                                        <input id="ReturnDateDisplay" class="form-control form-control-sm text-center"
                                               value="@returnDateText" readonly />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">وقت المرتجع</label>
                                        <input id="ReturnTimeDisplay" class="form-control form-control-sm text-center"
                                               value="@returnTimeText" readonly />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row g-3 align-items-end">
                            <div class="col-lg-2 col-md-3">
                                <label class="form-label form-label-sm">حالة المرتجع</label>
                                @{
                                    int? stage = ViewBag.ReturnStage as int?;
                                    string statusDisplayValue = Model.Status switch
                                    {
                                        "Draft" => "غير مرحلة",
                                        "Posted" => (stage.HasValue ? $"مرحلة {stage.Value}" : "مرحلة 1"),
                                        "Cancelled" => "ملغى",
                                        _ => string.IsNullOrWhiteSpace(Model.Status) ? (Model.IsPosted ? (stage.HasValue ? $"مرحلة {stage.Value}" : "مرحلة 1") : "غير مرحلة") : Model.Status
                                    };
                                }
                                <input id="ReturnStatusDisplay" class="form-control form-control-sm text-center" value="@statusDisplayValue" readonly />
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <label class="form-label form-label-sm" for="WarehouseId">المخزن</label>
                                <select asp-for="WarehouseId" asp-items="ViewBag.Warehouses" data-lock-posted="1"
                                        class="form-select form-select-sm" data-is-posted="@(Model.IsPosted ? "1" : "0")">
                                    <option value="">اختر المخزن...</option>
                                </select>
                            </div>
                        </div>
                        @if (allowStandaloneMode)
                        {
                            <div class="form-check form-switch mt-2 mb-0" dir="rtl">
                                <input class="form-check-input" type="checkbox" id="srChkStandalone" data-lock-posted="1" @(initialStandalone ? "checked=\"checked\"" : "") />
                                <label class="form-check-label" for="srChkStandalone">مرتجع بدون فاتورة</label>
                            </div>
                        }
                    </div>
                </div>

                @* =====================================================
                   كارت إدخال الصنف في المرتجع
                   ===================================================== *@
                <div class="card shadow-sm mb-3 invoice-Add-card">
                    <div class="card-body">
                        @* وضع: من فاتورة بيع *@
                        <div id="srInvoiceAddPanel" class="@(initialStandalone && allowStandaloneMode ? "d-none" : "")">
                            <div class="row g-2 align-items-end">
                                <div class="col-lg-5 col-md-4">
                                    <label class="form-label form-label-sm">اختر صنف من فاتورة البيع</label>
                                    <select id="InvoiceItemSelect"
                                            class="form-select form-select-sm sr-invoice-item-select"
                                            data-lock-posted="@(Model.IsPosted ? "1" : "0")">
                                        <option value="">-- اختر صنف من الفاتورة --</option>
                                    </select>
                                </div>

                                <div class="col-auto">
                                    <label class="form-label form-label-sm">الكمية المرتجعة</label>
                                    <input type="number"
                                           id="ReturnQtyInput"
                                           class="form-control form-control-sm text-center return-line-field"
                                           placeholder="0"
                                           min="1"
                                           data-lock-posted="@(Model.IsPosted ? "1" : "0")" />
                                </div>

                                <div class="col-auto">
                                    <label class="form-label form-label-sm">الكمية في الفاتورة</label>
                                    <input type="number"
                                           id="InvoiceQtyDisplay"
                                           class="form-control form-control-sm text-center bg-light return-line-field"
                                           readonly />
                                </div>

                                <div class="col-auto">
                                    <label class="form-label form-label-sm">التشغيلة</label>
                                    <input type="text"
                                           id="ReturnBatchDisplay"
                                           class="form-control form-control-sm text-center bg-light return-line-field"
                                           readonly />
                                </div>

                                <div class="col-auto">
                                    <label class="form-label form-label-sm">تاريخ الصلاحية</label>
                                    <input type="text"
                                           id="ReturnExpiryDisplay"
                                           class="form-control form-control-sm text-center bg-light return-line-field"
                                           readonly />
                                </div>

                                <div class="col-lg-2 col-md-4 d-grid">
                                    <label class="form-label form-label-sm">&nbsp;</label>
                                    <button type="button"
                                            id="btnAddReturnLine"
                                            class="btn btn-primary btn-sm w-100"
                                            data-lock-posted="@(Model.IsPosted ? "1" : "0")">
                                        إضافة
                                    </button>
                                </div>
                            </div>
                        </div>

                        @* وضع: بدون فاتورة *@
                        @if (allowStandaloneMode)
                        {
                            <div id="srStandaloneAddPanel" class="@(initialStandalone ? "" : "d-none")">
                                <p class="small text-muted mb-2">ابحث عن الصنف بالاسم أو الكود أو الباركود (متعدد الكلمات)، ثم عيّن الكمية والتشغيلة والصلاحية وسعر الجمهور — نفس نمط فاتورة المبيعات.</p>
                                <div class="row g-2 align-items-end">
                                    <div class="col-lg-4 col-md-6 position-relative">
                                        <label class="form-label form-label-sm" for="srStandaloneProdNameInput">اسم الصنف</label>
                                        <div class="position-relative" id="srStandaloneProductDropdownWrap">
                                            <div class="product-dropdown-onebox" id="srStandaloneProductDropdownInputGroup">
                                                <span class="product-dropdown-arrow-inside" id="srStandaloneProductDropdownArrow" title="افتح القائمة">▼</span>
                                                <input type="text"
                                                       id="srStandaloneProdNameInput"
                                                       name="sr_standalone_product_search_no_autofill"
                                                       class="form-control form-control-sm product-dropdown-input"
                                                       placeholder="اختر صنفاً..."
                                                       autocomplete="new-password"
                                                       autocorrect="off"
                                                       autocapitalize="off"
                                                       spellcheck="false"
                                                       data-lock-posted="1" />
                                            </div>
                                            <div id="srStandaloneProductDropdownList" class="product-dropdown-list" role="listbox" data-open="false"></div>
                                        </div>
                                        <input type="hidden" id="srStandaloneProdId" value="" />
                                    </div>
                                    <div class="col-auto">
                                        <label class="form-label form-label-sm">سعر الجمهور</label>
                                        <input type="number" step="0.01" min="0" id="srStandalonePriceRetail" class="form-control form-control-sm text-center bg-light" value="0" readonly data-lock-posted="1" />
                                    </div>
                                    <div class="col-auto">
                                        <label class="form-label form-label-sm">خصم %</label>
                                        <input type="number" step="0.01" min="0" max="100" id="srStandaloneDisc1" class="form-control form-control-sm text-center" value="0" data-lock-posted="1" />
                                    </div>
                                    <div class="col-auto">
                                        <label class="form-label form-label-sm">الكمية</label>
                                        <input type="number" id="srStandaloneQtyInput" class="form-control form-control-sm text-center" placeholder="0" min="1" data-lock-posted="1" />
                                    </div>
                                    <div class="col-auto">
                                        <label class="form-label form-label-sm">التشغيلة</label>
                                        <input type="text" id="srStandaloneBatchInput" class="form-control form-control-sm text-center" data-lock-posted="1" />
                                    </div>
                                    <div class="col-auto">
                                        <label class="form-label form-label-sm">الصلاحية</label>
                                        <input type="text" id="srStandaloneExpiryInput" class="form-control form-control-sm text-center" placeholder="yyyy-MM-dd" data-lock-posted="1" />
                                    </div>
                                    <div class="col-lg-2 col-md-4 d-grid">
                                        <label class="form-label form-label-sm">&nbsp;</label>
                                        <button type="button" id="btnAddStandaloneLine" class="btn btn-primary btn-sm w-100" data-lock-posted="1">إضافة</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @* ==========================================
                   5) جدول سطور المرتجع — نفس أعمدة فاتورة المبيعات (PILinesTable)
                   ========================================== *@
                <div class="invoice-lines-container">
                    <div class="erp-table-wrapper mb-0">
                        <table id="SalesReturnLinesTable" class="table table-sm table-striped table-hover mb-0 erp-table">
                            <thead class="sr-return-lines-thead">
                                <tr>
                                    <th class="text-center">#</th>
                                    <th class="text-center">الموقع</th>
                                    <th>اسم الصنف</th>
                                    <th class="text-center">التشغيلة</th>
                                    <th class="text-center">الصلاحية</th>
                                    <th class="text-center">الكمية</th>
                                    <th class="text-center">سعر الجمهور</th>
                                    <th class="text-center">خصم البيع %</th>
                                    <th class="text-center">قيمة السطر</th>
                                </tr>
                            </thead>
                            <tbody id="SalesReturnLinesTableBody">
                                @if (Model.Lines != null && Model.Lines.Any())
                                {
                                    var _prodNames = ViewBag.ProdNames as Dictionary<int, string>;
                                    var _prodLocs = ViewBag.ProdLocations as Dictionary<int, string>;
                                    foreach (var line in Model.Lines.OrderBy(l => l.LineNo))
                                    {
                                        var prodName = (_prodNames != null && _prodNames.TryGetValue(line.ProdId, out var _pn)) ? _pn : ("صنف #" + line.ProdId);
                                        var locDisp = (_prodLocs != null && _prodLocs.TryGetValue(line.ProdId, out var _pl) && !string.IsNullOrWhiteSpace(_pl)) ? _pl : "—";
                                        <tr class="erp-list-selectable-row" data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                            <td class="text-center">@line.LineNo</td>
                                            <td class="text-center text-muted small">@locDisp</td>
                                            <td>
                                                <strong>@prodName</strong>
                                                <span class="text-muted small"> | كود: @line.ProdId</span>
                                            </td>
                                            <td class="text-center">@(line.BatchNo ?? "")</td>
                                            <td class="text-center">@(line.Expiry.HasValue ? line.Expiry.Value.ToString("yyyy-MM-dd") : "")</td>
                                            <td class="text-center">@line.Qty</td>
                                            <td class="text-center">@line.PriceRetail.ToString("0.00")</td>
                                            <td class="text-center">@line.Disc1Percent.ToString("0.##")</td>
                                            <td class="text-center">@line.LineTotalAfterDiscount.ToString("0.00")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr id="SalesReturnLinesEmptyRow">
                                        <td colspan="9" class="text-center text-muted py-4">
                                            لا توجد سطور مسجَّلة لهذا المرتجع في هذه المرحلة.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @* ====================================
                   6) ملخص إجماليات المرتجع — ثلاثة كروت: قبل الضريبة / الضريبة / بعد الضريبة
                   ==================================== *@
                <div class="card shadow-sm invoice-totals-card mb-2">
                    <div class="card-body">
                        <div class="d-flex flex-wrap align-items-stretch justify-content-between gap-2 invoice-summary-row">
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">الإجمالي قبل الضريبة</span>
                                <span id="TotalBeforeTaxBadge" class="invoice-summary-value">@Model.TotalAfterDiscountBeforeTax.ToString("0.00")</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">قيمة الضريبة</span>
                                <span id="TaxAmountBadge" class="invoice-summary-value">@Model.TaxAmount.ToString("0.00")</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box invoice-summary-box-main">
                                <span class="invoice-summary-label">الإجمالي بعد الضريبة</span>
                                <span id="NetTotalBadge" class="invoice-summary-value invoice-summary-value-main fw-bold">@Model.NetTotal.ToString("0.00")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="piPrintWrapper" class="erp-print-area print-only">
                    <div id="piPrintArea" class="pi-print-copy">
                        <table class="pi-print-master-table table table-bordered table-sm mb-0 w-100">
                            <thead>
                                <tr>
                                    <td colspan="9" class="p-0 border-0 pi-print-thead-banner-cell">
                                        <div class="pi-print-header mb-2">
                                            <div class="pi-print-company-row d-flex justify-content-between align-items-center">
                                                <div class="pi-print-logo-placeholder">
                                                    @if (!string.IsNullOrWhiteSpace(ViewBag.PrintHeaderLogoUrl as string))
                                                    {
                                                        <img src="@((string)ViewBag.PrintHeaderLogoUrl)" alt="logo" style="max-width:80px; max-height:36px;" />
                                                    }
                                                </div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <h2 class="pi-print-company-name mb-0 fw-bold">@((string?)ViewBag.PrintHeaderCompanyName ?? "شركة الهدى")</h2>
                                                    <span class="pi-print-doc-title">ERP — مرتجع بيع</span>
                                                </div>
                                            </div>
                                            <hr class="pi-print-company-underline my-1" />
                                            <div class="pi-print-details-grid small w-100" role="presentation">
                                                <div>اسم العميل: <strong id="piPrintSupplier"></strong></div>
                                                <div>الكاتب: <strong id="piPrintAuthor"></strong></div>
                                                <div>المخزن: <strong id="piPrintWarehouse"></strong></div>
                                                <div>التاريخ: <strong id="piPrintInvoiceDate"></strong></div>
                                                <div>الهاتف: <strong id="piPrintCustomerPhone"></strong></div>
                                                <div>رقم المرتجع: <strong id="piPrintInvoiceNo"></strong></div>
                                                <div class="pi-print-details-cell-span2" aria-hidden="true"></div>
                                                <div class="pi-print-details-span-row">العنوان: <strong id="piPrintCustomerAddress"></strong></div>
                                                <div class="pi-print-details-span-row text-muted small" id="piPrintNow"></div>
                                            </div>
                                        </div>
                                        <hr class="my-1 pi-print-hr-after-banner" />
                                    </td>
                                </tr>
                                <tr class="pi-print-column-head-row table-light">
                                    <th class="text-center">#</th>
                                    <th class="text-center">الموقع</th>
                                    <th>اسم الصنف</th>
                                    <th class="text-center">التشغيلة</th>
                                    <th class="text-center">الصلاحية</th>
                                    <th class="text-center">الكمية</th>
                                    <th class="text-center">سعر الجمهور</th>
                                    <th class="text-center">خصم البيع %</th>
                                    <th class="text-center">قيمة السطر</th>
                                </tr>
                            </thead>
                            <tbody id="piPrintMasterTbody" class="pi-print-master-tbody"></tbody>
                        </table>
                        <div id="piPrintTotalsWrap" class="pi-print-totals-block mt-2"></div>
                    </div>
                </div>

                @* قوائم الأوتوكومبليت الثقيلة: في آخر العمود الرئيسي حتى يكتمل رسم الكروت دفعة واحدة *@
                <datalist id="customersList" hidden aria-hidden="true">
                    @if (ViewBag.Customers != null)
                    {
                        foreach (var c in ViewBag.Customers)
                        {
                            <option value="@c.Name"
                                    data-id="@c.Id"
                                    data-is-active="1"
                                    data-policy="@c.PolicyName"
                                    data-user="@c.UserName"
                                    data-phone="@c.Phone"
                                    data-address="@c.Address"
                                    data-credit="@c.CreditLimit">
                            </option>
                        }
                    }
                </datalist>
                @if (allowStandaloneMode)
                {
                    <datalist id="srStandaloneProductsList" hidden aria-hidden="true"></datalist>
                }

            </div>

        </div>

    </div>
</div>

@section Scripts {
    <script>
        // تعبئة بيانات العميل — من سجل مشتق من الـ datalist (نفس نمط فاتورة المبيعات)
        function fillCustomerFromRecord(rec) {
            var idInput = document.getElementById('CustomerId');
            var codeDisplay = document.getElementById('CustomerCodeDisplay');
            var policyInput = document.getElementById('PolicyName');
            var userInput = document.getElementById('LinkedUserName');
            var phoneInput = document.getElementById('CustomerPhone');
            var addressInput = document.getElementById('CustomerAddress');
            var creditInput = document.getElementById('CustomerCreditLimit');
            var summary = document.getElementById('CustomerSummaryText');
            var suspendedMsg = document.getElementById('customerSuspendedMsg');
            var saveBtn = document.getElementById('btnSaveReturnHeader');

            if (!rec) {
                if (idInput) idInput.value = '';
                if (codeDisplay) codeDisplay.value = '';
                if (policyInput) policyInput.value = '';
                if (userInput) userInput.value = '';
                if (phoneInput) phoneInput.value = '';
                if (addressInput) addressInput.value = '';
                if (creditInput) creditInput.value = '';
                if (summary) summary.textContent = '';
                if (suspendedMsg) suspendedMsg.classList.add('d-none');
                if (saveBtn) saveBtn.disabled = false;
                return;
            }

            var id = (rec.id || '').toString();
            var policy = (rec.policy || '').toString();
            var user = (rec.user || '').toString();
            var phone = (rec.phone || '').toString();
            var address = (rec.address || '').toString();
            var credit = (rec.credit || '').toString();
            var isActive = ((rec.isActive || '1') === '1');

            if (idInput) idInput.value = id;
            if (codeDisplay) codeDisplay.value = id;
            if (policyInput) policyInput.value = policy;
            if (userInput) userInput.value = user;
            if (phoneInput) phoneInput.value = phone;
            if (addressInput) addressInput.value = address;
            if (creditInput) creditInput.value = credit;
            if (summary) {
                var parts = [];
                if (policy) parts.push('سياسة: ' + policy);
                if (user) parts.push('مستخدم: ' + user);
                if (credit) parts.push('حد ائتماني: ' + credit);
                summary.textContent = parts.join(' — ');
            }
            if (suspendedMsg) suspendedMsg.classList.toggle('d-none', isActive);
            if (saveBtn) saveBtn.disabled = !isActive;
        }

        function fillCustomerFromOption(opt) {
            if (!opt) {
                fillCustomerFromRecord(null);
                return;
            }
            fillCustomerFromRecord({
                id: opt.getAttribute('data-id') || '',
                policy: opt.getAttribute('data-policy') || '',
                user: opt.getAttribute('data-user') || '',
                phone: opt.getAttribute('data-phone') || '',
                address: opt.getAttribute('data-address') || '',
                credit: opt.getAttribute('data-credit') || '',
                isActive: (opt.getAttribute('data-is-active') || '1').toString()
            });
        }

        /** بحث عن خيار العميل في datalist العملاء — خارج IIFE الأوتوكومبليت ليُستدعى من loadInvoiceByNumber */
        function findCustomerDatalistOptionById(id) {
            if (!id) return null;
            var dl = document.getElementById('customersList');
            if (!dl || !dl.options) return null;
            var options = dl.options;
            for (var i = 0; i < options.length; i++) {
                if (options[i].getAttribute('data-id') == id) return options[i];
            }
            return null;
        }

        document.addEventListener('DOMContentLoaded', function () {
            // فتح شاشة المرتجع: عند الطلب من فاتورة البيع يكون الفوكس على الصنف مباشرة
            setTimeout(function () {
                var qs = new URLSearchParams(window.location.search || '');
                var focusProduct = (qs.get('focusProduct') || '').toString() === '1';
                if (focusProduct) {
                    var standaloneProdName = document.getElementById('srStandaloneProdNameInput');
                    if (standaloneProdName) {
                        standaloneProdName.focus();
                        if (typeof standaloneProdName.select === 'function') standaloneProdName.select();
                        return;
                    }

                    var invoiceItemSelect = document.getElementById('InvoiceItemSelect');
                    if (invoiceItemSelect) {
                        invoiceItemSelect.focus();
                        if (typeof invoiceItemSelect.click === 'function') invoiceItemSelect.click();
                        return;
                    }
                }

                var standaloneMode = (typeof isStandaloneMode === 'function' && isStandaloneMode());
                if (standaloneMode) {
                    var custCode = document.getElementById('CustomerCodeDisplay');
                    if (custCode) {
                        custCode.focus();
                        if (typeof custCode.select === 'function') custCode.select();
                        return;
                    }
                }

                var custName = document.getElementById('CustomerNameInput');
                if (custName) {
                    custName.focus();
                    if (typeof custName.select === 'function') custName.select();
                }
            }, 120);

            function showToast(text, type, durationMs) {
                if (!text) return;
                if (typeof ERP !== 'undefined' && typeof ERP.showToast === 'function') {
                    ERP.showToast(text, type, durationMs);
                    return;
                }
                var container = document.getElementById('srToastContainer');
                if (!container) return;
                type = type || 'muted';
                var ms = typeof durationMs === 'number' && durationMs >= 0 ? durationMs : 4000;
                var el = document.createElement('div');
                el.className = 'sr-toast text-' + type;
                el.textContent = text;
                container.appendChild(el);
                setTimeout(function () {
                    el.style.opacity = '0';
                    el.style.transition = 'opacity 0.25s ease';
                    setTimeout(function () {
                        if (el.parentNode) el.parentNode.removeChild(el);
                    }, 250);
                }, ms);
            }

            /** رسالة نجاح مسح السطر: وسط الشاشة، خلفية خضراء + ✓ لمدة ثانية واحدة */
            function showLineDeletedSuccessFlash() {
                var el = document.createElement('div');
                el.className = 'sr-line-deleted-flash';
                el.setAttribute('role', 'status');
                el.innerHTML = '<span class="sr-line-deleted-flash__icon" aria-hidden="true">✓</span><span class="sr-line-deleted-flash__text"></span>';
                var textEl = el.querySelector('.sr-line-deleted-flash__text');
                if (textEl) textEl.textContent = 'تم مسح السطر بنجاح';
                document.body.appendChild(el);
                setTimeout(function () {
                    el.style.opacity = '0';
                    setTimeout(function () {
                        if (el.parentNode) el.parentNode.removeChild(el);
                    }, 280);
                }, 1000);
            }

            function syncDeleteSelectedReturnLineButton() {
                var btn = document.getElementById('btnDeleteSelectedReturnLine');
                var tbody = document.getElementById('SalesReturnLinesTableBody');
                if (!btn || !tbody) return;
                if (typeof isReturnPosted === 'function' && isReturnPosted()) {
                    btn.disabled = true;
                    return;
                }
                var sel = tbody.querySelector('tr.erp-list-selectable-row.selected');
                btn.disabled = !sel;
            }

            // تحويل حالة المرتجع من السيرفر (Draft/Posted/Cancelled) إلى النص المعروض
            function getReturnStatusDisplay(status) {
                if (!status) return 'غير مرحلة';
                switch (String(status)) {
                    case 'Draft': return 'غير مرحلة';
                    case 'Posted': return 'مرحلة 1';
                    case 'Cancelled': return 'ملغى';
                    default: return status;
                }
            }

            // =========================================================
            // دوال مساعدة: إدارة حالة الترحيل (مثل فاتورة المبيعات)
            // =========================================================
            function isReturnPosted() {
                const flag = document.getElementById("ReturnIsPostedFlag");
                return flag && flag.value === "1";
            }

            function setReturnPosted(posted) {
                const flag = document.getElementById("ReturnIsPostedFlag");
                if (flag) flag.value = posted ? "1" : "0";
            }

            function applyPostedUiLock() {
                const posted = isReturnPosted();
                const lockables = document.querySelectorAll('[data-lock-posted="1"]');

                lockables.forEach(el => {
                    if (!el.dataset.origDisabled) {
                        el.dataset.origDisabled = el.disabled ? "1" : "0";
                    }
