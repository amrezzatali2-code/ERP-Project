@using ERP.Models
@model SalesReturn
@{
    ViewData["Title"] = $"تفاصيل مرتجع: {Model.SRId}";
    var lines = (IEnumerable<SalesReturnLine>)(ViewBag.Lines ?? Enumerable.Empty<SalesReturnLine>());
    var cnt = (int)(ViewBag.LinesCount ?? 0);
}

<h2 class="mb-3">تفاصيل مرتجع البيع — @Model.SRId</h2>

<div class="card mb-3">
    <div class="card-body">
        <div class="row gy-2">
            <div class="col-md-3"><b>التاريخ:</b> @Model.SRDate.ToString("yyyy-MM-dd") @Model.SRTime</div>
            <div class="col-md-3"><b>العميل:</b> @Model.CustomerId</div>
            <div class="col-md-3"><b>المخزن:</b> @Model.WarehouseId</div>
            <div class="col-md-3"><b>الحالة:</b> @Model.Status</div>

            <div class="col-md-3"><b>إجمالي قبل الخصم:</b> @Model.TotalBeforeDiscount.ToString("0.00")</div>
            <div class="col-md-3"><b>إجمالي بعد الخصم قبل الضريبة:</b> @Model.TotalAfterDiscountBeforeTax.ToString("0.00")</div>
            <div class="col-md-3"><b>الضريبة:</b> @Model.TaxAmount.ToString("0.00")</div>
            <div class="col-md-3"><b>الصافي:</b> @Model.NetTotal.ToString("0.00")</div>

            <div class="col-md-3"><b>خصم الهيدر (%):</b> @Model.HeaderDiscountPercent</div>
            <div class="col-md-3"><b>خصم الهيدر (قيمة):</b> @Model.HeaderDiscountValue.ToString("0.00")</div>
            <div class="col-md-3"><b>أنشأه:</b> @Model.CreatedBy</div>
            <div class="col-md-3"><b>أُنشئ في:</b> @Model.CreatedAt</div>
        </div>
    </div>
</div>

<h5 class="mb-2">السطور (@cnt)</h5>
<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>سطر</th>
            <th>الصنف</th>
            <th class="text-end">الكمية</th>
            <th class="text-end">سعر الجمهور</th>
            <th class="text-end">صافي السطر</th>
            <th>التشغيلة</th>
            <th>الصلاحية</th>
        </tr>
    </thead>
    <tbody>
        @if (!lines.Any())
        {
            <tr><td colspan="7" class="text-center text-muted">لا توجد سطور.</td></tr>
        }
        else
        {
            foreach (var l in lines)
            {
                <tr>
                    <td>@l.LineNo</td>
                    <td>@l.ProdId</td>
                    <td class="text-end">@l.Qty</td>
                    <td class="text-end">@l.PriceRetail.ToString("0.00")</td>
                    <td class="text-end">@l.LineNetTotal.ToString("0.00")</td>
                    <td>@l.BatchNo</td>
                    <td>@(l.Expiry?.ToString("yyyy-MM") ?? "")</td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="mt-3">
    <a class="btn btn-secondary" asp-action="Index">رجوع</a>
</div>
