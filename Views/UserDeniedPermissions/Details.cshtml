@model ERP.Models.UserDeniedPermission

@{
    ViewData["Title"] = "تفاصيل استثناء صلاحية";
    var userName = Model.User?.DisplayName ?? Model.User?.UserName ?? "";
    var permName = Model.Permission?.NameAr ?? "";
    var permCode = Model.Permission?.Code ?? "";
}

<div class="container" dir="rtl">
    <h2 class="mb-3">تفاصيل استثناء صلاحية — @Model.Id</h2>

    <div class="card">
        <div class="card-body">
            <dl class="row">

                <dt class="col-sm-3">المعرّف</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">المستخدم</dt>
                <dd class="col-sm-9">
                    @userName (@Model.UserId)
                </dd>

                <dt class="col-sm-3">الصلاحية</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(permCode))
                    {
                        @($"{permName} ({permCode})")
                    }
                    else
                    {
                        @permName
                    }
                </dd>

                <dt class="col-sm-3">سماح/منع</dt>
                <dd class="col-sm-9">
                    @(Model.IsAllowed ? "سماح (Allow)" : "منع (Deny)")
                </dd>

                <dt class="col-sm-3">تاريخ الإضافة</dt>
                <dd class="col-sm-9">
                    @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                </dd>
            </dl>
        </div>

        <div class="card-footer d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">رجوع للقائمة</a>
            <div>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">تعديل</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger ms-2">حذف</a>
            </div>
        </div>
    </div>
</div>
