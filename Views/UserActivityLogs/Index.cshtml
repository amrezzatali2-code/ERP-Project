@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<UserActivityLog>

@{
    ViewData["Title"] = "سجل نشاط المستخدمين";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "UserActivityLogs";

    var searchRaw = Model.Search ?? (string?)ViewBag.Search ?? "";
    // منع عرض أسماء أعمدة الترتيب في حقل البحث (مثل ActionTime)
    var sortCols = new[] { "Id", "UserName", "ActionType", "EntityName", "EntityId", "ActionTime", "IpAddress" };
    var search = (!string.IsNullOrEmpty(searchRaw) && sortCols.Contains(searchRaw.Trim(), StringComparer.OrdinalIgnoreCase)) ? "" : searchRaw;
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var searchMode = (string?)ViewBag.SearchMode ?? "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "ActionTime";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;
    var dateField = (string?)ViewBag.DateField ?? "ActionTime";

    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_user = ViewBag.FilterCol_User as string;
    string? filterCol_action = ViewBag.FilterCol_Action as string;
    string? filterCol_entity = ViewBag.FilterCol_Entity as string;
    string? filterCol_entityId = ViewBag.FilterCol_EntityId as string;
    string? filterCol_entityIdExpr = ViewBag.FilterCol_EntityIdExpr as string;
    string? filterCol_time = ViewBag.FilterCol_Time as string;
    string? filterCol_ip = ViewBag.FilterCol_Ip as string;
    string? filterCol_desc = ViewBag.FilterCol_Desc as string;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        dateField,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_idExpr,
        filterCol_user,
        filterCol_action,
        filterCol_entity,
        filterCol_entityId,
        filterCol_entityIdExpr,
        filterCol_time,
        filterCol_ip,
        filterCol_desc
    })!;

    string? FilterForCol(string colKey) => colKey == "id" ? (!string.IsNullOrWhiteSpace(filterCol_idExpr) ? filterCol_idExpr : filterCol_id) : colKey == "user" ? filterCol_user : colKey == "action" ? filterCol_action : colKey == "entity" ? filterCol_entity : colKey == "entityId" ? (!string.IsNullOrWhiteSpace(filterCol_entityIdExpr) ? filterCol_entityIdExpr : filterCol_entityId) : colKey == "time" ? filterCol_time : colKey == "ip" ? filterCol_ip : colKey == "desc" ? filterCol_desc : null;

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

@functions {
    private string EntityNameToArabic(string? en)
    {
        if (string.IsNullOrWhiteSpace(en)) return "";
        var map = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["CashReceipt"] = "إذن استلام نقدية",
            ["CashPayment"] = "إذن دفع",
            ["SalesInvoice"] = "فاتورة مبيعات",
            ["PurchaseInvoice"] = "فاتورة مشتريات",
            ["PurchaseRequest"] = "طلب شراء",
            ["PurchaseRequests"] = "طلبات شراء",
            ["Product"] = "صنف",
            ["User"] = "مستخدم",
            ["Customer"] = "عميل",
            ["Category"] = "فئة",
            ["Warehouse"] = "مخزن",
            ["Account"] = "حساب",
            ["LedgerEntry"] = "قيد محاسبي",
            ["StockLedger"] = "دفتر الحركة المخزنية",
            ["PILine"] = "سطر فاتورة مشتريات",
            ["SILine"] = "سطر فاتورة مبيعات",
            ["SalesInvoiceLine"] = "سطر فاتورة مبيعات",
            ["SalesInvoiceLines"] = "سطور فاتورة مبيعات",
            ["SalesInvoices"] = "فواتير مبيعات",
            ["PurchaseInvoices"] = "فواتير مشتريات",
            ["PurchaseInvoiceLine"] = "سطر فاتورة مشتريات",
            ["SalesOrder"] = "أمر بيع",
            ["SalesOrderLine"] = "سطر أمر بيع",
            ["SalesReturn"] = "مرتجع بيع",
            ["PurchaseReturn"] = "مرتجع شراء",
            ["DebitNote"] = "إشعار خصم",
            ["CreditNote"] = "إشعار إضافة",
            ["StockTransfer"] = "تحويل مخزني",
            ["ProductDiscountOverride"] = "خصم يدوي للصنف",
            ["DocumentSeries"] = "سلسلة مستندات",
            ["SalesReturnLine"] = "سطر مرتجع بيع",
            ["PurchaseReturnLine"] = "سطر مرتجع شراء",
            ["StockAdjustment"] = "تسوية مخزنية",
            ["Batch"] = "تشغيلة",
            ["Governorate"] = "محافظة",
            ["District"] = "مديرية",
            ["Area"] = "منطقة",
            ["NumberSeries"] = "سلاسل الترقيم",
            ["Policy"] = "سياسة",
            ["Invoice"] = "فاتورة",
            ["Permission"] = "صلاحية",
            ["Role"] = "دور",
            ["Branch"] = "فرع",
            ["City"] = "مدينة",
            ["ProductGroup"] = "مجموعة أصناف",
            ["StockAdjustmentLine"] = "سطر تسوية مخزنية",
            ["PRLine"] = "سطر طلب شراء",
            ["SOLine"] = "سطر أمر بيع"
        };
        return map.TryGetValue(en.Trim(), out var ar) ? ar : en;
    }

    /// <summary>تحويل مفاتيح ومصطلحات الوصف الإنجليزية إلى عربية للعرض.</summary>
    private string DescriptionToArabic(string? desc)
    {
        if (string.IsNullOrWhiteSpace(desc)) return "";
        var opt = System.Text.RegularExpressions.RegexOptions.IgnoreCase;
        var s = desc;
        // عبارات مركبة أولاً
        s = System.Text.RegularExpressions.Regex.Replace(s, @"Bulk/DeleteAll", "حذف جماعي / حذف الكل", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bDeleteAll\b", "حذف الكل", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bBulkDelete\b", "حذف جماعي", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bBulk\b", "جماعي", opt);
        // مفاتيح بالصيغة Key=
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bStockLedger\s*=", "قيود دفتر الحركة=", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bLines\s*=", "عدد السطور=", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bSIId\s*=", "رقم الفاتورة=", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bSlId\s*=", "رقم السطر=", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bProdId\s*=", "كود الصنف=", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bQty\s*=", "الكمية=", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bSegments\s*=", "الشرائح=", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bLineNo\s*=", "رقم السطر=", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bClearAllLines\b", "مسح كل السطور", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bLinesCount\s*=", "عدد السطور=", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bPIId\s*=", "رقم فاتورة المشتريات=", opt);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"\bPRId\s*=", "رقم طلب الشراء=", opt);
        return s;
    }

    private string FormatActivityValues(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return "-";

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var root = doc.RootElement;

            if (root.ValueKind == System.Text.Json.JsonValueKind.Object)
            {
                var parts = new List<string>();

                foreach (var prop in root.EnumerateObject())
                {
                    string key = prop.Name;
                    var valEl = prop.Value;

                    // تخطي الحقول غير المهمة في أغلب الكيانات (DisplayName / Email)
                    if (string.Equals(key, "DisplayName", StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(key, "Email", StringComparison.OrdinalIgnoreCase))
                        continue;

                    if (valEl.ValueKind == System.Text.Json.JsonValueKind.Null)
                        continue;

                    string valueText = valEl.ValueKind switch
                    {
                        System.Text.Json.JsonValueKind.String => valEl.GetString() ?? "",
                        System.Text.Json.JsonValueKind.Number => valEl.GetRawText(),
                        System.Text.Json.JsonValueKind.True => "نعم",
                        System.Text.Json.JsonValueKind.False => "لا",
                        _ => valEl.GetRawText()
                    };

                    if (string.IsNullOrWhiteSpace(valueText) || string.Equals(valueText, "null", StringComparison.OrdinalIgnoreCase))
                        continue;

                    // أسماء عربية للحقول المعروفة (إذن استلام/إذن دفع: المبلغ قبل والمبلغ بعد)
                    string label = key switch
                    {
                        "UserName" => "الاسم",
                        "IsActive" => "نشط؟",
                        "IsAdmin" => "أدمن؟",
                        "Amount" => "المبلغ",
                        "ReceiptDate" => "تاريخ الإذن",
                        "PaymentDate" => "تاريخ الدفع",
                        "Description" => "البيان",
                        "PolicyId" => "سياسة العميل (رقم)",
                        "CustomerName" => "اسم العميل",
                        "PartyCategory" => "نوع الطرف",
                        "CreditLimit" => "الحد الائتماني",
                        _ => key
                    };

                    parts.Add($"{label}: {valueText}");
                }

                if (parts.Count == 0)
                    return "-";

                var joined = string.Join(" | ", parts);
                return joined.Length > 80 ? joined.Substring(0, 80) + "..." : joined;
            }

            // لو مش Object (مثلاً نص عادي) نرجعه كما هو مع اختصار
            return json.Length > 80 ? json.Substring(0, 80) + "..." : json;
        }
        catch
        {
            // فى حالة JSON غير صالح نعرض النص الخام مختصرًا
            return json.Length > 140 ? json.Substring(0, 140) + "..." : json;
        }
    }
}

<div dir="rtl" class="container-fluid">

    @* العنوان + إجمالي السجلات (نمط القوائم) *@
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <small class="text-muted d-none d-md-inline">إجمالي السجلات: @total</small>
    </div>

    @* ===== شريط الفلاتر الموحد (نمط القوائم) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث (نفس نمط قائمة العملاء: وضع النص + حقل + البحث في، ثم عرض/إلغاء) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في سجل النشاط</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100" style="overflow-x:auto;">
                        <select name="searchMode" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:110px;min-width:100px">
                            <option value="starts"@Html.Raw(searchMode == "starts" ? " selected" : "")>يبدأ بـ</option>
                            <option value="contains"@Html.Raw(searchMode == "contains" || string.IsNullOrEmpty(searchMode) ? " selected" : "")>يحتوي</option>
                            <option value="ends"@Html.Raw(searchMode == "ends" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                        <input type="text" name="search" class="form-control erp-filter-input flex-shrink-1" placeholder="نص أو رقم..." value="@search" style="min-width:100px;max-width:200px;width:180px;" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:160px;min-width:130px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>البحث في الكل</option>
                            <option value="user"@Html.Raw(searchBy == "user" ? " selected" : "")>المستخدم</option>
                            <option value="action"@Html.Raw(searchBy == "action" ? " selected" : "")>نوع العملية</option>
                            <option value="entity"@Html.Raw(searchBy == "entity" ? " selected" : "")>اسم الكيان</option>
                            <option value="description"@Html.Raw(searchBy == "description" ? " selected" : "")>الوصف</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>رقم السجل</option>
                        </select>
                    </div>
                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-2 w-100">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_action)) { <input type="hidden" name="filterCol_action" value="@filterCol_action" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_entity)) { <input type="hidden" name="filterCol_entity" value="@filterCol_entity" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_entityId)) { <input type="hidden" name="filterCol_entityId" value="@filterCol_entityId" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_entityIdExpr)) { <input type="hidden" name="filterCol_entityIdExpr" value="@filterCol_entityIdExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_time)) { <input type="hidden" name="filterCol_time" value="@filterCol_time" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_ip)) { <input type="hidden" name="filterCol_ip" value="@filterCol_ip" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_desc)) { <input type="hidden" name="filterCol_desc" value="@filterCol_desc" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر رقم السجل من/إلى --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">رقم السجل من / إلى</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم (صفّين) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center">

                    @* الصف الأول: فلترة، اختيار أعمدة، طباعة *@
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center">
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModalActivity">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalActivity">اختيار الأعمدة</button>
                        <button type="button" id="btnPrintActivity" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                    </div>

                    @* الصف الثاني: التصدير فقط *@
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center mt-2 align-items-center">
                        <form method="get" asp-action="Export" asp-controller="UserActivityLogs" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="searchMode" value="@searchMode" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="dateField" value="@dateField" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_action)) { <input type="hidden" name="filterCol_action" value="@filterCol_action" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_entity)) { <input type="hidden" name="filterCol_entity" value="@filterCol_entity" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_entityId)) { <input type="hidden" name="filterCol_entityId" value="@filterCol_entityId" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_entityIdExpr)) { <input type="hidden" name="filterCol_entityIdExpr" value="@filterCol_entityIdExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_time)) { <input type="hidden" name="filterCol_time" value="@filterCol_time" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_ip)) { <input type="hidden" name="filterCol_ip" value="@filterCol_ip" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_desc)) { <input type="hidden" name="filterCol_desc" value="@filterCol_desc" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;" title="اختر صيغة التصدير">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>

    @* ===== جدول سجل النشاط (نمط القوائم: حاوية تمرير، رأس ثابت، أعمدة قابلة للفلترة والتوسعة) ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0" dir="rtl">
        <div id="activityTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
            <table id="activityTable" class="table table-striped table-hover erp-table erp-table-sortable">
                <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                    <tr>
                        <th data-col="id">@filterableCol("id", "Id", "المعرّف")</th>
                        <th data-col="user">@filterableCol("user", "UserName", "المستخدم")</th>
                        <th data-col="action">@filterableCol("action", "ActionType", "نوع العملية")</th>
                        <th data-col="entity">@filterableCol("entity", "EntityName", "اسم الكيان")</th>
                        <th data-col="entityId">@filterableCol("entityId", "EntityId", "رقم السجل")</th>
                        <th data-col="time">@filterableCol("time", "ActionTime", "وقت العملية")</th>
                        <th data-col="ip">@filterableCol("ip", "IpAddress", "عنوان IP")</th>
                        <th data-col="agent">المتصفح / الجهاز</th>
                        <th data-col="desc">@filterableCol("desc", "ActionTime", "الوصف")</th>
                        <th data-col="old">قبل</th>
                        <th data-col="new">بعد</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="11" class="text-center text-muted py-4">لا توجد بيانات.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var r in Model.Items)
                        {
                            <tr>
                                <td data-col="id">@r.Id</td>
                                <td data-col="user">@(r.User?.DisplayName ?? r.User?.UserName ?? "")</td>
                                <td data-col="action">@r.ActionType</td>
                                <td data-col="entity">@EntityNameToArabic(r.EntityName)</td>
                                <td data-col="entityId">@r.EntityId</td>
                                <td data-col="time">@r.ActionTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td data-col="ip">@r.IpAddress</td>
                                <td data-col="agent">@r.UserAgent</td>
                                <td data-col="desc">@DescriptionToArabic(r.Description)</td>
                                <td data-col="old" class="text-muted small">@FormatActivityValues(r.OldValues)</td>
                                <td data-col="new" class="text-muted small">@FormatActivityValues(r.NewValues)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ===== لوحة فلتر العمود (بنمط Excel) ===== *@
    <div id="erpColumnFilterPanelActivity" class="erp-column-filter-panel d-none" dir="rtl">
        <div class="erp-column-filter-header">
            <span id="erpColumnFilterTitleActivity">ترتيب وفلتر</span>
            <button type="button" class="btn-close btn-sm" id="erpColumnFilterCloseActivity" aria-label="إغلاق"></button>
        </div>
        <div class="erp-column-filter-body">
            <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                <label class="form-label small mb-1 fw-bold">الترتيب:</label>
                <div class="d-flex flex-column gap-1">
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
                </div>
            </div>
            <div class="erp-filter-section">
                <div id="erpColumnFilterSearchRowActivity">
                    <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                    <input type="text" id="erpColumnFilterSearchActivity" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                </div>
                <div id="erpColumnFilterListActivity" class="erp-column-filter-list">
                    <div class="text-muted text-center py-3">جاري التحميل...</div>
                </div>
            </div>
            <div class="erp-column-filter-actions">
                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOkActivity">تطبيق</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClearActivity">مسح الفلتر</button>
            </div>
        </div>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة (نفس المستخدمين) ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print" dir="rtl">
        <small class="text-muted text-start">عرض @start - @end من @total</small>
        <form method="get" action="@Url.Action(action, controller)" class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="searchMode" value="@searchMode" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_action)) { <input type="hidden" name="filterCol_action" value="@filterCol_action" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_entity)) { <input type="hidden" name="filterCol_entity" value="@filterCol_entity" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_entityId)) { <input type="hidden" name="filterCol_entityId" value="@filterCol_entityId" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_entityIdExpr)) { <input type="hidden" name="filterCol_entityIdExpr" value="@filterCol_entityIdExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_time)) { <input type="hidden" name="filterCol_time" value="@filterCol_time" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_ip)) { <input type="hidden" name="filterCol_ip" value="@filterCol_ip" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_desc)) { <input type="hidden" name="filterCol_desc" value="@filterCol_desc" /> }
            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="10" selected="@(ps == 10 ? "selected" : null)">10</option>
                <option value="25" selected="@(ps == 25 ? "selected" : null)">25</option>
                <option value="50" selected="@(ps == 50 ? "selected" : null)">50</option>
                <option value="100" selected="@(ps == 100 ? "selected" : null)">100</option>
                <option value="200" selected="@(ps == 200 ? "selected" : null)">200</option>
                <option value="0" selected="@(ps == 0 ? "selected" : null)">الكل</option>
            </select>
        </form>
    </div>

    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")"><a class="page-link" href="@Link(first)">الأول</a></li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")"><a class="page-link" href="@Link(prev)">السابق</a></li>
            <li class="page-item disabled"><span class="page-link">صفحة @(page) من @(pages)</span></li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")"><a class="page-link" href="@Link(next)">التالي</a></li>
            <li class="page-item @(page == last ? "disabled" : "")"><a class="page-link" href="@Link(last)">الأخير</a></li>
        </ul>
    </nav>
</div>

