@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<UserActivityLog>

@{
    ViewData["Title"] = "سجل نشاط المستخدمين";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "UserActivityLogs";

    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "ActionTime";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;
    var dateField = (string?)ViewBag.DateField ?? "ActionTime";

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        dateField,
        fromCode,
        toCode
    })!;

    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate,
            dateField,
            fromCode,
            toCode
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };
}

<div dir="rtl" class="container-fluid">

    @* ===== الكارت العلوي: بحث + فلتر كود + أزرار التحكم ===== *@
    <div class="card mb-3 d-print-none mt-2">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* البحث العام في سجل النشاط *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث في سجل النشاط</label>
                        </div>

                        <div class="col-sm-5">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-5">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                <option value="all" selected="@(searchBy == "all" ? "selected" : null)">
                                    البحث في الكل
                                </option>
                                <option value="user" selected="@(searchBy == "user" ? "selected" : null)">
                                    المستخدم
                                </option>
                                <option value="action" selected="@(searchBy == "action" ? "selected" : null)">
                                    نوع العملية
                                </option>
                                <option value="entity" selected="@(searchBy == "entity" ? "selected" : null)">
                                    اسم الكيان
                                </option>
                                <option value="description" selected="@(searchBy == "description" ? "selected" : null)">
                                    الوصف
                                </option>
                                <option value="id" selected="@(searchBy == "id" ? "selected" : null)">
                                    رقم السجل
                                </option>
                            </select>
                        </div>

                        @* مخفيّات النظام الثابت *@
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="dateField" value="@dateField" />
                        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />

                        @if (fromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                        }
                        @if (toDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                        }
                        @if (fromCode.HasValue)
                        {
                            <input type="hidden" name="fromCode" value="@fromCode" />
                        }
                        @if (toCode.HasValue)
                        {
                            <input type="hidden" name="toCode" value="@toCode" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm px-3">
                                بحث
                            </button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm"
                               href="@Url.Action(action, controller)">
                                إلغاء
                            </a>
                        </div>
                    </form>
                </div>

                @* فلتر كود من/إلى على Id *@
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-semibold">من كود</span>
                        <input id="codeFromInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(fromCode?.ToString() ?? "")" />

                        <span class="fw-semibold">إلى كود</span>
                        <input id="codeToInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(toCode?.ToString() ?? "")" />

                        <button type="button"
                                id="btnApplyCodeFilter"
                                class="btn btn-erp btn-erp-primary btn-erp-sm">
                            تطبيق فلتر الكود
                        </button>

                        <button type="button"
                                id="btnClearCodeFilter"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            مسح
                        </button>
                    </div>
                </div>

                @* أزرار التحكم: حذف + فلترة + اختيار أعمدة + طباعة + تصدير *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        @* حذف السجلات المحددة *@
                        <form id="formBulkDelete"
                              asp-action="BulkDelete"
                              asp-controller="UserActivityLogs"
                              method="post"
                              class="d-inline">
                            <button type="button"
                                    id="btnBulkDelete"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف المحدد
                            </button>
                        </form>

                        @* حذف كل السجلات (للبيئة التجريبية) *@
                        <form id="formDeleteAll"
                              asp-action="DeleteAll"
                              asp-controller="UserActivityLogs"
                              method="post"
                              class="d-inline">
                            <button type="submit"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm"
                                    onclick="return confirm('هل أنت متأكد من حذف جميع سجل النشاط؟ يُفضّل هذا في بيئة تجريبية فقط.');">
                                حذف الجميع
                            </button>
                        </form>

                        @* فلترة بالتاريخ *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#dateFilterModalActivity">
                            فلترة بالتاريخ/الوقت
                        </button>

                        @* اختيار الأعمدة *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalActivity">
                            اختيار الأعمدة
                        </button>

                        @* طباعة *@
                        <button type="button"
                                id="btnPrintActivity"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        @* تصدير *@
                        <form method="get"
                              asp-action="Export"
                              asp-controller="UserActivityLogs"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="dateField" value="@dateField" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                            }
                            @if (toDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                            }
                            @if (fromCode.HasValue)
                            {
                                <input type="hidden" name="fromCode" value="@fromCode" />
                            }
                            @if (toCode.HasValue)
                            {
                                <input type="hidden" name="toCode" value="@toCode" />
                            }

                            <select name="format"
                                    class="form-select form-select-sm"
                                    style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit"
                                    class="btn btn-success btn-erp btn-erp-sm">
                                تصدير
                            </button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

@* ===== جدول سجل النشاط ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="activityTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    <th class="text-center no-print"
                        data-col="actions"
                        data-col-fixed="true"
                        style="width:220px;">
                        <input type="checkbox"
                               id="selectAll"
                               class="form-check-input" />
                    </th>

                    <th data-col="id">@sortLink("Id", "المعرّف")</th>
                    <th data-col="user">@sortLink("UserName", "المستخدم")</th>
                    <th data-col="action">@sortLink("ActionType", "نوع العملية")</th>
                    <th data-col="entity">@sortLink("EntityName", "اسم الكيان")</th>
                    <th data-col="entityId">@sortLink("EntityId", "رقم السجل")</th>
                    <th data-col="time">@sortLink("ActionTime", "وقت العملية")</th>

                    <th data-col="ip">عنوان IP</th>
                    <th data-col="agent">المتصفح / الجهاز</th>
                    <th data-col="desc">الوصف</th>

                    @* ✅ جديد: قبل / بعد *@
                    <th data-col="old">قبل</th>
                    <th data-col="new">بعد</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="12" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model.Items)
                    {
                        <tr>
                            <td class="text-nowrap no-print" data-col="actions">
                                <input type="checkbox"
                                       class="form-check-input ms-2 row-select"
                                       value="@r.Id" />

                                <a class="btn btn-erp btn-erp-secondary btn-erp-sm ms-1"
                                   asp-action="Details"
                                   asp-route-id="@r.Id">
                                    تفاصيل
                                </a>

                                <a class="btn btn-erp btn-erp-danger btn-erp-sm"
                                   asp-action="Delete"
                                   asp-route-id="@r.Id">
                                    حذف
                                </a>
                            </td>

                            <td data-col="id">@r.Id</td>
                            <td data-col="user">@r.User?.UserName</td>
                            <td data-col="action">@r.ActionType</td>
                            <td data-col="entity">@r.EntityName</td>
                            <td data-col="entityId">@r.EntityId</td>
                            <td data-col="time">@r.ActionTime.ToString("yyyy-MM-dd HH:mm")</td>

                            <td data-col="ip">@r.IpAddress</td>
                            <td data-col="agent">@r.UserAgent</td>
                            <td data-col="desc">@r.Description</td>

                            @* ✅ جديد: قبل / بعد (ملخص سريع بدل JSON كامل) *@
                            <td data-col="old" class="text-muted small">
                                @(
                                                        string.IsNullOrWhiteSpace(r.OldValues)
                                                        ? "-"
                                                        : (r.OldValues!.Length > 40 ? r.OldValues.Substring(0, 40) + "..." : r.OldValues)
                                                        )
                            </td>

                            <td data-col="new" class="text-muted small">
                                @(
                                                        string.IsNullOrWhiteSpace(r.NewValues)
                                                        ? "-"
                                                        : (r.NewValues!.Length > 40 ? r.NewValues.Substring(0, 40) + "..." : r.NewValues)
                                                        )
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>




@* شريط أسفل الجدول: عرض X–Y من Z + حجم الصفحة *@
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
    <small class="text-muted">
        عرض @start - @end من @total
    </small>

    @* =========================================================
       فورم تغيير حجم الصفحة
       - مهم: عند تغيير pageSize لازم نرجع الصفحة 1
       - ونحافظ على كل الباراميترات (بحث/ترتيب/فلاتر)
       ========================================================= *@
    <form method="get"
          action="@Url.Action(action, controller)"
          class="d-flex align-items-center gap-2">

        @* ===== باراميترات ثابتة للحفاظ على حالة الفلاتر ===== *@
        <input type="hidden" name="search" value="@search" />
        <input type="hidden" name="searchBy" value="@searchBy" />
        <input type="hidden" name="sort" value="@sort" />
        <input type="hidden" name="dir" value="@dir" />

        @* عند تغيير pageSize هنرجع الصفحة 1 *@
        <input type="hidden" name="page" id="PageInput" value="1" />

        <input type="hidden" name="dateField" value="@dateField" />
        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />

        @if (fromDate.HasValue)
        {
            <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
        }
        @if (toDate.HasValue)
        {
            <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
        }
        @if (fromCode.HasValue)
        {
            <input type="hidden" name="fromCode" value="@fromCode" />
        }
        @if (toCode.HasValue)
        {
            <input type="hidden" name="toCode" value="@toCode" />
        }

        <label class="form-label m-0 nowrap">حجم الصفحة</label>

        <select name="pageSize"
                class="form-select form-select-sm"
                onchange="document.getElementById('PageInput').value = 1; this.form.submit();">

            <option value="25" selected='@(ps == 25 ? "selected" : null)'>25</option>
            <option value="50" selected='@(ps == 50 ? "selected" : null)'>50</option>
            <option value="100" selected='@(ps == 100 ? "selected" : null)'>100</option>
            <option value="200" selected='@(ps == 200 ? "selected" : null)'>200</option>

        </select>
    </form>
</div>

<div class="no-print">
    <small class="text-muted d-none d-md-inline">
        إجمالي السجلات: @total
    </small>
</div>

@* الترقيم: استخدام Link(int p) المعرّفة أعلى الصفحة لبناء الرابط مع الحفاظ على الفلاتر *@
<nav aria-label="pagination" class="mt-3 no-print">
    <ul class="pagination justify-content-center">
        <li class="page-item @(page == first ? "disabled" : "")">
            <a class="page-link"
               href="@(Link(first))">
                الأول
            </a>
        </li>

        <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
            <a class="page-link"
               href="@(Link(prev))">
                السابق
            </a>
        </li>

        <li class="page-item disabled">
            <span class="page-link">
                صفحة @(page) من @(pages)
            </span>
        </li>

        <li class="page-item @(Model.HasNext ? "" : "disabled")">
            <a class="page-link"
               href="@(Link(next))">
                التالي
            </a>
        </li>

        <li class="page-item @(page == last ? "disabled" : "")">
            <a class="page-link"
               href="@(Link(last))">
                الأخير
            </a>
        </li>
    </ul>
</nav>




@* Modal فلترة التاريخ/الوقت *@
<div class="modal fade no-print"
     id="dateFilterModalActivity"
     tabindex="-1"
     aria-labelledby="dateFilterModalActivityLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalActivityLabel">
                    فلترة بالتاريخ والوقت (وقت العملية)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRangeActivity"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRangeActivity">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* Modal اختيار الأعمدة *@
<div class="modal fade no-print"
     id="columnsModalActivity"
     tabindex="-1"
     aria-labelledby="columnsModalActivityLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalActivityLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
            </div>
            <div class="modal-body">
                <div id="columnsListActivity"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsActivity"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // طباعة سجل النشاط
        document.getElementById("btnPrintActivity")?.addEventListener("click", function () {
            window.print();
        });

        // اختيار الأعمدة + حفظ في localStorage
        (function () {
            const table = document.getElementById("activityTable");
            if (!table) return;

            const storageKey = "activity-columns-visibility";
            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListActivity");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_act_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsActivity")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalActivity");
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // تحديد الكل + الحذف الجماعي
        (function () {
            const selectAll = document.getElementById("selectAll");
            const bulkBtn = document.getElementById("btnBulkDelete");
            const bulkForm = document.getElementById("formBulkDelete");

            function getRowCheckboxes() {
                return Array.from(document.querySelectorAll(".row-select"));
            }

            selectAll?.addEventListener("change", function () {
                const checked = this.checked;
                getRowCheckboxes().forEach(cb => cb.checked = checked);
            });

            bulkBtn?.addEventListener("click", function () {
                const checks = getRowCheckboxes().filter(cb => cb.checked);
                if (checks.length === 0) {
                    alert("من فضلك اختر على الأقل سجل نشاط واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف سجلات النشاط المحددة؟")) {
                    return;
                }

                const oldHidden = bulkForm.querySelectorAll("input[type='hidden'][name='ids']");
                oldHidden.forEach(h => h.remove());

                checks.forEach(cb => {
                    const input = document.createElement("input");
                    input.type = "hidden";
                    input.name = "ids";
                    input.value = cb.value;
                    bulkForm.appendChild(input);
                });

                bulkForm.submit();
            });
        })();

        // فلتر الكود من/إلى
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp = document.getElementById("codeFromInput");
            const toInp = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);

                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else url.searchParams.delete("fromCode");

                if (codeTo) url.searchParams.set("toCode", codeTo);
                else url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
