@* Modal اختيار الأعمدة *@
<div class="modal fade no-print"
     id="columnsModalActivity"
     tabindex="-1"
     aria-labelledby="columnsModalActivityLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalActivityLabel">اختيار الأعمدة الظاهرة</h5>
            </div>
            <div class="modal-body">
                <div id="columnsListActivity"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-erp btn-erp-secondary" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" id="btnApplyColumnsActivity" class="btn btn-erp btn-erp-primary">تطبيق</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        document.getElementById("btnPrintActivity")?.addEventListener("click", function () { window.print(); });

        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanelActivity',
            tableId: 'activityTable',
            wrapperId: 'activityTableScrollWrapper',
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "UserActivityLogs")',
            defaultSort: 'ActionTime',
            defaultDir: 'desc',
            numericColumns: ['id', 'entityId']
        });

        // اختيار الأعمدة
        (function () {
            const table = document.getElementById("activityTable");
            if (!table) return;
            const storageKey = "activity-columns-visibility";
            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells.filter(th => !th.hasAttribute("data-col-fixed")).map(th => ({
                key: th.getAttribute("data-col"),
                title: th.innerText.trim()
            }));
            if (columns.length === 0) return;
            let hidden = [];
            try { const saved = localStorage.getItem(storageKey); if (saved) hidden = JSON.parse(saved); } catch { }
            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']").forEach(cell => cell.classList.toggle("d-none", isHidden));
                });
            }
            applyVisibility();
            const listContainer = document.getElementById("columnsListActivity");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_act_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";
                    const cb = document.createElement("input");
                    cb.type = "checkbox"; cb.className = "form-check-input ms-2"; cb.id = id;
                    cb.checked = !hidden.includes(col.key); cb.dataset.colKey = col.key;
                    const label = document.createElement("label");
                    label.className = "form-check-label"; label.setAttribute("for", id); label.innerText = col.title;
                    wrapper.appendChild(cb); wrapper.appendChild(label); listContainer.appendChild(wrapper);
                });
            }
            document.getElementById("btnApplyColumnsActivity")?.addEventListener("click", function () {
                const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                hidden = [];
                checks.forEach(cb => { if (!cb.checked) hidden.push(cb.dataset.colKey); });
                try { localStorage.setItem(storageKey, JSON.stringify(hidden)); } catch { }
                applyVisibility();
                bootstrap.Modal.getInstance(document.getElementById("columnsModalActivity"))?.hide();
            });
        })();

        // التمرير الأفقي: عند الفتح يكون الشريط في أقصى اليمين (RTL)
        (function () {
            var wrapper = document.getElementById("activityTableScrollWrapper");
            if (wrapper) {
                function scrollToRtlStart() {
                    var maxScroll = wrapper.scrollWidth - wrapper.clientWidth;
                    wrapper.scrollLeft = maxScroll > 0 ? maxScroll : 0;
                }
                scrollToRtlStart();
                window.addEventListener("load", function () { setTimeout(scrollToRtlStart, 50); });
            }
        })();

        // فلتر الكود من/إلى
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp = document.getElementById("codeFromInput");
            const toInp = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);

                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else url.searchParams.delete("fromCode");

                if (codeTo) url.searchParams.set("toCode", codeTo);
                else url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
