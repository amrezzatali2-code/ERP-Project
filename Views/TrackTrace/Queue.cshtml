@using ERP.ViewModels
@model TrackTraceQueueIndexViewModel

@{
    ViewData["Title"] = "سجل إرسال التتبع";
    var rows = Model.Result.Items;
    var currentPage = Model.Result.PageNumber;
    var totalPages = Model.Result.TotalPages;
    var prevPage = Math.Max(1, currentPage - 1);
    var nextPage = Math.Min(totalPages, currentPage + 1);

    string BuildPageLink(int targetPage) => Url.Action("Queue", "TrackTrace", new
    {
        frame = 1,
        search = Model.Search,
        status = Model.Status,
        eventType = Model.EventType,
        page = targetPage,
        pageSize = Model.Result.PageSize
    })!;
}

<div class="container-fluid py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <h2 class="mb-0">سجل إرسال التتبع</h2>
        <div class="text-muted small">قائمة انتظار التكامل مع هيئة الدواء</div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-lg-4 col-md-6">
            <div class="card shadow-sm border-warning-subtle h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Pending</div>
                    <div class="fs-3 fw-bold text-warning">@Model.PendingCount</div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="card shadow-sm border-danger-subtle h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Failed</div>
                    <div class="fs-3 fw-bold text-danger">@Model.FailedCount</div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="card shadow-sm border-success-subtle h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Sent</div>
                    <div class="fs-3 fw-bold text-success">@Model.SentCount</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">
                <input type="hidden" name="frame" value="1" />
                <div class="col-lg-4 col-md-6">
                    <label class="form-label">بحث</label>
                    <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="UID / الصنف / رقم السجل" />
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label">الحالة</label>
                    <select name="status" class="form-select">
                        <option value="">الكل</option>
                        <option value="Pending" selected="@(Model.Status == "Pending")">Pending</option>
                        <option value="Failed" selected="@(Model.Status == "Failed")">Failed</option>
                        <option value="Sent" selected="@(Model.Status == "Sent")">Sent</option>
                    </select>
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label">نوع الحدث</label>
                    <select name="eventType" class="form-select">
                        <option value="">الكل</option>
                        <option value="Receive" selected="@(Model.EventType == "Receive")">Receive</option>
                        <option value="Sale" selected="@(Model.EventType == "Sale")">Sale</option>
                        <option value="Transfer" selected="@(Model.EventType == "Transfer")">Transfer</option>
                        <option value="Return" selected="@(Model.EventType == "Return")">Return</option>
                        <option value="Adjustment" selected="@(Model.EventType == "Adjustment")">Adjustment</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-6 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">عرض</button>
                    <a class="btn btn-outline-secondary w-100" href="@Url.Action("Queue", "TrackTrace", new { frame = 1 })">إلغاء</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle text-center mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>الحدث</th>
                            <th>الحالة</th>
                            <th>الصنف</th>
                            <th>UID</th>
                            <th>المحاولات</th>
                            <th>آخر خطأ</th>
                            <th>وقت الإنشاء</th>
                            <th>المحاولة القادمة</th>
                            <th>وقت الإرسال</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (rows.Count == 0)
                        {
                            <tr>
                                <td colspan="10" class="py-4 text-muted">لا توجد سجلات في قائمة انتظار التتبع حاليًا.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var row in rows)
                            {
                                <tr>
                                    <td>@row.Id</td>
                                    <td>@row.EventType</td>
                                    <td>@row.Status</td>
                                    <td>@(string.IsNullOrWhiteSpace(row.ProductName) ? "—" : row.ProductName)</td>
                                    <td class="font-monospace">@(!string.IsNullOrWhiteSpace(row.Uid) ? row.Uid : "—")</td>
                                    <td>@row.RetryCount</td>
                                    <td class="text-danger small text-wrap">@(!string.IsNullOrWhiteSpace(row.LastError) ? row.LastError : "—")</td>
                                    <td>@row.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                                    <td>@(row.NextRetryAt.HasValue ? row.NextRetryAt.Value.ToLocalTime().ToString("yyyy/MM/dd HH:mm") : "—")</td>
                                    <td>@(row.SentAt.HasValue ? row.SentAt.Value.ToLocalTime().ToString("yyyy/MM/dd HH:mm") : "—")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="text-muted small">
                عرض @Model.Result.StartIndex - @Model.Result.EndIndex من @Model.Result.TotalCount
            </div>
            <div class="btn-group">
                <a class="btn btn-outline-secondary @(currentPage <= 1 ? "disabled" : "")" href="@(currentPage <= 1 ? "#" : BuildPageLink(1))">الأول</a>
                <a class="btn btn-outline-secondary @(currentPage <= 1 ? "disabled" : "")" href="@(currentPage <= 1 ? "#" : BuildPageLink(prevPage))">السابق</a>
                <span class="btn btn-light disabled">صفحة @currentPage من @totalPages</span>
                <a class="btn btn-outline-secondary @(currentPage >= totalPages ? "disabled" : "")" href="@(currentPage >= totalPages ? "#" : BuildPageLink(nextPage))">التالي</a>
                <a class="btn btn-outline-secondary @(currentPage >= totalPages ? "disabled" : "")" href="@(currentPage >= totalPages ? "#" : BuildPageLink(totalPages))">الأخير</a>
            </div>
        </div>
    </div>
</div>
