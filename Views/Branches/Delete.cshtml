@model ERP.Models.Warehouse
@{
    ViewData["Title"] = "حذف مخزن";
}

<div class="container" dir="rtl">
    <h2 class="mb-3 text-danger">حذف مخزن</h2>
    <p>هل أنت متأكد من حذف السجل التالي؟ لا يمكن التراجع بعد الإتمام.</p>

    <!-- تعليق: عرض موجز لبيانات السجل قبل الحذف -->
    <dl class="row">
        <dt class="col-sm-2">المعرّف</dt>
        <dd class="col-sm-10">@Model.WarehouseId</dd>

        <dt class="col-sm-2">الاسم</dt>
        <dd class="col-sm-10">@Model.WarehouseName</dd>

        <dt class="col-sm-2">الفرع</dt>
        <dd class="col-sm-10">@Model.Branch?.BranchName</dd>

        <dt class="col-sm-2">فعّال</dt>
        <dd class="col-sm-10">@(Model.IsActive ? "نعم" : "لا")</dd>

        <dt class="col-sm-2">ملاحظات</dt>
        <dd class="col-sm-10">@Model.Notes</dd>
    </dl>

    <!-- تعليق: نموذج تأكيد الحذف -->
    <form asp-action="Delete" method="post" class="d-flex gap-2">
        @* تمرير المعرّف في حقل مخفي *@
        <input type="hidden" asp-for="WarehouseId" />
        <button class="btn btn-danger">تأكيد الحذف</button>
        <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
    </form>
</div>
