@model ERP.Models.Branch
@{
    ViewData["Title"] = "حذف فرع";
}

<div class="container" dir="rtl">
    <h2 class="mb-3 text-danger">حذف فرع</h2>
    <p>هل أنت متأكد من حذف السجل التالي؟ لا يمكن التراجع بعد الإتمام.</p>

    <dl class="row">
        <dt class="col-sm-2">المعرّف</dt>
        <dd class="col-sm-10">@Model.BranchId</dd>

        <dt class="col-sm-2">الاسم</dt>
        <dd class="col-sm-10">@Model.BranchName</dd>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.BranchId" method="post" class="d-flex gap-2">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">تأكيد الحذف</button>
        <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
    </form>
</div>
