@section Scripts {
    <script>
        (function () {
            var soId = parseInt(document.getElementById('SOId').value, 10) || 0;
            var isLocked = document.getElementById('SOIsConverted').value === '1';

            /** تنقّل أمر البيع في نفس الإطار (بدون open-same-tab / erpTabs يفتح تاباً جديداً) — مرجع: docs/erp-sidebar-navigation-arrows.md */
            function ensureSoNavUrl(url) {
                if (!url) return url;
                try {
                    var u = new URL(url, window.location.href);
                    if (!u.searchParams.has('frame')) u.searchParams.set('frame', '1');
                    u.searchParams.set('_ts', Date.now().toString());
                    return u.toString();
                } catch (e) {
                    var j = url.indexOf('?') >= 0 ? '&' : '?';
                    return url + j + 'frame=1&_ts=' + Date.now();
                }
            }
            document.addEventListener('click', function soOrderNavCapture(ev) {
                var t = ev.target;
                if (!(t instanceof Element)) return;
                var btn = t.closest('#btnSoFirst, #btnSoPrev, #btnSoNext, #btnSoLast, #btnNavOrderSearch');
                if (!btn) return;
                if (btn.hasAttribute('disabled')) return;
                ev.preventDefault();
                ev.stopPropagation();
                ev.stopImmediatePropagation();
                if (btn.id === 'btnNavOrderSearch') {
                    var inp = document.getElementById('NavOrderSearchInput');
                    var oid = inp ? parseInt(inp.value || '0', 10) : 0;
                    if (!oid || oid <= 0) return;
                    var base = (btn.getAttribute('data-base-url') || '').trim();
                    if (!base) return;
                    var joiner = base.indexOf('?') >= 0 ? '&' : '?';
                    window.location.assign(ensureSoNavUrl(base + joiner + 'id=' + encodeURIComponent(oid)));
                    return;
                }
                var url = (btn.getAttribute('data-url') || '').trim();
                if (!url) {
                    var baseUrl = (btn.getAttribute('data-base-url') || '').trim();
                    var bid = btn.getAttribute('data-id');
                    if (baseUrl && bid != null && bid !== '') {
                        var j = baseUrl.indexOf('?') >= 0 ? '&' : '?';
                        url = baseUrl + j + 'id=' + encodeURIComponent(bid);
                    }
                }
                if (!url) return;
                window.location.assign(ensureSoNavUrl(url));
            }, true);

            function getToken() {
                return document.querySelector('#__AntiForgeryForm input[name="__RequestVerificationToken"]').value;
            }

            function showToast(msg, type) {
                type = type || 'muted';
                var c = document.getElementById('soToastContainer');
                var el = document.createElement('div');
                el.className = 'so-toast text-' + type;
                el.textContent = msg;
                c.appendChild(el);
                setTimeout(function () { el.remove(); }, 4000);
            }

            function syncSoCreditRow() {
