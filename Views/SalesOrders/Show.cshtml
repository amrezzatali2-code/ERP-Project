                        }
                    }
                    if (list.length === 0) {
                        var empty = document.createElement('div');
                        empty.className = 'product-dropdown-item text-muted py-2 px-3 small';
                        empty.textContent = inp.value ? 'لا توجد نتائج' : ('اكتب للبحث ثم انزل بالسهم ▼ واختر (' + PRODUCT_LIST_MAX + ' كحد أقصى)');
                        panel.appendChild(empty);
                    } else {
                        list.forEach(function (opt, idx) {
                            var id = (opt.getAttribute('data-id') || '').toString();
                            var name = (opt.value || '').trim();
                            var it = document.createElement('div');
                            it.className = 'product-dropdown-item py-2 px-3' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                            it.setAttribute('role', 'option');
                            it.setAttribute('data-id', id);
                            it.textContent = name;
                            it.addEventListener('click', function (e) {
                                e.preventDefault();
                                var o = findProductByCode(id);
                                fillProductFromOption(o);
                                if (inp) inp.value = name;
                                closeProductDropdown();
                            });
                            panel.appendChild(it);
                            productDropdownSelectableItems.push(it);
                        });
                        productDropdownHighlightedIndex = highlightIdx;
                    }
                    panel.style.display = 'block';
                    panel.setAttribute('data-open', 'true');
                    positionProductDropdownList();
                }
                function selectHighlightedProduct() {
                    if (productDropdownHighlightedIndex < 0 || productDropdownHighlightedIndex >= productDropdownSelectableItems.length) return false;
                    var el = productDropdownSelectableItems[productDropdownHighlightedIndex];
                    var id = el.getAttribute('data-id');
                    var name = el.textContent.trim();
                    var o = findProductByCode(id);
                    if (o) {
                        fillProductFromOption(o);
                        if (prodNameInput) prodNameInput.value = name;
                    }
                    closeProductDropdown();
                    return true;
                }

                function fillProductFromOption(opt) {
                    if (!opt) {
                        if (document.getElementById('ProdId')) document.getElementById('ProdId').value = '';
                        if (prodCodeInput) prodCodeInput.value = '';
                        if (prodNameInput) prodNameInput.value = '';
                        return;
                    }
                    var id = parseInt(opt.getAttribute('data-id'), 10) || 0;
                    if (document.getElementById('ProdId')) document.getElementById('ProdId').value = id || '';
                    if (prodCodeInput) prodCodeInput.value = (opt.getAttribute('data-code') || id || '').toString();
                    if (prodNameInput) prodNameInput.value = opt.value || '';
                    if (id) loadSalesProductInfo(id);
                }

                prodNameInput.addEventListener('input', function () { openProductDropdown(); });
                prodNameInput.addEventListener('blur', function () {
                    setTimeout(function () {
                        closeProductDropdown();
                        fillProductFromOption(findProductByName(prodNameInput.value));
                    }, 180);
                });
                prodNameInput.addEventListener('keydown', function (e) {
                    var panel = document.getElementById('productDropdownList');
                    var isOpen = panel && panel.getAttribute('data-open') === 'true';
                    if (e.key === 'ArrowDown') {
                        e.preventDefault(); productDropdownPendingMoveToQuantity = false;
                        if (!isOpen) openProductDropdown();
                        if (isOpen && productDropdownSelectableItems.length > 0) {
                            var next = Math.min(productDropdownHighlightedIndex + 1, productDropdownSelectableItems.length - 1);
                            setProductDropdownHighlight(next);
                        } else if (productDropdownSelectableItems.length > 0) setProductDropdownHighlight(0);
                        return;
                    }
                    if (e.key === 'ArrowUp') {
                        e.preventDefault(); productDropdownPendingMoveToQuantity = false;
                        if (!isOpen) openProductDropdown();
                        if (isOpen && productDropdownSelectableItems.length > 0) {
                            var prev = Math.max(productDropdownHighlightedIndex - 1, 0);
                            setProductDropdownHighlight(prev);
                        }
                        return;
                    }
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        if (productDropdownPendingMoveToQuantity) {
                            closeProductDropdown();
                            productDropdownPendingMoveToQuantity = false;
                            var q = document.getElementById('ProdQtyInput');
                            if (q) { q.focus(); if (q.select) q.select(); }
                            return;
                        }
                        if (isOpen && productDropdownSelectableItems.length > 0) {
                            selectHighlightedProduct();
                            productDropdownPendingMoveToQuantity = true;
                            return;
                        }
                        fillProductFromOption(findProductByName(prodNameInput.value));
                        var priceInput = document.getElementById('ProdPriceInput');
                        var qtyInput = document.getElementById('ProdQtyInput');
                        if (priceInput && !priceInput.readOnly) { priceInput.focus(); if (priceInput.select) priceInput.select(); }
                        else if (qtyInput) { qtyInput.focus(); if (qtyInput.select) qtyInput.select(); }
                    }
                });
                document.addEventListener('click', function (ev) {
                    var wrap = document.getElementById('productDropdownWrap');
                    if (wrap && !wrap.contains(ev.target)) closeProductDropdown();
                });
                var productDropdownArrow = document.getElementById('productDropdownArrow');
                if (productDropdownArrow) {
                    productDropdownArrow.addEventListener('click', function (ev) {
                        ev.preventDefault();
                        prodNameInput.focus();
                        openProductDropdown();
                    });
                }
                if (prodCodeInput) {
                    prodCodeInput.addEventListener('change', function () { fillProductFromOption(findProductByCode(this.value)); });
                    prodCodeInput.addEventListener('keydown', function (e) {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            fillProductFromOption(findProductByCode(this.value));
                            if (prodNameInput) { prodNameInput.focus(); if (prodNameInput.select) prodNameInput.select(); }
                        }
                    });
                }
            })();

            var prodPriceInputForEnter = document.getElementById('ProdPriceInput');
            if (prodPriceInputForEnter) prodPriceInputForEnter.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    var qtyInput = document.getElementById('ProdQtyInput');
                    if (qtyInput) { qtyInput.focus(); if (typeof qtyInput.select === 'function') qtyInput.select(); }
                }
            });
            var prodQtyInputForEnter = document.getElementById('ProdQtyInput');
            if (prodQtyInputForEnter) prodQtyInputForEnter.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    var btnAdd = document.getElementById('btnAddLine');
                    if (btnAdd) btnAdd.focus();
                }
            });
            var btnAddLineForEnter = document.getElementById('btnAddLine');
            if (btnAddLineForEnter) btnAddLineForEnter.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    this.click();
                    var nameInput = document.getElementById('ProdNameInput');
                    if (nameInput) { setTimeout(function () { nameInput.focus(); if (typeof nameInput.select === 'function') nameInput.select(); }, 100); }
                }
            });

            var btnSaveHeaderNav = document.getElementById('btnSaveHeader');
            if (btnSaveHeaderNav) {
                btnSaveHeaderNav.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        this.click();
                        setTimeout(function () {
                            var prodNameInput = document.getElementById('ProdNameInput');
                            if (prodNameInput) { prodNameInput.focus(); if (typeof prodNameInput.select === 'function') prodNameInput.select(); }
                        }, 150);
                    }
                });
            }

            // تحميل بيانات الصنف من فاتورة المبيعات (كميات، كوتة، بونص، تشغيلات، سعر، خصم) — مثل فاتورة المبيعات بالضبط
            var busyLoadInfo = false;
            var currentProductBatches = [];
            function loadSalesProductInfo(prodId) {
                if (!prodId) return;
                var warehouseId = parseInt((document.getElementById('WarehouseId') && document.getElementById('WarehouseId').value) || '0', 10) || 0;
                if (!warehouseId) return;
                var customerId = parseInt((document.getElementById('CustomerId') && document.getElementById('CustomerId').value) || '0', 10) || 0;
                if (busyLoadInfo) return;
                busyLoadInfo = true;
                var url = '@Url.Action("GetSalesProductInfo", "SalesInvoices")' + '?prodId=' + encodeURIComponent(prodId) + '&warehouseId=' + encodeURIComponent(warehouseId) + '&customerId=' + encodeURIComponent(customerId);
                fetch(url, { method: 'GET', headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (data) {
                        busyLoadInfo = false;
                        if (!data || !data.ok) {
                            currentProductBatches = [];
                            var batchSelectInRow0 = document.getElementById('ProdBatchSelectInRow');
                            if (batchSelectInRow0) { batchSelectInRow0.innerHTML = '<option value="">—</option>'; batchSelectInRow0.classList.add('d-none'); }
                            var probatchInput0 = document.getElementById('ProdBatchInput');
                            if (probatchInput0) probatchInput0.classList.remove('d-none');
                            var qw = document.getElementById('ProdQtyCurrentWarehouse'); if (qw) qw.value = '0';
                            var qa = document.getElementById('ProdQtyAllWarehouses'); if (qa) qa.value = '0';
                            var qt = document.getElementById('ProdQuotaText'); if (qt) qt.value = 'بدون كوتة';
                            var bt = document.getElementById('ProdBonusText'); if (bt) bt.value = 'بدون بونص';
                            var gt = document.getElementById('ProdGroupText'); if (gt) gt.value = 'بدون مجموعة';
                            var gpt = document.getElementById('ProdGroupPolicyText'); if (gpt) gpt.value = '—';
                            var wd = document.getElementById('ProdWeightedDiscount'); if (wd) wd.value = '0';
                            var tbody = document.getElementById('BatchQueueBody'); if (tbody) tbody.innerHTML = '<tr><td colspan="5" class="text-muted">لا توجد تشغيلات.</td></tr>';
                            return;
                        }
                        var qw = document.getElementById('ProdQtyCurrentWarehouse'); if (qw) qw.value = (data.qtyCurrentWarehouse ?? 0);
                        var qa = document.getElementById('ProdQtyAllWarehouses'); if (qa) qa.value = (data.qtyAllWarehouses ?? 0);
                        var qt = document.getElementById('ProdQuotaText'); if (qt) qt.value = (data.quotaText || 'بدون كوتة').toString();
                        var bt = document.getElementById('ProdBonusText'); if (bt) bt.value = (data.bonusText || 'بدون بونص').toString();
                        var gt = document.getElementById('ProdGroupText'); if (gt) gt.value = (data.productGroupName || 'بدون مجموعة').toString();
                        var gpt = document.getElementById('ProdGroupPolicyText'); if (gpt) gpt.value = (data.appliedGroupPolicyName || data.appliedGroupPolicyId || '—').toString() || '—';
                        var wd = document.getElementById('ProdWeightedDiscount'); if (wd) { var w = Number(data.weightedDiscount ?? 0); wd.value = (w >= 0 && w <= 100) ? w.toFixed(2) : '0.00'; }
                        var discInput = document.getElementById('ProdDiscInput'); if (discInput) { var sd = Number(data.saleDisc1 ?? 0); discInput.value = (sd >= 0 && sd <= 100) ? sd.toFixed(2) : '0.00'; }
                        var batches = data.batches || [];
                        currentProductBatches = batches;
                        var tbody = document.getElementById('BatchQueueBody');
                        if (tbody) {
                            if (!batches.length) tbody.innerHTML = '<tr><td colspan="5" class="text-muted">لا توجد تشغيلات.</td></tr>';
                            else {
                                tbody.innerHTML = batches.map(function (b, idx) {
                                    var p = (b.priceRetailBatch != null ? Number(b.priceRetailBatch).toFixed(2) : '0.00');
                                    return '<tr data-batch-index="' + idx + '"' + (idx === 0 ? ' class="table-success"' : '') + '><td class="text-center">' + (idx + 1) + '</td><td class="text-center">' + (b.batchNo || '') + '</td><td class="text-center">' + (b.expiryText || '') + '</td><td class="text-center">' + (b.qty ?? 0) + '</td><td class="text-center">' + p + '</td></tr>';
                                }).join('');
                            }
                        }
                        var batchSelectInRow = document.getElementById('ProdBatchSelectInRow');
                        var probatchInput = document.getElementById('ProdBatchInput');
                        if (batchSelectInRow && probatchInput) {
                            if (batches.length >= 2) {
                                probatchInput.classList.add('d-none');
                                batchSelectInRow.classList.remove('d-none');
                                batchSelectInRow.innerHTML = '';
                                batches.forEach(function (b, idx) {
                                    var opt = document.createElement('option');
                                    opt.value = String(idx);
                                    opt.textContent = (b.batchNo || '').toString() || '—';
                                    if (idx === 0) opt.selected = true;
                                    batchSelectInRow.appendChild(opt);
                                });
                                applyBatchSelection(0);
                            } else {
                                batchSelectInRow.innerHTML = '<option value="">—</option>';
                                batchSelectInRow.classList.add('d-none');
                                probatchInput.classList.remove('d-none');
                            }
                        }
                        var pb = document.getElementById('ProdBatchInput');
                        var pe = document.getElementById('ProdExpiryInput');
                        var pp = document.getElementById('ProdPriceInput');
                        if (batches.length < 2) {
                            if (data.auto) {
                                if (pb) pb.value = data.auto.batchNo || '';
                                if (pe) pe.value = data.auto.expiryText || '';
                                if (pp) pp.value = (data.auto.priceRetailBatch != null ? Number(data.auto.priceRetailBatch).toFixed(2) : '0.00');
                            } else if (batches.length === 1 && batches[0]) {
                                if (pb) pb.value = batches[0].batchNo || '';
                                if (pe) pe.value = batches[0].expiryText || '';
                                if (pp) pp.value = (batches[0].priceRetailBatch != null ? Number(batches[0].priceRetailBatch).toFixed(2) : '0.00');
                            }
                        }
                        applyPriceLockUI();
                        // بدائل الصنف
                        fetch('@Url.Action("GetAlternativeProducts", "SalesInvoices")' + '?prodId=' + encodeURIComponent(prodId), { method: 'GET', headers: { 'Accept': 'application/json' } })
                            .then(function (r) { return r.ok ? r.json() : []; })
                            .then(function (arr) {
                                var sel = document.getElementById('AlternativeProducts');
                                if (!sel) return;
                                sel.innerHTML = '<option value="">اختر بديلاً (للمشاهدة فقط)</option>';
                                (arr || []).forEach(function (p) {
                                    var opt = document.createElement('option');
                                    opt.value = (p.id || '').toString();
                                    opt.textContent = (p.name || '') + (p.company ? ' — ' + p.company : '');
                                    sel.appendChild(opt);
                                });
                            })
                            .catch(function () { });
                    })
                    .catch(function () { busyLoadInfo = false; });
            }

            function applyBatchSelection(idx) {
                var b = currentProductBatches[idx];
                if (!b) return;
                var pb = document.getElementById('ProdBatchInput'); if (pb) pb.value = b.batchNo || '';
                var pe = document.getElementById('ProdExpiryInput'); if (pe) pe.value = b.expiryText || '';
                var pp = document.getElementById('ProdPriceInput'); if (pp) pp.value = (b.priceRetailBatch != null ? Number(b.priceRetailBatch).toFixed(2) : '0.00');
                var tbody = document.getElementById('BatchQueueBody');
                if (tbody) {
                    tbody.querySelectorAll('tr[data-batch-index]').forEach(function (tr) {
                        var i = parseInt(tr.getAttribute('data-batch-index'), 10);
                        tr.classList.toggle('table-success', i === idx);
                    });
                }
            }
            var prodBatchSelectInRowEl = document.getElementById('ProdBatchSelectInRow');
            if (prodBatchSelectInRowEl) prodBatchSelectInRowEl.addEventListener('change', function () {
                var idx = parseInt(this.value, 10);
                if (isNaN(idx) || idx < 0 || idx >= currentProductBatches.length) return;
                applyBatchSelection(idx);
            });

            // قفل/فتح السعر بالضغط على اللابل — مثل فاتورة المبيعات
            var priceLocked = true;
            var priceLabelEl = document.getElementById('ProdPriceLabel');
            var priceLockStateEl = document.getElementById('ProdPriceLockState');
            var prodPriceInputEl = document.getElementById('ProdPriceInput');
            function applyPriceLockUI() {
                if (!prodPriceInputEl) return;
                prodPriceInputEl.readOnly = priceLocked;
                if (priceLocked) {
                    prodPriceInputEl.classList.add('bg-light', 'text-muted');
                    if (priceLockStateEl) priceLockStateEl.textContent = '(مغلق)';
                } else {
                    prodPriceInputEl.classList.remove('bg-light', 'text-muted');
                    if (priceLockStateEl) priceLockStateEl.textContent = '(مفتوح)';
                }
            }
            if (priceLabelEl && !priceLabelEl.dataset.boundPriceToggle) {
                priceLabelEl.dataset.boundPriceToggle = '1';
                priceLabelEl.addEventListener('click', function () {
                    priceLocked = !priceLocked;
                    applyPriceLockUI();
                    if (!priceLocked && prodPriceInputEl) { prodPriceInputEl.focus(); if (typeof prodPriceInputEl.select === 'function') prodPriceInputEl.select(); }
                });
            }

            // تحديث قائمة الأصناف (أصناف لها رصيد فقط أو الكل حسب «عرض الصفر») — مثل فاتورة المبيعات
            function refreshProductsDatalist() {
                var list = document.getElementById('productsList');
                if (!list) return;
                list.innerHTML = '';
                var chk = document.getElementById('chkIncludeZeroQty');
                var warehouseId = parseInt((document.getElementById('WarehouseId') && document.getElementById('WarehouseId').value) || '0', 10) || 0;
                var includeZero = chk ? !!chk.checked : false;
                var url = '@Url.Action("GetProductsForDatalist", "SalesOrders")?includeZeroQty=' + includeZero + '&warehouseId=' + (warehouseId || '');
                fetch(url, { method: 'GET', headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.ok ? r.json() : []; })
                    .then(function (products) {
                        if (!list.parentNode) return;
                        list.innerHTML = '';
                        (products || []).forEach(function (p) {
                            var opt = document.createElement('option');
                            opt.value = p.name || '';
                            opt.setAttribute('data-id', (p.id || '').toString());
                            opt.setAttribute('data-code', (p.id || '').toString());
                            if (p.genericName != null) opt.setAttribute('data-generic', p.genericName);
                            if (p.company != null) opt.setAttribute('data-company', p.company);
                            opt.setAttribute('data-price', p.price != null ? String(p.price) : '0');
                            opt.setAttribute('data-hasquota', p.hasQuota ? 'true' : 'false');
                            opt.setAttribute('data-hasbonus', p.hasBonus ? 'true' : 'false');
                            if (p.bonusGroupName != null) opt.setAttribute('data-bonusgroup', p.bonusGroupName);
                            list.appendChild(opt);
                        });
                        var currentId = (document.getElementById('ProdId') && document.getElementById('ProdId').value) || '';
                        if (!includeZero && currentId) {
                            var ids = (products || []).map(function (x) { return (x.id || '').toString(); });
                            if (ids.indexOf(currentId) < 0) {
                                document.getElementById('ProdId').value = '';
                                if (document.getElementById('ProdCodeInput')) document.getElementById('ProdCodeInput').value = '';
                                if (document.getElementById('ProdNameInput')) document.getElementById('ProdNameInput').value = '';
                            }
                        }
                    })
                    .catch(function () { });
            }
            var chkIncludeZero = document.getElementById('chkIncludeZeroQty');
            if (chkIncludeZero) chkIncludeZero.addEventListener('change', refreshProductsDatalist);
            var warehouseSelect = document.getElementById('WarehouseId');
            if (warehouseSelect) warehouseSelect.addEventListener('change', refreshProductsDatalist);

            function refreshLines() {
                if (soId <= 0) return;
                fetch('@Url.Action("GetLinesJson", "SalesOrders")?id=' + soId, { headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (!data.ok) { showToast(data.message || 'خطأ', 'danger'); return; }
                        var tbody = document.getElementById('SOLinesTbody');
                        tbody.innerHTML = '';
                        if (!data.lines || data.lines.length === 0) {
                            tbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-3">لا توجد سطور.</td></tr>';
                        } else {
                            data.lines.forEach(function (l) {
                                var tr = document.createElement('tr');
                                tr.className = 'erp-list-selectable-row';
                                tr.setAttribute('data-line-no', l.lineNo);
                                tr.setAttribute('data-so-id', soId);
                                tr.setAttribute('data-prodid', l.prodId);
                                var batch = (l.batchNo != null && l.batchNo !== '') ? l.batchNo : '—';
                                var expiry = (l.expiry != null && l.expiry !== '') ? l.expiry : '—';
                                var loc = (l.location != null && l.location !== '') ? l.location : '—';
                                var pn = escapeSoHtml(l.prodName || '');
                                tr.innerHTML = '<td class="text-center">' + l.lineNo + '</td><td class="text-center text-muted small">' + escapeSoHtml(loc) + '</td><td><strong>' + pn + '</strong> <span class="text-muted small">| ' + l.prodId + '</span></td><td class="text-center">' + escapeSoHtml(batch) + '</td><td class="text-center">' + escapeSoHtml(expiry) + '</td><td class="text-center">' + l.qty + '</td><td class="text-center">' + (l.requestRetailPrice != null ? Number(l.requestRetailPrice).toFixed(2) : '') + '</td><td class="text-center">' + (l.salesDiscountPct != null ? Number(l.salesDiscountPct).toFixed(2) : '') + '</td><td class="text-center line-value">' + (l.lineValue != null ? Number(l.lineValue).toFixed(2) : '') + '</td>';
                                tbody.appendChild(tr);
                            });
                        }
                        if (data.totals) applySoTotalsFromServer(data.totals);
                        syncDeleteSelectedSoLineButton();
                    })
                    .catch(function () { showToast('فشل تحميل السطور', 'danger'); });
            }

            function removeLine(lineNo) {
                if (soId <= 0 || lineNo <= 0) return;
                fetch('@Url.Action("RemoveLineJson", "SalesOrders")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
                    body: JSON.stringify({ SOId: soId, LineNo: lineNo })
                }).then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data.ok) { showToast(data.message || 'تم حذف السطر', 'success'); refreshLines(); }
                        else showToast(data.message || 'خطأ', 'danger');
                    }).catch(function () { showToast('فشل حذف السطر', 'danger'); });
            }

            document.getElementById('SOLinesTbody').addEventListener('click', function (e) {
                var row = e.target.closest('tr.erp-list-selectable-row');
                if (!row || !document.getElementById('SOLinesTbody').contains(row)) return;
                if (e.target.closest('a')) return;
                document.querySelectorAll('#SOLinesTbody tr.erp-list-selectable-row.selected').forEach(function (r) { r.classList.remove('selected'); });
                row.classList.add('selected');
                syncDeleteSelectedSoLineButton();
                var prodId = (row.getAttribute('data-prodid') || '').trim();
                if (!prodId) return;
                function setVal(el, value) {
                    if (!el) return;
                    el.value = value != null ? value : '';
                    el.dispatchEvent(new Event('input', { bubbles: true }));
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                }
                var ProdIdEl = document.getElementById('ProdId');
                var ProdNameEl = document.getElementById('ProdNameInput');
                var ProdCodeEl = document.getElementById('ProdCodeInput');
                var ProdBatchEl = document.getElementById('ProdBatchInput');
                var ProdExpiryEl = document.getElementById('ProdExpiryInput');
                var ProdQtyEl = document.getElementById('ProdQtyInput');
                var ProdPriceEl = document.getElementById('ProdPriceInput');
                var ProdDiscEl = document.getElementById('ProdDiscInput');
                setVal(ProdIdEl, prodId);
                setVal(ProdCodeEl, prodId);
                var nameCell = row.cells[2];
                var prodName = '';
                if (nameCell) {
                    var strong = nameCell.querySelector('strong');
                    prodName = strong ? (strong.innerText || '').trim() : (nameCell.innerText || '').trim();
                }
                setVal(ProdNameEl, prodName);
                var batchText = (row.cells[3] && row.cells[3].innerText) ? row.cells[3].innerText.trim() : '';
                var expRaw = (row.cells[4] && row.cells[4].innerText) ? row.cells[4].innerText.trim() : '';
                var qtyText = (row.cells[5] && row.cells[5].innerText) ? row.cells[5].innerText.trim() : '';
                var priceText = (row.cells[6] && row.cells[6].innerText) ? row.cells[6].innerText.trim() : '';
                var discText = (row.cells[7] && row.cells[7].innerText) ? row.cells[7].innerText.trim() : '';
                var expMMYYYY = expRaw;
                if (expRaw && expRaw.indexOf('-') >= 0) {
                    var parts = expRaw.split('-');
                    if (parts.length >= 2) expMMYYYY = parts[1] + '/' + parts[0];
                }
                setVal(ProdBatchEl, batchText === '—' ? '' : batchText);
                setVal(ProdExpiryEl, expMMYYYY === '—' ? '' : expMMYYYY);
                setVal(ProdQtyEl, qtyText);
                setVal(ProdPriceEl, priceText);
                setVal(ProdDiscEl, discText);
                if (typeof loadSalesProductInfo === 'function') loadSalesProductInfo(parseInt(prodId, 10) || 0);
                if (ProdNameEl) ProdNameEl.focus();
            });

            var btnDeleteSelectedSoLine = document.getElementById('btnDeleteSelectedSoLine');
            if (btnDeleteSelectedSoLine) {
                btnDeleteSelectedSoLine.addEventListener('click', function () {
                    if (btnDeleteSelectedSoLine.disabled || isLocked) return;
                    var sel = document.querySelector('#SOLinesTbody tr.erp-list-selectable-row.selected');
                    var lineNo = sel ? parseInt(sel.getAttribute('data-line-no') || '0', 10) : 0;
                    if (lineNo <= 0) { showToast('اختر سطراً في الجدول أولاً.', 'danger'); return; }
                    var msg = 'هل تريد مسح السطر رقم (' + lineNo + ')؟';
                    if (typeof ERP !== 'undefined' && typeof ERP.showConfirmModal === 'function') {
                        ERP.showConfirmModal({ title: 'مسح سطر من أمر البيع', message: msg, confirmText: 'مسح', cancelText: 'إلغاء' }).then(function (confirmed) { if (confirmed) removeLine(lineNo); });
                        return;
                    }
                    if (confirm(msg)) removeLine(lineNo);
                });
            }

            document.getElementById('btnSaveHeader').addEventListener('click', function () {
                var customerId = parseInt(document.getElementById('CustomerId').value, 10) || 0;
                var warehouseId = parseInt(document.getElementById('WarehouseId').value, 10) || 0;
                var notes = '';
                if (customerId <= 0) { showToast('يجب اختيار العميل', 'danger'); return; }
                if (warehouseId <= 0) { showToast('يجب اختيار المخزن', 'danger'); return; }
                fetch('@Url.Action("SaveHeader", "SalesOrders")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ SOId: soId, CustomerId: customerId, WarehouseId: warehouseId, Notes: notes })
                }).then(function (r) {
                    return r.text().then(function (text) {
                        try { return { response: r, data: text ? JSON.parse(text) : {} }; } catch (e) { return { response: r, data: { message: text || 'خطأ في الحفظ' } }; }
                    });
                }).then(function (result) {
                    var r = result.response, data = result.data;
                    if (r.ok && data.success && data.SOId) {
                            soId = data.SOId;
                            document.getElementById('SOId').value = soId;
                            document.getElementById('OrderNumberDisplay').value = data.orderNumber || soId;
                            document.getElementById('OrderDateDisplay').value = data.orderDate || '';
                            document.getElementById('OrderTimeDisplay').value = data.orderTime || '';
                            document.getElementById('StatusDisplay').value = data.isConverted ? 'محول' : (data.status || 'غير مرحلة');
                            if (data.createdBy) document.getElementById('OrderCreatedByDisplay').value = data.createdBy;
                            if (data.isConverted) { document.getElementById('SOIsConverted').value = '1'; isLocked = true; }
                            var btnPrintSo = document.getElementById('btnPrintSoDropdown');
                            if (btnPrintSo && soId > 0) btnPrintSo.disabled = false;
                            if (data.isConverted) {
                                var bds = document.getElementById('btnDeleteSelectedSoLine');
                                if (bds) bds.disabled = true;
                            }
                            showToast('تم حفظ الأمر', 'success');
                            if (soId > 0) { var u = '@Url.Action("Show", "SalesOrders")' + '/' + soId + '?frame=1'; if (window.location.pathname + window.location.search !== u) window.history.replaceState(null, '', u); }
                        } else {
                            showToast(data.message || 'خطأ في الحفظ', 'danger');
                        }
                    }).catch(function () { showToast('فشل الحفظ', 'danger'); });
            });

            document.getElementById('btnAddLine').addEventListener('click', function () {
                var pid = parseInt(document.getElementById('ProdId').value, 10) || 0;
                var qty = parseInt(document.getElementById('ProdQtyInput').value, 10) || 0;
                if (soId <= 0) { showToast('احفظ الأمر أولاً (عميل + مخزن) ثم أضف أصنافاً', 'danger'); return; }
                if (pid <= 0) { showToast('اختر صنفاً', 'danger'); return; }
                if (qty <= 0) { showToast('أدخل كمية صحيحة', 'danger'); return; }
                var price = parseFloat(document.getElementById('ProdPriceInput').value, 10) || 0;
                var disc = parseFloat(document.getElementById('ProdDiscInput').value, 10) || 0;
                var batch = '';
                var expiry = '';
                var batchSelectInRow = document.getElementById('ProdBatchSelectInRow');
                if (batchSelectInRow && !batchSelectInRow.classList.contains('d-none') && currentProductBatches.length > 0) {
                    var idx = parseInt(batchSelectInRow.value, 10);
                    if (!isNaN(idx) && idx >= 0 && idx < currentProductBatches.length) {
                        var b = currentProductBatches[idx];
                        if (b) { batch = (b.batchNo || '').toString().trim(); expiry = (b.expiryText || '').toString().trim(); }
                    }
                }
                if (batch === '' && document.getElementById('ProdBatchInput')) batch = (document.getElementById('ProdBatchInput').value || '').trim();
                if (expiry === '' && document.getElementById('ProdExpiryInput')) expiry = (document.getElementById('ProdExpiryInput').value || '').trim();
                var expectedUnitPrice = price * (1 - disc / 100);
                fetch('@Url.Action("AddLineJson", "SalesOrders")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
                    body: JSON.stringify({ SOId: soId, prodId: pid, qty: qty, requestRetailPrice: price, salesDiscountPct: disc, expectedUnitPrice: expectedUnitPrice, BatchNo: batch || null, expiryText: expiry || null })
                }).then(function (r) {
                    return r.text().then(function (text) {
                        try { return { ok: r.ok, data: text ? JSON.parse(text) : {} }; } catch (e) { return { ok: r.ok, data: { message: text || 'خطأ في الخادم' } }; }
                    });
                }).then(function (result) {
                    var data = result.data;
                    if (result.ok && data.ok) { showToast(data.message || 'تمت الإضافة', 'success'); refreshLines(); document.getElementById('ProdQtyInput').value = '1'; }
                    else showToast(data.message || 'فشل إضافة السطر', 'danger');
                }).catch(function () { showToast('فشل إضافة السطر', 'danger'); });
            });

            document.getElementById('btnClearLines').addEventListener('click', function () {
                var id = parseInt(this.getAttribute('data-so-id'), 10) || soId;
                if (id <= 0) { showToast('لا يوجد أمر محدد', 'danger'); return; }
                if (!confirm('مسح كل أصناف هذا الأمر؟')) return;
                fetch('@Url.Action("ClearAllLinesJson", "SalesOrders")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
                    body: JSON.stringify({ SOId: id })
                }).then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data.ok) { showToast(data.message, 'success'); refreshLines(); }
                        else showToast(data.message || 'خطأ', 'danger');
                    }).catch(function () { showToast('فشل المسح', 'danger'); });
            });

            document.getElementById('btnConvertToSI').addEventListener('click', function () {
                if (soId <= 0) { showToast('احفظ الأمر أولاً', 'danger'); return; }
                if (isLocked) { showToast('الأمر محوّل مسبقاً', 'muted'); return; }
                if (!confirm('تحويل أمر البيع إلى فاتورة مبيعات؟')) return;
                fetch('@Url.Action("ConvertToSalesInvoice", "SalesOrders")/' + soId, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' } })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data.ok) {
                            showToast(data.message || 'تم التحويل', 'success');
                            document.getElementById('SOIsConverted').value = '1';
                            document.getElementById('StatusDisplay').value = 'محول';
                            isLocked = true;
                            document.getElementById('btnSaveHeader').disabled = true;
                            document.getElementById('btnConvertToSI').disabled = true;
                            document.getElementById('btnClearLines').disabled = true;
                            var btnDelSel = document.getElementById('btnDeleteSelectedSoLine');
                            if (btnDelSel) btnDelSel.disabled = true;
                        } else showToast(data.message || 'خطأ', 'danger');
                    }).catch(function () { showToast('فشل التحويل', 'danger'); });
            });

            var btnVol = document.getElementById('btnCustomerVolume');
            if (btnVol) {
                var cid = parseInt(document.getElementById('CustomerId').value, 10) || 0;
                var base = (btnVol.getAttribute('data-base-url') || '').trim();
                var url = cid > 0 ? (base + (base.indexOf('?') >= 0 ? '&' : '?') + 'id=' + cid) : '#';
                btnVol.href = url;
                btnVol.setAttribute('data-url', url);
            }

            var baseUrl = '@Url.Action("Show", "SalesOrders", new { frame = 1 })';
            function setParam(u, key, val) {
                if (!u) return u;
                var sep = u.indexOf('?') >= 0 ? '&' : '?';
                return u + sep + key + '=' + encodeURIComponent(val);
            }
            var btnSoFirst = document.getElementById('btnSoFirst');
            var btnSoPrev = document.getElementById('btnSoPrev');
            var btnSoNext = document.getElementById('btnSoNext');
            var btnSoLast = document.getElementById('btnSoLast');
            if (btnSoFirst) btnSoFirst.setAttribute('data-url', setParam(baseUrl, 'id', @(navFirst ?? 0)));
            if (btnSoPrev) btnSoPrev.setAttribute('data-url', setParam(baseUrl, 'id', @(prevEffective ?? 0)));
            if (btnSoNext) btnSoNext.setAttribute('data-url', setParam(baseUrl, 'id', @(nextEffective ?? 0)));
            if (btnSoLast) btnSoLast.setAttribute('data-url', setParam(baseUrl, 'id', @(navLast ?? 0)));

            var navOrderSearchInput = document.getElementById('NavOrderSearchInput');
            if (navOrderSearchInput) {
                navOrderSearchInput.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        var b = document.getElementById('btnNavOrderSearch');
                        if (b) b.click();
                    }
                });
            }

            syncDeleteSelectedSoLineButton();

            // ——— طباعة أمر البيع (نفس آلية فاتورة المبيعات: piPrintWrapper / print-mode / afterprint) ———
            (function () {
                var btnPrint = document.getElementById('btnPrintSoDropdown');
                if (!btnPrint || btnPrint.dataset.boundSoPrint) return;
                btnPrint.dataset.boundSoPrint = '1';
                var printing = false;
                var printWrapperParent = null;
                var printWrapperNext = null;

                function el(id) { return document.getElementById(id); }

                function prepareSalesOrderPrint() {
                    if (!el('soPrintArea')) return false;
                    var cust = (el('CustomerNameInput') && el('CustomerNameInput').value) ? el('CustomerNameInput').value.trim() : '';
                    if (el('soPrintCustomer')) el('soPrintCustomer').textContent = cust || '—';
                    if (el('soPrintOrderNo')) el('soPrintOrderNo').textContent = (el('OrderNumberDisplay') && el('OrderNumberDisplay').value) ? el('OrderNumberDisplay').value.trim() : '';
                    if (el('soPrintOrderDate')) el('soPrintOrderDate').textContent = (el('OrderDateDisplay') && el('OrderDateDisplay').value) ? el('OrderDateDisplay').value.trim() : '';
                    var whName = '';
                    var whSel = el('WarehouseId');
                    if (whSel && whSel.options && whSel.selectedIndex >= 0) whName = (whSel.options[whSel.selectedIndex].text || '').trim();
                    if (el('soPrintWarehouse')) el('soPrintWarehouse').textContent = whName || '—';
                    if (el('soPrintAuthor')) el('soPrintAuthor').textContent = (el('OrderCreatedByDisplay') && el('OrderCreatedByDisplay').value) ? el('OrderCreatedByDisplay').value.trim() : '—';
                    var phone = (el('CustomerPhone') && el('CustomerPhone').value) ? el('CustomerPhone').value.trim() : '';
                    if (el('soPrintCustomerPhone')) el('soPrintCustomerPhone').textContent = phone || '—';
                    var addr = (el('CustomerAddress') && el('CustomerAddress').value) ? el('CustomerAddress').value.trim() : '';
                    if (el('soPrintCustomerAddress')) el('soPrintCustomerAddress').textContent = addr || '—';
                    if (el('soPrintNow')) el('soPrintNow').textContent = new Date().toLocaleString();
                    var destTbody = el('soPrintMasterTbody');
                    if (!destTbody) return false;
                    destTbody.innerHTML = '';
                    var srcTbody = el('SOLinesTbody');
                    if (!srcTbody) {
                        destTbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-2">لا توجد سطور للطباعة.</td></tr>';
                    } else {
                        var rows = srcTbody.querySelectorAll('tr.erp-list-selectable-row');
                        if (!rows.length) {
                            destTbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-2">لا توجد سطور للطباعة.</td></tr>';
                        } else {
                            rows.forEach(function (tr) {
                                var c = tr.cloneNode(true);
                                c.classList.remove('selected');
                                c.querySelectorAll('button, a, .no-print').forEach(function (x) { x.remove(); });
                                destTbody.appendChild(c);
                            });
                        }
                    }
                    var totalsWrap = el('soPrintTotalsWrap');
                    if (!totalsWrap) return false;
                    var totalLines = el('TotalLinesValue') ? el('TotalLinesValue').textContent.trim() : '0';
                    var totalItems = el('TotalItemsValue') ? el('TotalItemsValue').textContent.trim() : '0';
                    var totalQty = el('TotalQtyValue') ? el('TotalQtyValue').textContent.trim() : '0';
                    var totalRetail = el('TotalRetailValue') ? el('TotalRetailValue').textContent.trim() : '0';
                    var totalAfterDiscount = el('TotalAfterDiscountValue') ? el('TotalAfterDiscountValue').textContent.trim() : '0';
                    var taxPct = (el('TaxPercentInput') && el('TaxPercentInput').value) ? el('TaxPercentInput').value.trim() : '0';
                    var tax = (el('TaxAmountValue') && el('TaxAmountValue').textContent) ? el('TaxAmountValue').textContent.trim() : '0';
                    var grandWithPrev = el('GrandTotalWithPreviousValue') ? el('GrandTotalWithPreviousValue').textContent.trim() : totalAfterDiscount;
                    var prevBalance = el('CustomerPreviousBalanceValue') ? el('CustomerPreviousBalanceValue').textContent.trim() : '0';
                    var creditRemaining = el('CreditRemainingValue') ? el('CreditRemainingValue').textContent.trim() : '0';
                    totalsWrap.innerHTML =
                        '<div class="card shadow-sm invoice-totals-card mb-0">' +
                        '<div class="card-body py-2">' +
                        '<div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-boxes">' +
                        '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">عدد السطور</span><span class="invoice-summary-value">' + totalLines + '</span></div>' +
                        '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">عدد الأصناف</span><span class="invoice-summary-value">' + totalItems + '</span></div>' +
                        '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي الكمية</span><span class="invoice-summary-value">' + totalQty + '</span></div>' +
                        '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">الحساب السابق للعميل</span><span class="invoice-summary-value">' + prevBalance + '</span></div>' +
                        '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">المبلغ المتبقى من الحد الائتماني</span><span class="invoice-summary-value">' + creditRemaining + '</span></div>' +
                        '</div>' +
                        '<div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-totals mt-2">' +
                        '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي سعر الجمهور</span><span class="invoice-summary-value">' + totalRetail + '</span></div>' +
                        '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي الأمر بعد الخصم</span><span class="invoice-summary-value">' + totalAfterDiscount + '</span></div>' +
                        '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">نسبة الضريبة %</span><span class="invoice-summary-value">' + taxPct + '</span></div>' +
                        '<div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">قيمة الضريبة</span><span class="invoice-summary-value">' + tax + '</span></div>' +
                        '<div class="invoice-summary-item invoice-summary-box invoice-summary-box-main"><span class="invoice-summary-label">الإجمالي المتوقع</span><span class="invoice-summary-value invoice-summary-value-main fw-bold">' + grandWithPrev + '</span></div>' +
                        '</div></div></div>';
                    return true;
                }

                function doSoPrint(mode) {
                    var id = parseInt((el('SOId') && el('SOId').value) || '0', 10) || 0;
                    if (id <= 0) {
                        showToast('احفظ الأمر أولاً ثم اطبع.', 'warning');
                        return;
                    }
                    if (printing) return;
                    printing = true;
                    if (!prepareSalesOrderPrint()) {
                        printing = false;
                        showToast('تعذر تجهيز الطباعة.', 'danger');
                        return;
                    }
                    var wrapper = el('soPrintWrapper');
                    var printArea = el('soPrintArea');
                    if (!wrapper || !printArea) { printing = false; return; }
                    wrapper.classList.remove('print-mode-1', 'print-mode-2', 'print-mode-3');
                    wrapper.querySelectorAll('.pi-print-copy:not(#soPrintArea)').forEach(function (c) { c.remove(); });
                    if (mode === 2 || mode === 3) {
                        var copies = mode === 2 ? 2 : 3;
                        for (var i = 1; i < copies; i++) {
                            var clone = printArea.cloneNode(true);
                            clone.id = '';
                            clone.classList.add('pi-print-copy');
                            clone.querySelectorAll('[id]').forEach(function (node) { node.removeAttribute('id'); });
                            wrapper.appendChild(clone);
                        }
                        wrapper.classList.add('print-mode-' + mode);
                    } else {
                        wrapper.classList.add('print-mode-1');
                    }
                    printWrapperParent = null;
                    printWrapperNext = null;
                    if (wrapper.parentNode !== document.body) {
                        printWrapperParent = wrapper.parentNode;
                        printWrapperNext = wrapper.nextSibling;
                        document.body.appendChild(wrapper);
                    }
                    document.body.classList.add('printing-invoice');
                    setTimeout(function () { window.print(); }, 50);
                }

                document.querySelectorAll('[data-so-print-mode]').forEach(function (item) {
                    item.addEventListener('click', function (e) {
                        e.preventDefault();
                        var mode = parseInt(this.getAttribute('data-so-print-mode') || '1', 10);
                        doSoPrint(mode);
                    });
                });

                window.addEventListener('afterprint', function () {
                    document.body.classList.remove('printing-invoice');
                    printing = false;
                    var wrapper = el('soPrintWrapper');
                    if (wrapper) {
                        wrapper.classList.remove('print-mode-1', 'print-mode-2', 'print-mode-3');
                        wrapper.querySelectorAll('.pi-print-copy:not(#soPrintArea)').forEach(function (c) { c.remove(); });
                        if (printWrapperParent) {
                            if (printWrapperNext) printWrapperParent.insertBefore(wrapper, printWrapperNext);
                            else printWrapperParent.appendChild(wrapper);
                            printWrapperParent = null;
                            printWrapperNext = null;
                        }
                    }
                });
            })();
        })();
    </script>
}
