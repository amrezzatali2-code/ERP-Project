@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.SalesOrder

@{
    ViewData["Title"] = Model == null || Model.SOId == 0 ? "أمر بيع جديد" : $"أمر بيع — رقم {Model.SOId}";
    bool isNew = Model == null || Model.SOId == 0;
    bool isLocked = ViewBag.IsLocked == true;
    var linesList = Model?.Lines?.OrderBy(l => l.LineNo).ToList() ?? new List<ERP.Models.SOLine>();
    int totalLines = linesList.Count;
    int totalItems = linesList.Select(l => l.ProdId).Distinct().Count();
    int totalQty = linesList.Sum(l => l.QtyRequested);
    decimal totalRetail = linesList.Sum(l => l.QtyRequested * l.RequestedRetailPrice);
    decimal expectedTotal = Model?.ExpectedItemsTotal ?? 0m;
    decimal taxAmountSo = 0m;
    decimal taxPercentDisplaySo = 0m;
    decimal totalAfterDiscountSo = expectedTotal;
    int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
    int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
    int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
    int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;
    int currentId = Model?.SOId ?? 0;
    int? prevEffective = (currentId == 0) ? navLast : navPrev;
    int? nextEffective = (currentId == 0) ? navFirst : navNext;
    bool hasAny = (navFirst ?? 0) > 0 && (navLast ?? 0) > 0;
    bool canFirst = hasAny && (navFirst ?? 0) != currentId;
    bool canPrev = hasAny && (prevEffective ?? 0) != currentId;
    bool canNext = hasAny && (nextEffective ?? 0) != currentId;
    bool canLast = hasAny && (navLast ?? 0) != currentId;
    string orderDateText = Model != null && Model.SOId > 0 ? Model.SODate.ToString("yyyy/MM/dd") : "";
    string orderTimeText = Model != null && Model.SOId > 0 ? Model.CreatedAt.ToLocalTime().ToString("HH:mm") : "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/invoice-cards.css" />
    <style>
        .pi-input[type="number"]::-webkit-outer-spin-button,
        .pi-input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        .pi-input[type="number"] { -moz-appearance: textfield; }
        .invoice-page { background-color: #f3f6fb; min-height: 0; padding-bottom: 1rem; }
        .invoice-page .container-fluid { padding: 0; max-width: 100%; }
        .invoice-page .col-lg-2.order-1 { padding: 0.5rem 0.5rem; }
        .invoice-page .col-12.col-lg-10.order-2.order-lg-1,
        .invoice-page .col-lg-10.order-2 {
            background: transparent !important;
            padding: 0.5rem 1rem;
            border: none !important;
            box-shadow: none !important;
        }
        #SO_BodyHost,
        div#SO_BodyHost,
        .invoice-page div#SO_BodyHost {
            display: block !important;
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            outline: none !important;
            padding: 0 !important;
        }
        .invoice-page .container-fluid,
        .invoice-page .row {
            border: none !important;
            box-shadow: none !important;
        }
        #SO_BodyHost .invoice-header-card .form-control,
        #SO_BodyHost .invoice-header-card .form-select,
        #SO_BodyHost .invoice-product-card .form-control,
        #SO_BodyHost .invoice-product-card .form-select,
        #SO_BodyHost .invoice-Add-card .form-control,
        #SO_BodyHost .invoice-Add-card .form-select,
        #SO_BodyHost .invoice-totals-card .form-control,
        #SO_BodyHost .invoice-totals-card .form-select {
            border-color: #64748b !important;
        }
        #SO_BodyHost .invoice-header-card .form-control,
        #SO_BodyHost .invoice-header-card .form-select {
            border-radius: 0.375rem;
            padding: 0.4rem 0.55rem;
            min-height: 2rem;
            font-size: 0.875rem;
        }
        #SO_BodyHost .invoice-header-card .card-body .form-control,
        #SO_BodyHost .invoice-header-card .card-body .form-select {
            text-align: center;
        }
        #SO_BodyHost .invoice-header-card #CustomerNameInput {
            text-align: right !important;
        }
        #SO_BodyHost .invoice-header-card #customerDropdownWrap {
            border: 2px solid #4f46e5 !important;
            border-radius: 0.55rem !important;
        }
        #SO_BodyHost .invoice-header-card #customerDropdownWrap:focus-within {
            border-color: #4338ca !important;
            box-shadow: none !important;
        }
        #SO_BodyHost .invoice-header-card #customerDropdownWrap .product-dropdown-onebox:focus-within {
            box-shadow: none !important;
            border-color: transparent !important;
        }
        #SO_BodyHost .invoice-header-card #customerDropdownWrap .product-dropdown-onebox {
            border: 0 !important;
            background: transparent !important;
            border-radius: 0.45rem !important;
        }
        #SO_BodyHost .invoice-Add-card #productDropdownWrap {
            border: 2px solid #4f46e5 !important;
            border-radius: 0.55rem !important;
            padding: 3px !important;
        }
        #SO_BodyHost .invoice-Add-card #productDropdownWrap:focus-within {
            border-color: #4338ca !important;
            box-shadow: none !important;
        }
        #SO_BodyHost .invoice-Add-card .product-dropdown-onebox {
            border: 0 !important;
            background: transparent !important;
            border-radius: 0.45rem !important;
        }
        #SO_BodyHost .invoice-Add-card .product-dropdown-onebox:focus-within {
            box-shadow: none !important;
            border-color: transparent !important;
        }
        #ProdNameInput.pi-product-name-input,
        .invoice-Add-card #ProdNameInput,
        .invoice-Add-card input#ProdNameInput {
            border: 0 !important;
            border-radius: 0.55rem;
            background: transparent !important;
        }
        .product-dropdown-onebox {
            position: relative;
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
            background: #fff;
        }
        .product-dropdown-arrow-inside {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #495057;
            cursor: pointer;
            user-select: none;
            font-size: 0.6rem;
            z-index: 1;
        }
        .product-dropdown-onebox .product-dropdown-input {
            width: 100%;
            border: none !important;
            background: transparent !important;
            padding-left: 2.25rem !important;
        }
        .product-dropdown-list {
            position: fixed;
            z-index: 4000;
            max-height: 240px;
            overflow-y: auto;
            background: #fff;
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,.15);
        }
        .product-dropdown-item { cursor: pointer; }
        .product-dropdown-item-active { background: #e0e7ff !important; }
        div.card.invoice-side-card,
        div.card.invoice-header-card,
        div.card.invoice-product-card,
        div.card.invoice-Add-card,
        div.card.invoice-lines-card,
        div.card.invoice-totals-card {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
            overflow: hidden;
        }
        .invoice-side-card { background: #ffffff !important; min-width: 220px; }
        .invoice-side-card .card-header,
        .invoice-header-bar { background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important; color: #fff !important; border-bottom: none; padding: 0.55rem 1rem; }
        .invoice-side-card .invoice-actions-bar hr { display: none !important; }
        .invoice-side-card .btn-erp { font-size: 0.85rem; padding: 0.35rem 0.6rem; border: 1px solid #64748b !important; }
        .invoice-actions-sticky { position: sticky; top: 58px; z-index: 3000; background: #fff !important; border: 1px solid #6366f1 !important; padding: 10px; border-radius: 12px; box-shadow: 0 1px 3px rgba(99,102,241,.25) !important; }
        .invoice-page .col-lg-10.order-2 { background: transparent; padding: 0.5rem 1rem; }
        .invoice-page .invoice-lines-container {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
            overflow: hidden;
            background: #fff;
        }
        .invoice-lines-header th { background: #e2e8f0 !important; color: #0f172a !important; font-weight: 600; padding: 0.5rem 0.55rem; border: 1px solid #cbd5e1 !important; }
        .invoice-card-line { display: none; }
        /* خط الهيدر الزائف: site.css يفرض sticky + box-shadow على thead — نطابق فاتورة المبيعات ونلغي الظل داخل كارت التشغيلات */
        #SO_BodyHost .invoice-lines-container .erp-table-wrapper table thead.invoice-lines-header th {
            position: sticky;
            top: 0;
            z-index: 10;
            background-color: #e9ecef !important;
            color: #212529 !important;
            font-weight: 600;
            border: 1px solid #dee2e6 !important;
            box-shadow: 0 1px 0 0 #dee2e6 !important;
        }
        #SO_BodyHost .invoice-product-card .table-responsive thead th {
            position: static !important;
            top: auto !important;
            box-shadow: none !important;
        }
        #SO_BodyHost .invoice-product-card #ProdQtyCurrentWarehouse,
        #SO_BodyHost .invoice-product-card #ProdQtyAllWarehouses { max-width: 90px; }
        #SO_BodyHost .invoice-product-card .card-body .form-control,
        #SO_BodyHost .invoice-product-card .card-body .form-control-sm {
            padding: 0.4rem 0.55rem;
            min-height: 2rem;
            font-size: 0.875rem;
        }
        #SO_BodyHost .invoice-header-card .card-body > .row + .row { border-top: none !important; }
        #SO_BodyHost .invoice-lines-container .erp-table tbody tr.erp-list-selectable-row { cursor: pointer; }
        #SO_BodyHost .invoice-lines-container .erp-table tbody tr.erp-list-selectable-row.selected > td {
            background-color: rgba(13, 110, 253, 0.12) !important;
        }
        .invoice-page .so-print-dropdown-menu {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 8px 28px rgba(99, 102, 241, 0.22) !important;
            padding: 0.35rem 0 !important;
            margin-top: 0.35rem !important;
            overflow: hidden;
            min-width: 100%;
        }
        .invoice-page .so-print-dropdown-header { font-weight: 600; color: #475569 !important; letter-spacing: 0.02em; }
        .invoice-page .so-print-dropdown-item {
            display: flex !important;
            align-items: center;
            gap: 0.65rem;
            padding: 0.55rem 1rem !important;
            font-size: 0.9rem;
            font-weight: 500;
            color: #0f172a !important;
        }
        .invoice-page .invoice-lines-container .erp-table-wrapper {
            max-height: 360px;
            overflow: auto;
            border: none;
            border-radius: 0;
        }
        #soToastContainer { position: fixed; top: 70px; left: 50%; transform: translateX(-50%); z-index: 9999; pointer-events: none; display: flex; flex-direction: column; align-items: center; gap: 0.35rem; }
        #soToastContainer .so-toast { padding: 0.6rem 1.2rem; border-radius: 8px; font-size: 0.9rem; box-shadow: 0 2px 8px rgba(0,0,0,.12); }
        #soToastContainer .so-toast.text-success { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
        #soToastContainer .so-toast.text-danger { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
        #soToastContainer .so-toast.text-muted { background: #f1f5f9; color: #334155; border: 1px solid #64748b; }
        .invoice-totals-card .card-body { padding: 0.9rem 1rem !important; }
        .invoice-summary-row {
            flex-wrap: wrap;
            gap: 0.35rem 0.5rem;
            align-items: stretch;
            justify-content: space-between;
        }
        .invoice-totals-card .invoice-summary-item.invoice-summary-box {
            flex: 1 1 0;
            min-width: 0;
            max-width: 100%;
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
            align-items: center;
            justify-content: flex-start;
            padding: 0.25rem 0.35rem;
            background: #f8fafc;
            border: 1px solid #64748b;
            border-radius: 6px;
        }
        .invoice-totals-card .invoice-summary-label {
            font-size: 0.8rem;
            line-height: 1.2;
            color: #64748b;
            margin-bottom: 0;
        }
        .invoice-totals-card .invoice-summary-value {
            font-size: 1rem;
            font-weight: 500;
            color: #0f172a;
        }
        .invoice-totals-card .invoice-summary-value-main {
            font-size: 1.05rem;
            color: #fff !important;
        }
        .invoice-summary-tax-input {
            max-width: 75px;
            font-size: 0.95rem;
            text-align: center;
            border: 1px solid #64748b;
            border-radius: 5px;
            padding: 0.25rem 0.35rem;
        }
        .invoice-summary-box-main {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%) !important;
            border-color: #0284c7 !important;
        }
        .invoice-summary-box-main .invoice-summary-label { color: rgba(255,255,255,.9); }
        @@media (max-width: 992px) { .invoice-actions-sticky { top: 56px; } }
    </style>
}

<div class="invoice-page" dir="rtl">
    <div id="soToastContainer" aria-live="polite"></div>
    <div class="container-fluid pt-3">
        <form id="__AntiForgeryForm" method="post" style="display:none">@Html.AntiForgeryToken()</form>

        <div class="row g-3">
            @* الشريط الجانبي — نفس مكونات فاتورة المبيعات *@
            <div class="col-12 col-lg-2 order-1 order-lg-2">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="invoice-header-bar d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <h6 class="mb-0">إجراءات أمر البيع</h6>
                    </div>
                    <input type="hidden" id="SOId" value="@(Model?.SOId ?? 0)" />
                    <input type="hidden" id="SOIsConverted" value="@(Model?.IsConverted == true ? "1" : "0")" />

                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">
                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            @* معرفات SO-*: لا تستخدم open-same-tab — التنقّل عبر اعتراض capture + نفس النافذة (انظر docs/erp-sidebar-navigation-arrows.md) *@
                            <button type="button" id="btnSoFirst" class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-base-url="@Url.Action("Show", "SalesOrders", new { frame = 1 })"
                                    data-id="@(navFirst ?? 0)" title="أول أمر" @(canFirst ? "" : "disabled")>⏮</button>
                            <button type="button" id="btnSoPrev" class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-base-url="@Url.Action("Show", "SalesOrders", new { frame = 1 })"
                                    data-id="@(prevEffective ?? 0)" title="السابق" @(canPrev ? "" : "disabled")>◀</button>
                            <button type="button" id="btnSoNext" class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-base-url="@Url.Action("Show", "SalesOrders", new { frame = 1 })"
                                    data-id="@(nextEffective ?? 0)" title="التالي" @(canNext ? "" : "disabled")>▶</button>
                            <button type="button" id="btnSoLast" class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-base-url="@Url.Action("Show", "SalesOrders", new { frame = 1 })"
                                    data-id="@(navLast ?? 0)" title="آخر أمر" @(canLast ? "" : "disabled")>⏭</button>
                        </div>
                        <div class="d-flex align-items-center gap-1">
                            <input type="number" id="NavOrderSearchInput" class="form-control form-control-sm" placeholder="بحث برقم الأمر" />
                            <button type="button" id="btnNavOrderSearch" class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-base-url="@Url.Action("Show", "SalesOrders", new { frame = 1 })">بحث</button>
                        </div>

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           data-tab-id="so-show-tab" data-tab-title="أمر بيع"
                           data-url="@Url.Action("Create", "SalesOrders", new { frame = 1 })">➕ أمر بيع جديد</a>

                        <button type="button" id="btnSaveHeader" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" @(isLocked ? "disabled" : "")>💾 حفظ الأمر</button>
                        <button type="button" id="btnConvertToSI" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" @(isLocked ? "disabled" : "")>🔄 تحويل إلى فاتورة مبيعات</button>
                        <button type="button" id="btnClearLines" class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100" data-so-id="@(Model?.SOId ?? 0)" @(isLocked ? "disabled" : "")>🗑️ مسح كل الأصناف</button>

                        <div class="erp-list-toolbar-selected-actions d-flex flex-column gap-1 w-100">
                            <button type="button" id="btnDeleteSelectedSoLine" class="btn btn-erp btn-erp-secondary btn-erp-sm w-100" @(isLocked ? "disabled" : "") title="مسح السطر المحدد في الجدول">🗑️ مسح السطر المحدد</button>
                        </div>

                        <div>
                            <button type="button" id="btnOpenProductMovement" class="btn btn-erp btn-erp-outline-secondary btn-erp-sm w-100">📊 حركة الصنف</button>
                        </div>
                        <div>
                            <button type="button" id="btnOpenProductEdit" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100">✏️ تعديل بيانات الصنف</button>
                        </div>
                        <a href="@(Model?.CustomerId > 0 ? Url.Action("Show", "Customers", new { id = Model.CustomerId, frame = 1 }) : "#")" id="btnCustomerVolume" class="btn btn-erp btn-erp-outline-secondary btn-erp-sm open-same-tab w-100 text-decoration-none"
                           data-tab-id="customer-engagement" data-tab-title="حجم تعامل عميل"
                           data-base-url="@Url.Action("Show", "Customers", new { frame = 1 })">📊 حجم تعامل</a>

                        @if (Model?.SOId > 0)
                        {
                            <a href="@Url.Action("ExportShowExcel", "SalesOrders", new { id = Model.SOId })" target="_blank" rel="noopener" class="btn btn-erp btn-erp-success btn-erp-sm w-100 text-decoration-none">📥 تصدير Excel</a>
                        }

                        <div class="dropdown w-100 si-print-dropdown">
                            <button type="button" id="btnPrintSoDropdown"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100 dropdown-toggle si-print-dropdown-btn"
                                    data-bs-toggle="dropdown" aria-expanded="false" @(Model?.SOId > 0 ? "" : "disabled")>
                                🖨️ طباعة
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end w-100 so-print-dropdown-menu" aria-labelledby="btnPrintSoDropdown">
                                <li class="so-print-dropdown-header px-3 py-2 small text-muted border-bottom mb-0">اختر نوع الطباعة</li>
                                <li><a class="dropdown-item so-print-dropdown-item" href="#" data-so-print-mode="1"><span class="si-print-opt-icon" aria-hidden="true">📄</span><span class="si-print-opt-text">طباعة صفحة واحدة</span></a></li>
                                <li><a class="dropdown-item so-print-dropdown-item" href="#" data-so-print-mode="2"><span class="si-print-opt-icon" aria-hidden="true">📑</span><span class="si-print-opt-text">طباعة أصل وصورة</span></a></li>
                                <li><a class="dropdown-item so-print-dropdown-item" href="#" data-so-print-mode="3"><span class="si-print-opt-icon" aria-hidden="true">📚</span><span class="si-print-opt-text">طباعة أصل وصورتين</span></a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            @* المحتوى الرئيسي — نفس ترتيب الكروت كفاتورة المبيعات *@
            <div class="col-12 col-lg-10 order-2 order-lg-1">
                <div id="SO_BodyHost">
                    @* 1) كارت بيانات الأمر + العميل + المخزن *@
                    <div class="card shadow-sm mb-2 invoice-header-card">
                        <div class="invoice-header-bar"><h6 class="mb-0">أمر بيع</h6></div>
                        <div class="card-body">
                            <div class="row g-3 align-items-end">
                                <div class="col-lg-1 col-md-2">
                                    <label class="form-label form-label-sm">كود العميل</label>
                                    <input id="CustomerCodeDisplay" class="form-control form-control-sm text-center" type="number" readonly />
                                    <input type="hidden" id="CustomerId" value="@(Model?.CustomerId ?? 0)" />
                                </div>
                                <div class="col-lg-4 col-md-3">
                                    <label for="CustomerNameInput" class="form-label form-label-sm">اسم العميل</label>
                                    <div class="position-relative" id="customerDropdownWrap">
                                        <div class="product-dropdown-onebox" id="customerDropdownInputGroup">
                                            <span class="product-dropdown-arrow-inside" id="customerDropdownArrow" title="افتح القائمة">▼</span>
                                            <input id="CustomerNameInput"
                                                   name="CustomerNameInput"
                                                   type="text"
                                                   class="form-control form-control-sm product-dropdown-input"
                                                   placeholder="اكتب اسم العميل"
                                                   autocomplete="off"
                                                   value="@(ViewBag.SelectedCustomerName ?? Model?.Customer?.CustomerName)" />
                                        </div>
                                        <div id="customerDropdownList" class="product-dropdown-list" role="listbox" data-open="false"></div>
                                    </div>
                                    <div id="customerSuspendedMsg" class="small text-danger mt-1 d-none">⚠️ العميل موقوف — لا يمكن حفظ الأمر.</div>
                                </div>
                                <div class="col-lg-1 col-md-2">
                                    <label class="form-label form-label-sm">رقم الأمر</label>
                                    <input id="OrderNumberDisplay" class="form-control form-control-sm text-center" value="@(Model?.SOId > 0 ? Model.SOId.ToString() : "")" readonly />
                                </div>
                                <div class="col-lg-2 col-md-6">
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <label class="form-label form-label-sm">تاريخ الأمر</label>
                                            <input id="OrderDateDisplay" class="form-control form-control-sm text-center" value="@orderDateText" readonly />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label form-label-sm">وقت الإنشاء</label>
                                            <input id="OrderTimeDisplay" class="form-control form-control-sm text-center" value="@orderTimeText" readonly />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-2 col-md-2">
                                    <label class="form-label form-label-sm">المخزن</label>
                                    <select id="WarehouseId" asp-for="WarehouseId" asp-items="ViewBag.Warehouses" class="form-select form-select-sm">
                                        <option value="">اختر المخزن</option>
                                    </select>
                                </div>
