@* Views/SalesOrders/Index.cshtml — قائمة أوامر البيع بنفس نموذج الفواتير *@
@using Microsoft.AspNetCore.Html        @* علشان IHtmlContent و HtmlString *@
@using ERP.Infrastructure               @* كلاس PagedResult *@
@model PagedResult<ERP.Models.SalesOrder>

@{
    ViewData["Title"] = "قائمة أوامر البيع";

    // أسماء الأكشن/الكنترولر الحالية (مهم علشان Link() يشتغل صح)
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "SalesOrders";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = Model.SearchBy ?? (string?)ViewBag.SearchBy ?? "id";        // افتراضي: البحث برقم الأمر
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "SODate";    // افتراضي: التاريخ
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "desc");

    // بيانات الترقيم
    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int totalSoCards = ViewBag.TotalCountForCards != null ? (int)ViewBag.TotalCountForCards : total;
    decimal totalExpectedCards = ViewBag.TotalExpectedForCards != null ? (decimal)ViewBag.TotalExpectedForCards : 0m;
    var n2 = System.Globalization.CultureInfo.InvariantCulture;

    // نطاق العرض السفلي — نمط القوائم (ps=0 يعني «الكل»)
    int start = total == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
    int end = (ps == 0 || total == 0) ? total : Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;
    var dateField = (string?)ViewBag.DateField ?? "SODate";

    // فلاتر الأعمدة بنمط Excel
    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_date = ViewBag.FilterCol_Date as string;
    string? filterCol_customer = ViewBag.FilterCol_Customer as string;
    string? filterCol_warehouse = ViewBag.FilterCol_Warehouse as string;
    string? filterCol_status = ViewBag.FilterCol_Status as string;
    string? filterCol_createdBy = ViewBag.FilterCol_CreatedBy as string;
    string? filterCol_region = ViewBag.FilterCol_Region as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_totalExpr = ViewBag.FilterCol_TotalExpr as string;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_idExpr,
        filterCol_date,
        filterCol_customer,
        filterCol_warehouse,
        filterCol_region,
        filterCol_status,
        filterCol_totalExpr,
        filterCol_createdBy
    })!;

    string? FilterForCol(string colKey) =>
        colKey == "id" ? (!string.IsNullOrWhiteSpace(filterCol_idExpr) ? filterCol_idExpr : filterCol_id)
        : colKey == "date" ? filterCol_date
        : colKey == "customer" ? filterCol_customer
        : colKey == "warehouse" ? filterCol_warehouse
        : colKey == "region" ? filterCol_region
        : colKey == "status" ? filterCol_status
        : colKey == "total" ? filterCol_totalExpr
        : colKey == "createdby" ? filterCol_createdBy
        : null;

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid erp-so-index">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0 fs-6 text-secondary">@ViewData["Title"]</h5>
    </div>

    @* ===== شريط الفلاتر الموحد (بنفس قائمة المبيعات) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في أوامر البيع</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:160px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>الكل</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>رقم أمر البيع</option>
                            <option value="customer"@Html.Raw(searchBy == "customer" ? " selected" : "")>العميل</option>
                            <option value="warehouse"@Html.Raw(searchBy == "warehouse" ? " selected" : "")>المخزن</option>
                            <option value="status"@Html.Raw(searchBy == "status" ? " selected" : "")>الحالة</option>
                            <option value="createdBy"@Html.Raw(searchBy == "createdBy" ? " selected" : "")>الكاتب</option>
                        </select>
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                    @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
                    @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    <input type="hidden" name="filterCol_id" value="@(filterCol_id ?? "")" />
                    <input type="hidden" name="filterCol_idExpr" value="@(filterCol_idExpr ?? "")" />
                    <input type="hidden" name="filterCol_date" value="@(filterCol_date ?? "")" />
                    <input type="hidden" name="filterCol_customer" value="@(filterCol_customer ?? "")" />
                    <input type="hidden" name="filterCol_warehouse" value="@(filterCol_warehouse ?? "")" />
                    <input type="hidden" name="filterCol_region" value="@(filterCol_region ?? "")" />
                    <input type="hidden" name="filterCol_status" value="@(filterCol_status ?? "")" />
                    <input type="hidden" name="filterCol_totalExpr" value="@(filterCol_totalExpr ?? "")" />
                    <input type="hidden" name="filterCol_createdBy" value="@(filterCol_createdBy ?? "")" />
                </form>
            </div>

            @* --- القسم الثاني: فلتر رقم الأمر --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر رقم أمر البيع</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: صف أدوات + صف (حذف / Excel / تصدير) — نمط القوائم --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    @* dir=rtl: أول عنصر = أقصى اليمين — فلترة | أعمدة | طباعة (مكان حجم التعامل سابقاً) | عرض *@
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center" dir="rtl">
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalSO">اختيار الأعمدة</button>
                        <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <button type="button" id="btnShowSO" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="عرض أمر البيع">عرض</button>
                    </div>
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center" dir="rtl">
                        <button type="button" id="btnCustomerVolumeSO" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="حجم تعامل العميل">حجم التعامل</button>
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteSelected">حذف المحدد</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف الجميع</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="SalesOrders" class="d-inline-flex flex-nowrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                            @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
                            @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="codeFrom" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="codeTo" value="@toCode" /> }
                            <input type="hidden" name="filterCol_id" value="@(filterCol_id ?? "")" />
                            <input type="hidden" name="filterCol_idExpr" value="@(filterCol_idExpr ?? "")" />
                            <input type="hidden" name="filterCol_date" value="@(filterCol_date ?? "")" />
                            <input type="hidden" name="filterCol_customer" value="@(filterCol_customer ?? "")" />
                            <input type="hidden" name="filterCol_warehouse" value="@(filterCol_warehouse ?? "")" />
                            <input type="hidden" name="filterCol_region" value="@(filterCol_region ?? "")" />
                            <input type="hidden" name="filterCol_status" value="@(filterCol_status ?? "")" />
                            <input type="hidden" name="filterCol_totalExpr" value="@(filterCol_totalExpr ?? "")" />
                            <input type="hidden" name="filterCol_createdBy" value="@(filterCol_createdBy ?? "")" />
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;" title="اختر صيغة التصدير">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                    <form id="bulkDeleteForm" asp-action="BulkDelete" asp-controller="SalesOrders" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="selectedIds" id="selectedIdsInput" />
                    </form>
                    <form id="deleteAllForm" asp-action="DeleteAll" asp-controller="SalesOrders" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>
        </div>
    </div>

    @* ===== كروت إجمالي العدد وإجمالي القيمة المتوقعة (بعد الفلترة) ===== *@
    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row mb-3" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي العدد</div>
                    <div class="h4 mb-0 text-primary fw-bold">@totalSoCards.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #15803d !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي القيمة المتوقعة</div>
                    <div class="h4 mb-0 text-success fw-bold">@totalExpectedCards.ToString("N2", n2)</div>
                </div>
            </div>
        </div>
    </div>

    @* ===== جدول أوامر البيع ===== *@
    <div class="erp-print-area">
        <h5 class="mb-2 print-only fs-6 text-secondary">@ViewData["Title"]</h5>
    <div class="erp-table-scroll-container mt-0 erp-list-table-after-summary ps-0 pe-0" id="soTableScrollContainer">
        <div class="erp-table-wrapper" id="soTableWrapper">
            <table id="soTable" class="table table-striped table-hover erp-table erp-table-sortable">
                <thead class="table-light sticky-top" style="position: sticky; top: 0; z-index: 10; font-weight: 600;">
                    <tr>
                        <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true"><input type="checkbox" id="chkAllRows" /></th>
                        <th data-col="id">@filterableCol("id", "SOId", "رقم الأمر")</th>
                        <th data-col="date">@filterableCol("date", "SODate", "تاريخ الأمر")</th>
                        <th data-col="customer">@filterableCol("customer", "CustomerId", "العميل")</th>
                        <th data-col="warehouse">@filterableCol("warehouse", "WarehouseId", "المخزن")</th>
                        <th data-col="region">@filterableCol("region", "Region", "المنطقة")</th>
                        <th data-col="status">@filterableCol("status", "Status", "الحالة")</th>
                        <th data-col="total">@filterableCol("total", "ExpectedItemsTotal", "الإجمالي")</th>
                        <th data-col="createdBy">@filterableCol("createdby", "CreatedBy", "الكاتب")</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">لا توجد بيانات.</td></tr>
                    }
                    else
                    {
                        foreach (var so in Model.Items)
                        {
                            var showUrl = Url.Action("Show", "SalesOrders", new { id = so.SOId }) + "?frame=1";
                            var volUrl = so.CustomerId > 0 ? Url.Action("Show", "Customers", new { id = so.CustomerId, frame = 1 }) : "";
                            var regionDisplay = so.Customer == null
                                ? ""
                                : (!string.IsNullOrWhiteSpace(so.Customer.RegionName)
                                    ? so.Customer.RegionName
                                    : (so.Customer.Area != null && so.Customer.Area.AreaName != null
                                        ? so.Customer.Area.AreaName
                                        : ""));
                            <tr class="erp-list-selectable-row"
                                data-so-id="@so.SOId"
                                data-show-url="@showUrl"
                                data-tab-title="أمر بيع"
                                data-customer-volume-url="@volUrl">
                                <td class="text-center no-print" data-col="select"><input type="checkbox" class="row-select" value="@so.SOId" /></td>
                                <td data-col="id">@so.SOId</td>
                                <td data-col="date">@so.SODate.ToString("yyyy-MM-dd")</td>
                                <td data-col="customer" class="text-start">@(so.Customer?.CustomerName ?? so.CustomerId.ToString())</td>
                                <td data-col="warehouse" class="text-start">@(so.Warehouse?.WarehouseName ?? so.WarehouseId.ToString())</td>
                                <td data-col="region" class="text-start">@regionDisplay</td>
                                <td data-col="status">@so.Status</td>
                                <td data-col="total">@so.ExpectedItemsTotal.ToString("0.00")</td>
                                <td data-col="createdBy">@so.CreatedBy</td>
                            </tr>
                        }
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr class="fw-bold">
                        <td class="text-center no-print" data-col="select"></td>
                        <td data-col="id" class="text-muted">إجمالي</td>
                        <td data-col="date"></td>
                        <td data-col="customer"></td>
                        <td data-col="warehouse"></td>
                        <td data-col="region"></td>
                        <td data-col="status"></td>
                        <td data-col="total">@totalExpectedCards.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)</td>
                        <td data-col="createdBy"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
    </div>

    @* ===== الشريط السفلي ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print" dir="rtl">
        <small class="text-muted text-start">عرض @start - @end من @total</small>
        <form method="get" action="@Url.Action(action, controller)" class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
            @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
            <input type="hidden" name="filterCol_id" value="@(filterCol_id ?? "")" />
            <input type="hidden" name="filterCol_idExpr" value="@(filterCol_idExpr ?? "")" />
            <input type="hidden" name="filterCol_date" value="@(filterCol_date ?? "")" />
            <input type="hidden" name="filterCol_customer" value="@(filterCol_customer ?? "")" />
            <input type="hidden" name="filterCol_warehouse" value="@(filterCol_warehouse ?? "")" />
            <input type="hidden" name="filterCol_region" value="@(filterCol_region ?? "")" />
            <input type="hidden" name="filterCol_status" value="@(filterCol_status ?? "")" />
            <input type="hidden" name="filterCol_totalExpr" value="@(filterCol_totalExpr ?? "")" />
            <input type="hidden" name="filterCol_createdBy" value="@(filterCol_createdBy ?? "")" />
            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
            </select>
        </form>
    </div>

    @* ===== الترقيم (Pagination) بنفس شكل المحافظات والفواتير ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة التاريخ/الوقت ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ أمر البيع)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="filterCol_id" value="@(filterCol_id ?? "")" />
                    <input type="hidden" name="filterCol_idExpr" value="@(filterCol_idExpr ?? "")" />
                    <input type="hidden" name="filterCol_date" value="@(filterCol_date ?? "")" />
                    <input type="hidden" name="filterCol_customer" value="@(filterCol_customer ?? "")" />
                    <input type="hidden" name="filterCol_warehouse" value="@(filterCol_warehouse ?? "")" />
                    <input type="hidden" name="filterCol_region" value="@(filterCol_region ?? "")" />
                    <input type="hidden" name="filterCol_status" value="@(filterCol_status ?? "")" />
                    <input type="hidden" name="filterCol_totalExpr" value="@(filterCol_totalExpr ?? "")" />
                    <input type="hidden" name="filterCol_createdBy" value="@(filterCol_createdBy ?? "")" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(Model.UseDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== لوحة فلتر العمود ===== *@
<div id="erpColumnFilterPanel" class="erp-column-filter-panel d-none" dir="rtl">
    <div class="erp-column-filter-header">
        <span id="erpColumnFilterTitle">ترتيب وفلتر</span>
        <button type="button" class="btn-close btn-sm" id="erpColumnFilterClose" aria-label="إغلاق"></button>
    </div>
    <div class="erp-column-filter-body">
        <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
            <label class="form-label small mb-1 fw-bold">الترتيب:</label>
            <div class="d-flex flex-column gap-1">
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
            </div>
        </div>
        <div class="erp-filter-section">
            <div id="erpColumnFilterSearchRow">
                <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                <input type="text" id="erpColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
            </div>
            <div id="erpColumnFilterList" class="erp-column-filter-list">
                <div class="text-muted text-center py-3">جاري التحميل...</div>
            </div>
        </div>
        <div class="erp-column-filter-actions">
            <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOk">تطبيق</button>
            <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClear">مسح الفلتر</button>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print erp-columns-modal"
     id="columnsModalSO"
     tabindex="-1"
     aria-labelledby="columnsModalSOLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalSOLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListSO" class="erp-columns-modal-list"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsSO"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        (function () {
            var el = document.getElementById("soTableScrollContainer");
            if (el) requestAnimationFrame(function () { el.scrollLeft = el.scrollWidth - el.clientWidth; });
        })();

        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanel',
            tableId: 'soTable',
            wrapperId: 'soTableWrapper',
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "SalesOrders")',
            defaultSort: 'SODate',
            defaultDir: 'desc',
            numericColumns: ['id', 'total']
        });

        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // اختيار صف + عرض أمر البيع + حجم تعامل العميل
        // =========================
        if (typeof ERP !== "undefined" && ERP.initListSelection) {
            ERP.initListSelection({
                rowSelector: ".erp-list-selectable-row",
                showButtonId: "btnShowSO",
                idAttribute: "data-so-id",
                showUrlAttribute: "data-show-url",
                tabTitleAttribute: "data-tab-title",
                showTabId: "so-show-tab",
                movementButtonId: "btnCustomerVolumeSO",
                movementUrlAttribute: "data-customer-volume-url",
                movementTabTitle: "حجم تعامل عميل",
                movementTabId: "customer-engagement"
            });
        }

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table = document.getElementById("soTable");
            if (!table) return;

            const chkAll  = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected");
            const bulkForm          = document.getElementById("bulkDeleteForm");
            const selectedInput     = document.getElementById("selectedIdsInput");

            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل أمر بيع واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف أوامر البيع المحددة؟ سيتم حذف السطور التابعة لها أيضاً.")) return;

                selectedInput.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("deleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع أوامر البيع وسطورها. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("soTable");
            if (!table) return;

            const storageKey = "so-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListSO");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsSO")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalSO");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر رقم الأمر من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else url.searchParams.delete("fromCode");
                if (codeTo) url.searchParams.set("toCode", codeTo);
                else url.searchParams.delete("toCode");
                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
