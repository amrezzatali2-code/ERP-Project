@* ============================
   صفحة تأكيد حذف أمر البيع (الهيدر)
   ============================ *@
@model ERP.Models.SalesOrder
@{
    ViewData["Title"] = "حذف أمر بيع";
}

<section class="container" dir="rtl">
    <h2 class="mt-3 mb-4">حذف أمر بيع</h2>

    <div class="alert alert-warning" role="alert">
        <strong>تنبيه:</strong> سيتم حذف <u>أمر البيع</u> وجميع <u>سطوره</u> المرتبطة نهائيًا.
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-header">مراجعة البيانات قبل الحذف</div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">رقم الأمر</dt>
                <dd class="col-sm-9">@Model.SOId</dd>

                <dt class="col-sm-3">التاريخ</dt>
                <dd class="col-sm-9">@Model.SODate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">العميل</dt>
                <dd class="col-sm-9">@Model.CustomerId</dd>

                <dt class="col-sm-3">المخزن</dt>
                <dd class="col-sm-9">@Model.WarehouseId</dd>

                <dt class="col-sm-3">الحالة</dt>
                <dd class="col-sm-9">@Model.Status</dd>

                <dt class="col-sm-3">ملاحظات</dt>
                <dd class="col-sm-9">@Model.Notes</dd>
            </dl>
        </div>
    </div>

    <div class="d-flex gap-2">
        <form asp-action="Delete" asp-route-id="@Model.SOId" method="post"
              onsubmit="return confirm('هل أنت متأكد من حذف أمر البيع وجميع سطوره؟');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">حذف الأمر وسطورِه</button>
        </form>

        <a asp-action="Index" class="btn btn-secondary">إلغاء والعودة</a>
    </div>
</section>
