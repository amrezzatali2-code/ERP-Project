@* Views/PRLines/Index.cshtml — قائمة سطور طلبات الشراء بنفس نظام القوائم الموحد *@
@using Microsoft.AspNetCore.Html          @* لاستخدام HtmlString *@
@using ERP.Infrastructure                 @* لاستخدام PagedResult *@
@using ERP.Models                         @* لاستخدام الموديل PRLine *@
@model PagedResult<PRLine>

@{
    ViewData["Title"] = "سطور طلبات الشراء";

    // أسماء الأكشن/الكنترولر الحالية
    var action     = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "PRLines";

    // قيم البحث/الترتيب الحالية
    var search   = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";      // all | pr | line | prod | qty
    var sort     = Model.SortColumn ?? (string?)ViewBag.Sort ?? "PRId";
    var dir      = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    // بيانات الترقيم
    int ps    = Model.PageSize;
    int total = Model.TotalCount;
    int page  = Model.PageNumber;
    int pages = Model.TotalPages;

    // نطاق العرض السفلي (عرض X - Y من Z)
    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end   = Math.Min(total, page * ps);

    int first = 1;
    int last  = Math.Max(1, pages);
    int prev  = Math.Max(first, page - 1);
    int next  = Math.Min(last, page + 1);

    // فلتر كود من/إلى على كود الصنف ProdId
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode   = ViewBag.ToCode as int?;

    // دالة توليد لينكات الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        fromCode,
        toCode
    })!;

    // دالة إنشاء لينك الترتيب في رأس الجدول + أيقونة السهم (نفس فكرة SalesInvoiceLines)
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir    = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir  = newDir,
            page = 1,
            pageSize = ps,
            fromCode,
            toCode
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };
}

<div dir="rtl" class="container-fluid">

    @* ===== شريط الفلاتر الموحد (بنفس قائمة المبيعات) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في أصناف طلبات الشراء</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:160px">
                            <option value="all"@Html.Raw(searchBy == "" || searchBy == "all" ? " selected" : "")>الكل</option>
                            <option value="pr"@Html.Raw(searchBy == "pr" ? " selected" : "")>رقم طلب الشراء</option>
                            <option value="line"@Html.Raw(searchBy == "line" ? " selected" : "")>رقم السطر</option>
                            <option value="prod"@Html.Raw(searchBy == "prod" ? " selected" : "")>كود الصنف</option>
                            <option value="qty"@Html.Raw(searchBy == "qty" ? " selected" : "")>الكمية المطلوبة</option>
                        </select>
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر كود الصنف --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر كود الصنف</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnBulkDelete">حذف المحدد</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="PRLines" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:70px;min-width:70px;font-size:0.8rem;padding:0.25rem 0.4rem;">
                                <option value="csv">CSV</option>
                                <option value="excel" selected>Excel</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                    <form id="bulkDeleteForm" asp-action="BulkDelete" asp-controller="PRLines" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>
        </div>
    </div>

    @* ===== رسائل النجاح/الخطأ من TempData ===== *@
    @if (TempData["Success"] is string success && !string.IsNullOrWhiteSpace(success))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @success
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="إغلاق"></button>
        </div>
    }
    @if (TempData["Error"] is string error && !string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="إغلاق"></button>
        </div>
    }

    @* ===== جدول سطور طلبات الشراء ===== *@
    <div class="erp-table-scroll-container mt-3 erp-print-area" id="prLinesTableScrollContainer">
        <div class="erp-table-wrapper" id="prLinesTableWrapper">
            <table id="prLinesTable" class="table table-striped table-hover erp-table">
                <thead class="table-light sticky-top">
                    <tr>
                        <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                            <input type="checkbox" id="selectAll" />
                        </th>

                        <th data-col="prid">@sortLink("PRId", "رقم طلب الشراء")</th>
                    <th data-col="lineno">@sortLink("LineNo", "رقم السطر")</th>
                    <th data-col="prodid">@sortLink("ProdId", "كود الصنف")</th>
                    <th data-col="prodname">@sortLink("prodname", "اسم الصنف")</th>
                    <th data-col="qty">@sortLink("QtyRequested", "الكمية المطلوبة")</th>

                    <th data-col="priceBasis">مرجع السعر</th>
                    <th data-col="priceRetail">سعر الجمهور المرجعي</th>
                    <th data-col="disc">خصم الشراء %</th>
                    <th data-col="expectedCost">التكلفة المتوقعة</th>
                    <th data-col="linevalue">@sortLink("linevalue", "قيمة السطر")</th>
                    <th data-col="batch">التشغيلة المفضلة</th>
                    <th data-col="expiry">الصلاحية المفضلة</th>
                        <th data-col="qtyConv">الكمية المحوّلة</th>

                        <th class="text-center no-print" style="width:140px;" data-col="actions" data-col-fixed="true">إجراءات</th>
                    </tr>
                </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="15" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var l in Model.Items)
                    {
                        var key = $"{l.PRId}_{l.LineNo}";   @* مفتاح مركّب للسطر: رقم الطلب + رقم السطر *@

                        // ✅ اسم الصنف من جدول Products
                        var prodName = l.Product?.ProdName ?? "";

                        // ✅ حساب قيمة السطر = (QtyRequested * PriceRetail) * (1 - PurchaseDiscountPct / 100)
                        decimal lineValue = (l.QtyRequested * l.PriceRetail) * (1m - (l.PurchaseDiscountPct / 100m));

                        <tr>
                            <td class="text-center no-print">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@key" />
                            </td>

                            <td data-col="prid">@l.PRId</td>
                            <td data-col="lineno">@l.LineNo</td>
                            <td data-col="prodid">@l.ProdId</td>
                            <td data-col="prodname">@prodName</td>
                            <td data-col="qty">@l.QtyRequested</td>

                            <td data-col="priceBasis">@l.PriceBasis</td>
                            <td data-col="priceRetail">@l.PriceRetail.ToString("0.00")</td>
                            <td data-col="disc">@l.PurchaseDiscountPct.ToString("0.00")</td>
                            <td data-col="expectedCost">@l.ExpectedCost.ToString("0.0000")</td>
                            <td data-col="linevalue">@lineValue.ToString("0.00")</td>
                            <td data-col="batch">@l.PreferredBatchNo</td>
                            <td data-col="expiry">
                                @(l.PreferredExpiry.HasValue
                                    ? l.PreferredExpiry.Value.ToString("yyyy-MM-dd")
                                    : "")
                            </td>
                            <td data-col="qtyConv">@l.QtyConverted</td>

                            <td class="text-center text-nowrap no-print">
                                <a class="btn btn-erp btn-erp-primary btn-erp-sm open-tab"
                                   href="@Url.Action("Show", "PurchaseRequests", new { id = l.PRId, frame = 1 })"
                                   data-tab-id="pr-show-tab"
                                   data-tab-title="طلب شراء">
                                    عرض
                                </a>

                                <form asp-action="Delete"
                                      asp-route-prId="@l.PRId"
                                      asp-route-lineNo="@l.LineNo"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('هل أنت متأكد من حذف هذا السطر؟');">
                                    <button type="submit"
                                            class="btn btn-erp btn-erp-danger btn-erp-sm">
                                        حذف
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="table-light">
                <tr class="fw-bold">
                    <td class="text-center no-print" data-col="select"></td>
                    <td data-col="prid" class="text-muted">إجمالي</td>
                    <td data-col="lineno"></td>
                    <td data-col="prodid"></td>
                    <td data-col="prodname"></td>
                    <td data-col="qty"></td>
                    <td data-col="priceBasis"></td>
                    <td data-col="priceRetail"></td>
                    <td data-col="disc"></td>
                    <td data-col="expectedCost"></td>
                    <td data-col="linevalue">@((ViewBag.TotalLineValue != null ? (decimal)ViewBag.TotalLineValue : 0m).ToString("0.00"))</td>
                    <td data-col="batch"></td>
                    <td data-col="expiry"></td>
                    <td data-col="qtyConv"></td>
                    <td class="text-center no-print" data-col="actions"></td>
                </tr>
                </tfoot>
            </table>
        </div>
    </div>

    @* ===== الشريط السفلي ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print" dir="rtl">
        <small class="text-muted text-start">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search"   value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort"     value="@sort" />
            <input type="hidden" name="dir"      value="@dir" />
            <input type="hidden" name="page"     value="1" />
            <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
            <input type="hidden" name="toCode"   value="@(toCode?.ToString() ?? "")" />

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    @* ===== الترقيم ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(page > first ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @pages
                </span>
            </li>
            <li class="page-item @(page < last ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@section Scripts {
    <script>
        (function () {
            var el = document.getElementById("prLinesTableScrollContainer");
            if (el) requestAnimationFrame(function () { el.scrollLeft = el.scrollWidth - el.clientWidth; });
        })();
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // فلتر الكود من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();

        // =========================
        // اختيار الكل + الحذف الجماعي
        // =========================
        (function () {
            const selectAll     = document.getElementById("selectAll");
            const btnBulkDelete = document.getElementById("btnBulkDelete");
            const form          = document.getElementById("bulkDeleteForm");

            function getRowCheckboxes() {
                return Array.from(document.querySelectorAll(".row-select"));
            }

            // تحديد/إلغاء تحديد الكل
            selectAll?.addEventListener("change", function () {
                const checked   = this.checked;
                const checkboxes = getRowCheckboxes();
                checkboxes.forEach(cb => cb.checked = checked);
            });

            // الحذف الجماعي
            btnBulkDelete?.addEventListener("click", function () {
                const checkboxes = getRowCheckboxes().filter(cb => cb.checked);

                if (checkboxes.length === 0) {
                    alert("من فضلك اختر سطرًا واحدًا على الأقل للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف السطور المحددة؟")) {
                    return;
                }

                // مسح أي مفاتيح قديمة
                form.querySelectorAll("input[name='keys']").forEach(i => i.remove());

                // إضافة المفاتيح الجديدة (PRId_LineNo)
                checkboxes.forEach(cb => {
                    const input = document.createElement("input");
                    input.type  = "hidden";
                    input.name  = "keys";
                    input.value = cb.value; // القيمة في شكل "PRId_LineNo"
                    form.appendChild(input);
                });

                form.submit();
            });
        })();
    </script>
}
