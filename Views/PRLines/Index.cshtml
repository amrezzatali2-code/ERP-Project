@* Views/PRLines/Index.cshtml — قائمة سطور طلبات الشراء بنفس نظام القوائم الموحد *@
@using Microsoft.AspNetCore.Html          @* لاستخدام HtmlString *@
@using ERP.Infrastructure                 @* لاستخدام PagedResult *@
@using ERP.Models                         @* لاستخدام الموديل PRLine *@
@model PagedResult<PRLine>

@{
    ViewData["Title"] = "سطور طلبات الشراء";

    // أسماء الأكشن/الكنترولر الحالية
    var action     = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "PRLines";

    // قيم البحث/الترتيب الحالية
    var search   = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var searchMode = ((string?)ViewBag.SearchMode ?? "contains").Trim().ToLowerInvariant();
    if (searchMode == "startswith") searchMode = "starts";
    else if (searchMode == "endswith") searchMode = "ends";
    else if (searchMode != "starts" && searchMode != "ends") searchMode = "contains";
    var sort     = Model.SortColumn ?? (string?)ViewBag.Sort ?? "PRId";
    var dir      = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps    = Model.PageSize;
    int total = Model.TotalCount;
    int page  = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
    int end   = (ps == 0 || total == 0) ? total : Math.Min(total, page * ps);

    int first = 1;
    int last  = Math.Max(1, pages);
    int prev  = Math.Max(first, page - 1);
    int next  = Math.Min(last, page + 1);

    // فلتر كود من/إلى على كود الصنف ProdId
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode   = ViewBag.ToCode as int?;

    // فلترة بالتاريخ (تاريخ طلب الشراء)
    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;
    string dateField = (string?)ViewBag.DateField ?? "PRDate";

    // فلاتر الأعمدة (بنمط Excel)
    string? filterCol_prid = ViewBag.FilterCol_prid as string;
    string? filterCol_lineno = ViewBag.FilterCol_lineno as string;
    string? filterCol_prodid = ViewBag.FilterCol_prodid as string;
    string? filterCol_prodname = ViewBag.FilterCol_prodname as string;
    string? filterCol_qty = ViewBag.FilterCol_qty as string;
    string? filterCol_priceBasis = ViewBag.FilterCol_priceBasis as string;
    string? filterCol_priceRetail = ViewBag.FilterCol_priceRetail as string;
    string? filterCol_disc = ViewBag.FilterCol_disc as string;
    string? filterCol_expectedCost = ViewBag.FilterCol_expectedCost as string;
    string? filterCol_linevalue = ViewBag.FilterCol_linevalue as string;
    string? filterCol_batch = ViewBag.FilterCol_batch as string;
    string? filterCol_expiry = ViewBag.FilterCol_expiry as string;
    string? filterCol_qtyConv = ViewBag.FilterCol_qtyConv as string;
    string? filterCol_pridExpr = ViewBag.FilterCol_pridExpr as string;
    string? filterCol_linenoExpr = ViewBag.FilterCol_linenoExpr as string;
    string? filterCol_prodidExpr = ViewBag.FilterCol_prodidExpr as string;
    string? filterCol_qtyExpr = ViewBag.FilterCol_qtyExpr as string;
    string? filterCol_priceRetailExpr = ViewBag.FilterCol_priceRetailExpr as string;
    string? filterCol_discExpr = ViewBag.FilterCol_discExpr as string;
    string? filterCol_expectedCostExpr = ViewBag.FilterCol_expectedCostExpr as string;
    string? filterCol_linevalueExpr = ViewBag.FilterCol_linevalueExpr as string;
    string? filterCol_qtyConvExpr = ViewBag.FilterCol_qtyConvExpr as string;

    string? FilterForCol(string colKey) =>
        colKey == "prid" ? (!string.IsNullOrWhiteSpace(filterCol_pridExpr) ? filterCol_pridExpr : filterCol_prid)
        : colKey == "lineno" ? (!string.IsNullOrWhiteSpace(filterCol_linenoExpr) ? filterCol_linenoExpr : filterCol_lineno)
        : colKey == "prodid" ? (!string.IsNullOrWhiteSpace(filterCol_prodidExpr) ? filterCol_prodidExpr : filterCol_prodid)
        : colKey == "qty" ? (!string.IsNullOrWhiteSpace(filterCol_qtyExpr) ? filterCol_qtyExpr : filterCol_qty)
        : colKey == "priceRetail" ? (!string.IsNullOrWhiteSpace(filterCol_priceRetailExpr) ? filterCol_priceRetailExpr : filterCol_priceRetail)
        : colKey == "disc" ? (!string.IsNullOrWhiteSpace(filterCol_discExpr) ? filterCol_discExpr : filterCol_disc)
        : colKey == "expectedCost" ? (!string.IsNullOrWhiteSpace(filterCol_expectedCostExpr) ? filterCol_expectedCostExpr : filterCol_expectedCost)
        : colKey == "linevalue" ? (!string.IsNullOrWhiteSpace(filterCol_linevalueExpr) ? filterCol_linevalueExpr : filterCol_linevalue)
        : colKey == "qtyConv" ? (!string.IsNullOrWhiteSpace(filterCol_qtyConvExpr) ? filterCol_qtyConvExpr : filterCol_qtyConv)
        : colKey == "prodname" ? filterCol_prodname
        : colKey == "priceBasis" ? filterCol_priceBasis
        : colKey == "batch" ? filterCol_batch
        : colKey == "expiry" ? filterCol_expiry
        : null;

    var n2 = System.Globalization.CultureInfo.InvariantCulture;
    decimal totalLineValCards = ViewBag.TotalLineValue != null ? (decimal)ViewBag.TotalLineValue : 0m;
    int totalQtyCards = ViewBag.TotalQtyFiltered != null ? (int)ViewBag.TotalQtyFiltered : 0;

    object PrLinesRouteValues(int? pageNum = null, string? sortCol = null, string? sortDir = null) => new
    {
        search,
        searchBy,
        searchMode,
        sort = sortCol ?? sort,
        dir = sortDir ?? dir,
        useDateRange,
        fromDate,
        toDate,
        dateField,
        page = pageNum ?? page,
        pageSize = ps,
        fromCode,
        toCode,
        filterCol_prid,
        filterCol_pridExpr,
        filterCol_lineno,
        filterCol_linenoExpr,
        filterCol_prodid,
        filterCol_prodidExpr,
        filterCol_prodname,
        filterCol_qty,
        filterCol_qtyExpr,
        filterCol_priceBasis,
        filterCol_priceRetail,
        filterCol_priceRetailExpr,
        filterCol_disc,
        filterCol_discExpr,
        filterCol_expectedCost,
        filterCol_expectedCostExpr,
        filterCol_linevalue,
        filterCol_linevalueExpr,
        filterCol_batch,
        filterCol_expiry,
        filterCol_qtyConv,
        filterCol_qtyConvExpr
    };

    // دالة توليد لينكات الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, PrLinesRouteValues(pageNum: p))!;

    // دالة إنشاء لينك الترتيب في رأس الجدول + أيقونة السهم (نفس فكرة SalesInvoiceLines)
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir    = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, PrLinesRouteValues(pageNum: 1, sortCol: col, sortDir: newDir)) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    // عمود قابل للفلترة والترتيب (بنمط Excel — أيقونة فلتر + لوحة)
    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    @* العنوان + إجمالي السطور (نفس تنسيق قائمة أصناف فواتير المشتريات) *@
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0 fs-6 text-secondary">@ViewData["Title"]</h5>
        <small class="text-muted d-none d-md-inline">إجمالي السطور: @total</small>
    </div>

    @* ===== شريط الفلاتر الموحد (نمط القوائم — جداول السطور بدون حذف، نفس PILines) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في أصناف طلبات الشراء</label>
                    <div class="d-flex flex-wrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" style="min-width:120px" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:160px;min-width:100px">
                            <option value="all"@Html.Raw(searchBy == "" || searchBy == "all" ? " selected" : "")>الكل</option>
                            <option value="pr"@Html.Raw(searchBy == "pr" ? " selected" : "")>رقم طلب الشراء</option>
                            <option value="line"@Html.Raw(searchBy == "line" ? " selected" : "")>رقم السطر</option>
                            <option value="prod"@Html.Raw(searchBy == "prod" ? " selected" : "")>كود الصنف</option>
                            <option value="qty"@Html.Raw(searchBy == "qty" ? " selected" : "")>الكمية المطلوبة</option>
                        </select>
                        <select name="searchMode" class="form-select form-select-arrow erp-filter-input order-first flex-shrink-0" style="max-width:130px;min-width:100px" title="طريقة المطابقة">
                            <option value="starts"@Html.Raw(searchMode == "starts" ? " selected" : "")>يبدأ بـ</option>
                            <option value="contains"@Html.Raw(searchMode == "contains" ? " selected" : "")>يحتوي</option>
                            <option value="ends"@Html.Raw(searchMode == "ends" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-2 justify-content-center w-100 mt-2">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prid)) { <input type="hidden" name="filterCol_prid" value="@filterCol_prid" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_lineno)) { <input type="hidden" name="filterCol_lineno" value="@filterCol_lineno" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prodid)) { <input type="hidden" name="filterCol_prodid" value="@filterCol_prodid" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prodname)) { <input type="hidden" name="filterCol_prodname" value="@filterCol_prodname" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qty)) { <input type="hidden" name="filterCol_qty" value="@filterCol_qty" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_priceBasis)) { <input type="hidden" name="filterCol_priceBasis" value="@filterCol_priceBasis" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_priceRetail)) { <input type="hidden" name="filterCol_priceRetail" value="@filterCol_priceRetail" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_disc)) { <input type="hidden" name="filterCol_disc" value="@filterCol_disc" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_expectedCost)) { <input type="hidden" name="filterCol_expectedCost" value="@filterCol_expectedCost" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_linevalue)) { <input type="hidden" name="filterCol_linevalue" value="@filterCol_linevalue" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_batch)) { <input type="hidden" name="filterCol_batch" value="@filterCol_batch" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_expiry)) { <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyConv)) { <input type="hidden" name="filterCol_qtyConv" value="@filterCol_qtyConv" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_pridExpr)) { <input type="hidden" name="filterCol_pridExpr" value="@filterCol_pridExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_linenoExpr)) { <input type="hidden" name="filterCol_linenoExpr" value="@filterCol_linenoExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prodidExpr)) { <input type="hidden" name="filterCol_prodidExpr" value="@filterCol_prodidExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyExpr)) { <input type="hidden" name="filterCol_qtyExpr" value="@filterCol_qtyExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_priceRetailExpr)) { <input type="hidden" name="filterCol_priceRetailExpr" value="@filterCol_priceRetailExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_discExpr)) { <input type="hidden" name="filterCol_discExpr" value="@filterCol_discExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_expectedCostExpr)) { <input type="hidden" name="filterCol_expectedCostExpr" value="@filterCol_expectedCostExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_linevalueExpr)) { <input type="hidden" name="filterCol_linevalueExpr" value="@filterCol_linevalueExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyConvExpr)) { <input type="hidden" name="filterCol_qtyConvExpr" value="@filterCol_qtyConvExpr" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر كود صنف (من – إلى) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">من كود صنف – إلى كود صنف</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم (صفان مثل PILines — بدون حذف) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModalPR">فلترة بالتاريخ والوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalPR">اختيار الأعمدة</button>
                        <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <span class="erp-list-toolbar-selected-actions d-inline-flex flex-wrap gap-2 align-items-center" role="group" aria-label="إجراءات السطر المحدد">
                            <button type="button" id="btnShowPRLine" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="عرض طلب الشراء">عرض</button>
                        </span>
                    </div>
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center" dir="rtl">
                        <button type="button" id="btnMovementPRLine" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="حركة الصنف">حركة الصنف</button>
                        <form method="get" asp-action="Export" asp-controller="PRLines" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="visibleCols" value="" />
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="searchMode" value="@searchMode" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_prid)) { <input type="hidden" name="filterCol_prid" value="@filterCol_prid" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_lineno)) { <input type="hidden" name="filterCol_lineno" value="@filterCol_lineno" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_prodid)) { <input type="hidden" name="filterCol_prodid" value="@filterCol_prodid" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_prodname)) { <input type="hidden" name="filterCol_prodname" value="@filterCol_prodname" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_qty)) { <input type="hidden" name="filterCol_qty" value="@filterCol_qty" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_priceBasis)) { <input type="hidden" name="filterCol_priceBasis" value="@filterCol_priceBasis" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_priceRetail)) { <input type="hidden" name="filterCol_priceRetail" value="@filterCol_priceRetail" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_disc)) { <input type="hidden" name="filterCol_disc" value="@filterCol_disc" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_expectedCost)) { <input type="hidden" name="filterCol_expectedCost" value="@filterCol_expectedCost" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_linevalue)) { <input type="hidden" name="filterCol_linevalue" value="@filterCol_linevalue" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_batch)) { <input type="hidden" name="filterCol_batch" value="@filterCol_batch" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_expiry)) { <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_qtyConv)) { <input type="hidden" name="filterCol_qtyConv" value="@filterCol_qtyConv" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_pridExpr)) { <input type="hidden" name="filterCol_pridExpr" value="@filterCol_pridExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_linenoExpr)) { <input type="hidden" name="filterCol_linenoExpr" value="@filterCol_linenoExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_prodidExpr)) { <input type="hidden" name="filterCol_prodidExpr" value="@filterCol_prodidExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_qtyExpr)) { <input type="hidden" name="filterCol_qtyExpr" value="@filterCol_qtyExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_priceRetailExpr)) { <input type="hidden" name="filterCol_priceRetailExpr" value="@filterCol_priceRetailExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_discExpr)) { <input type="hidden" name="filterCol_discExpr" value="@filterCol_discExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_expectedCostExpr)) { <input type="hidden" name="filterCol_expectedCostExpr" value="@filterCol_expectedCostExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_linevalueExpr)) { <input type="hidden" name="filterCol_linevalueExpr" value="@filterCol_linevalueExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_qtyConvExpr)) { <input type="hidden" name="filterCol_qtyConvExpr" value="@filterCol_qtyConvExpr" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;padding:0.3rem 0.5rem;" title="اختر صيغة التصدير">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row mt-2" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي العدد (بعد الفلترة)</div>
                    <div class="h4 mb-0 text-primary fw-bold">@total.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #0369a1 !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي الكمية</div>
                    <div class="h4 mb-0 fw-bold" style="color:#0369a1;">@totalQtyCards.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
