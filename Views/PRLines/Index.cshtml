<div class="modal fade no-print" id="dateFilterModalPR" tabindex="-1" aria-labelledby="dateFilterModalPRLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalPRLabel">فلترة بالتاريخ والوقت (تاريخ طلب الشراء)</h5>
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="searchMode" value="@searchMode" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_pridExpr)) { <input type="hidden" name="filterCol_pridExpr" value="@filterCol_pridExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_linenoExpr)) { <input type="hidden" name="filterCol_linenoExpr" value="@filterCol_linenoExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prodidExpr)) { <input type="hidden" name="filterCol_prodidExpr" value="@filterCol_prodidExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyExpr)) { <input type="hidden" name="filterCol_qtyExpr" value="@filterCol_qtyExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_priceRetailExpr)) { <input type="hidden" name="filterCol_priceRetailExpr" value="@filterCol_priceRetailExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_discExpr)) { <input type="hidden" name="filterCol_discExpr" value="@filterCol_discExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_expectedCostExpr)) { <input type="hidden" name="filterCol_expectedCostExpr" value="@filterCol_expectedCostExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_linevalueExpr)) { <input type="hidden" name="filterCol_linevalueExpr" value="@filterCol_linevalueExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyConvExpr)) { <input type="hidden" name="filterCol_qtyConvExpr" value="@filterCol_qtyConvExpr" /> }
                    @foreach (var kv in new[] { "prid", "lineno", "prodid", "prodname", "qty", "priceBasis", "priceRetail", "disc", "expectedCost", "linevalue", "batch", "expiry", "qtyConv" })
                    {
                        var fv = kv switch { "prid" => filterCol_prid, "lineno" => filterCol_lineno, "prodid" => filterCol_prodid, "prodname" => filterCol_prodname, "qty" => filterCol_qty, "priceBasis" => filterCol_priceBasis, "priceRetail" => filterCol_priceRetail, "disc" => filterCol_disc, "expectedCost" => filterCol_expectedCost, "linevalue" => filterCol_linevalue, "batch" => filterCol_batch, "expiry" => filterCol_expiry, "qtyConv" => filterCol_qtyConv, _ => null };
                        if (!string.IsNullOrWhiteSpace(fv)) { <input type="hidden" name="@("filterCol_" + kv)" value="@fv" /> }
                    }
                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2" type="checkbox" id="useDateRangePR" name="useDateRange" value="true" @(useDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRangePR">تفعيل فلترة التاريخ</label>
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من تاريخ</label>
                            <input type="datetime-local" class="form-control" name="fromDate" value="@(fromDate.HasValue ? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى تاريخ</label>
                            <input type="datetime-local" class="form-control" name="toDate" value="@(toDate.HasValue ? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">تطبيق الفلتر</button>
                    <a class="btn btn-erp btn-erp-secondary" asp-action="@action" asp-controller="@controller">مسح الفلتر</a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print erp-columns-modal" id="columnsModalPR" tabindex="-1" aria-labelledby="columnsModalPRLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalPRLabel">اختيار الأعمدة</h5>
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListPR" class="erp-columns-modal-list"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-erp btn-erp-secondary" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" id="btnApplyColumnsPR" class="btn btn-erp btn-erp-primary">تطبيق</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        if (typeof ERP !== "undefined" && ERP.initListSelection) {
            ERP.initListSelection({
                rowSelector: ".erp-list-selectable-row",
                showButtonId: "btnShowPRLine",
                showUrlAttribute: "data-show-url",
                tabTitleAttribute: "data-tab-title",
                showTabId: "pr-show-tab",
                idAttribute: "data-row-id",
                movementButtonId: "btnMovementPRLine",
                movementUrlAttribute: "data-movement-url",
                movementTabTitle: "حركة الصنف",
                movementTabId: "product-movement-tab"
            });
        }

        // التمرير الأفقي: عند فتح الصفحة يكون الشريط في أقصى اليمين (RTL) — مثل PILines
        (function () {
            var wrapper = document.getElementById("prLinesTableWrapper");
            if (wrapper) {
                function scrollToRtlStart() {
                    var maxScroll = wrapper.scrollWidth - wrapper.clientWidth;
                    wrapper.scrollLeft = maxScroll > 0 ? maxScroll : 0;
                }
                scrollToRtlStart();
                window.addEventListener("load", function () { setTimeout(scrollToRtlStart, 50); });
            }
        })();

        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // فلتر الكود من/إلى
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");
                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");
                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                var cf = fromInp.value.trim();
                var ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();

        // اختيار الأعمدة + حفظ في localStorage (مثل PILines)
        (function () {
            const table = document.getElementById("prLinesTable");
            if (!table) return;

            const storageKey = "prl-columns-visibility";
            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({ key: th.getAttribute("data-col"), title: th.innerText.trim() }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']").forEach(cell => cell.classList.toggle("d-none", isHidden));
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListPR");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";
                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;
                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;
                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsPR")?.addEventListener("click", function () {
                const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                hidden = [];
                checks.forEach(cb => {
                    if (!cb.checked) hidden.push(cb.dataset.colKey);
                });
                try { localStorage.setItem(storageKey, JSON.stringify(hidden)); } catch { }
                applyVisibility();
                const modalEl = document.getElementById("columnsModalPR");
                const modal = bootstrap.Modal.getInstance(modalEl);
                modal?.hide();
            });

            function getVisibleColsInTableOrder() {
                const ordered = Array.from(table.querySelectorAll("thead th[data-col]"))
                    .filter(th => !th.hasAttribute("data-col-fixed"))
                    .map(th => th.getAttribute("data-col"))
                    .filter(Boolean);

                let hiddenCols = [];
                try {
                    const saved = localStorage.getItem(storageKey);
                    if (saved) hiddenCols = JSON.parse(saved) || [];
                } catch { hiddenCols = []; }

                const hiddenSet = new Set(hiddenCols.map(x => String(x)));
                return ordered.filter(k => !hiddenSet.has(String(k)));
            }

            document.querySelectorAll("form.erp-export-form").forEach(function (form) {
                form.addEventListener("submit", function () {
                    const inp = form.querySelector("input[name='visibleCols']");
                    if (!inp) return;
                    inp.value = getVisibleColsInTableOrder().join(",");
                });
            });
        })();

        if (typeof ERP !== "undefined" && ERP.initListColumnFilter) {
            ERP.initListColumnFilter({
                panelId: "erpColumnFilterPanelPrl",
                tableId: "prLinesTable",
                wrapperId: "prLinesTableWrapper",
                getColumnValuesUrl: "@Url.Action("GetColumnValues", "PRLines")",
                defaultSort: "PRId",
                defaultDir: "asc",
                numericColumns: ["prid", "lineno", "prodid", "qty", "priceRetail", "disc", "expectedCost", "linevalue", "qtyConv"]
            });
        }
    </script>
}






