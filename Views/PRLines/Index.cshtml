    @* ===== جدول سطور طلبات الشراء (نفس تنسيق PILines: حاوية تمرير، رأس ثابت) ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0" dir="rtl" id="prLinesTableScrollContainer">
        <div id="prLinesTableWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
            <table id="prLinesTable" class="table table-striped table-hover erp-table erp-table-sortable">
                <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                    <tr>
                        <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                            <input type="checkbox" id="chkAllRowsPR" />
                        </th>
                        <th data-col="prid">@filterableCol("prid", "PRId", "رقم طلب الشراء")</th>
                        <th data-col="lineno">@filterableCol("lineno", "LineNo", "رقم السطر")</th>
                        <th data-col="prodid">@filterableCol("prodid", "ProdId", "كود الصنف")</th>
                        <th data-col="prodname">@filterableCol("prodname", "prodname", "اسم الصنف")</th>
                        <th data-col="qty">@filterableCol("qty", "QtyRequested", "الكمية المطلوبة")</th>
                        <th data-col="priceBasis">@filterableCol("priceBasis", "PRId", "مرجع السعر")</th>
                        <th data-col="priceRetail">@filterableCol("priceRetail", "PRId", "سعر الجمهور المرجعي")</th>
                        <th data-col="disc">@filterableCol("disc", "PRId", "خصم الشراء %")</th>
                        <th data-col="expectedCost">@filterableCol("expectedCost", "PRId", "التكلفة المتوقعة")</th>
                        <th data-col="linevalue">@filterableCol("linevalue", "linevalue", "قيمة السطر")</th>
                        <th data-col="batch">@filterableCol("batch", "PRId", "التشغيلة المفضلة")</th>
                        <th data-col="expiry">@filterableCol("expiry", "PRId", "الصلاحية المفضلة")</th>
                        <th data-col="qtyConv">@filterableCol("qtyConv", "PRId", "الكمية المحوّلة")</th>
                    </tr>
                </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="14" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var l in Model.Items)
                    {
                        var key = $"{l.PRId}_{l.LineNo}";   @* مفتاح مركّب للسطر: رقم الطلب + رقم السطر *@

                        // ✅ اسم الصنف من جدول Products
                        var prodName = l.Product?.ProdName ?? "";

                        // ✅ حساب قيمة السطر = (QtyRequested * PriceRetail) * (1 - PurchaseDiscountPct / 100)
                        decimal lineValue = (l.QtyRequested * l.PriceRetail) * (1m - (l.PurchaseDiscountPct / 100m));
                        var showUrl = Url.Action("Show", "PurchaseRequests", new { id = l.PRId, frame = 1 });
                        var movementUrl = Url.Action("Show", "Products", new { id = l.ProdId }) + "?frame=1";
                        var rowId = $"{l.PRId}_{l.LineNo}";

                        <tr class="erp-list-selectable-row" data-row-id="@rowId" data-pr-id="@l.PRId" data-line-no="@l.LineNo" data-prod-id="@l.ProdId"
                            data-show-url="@showUrl" data-movement-url="@movementUrl" data-tab-title="طلب شراء">
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox" class="row-select" value="@rowId" />
                            </td>
                            <td data-col="prid">@l.PRId</td>
                            <td data-col="lineno">@l.LineNo</td>
                            <td data-col="prodid">@l.ProdId</td>
                            <td data-col="prodname">@prodName</td>
                            <td data-col="qty">@l.QtyRequested</td>

                            <td data-col="priceBasis">@l.PriceBasis</td>
                            <td data-col="priceRetail">@l.PriceRetail.ToString("0.00")</td>
                            <td data-col="disc">@l.PurchaseDiscountPct.ToString("0.00")</td>
                            <td data-col="expectedCost">@l.ExpectedCost.ToString("0.0000")</td>
                            <td data-col="linevalue">@lineValue.ToString("0.00")</td>
                            <td data-col="batch">@l.PreferredBatchNo</td>
                            <td data-col="expiry">
                                @(l.PreferredExpiry.HasValue
                                    ? l.PreferredExpiry.Value.ToString("yyyy-MM-dd")
                                    : "")
                            </td>
                            <td data-col="qtyConv">@l.QtyConverted</td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="table-light">
                <tr class="fw-bold text-start">
                    <td class="text-center no-print" data-col="select"></td>
                    <td data-col="prid" class="text-muted">إجمالي</td>
                    <td data-col="lineno"></td>
                    <td data-col="prodid"></td>
                    <td data-col="prodname"></td>
                    <td data-col="qty"></td>
                    <td data-col="priceBasis"></td>
                    <td data-col="priceRetail"></td>
                    <td data-col="disc"></td>
                    <td data-col="expectedCost"></td>
                    <td data-col="linevalue">@((ViewBag.TotalLineValue != null ? (decimal)ViewBag.TotalLineValue : 0m).ToString("0.00"))</td>
                    <td data-col="batch"></td>
                    <td data-col="expiry"></td>
                    <td data-col="qtyConv"></td>
                </tr>
                </tfoot>
            </table>
        </div>
    </div>

