@model ERP.Models.ProductBonusGroup

@{
    ViewData["Title"] = "تعديل مجموعة حافز";
}

<div class="container" dir="rtl">
    <h2 class="mt-3 mb-3">تعديل مجموعة حافز — @Model.ProductBonusGroupId</h2>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="card mb-3">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="ProductBonusGroupId" />
                <input type="hidden" asp-for="CreatedAt" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">اسم مجموعة الحافز</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="BonusAmount" class="form-label">قيمة الحافز لكل علبة (جنيه)</label>
                    <input asp-for="BonusAmount" class="form-control" />
                    <span asp-validation-for="BonusAmount" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">الوصف (اختياري)</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsActive" class="form-check-input ms-2" />
                    <label asp-for="IsActive" class="form-check-label">مفعّلة؟</label>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">تاريخ الإنشاء</label>
                        <input class="form-control"
                               value="@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")"
                               disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">آخر تعديل</label>
                        <input class="form-control"
                               value="@(Model.UpdatedAt.HasValue? Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")"
                               disabled />
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        حفظ التغييرات
                    </button>
                    <a asp-action="Index" class="btn btn-erp btn-erp-secondary">
                        رجوع للقائمة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
