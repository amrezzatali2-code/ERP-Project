@using ERP.Infrastructure
@using ERP.Models
@using Microsoft.AspNetCore.Mvc.Rendering
@using Microsoft.AspNetCore.Html
@model PagedResult<LedgerEntry>

@functions {
    string SourceTypeAr(LedgerSourceType t)
    {
        switch (t)
        {
            case LedgerSourceType.Opening: return "رصيد افتتاحي";
            case LedgerSourceType.SalesInvoice: return "فاتورة مبيعات";
            case LedgerSourceType.SalesReturn: return "مرتجع بيع";
            case LedgerSourceType.PurchaseInvoice: return "فاتورة مشتريات";
            case LedgerSourceType.PurchaseReturn: return "مرتجع شراء";
            case LedgerSourceType.Receipt: return "إذن استلام";
            case LedgerSourceType.Payment: return "إذن دفع";
            case LedgerSourceType.Journal: return "قيد يومية";
            case LedgerSourceType.Adjustment: return "تسوية";
            case LedgerSourceType.StockTransfer: return "تحويل مخزني";
            case LedgerSourceType.StockAdjustment: return "تسوية جرد";
            case LedgerSourceType.DebitNote: return "إشعار خصم";
            case LedgerSourceType.CreditNote: return "إشعار إضافة";
            default: return t.ToString();
        }
    }
}

@{
    ViewData["Title"] = "كشف حساب عميل";
    var customer = ViewBag.Customer as Customer;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    decimal totalDebit = ViewBag.TotalDebit != null ? (decimal)ViewBag.TotalDebit : 0m;
    decimal totalCredit = ViewBag.TotalCredit != null ? (decimal)ViewBag.TotalCredit : 0m;
    decimal netBalance = ViewBag.NetBalance != null ? (decimal)ViewBag.NetBalance : 0m;
    var customersJson = ViewBag.CustomersJson as string ?? "[]";
    var selectedCustomerDisplay = customer != null ? $"{customer.CustomerId} — {customer.CustomerName}" : "";

    var sort = (string?)ViewBag.Sort ?? "entryDate";
    var dir = (string?)ViewBag.Dir ?? "asc";
    string? filterCol_id = ViewBag.FilterCol_Id as string ?? Context.Request.Query["filterCol_id"].ToString();
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string ?? Context.Request.Query["filterCol_idExpr"].ToString();
    string? filterCol_entryDate = ViewBag.FilterCol_EntryDate as string ?? Context.Request.Query["filterCol_entryDate"].ToString();
    string? filterCol_sourceType = ViewBag.FilterCol_SourceType as string ?? Context.Request.Query["filterCol_sourceType"].ToString();
    string? filterCol_voucherNo = ViewBag.FilterCol_VoucherNo as string ?? Context.Request.Query["filterCol_voucherNo"].ToString();
    string? filterCol_account = ViewBag.FilterCol_Account as string ?? Context.Request.Query["filterCol_account"].ToString();
    string? filterCol_debit = ViewBag.FilterCol_Debit as string ?? Context.Request.Query["filterCol_debit"].ToString();
    string? filterCol_credit = ViewBag.FilterCol_Credit as string ?? Context.Request.Query["filterCol_credit"].ToString();
    string? filterCol_description = ViewBag.FilterCol_Description as string ?? Context.Request.Query["filterCol_description"].ToString();

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;
    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);
    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    string Link(int p) => Url.Action("Index", "CustomerLedger", new
    {
        customerId = customer?.CustomerId,
        fromDate,
        toDate,
        sort,
        dir,
        page = p,
        pageSize = ps,
        filterCol_id, filterCol_idExpr, filterCol_entryDate, filterCol_sourceType, filterCol_voucherNo,
        filterCol_account, filterCol_debit, filterCol_credit, filterCol_description
    })!;

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        var currentFilter = colKey == "id" ? (filterCol_id ?? filterCol_idExpr) : colKey == "entryDate" ? filterCol_entryDate :
            colKey == "sourceType" ? filterCol_sourceType : colKey == "voucherNo" ? filterCol_voucherNo : colKey == "account" ? filterCol_account :
            colKey == "debit" ? filterCol_debit : colKey == "credit" ? filterCol_credit : colKey == "description" ? filterCol_description : null;
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<style>
    /* خانات التجميعات — كشف حساب عميل: أكبر وأوضح */
    .customer-ledger-summary-card {
        min-height: 72px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .customer-ledger-summary-label {
        font-size: 0.95rem;
        font-weight: 600;
        opacity: 0.95;
        margin-bottom: 0.25rem;
    }
    .customer-ledger-summary-value {
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }
    .customer-ledger-summary-debit {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        box-shadow: 0 2px 8px rgba(59, 130, 246, 0.35);
    }
    .customer-ledger-summary-credit {
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        box-shadow: 0 2px 8px rgba(34, 197, 94, 0.35);
    }
    .customer-ledger-summary-net {
        background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
        box-shadow: 0 2px 8px rgba(168, 85, 247, 0.35);
    }
</style>

<div dir="rtl" class="container-fluid">
    <h4 class="mb-3">كشف حساب عميل — @(customer?.CustomerName ?? "اختر عميلاً")</h4>

    @* فلتر: اختيار العميل + التاريخ *@
    <div class="erp-list-filter-bar mb-3">
        <form id="customerLedgerForm" method="get" asp-action="Index" asp-controller="CustomerLedger" class="row g-3 align-items-end">
            <input type="hidden" name="customerId" id="customerIdHidden" value="@(customer?.CustomerId)" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_entryDate)) { <input type="hidden" name="filterCol_entryDate" value="@filterCol_entryDate" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_sourceType)) { <input type="hidden" name="filterCol_sourceType" value="@filterCol_sourceType" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_voucherNo)) { <input type="hidden" name="filterCol_voucherNo" value="@filterCol_voucherNo" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_account)) { <input type="hidden" name="filterCol_account" value="@filterCol_account" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_debit)) { <input type="hidden" name="filterCol_debit" value="@filterCol_debit" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_credit)) { <input type="hidden" name="filterCol_credit" value="@filterCol_credit" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_description)) { <input type="hidden" name="filterCol_description" value="@filterCol_description" /> }
            <div class="col-12 col-md-3 erp-filter-section">
                <label class="form-label">العميل</label>
                <div class="position-relative">
                    <input id="customerNameInput"
                           type="text"
                           class="form-control erp-filter-input"
                           placeholder="اكتب اسم العميل ثم اختره من القائمة"
                           autocomplete="off"
                           value="@selectedCustomerDisplay" />
                    <div id="customerSuggestions"
                         class="list-group position-absolute w-100 shadow-sm"
                         style="z-index: 1050; max-height: 200px; overflow-y: auto; display: none;">
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-2 erp-filter-section">
                <label class="form-label">من تاريخ</label>
                <input type="date" name="fromDate" dir="ltr" class="form-control erp-filter-input"
                       value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
            </div>
            <div class="col-12 col-md-2 erp-filter-section">
                <label class="form-label">إلى تاريخ</label>
                <input type="date" name="toDate" dir="ltr" class="form-control erp-filter-input"
                       value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
            </div>
            <div class="col-12 col-md-2 erp-filter-section">
                <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm w-100">عرض</button>
            </div>
            @if (customer != null)
            {
                <div class="col-12 col-md-2 erp-filter-section">
                    <a asp-action="Show" asp-controller="Customers" asp-route-id="@customer.CustomerId" asp-route-frame="1"
                       class="btn btn-erp btn-erp-secondary btn-erp-sm w-100 text-decoration-none app-menu-link"
                       data-tab-id="customer-engagement"
                       data-tab-title="حجم تعامل عميل">📊 حجم التعامل</a>
                </div>
            }
        </form>
    </div>

    @* خانات التجميعات — أكبر وأوضح *@
    <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
            <div class="customer-ledger-summary-card customer-ledger-summary-debit rounded-3 shadow-sm border-0 p-3 text-white">
                <div class="customer-ledger-summary-label">إجمالي المدين</div>
                <div class="customer-ledger-summary-value">@totalDebit.ToString("N2")</div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="customer-ledger-summary-card customer-ledger-summary-credit rounded-3 shadow-sm border-0 p-3 text-white">
                <div class="customer-ledger-summary-label">إجمالي الدائن</div>
                <div class="customer-ledger-summary-value">@totalCredit.ToString("N2")</div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="customer-ledger-summary-card customer-ledger-summary-net rounded-3 shadow-sm border-0 p-3 text-white">
                <div class="customer-ledger-summary-label">صافي الحركة</div>
                <div class="customer-ledger-summary-value">@netBalance.ToString("N2")</div>
            </div>
        </div>
    </div>

    @* جدول القيود (فلترة بنمط Excel على كل الأعمدة) *@
    <div class="erp-table-wrapper">
        <table id="ledgerTable" class="table table-striped table-hover erp-table">
            <thead class="table-light">
                <tr>
                    <th style="width:100px;" data-col="id">@filterableCol("id", "id", "رقم القيد")</th>
                    <th style="width:140px;" data-col="entryDate">@filterableCol("entryDate", "entryDate", "التاريخ")</th>
                    <th data-col="sourceType">@filterableCol("sourceType", "sourceType", "نوع المستند")</th>
                    <th data-col="voucherNo">@filterableCol("voucherNo", "voucherNo", "رقم المستند")</th>
                    <th data-col="account">@filterableCol("account", "account", "الحساب")</th>
                    <th class="text-end" data-col="debit">@filterableCol("debit", "debit", "مدين")</th>
                    <th class="text-end" data-col="credit">@filterableCol("credit", "credit", "دائن")</th>
                    <th data-col="description">@filterableCol("description", "description", "البيان")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            @(customer != null
                                ? "لا توجد عمليات للعميل في الفترة المحددة. غيّر من تاريخ / إلى تاريخ ثم اضغط عرض."
                                : "اختر عميلاً وحدّد الفترة ثم اضغط عرض.")
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var e in Model.Items)
                    {
                        var desc = e.Description ?? "";
                        var descShort = desc.Length > 60 ? desc.Substring(0, 60) + "…" : desc;
                        <tr>
                            <td data-col="id">@e.Id</td>
                            <td data-col="entryDate">@e.EntryDate.ToString("HH:mm yyyy-MM-dd")</td>
                            <td data-col="sourceType">@SourceTypeAr(e.SourceType)</td>
                            <td data-col="voucherNo">@e.VoucherNo</td>
                            <td data-col="account">@(e.Account != null ? $"{e.Account.AccountCode} - {e.Account.AccountName}" : "")</td>
                            <td class="text-end" data-col="debit">@(e.Debit > 0 ? e.Debit.ToString("N2") : "")</td>
                            <td class="text-end" data-col="credit">@(e.Credit > 0 ? e.Credit.ToString("N2") : "")</td>
                            <td data-col="description" title="@desc">@descShort</td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="table-light">
                <tr class="fw-bold">
                    <td colspan="5" class="text-end">الإجمالي:</td>
                    <td class="text-end">@totalDebit.ToString("N2")</td>
                    <td class="text-end">@totalCredit.ToString("N2")</td>
                    <td>صافي: @netBalance.ToString("N2")</td>
                </tr>
            </tfoot>
        </table>
    </div>

    @* لوحة فلتر العمود (بنمط Excel) *@
    <div id="erpColumnFilterPanel" class="erp-column-filter-panel d-none" dir="rtl">
        <div class="erp-column-filter-header">
            <span id="erpColumnFilterTitle">ترتيب وفلتر</span>
            <button type="button" class="btn-close btn-sm" id="erpColumnFilterClose" aria-label="إغلاق"></button>
        </div>
        <div class="erp-column-filter-body">
            <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                <label class="form-label small mb-1 fw-bold">الترتيب:</label>
                <div class="d-flex flex-column gap-1">
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
                </div>
            </div>
            <div class="erp-filter-section">
                <div id="erpColumnFilterSearchRow">
                    <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                    <input type="text" id="erpColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                </div>
                <div id="erpColumnFilterList" class="erp-column-filter-list">
                    <div class="text-muted text-center py-3">جاري التحميل...</div>
                </div>
            </div>
            <div class="erp-column-filter-actions">
                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOk">تطبيق</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClear">مسح الفلتر</button>
            </div>
        </div>
    </div>

    @* الترقيم *@
    @if (pages > 1)
    {
        <nav class="mt-3" aria-label="ترقيم الصفحات">
            <ul class="pagination justify-content-center">
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@(page > 1 ? Link(1) : "#")">الأولى</a>
                </li>
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@(page > 1 ? Link(prev) : "#")">السابق</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">@start - @end من @total</span>
                </li>
                <li class="page-item @(page >= pages ? "disabled" : "")">
                    <a class="page-link" href="@(page < pages ? Link(next) : "#")">التالي</a>
                </li>
                <li class="page-item @(page >= pages ? "disabled" : "")">
                    <a class="page-link" href="@(page < pages ? Link(last) : "#")">الأخيرة</a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        // جعل الشريط الأفقي يفتح من جهة اليمين
        (function () {
            var table = document.getElementById("ledgerTable");
            if (table) {
                var wrapper = table.closest(".erp-table-wrapper");
                if (wrapper) wrapper.scrollLeft = wrapper.scrollWidth - wrapper.clientWidth;
            }
        })();

        // فلتر الأعمدة بنمط Excel (كشف حساب عميل)
        (function () {
            var panel = document.getElementById("erpColumnFilterPanel");
            var titleEl = document.getElementById("erpColumnFilterTitle");
            var searchInp = document.getElementById("erpColumnFilterSearch");
            var searchRowEl = document.getElementById("erpColumnFilterSearchRow");
            var listEl = document.getElementById("erpColumnFilterList");
            var btnOk = document.getElementById("erpColumnFilterOk");
            var btnClear = document.getElementById("erpColumnFilterClear");
            var btnClose = document.getElementById("erpColumnFilterClose");
            var customerIdHidden = document.getElementById("customerIdHidden");

            var currentCol = null, currentSortKey = null, allItems = [], currentSelected = new Set(), anchorRect = null;
            var numericColumns = ["id"];
            var columnToSearchBy = { entryDate: "all", sourceType: "all", voucherNo: "all", account: "all", debit: "all", credit: "all", description: "all" };

            function getCustomerId() { return (customerIdHidden && customerIdHidden.value) ? parseInt(customerIdHidden.value, 10) : 0; }
            function getCurrentFilterValue(col) {
                if (numericColumns.indexOf(col) >= 0) {
                    var url = new URL(window.location.href);
                    return url.searchParams.get("filterCol_" + col + "Expr") || url.searchParams.get("filterCol_" + col) || "";
                }
                return new URL(window.location.href).searchParams.get("filterCol_" + col) || "";
            }
            function getCurrentSort() {
                var url = new URL(window.location.href);
                return { sort: url.searchParams.get("sort") || "entryDate", dir: url.searchParams.get("dir") || "asc" };
            }
            function adjustPanelPosition() {
                if (!panel || !anchorRect) return;
                setTimeout(function () {
                    var r = panel.getBoundingClientRect();
                    var top = anchorRect.bottom + 4, left = anchorRect.left;
                    if (top + r.height > window.innerHeight - 8) top = Math.max(8, window.innerHeight - 8 - r.height);
                    if (left + r.width > window.innerWidth - 8) left = Math.max(8, window.innerWidth - 8 - r.width);
                    panel.style.top = top + "px";
                    panel.style.left = left + "px";
                }, 50);
            }

            function showPanel(btn) {
                var cid = getCustomerId();
                if (!cid) {
                    alert("من فضلك اختر عميلاً أولاً ثم اضغط عرض.");
                    return;
                }
                currentCol = btn.dataset.col;
                currentSortKey = btn.dataset.sortKey || currentCol;
                titleEl.textContent = "ترتيب وفلتر: " + (btn.dataset.colTitle || currentCol);
                searchInp.value = "";
                currentSelected = new Set();
                anchorRect = btn.getBoundingClientRect();
                panel.style.minWidth = Math.max(250, anchorRect.width) + "px";
                panel.classList.remove("d-none");

                var currentSort = getCurrentSort();
                var isCurrent = currentSort.sort.toLowerCase() === currentSortKey.toLowerCase();
                var currentDir = isCurrent ? currentSort.dir : "asc";
                panel.querySelectorAll(".erp-sort-btn").forEach(function (b) {
                    if (isCurrent && b.dataset.sortDir === currentDir) {
                        b.classList.add("active", "btn-primary");
                        b.classList.remove("btn-outline-secondary");
                    } else {
                        b.classList.remove("active", "btn-primary");
                        b.classList.add("btn-outline-secondary");
                    }
                });
                adjustPanelPosition();

                if (numericColumns.indexOf(currentCol) >= 0) {
                    if (searchRowEl) searchRowEl.style.display = "none";
                    var currentExpr = getCurrentFilterValue(currentCol);
                    listEl.innerHTML = '<div class="mb-2"><label class="form-label small mb-1">بحث رقمي:</label><input type="text" id="erpNumericExpr" class="form-control form-control-sm" placeholder="مثال: 10 أو &lt;100 أو 10:200" value="' + (currentExpr || "").replace(/</g, "&lt;").replace(/>/g, "&gt;") + '"></div>';
                    adjustPanelPosition();
                    setTimeout(function () {
                        var exprInput = document.getElementById("erpNumericExpr");
                        if (exprInput) {
                            exprInput.onkeydown = function (e) { if (e.key === "Enter") { e.preventDefault(); applyFilter(); } };
                            exprInput.focus();
                        }
                    }, 100);
                    return;
                }
                if (searchRowEl) searchRowEl.style.display = "";
                listEl.innerHTML = '<div class="text-muted text-center py-3">جاري التحميل...</div>';
                currentSelected = new Set((getCurrentFilterValue(currentCol) || "").split("|").filter(Boolean));
                var url = "/CustomerLedger/GetColumnValues?customerId=" + cid + "&column=" + encodeURIComponent(currentCol);
                var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                if (searchVal) url += "&search=" + encodeURIComponent(searchVal);
                fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                    allItems = items;
                    renderList(searchInp ? searchInp.value : "");
                }).catch(function () { listEl.innerHTML = '<div class="text-danger text-center py-2">فشل التحميل</div>'; });
            }

            function renderList(search) {
                var term = (search || "").toLowerCase();
                var filtered = term ? allItems.filter(function (x) { return (x.display || x.value || "").toLowerCase().indexOf(term) >= 0; }) : allItems;
                var allChecked = filtered.length > 0 && filtered.every(function (x) { return currentSelected.has(String(x.value)); });
                listEl.innerHTML = '<div class="form-check mb-1"><input type="checkbox" class="form-check-input" id="erpFilterSelectAll" ' + (allChecked ? "checked" : "") + '><label class="form-check-label small" for="erpFilterSelectAll">(تحديد الكل)</label></div><div class="erp-filter-items" style="max-height:200px;overflow-y:auto;">' + filtered.map(function (x) {
                    var v = String(x.value);
                    var checked = currentSelected.has(v);
                    return '<div class="form-check"><input type="checkbox" class="form-check-input erp-filter-item" value="' + v.replace(/"/g, "&quot;") + '" ' + (checked ? "checked" : "") + '><label class="form-check-label small">' + (x.display || v).replace(/</g, "&lt;") + '</label></div>';
                }).join("") + "</div>";
                var selectAllCb = listEl.querySelector("#erpFilterSelectAll");
                if (selectAllCb) {
                    selectAllCb.indeterminate = filtered.some(function (x) { return currentSelected.has(String(x.value)); }) && !allChecked;
                    selectAllCb.onchange = function () {
                        filtered.forEach(function (x) {
                            if (this.checked) currentSelected.add(String(x.value)); else currentSelected.delete(String(x.value));
                        }.bind(this));
                        renderList(searchInp.value);
                    };
                }
                listEl.querySelectorAll(".erp-filter-item").forEach(function (cb) {
                    cb.onchange = function () {
                        if (this.checked) currentSelected.add(this.value); else currentSelected.delete(this.value);
                        renderList(searchInp.value);
                    };
                });
                adjustPanelPosition();
            }

            function applyFilter(applySort, sortDir) {
                if (!currentCol) return;
                var url = new URL(window.location.href);
                url.searchParams.forEach(function (_, key) { if (key.indexOf("filterCol_") === 0) url.searchParams.delete(key); });
                if (applySort !== undefined && applySort !== null && sortDir !== undefined && sortDir !== null) {
                    url.searchParams.set("sort", applySort);
                    url.searchParams.set("dir", sortDir);
                } else if (currentSortKey) {
                    var cur = getCurrentSort();
                    url.searchParams.set("sort", cur.sort);
                    url.searchParams.set("dir", cur.dir);
                }
                url.searchParams.set("customerId", getCustomerId());
                if (numericColumns.indexOf(currentCol) >= 0) {
                    var exprInput = document.getElementById("erpNumericExpr");
                    var expr = exprInput ? String(exprInput.value || "").trim() : "";
                    if (expr) url.searchParams.set("filterCol_" + currentCol + "Expr", expr);
                } else {
                    var val = Array.from(currentSelected).filter(Boolean).join("|");
                    if (val) url.searchParams.set("filterCol_" + currentCol, val);
                }
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }
            function clearFilter() {
                if (!currentCol) return;
                var url = new URL(window.location.href);
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.delete("filterCol_" + currentCol + "Expr");
                url.searchParams.set("customerId", getCustomerId());
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }

            document.querySelectorAll(".erp-col-filter-btn").forEach(function (btn) {
                btn.addEventListener("click", function (e) { e.stopPropagation(); showPanel(this); });
            });
            document.addEventListener("click", function (e) {
                if (e.target.closest(".erp-sort-btn")) {
                    var sortBtn = e.target.closest(".erp-sort-btn");
                    if (currentSortKey) applyFilter(currentSortKey, sortBtn.dataset.sortDir);
                }
            });
            var fetchDebounce = null;
            searchInp && searchInp.addEventListener("input", function () {
                if (numericColumns.indexOf(currentCol) >= 0) return;
                renderList(this.value);
                if (fetchDebounce) clearTimeout(fetchDebounce);
                fetchDebounce = setTimeout(function () {
                    fetchDebounce = null;
                    if (!currentCol || !getCustomerId()) return;
                    var url = "/CustomerLedger/GetColumnValues?customerId=" + getCustomerId() + "&column=" + encodeURIComponent(currentCol);
                    var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                    if (searchVal) url += "&search=" + encodeURIComponent(searchVal);
                    fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                        allItems = items;
                        renderList(searchInp ? searchInp.value : "");
                    });
                }, 400);
            });
            searchInp && searchInp.addEventListener("keydown", function (e) { if (e.key === "Enter") { e.preventDefault(); applyFilter(); } });
            btnOk && btnOk.addEventListener("click", function (e) { e.preventDefault(); e.stopPropagation(); applyFilter(); });
            btnClear && btnClear.addEventListener("click", clearFilter);
            btnClose && btnClose.addEventListener("click", function () { panel.classList.add("d-none"); });
            document.addEventListener("click", function (e) {
                if (panel && !panel.classList.contains("d-none") && !panel.contains(e.target) && !e.target.closest(".erp-col-filter-btn"))
                    panel.classList.add("d-none");
            });
        })();

        (function () {
            var customersData = @Html.Raw(customersJson);
            var input = document.getElementById('customerNameInput');
            var hiddenId = document.getElementById('customerIdHidden');
            var list = document.getElementById('customerSuggestions');
            var form = document.getElementById('customerLedgerForm');
            var activeIndex = -1;

            if (input) setTimeout(function () { input.focus(); }, 150);

            if (input && hiddenId && list && form) {
                input.addEventListener('input', function () {
                    var term = input.value.trim();
                    hiddenId.value = "";
                    activeIndex = -1;

                    if (term.length < 1) {
                        list.style.display = 'none';
                        list.innerHTML = '';
                        return;
                    }

                    var termLower = term.toLowerCase();
                    var results = customersData.filter(function (item) {
                        var codeMatch = item.code && String(item.code).indexOf(term) !== -1;
                        var nameMatch = item.name && item.name.toLowerCase().indexOf(termLower) !== -1;
                        return codeMatch || nameMatch;
                    });

                    list.innerHTML = '';

                    if (!results || results.length === 0) {
                        list.style.display = 'none';
                        return;
                    }

                    results.slice(0, 30).forEach(function (item) {
                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'list-group-item list-group-item-action';
                        btn.dataset.id = item.id;
                        btn.textContent = item.code + ' — ' + item.name;

                        btn.addEventListener('click', function () {
                            hiddenId.value = item.id;
                            input.value = item.code + ' — ' + item.name;
                            list.style.display = 'none';
                        });

                        list.appendChild(btn);
                    });

                    list.style.display = 'block';
                });

                input.addEventListener('keydown', function (e) {
                    var items = list.querySelectorAll('button');
                    if (list.style.display !== 'block' || items.length === 0) return;

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        activeIndex = (activeIndex + 1) % items.length;
                        items.forEach(function (el) { el.classList.remove('active'); });
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            items[activeIndex].classList.add('active');
                            items[activeIndex].scrollIntoView({ block: 'nearest' });
                        }
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        activeIndex = (activeIndex - 1 + items.length) % items.length;
                        items.forEach(function (el) { el.classList.remove('active'); });
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            items[activeIndex].classList.add('active');
                            items[activeIndex].scrollIntoView({ block: 'nearest' });
                        }
                    } else if (e.key === 'Enter') {
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            e.preventDefault();
                            items[activeIndex].click();
                        }
                    } else if (e.key === 'Escape') {
                        list.style.display = 'none';
                    }
                });

                document.addEventListener('click', function (e) {
                    if (!list.contains(e.target) && e.target !== input) {
                        list.style.display = 'none';
                    }
                });

                form.addEventListener('submit', function (e) {
                    if (!hiddenId.value) {
                        var txt = input.value.trim();
                        if (/^\d+$/.test(txt)) {
                            hiddenId.value = txt;
                        } else if (txt.length > 0) {
                            var exactMatch = customersData.find(function(item) {
                                return item.name.toLowerCase() === txt.toLowerCase() ||
                                       item.code === txt ||
                                       (item.code + ' — ' + item.name) === txt;
                            });
                            if (exactMatch) {
                                hiddenId.value = exactMatch.id.toString();
                                input.value = exactMatch.code + ' — ' + exactMatch.name;
                            } else {
                                var termLower = txt.toLowerCase();
                                var matches = customersData.filter(function (item) {
                                    var codeMatch = item.code && String(item.code).indexOf(txt) !== -1;
                                    var nameMatch = item.name && item.name.toLowerCase().indexOf(termLower) !== -1;
                                    return codeMatch || nameMatch;
                                });
                                if (matches.length === 1) {
                                    hiddenId.value = matches[0].id.toString();
                                    input.value = matches[0].code + ' — ' + matches[0].name;
                                }
                            }
                        }
                    }

                    if (!hiddenId.value) {
                        e.preventDefault();
                        alert('من فضلك اختر عميلاً من القائمة أو أدخل كوده الرقمي ثم اضغط عرض.');
                    }
                });
            }
        })();
    </script>
}
