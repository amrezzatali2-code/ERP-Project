@using ERP.Infrastructure
@using ERP.Models
@using Microsoft.AspNetCore.Mvc.Rendering
@model PagedResult<LedgerEntry>

@{
    ViewData["Title"] = "كشف حساب عميل";
    var customer = ViewBag.Customer as Customer;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    decimal totalDebit = ViewBag.TotalDebit != null ? (decimal)ViewBag.TotalDebit : 0m;
    decimal totalCredit = ViewBag.TotalCredit != null ? (decimal)ViewBag.TotalCredit : 0m;
    decimal netBalance = ViewBag.NetBalance != null ? (decimal)ViewBag.NetBalance : 0m;
    var customersJson = ViewBag.CustomersJson as string ?? "[]";
    var selectedCustomerDisplay = customer != null ? $"{customer.CustomerId} — {customer.CustomerName}" : "";

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;
    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);
    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    string Link(int p) => Url.Action("Index", "CustomerLedger", new
    {
        customerId = customer?.CustomerId,
        fromDate,
        toDate,
        page = p,
        pageSize = ps
    })!;
}

<div dir="rtl" class="container-fluid">
    <h4 class="mb-3">كشف حساب عميل — @(customer?.CustomerName ?? "اختر عميلاً")</h4>

    @* فلتر: اختيار العميل + التاريخ (نفس أسلوب فاتورة البيع / حجم التعامل) *@
    <div class="erp-list-filter-bar mb-3">
        <form id="customerLedgerForm" method="get" asp-action="Index" asp-controller="CustomerLedger" class="row g-3 align-items-end">
            <input type="hidden" name="customerId" id="customerIdHidden" value="@(customer?.CustomerId)" />
            <div class="col-12 col-md-3 erp-filter-section">
                <label class="form-label">العميل</label>
                <div class="position-relative">
                    <input id="customerNameInput"
                           type="text"
                           class="form-control erp-filter-input"
                           placeholder="اكتب اسم العميل ثم اختره من القائمة"
                           autocomplete="off"
                           value="@selectedCustomerDisplay" />
                    <div id="customerSuggestions"
                         class="list-group position-absolute w-100 shadow-sm"
                         style="z-index: 1050; max-height: 200px; overflow-y: auto; display: none;">
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-2 erp-filter-section">
                <label class="form-label">من تاريخ</label>
                <input type="date" name="fromDate" dir="ltr" class="form-control erp-filter-input"
                       value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
            </div>
            <div class="col-12 col-md-2 erp-filter-section">
                <label class="form-label">إلى تاريخ</label>
                <input type="date" name="toDate" dir="ltr" class="form-control erp-filter-input"
                       value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
            </div>
            <div class="col-12 col-md-2 erp-filter-section">
                <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm w-100">عرض</button>
            </div>
            @if (customer != null)
            {
                <div class="col-12 col-md-2 erp-filter-section">
                    <a asp-action="Show" asp-controller="Customers" asp-route-id="@customer.CustomerId"
                       class="btn btn-erp btn-erp-secondary btn-erp-sm w-100 text-decoration-none">← حجم التعامل</a>
                </div>
            }
        </form>
    </div>

    @* ملخص الإجماليات *@
    <div class="row g-2 mb-3">
        <div class="col-auto">
            <span class="badge bg-primary">إجمالي المدين: @totalDebit.ToString("N2")</span>
        </div>
        <div class="col-auto">
            <span class="badge bg-success">إجمالي الدائن: @totalCredit.ToString("N2")</span>
        </div>
        <div class="col-auto">
            <span class="badge @(netBalance >= 0 ? "bg-warning text-dark" : "bg-info")">صافي الحركة: @netBalance.ToString("N2")</span>
        </div>
    </div>

    @* جدول القيود *@
    <div class="erp-table-wrapper">
        <table class="table table-striped table-hover erp-table">
            <thead class="table-light">
                <tr>
                    <th>رقم القيد</th>
                    <th>التاريخ</th>
                    <th>نوع المستند</th>
                    <th>رقم المستند</th>
                    <th>الحساب</th>
                    <th class="text-end">مدين</th>
                    <th class="text-end">دائن</th>
                    <th>البيان</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            @(customer != null
                                ? "لا توجد عمليات للعميل في الفترة المحددة. غيّر من تاريخ / إلى تاريخ ثم اضغط عرض."
                                : "اختر عميلاً وحدّد الفترة ثم اضغط عرض.")
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var e in Model.Items)
                    {
                        var desc = e.Description ?? "";
                        var descShort = desc.Length > 60 ? desc.Substring(0, 60) + "…" : desc;
                        <tr>
                            <td>@e.Id</td>
                            <td>@e.EntryDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@e.SourceType</td>
                            <td>@e.VoucherNo</td>
                            <td>@(e.Account != null ? $"{e.Account.AccountCode} - {e.Account.AccountName}" : "")</td>
                            <td class="text-end">@(e.Debit > 0 ? e.Debit.ToString("N2") : "")</td>
                            <td class="text-end">@(e.Credit > 0 ? e.Credit.ToString("N2") : "")</td>
                            <td>@descShort</td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="table-light">
                <tr class="fw-bold">
                    <td colspan="5" class="text-end">الإجمالي:</td>
                    <td class="text-end">@totalDebit.ToString("N2")</td>
                    <td class="text-end">@totalCredit.ToString("N2")</td>
                    <td>صافي: @netBalance.ToString("N2")</td>
                </tr>
            </tfoot>
        </table>
    </div>

    @* الترقيم *@
    @if (pages > 1)
    {
        <nav class="mt-3" aria-label="ترقيم الصفحات">
            <ul class="pagination justify-content-center">
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@(page > 1 ? Link(1) : "#")">الأولى</a>
                </li>
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@(page > 1 ? Link(prev) : "#")">السابق</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">@start - @end من @total</span>
                </li>
                <li class="page-item @(page >= pages ? "disabled" : "")">
                    <a class="page-link" href="@(page < pages ? Link(next) : "#")">التالي</a>
                </li>
                <li class="page-item @(page >= pages ? "disabled" : "")">
                    <a class="page-link" href="@(page < pages ? Link(last) : "#")">الأخيرة</a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        (function () {
            var customersData = @Html.Raw(customersJson);
            var input = document.getElementById('customerNameInput');
            var hiddenId = document.getElementById('customerIdHidden');
            var list = document.getElementById('customerSuggestions');
            var form = document.getElementById('customerLedgerForm');
            var activeIndex = -1;

            if (input) setTimeout(function () { input.focus(); }, 150);

            if (input && hiddenId && list && form) {
                input.addEventListener('input', function () {
                    var term = input.value.trim();
                    hiddenId.value = "";
                    activeIndex = -1;

                    if (term.length < 1) {
                        list.style.display = 'none';
                        list.innerHTML = '';
                        return;
                    }

                    var termLower = term.toLowerCase();
                    var results = customersData.filter(function (item) {
                        var codeMatch = item.code && String(item.code).indexOf(term) !== -1;
                        var nameMatch = item.name && item.name.toLowerCase().indexOf(termLower) !== -1;
                        return codeMatch || nameMatch;
                    });

                    list.innerHTML = '';

                    if (!results || results.length === 0) {
                        list.style.display = 'none';
                        return;
                    }

                    results.slice(0, 30).forEach(function (item) {
                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'list-group-item list-group-item-action';
                        btn.dataset.id = item.id;
                        btn.textContent = item.code + ' — ' + item.name;

                        btn.addEventListener('click', function () {
                            hiddenId.value = item.id;
                            input.value = item.code + ' — ' + item.name;
                            list.style.display = 'none';
                        });

                        list.appendChild(btn);
                    });

                    list.style.display = 'block';
                });

                input.addEventListener('keydown', function (e) {
                    var items = list.querySelectorAll('button');
                    if (list.style.display !== 'block' || items.length === 0) return;

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        activeIndex = (activeIndex + 1) % items.length;
                        items.forEach(function (el) { el.classList.remove('active'); });
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            items[activeIndex].classList.add('active');
                            items[activeIndex].scrollIntoView({ block: 'nearest' });
                        }
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        activeIndex = (activeIndex - 1 + items.length) % items.length;
                        items.forEach(function (el) { el.classList.remove('active'); });
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            items[activeIndex].classList.add('active');
                            items[activeIndex].scrollIntoView({ block: 'nearest' });
                        }
                    } else if (e.key === 'Enter') {
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            e.preventDefault();
                            items[activeIndex].click();
                        }
                    } else if (e.key === 'Escape') {
                        list.style.display = 'none';
                    }
                });

                document.addEventListener('click', function (e) {
                    if (!list.contains(e.target) && e.target !== input) {
                        list.style.display = 'none';
                    }
                });

                form.addEventListener('submit', function (e) {
                    if (!hiddenId.value) {
                        var txt = input.value.trim();
                        if (/^\d+$/.test(txt)) {
                            hiddenId.value = txt;
                        } else if (txt.length > 0) {
                            var exactMatch = customersData.find(function(item) {
                                return item.name.toLowerCase() === txt.toLowerCase() ||
                                       item.code === txt ||
                                       (item.code + ' — ' + item.name) === txt;
                            });
                            if (exactMatch) {
                                hiddenId.value = exactMatch.id.toString();
                                input.value = exactMatch.code + ' — ' + exactMatch.name;
                            } else {
                                var termLower = txt.toLowerCase();
                                var matches = customersData.filter(function (item) {
                                    var codeMatch = item.code && String(item.code).indexOf(txt) !== -1;
                                    var nameMatch = item.name && item.name.toLowerCase().indexOf(termLower) !== -1;
                                    return codeMatch || nameMatch;
                                });
                                if (matches.length === 1) {
                                    hiddenId.value = matches[0].id.toString();
                                    input.value = matches[0].code + ' — ' + matches[0].name;
                                }
                            }
                        }
                    }

                    if (!hiddenId.value) {
                        e.preventDefault();
                        alert('من فضلك اختر عميلاً من القائمة أو أدخل كوده الرقمي ثم اضغط عرض.');
                    }
                });
            }
        })();
    </script>
}
