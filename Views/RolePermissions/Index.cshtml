@section Scripts {
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script>
        document.getElementById("btnPrintRP")?.addEventListener("click", function () { window.print(); });

        ERP.initListColumnFilter({
            panelId: 'erpRpColumnFilterPanel',
            tableId: 'rpTable',
            wrapperId: 'rpTableScrollWrapper',
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "RolePermissions")',
            defaultSort: 'Id',
            defaultDir: 'asc',
            numericColumns: ['id']
        });

        (function () {
            const table = document.getElementById("rpTable");
            if (!table) return;
            const storageKey = "roleperm-columns-visibility";
            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells.filter(th => !th.hasAttribute("data-col-fixed")).map(th => ({
                key: th.getAttribute("data-col"),
                title: (th.querySelector(".erp-col-title") && th.querySelector(".erp-col-title").textContent) || th.innerText.trim()
            }));
            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }
            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']").forEach(cell => cell.classList.toggle("d-none", isHidden));
                });
            }
            applyVisibility();
            const listContainer = document.getElementById("columnsListRP");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_rp_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";
                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;
                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;
                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }
            document.getElementById("btnApplyColumnsRP")?.addEventListener("click", function () {
                const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                hidden = [];
                checks.forEach(cb => { if (!cb.checked) hidden.push(cb.dataset.colKey); });
                try { localStorage.setItem(storageKey, JSON.stringify(hidden)); } catch { }
                applyVisibility();
                bootstrap.Modal.getInstance(document.getElementById("columnsModalRP"))?.hide();
            });
        })();

        (function () {
            const selectAll = document.getElementById("selectAll");
            const bulkBtn = document.getElementById("btnBulkDelete");
            const bulkForm = document.getElementById("formBulkDelete");
            const deleteAllBtn = document.getElementById("btnDeleteAll");
            const formDeleteAll = document.getElementById("formDeleteAll");
            const idsContainer = document.getElementById("bulkDeleteIdsContainer");
            function getRowCheckboxes() { return Array.from(document.querySelectorAll(".row-select")); }
            function syncSelectAllState() {
                const checks = getRowCheckboxes();
                if (!selectAll || checks.length === 0) return;
                const checkedCount = checks.filter(cb => cb.checked).length;
                selectAll.checked = checkedCount > 0 && checkedCount === checks.length;
                selectAll.indeterminate = checkedCount > 0 && checkedCount < checks.length;
            }
            selectAll?.addEventListener("change", function () { getRowCheckboxes().forEach(cb => cb.checked = this.checked); });
            getRowCheckboxes().forEach(cb => cb.addEventListener("change", syncSelectAllState));
            syncSelectAllState();
            bulkBtn?.addEventListener("click", function () {
                const checks = getRowCheckboxes().filter(cb => cb.checked);
                if (checks.length === 0) { alert("من فضلك اختر على الأقل سطر واحد للحذف."); return; }
                if (!confirm("هل أنت متأكد من حذف السطور المحددة؟")) return;
                idsContainer.innerHTML = "";
                checks.forEach(cb => {
                    const input = document.createElement("input");
                    input.type = "hidden";
                    input.name = "ids";
                    input.value = cb.value;
                    idsContainer.appendChild(input);
                });
                if (typeof bulkForm.requestSubmit === "function") bulkForm.requestSubmit(); else bulkForm.submit();
            });
            deleteAllBtn?.addEventListener("click", function () {
                if (!confirm("هل أنت متأكد من حذف جميع صلاحيات الأدوار؟")) return;
                if (typeof formDeleteAll.requestSubmit === "function") formDeleteAll.requestSubmit(); else formDeleteAll.submit();
            });
        })();

        if (window.ERP && typeof ERP.initListSelection === "function") {
            ERP.initListSelection({
                rowSelector: "#rpTable tbody tr.erp-list-selectable-row",
                idAttribute: "data-rolepermission-id",
                editButtonId: "btnEditRP",
                editUrlAttribute: "data-edit-url",
                tabTitleAttribute: "data-tab-title",
                editTabTitleAttribute: "data-tab-title",
                editTabId: "rolepermission-edit-tab",
                multiSelectCheckboxes: true
            });
        }

        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp = document.getElementById("codeFromInput");
            const toInp = document.getElementById("codeToInput");
            function applyCodeToUrl(url, codeFrom, codeTo) {
                if (codeFrom) url.searchParams.set("fromCode", codeFrom); else url.searchParams.delete("fromCode");
                if (codeTo) url.searchParams.set("toCode", codeTo); else url.searchParams.delete("toCode");
                url.searchParams.set("page", "1");
            }
            btnApply?.addEventListener("click", function () {
                const url = new URL(window.location.href);
                applyCodeToUrl(url, fromInp?.value.trim() ?? "", toInp?.value.trim() ?? "");
                window.location.href = url.toString();
            });
            btnClear?.addEventListener("click", function () {
                if (fromInp) fromInp.value = "";
                if (toInp) toInp.value = "";
                const url = new URL(window.location.href);
                applyCodeToUrl(url, "", "");
                window.location.href = url.toString();
            });
        })();
    </script>
}
