@model ERP.Models.RolePermission

@{
    ViewData["Title"] = "تعديل صلاحيات دور";
    string roleName = ViewBag.RoleName as string ?? "";
    var permissions = ViewBag.Permissions as List<ERP.Models.Permission> ?? new List<ERP.Models.Permission>();
    var selectedIds = ViewBag.SelectedPermissionIds as HashSet<int> ?? new HashSet<int>();
    var moduleOrder = new[] { "لوحات التحكم", "الإعدادات", "المستخدمون والصلاحيات", "المناطق الجغرافية", "العملاء", "إدارة المخازن", "المبيعات", "المشتريات", "الحسابات", "التقارير", "أخرى" };
    var grouped = permissions
        .GroupBy(p => string.IsNullOrWhiteSpace(p.Module) ? "أخرى" : (p.Module ?? "أخرى"))
        .ToDictionary(g => g.Key, g => g.ToList());
    var byModule = moduleOrder
        .Where(m => grouped.ContainsKey(m))
        .Select(m => new { Key = m, Items = grouped[m] })
        .Concat(grouped.Where(kv => !moduleOrder.Contains(kv.Key)).Select(kv => new { Key = kv.Key, Items = kv.Value }))
        .ToList();
}

<div class="container-fluid" dir="rtl">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <h2 class="mb-0">تعديل صلاحيات دور — @roleName (@Model.RoleId)</h2>
        <a asp-action="Index" class="btn btn-primary">صلاحيات الأدوار</a>
    </div>

    <form asp-action="Edit" method="post" class="card">
        @Html.AntiForgeryToken()
        <input type="hidden" name="roleId" value="@Model.RoleId" />

        <div class="card-body">
            @* بحث في الصلاحيات (مثل أدوار المستخدمين) *@
            <div class="erp-list-filter-bar mb-3 p-2 rounded bg-light">
                <label class="form-label fw-semibold mb-2">بحث في الصلاحيات</label>
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <input type="text"
                           id="permSearch"
                           class="form-control"
                           style="max-width: 320px;"
                           placeholder="اكتب جزء من اسم الصلاحية أو الموديول أو الكود..." />
                    <button type="button" id="btnPermSearch" class="btn btn-primary btn-sm">بحث</button>
                    <button type="button" id="btnPermClear" class="btn btn-secondary btn-sm">مسح البحث</button>
                </div>
            </div>

            @* جدول الصلاحيات مقسم حسب الموديول *@
            <div class="table-responsive" style="max-height: 65vh; overflow: auto;">
                <table class="table table-sm table-hover table-striped">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th style="width: 50px;" class="text-center">
                                <input type="checkbox" id="chkAll" title="تحديد الكل / إلغاء الكل" />
                            </th>
                            <th style="width: 42px;"></th>
                            <th>الصلاحية</th>
                            <th>الموديول</th>
                            <th>الكود</th>
                            <th style="width: 80px;" class="text-center">مسموح؟</th>
                        </tr>
                    </thead>
                    <tbody id="permTableBody">
                        @foreach (var group in byModule)
                        {
                            var moduleName = group.Key;
                            var modulePerms = group.Items.OrderBy(x => x.NameAr).ToList();
                            var allSelected = modulePerms.Count > 0 && modulePerms.All(x => selectedIds.Contains(x.PermissionId));
                            <tr class="perm-module-row" data-module="@moduleName" style="background: linear-gradient(90deg, #e8eaf6 0%, #c5cae9 100%); font-size: 1.05em;">
                                <td class="text-center align-middle" style="width: 42px;">
                                    <input type="checkbox" class="form-check-input perm-module-cb" data-module="@moduleName"
                                           @(allSelected ? "checked" : "") title="تحديد كل صلاحيات هذا الموديول / إلغاء الكل" />
                                </td>
                                <td class="text-center align-middle" style="width: 42px;">
                                    <button type="button" class="btn btn-sm btn-outline-secondary perm-module-toggle" aria-label="فتح/إغلاق" title="فتح/إغلاق الصلاحيات">
                                        <span class="perm-toggle-icon">−</span>
                                    </button>
                                </td>
                                <td class="align-middle" colspan="2"><strong>@moduleName</strong></td>
                                <td class="small text-muted"></td>
                                <td class="text-center align-middle">
                                    <span class="perm-module-status @(allSelected ? "text-success" : "text-danger")">@(allSelected ? "✔" : "✖")</span>
                                </td>
                            </tr>
                            foreach (var p in group.Items.OrderBy(x => x.NameAr))
                            {
                                bool isChecked = selectedIds.Contains(p.PermissionId);
                                var rowText = $"{p.NameAr} {p.Module} {p.Code}".ToLower();
                                <tr class="perm-data-row perm-module-content" data-search="@rowText" data-module="@moduleName">
                                    <td class="text-center align-middle">
                                        <input type="checkbox"
                                               name="selectedPermissionIds"
                                               value="@p.PermissionId"
                                               class="perm-checkbox" @(isChecked ? "checked" : "") />
                                    </td>
                                    <td></td>
                                    <td>@p.NameAr</td>
                                    <td>@(p.Module ?? "-")</td>
                                    <td class="small text-muted">@p.Code</td>
                                    <td class="text-center align-middle">
                                        <span class="perm-row-status @(isChecked ? "text-success" : "text-danger")">@(isChecked ? "✔" : "✖")</span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <p class="form-text mt-2 mb-0">
                <strong>تشيك بوكس الموديول:</strong> عند تحديده يختار كل صلاحيات هذا الموديول، وعند إلغائه يزيل التحديد عن الكل (مثل أدوار المستخدمين). ✔ = الكل مُختار، ✖ = غير كامل.
            </p>
        </div>

        <div class="card-footer d-flex justify-content-between flex-wrap gap-2">
            <a asp-action="Index" class="btn btn-secondary">رجوع للقائمة</a>
            <button type="submit" class="btn btn-success" id="btnSave">حفظ التعديلات</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (function () {
            const tbody = document.getElementById('permTableBody');
            const chkAll = document.getElementById('chkAll');
            const permSearch = document.getElementById('permSearch');
            const btnSearch = document.getElementById('btnPermSearch');
            const btnClear = document.getElementById('btnPermClear');

            function applySearch() {
                const term = (permSearch && permSearch.value) ? permSearch.value.trim().toLowerCase() : '';
                const dataRows = tbody ? tbody.querySelectorAll('tr.perm-data-row') : [];
                const moduleRows = tbody ? tbody.querySelectorAll('tr.perm-module-row') : [];
                if (term === '') {
                    dataRows.forEach(function (tr) { tr.style.display = ''; });
                    moduleRows.forEach(function (tr) { tr.style.display = ''; });
                    return;
                }
                moduleRows.forEach(function (modRow) {
                    const moduleName = (modRow.getAttribute('data-module') || '').toLowerCase();
                    const nextRows = [];
                    let el = modRow.nextElementSibling;
                    while (el && el.classList.contains('perm-data-row')) {
                        nextRows.push(el);
                        el = el.nextElementSibling;
                    }
                    const anyVisible = nextRows.some(function (r) {
                        const text = (r.getAttribute('data-search') || '').toLowerCase();
                        return text.indexOf(term) >= 0;
                    });
                    nextRows.forEach(function (r) {
                        const text = (r.getAttribute('data-search') || '').toLowerCase();
                        r.style.display = (text.indexOf(term) >= 0) ? '' : 'none';
                    });
                    modRow.style.display = (anyVisible || moduleName.indexOf(term) >= 0) ? '' : 'none';
                });
            }

            if (btnSearch) btnSearch.addEventListener('click', applySearch);
            if (btnClear) {
                btnClear.addEventListener('click', function () {
                    if (permSearch) permSearch.value = '';
                    applySearch();
                    if (permSearch) permSearch.focus();
                });
            }
            if (permSearch) {
                permSearch.addEventListener('input', applySearch);
                permSearch.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); applySearch(); } });
            }

            function updateDataRowStatus(dataRow) {
                if (!dataRow) return;
                var cb = dataRow.querySelector('.perm-checkbox');
                var span = dataRow.querySelector('.perm-row-status');
                if (span && cb) { span.textContent = cb.checked ? '✔' : '✖'; span.className = 'perm-row-status ' + (cb.checked ? 'text-success' : 'text-danger'); }
            }
            function updateModuleRowStatus(modRow) {
                if (!modRow) return;
                var contentRows = [];
                var el = modRow.nextElementSibling;
                while (el && el.classList.contains('perm-data-row')) {
                    contentRows.push(el);
                    el = el.nextElementSibling;
                }
                var allChecked = contentRows.length > 0 && contentRows.every(function (r) {
                    var cb = r.querySelector('.perm-checkbox');
                    return cb && cb.checked;
                });
                var modCb = modRow.querySelector('.perm-module-cb');
                var span = modRow.querySelector('.perm-module-status');
                if (modCb) modCb.checked = allChecked;
                if (span) { span.textContent = allChecked ? '✔' : '✖'; span.className = 'perm-module-status ' + (allChecked ? 'text-success' : 'text-danger'); }
                contentRows.forEach(updateDataRowStatus);
            }

            // تشيك بوكس الموديول: عند التحديد يختار كل عناصر الموديول، عند الإلغاء يزيلها (مثل أدوار المستخدمين)
            tbody.querySelectorAll('.perm-module-cb').forEach(function (modCb) {
                modCb.addEventListener('change', function () {
                    var modRow = this.closest('tr.perm-module-row');
                    var moduleName = (this.getAttribute('data-module') || '').trim();
                    var checked = this.checked;
                    var el = modRow ? modRow.nextElementSibling : null;
                    while (el && el.classList.contains('perm-data-row')) {
                        if ((el.getAttribute('data-module') || '') === moduleName) {
                            var cb = el.querySelector('.perm-checkbox');
                            if (cb) cb.checked = checked;
                        }
                        el = el.nextElementSibling;
                    }
                    updateModuleRowStatus(modRow);
                });
            });

            // عند تغيير أي صلاحية فردية نحدّث علامة الصف + تشيك بوكس الموديول
            tbody.querySelectorAll('.perm-checkbox').forEach(function (cb) {
                cb.addEventListener('change', function () {
                    var tr = this.closest('tr.perm-data-row');
                    if (!tr) return;
                    updateDataRowStatus(tr);
                    var prev = tr.previousElementSibling;
                    while (prev && !prev.classList.contains('perm-module-row')) prev = prev.previousElementSibling;
                    updateModuleRowStatus(prev);
                });
            });

            if (chkAll && tbody) {
                chkAll.addEventListener('change', function () {
                    const checked = chkAll.checked;
                    tbody.querySelectorAll('.perm-data-row').forEach(function (tr) {
                        if (tr.style.display !== 'none') {
                            var cb = tr.querySelector('.perm-checkbox');
                            if (cb) cb.checked = checked;
                            updateDataRowStatus(tr);
                        }
                    });
                    tbody.querySelectorAll('tr.perm-module-row').forEach(updateModuleRowStatus);
                });
            }

            // فتح/إغلاق صلاحيات كل موديول بزر +
            tbody.querySelectorAll('.perm-module-toggle').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var row = btn.closest('tr.perm-module-row');
                    if (!row) return;
                    var moduleName = row.getAttribute('data-module') || '';
                    var contentRows = [];
                    var el = row.nextElementSibling;
                    while (el && el.classList.contains('perm-data-row')) {
                        contentRows.push(el);
                        el = el.nextElementSibling;
                    }
                    var isHidden = contentRows.length > 0 && contentRows[0].style.display === 'none';
                    var icon = row.querySelector('.perm-toggle-icon');
                    contentRows.forEach(function (r) {
                        r.style.display = isHidden ? '' : 'none';
                    });
                    if (icon) icon.textContent = isHidden ? '−' : '+';
                });
            });
        })();
    </script>
}
