@model ERP.Models.RolePermission

@{
    ViewData["Title"] = "ربط دور بصلاحياته";
}

<div class="container" dir="rtl">
    <h2 class="mb-3">ربط دور بصلاحياته</h2>
    <p class="text-muted mb-4">اختر الدور ثم اضغط «تعديل صلاحيات هذا الدور» لفتح صفحة تحديد الصلاحيات (نفس نظام التعديل — تحديد وإلغاء بحرية ثم حفظ).</p>

    <div class="card">
        <div class="card-body">
            <div class="mb-3">
                <label for="roleId" class="form-label">الدور</label>
                <select id="roleId"
                        class="form-select"
                        style="max-width: 400px;">
                    <option value="">-- اختر دورًا --</option>
                    @if (ViewBag.RoleId is SelectList roleList)
                    {
                        @foreach (SelectListItem item in roleList)
                        {
                            if (!string.IsNullOrEmpty(item.Value))
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    }
                </select>
            </div>
            <button type="button" id="btnGoToEdit" class="btn btn-primary" disabled>
                تعديل صلاحيات هذا الدور
            </button>
        </div>
        <div class="card-footer">
            <a asp-action="Index" class="btn btn-secondary">رجوع للقائمة</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var roleSelect = document.getElementById('roleId');
            var btnGo = document.getElementById('btnGoToEdit');
            if (roleSelect) {
                roleSelect.addEventListener('change', function () {
                    if (btnGo) btnGo.disabled = !this.value || this.value === '';
                });
            }
            if (btnGo && roleSelect) {
                btnGo.addEventListener('click', function () {
                    var roleId = roleSelect.value;
                    if (!roleId) return;
                    window.location.href = '@Url.Action("Edit", "RolePermissions")/' + roleId;
                });
            }
        })();
    </script>
}
