<form id="formBulkDelete" asp-action="BulkDelete" asp-controller="CreditNotes" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>
<form id="formDeleteAll" asp-action="DeleteAll" asp-controller="CreditNotes" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
<script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
<script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
<script>
    document.getElementById("btnPrintCreditNotes")?.addEventListener("click", function () { window.print(); });

    ERP.initListColumnFilter({
        panelId: 'erpColumnFilterPanelCreditNotes',
        tableId: 'creditNotesTable',
        wrapperId: 'creditNotesTableScrollWrapper',
        getColumnValuesUrl: '@Url.Action("GetColumnValues", "CreditNotes")',
        defaultSort: 'NoteDate',
        defaultDir: 'desc',
        numericColumns: ['id', 'amount']
    });

    ERP.initListSelection({
        rowSelector: '.erp-list-selectable-row',
        showButtonId: 'btnShowCn',
        editButtonId: 'btnEditCn',
        idAttribute: 'data-row-id',
        showUrlAttribute: 'data-show-url',
        editUrlAttribute: 'data-edit-url',
        tabTitleAttribute: 'data-tab-title',
        multiSelectCheckboxes: true
    });

    document.getElementById('btnDeleteCn')?.addEventListener('click', function () {
        var row = document.querySelector('.erp-list-selectable-row.selected');
        if (!row) return;
        var url = row.getAttribute('data-delete-url');
        if (url) window.location.href = url;
    });

    (function () {
        const table = document.getElementById("creditNotesTable");
        if (!table) return;
        const storageKey = "creditnotes-columns-visibility";
        const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
        const columns = headerCells.filter(th => !th.hasAttribute("data-col-fixed")).map(th => ({ key: th.getAttribute("data-col"), title: th.innerText.trim() }));
        if (columns.length === 0) return;
        let hidden = [];
        try { const saved = localStorage.getItem(storageKey); if (saved) hidden = JSON.parse(saved); } catch { hidden = []; }
        function applyVisibility() {
            columns.forEach(col => {
                const isHidden = hidden.includes(col.key);
                table.querySelectorAll("[data-col='" + col.key + "']").forEach(cell => cell.classList.toggle("d-none", isHidden));
            });
        }
        applyVisibility();
        const listContainer = document.getElementById("columnsListCreditNotes");
        if (listContainer) {
            listContainer.innerHTML = "";
            columns.forEach(col => {
                const id = "col_cn_" + col.key;
                const wrapper = document.createElement("div"); wrapper.className = "form-check mb-1";
                const cb = document.createElement("input"); cb.type = "checkbox"; cb.className = "form-check-input ms-2"; cb.id = id; cb.checked = !hidden.includes(col.key); cb.dataset.colKey = col.key;
                const label = document.createElement("label"); label.className = "form-check-label"; label.setAttribute("for", id); label.innerText = col.title;
                wrapper.appendChild(cb); wrapper.appendChild(label); listContainer.appendChild(wrapper);
            });
        }
        document.getElementById("btnApplyColumnsCreditNotes")?.addEventListener("click", function () {
            const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
            hidden = []; checks.forEach(cb => { if (!cb.checked) hidden.push(cb.dataset.colKey); });
            try { localStorage.setItem(storageKey, JSON.stringify(hidden)); } catch { }
            applyVisibility();
            const modalEl = document.getElementById("columnsModalCreditNotes");
            bootstrap.Modal.getInstance(modalEl)?.hide();
        });
    })();

    (function () {
        const selectAll = document.getElementById("selectAll");
        const bulkBtn = document.getElementById("btnBulkDelete");
        const deleteAllBtn = document.getElementById("btnDeleteAll");
        const bulkForm = document.getElementById("formBulkDelete");
        const deleteAllForm = document.getElementById("formDeleteAll");

        function getRowCheckboxes() { return Array.from(document.querySelectorAll(".row-select")); }
        selectAll?.addEventListener("change", function () { const checked = this.checked; getRowCheckboxes().forEach(cb => cb.checked = checked); });

        function doBulkDelete() {
            const checks = getRowCheckboxes().filter(cb => cb.checked);
            if (checks.length === 0) { alert("من فضلك اختر على الأقل إشعاراً واحداً للحذف."); return; }
            if (!confirm("هل أنت متأكد من حذف إشعارات الإضافة المحددة؟")) return;
            bulkForm.querySelectorAll("input[type='hidden'][name='ids']").forEach(h => h.remove());
            checks.forEach(cb => { const input = document.createElement("input"); input.type = "hidden"; input.name = "ids"; input.value = cb.value; bulkForm.appendChild(input); });
            bulkForm.submit();
        }
        function doDeleteAll() {
            if (!confirm("هل أنت متأكد من حذف جميع إشعارات الإضافة؟ يُنصح باستخدام هذا في بيئة تجريبية فقط.")) return;
            deleteAllForm.submit();
        }

        if (bulkBtn) bulkBtn.addEventListener("click", doBulkDelete);
        if (deleteAllBtn) deleteAllBtn.addEventListener("click", doDeleteAll);
    })();

    (function () {
        const btnApply = document.getElementById("btnApplyCodeFilter");
        const btnClear = document.getElementById("btnClearCodeFilter");
        const fromInp = document.getElementById("codeFromInput");
        const toInp = document.getElementById("codeToInput");
        function buildUrl(codeFrom, codeTo) {
            const url = new URL(window.location.href);
            if (codeFrom) url.searchParams.set("fromCode", codeFrom); else url.searchParams.delete("fromCode");
            if (codeTo) url.searchParams.set("toCode", codeTo); else url.searchParams.delete("toCode");
            url.searchParams.set("page", "1");
            return url.toString();
        }
        btnApply?.addEventListener("click", function () { window.location.href = buildUrl(fromInp.value.trim(), toInp.value.trim()); });
        btnClear?.addEventListener("click", function () { fromInp.value = ""; toInp.value = ""; window.location.href = buildUrl("", ""); });
    })();

    (function () {
        function syncDeleteBtn() {
            var row = document.querySelector('.erp-list-selectable-row.selected');
            var btn = document.getElementById('btnDeleteCn');
            if (btn) btn.disabled = !row;
        }
        document.getElementById('creditNotesTable')?.addEventListener('click', function () { setTimeout(syncDeleteBtn, 0); });
    })();
</script>
}
