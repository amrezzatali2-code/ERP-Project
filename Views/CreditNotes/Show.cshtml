@model ERP.Models.CreditNote

@{
    ViewData["Title"] = "إشعار إضافة";
}

<div class="container mt-3" dir="rtl">
    <div class="card" style="max-width: 700px; margin:auto;">
        <div class="card-header text-center">
            <h4 class="mb-0">إشعار إضافة — @Model.CreditNoteId</h4>
        </div>
        <div class="card-body">
            <div class="d-flex justify-content-between mb-3">
                <div>
                    <strong>رقم الإشعار:</strong> @Model.CreditNoteId<br />
                    <strong>التاريخ:</strong> @Model.NoteDate.ToString("yyyy-MM-dd")
                </div>
                <div class="text-end">
                    <strong>الطرف:</strong> @Model.Customer?.CustomerName<br />
                    <strong>المبلغ:</strong> @Model.Amount.ToString("N2")
                </div>
            </div>

            <hr />

            <p><strong>إشعار إضافة بقيمة:</strong> @Model.Amount.ToString("N2")</p>
            <p><strong>على الطرف:</strong> @Model.Customer?.CustomerName</p>
            <p><strong>حساب الطرف:</strong> @(Model.Account != null ? $"{Model.Account.AccountCode} - {Model.Account.AccountName}" : "-")</p>
            @if (Model.OffsetAccount != null)
            {
                <p><strong>الحساب المقابل:</strong> @($"{Model.OffsetAccount.AccountCode} - {Model.OffsetAccount.AccountName}")</p>
            }
            @if (!string.IsNullOrEmpty(Model.Reason))
            {
                <p><strong>السبب:</strong> @Model.Reason</p>
            }
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p><strong>البيان:</strong> @Model.Description</p>
            }

            <p class="mt-2">
                <span class="badge @(Model.IsPosted ? "bg-success" : "bg-secondary")">
                    @(Model.IsPosted ? "مرحّل" : "مسودة")
                </span>
            </p>

            <hr />

            <div class="row mt-4">
                <div class="col text-center">
                    <strong>المستلم</strong>
                    <div style="height:60px;border-bottom:1px dashed #999;"></div>
                </div>
                <div class="col text-center">
                    <strong>المراجع</strong>
                    <div style="height:60px;border-bottom:1px dashed #999;"></div>
                </div>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary btn-sm">عودة للقائمة</a>
            <div>
                <a asp-action="Edit" asp-route-id="@Model.CreditNoteId" class="btn btn-primary btn-sm">تعديل</a>
                <button type="button" class="btn btn-outline-primary btn-sm" onclick="window.print();">طباعة</button>
            </div>
        </div>
    </div>
</div>
