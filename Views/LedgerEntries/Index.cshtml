                    <th data-col="sourceId">@filterableCol("sourceId", "SourceId", "معرّف المصدر")</th>
                    <th data-col="accId">@filterableCol("accId", "AccountId", "كود/رقم الحساب")</th>
                    <th data-col="accName">@filterableCol("accName", "AccountName", "اسم الحساب")</th>
                    <th data-col="customer">@filterableCol("customer", "CustomerName", "العميل / الطرف")</th>
                    <th data-col="externalCode" style="width:90px;">كود الإكسل</th>
                    <th data-col="debit">@filterableCol("debit", "Debit", "مدين")</th>
                    <th data-col="credit">@filterableCol("credit", "Credit", "دائن")</th>
                    <th data-col="desc">@filterableCol("desc", "Description", "البيان")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="12" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var e in Model.Items)
                    {
                        var desc = e.Description ?? "";
                        var descShort = desc.Length > 80 ? desc.Substring(0, 80) + "…" : desc;
                        var showUrl = (Url.Action("Show", "LedgerEntries", new { id = e.Id }) ?? "") + "?frame=1";
                        var tabTitle = $"قيد {e.Id}";

                        <tr class="erp-list-selectable-row"
                            data-row-id="@e.Id"
                            data-show-url="@showUrl"
                            data-tab-title="@tabTitle">
                            <td data-col="id">@e.Id</td>
                            <td data-col="date">@e.EntryDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td data-col="source">@e.SourceType</td>
                            <td data-col="postVersion">@(e.PostVersion > 0 ? e.PostVersion.ToString() : "")</td>
                            <td data-col="sourceId">@e.SourceId</td>
                            <td data-col="accId">@(e.Account != null ? e.Account.AccountCode + " (" + e.AccountId + ")" : e.AccountId.ToString())</td>
