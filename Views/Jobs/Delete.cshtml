@model ERP.Models.Job
@{
    ViewData["Title"] = "حذف وظيفة";
}
<div class="container" dir="rtl">
    <h2 class="mb-3">تأكيد حذف الوظيفة</h2>
    <p class="text-danger">هل أنت متأكد من حذف الوظيفة التالية؟</p>
    <dl class="row">
        <dt class="col-sm-3">كود الوظيفة</dt>
        <dd class="col-sm-9">@Model.Id</dd>
        <dt class="col-sm-3">الوظيفة / المسمى</dt>
        <dd class="col-sm-9">@Model.Name</dd>
    </dl>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">نعم، احذف</button>
        <a class="btn btn-secondary" asp-action="Index">إلغاء</a>
    </form>
</div>
