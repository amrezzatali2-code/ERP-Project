@* Views/SalesInvoiceLines/Index.cshtml — قائمة أصناف المبيعات بنفس نموذج الفواتير *@
@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.SalesInvoiceLine>

@{
    ViewData["Title"] = "قائمة أصناف المبيعات";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "SalesInvoiceLines";

    // قيم البحث/الترتيب الحالية
    var searchRaw = Model.Search ?? (string?)ViewBag.Search ?? "";
    
    // تنظيف search من أسماء الأعمدة المعروفة
    var columnNames = new[] { "siid", "line", "lineno", "prodid", "prodname", "customername", "region", "createdby",
        "qty", "price", "unit", "total", "net", "disc1", "disc2", "disc3", "discval",
        "itemreturnqty", "finalnetafterall",
        "batch", "expiry", "رقم الفاتورة", "رقم السطر", "كود الصنف", "اسم الصنف",
        "اسم العميل", "المنطقة", "الكاتب", "الكمية", "سعر الجمهور", "التشغيلة", "الصلاحية",
        "الخصم", "قيمة الخصم", "مرتجع الصنف", "الصافي النهائي بعد كل حاجة" };
    
    var search = "";
    if (!string.IsNullOrWhiteSpace(searchRaw))
    {
        var searchLower = searchRaw.Trim().ToLowerInvariant();
        if (!columnNames.Contains(searchLower))
        {
            search = searchRaw.Trim();
        }
    }
    
    var searchBy = (string?)ViewBag.SearchBy ?? "all";          // all | si | prod | batch | notes
    var searchMode = ((string?)ViewBag.SearchMode ?? "contains").ToLowerInvariant();
    if (searchMode != "starts" && searchMode != "ends") searchMode = "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "LineNo";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    // بيانات الترقيم
    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
    int end = (ps == 0 || total == 0) ? total : Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;
    var dateField = (string?)ViewBag.DateField ?? "Expiry";
    int? siIdFilter = ViewBag.SIId as int?;

    string? filterCol_siid = ViewBag.FilterCol_Siid as string;
    string? filterCol_lineno = ViewBag.FilterCol_Lineno as string;
    string? filterCol_prodid = ViewBag.FilterCol_Prodid as string;
    string? filterCol_prodname = ViewBag.FilterCol_Prodname as string;
    string? filterCol_customername = ViewBag.FilterCol_Customername as string;
    string? filterCol_qty = ViewBag.FilterCol_Qty as string;
    string? filterCol_price = ViewBag.FilterCol_Price as string;
    string? filterCol_disc1 = ViewBag.FilterCol_Disc1 as string;
    string? filterCol_disc2 = ViewBag.FilterCol_Disc2 as string;
    string? filterCol_disc3 = ViewBag.FilterCol_Disc3 as string;
    string? filterCol_discval = ViewBag.FilterCol_Discval as string;
    string? filterCol_total = ViewBag.FilterCol_Total as string;
    string? filterCol_net = ViewBag.FilterCol_Net as string;
    string? filterCol_batch = ViewBag.FilterCol_Batch as string;
    string? filterCol_expiry = ViewBag.FilterCol_Expiry as string;
    string? filterCol_region = ViewBag.FilterCol_Region as string;
    string? filterCol_createdby = ViewBag.FilterCol_Createdby as string;
    string? filterCol_siidExpr = ViewBag.FilterCol_SiidExpr as string;
    string? filterCol_linenoExpr = ViewBag.FilterCol_LinenoExpr as string;
    string? filterCol_prodidExpr = ViewBag.FilterCol_ProdidExpr as string;
    string? filterCol_qtyExpr = ViewBag.FilterCol_QtyExpr as string;
    string? filterCol_priceExpr = ViewBag.FilterCol_PriceExpr as string;
    string? filterCol_disc1Expr = ViewBag.FilterCol_Disc1Expr as string;
    string? filterCol_disc2Expr = ViewBag.FilterCol_Disc2Expr as string;
    string? filterCol_disc3Expr = ViewBag.FilterCol_Disc3Expr as string;
    string? filterCol_discvalExpr = ViewBag.FilterCol_DiscvalExpr as string;
    string? filterCol_totalExpr = ViewBag.FilterCol_TotalExpr as string;
    string? filterCol_netExpr = ViewBag.FilterCol_NetExpr as string;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField,
        fromCode,
        toCode,
        siId = siIdFilter,
        filterCol_siid,
        filterCol_lineno,
        filterCol_prodid,
        filterCol_prodname,
        filterCol_customername,
        filterCol_qty,
        filterCol_price,
        filterCol_disc1,
        filterCol_disc2,
        filterCol_disc3,
        filterCol_discval,
        filterCol_total,
        filterCol_net,
        filterCol_batch,
        filterCol_expiry,
        filterCol_region,
        filterCol_createdby,
        filterCol_siidExpr,
        filterCol_linenoExpr,
        filterCol_prodidExpr,
        filterCol_qtyExpr,
        filterCol_priceExpr,
        filterCol_disc1Expr,
        filterCol_disc2Expr,
        filterCol_disc3Expr,
        filterCol_discvalExpr,
        filterCol_totalExpr,
        filterCol_netExpr
    })!;

    string? FilterForCol(string colKey) =>
        colKey == "siid" ? (!string.IsNullOrWhiteSpace(filterCol_siidExpr) ? filterCol_siidExpr : filterCol_siid)
        : colKey == "lineno" ? (!string.IsNullOrWhiteSpace(filterCol_linenoExpr) ? filterCol_linenoExpr : filterCol_lineno)
        : colKey == "prodid" ? (!string.IsNullOrWhiteSpace(filterCol_prodidExpr) ? filterCol_prodidExpr : filterCol_prodid)
        : colKey == "prodname" ? filterCol_prodname
        : colKey == "customername" ? filterCol_customername
        : colKey == "region" ? filterCol_region
        : colKey == "createdby" ? filterCol_createdby
        : colKey == "qty" ? (!string.IsNullOrWhiteSpace(filterCol_qtyExpr) ? filterCol_qtyExpr : filterCol_qty)
        : colKey == "price" ? (!string.IsNullOrWhiteSpace(filterCol_priceExpr) ? filterCol_priceExpr : filterCol_price)
        : colKey == "disc1" ? (!string.IsNullOrWhiteSpace(filterCol_disc1Expr) ? filterCol_disc1Expr : filterCol_disc1)
        : colKey == "disc2" ? (!string.IsNullOrWhiteSpace(filterCol_disc2Expr) ? filterCol_disc2Expr : filterCol_disc2)
        : colKey == "disc3" ? (!string.IsNullOrWhiteSpace(filterCol_disc3Expr) ? filterCol_disc3Expr : filterCol_disc3)
        : colKey == "discval" ? (!string.IsNullOrWhiteSpace(filterCol_discvalExpr) ? filterCol_discvalExpr : filterCol_discval)
        : colKey == "total" ? (!string.IsNullOrWhiteSpace(filterCol_totalExpr) ? filterCol_totalExpr : filterCol_total)
        : colKey == "net" ? (!string.IsNullOrWhiteSpace(filterCol_netExpr) ? filterCol_netExpr : filterCol_net)
        : colKey == "batch" ? filterCol_batch
        : colKey == "expiry" ? filterCol_expiry
        : null;

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };

    int totalCountForCards = total;
    int totalQtyForCards = ViewBag.TotalQty != null ? (int)ViewBag.TotalQty : 0;
    decimal totalDiscForCards = ViewBag.TotalDiscountValue != null ? (decimal)ViewBag.TotalDiscountValue : 0m;
    decimal totalAfterDiscForCards = ViewBag.TotalAfterDiscount != null ? (decimal)ViewBag.TotalAfterDiscount : 0m;
    decimal totalNetForCards = ViewBag.TotalNet != null ? (decimal)ViewBag.TotalNet : 0m;
    int categoriesCountForCards = ViewBag.CategoriesCount != null ? (int)ViewBag.CategoriesCount : 0;
    var returnQtyByLine = ViewBag.ReturnQtyByLine as IReadOnlyDictionary<string, int> ?? new Dictionary<string, int>();
    var finalNetByLine = ViewBag.FinalNetByLine as IReadOnlyDictionary<string, decimal> ?? new Dictionary<string, decimal>();
    int totalReturnQtyForPage = 0;
    decimal totalFinalNetForPage = 0m;
    foreach (var line in Model.Items)
    {
        var key = $"{line.SIId}:{line.LineNo}:{line.ProdId}";
        totalReturnQtyForPage += returnQtyByLine.TryGetValue(key, out var rq) ? rq : 0;
        totalFinalNetForPage += finalNetByLine.TryGetValue(key, out var fn) ? fn : line.LineNetTotal;
    }
    var n2 = System.Globalization.CultureInfo.InvariantCulture;
}

<div dir="rtl" class="container-fluid erp-sil-index">

    <style>
        /* كروت إجماليات أصناف المبيعات — حدود خفيفة موحّدة، أرقام بلون يتماشى مع الإطار (رفيع) */
        .erp-sil-index .erp-sil-summary-stat {
            border: 1px solid #d4dcfa !important;
            border-radius: 10px !important;
            box-shadow: 0 1px 2px rgba(99, 102, 241, 0.06) !important;
            background: #fff !important;
            overflow: hidden;
        }
        .erp-sil-index .erp-sil-summary-stat .card-body { text-align: right; }
        .erp-sil-index .erp-sil-summary-stat .erp-sil-summary-label {
            color: #64748b !important;
            font-size: 0.8rem;
            margin-bottom: 0.35rem !important;
        }
        .erp-sil-index .erp-sil-summary-stat .erp-sil-summary-value {
            font-size: 1.35rem;
            font-weight: 700;
            line-height: 1.2;
            color: #4f46e5;
            letter-spacing: -0.02em;
        }
        .erp-sil-index .erp-sil-summary-stat.erp-sil-summary-stat--net .erp-sil-summary-value {
            color: #15803d;
        }
    </style>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0 fs-6 text-secondary">@ViewData["Title"]</h5>
    </div>

    @* ===== شريط الفلاتر الموحد (مثل قائمة فواتير المبيعات) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get"
                      action="@Url.Action(action, controller)"
                      class="erp-list-search-form d-flex flex-column align-items-center w-100">

                    <label class="form-label w-100 text-center">بحث في أصناف المبيعات</label>

                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <select name="searchMode"
                                class="form-select form-select-arrow erp-filter-input flex-shrink-0"
                                style="max-width:110px;min-width:100px">
                            <option value="starts"   @Html.Raw(searchMode == "starts" ? " selected" : "")>يبدأ بـ</option>
                            <option value="contains" @Html.Raw(searchMode == "contains" ? " selected" : "")>يحتوي</option>
                            <option value="ends"     @Html.Raw(searchMode == "ends" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                        <input type="text"
                               name="search"
                               class="form-control erp-filter-input"
                               placeholder="اكتب نص البحث..."
                               value="@search" />

                        <select name="searchBy"
                                class="form-select form-select-arrow erp-filter-input"
                                style="max-width:180px;min-width:140px">
                            <option value="all"          @Html.Raw(searchBy == "all" ? " selected" : "")>الكل</option>
                            <option value="id"           @Html.Raw(searchBy == "id" ? " selected" : "")>رقم الفاتورة</option>
                            <option value="line"         @Html.Raw(searchBy == "line" ? " selected" : "")>رقم السطر</option>
                            <option value="prod"         @Html.Raw(searchBy == "prod" ? " selected" : "")>كود الصنف</option>
                            <option value="prodname"     @Html.Raw(searchBy == "prodname" ? " selected" : "")>اسم الصنف</option>
                            <option value="customername" @Html.Raw(searchBy == "customername" ? " selected" : "")>اسم العميل</option>
                            <option value="qty"          @Html.Raw(searchBy == "qty" ? " selected" : "")>الكمية</option>
                            <option value="batch"        @Html.Raw(searchBy == "batch" ? " selected" : "")>التشغيلة</option>
                            <option value="notes"        @Html.Raw(searchBy == "notes" ? " selected" : "")>الملاحظات</option>
                        </select>

                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3 flex-shrink-0">
                            عرض
                        </button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none flex-shrink-0"
                           href="@Url.Action(action, controller)">
                            إلغاء
                        </a>
                    </div>

                    @* الحفاظ على باقي الفلاتر *@
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                    @if (siIdFilter.HasValue) { <input type="hidden" name="siId" value="@siIdFilter.Value" /> }
                    @if (Model.FromDate.HasValue)
                    {
                        <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                    }
                    @if (Model.ToDate.HasValue)
                    {
                        <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                    }
                    @if (fromCode.HasValue)
                    {
                        <input type="hidden" name="fromCode" value="@fromCode" />
                    }
                    @if (toCode.HasValue)
                    {
                        <input type="hidden" name="toCode" value="@toCode" />
                    }
                    @if (!string.IsNullOrWhiteSpace(filterCol_siid)) { <input type="hidden" name="filterCol_siid" value="@filterCol_siid" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_siidExpr)) { <input type="hidden" name="filterCol_siidExpr" value="@filterCol_siidExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_lineno)) { <input type="hidden" name="filterCol_lineno" value="@filterCol_lineno" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_linenoExpr)) { <input type="hidden" name="filterCol_linenoExpr" value="@filterCol_linenoExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prodid)) { <input type="hidden" name="filterCol_prodid" value="@filterCol_prodid" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prodidExpr)) { <input type="hidden" name="filterCol_prodidExpr" value="@filterCol_prodidExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prodname)) { <input type="hidden" name="filterCol_prodname" value="@filterCol_prodname" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_customername)) { <input type="hidden" name="filterCol_customername" value="@filterCol_customername" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qty)) { <input type="hidden" name="filterCol_qty" value="@filterCol_qty" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyExpr)) { <input type="hidden" name="filterCol_qtyExpr" value="@filterCol_qtyExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_price)) { <input type="hidden" name="filterCol_price" value="@filterCol_price" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_priceExpr)) { <input type="hidden" name="filterCol_priceExpr" value="@filterCol_priceExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_disc1)) { <input type="hidden" name="filterCol_disc1" value="@filterCol_disc1" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_disc1Expr)) { <input type="hidden" name="filterCol_disc1Expr" value="@filterCol_disc1Expr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_disc2)) { <input type="hidden" name="filterCol_disc2" value="@filterCol_disc2" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_disc2Expr)) { <input type="hidden" name="filterCol_disc2Expr" value="@filterCol_disc2Expr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_disc3)) { <input type="hidden" name="filterCol_disc3" value="@filterCol_disc3" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_disc3Expr)) { <input type="hidden" name="filterCol_disc3Expr" value="@filterCol_disc3Expr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_discval)) { <input type="hidden" name="filterCol_discval" value="@filterCol_discval" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_discvalExpr)) { <input type="hidden" name="filterCol_discvalExpr" value="@filterCol_discvalExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_total)) { <input type="hidden" name="filterCol_total" value="@filterCol_total" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_totalExpr)) { <input type="hidden" name="filterCol_totalExpr" value="@filterCol_totalExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_net)) { <input type="hidden" name="filterCol_net" value="@filterCol_net" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_netExpr)) { <input type="hidden" name="filterCol_netExpr" value="@filterCol_netExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_batch)) { <input type="hidden" name="filterCol_batch" value="@filterCol_batch" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_expiry)) { <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_region)) { <input type="hidden" name="filterCol_region" value="@filterCol_region" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_createdby)) { <input type="hidden" name="filterCol_createdby" value="@filterCol_createdby" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر رقم من/إلى --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر رقم الفاتورة</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput"
                           type="number"
                           class="form-control erp-filter-input"
                           placeholder="من"
                           value="@(fromCode?.ToString() ?? "")" />

                    <input id="codeToInput"
                           type="number"
                           class="form-control erp-filter-input"
                           placeholder="إلى"
                           value="@(toCode?.ToString() ?? "")" />

                    <button type="button"
                            id="btnApplyCodeFilter"
                            class="btn btn-erp btn-erp-primary btn-erp-sm">
                        تطبيق
                    </button>

                    <button type="button"
                            id="btnClearCodeFilter"
                            class="btn btn-erp btn-erp-secondary btn-erp-sm">
                        مسح
                    </button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم — نفس هيكل قائمة فواتير المبيعات: صف أوامر + صف تصدير --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalSILines">اختيار الأعمدة</button>
                        <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <span class="erp-list-toolbar-selected-actions erp-list-toolbar-selected-actions--plain d-inline-flex flex-wrap gap-2 align-items-center" role="group" aria-label="إجراءات السطر المحدد">
                            <button type="button" id="btnShowSILine" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="عرض الفاتورة">عرض</button>
                        </span>
                    </div>
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center" dir="rtl">
                        <div class="d-inline-flex flex-wrap gap-2 align-items-center" dir="rtl">
                        <button type="button" id="btnMovementSILine" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="حركة الصنف">حركة الصنف</button>
                        <form method="get" asp-action="Export" asp-controller="SalesInvoiceLines" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form" dir="rtl">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="searchMode" value="@searchMode" />
                            <input type="hidden" name="visibleCols" value="" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            @if (siIdFilter.HasValue) { <input type="hidden" name="siId" value="@siIdFilter.Value" /> }
                            <input type="hidden" name="dateField" value="@dateField" />
                            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                            @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
                            @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_siid)) { <input type="hidden" name="filterCol_siid" value="@filterCol_siid" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_siidExpr)) { <input type="hidden" name="filterCol_siidExpr" value="@filterCol_siidExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_lineno)) { <input type="hidden" name="filterCol_lineno" value="@filterCol_lineno" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_linenoExpr)) { <input type="hidden" name="filterCol_linenoExpr" value="@filterCol_linenoExpr" /> }
