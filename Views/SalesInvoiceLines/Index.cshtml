    @* ===== جدول أصناف المبيعات ===== *@
    <div class="erp-print-area">
        <h5 class="mb-2 print-only fs-6 text-secondary">@ViewData["Title"]</h5>
        <div class="erp-list-table-frame erp-table-scroll-container erp-list-table-after-summary ps-0 pe-0">
        <div id="silTableScrollWrapper" class="erp-table-wrapper" style="position: relative; max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="silTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; font-weight: 600;">
                <tr>
                    <th data-col="siid">@filterableCol("siid", "SIId", "رقم الفاتورة")</th>
                    <th data-col="lineno">@filterableCol("lineno", "LineNo", "رقم السطر")</th>
                    <th data-col="prodid">@filterableCol("prodid", "ProdId", "كود الصنف")</th>
                    <th data-col="prodname">@filterableCol("prodname", "ProdName", "اسم الصنف")</th>
                    <th data-col="customername">@filterableCol("customername", "CustomerName", "اسم العميل")</th>
                    <th data-col="region">@filterableCol("region", "Region", "المنطقة")</th>
                    <th data-col="createdby">@filterableCol("createdby", "CreatedBy", "الكاتب")</th>
                    <th data-col="qty">@filterableCol("qty", "Qty", "الكمية")</th>
                    <th data-col="price">@filterableCol("price", "Price", "سعر الجمهور")</th>
                    <th data-col="disc1">@filterableCol("disc1", "Disc1", "الخصم")</th>
                    <th data-col="disc2">@filterableCol("disc2", "Disc2", "خصم 2 %")</th>
                    <th data-col="disc3">@filterableCol("disc3", "Disc3", "خصم 3 %")</th>
                    <th data-col="discval">@filterableCol("discval", "DiscVal", "قيمة الخصم")</th>
                    <th data-col="total">@filterableCol("total", "Total", "الإجمالي بعد الخصم")</th>
                    <th data-col="net">@filterableCol("net", "Net", "الصافي بعد الضريبة")</th>
                    <th data-col="itemReturnQty">مرتجع الصنف</th>
                    <th data-col="finalNetAfterAll">الصافي النهائي بعد كل حاجة</th>
                    <th data-col="batch">@filterableCol("batch", "Batch", "التشغيلة")</th>
                    <th data-col="expiry">@filterableCol("expiry", "Expiry", "الصلاحية")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="19" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var x in Model.Items)
                    {
                        var showUrl = Url.Action("Show", "SalesInvoices", new { id = x.SIId }) + "?frame=1";
                        var movementUrl = Url.Action("Show", "Products", new { id = x.ProdId }) + "?frame=1";
                        var rowId = x.SIId + "_" + x.LineNo;
                        var returnKey = $"{x.SIId}:{x.LineNo}:{x.ProdId}";
                        var returnedQty = returnQtyByLine.TryGetValue(returnKey, out var rq) ? rq : 0;
                        var finalNetAfterAll = finalNetByLine.TryGetValue(returnKey, out var fn) ? fn : x.LineNetTotal;
                        var regionDisplay = x.SalesInvoice?.Customer == null
                            ? ""
                            : (!string.IsNullOrWhiteSpace(x.SalesInvoice.Customer.RegionName)
                                ? x.SalesInvoice.Customer.RegionName
                                : (x.SalesInvoice.Customer.Area != null && x.SalesInvoice.Customer.Area.AreaName != null
                                    ? x.SalesInvoice.Customer.Area.AreaName
                                    : ""));
                        <tr class="erp-list-selectable-row" data-row-id="@rowId" data-si-id="@x.SIId" data-line-no="@x.LineNo" data-prod-id="@x.ProdId" data-show-url="@showUrl" data-movement-url="@movementUrl" data-tab-title="فاتورة مبيعات">
                            <td data-col="siid">@x.SIId</td>
                            <td data-col="lineno">@x.LineNo</td>
                            <td data-col="prodid">@x.ProdId</td>
                            <td data-col="prodname">@(x.Product?.ProdName ?? "-")</td>
                            <td data-col="customername">@(x.SalesInvoice?.Customer?.CustomerName ?? "-")</td>
                            <td data-col="region">@regionDisplay</td>
                            <td data-col="createdby">@(x.SalesInvoice?.CreatedBy ?? "")</td>
                            <td data-col="qty">@x.Qty</td>
                            <td data-col="price">@x.PriceRetail.ToString("0.00")</td>

                            <td data-col="disc1">@x.Disc1Percent.ToString("0.##")</td>
                            <td data-col="disc2">@x.Disc2Percent.ToString("0.##")</td>
                            <td data-col="disc3">@x.Disc3Percent.ToString("0.##")</td>

                            <td data-col="discval">@x.DiscountValue.ToString("0.00")</td>
                            <td data-col="total">@x.LineTotalAfterDiscount.ToString("0.00")</td>
                            <td data-col="net">@x.LineNetTotal.ToString("0.00")</td>
                            <td data-col="itemReturnQty">@returnedQty</td>
                            <td data-col="finalNetAfterAll">@finalNetAfterAll.ToString("0.00")</td>

                            <td data-col="batch">@(x.BatchNo ?? "-")</td>
                            <td data-col="expiry">
                                @(x.Expiry.HasValue ? x.Expiry.Value.ToString("yyyy-MM") : "-")
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="table-light">
                <tr class="fw-bold">
                    <td data-col="siid" class="text-muted">إجمالي</td>
                    <td data-col="lineno"></td>
                    <td data-col="prodid"></td>
                    <td data-col="prodname"></td>
                    <td data-col="customername"></td>
                    <td data-col="region"></td>
                    <td data-col="createdby"></td>
                    <td data-col="qty">@((ViewBag.TotalQty != null ? (int)ViewBag.TotalQty : 0))</td>
                    <td data-col="price"></td>
                    <td data-col="disc1"></td>
                    <td data-col="disc2"></td>
                    <td data-col="disc3"></td>
                    <td data-col="discval">@((ViewBag.TotalDiscountValue != null ? (decimal)ViewBag.TotalDiscountValue : 0m).ToString("0.00"))</td>
                    <td data-col="total">@((ViewBag.TotalAfterDiscount != null ? (decimal)ViewBag.TotalAfterDiscount : 0m).ToString("0.00"))</td>
                    <td data-col="net">@((ViewBag.TotalNet != null ? (decimal)ViewBag.TotalNet : 0m).ToString("0.00"))</td>
                    <td data-col="itemReturnQty">@totalReturnQtyForPage</td>
                    <td data-col="finalNetAfterAll">@totalFinalNetForPage.ToString("0.00")</td>
                    <td data-col="batch"></td>
                    <td data-col="expiry"></td>
                </tr>
            </tfoot>
        </table>
        </div>
        </div>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة (مثل قائمة فواتير المبيعات) ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print" dir="rtl">
        <small class="text-muted text-start">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="searchMode" value="@searchMode" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            @if (siIdFilter.HasValue) { <input type="hidden" name="siId" value="@siIdFilter.Value" /> }
            @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
            @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }

            <input type="hidden" name="filterCol_siid" value="@filterCol_siid" />
            <input type="hidden" name="filterCol_siidExpr" value="@filterCol_siidExpr" />
            <input type="hidden" name="filterCol_lineno" value="@filterCol_lineno" />
            <input type="hidden" name="filterCol_linenoExpr" value="@filterCol_linenoExpr" />
            <input type="hidden" name="filterCol_prodid" value="@filterCol_prodid" />
            <input type="hidden" name="filterCol_prodidExpr" value="@filterCol_prodidExpr" />
            <input type="hidden" name="filterCol_prodname" value="@filterCol_prodname" />
            <input type="hidden" name="filterCol_customername" value="@filterCol_customername" />
            <input type="hidden" name="filterCol_region" value="@filterCol_region" />
            <input type="hidden" name="filterCol_createdby" value="@filterCol_createdby" />
            <input type="hidden" name="filterCol_qty" value="@filterCol_qty" />
            <input type="hidden" name="filterCol_qtyExpr" value="@filterCol_qtyExpr" />
            <input type="hidden" name="filterCol_price" value="@filterCol_price" />
            <input type="hidden" name="filterCol_priceExpr" value="@filterCol_priceExpr" />
            <input type="hidden" name="filterCol_disc1" value="@filterCol_disc1" />
            <input type="hidden" name="filterCol_disc1Expr" value="@filterCol_disc1Expr" />
            <input type="hidden" name="filterCol_disc2" value="@filterCol_disc2" />
            <input type="hidden" name="filterCol_disc2Expr" value="@filterCol_disc2Expr" />
            <input type="hidden" name="filterCol_disc3" value="@filterCol_disc3" />
            <input type="hidden" name="filterCol_disc3Expr" value="@filterCol_disc3Expr" />
            <input type="hidden" name="filterCol_discval" value="@filterCol_discval" />
            <input type="hidden" name="filterCol_discvalExpr" value="@filterCol_discvalExpr" />
            <input type="hidden" name="filterCol_total" value="@filterCol_total" />
            <input type="hidden" name="filterCol_totalExpr" value="@filterCol_totalExpr" />
            <input type="hidden" name="filterCol_net" value="@filterCol_net" />
            <input type="hidden" name="filterCol_netExpr" value="@filterCol_netExpr" />
            <input type="hidden" name="filterCol_batch" value="@filterCol_batch" />
            <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" />

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
            </select>
        </form>
    </div>

    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

