@* Views/SalesInvoiceLines/Index.cshtml — قائمة أصناف المبيعات بنفس نموذج الفواتير *@
@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.SalesInvoiceLine>

@{
    ViewData["Title"] = "قائمة أصناف المبيعات";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "SalesInvoiceLines";

    // قيم البحث/الترتيب الحالية
    var searchRaw = Model.Search ?? (string?)ViewBag.Search ?? "";
    
    // تنظيف search من أسماء الأعمدة المعروفة
    var columnNames = new[] { "siid", "line", "lineno", "prodid", "prodname", "customername",
        "qty", "price", "unit", "total", "net", "disc1", "disc2", "disc3", "discval",
        "batch", "expiry", "رقم الفاتورة", "رقم السطر", "كود الصنف", "اسم الصنف",
        "اسم العميل", "الكمية", "سعر الجمهور", "التشغيلة", "الصلاحية" };
    
    var search = "";
    if (!string.IsNullOrWhiteSpace(searchRaw))
    {
        var searchLower = searchRaw.Trim().ToLowerInvariant();
        if (!columnNames.Contains(searchLower))
        {
            search = searchRaw.Trim();
        }
    }
    
    var searchBy = (string?)ViewBag.SearchBy ?? "all";          // all | si | prod | batch | notes
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "LineNo";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    // بيانات الترقيم
    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    // نطاق العرض السفلي
    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلتر كود من/إلى (هنا نستخدمه لفلترة رقم الفاتورة أو رقم السطر حسب ما هتضبطه في الكنترولر)
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    // حقل التاريخ المستخدم في فلترة التاريخ/الوقت (مثلاً تاريخ الصلاحية أو تاريخ الفاتورة)
    var dateField = (string?)ViewBag.DateField ?? "Expiry";

    // لو الصفحة مفتوحة على فاتورة معينة (اختياري)
    string siId = ViewBag.SIId as string
                  ?? (ViewContext?.HttpContext?.Request?.Query["siId"].ToString() ?? "");

    // دالة توليد لينكات الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField,
        fromCode,
        toCode,
        siId
    })!;

    // دالة إنشاء لينك الترتيب في رأس الجدول + أيقونة السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        // تنظيف search من أسماء الأعمدة المعروفة (منع ظهورها في حقل البحث)
        var cleanSearch = "";
        if (!string.IsNullOrWhiteSpace(search))
        {
            var searchLower = search.Trim().ToLowerInvariant();
            // قائمة أسماء الأعمدة المعروفة
            var columnNames = new[] { "siid", "line", "lineno", "prodid", "prodname", "customername", 
                "qty", "price", "unit", "total", "net", "disc1", "disc2", "disc3", "discval", 
                "batch", "expiry", "رقم الفاتورة", "رقم السطر", "كود الصنف", "اسم الصنف", 
                "اسم العميل", "الكمية", "سعر الجمهور", "التشغيلة", "الصلاحية" };
            
            // إذا كان search يحتوي على اسم عمود، نجعله فارغاً
            if (!columnNames.Contains(searchLower))
            {
                cleanSearch = search;
            }
        }

        var url = Url.Action(action, controller, new
        {
            search = cleanSearch,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange = Model.UseDateRange,
            fromDate = Model.FromDate,
            toDate = Model.ToDate,
            dateField,
            fromCode,
            toCode,
            siId
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"" class=""sort-link"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };
}

<div dir="rtl" class="container-fluid">

    @* ===== الكارت العلوي: بحث + فلتر رقم + أزرار التحكم ===== *@
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* العمود الأول: البحث *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث</label>
                        </div>

                        <div class="col-sm-4">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-4">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                @* الكل *@
                                <option value="all"
                                        selected="@(searchBy == "all" ? "selected" : null)">
                                    الكل
                                </option>

                                @* البحث برقم الفاتورة *@
                                <option value="id"
                                        selected="@(searchBy == "id" ? "selected" : null)">
                                    رقم الفاتورة
                                </option>
                                <option value="si"
                                        selected="@(searchBy == "si" ? "selected" : null)">
                                    رقم الفاتورة
                                </option>

                                @* البحث برقم السطر *@
                                <option value="line"
                                        selected="@(searchBy == "line" ? "selected" : null)">
                                    رقم السطر
                                </option>

                                @* البحث بكود الصنف *@
                                <option value="prod"
                                        selected="@(searchBy == "prod" ? "selected" : null)">
                                    كود الصنف
                                </option>

                                @* البحث باسم الصنف *@
                                <option value="prodname"
                                        selected="@(searchBy == "prodname" ? "selected" : null)">
                                    اسم الصنف
                                </option>

                                @* البحث باسم العميل *@
                                <option value="customername"
                                        selected="@(searchBy == "customername" ? "selected" : null)">
                                    اسم العميل
                                </option>

                                @* البحث بالكمية *@
                                <option value="qty"
                                        selected="@(searchBy == "qty" ? "selected" : null)">
                                    الكمية
                                </option>

                                @* البحث بالتشغيلة *@
                                <option value="batch"
                                        selected="@(searchBy == "batch" ? "selected" : null)">
                                    التشغيلة
                                </option>

                                @* البحث بالملاحظات *@
                                <option value="notes"
                                        selected="@(searchBy == "notes" ? "selected" : null)">
                                    الملاحظات
                                </option>
                            </select>
                        </div>

                        @* الحفاظ على باقي الفلاتر *@
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="dateField" value="@dateField" />
                        <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                        <input type="hidden" name="siId" value="@siId" />
                        @if (Model.FromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                        }
                        @if (Model.ToDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                        }
                        @if (fromCode.HasValue)
                        {
                            <input type="hidden" name="fromCode" value="@fromCode" />
                        }
                        @if (toCode.HasValue)
                        {
                            <input type="hidden" name="toCode" value="@toCode" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">
                                بحث
                            </button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm"
                               href="@Url.Action(action, controller)">
                                إلغاء
                            </a>
                        </div>
                    </form>
                </div>

                @* العمود الثاني: فلتر رقم من/إلى (رقم فاتورة أو رقم سطر حسب ما تضبطه في الكنترولر) *@
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-semibold">من رقم</span>
                        <input id="codeFromInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(ViewBag.CodeFrom?.ToString() ?? "")" />

                        <span class="fw-semibold">إلى رقم</span>
                        <input id="codeToInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(ViewBag.CodeTo?.ToString() ?? "")" />

                        <button type="button"
                                id="btnApplyCodeFilter"
                                class="btn btn-erp btn-erp-primary btn-erp-sm">
                            تطبيق فلتر الرقم
                        </button>

                        <button type="button"
                                id="btnClearCodeFilter"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            مسح
                        </button>
                    </div>
                </div>

                @* العمود الثالث: أزرار الفلاتر / الطباعة / التصدير (بدون زر إضافة) *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        @* فلترة بالتاريخ/الوقت *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#dateFilterModal">
                            فلترة بالتاريخ/الوقت
                        </button>

                        @* اختيار الأعمدة *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalSILines">
                            اختيار الأعمدة
                        </button>

                        @* طباعة (الجدول فقط) *@
                        <button type="button"
                                id="btnPrint"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        @* تصدير *@
                        <form method="get"
                              asp-action="Export"
                              asp-controller="SalesInvoiceLines"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="siId" value="@siId" />
                            <input type="hidden" name="dateField" value="@dateField" />
                            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                            @if (Model.FromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                            }
                            @if (Model.ToDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                            }
                            @if (ViewBag.CodeFrom != null)
                            {
                                <input type="hidden" name="codeFrom" value="@ViewBag.CodeFrom" />
                            }
                            @if (ViewBag.CodeTo != null)
                            {
                                <input type="hidden" name="codeTo" value="@ViewBag.CodeTo" />
                            }

                            <select name="format"
                                    class="form-select form-select-sm"
                                    style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm">
                                تصدير
                            </button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

    @* لو الشاشة مفتوحة على فاتورة معينة نعرض شارة *@
    @if (!string.IsNullOrWhiteSpace(siId))
    {
        <div class="alert alert-secondary py-2">
            عرض سطور الفاتورة رقم: <strong>@siId</strong>
        </div>
    }

    @* ===== جدول أصناف المبيعات (هو الوحيد اللي يتطبع) ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="silTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    @* زر العرض - تم نقله إلى اليسار *@
                    <th class="text-nowrap no-print"
                        data-col="actions"
                        data-col-fixed="true"
                        style="width:100px;">عرض</th>

                    <th data-col="siId">@sortLink("SIId", "رقم الفاتورة")</th>
                    <th data-col="lineNo">@sortLink("LineNo", "رقم السطر")</th>
                    <th data-col="prodId">@sortLink("ProdId", "كود الصنف")</th>
                    <th data-col="prodName">@sortLink("ProdName", "اسم الصنف")</th>
                    <th data-col="customerName">@sortLink("CustomerName", "اسم العميل")</th>
                    <th data-col="qty">@sortLink("Qty", "الكمية")</th>
                    <th data-col="price">@sortLink("Price", "سعر الجمهور")</th>
                    <th data-col="disc1">@sortLink("Disc1", "خصم 1 %")</th>
                    <th data-col="disc2">@sortLink("Disc2", "خصم 2 %")</th>
                    <th data-col="disc3">@sortLink("Disc3", "خصم 3 %")</th>
                    <th data-col="discVal">@sortLink("DiscVal", "خصم (قيمة)")</th>
                    <th data-col="totalAfterDisc">@sortLink("Total", "الإجمالي بعد الخصم")</th>
                    <th data-col="net">@sortLink("Net", "الصافي بعد الضريبة")</th>
                    <th data-col="batch">@sortLink("Batch", "التشغيلة")</th>
                    <th data-col="expiry">@sortLink("Expiry", "الصلاحية")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="16" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var x in Model.Items)
                    {
                        <tr>
                            @* زر عرض السطر - تم نقله إلى اليسار وتغيير اسمه *@
                            <td class="text-nowrap no-print" data-col="actions">
                                <a class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                   asp-action="Details"
                                   asp-route-siId="@x.SIId"
                                   asp-route-lineNo="@x.LineNo">
                                    عرض
                                </a>
                            </td>

                            <td data-col="siId">@x.SIId</td>
                            <td data-col="lineNo">@x.LineNo</td>
                            <td data-col="prodId">@x.ProdId</td>
                            <td data-col="prodName">@(x.Product?.ProdName ?? "-")</td>
                            <td data-col="customerName">@(x.SalesInvoice?.Customer?.CustomerName ?? "-")</td>
                            <td data-col="qty">@x.Qty</td>
                            <td data-col="price">@x.PriceRetail.ToString("0.00")</td>

                            <td data-col="disc1">@x.Disc1Percent.ToString("0.##")</td>
                            <td data-col="disc2">@x.Disc2Percent.ToString("0.##")</td>
                            <td data-col="disc3">@x.Disc3Percent.ToString("0.##")</td>

                            <td data-col="discVal">@x.DiscountValue.ToString("0.00")</td>
                            <td data-col="totalAfterDisc">@x.LineTotalAfterDiscount.ToString("0.00")</td>
                            <td data-col="net">@x.LineNetTotal.ToString("0.00")</td>

                            <td data-col="batch">@(x.BatchNo ?? "-")</td>
                            <td data-col="expiry">
                                @(x.Expiry.HasValue ? x.Expiry.Value.ToString("yyyy-MM") : "-")
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="table-light">
                <tr class="fw-bold">
                    @* الأكشن *@
                    <td class="text-nowrap no-print" data-col="actions"></td>

                    @* رقم الفاتورة *@
                    <td data-col="siId" class="text-muted">إجمالي</td>

                    @* رقم السطر *@
                    <td data-col="lineNo"></td>

                    @* كود الصنف *@
                    <td data-col="prodId"></td>

                    @* اسم الصنف *@
                    <td data-col="prodName"></td>

                    @* اسم العميل *@
                    <td data-col="customerName"></td>

                    @* ✅ الكمية *@
                    <td data-col="qty">@((ViewBag.TotalQty != null ? (int)ViewBag.TotalQty : 0))</td>

                    @* سعر الجمهور *@
                    <td data-col="price"></td>

                    @* خصم 1% *@
                    <td data-col="disc1"></td>

                    @* خصم 2% *@
                    <td data-col="disc2"></td>

                    @* خصم 3% *@
                    <td data-col="disc3"></td>

                    @* ✅ خصم (قيمة) *@
                    <td data-col="discVal">@((ViewBag.TotalDiscountValue != null ? (decimal)ViewBag.TotalDiscountValue : 0m).ToString("0.00"))</td>

                    @* ✅ الإجمالي بعد الخصم *@
                    <td data-col="totalAfterDisc">@((ViewBag.TotalAfterDiscount != null ? (decimal)ViewBag.TotalAfterDiscount : 0m).ToString("0.00"))</td>

                    @* ✅ الصافي بعد الضريبة *@
                    <td data-col="net">@((ViewBag.TotalNet != null ? (decimal)ViewBag.TotalNet : 0m).ToString("0.00"))</td>

                    @* التشغيلة *@
                    <td data-col="batch"></td>

                    @* الصلاحية *@
                    <td data-col="expiry"></td>
                </tr>
            </tfoot>
        </table>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            <input type="hidden" name="siId" value="@siId" />
            @if (Model.FromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
            }
            @if (Model.ToDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25" selected="@(ps == 25 ? "selected" : null)">25</option>
                <option value="50" selected="@(ps == 50 ? "selected" : null)">50</option>
                <option value="100" selected="@(ps == 100 ? "selected" : null)">100</option>
                <option value="200" selected="@(ps == 200 ? "selected" : null)">200</option>
            </select>
        </form>
    </div>

    <div>
        <small class="text-muted d-none d-md-inline">
            إجمالي السطور: @total
        </small>
    </div>

    @* ===== الترقيم (Pagination) بنفس شكل الفواتير/المحافظات ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة التاريخ/الوقت ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بالتاريخ والوقت (مثلاً تاريخ الصلاحية)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="siId" value="@siId" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(Model.UseDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="columnsModalSILines"
     tabindex="-1"
     aria-labelledby="columnsModalSILinesLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalSILinesLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListSILines"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsSILines"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط
        // =========================
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("silTable");
            if (!table) return;

            const storageKey = "sil-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListSILines");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsSILines")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalSILines");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر الكود من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();

        // =========================
        // منع النقر على روابط الترتيب من التأثير على حقل البحث
        // =========================
        (function () {
            const searchInput = document.querySelector('input[name="search"]');
            if (!searchInput) return;

            // قائمة أسماء الأعمدة المعروفة (لتنظيف حقل البحث)
            const columnNames = ['siid', 'line', 'lineno', 'prodid', 'prodname', 'customername',
                'qty', 'price', 'unit', 'total', 'net', 'disc1', 'disc2', 'disc3', 'discval',
                'batch', 'expiry', 'رقم الفاتورة', 'رقم السطر', 'كود الصنف', 'اسم الصنف',
                'اسم العميل', 'الكمية', 'سعر الجمهور', 'التشغيلة', 'الصلاحية'];

            // دالة للتحقق من أن القيمة ليست اسم عمود
            function isColumnName(value) {
                if (!value) return false;
                const valueLower = value.trim().toLowerCase();
                return columnNames.some(col => valueLower === col || valueLower.includes(col));
            }

            // منع أي JavaScript من وضع قيمة في حقل البحث عند النقر على روابط الترتيب
            document.addEventListener('click', function (e) {
                const sortLink = e.target.closest('a.sort-link, a[href*="sort="]');
                if (sortLink) {
                    // حفظ القيمة الحالية
                    const currentValue = searchInput.value;
                    
                    // منع أي تغيير في حقل البحث عند النقر على رابط الترتيب
                    setTimeout(function() {
                        // التحقق من القيمة من URL
                        const urlParams = new URLSearchParams(window.location.search);
                        const searchParam = urlParams.get('search') || '';
                        
                        // إذا كانت القيمة من URL هي اسم عمود، نجعله فارغاً
                        if (isColumnName(searchParam)) {
                            searchInput.value = '';
                        } else if (searchInput.value !== currentValue && isColumnName(searchInput.value)) {
                            // إذا تغيرت القيمة وأصبحت اسم عمود، نعيد القيمة السابقة
                            searchInput.value = currentValue || '';
                        } else if (searchInput.value !== searchParam && searchParam) {
                            // إذا كانت القيمة من URL صحيحة، نستخدمها
                            if (!isColumnName(searchParam)) {
                                searchInput.value = searchParam;
                            }
                        }
                    }, 50);
                }
            });

            // تنظيف حقل البحث عند تحميل الصفحة إذا كان يحتوي على اسم عمود
            window.addEventListener('load', function() {
                const urlParams = new URLSearchParams(window.location.search);
                const searchParam = urlParams.get('search') || '';
                if (isColumnName(searchParam)) {
                    searchInput.value = '';
                }
            });
        })();
    </script>
}
