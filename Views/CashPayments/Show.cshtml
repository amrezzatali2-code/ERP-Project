@model ERP.Models.CashPayment

@{
    ViewData["Title"] = "إذن دفع نقدية";
}

<div class="container mt-3" dir="rtl">
    <div class="card" style="max-width: 700px; margin:auto;">
        <div class="card-header text-center">
            <h4 class="mb-0">إذن دفع نقدية</h4>
        </div>
        <div class="card-body">
            <div class="d-flex justify-content-between mb-3">
                <div>
                    <strong>رقم الإذن:</strong> @Model.CashPaymentId<br />
                    <strong>التاريخ:</strong> @Model.PaymentDate.ToString("yyyy-MM-dd")
                </div>
                <div class="text-end">
                    <strong>الطرف:</strong> @Model.Customer?.CustomerName<br />
                    <strong>المبلغ:</strong> @Model.Amount.ToString("N2")
                </div>
            </div>

            <hr />

            <p><strong>تم صرف مبلغ وقدره:</strong> @Model.Amount.ToString("N2")</p>
            <p><strong>للسيد/السيدة:</strong> @Model.Customer?.CustomerName</p>
            <p>
                <strong>حساب الصندوق/البنك:</strong>
                @if (Model.CashAccount != null)
                {
                    @($"{Model.CashAccount.AccountCode} - {Model.CashAccount.AccountName}")
                }
            </p>
            <p><strong>بيان:</strong> @Model.Description</p>

            <hr />

            <div class="row mt-4">
                <div class="col text-center">
                    <strong>المستلم</strong>
                    <div style="height:60px;border-bottom:1px dashed #999;"></div>
                </div>
                <div class="col text-center">
                    <strong>المراجع</strong>
                    <div style="height:60px;border-bottom:1px dashed #999;"></div>
                </div>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary btn-sm">عودة للقائمة</a>
            <button type="button" class="btn btn-outline-primary btn-sm" onclick="window.print();">طباعة</button>
        </div>
    </div>
</div>
