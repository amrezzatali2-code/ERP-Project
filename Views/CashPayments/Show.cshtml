@model ERP.Models.CashPayment

@{
    ViewData["Title"] = "إيصال دفع نقدية";
}

<style>
    .cp-print-page {
        max-width: 980px;
        margin: 1rem auto;
        border: 2px solid #5b8def;
        border-radius: 14px;
        box-shadow: 0 10px 26px rgba(37, 99, 235, .12);
        background: #fff;
        overflow: hidden;
    }
    .cp-print-head {
        background: linear-gradient(135deg, #f8fbff 0%, #edf5ff 100%);
        border-bottom: 1px solid #dbe3ef;
        padding: 1rem 1.25rem;
    }
    .cp-print-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }
    .cp-print-sub {
        font-size: .88rem;
        color: #475569;
        margin-top: .25rem;
    }
    .cp-print-body { padding: 1.2rem 1.4rem; }
    .cp-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .7rem .9rem;
    }
    .cp-box {
        border: 1.5px solid #c7d8f7;
        border-radius: 10px;
        padding: .7rem .85rem;
        background: #f8fafc;
    }
    .cp-label {
        color: #64748b;
        font-size: .8rem;
        margin-bottom: .15rem;
        display: block;
    }
    .cp-value {
        color: #0f172a;
        font-weight: 600;
        font-size: 1.05rem;
    }
    .cp-note {
        margin-top: .9rem;
        border: 1px solid #dbe3ef;
        border-radius: 10px;
        padding: .7rem;
        min-height: 56px;
        background: #fff;
        color: #0f172a;
    }
    .cp-signs {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }
    .cp-sign {
        border-top: 1px dashed #94a3b8;
        text-align: center;
        padding-top: .35rem;
        color: #334155;
        min-height: 48px;
    }

    @@media print {
        body * { visibility: hidden !important; }
        #paymentPrintArea, #paymentPrintArea * { visibility: visible !important; }
        #paymentPrintArea {
            position: fixed;
            inset: 0;
            margin: 0 !important;
            max-width: none !important;
            border: 2px solid #5b8def !important;
            border-radius: 0 !important;
            box-shadow: none !important;
            padding: 8mm 10mm;
            background: #fff !important;
        }
        .cp-no-print { display: none !important; }
    }
</style>

<div class="container mt-3" dir="rtl">
    <div id="paymentPrintArea" class="cp-print-page erp-print-area">
        <div class="cp-print-head">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h4 class="cp-print-title">إيصال دفع نقدية</h4>
                    <div class="cp-print-sub">ERP - سند صرف نقدي</div>
                </div>
                <div class="text-end small text-muted">@DateTime.Now.ToString("yyyy/MM/dd HH:mm")</div>
            </div>
        </div>

        <div class="cp-print-body">
            <div class="cp-grid">
                <div class="cp-box"><span class="cp-label">رقم الإذن</span><span class="cp-value">@Model.CashPaymentId</span></div>
                <div class="cp-box"><span class="cp-label">التاريخ</span><span class="cp-value">@Model.PaymentDate.ToString("yyyy-MM-dd")</span></div>
                <div class="cp-box"><span class="cp-label">العميل</span><span class="cp-value">@Model.Customer?.CustomerName</span></div>
                <div class="cp-box"><span class="cp-label">المبلغ</span><span class="cp-value">@Model.Amount.ToString("N2")</span></div>
            </div>

            <div class="cp-note mt-3">
                <span class="cp-label">البيان</span>
                @Model.Description
            </div>

            <div class="cp-signs">
                <div class="cp-sign">المستلم</div>
                <div class="cp-sign">المراجع</div>
            </div>
        </div>
    </div>

    <div class="mt-2 d-flex justify-content-between cp-no-print">
        <a class="btn btn-secondary btn-sm open-same-tab"
           href="@Url.Action("Index", "CashPayments", new { frame = 1 })"
           data-tab-id="cash-payments"
           data-tab-title="قائمة أذون دفع نقدية"
           data-url="@Url.Action("Index", "CashPayments", new { frame = 1 })">عودة للقائمة</a>
        <button type="button" class="btn btn-outline-primary btn-sm" onclick="window.print();">طباعة</button>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const autoPrint = new URLSearchParams(window.location.search).get('autoPrint') === '1';
            if (!autoPrint) return;

            const returnUrl = new URLSearchParams(window.location.search).get('returnUrl') || document.referrer || '/CashPayments';
            let printed = false;
            const finishAutoPrint = function () {
                setTimeout(function () {
                    try { window.close(); } catch (_) { }
                    if (!window.closed) {
                        window.location.replace(returnUrl);
                    }
                }, 120);
            };

            window.addEventListener('load', function () {
                setTimeout(function () { window.print(); }, 240);
            });

            window.addEventListener('afterprint', function () {
                printed = true;
                finishAutoPrint();
            }, { once: true });

            window.addEventListener('focus', function () {
                if (printed) finishAutoPrint();
            });
        })();
    </script>
}
