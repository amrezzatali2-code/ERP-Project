@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<CashPayment>

@{
    ViewData["Title"] = "إذون صرف النقدية";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "CashPayments";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "PaymentDate";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "desc");

    // بيانات الترقيم
    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلتر كود من/إلى (على CashPaymentId)
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    // فلتر التاريخ
    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;
    var dateField = (string?)ViewBag.DateField ?? "PaymentDate";

    // دالة توليد لينك الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        dateField,
        fromCode,
        toCode
    })!;

    // دالة إنشاء لينك الترتيب في رأس الجدول + أيقونة السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate,
            dateField,
            fromCode,
            toCode
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };
}

<div dir="rtl" class="container-fluid">

    @* ===== الكارت العلوي: بحث + فلتر كود من/إلى + أزرار التحكم ===== *@
    <div class="card mb-3 d-print-none mt-2">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* العمود الأول: البحث العام في إذون الدفع *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث في إذون الدفع</label>
                        </div>

                        <div class="col-sm-5">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-5">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                <option value="all"
                                        selected="@(searchBy == "all" ? "selected" : null)">
                                    البحث في الكل
                                </option>

                                <option value="number"
                                        selected="@(searchBy == "number" ? "selected" : null)">
                                    رقم المستند
                                </option>

                                <option value="id"
                                        selected="@(searchBy == "id" ? "selected" : null)">
                                    رقم الإذن
                                </option>

                                <option value="customer"
                                        selected="@(searchBy == "customer" ? "selected" : null)">
                                    اسم الطرف
                                </option>

                                <option value="cashAccount"
                                        selected="@(searchBy == "cashAccount" ? "selected" : null)">
                                    حساب الصندوق/البنك
                                </option>

                                <option value="counterAccount"
                                        selected="@(searchBy == "counterAccount" ? "selected" : null)">
                                    حساب الطرف
                                </option>

                                <option value="desc"
                                        selected="@(searchBy == "desc" ? "selected" : null)">
                                    البيان
                                </option>

                                <option value="posted"
                                        selected="@(searchBy == "posted" ? "selected" : null)">
                                    حالة الترحيل
                                </option>
                            </select>
                        </div>

                        @* الحفاظ على باقي الفلاتر *@
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="dateField" value="@dateField" />
                        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                        @if (fromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                        }
                        @if (toDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                        }
                        @if (fromCode.HasValue)
                        {
                            <input type="hidden" name="fromCode" value="@fromCode" />
                        }
                        @if (toCode.HasValue)
                        {
                            <input type="hidden" name="toCode" value="@toCode" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm px-3">
                                بحث
                            </button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm"
                               href="@Url.Action(action, controller)">
                                إلغاء
                            </a>
                        </div>
                    </form>
                </div>

                @* العمود الثاني: فلتر من كود / إلى كود (CashPaymentId) *@
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-semibold">من كود</span>
                        <input id="codeFromInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(fromCode?.ToString() ?? "")" />

                        <span class="fw-semibold">إلى كود</span>
                        <input id="codeToInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(toCode?.ToString() ?? "")" />

                        <button type="button"
                                id="btnApplyCodeFilter"
                                class="btn btn-erp btn-erp-primary btn-erp-sm">
                            تطبيق فلتر الكود
                        </button>

                        <button type="button"
                                id="btnClearCodeFilter"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            مسح
                        </button>
                    </div>
                </div>

                @* العمود الثالث: أزرار الحذف / الفلاتر / الطباعة / التصدير *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        @* زر إضافة إذن جديد *@
                        <a asp-action="Create"
                           asp-controller="CashPayments"
                           class="btn btn-erp btn-erp-primary btn-erp-sm">
                            إضافة إذن دفع
                        </a>

                        @* حذف الإذون المحددة (BulkDelete) *@
                        <form id="formBulkDelete"
                              asp-action="BulkDelete"
                              asp-controller="CashPayments"
                              method="post"
                              class="d-inline">
                            <button type="button"
                                    id="btnBulkDelete"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف المحدد
                            </button>
                        </form>

                        @* حذف جميع الإذون (DeleteAll) *@
                        <form id="formDeleteAll"
                              asp-action="DeleteAll"
                              asp-controller="CashPayments"
                              method="post"
                              class="d-inline">
                            <button type="submit"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm"
                                    onclick="return confirm('هل أنت متأكد من حذف جميع إذون الدفع؟ يُنصح باستخدام هذا الزر في بيئة تجريبية فقط.');">
                                حذف الكل
                            </button>
                        </form>

                        @* فلترة بالتاريخ/الوقت (تاريخ الإذن) *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#dateFilterModalCashPayments">
                            فلترة بالتاريخ/الوقت
                        </button>

                        @* اختيار الأعمدة *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalCashPayments">
                            اختيار الأعمدة
                        </button>

                        @* طباعة الجدول *@
                        <button type="button"
                                id="btnPrintCashPayments"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        @* تصدير (Export) — زر أخضر لون إكسل *@
                        <form method="get"
                              asp-action="Export"
                              asp-controller="CashPayments"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="dateField" value="@dateField" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                            }
                            @if (toDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                            }
                            @if (fromCode.HasValue)
                            {
                                <input type="hidden" name="fromCode" value="@fromCode" />
                            }
                            @if (toCode.HasValue)
                            {
                                <input type="hidden" name="toCode" value="@toCode" />
                            }

                            <select name="format"
                                    class="form-select form-select-sm"
                                    style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            @* زر التصدير: استخدمنا btn-success ليكون أخضر ثابت *@
                            <button type="submit"
                                    class="btn btn-erp btn-success btn-erp-sm">
                                تصدير
                            </button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

    @* ===== جدول إذون الدفع ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="cashPaymentsTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    <th class="text-center no-print"
                        data-col="actions"
                        data-col-fixed="true"
                        style="width:220px;">
                        <input type="checkbox"
                               id="selectAll"
                               class="form-check-input" />
                    </th>

                    <th data-col="id">@sortLink("CashPaymentId", "رقم الإذن")</th>
                    <th data-col="number">@sortLink("PaymentNumber", "رقم المستند")</th>
                    <th data-col="date">@sortLink("PaymentDate", "تاريخ الإذن")</th>
                    <th data-col="customer">@sortLink("CustomerName", "الطرف")</th>
                    <th data-col="cashAccount">@sortLink("CashAccountName", "حساب الصندوق/البنك")</th>
                    <th data-col="counterAccount">@sortLink("CounterAccountName", "حساب الطرف")</th>
                    <th data-col="amount">@sortLink("Amount", "المبلغ")</th>
                    <th data-col="posted">@sortLink("IsPosted", "مرحّل؟")</th>
                    <th data-col="created">@sortLink("CreatedAt", "تاريخ الإنشاء")</th>
                    <th data-col="updated">@sortLink("UpdatedAt", "آخر تعديل")</th>
                    <th data-col="desc">@sortLink("Description", "البيان")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="12" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var p in Model.Items)
                    {
                        var desc = p.Description ?? "";
                        var descShort = desc.Length > 80 ? desc.Substring(0, 80) + "…" : desc;

                        <tr>
                            <td class="text-nowrap no-print" data-col="actions">
                                @* تشيك بوكس لكل إذن للحذف الجماعي *@
                                <input type="checkbox"
                                       class="form-check-input ms-2 row-select"
                                       value="@p.CashPaymentId" />

                                @* أزرار CRUD *@
                                <a class="btn btn-erp btn-erp-secondary btn-erp-sm ms-1"
                                   asp-action="Details"
                                   asp-route-id="@p.CashPaymentId">
                                    عرض
                                </a>
                                <a class="btn btn-erp btn-erp-primary btn-erp-sm ms-1"
                                   asp-action="Edit"
                                   asp-route-id="@p.CashPaymentId">
                                    تعديل
                                </a>
                                <a class="btn btn-erp btn-erp-danger btn-erp-sm"
                                   asp-action="Delete"
                                   asp-route-id="@p.CashPaymentId">
                                    حذف
                                </a>
                            </td>

                            <td data-col="id">@p.CashPaymentId</td>
                            <td data-col="number">@p.PaymentNumber</td>
                            <td data-col="date">@p.PaymentDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td data-col="customer">
                                @(p.Customer?.CustomerName ?? "")
                            </td>
                            <td data-col="cashAccount">
                                @(p.CashAccount?.AccountName ?? "")
                            </td>
                            <td data-col="counterAccount">
                                @(p.CounterAccount?.AccountName ?? "")
                            </td>
                            <td data-col="amount">
                                @p.Amount.ToString("0.00")
                            </td>
                            <td data-col="posted">
                                @(p.IsPosted ? "مرحّل" : "مسودة")
                            </td>
                            <td data-col="created">
                                @p.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                            </td>
                            <td data-col="updated">
                                @(p.UpdatedAt.HasValue? p.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")
                            </td>
                            <td data-col="desc">
                                @descShort
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
            }
            @if (toDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25" selected="@(ps == 25 ? "selected" : null)">25</option>
                <option value="50" selected="@(ps == 50 ? "selected" : null)">50</option>
                <option value="100" selected="@(ps == 100 ? "selected" : null)">100</option>
                <option value="200" selected="@(ps == 200 ? "selected" : null)">200</option>
            </select>
        </form>
    </div>

    <div class="no-print">
        <small class="text-muted d-none d-md-inline">
            إجمالي إذون الدفع: @total
        </small>
    </div>

    @* ===== الترقيم (Pagination) ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة التاريخ/الوقت (تاريخ الإذن) ===== *@
<div class="modal fade no-print"
     id="dateFilterModalCashPayments"
     tabindex="-1"
     aria-labelledby="dateFilterModalCashPaymentsLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalCashPaymentsLabel">
                    فلترة بالتاريخ والوقت (تاريخ إذن الدفع)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRangeCashPayments"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRangeCashPayments">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="columnsModalCashPayments"
     tabindex="-1"
     aria-labelledby="columnsModalCashPaymentsLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalCashPaymentsLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListCashPayments"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsCashPayments"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط
        // =========================
        document.getElementById("btnPrintCashPayments")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("cashPaymentsTable");
            if (!table) return;

            const storageKey = "cashpayments-columns-visibility";

            // قراءة رؤوس الأعمدة التى يمكن إخفاؤها
            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListCashPayments");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_cp_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsCashPayments")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalCashPayments");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // تحديد الكل + الحذف الجماعي (BulkDelete)
        // =========================
        (function () {
            const selectAll = document.getElementById("selectAll");
            const bulkBtn   = document.getElementById("btnBulkDelete");
            const bulkForm  = document.getElementById("formBulkDelete");

            function getRowCheckboxes() {
                return Array.from(document.querySelectorAll(".row-select"));
            }

            // تحديد/إلغاء تحديد كل الصفوف
            selectAll?.addEventListener("change", function () {
                const checked = this.checked;
                getRowCheckboxes().forEach(cb => cb.checked = checked);
            });

            // الحذف الجماعي
            bulkBtn?.addEventListener("click", function () {
                const checks = getRowCheckboxes().filter(cb => cb.checked);
                if (checks.length === 0) {
                    alert("من فضلك اختر على الأقل إذن واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف الإذون المحددة؟")) {
                    return;
                }

                // إزالة أى hidden قديمة
                const oldHidden = bulkForm.querySelectorAll("input[type='hidden'][name='ids']");
                oldHidden.forEach(h => h.remove());

                // إضافة hidden input لكل رقم إذن
                checks.forEach(cb => {
                    const input = document.createElement("input");
                    input.type  = "hidden";
                    input.name  = "ids";
                    input.value = cb.value;   // CashPaymentId
                    bulkForm.appendChild(input);
                });

                bulkForm.submit();
            });
        })();

        // =========================
        // فلتر الكود من/إلى (CashPaymentId)
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);

                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");   // نرجع لأول صفحة بعد تطبيق الفلتر
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
