@model ERP.Models.CashPayment

@{
    ViewData["Title"] = "تفاصيل إذن دفع نقدية";
}

<div class="container" dir="rtl">
    <h2 class="mb-3">تفاصيل إذن دفع نقدية</h2>

    <div class="card mb-3">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">المعرّف</dt>
                <dd class="col-sm-9">@Model.CashPaymentId</dd>

                <dt class="col-sm-3">رقم المستند</dt>
                <dd class="col-sm-9">@Model.PaymentNumber</dd>

                <dt class="col-sm-3">التاريخ</dt>
                <dd class="col-sm-9">@Model.PaymentDate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">الطرف</dt>
                <dd class="col-sm-9">@Model.Customer?.CustomerName</dd>

                <dt class="col-sm-3">حساب الصندوق / البنك</dt>
                <dd class="col-sm-9">
                    @if (Model.CashAccount != null)
                    {
                        @($"{Model.CashAccount.AccountCode} - {Model.CashAccount.AccountName}")
                    }
                </dd>

                <dt class="col-sm-3">حساب الطرف</dt>
                <dd class="col-sm-9">
                    @if (Model.CounterAccount != null)
                    {
                        @($"{Model.CounterAccount.AccountCode} - {Model.CounterAccount.AccountName}")
                    }
                </dd>

                <dt class="col-sm-3">المبلغ</dt>
                <dd class="col-sm-9">@Model.Amount.ToString("N2")</dd>

                <dt class="col-sm-3">البيان</dt>
                <dd class="col-sm-9">@Model.Description</dd>
            </dl>
        </div>
    </div>

    <div class="d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-secondary btn-sm">عودة للقائمة</a>
        <div>
            <a asp-action="Show" asp-route-id="@Model.CashPaymentId" class="btn btn-info btn-sm">عرض كإيصال</a>
            <a asp-action="Edit" asp-route-id="@Model.CashPaymentId" class="btn btn-primary btn-sm">تعديل</a>
        </div>
    </div>
</div>
