@model ERP.Models.Policy

@{
    ViewData["Title"] = "تعديل سياسة";
}

<div class="container" dir="rtl">
    <h2 class="mt-3 mb-3">تعديل سياسة — @Model.PolicyId</h2>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="card mb-3">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                @* المفتاح الأساسي مخفي *@
                <input type="hidden" asp-for="PolicyId" />

                @* اسم السياسة *@
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">اسم السياسة</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                @* الوصف *@
                <div class="mb-3">
                    <label asp-for="Description" class="form-label">الوصف</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                @* مفعلة أم لا *@
                <div class="mb-3 form-check">
                    <input asp-for="IsActive" class="form-check-input ms-2" />
                    <label asp-for="IsActive" class="form-check-label">مفعّلة؟</label>
                </div>

                @* معلومات للقراءة فقط عن الإنشاء والتعديل *@
                <div class="mb-3">
                    <label class="form-label">تاريخ الإنشاء</label>
                    <input class="form-control" value="@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")" disabled />
                </div>

                @if (Model.UpdatedAt.HasValue)
                {
                    <div class="mb-3">
                        <label class="form-label">آخر تعديل</label>
                        <input class="form-control" value="@Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")" disabled />
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        حفظ التغييرات
                    </button>
                    <a asp-action="Index" class="btn btn-erp btn-erp-secondary">
                        رجوع للقائمة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
