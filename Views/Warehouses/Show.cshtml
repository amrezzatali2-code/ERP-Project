@model ERP.Models.Warehouse
@{
    ViewData["Title"] = "عرض مخزن";
}
<div class="container" dir="rtl">
    <h2 class="mb-3">عرض مخزن</h2>
    <dl class="row">
        <dt class="col-sm-2">المعرّف</dt>
        <dd class="col-sm-10">@Model.WarehouseId</dd>
        <dt class="col-sm-2">الاسم</dt>
        <dd class="col-sm-10">@Model.WarehouseName</dd>
        <dt class="col-sm-2">الفرع</dt>
        <dd class="col-sm-10">@Model.Branch?.BranchName</dd>
        <dt class="col-sm-2">فعّال</dt>
        <dd class="col-sm-10">@(Model.IsActive ? "نعم" : "لا")</dd>
        <dt class="col-sm-2">ملاحظات</dt>
        <dd class="col-sm-10">@(string.IsNullOrWhiteSpace(Model.Notes) ? "—" : Model.Notes)</dd>
        <dt class="col-sm-2">تاريخ الإنشاء</dt>
        <dd class="col-sm-10">@Model.CreatedAt.ToLocalTime().ToString("g")</dd>
        <dt class="col-sm-2">آخر تعديل</dt>
        <dd class="col-sm-10">@(Model.UpdatedAt.HasValue ? Model.UpdatedAt.Value.ToLocalTime().ToString("g") : "—")</dd>
    </dl>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Edit" asp-route-id="@Model.WarehouseId" class="btn btn-primary">تعديل</a>
        <a asp-action="Index" class="btn btn-secondary">رجوع للقائمة</a>
    </div>
</div>
