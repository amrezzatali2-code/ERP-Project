@using Microsoft.AspNetCore.Html 
                                        <!-- لاستخدام HtmlString في sortLink -->
@using ERP.Infrastructure
@model PagedResult<ERP.Models.Warehouse>

@{
    ViewData["Title"] = "المخازن";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "Warehouses";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "name";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "name";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    // نطاق العرض السفلي
    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلترة بالتاريخ/الوقت (تاريخ إنشاء المخزن)
    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;

    // فلتر كود من/إلى + فلاتر أعمدة Excel
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;
    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_name = ViewBag.FilterCol_Name as string;
    string? filterCol_branch = ViewBag.FilterCol_Branch as string;
    string? filterCol_active = ViewBag.FilterCol_Active as string;
    string? filterCol_created = ViewBag.FilterCol_Created as string;
    string? filterCol_modified = ViewBag.FilterCol_Modified as string;

    // دالة توليد لينك الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_name,
        filterCol_branch,
        filterCol_active,
        filterCol_created,
        filterCol_modified
    })!;

    // دالة عمود قابل للفلترة (بنمط Excel - ترتيب وفلتر)
    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        var currentFilter = colKey == "id" ? filterCol_id : colKey == "name" ? filterCol_name : colKey == "branch" ? filterCol_branch : colKey == "active" ? filterCol_active : colKey == "created" ? filterCol_created : colKey == "modified" ? filterCol_modified : null;
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    @* عنوان الصفحة + إجمالي المخازن *@
    <div class="d-flex justify-content-between align-items-center mb-2 mt-2">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <small class="text-muted d-none d-md-inline">إجمالي المخازن: @total</small>
    </div>

    @* ===== شريط الفلاتر الموحد (نفس نظام قائمة الأصناف) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في المخازن</label>
                    <div class="d-flex flex-wrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:150px">
                            <option value="name"@Html.Raw(searchBy == "name" ? " selected" : "")>اسم المخزن</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>كود المخزن</option>
                            <option value="branch"@Html.Raw(searchBy == "branch" ? " selected" : "")>الفرع</option>
                            <option value="active"@Html.Raw(searchBy == "active" ? " selected" : "")>الحالة</option>
                            <option value="created"@Html.Raw(searchBy == "created" ? " selected" : "")>تاريخ الإنشاء</option>
                            <option value="updated"@Html.Raw(searchBy == "updated" ? " selected" : "")>آخر تعديل</option>
                        </select>
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">بحث</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر الكود --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر الكود</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <a class="btn btn-erp btn-erp-success btn-erp-sm" asp-action="Create">+ إضافة مخزن</a>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalWarehouse">اختيار الأعمدة</button>
                        <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteSelected">حذف المحدد</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف الجميع</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="Warehouses" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_branch)) { <input type="hidden" name="filterCol_branch" value="@filterCol_branch" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_active)) { <input type="hidden" name="filterCol_active" value="@filterCol_active" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_modified)) { <input type="hidden" name="filterCol_modified" value="@filterCol_modified" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:70px;min-width:70px;font-size:0.8rem;padding:0.25rem 0.4rem;">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                    <form id="bulkDeleteForm" asp-action="BulkDelete" asp-controller="Warehouses" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="selectedIds" id="selectedIdsInput" />
                    </form>
                    <form id="deleteAllForm" asp-action="DeleteAll" asp-controller="Warehouses" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>

        </div>
    </div>

    @* ===== جدول المخازن (نفس شكل جدول قائمة الأصناف) ===== *@
    <div class="erp-table-scroll-container erp-list-index-table-section mt-3">
        <div class="erp-table-wrapper erp-print-area" style="position: relative; max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="warehouseTable"
               class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    @* اختيار الصف *@
                    <th class="text-center no-print"
                        style="width:40px;"
                        data-col="select"
                        data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    <th data-col="id">@filterableCol("id", "id", "كود المخزن")</th>
                    <th data-col="name">@filterableCol("name", "name", "اسم المخزن")</th>
                    <th data-col="branch">@filterableCol("branch", "branch", "الفرع")</th>
                    <th data-col="active">@filterableCol("active", "active", "الحالة")</th>
                    <th data-col="created">@filterableCol("created", "created", "تاريخ الإنشاء")</th>
                    <th data-col="modified">@filterableCol("modified", "modified", "آخر تعديل")</th>

                    <th class="text-nowrap no-print"
                        data-col="actions"
                        data-col-fixed="true"
                        style="width:350px;">
                        إجراءات
                    </th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var w in Model.Items)
                    {
                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@w.WarehouseId" />
                            </td>

                            <td data-col="id">
                                <a asp-action="Show"
                                   asp-route-id="@w.WarehouseId"
                                   class="text-decoration-none fw-semibold"
                                   title="عرض تفاصيل المخزن">
                                    @w.WarehouseId
                                </a>
                            </td>
                            <td data-col="name">
                                <a asp-action="Show"
                                   asp-route-id="@w.WarehouseId"
                                   class="text-decoration-none fw-semibold"
                                   title="عرض تفاصيل المخزن">
                                    @w.WarehouseName
                                </a>
                            </td>
                            <td data-col="branch">@w.Branch?.BranchName</td>
                            <td data-col="active">@((w.IsActive) ? "نشط" : "موقوف")</td>
                            <td data-col="created">
                                @w.CreatedAt.ToString("yyyy/MM/dd HH:mm")
                            </td>
                            <td data-col="modified">
                                @(w.UpdatedAt.HasValue
                                                        ? w.UpdatedAt.Value.ToString("yyyy/MM/dd HH:mm")
                                                        : "")
                            </td>

                            <td class="text-nowrap no-print" data-col="actions">
                                <a class="btn btn-erp btn-erp-primary btn-erp-sm"
                                   asp-action="Edit"
                                   asp-route-id="@w.WarehouseId"
                                   title="تعديل بيانات المخزن">
                                    تعديل
                                </a>
                                <a class="btn btn-erp btn-erp-danger btn-erp-sm"
                                   asp-action="Delete"
                                   asp-route-id="@w.WarehouseId"
                                   title="حذف المخزن">
                                    حذف
                                </a>
                            </td>
                        </tr>
                    }

                    @* صف الإجمالي في نهاية الجدول *@
                    <tr class="table-secondary fw-bold">
                        <td colspan="7" class="text-end">
                            عدد المخازن (حسب الفلتر الحالي):
                        </td>
                        <td class="text-end">
                            @total
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
            }
            @if (toDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_branch)) { <input type="hidden" name="filterCol_branch" value="@filterCol_branch" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_active)) { <input type="hidden" name="filterCol_active" value="@filterCol_active" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_modified)) { <input type="hidden" name="filterCol_modified" value="@filterCol_modified" /> }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    @* ===== الترقيم ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== لوحة فلتر العمود (بنمط Excel - ترتيب + فلترة) ===== *@
<div id="erpColumnFilterPanel" class="erp-column-filter-panel d-none" dir="rtl">
    <div class="erp-column-filter-header">
        <span id="erpColumnFilterTitle">ترتيب وفلتر</span>
        <button type="button" class="btn-close btn-sm" id="erpColumnFilterClose" aria-label="إغلاق"></button>
    </div>
    <div class="erp-column-filter-body">
        <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
            <label class="form-label small mb-1 fw-bold">الترتيب:</label>
            <div class="d-flex flex-column gap-1">
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
            </div>
        </div>
        <div class="erp-filter-section">
            <div id="erpColumnFilterSearchRow">
                <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                <input type="text" id="erpColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
            </div>
            <div id="erpColumnFilterList" class="erp-column-filter-list">
                <div class="text-muted text-center py-3">جاري التحميل...</div>
            </div>
        </div>
        <div class="erp-column-filter-actions">
            <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOk">تطبيق</button>
            <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClear">مسح الفلتر</button>
        </div>
    </div>
</div>
<form id="erpColumnFilterApplyForm" method="get" action="@Url.Action("Index", "Warehouses")" class="d-none" style="display:none !important;"></form>

@* ===== Modal فلترة بالتاريخ/الوقت (تاريخ إنشاء المخزن) ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ إنشاء المخزن)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_branch)) { <input type="hidden" name="filterCol_branch" value="@filterCol_branch" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_active)) { <input type="hidden" name="filterCol_active" value="@filterCol_active" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_modified)) { <input type="hidden" name="filterCol_modified" value="@filterCol_modified" /> }

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة (ديناميكي) ===== *@
<div class="modal fade no-print erp-columns-modal"
     id="columnsModalWarehouse"
     tabindex="-1"
     aria-labelledby="columnsModalWarehouseLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalWarehouseLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListWarehouse" class="erp-columns-modal-list"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsWarehouse"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط
        // =========================
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table  = document.getElementById("warehouseTable");
            if (!table) return;

            const chkAll = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            // تحديد/إلغاء تحديد كل الصفوف
            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            // إذا ألغيت اختيار صف واحد يتم إلغاء "تحديد الكل"
            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected");
            const bulkForm          = document.getElementById("bulkDeleteForm");
            const selectedInput     = document.getElementById("selectedIdsInput");

            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل مخزن واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف المخازن المحددة؟")) return;

                selectedInput.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("deleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع المخازن. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("warehouseTable");
            if (!table) return;

            const storageKey = "warehouse-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListWarehouse");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "wh_col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsWarehouse")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalWarehouse");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر الكود من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);

                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();

        // =========================
        // لوحة فلتر الأعمدة (بنمط Excel) — ترتيب وفلتر
        // =========================
        (function () {
            const panel = document.getElementById("erpColumnFilterPanel");
            const titleEl = document.getElementById("erpColumnFilterTitle");
            const searchInp = document.getElementById("erpColumnFilterSearch");
            const listEl = document.getElementById("erpColumnFilterList");
            const searchRowEl = document.getElementById("erpColumnFilterSearchRow");
            if (!panel || !listEl) return;

            let currentCol = null, currentSortKey = null, currentSelected = new Set(), allItems = [], anchorRect = null;
            const getCurrentSort = () => {
                const url = new URL(window.location.href);
                return { sort: url.searchParams.get("sort") || "name", dir: url.searchParams.get("dir") || "asc" };
            };
            const getCurrentFilterValue = (col) => {
                const url = new URL(window.location.href);
                return url.searchParams.get("filterCol_" + col) || "";
            };

            function adjustPanelPosition() {
                if (!panel || !anchorRect) return;
                setTimeout(() => {
                    const panelRect = panel.getBoundingClientRect();
                    const margin = 8, maxBottom = window.innerHeight - margin, maxRight = window.innerWidth - margin;
                    let top = anchorRect.bottom + 4, left = anchorRect.left;
                    if (top + panelRect.height > maxBottom) top = Math.max(margin, maxBottom - panelRect.height);
                    if (left + panelRect.width > maxRight) left = Math.max(margin, maxRight - panelRect.width);
                    panel.style.top = top + "px";
                    panel.style.left = left + "px";
                }, 50);
            }

            function showPanel(btn) {
                currentCol = btn.dataset.col;
                currentSortKey = btn.dataset.sortKey || currentCol;
                const colTitle = btn.dataset.colTitle || currentCol;
                titleEl.textContent = "ترتيب وفلتر: " + colTitle;
                searchInp.value = "";
                currentSelected = new Set();
                anchorRect = btn.getBoundingClientRect();
                panel.style.minWidth = Math.max(250, anchorRect.width) + "px";
                panel.classList.remove("d-none");

                const currentSort = getCurrentSort();
                const isCurrent = currentSort.sort.toLowerCase() === currentSortKey.toLowerCase();
                const currentDir = isCurrent ? currentSort.dir : "asc";
                document.querySelectorAll("#erpColumnFilterPanel .erp-sort-btn").forEach(sortBtn => {
                    const btnDir = sortBtn.dataset.sortDir;
                    sortBtn.classList.toggle("active", isCurrent && btnDir === currentDir);
                    sortBtn.classList.toggle("btn-primary", isCurrent && btnDir === currentDir);
                    sortBtn.classList.toggle("btn-outline-secondary", !(isCurrent && btnDir === currentDir));
                });
                adjustPanelPosition();

                if (searchRowEl) searchRowEl.style.display = "";
                listEl.innerHTML = '<div class="text-muted text-center py-3">جاري التحميل...</div>';
                currentSelected = new Set((getCurrentFilterValue(currentCol) || "").split("|").filter(Boolean));
                const url = "/Warehouses/GetColumnValues?column=" + encodeURIComponent(currentCol) + (searchInp.value.trim() ? "&search=" + encodeURIComponent(searchInp.value.trim()) : "");
                fetch(url).then(r => r.json()).then(items => {
                    allItems = items;
                    renderList(searchInp.value);
                }).catch(() => { listEl.innerHTML = '<div class="text-danger text-center py-2">فشل التحميل</div>'; });
            }

            function renderList(search) {
                const term = (search || "").toLowerCase();
                const filtered = term ? allItems.filter(x => (x.display || x.value || "").toLowerCase().includes(term)) : allItems;
                const allChecked = filtered.length > 0 && filtered.every(x => currentSelected.has(String(x.value)));
                const someChecked = filtered.some(x => currentSelected.has(String(x.value)));
                listEl.innerHTML = `<div class="form-check mb-1"><input type="checkbox" class="form-check-input" id="erpFilterSelectAll" ${allChecked ? "checked" : ""}><label class="form-check-label small" for="erpFilterSelectAll">(تحديد الكل)</label></div><div class="erp-filter-items" style="max-height:200px;overflow-y:auto;">${filtered.map(x => { const v = String(x.value); const checked = currentSelected.has(v); return `<div class="form-check"><input type="checkbox" class="form-check-input erp-filter-item" value="${v.replace(/"/g, "&quot;")}" ${checked ? "checked" : ""} data-display="${(x.display || v).replace(/"/g, "&quot;")}"><label class="form-check-label small">${(x.display || v).replace(/</g, "&lt;")}</label></div>`; }).join("")}</div>`;
                const selectAllCb = listEl.querySelector("#erpFilterSelectAll");
                if (selectAllCb) { selectAllCb.indeterminate = someChecked && !allChecked; selectAllCb.addEventListener("change", function() { filtered.forEach(x => { if (this.checked) currentSelected.add(String(x.value)); else currentSelected.delete(String(x.value)); }); renderList(searchInp.value); }); }
                listEl.querySelectorAll(".erp-filter-item").forEach(cb => { cb.addEventListener("change", function() { if (this.checked) currentSelected.add(this.value); else currentSelected.delete(this.value); renderList(searchInp.value); }); });
                adjustPanelPosition();
            }

            function applyFilter(applySort, sortDir) {
                if (!currentCol) return;
                const url = new URL(window.location.href);
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.delete("filterCol_" + currentCol + "Expr");
                if (applySort != null && sortDir != null) { url.searchParams.set("sort", applySort); url.searchParams.set("dir", sortDir); } else { const cs = getCurrentSort(); url.searchParams.set("sort", cs.sort); url.searchParams.set("dir", cs.dir); }
                const val = Array.from(currentSelected).filter(Boolean).join("|");
                if (val) url.searchParams.set("filterCol_" + currentCol, val);
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }

            function clearFilter() {
                if (!currentCol) return;
                const url = new URL(window.location.href);
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }

            document.querySelectorAll(".erp-col-filter-btn").forEach(btn => { btn.addEventListener("click", function(e) { e.preventDefault(); e.stopPropagation(); showPanel(this); }); });
            document.getElementById("erpColumnFilterClose")?.addEventListener("click", () => panel.classList.add("d-none"));
            document.getElementById("erpColumnFilterOk")?.addEventListener("click", () => {
                const activeSort = panel.querySelector(".erp-sort-btn.active");
                const applySort = activeSort ? currentSortKey : null;
                const sortDir = activeSort ? activeSort.dataset.sortDir : null;
                applyFilter(applySort, sortDir);
            });
            document.getElementById("erpColumnFilterClear")?.addEventListener("click", () => clearFilter());
            panel.querySelectorAll(".erp-sort-btn").forEach(sortBtn => {
                sortBtn.addEventListener("click", function() {
                    panel.querySelectorAll(".erp-sort-btn").forEach(b => { b.classList.remove("active", "btn-primary"); b.classList.add("btn-outline-secondary"); });
                    this.classList.add("active", "btn-primary");
                    this.classList.remove("btn-outline-secondary");
                });
            });
            if (searchInp) searchInp.addEventListener("input", function() { if (!currentCol) return; const st = this.value.trim(); const u = "/Warehouses/GetColumnValues?column=" + encodeURIComponent(currentCol) + (st ? "&search=" + encodeURIComponent(st) : ""); fetch(u).then(r => r.json()).then(items => { allItems = items; renderList(st); }); });
            document.addEventListener("click", function(e) { if (panel && !panel.contains(e.target) && !e.target.closest(".erp-col-filter-btn")) panel.classList.add("d-none"); });
        })();
    </script>
}
