@model ERP.Models.Permission

@{
    ViewData["Title"] = "تعديل صلاحية";
}

<div class="container mt-3" dir="rtl">

    <h2 class="mb-3">تعديل صلاحية — @Model.NameAr</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card">
        <div class="card-body">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* فورم تعديل الصلاحية *@
            <form asp-action="Edit" asp-controller="Permissions" method="post">

                @* مفاتيح مخفية: رقم الصلاحية + تاريخ الإنشاء *@
                <input type="hidden" asp-for="PermissionId" />
                <input type="hidden" asp-for="CreatedAt" />

                @* كود الصلاحية *@
                <div class="mb-3">
                    <label asp-for="Code" class="form-label"></label>
                    <input asp-for="Code" class="form-control" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>

                @* اسم الصلاحية *@
                <div class="mb-3">
                    <label asp-for="NameAr" class="form-label"></label>
                    <input asp-for="NameAr" class="form-control" />
                    <span asp-validation-for="NameAr" class="text-danger"></span>
                </div>

                @* الموديول *@
                <div class="mb-3">
                    <label asp-for="Module" class="form-label"></label>
                    <input asp-for="Module" class="form-control" />
                    <span asp-validation-for="Module" class="text-danger"></span>
                </div>

                @* الوصف *@
                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                @* عرض قراءة فقط لتواريخ الإنشاء/التعديل الحالية (اختياري لراحة المحاسب) *@
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">تاريخ الإنشاء</label>
                        <input class="form-control" value="@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">آخر تعديل</label>
                        <input class="form-control"
                               value="@(Model.UpdatedAt.HasValue? Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")"
                               readonly />
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        حفظ التعديلات
                    </button>
                    <a asp-action="Index" class="btn btn-erp btn-erp-secondary">
                        رجوع للقائمة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
