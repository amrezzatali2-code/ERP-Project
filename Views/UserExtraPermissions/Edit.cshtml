@model ERP.Models.UserExtraPermissions

@{
    ViewData["Title"] = "تعديل الصلاحيات الإضافية لمستخدم";

    var permissions = ViewBag.Permissions as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    string userRolesText = ViewBag.UserRolesText as string ?? "";
}

<div class="container" dir="rtl">
    <h2 class="mb-3">تعديل الصلاحيات الإضافية لمستخدم</h2>

    <form asp-action="Edit" method="post" class="card">
        @* المعرّف الأساسي للسطر *@
        <input type="hidden" asp-for="Id" />

        <div class="card-body">

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger"
                 role="alert"></div>

            <div class="row g-3 mb-3">

                <div class="col-md-4">
                    <label asp-for="UserId" class="form-label fw-semibold">المستخدم</label>

                    @* نعرض الكومبو لكن معطل (عرض فقط) ونرسل القيمة في Hidden *@
                    <select asp-for="UserId"
                            asp-items="ViewBag.UserId"
                            class="form-select"
                            disabled="disabled">
                        <option value="">-- اختر مستخدم --</option>
                    </select>

                    <input type="hidden" asp-for="UserId" />

                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">أدوار المستخدم</label>
                    <input type="text"
                           class="form-control"
                           value="@userRolesText"
                           readonly />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">بحث في الصلاحيات أو الموديول</label>
                    <input id="permSearch"
                           type="text"
                           class="form-control"
                           placeholder="اكتب نص من الكود أو اسم الصلاحية..." />
                </div>
            </div>

            <hr />

            <div class="table-responsive" style="max-height:500px; overflow-y:auto;">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:25%;">الكود</th>
                            <th style="width:20%;">الموديول</th>
                            <th style="width:35%;">الصلاحية</th>
                            <th class="text-center" style="width:10%;">في الأدوار؟</th>
                            <th class="text-center" style="width:10%;">إضافية؟</th>
                        </tr>
                    </thead>
                    <tbody id="permTableBody">
                        @if (!permissions.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    لا توجد صلاحيات لعرضها.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var p in permissions)
                            {
                                bool isFromRole = p.IsFromRole;
                                bool isExtra = p.IsExtra;

                                <tr data-search="@($"{p.Code} {p.Module} {p.NameAr}")">
                                    <td>@p.Code</td>
                                    <td>@p.Module</td>
                                    <td>@p.NameAr</td>

                                    <td class="text-center">
                                        @if (isFromRole)
                                        {
                                            <span class="text-success fw-bold">✔</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">✖</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <input type="checkbox"
                                               class="form-check-input"
                                               name="selectedPermissionIds"
                                               value="@p.Id"
                                               @(isExtra ? "checked=\"checked\"" : "") />
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">
                رجوع للقائمة
            </a>

            <button type="submit" class="btn btn-primary">
                حفظ التعديلات
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // فلتر البحث في جدول الصلاحيات (نفس الكود المستخدم في Create)
        (function () {
            var searchInput = document.getElementById('permSearch');
            if (!searchInput) return;

            searchInput.addEventListener('input', function () {
                var term = this.value.toLowerCase();
                var rows = document.querySelectorAll('#permTableBody tr');

                rows.forEach(function (row) {
                    var text = row.getAttribute('data-search');
                    if (!text) {
                        row.style.display = '';
                        return;
                    }
                    row.style.display = text.toLowerCase().indexOf(term) >= 0 ? '' : 'none';
                });
            });
        })();
    </script>
}
