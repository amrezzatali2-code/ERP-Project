    @* ===== جدول سطور مرتجع البيع داخل حاوية تمرير ===== *@
    <div class="erp-print-area">
        <h5 class="mb-2 print-only fs-6 text-secondary">@ViewData["Title"]</h5>
        <div class="erp-list-table-frame erp-table-scroll-container erp-list-table-after-summary ps-0 pe-0">
        <div id="srlTableScrollWrapper" class="erp-table-wrapper" style="position: relative; max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="srlTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10;">
                <tr>
                    <th data-col="srid">@filterableCol("srid", "SRId", "رقم المرتجع")</th>
                    <th data-col="siid">@filterableCol("siid", "SalesInvoiceId", "رقم فاتورة الصنف")</th>
                    <th data-col="lineno">@filterableCol("lineno", "LineNo", "رقم السطر")</th>
                    <th data-col="prod">@filterableCol("prod", "ProdId", "كود الصنف")</th>
                    <th data-col="prodname">@filterableCol("prodname", "ProdName", "اسم الصنف")</th>
                    <th data-col="customer">@filterableCol("customer", "CustomerName", "العميل")</th>
                    <th data-col="createdby">@filterableCol("createdby", "CreatedBy", "الكاتب")</th>
                    <th data-col="area">@filterableCol("area", "AreaName", "المنطقة")</th>
                    <th data-col="qty">@filterableCol("qty", "Qty", "الكمية")</th>
                    <th data-col="priceretail">@filterableCol("priceretail", "PriceRetail", "سعر الجمهور")</th>
                    <th data-col="unitprice">@filterableCol("unitprice", "UnitSalePrice", "سعر البيع للوحدة")</th>
                    <th data-col="net">@filterableCol("net", "LineNetTotal", "صافي السطر")</th>
                    <th data-col="batch">@filterableCol("batch", "BatchNo", "التشغيلة")</th>
                    <th data-col="expiry">@filterableCol("expiry", "Expiry", "الصلاحية")</th>
                    <th data-col="status">@filterableCol("status", "Status", "حالة المرتجع")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="15" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var line in Model.Items)
                    {
                        var status = line.SalesReturn?.Status ?? "";
                        var showUrl = Url.Action("Edit", "SalesReturns", new { id = line.SRId }) + "?frame=1";
                        var movementUrl = Url.Action("Show", "Products", new { id = line.ProdId }) + "?frame=1";
                        var rowId = line.SRId + "_" + line.LineNo;
                        var areaName = line.SalesReturn?.Customer?.Area?.AreaName ?? "";

                        <tr class="erp-list-selectable-row"
                            data-row-id="@rowId"
                            data-sr-id="@line.SRId"
                            data-line-no="@line.LineNo"
                            data-prod-id="@line.ProdId"
                            data-show-url="@showUrl"
                            data-movement-url="@movementUrl"
                            data-tab-title="مرتجع مبيعات">
                            <td data-col="srid">@line.SRId</td>
                            <td data-col="siid">@(line.SalesInvoiceId?.ToString() ?? "-")</td>
                            <td data-col="lineno">@line.LineNo</td>
                            <td data-col="prod">@line.ProdId</td>
                            <td data-col="prodname">@(line.Product?.ProdName ?? "-")</td>
                            <td data-col="customer">@(line.SalesReturn?.Customer?.CustomerName ?? "-")</td>
                            <td data-col="createdby">@(line.SalesReturn?.CreatedBy ?? "")</td>
                            <td data-col="area">@areaName</td>
                            <td data-col="qty">@line.Qty</td>
                            <td data-col="priceretail">@line.PriceRetail.ToString("0.00")</td>
                            <td data-col="unitprice">@line.UnitSalePrice.ToString("0.00")</td>
                            <td data-col="net">@line.LineNetTotal.ToString("0.00")</td>
                            <td data-col="batch">@line.BatchNo</td>
                            <td data-col="expiry">@((line.Expiry?.ToString("yyyy-MM") ?? ""))</td>
                            <td data-col="status">@status</td>
                        </tr>
                    }
                }
            </tbody>
            @if (Model.TotalCount > 0)
            {
                <tfoot class="table-light">
                    <tr class="fw-bold">
                        <td data-col="srid" class="text-muted text-start">إجمالي</td>
                        <td data-col="siid"></td>
                        <td data-col="lineno"></td>
                        <td data-col="prod"></td>
                        <td data-col="prodname"></td>
                        <td data-col="customer"></td>
                        <td data-col="createdby"></td>
                        <td data-col="area"></td>
                        <td data-col="qty" class="text-start">@totalQtyForCards.ToString("N0", n2)</td>
                        <td data-col="priceretail" class="text-start" title="مجموع (كمية × سعر الجمهور)">@totalRetailGrossForCards.ToString("N2", n2)</td>
                        <td data-col="unitprice"></td>
                        <td data-col="net" class="text-start">@totalNetForCards.ToString("N2", n2)</td>
                        <td data-col="batch"></td>
                        <td data-col="expiry"></td>
                        <td data-col="status"></td>
                    </tr>
                </tfoot>
            }
        </table>
        </div>
        </div>
    </div>

