@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<SalesReturnLine>

@{
    ViewData["Title"] = "أصناف مرتجعات البيع";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "SalesReturnLines";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "SRId";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    // بيانات الترقيم
    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
    int end = (ps == 0 || total == 0) ? total : Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلتر رقم المرتجع (لو دخلنا من شاشة الهيدر برقم محدد)
    int? filterSRId = ViewBag.FilterSRId as int?;
    string srIdText = filterSRId?.ToString() ?? "";

    // فلتر كود من/إلى (هنا نستخدمه كـ "من رقم سطر / إلى رقم سطر")
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    // اسم حقل التاريخ المستخدم في فلترة التاريخ/الوقت (هنا نستهدف تاريخ الهيدر SRDate)
    var dateField = (string?)ViewBag.DateField ?? "SRDate";

    // فلاتر الأعمدة بنمط Excel
    string? filterCol_srid = ViewBag.FilterCol_srid as string;
    string? filterCol_siid = ViewBag.FilterCol_siid as string;
    string? filterCol_lineno = ViewBag.FilterCol_lineno as string;
    string? filterCol_prod = ViewBag.FilterCol_prod as string;
    string? filterCol_qty = ViewBag.FilterCol_qty as string;
    string? filterCol_priceretail = ViewBag.FilterCol_priceretail as string;
    string? filterCol_unitprice = ViewBag.FilterCol_unitprice as string;
    string? filterCol_net = ViewBag.FilterCol_net as string;
    string? filterCol_batch = ViewBag.FilterCol_batch as string;
    string? filterCol_expiry = ViewBag.FilterCol_expiry as string;
    string? filterCol_status = ViewBag.FilterCol_status as string;
    string? filterCol_prodname = ViewBag.FilterCol_prodname as string;
    string? filterCol_customer = ViewBag.FilterCol_customer as string;
    string? filterCol_createdby = ViewBag.FilterCol_createdby as string;
    string? filterCol_area = ViewBag.FilterCol_area as string;

    string? filterCol_sridExpr = ViewBag.FilterCol_sridExpr as string;
    string? filterCol_siidExpr = ViewBag.FilterCol_siidExpr as string;
    string? filterCol_linenoExpr = ViewBag.FilterCol_linenoExpr as string;
    string? filterCol_prodExpr = ViewBag.FilterCol_prodExpr as string;
    string? filterCol_qtyExpr = ViewBag.FilterCol_qtyExpr as string;
    string? filterCol_priceretailExpr = ViewBag.FilterCol_priceretailExpr as string;
    string? filterCol_unitpriceExpr = ViewBag.FilterCol_unitpriceExpr as string;
    string? filterCol_netExpr = ViewBag.FilterCol_netExpr as string;

    // دالة توليد لينكات الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        srId = filterSRId,
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField,
        fromCode,
        toCode,
        filterCol_srid,
        filterCol_siid,
        filterCol_lineno,
        filterCol_prod,
        filterCol_qty,
        filterCol_priceretail,
        filterCol_unitprice,
        filterCol_net,
        filterCol_batch,
        filterCol_expiry,
        filterCol_status,
        filterCol_prodname,
        filterCol_customer,
        filterCol_createdby,
        filterCol_area,
        filterCol_sridExpr,
        filterCol_siidExpr,
        filterCol_linenoExpr,
        filterCol_prodExpr,
        filterCol_qtyExpr,
        filterCol_priceretailExpr,
        filterCol_unitpriceExpr,
        filterCol_netExpr
    })!;

    // دالة إنشاء لينك الترتيب في رأس الجدول + أيقونة السهم (احتياطيًا)
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            srId = filterSRId,
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange = Model.UseDateRange,
            fromDate = Model.FromDate,
            toDate = Model.ToDate,
            dateField,
            fromCode,
            toCode,
            filterCol_srid,
            filterCol_siid,
            filterCol_lineno,
            filterCol_prod,
            filterCol_qty,
            filterCol_priceretail,
            filterCol_unitprice,
            filterCol_net,
            filterCol_batch,
            filterCol_expiry,
            filterCol_status,
            filterCol_prodname,
            filterCol_customer,
            filterCol_createdby,
            filterCol_area,
            filterCol_sridExpr,
            filterCol_siidExpr,
            filterCol_linenoExpr,
            filterCol_prodExpr,
            filterCol_qtyExpr,
            filterCol_priceretailExpr,
            filterCol_unitpriceExpr,
            filterCol_netExpr
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    // دالة مساعدة لإرجاع قيمة فلتر العمود الحالى (للأعمدة الرقمية: filterCol_*Expr له أولوية على الصيغة القديمة G:/L:/R:)
    string? FilterForCol(string colKey) =>
        colKey == "srid" ? (!string.IsNullOrWhiteSpace(filterCol_sridExpr) ? filterCol_sridExpr : filterCol_srid)
        : colKey == "siid" ? (!string.IsNullOrWhiteSpace(filterCol_siidExpr) ? filterCol_siidExpr : filterCol_siid)
        : colKey == "lineno" ? (!string.IsNullOrWhiteSpace(filterCol_linenoExpr) ? filterCol_linenoExpr : filterCol_lineno)
        : colKey == "prod" ? (!string.IsNullOrWhiteSpace(filterCol_prodExpr) ? filterCol_prodExpr : filterCol_prod)
        : colKey == "qty" ? (!string.IsNullOrWhiteSpace(filterCol_qtyExpr) ? filterCol_qtyExpr : filterCol_qty)
        : colKey == "priceretail" ? (!string.IsNullOrWhiteSpace(filterCol_priceretailExpr) ? filterCol_priceretailExpr : filterCol_priceretail)
        : colKey == "unitprice" ? (!string.IsNullOrWhiteSpace(filterCol_unitpriceExpr) ? filterCol_unitpriceExpr : filterCol_unitprice)
        : colKey == "net" ? (!string.IsNullOrWhiteSpace(filterCol_netExpr) ? filterCol_netExpr : filterCol_net)
        : colKey == "batch" ? filterCol_batch
        : colKey == "expiry" ? filterCol_expiry
        : colKey == "status" ? filterCol_status
        : colKey == "prodname" ? filterCol_prodname
        : colKey == "customer" ? filterCol_customer
        : colKey == "createdby" ? filterCol_createdby
        : colKey == "area" ? filterCol_area
        : null;

    // عمود قابل للفلترة بنمط Excel
    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };

    var n2 = System.Globalization.CultureInfo.InvariantCulture;
    int totalCountForCards = Model.TotalCount;
    int totalQtyForCards = ViewBag.TotalQtyFiltered != null ? (int)ViewBag.TotalQtyFiltered : 0;
    decimal totalRetailGrossForCards = ViewBag.TotalRetailGrossFiltered != null ? (decimal)ViewBag.TotalRetailGrossFiltered : 0m;
    decimal totalNetForCards = ViewBag.TotalNetFiltered != null ? (decimal)ViewBag.TotalNetFiltered : 0m;
}

<div dir="rtl" class="container-fluid erp-srl-index">

    <style>
        .erp-srl-index .erp-srl-summary-stat {
            border: 1px solid #d4dcfa !important;
            border-radius: 10px !important;
            box-shadow: 0 1px 2px rgba(99, 102, 241, 0.06) !important;
            background: #fff !important;
            overflow: hidden;
        }
        .erp-srl-index .erp-srl-summary-stat .card-body { text-align: right; }
        .erp-srl-index .erp-srl-summary-stat .erp-srl-summary-label {
            color: #64748b !important;
            font-size: 0.8rem;
            margin-bottom: 0.35rem !important;
        }
        .erp-srl-index .erp-srl-summary-stat .erp-srl-summary-value {
            font-size: 1.35rem;
            font-weight: 700;
            line-height: 1.2;
            color: #4f46e5;
            letter-spacing: -0.02em;
        }
        .erp-srl-index .erp-srl-summary-stat.erp-srl-summary-stat--qty .erp-srl-summary-value { color: #0369a1; }
        .erp-srl-index .erp-srl-summary-stat.erp-srl-summary-stat--retail .erp-srl-summary-value { color: #7c3aed; }
        .erp-srl-index .erp-srl-summary-stat.erp-srl-summary-stat--net .erp-srl-summary-value { color: #15803d; }
        .erp-srl-index .erp-srl-summary-stat[data-summary-filter-col] {
            cursor: pointer;
            transition: box-shadow .15s ease, border-color .15s ease;
        }
        .erp-srl-index .erp-srl-summary-stat[data-summary-filter-col]:hover {
            box-shadow: 0 2px 10px rgba(99, 102, 241, 0.18) !important;
            border-color: #a5b4fc !important;
        }
        .erp-srl-index .erp-srl-summary-toolbar-wrap .erp-list-summary-row {
            margin-top: 0;
            margin-bottom: 0;
        }
    </style>

    <h2 class="mb-3">
        أصناف مرتجعات البيع
        @if (filterSRId.HasValue)
        {
            <span class="text-muted fs-6">— مرتجع رقم @filterSRId</span>
        }
    </h2>

    @* رسائل نجاح/خطأ *@
    @if (TempData["ok"] is string ok)
    {
        <div class="alert alert-success">@ok</div>
    }
    @if (TempData["error"] is string err)
    {
        <div class="alert alert-danger">@err</div>
    }

    @* ===== شريط الفلاتر الموحد بنمط القوائم الأخرى ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث --- *@
            <div class="col-12 col-lg-6 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في أصناف مرتجعات البيع</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:160px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>الكل</option>
                            <option value="srid"@Html.Raw(searchBy == "srid" ? " selected" : "")>رقم المرتجع</option>
                            <option value="lineno"@Html.Raw(searchBy == "lineno" ? " selected" : "")>رقم السطر</option>
                            <option value="prod"@Html.Raw(searchBy == "prod" ? " selected" : "")>كود الصنف</option>
                            <option value="prodname"@Html.Raw(searchBy == "prodname" ? " selected" : "")>اسم الصنف</option>
                            <option value="customer"@Html.Raw(searchBy == "customer" ? " selected" : "")>العميل</option>
                            <option value="createdby"@Html.Raw(searchBy == "createdby" ? " selected" : "")>الكاتب</option>
                            <option value="area"@Html.Raw(searchBy == "area" ? " selected" : "")>المنطقة</option>
                            <option value="batch"@Html.Raw(searchBy == "batch" ? " selected" : "")>رقم التشغيلة</option>
                            <option value="expiry"@Html.Raw(searchBy == "expiry" ? " selected" : "")>تاريخ الصلاحية</option>
                        </select>
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller, new { srId = filterSRId })">إلغاء</a>
                    </div>
                    <input type="hidden" name="srId" value="@srIdText" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                    @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
                    @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @* الحفاظ على فلاتر الأعمدة الحالية *@
                    @if (!string.IsNullOrWhiteSpace(filterCol_srid))      { <input type="hidden" name="filterCol_srid"      value="@filterCol_srid" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_siid))      { <input type="hidden" name="filterCol_siid"      value="@filterCol_siid" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_lineno))    { <input type="hidden" name="filterCol_lineno"    value="@filterCol_lineno" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prod))      { <input type="hidden" name="filterCol_prod"      value="@filterCol_prod" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qty))       { <input type="hidden" name="filterCol_qty"       value="@filterCol_qty" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_priceretail)){ <input type="hidden" name="filterCol_priceretail" value="@filterCol_priceretail" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_unitprice)) { <input type="hidden" name="filterCol_unitprice" value="@filterCol_unitprice" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_net))       { <input type="hidden" name="filterCol_net"       value="@filterCol_net" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_batch))     { <input type="hidden" name="filterCol_batch"     value="@filterCol_batch" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_expiry))    { <input type="hidden" name="filterCol_expiry"    value="@filterCol_expiry" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_status))    { <input type="hidden" name="filterCol_status"    value="@filterCol_status" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prodname)) { <input type="hidden" name="filterCol_prodname" value="@filterCol_prodname" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_customer)) { <input type="hidden" name="filterCol_customer" value="@filterCol_customer" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_createdby)) { <input type="hidden" name="filterCol_createdby" value="@filterCol_createdby" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_area))     { <input type="hidden" name="filterCol_area"     value="@filterCol_area" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_sridExpr)) { <input type="hidden" name="filterCol_sridExpr" value="@filterCol_sridExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_siidExpr)) { <input type="hidden" name="filterCol_siidExpr" value="@filterCol_siidExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_linenoExpr)) { <input type="hidden" name="filterCol_linenoExpr" value="@filterCol_linenoExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prodExpr)) { <input type="hidden" name="filterCol_prodExpr" value="@filterCol_prodExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyExpr)) { <input type="hidden" name="filterCol_qtyExpr" value="@filterCol_qtyExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_priceretailExpr)) { <input type="hidden" name="filterCol_priceretailExpr" value="@filterCol_priceretailExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_unitpriceExpr)) { <input type="hidden" name="filterCol_unitpriceExpr" value="@filterCol_unitpriceExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_netExpr)) { <input type="hidden" name="filterCol_netExpr" value="@filterCol_netExpr" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر رقم السطر من/إلى --- *@
            <div class="col-12 col-lg-6 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر رقم السطر</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="lineFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="lineToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyLineFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearLineFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

        </div>
    </div>

    @* ===== كروت الإجماليات + أزرار التحكم (كارت واحد بنمط الفواتير — أعلى الجدول) ===== *@
    <div class="no-print erp-srl-summary-toolbar-wrap mb-3" dir="rtl">
        <div class="card border-0 erp-srl-summary-toolbar-card"
             style="border: 1px solid #6366f1 !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(99,102,241,.25) !important; overflow: hidden;">
            <div class="card-body py-3 px-3">
                <div class="row g-3 align-items-center justify-content-between flex-wrap">
                    <div class="col-12 col-xl">
                        <div class="row g-2 g-md-3 justify-content-start erp-list-summary-row" dir="rtl">
                            <div class="col-auto">
                                <div class="card h-100 border-0 erp-list-summary-card erp-srl-summary-stat"
                                     role="button" tabindex="0" title="فلترة عمود رقم المرتجع"
                                     data-summary-filter-col="srid">
                                    <div class="card-body py-3 px-3">
                                        <div class="erp-srl-summary-label">إجمالي العدد</div>
                                        <div class="erp-srl-summary-value">@totalCountForCards.ToString("N0", n2)</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-auto">
                                <div class="card h-100 border-0 erp-list-summary-card erp-srl-summary-stat erp-srl-summary-stat--qty"
                                     role="button" tabindex="0" title="فلترة عمود الكمية"
                                     data-summary-filter-col="qty">
                                    <div class="card-body py-3 px-3">
                                        <div class="erp-srl-summary-label">إجمالي الكمية</div>
                                        <div class="erp-srl-summary-value">@totalQtyForCards.ToString("N0", n2)</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-auto">
                                <div class="card h-100 border-0 erp-list-summary-card erp-srl-summary-stat erp-srl-summary-stat--retail"
                                     role="button" tabindex="0" title="فلترة عمود سعر الجمهور (الإجمالي المعروض = مجموع كمية × سعر الوحدة)"
                                     data-summary-filter-col="priceretail">
                                    <div class="card-body py-3 px-3">
                                        <div class="erp-srl-summary-label">إجمالي الجمهور</div>
                                        <div class="erp-srl-summary-value">@totalRetailGrossForCards.ToString("N2", n2)</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-auto">
                                <div class="card h-100 border-0 erp-list-summary-card erp-srl-summary-stat erp-srl-summary-stat--net"
                                     role="button" tabindex="0" title="فلترة عمود صافي السطر"
                                     data-summary-filter-col="net">
                                    <div class="card-body py-3 px-3">
                                        <div class="erp-srl-summary-label">إجمالي الصافي</div>
                                        <div class="erp-srl-summary-value">@totalNetForCards.ToString("N2", n2)</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-xl-auto d-flex justify-content-center justify-content-xl-end">
                        <div class="erp-toolbar-two-rows d-flex flex-column align-items-center align-items-xl-end gap-1">
                            <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModal">فلترة بتاريخ مرتجع البيع</button>
                                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalSRL">اختيار الأعمدة</button>
                                <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                                <span class="erp-list-toolbar-selected-actions erp-list-toolbar-selected-actions--plain d-inline-flex flex-wrap gap-2 align-items-center" role="group" aria-label="إجراءات السطر المحدد">
                                    <button type="button" id="btnShowSRL" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="عرض مرتجع البيع">عرض</button>
