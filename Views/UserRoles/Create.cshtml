@model ERP.Models.UserRole     
                                                @* موديل ربط المستخدم بالأدوار *@

@{
    ViewData["Title"] = "إسناد دور لمستخدم";   @* عنوان الصفحة في التاب *@
}

<div class="container" dir="rtl">
    <h2 class="mb-3">إسناد دور جديد لمستخدم</h2>

    @* فورم إسناد الدور للمستخدم *@
    <form asp-action="Create"
          method="post"
          class="card"
          id="userRoleCreateForm">
        <input type="hidden" name="SelectedRoleAccountIds" id="SelectedRoleAccountIds" value="" />

        <div class="card-body">

            @* ⭕ تم إلغاء الـ alert الأحمر الكبير
               لو حابب رسالة عامة نقدر نخليها Text عادي من غير background *@
            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3 small">
            </div>

            @* اختيار المستخدم *@
            <div class="mb-3">
                <label asp-for="UserId" class="form-label fw-semibold">المستخدم</label>
                <select asp-for="UserId"
                        asp-items="ViewBag.UserId"
                        class="form-select">
                    <option value="">-- اختر مستخدم --</option>
                </select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>

            @* اختيار الدور *@
            <div class="mb-3">
                <label asp-for="RoleId" class="form-label fw-semibold">الدور</label>
                <select asp-for="RoleId"
                        asp-items="ViewBag.RoleId"
                        class="form-select"
                        id="RoleId">
                    <option value="">-- اختر دور --</option>
                </select>
                <span asp-validation-for="RoleId" class="text-danger"></span>
            </div>

            @* فلاغ اختياري: هل هذا هو الدور الأساسي للمستخدم *@
            <div class="mb-3 form-check">
                <input asp-for="IsPrimary"
                       class="form-check-input ms-2"
                       id="IsPrimary" />
                <label asp-for="IsPrimary"
                       class="form-check-label"
                       title="عندما يكون للمستخدم أكثر من دور، الدور الافتراضي يُستخدم لتحديد الصلاحيات الأساسية أو العرض الافتراضي">
                    دور افتراضي؟
                </label>
                <div class="form-text small text-muted">
                    عندما يكون للمستخدم أكثر من دور، يُستخدم الدور الافتراضي كأساس عند الالتباس.
                </div>
            </div>

            @* ✅ هنا هنظهر تفاصيل صلاحيات الدور المختار *@
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    صلاحيات هذا الدور
                </label>

                <div id="role-permissions-box"
                     class="border rounded p-2 small bg-light">
                    @* نص افتراضي قبل اختيار أي دور *@
                    اختر دوراً من القائمة بالأعلى لعرض صلاحياته هنا.
                </div>
            </div>

        </div>

        @* أزرار الحفظ والرجوع *@
        <div class="card-footer d-flex justify-content-between">
            <a asp-action="Index"
               class="btn btn-secondary">
                رجوع للقائمة
            </a>

            @* زر الحفظ لازم يكون submit علشان يبعت الفورم للـ POST *@
            <button type="submit"
                    class="btn btn-primary">
                حفظ الإسناد
            </button>
        </div>

    </form>
</div>

@section Scripts {
    @* سكربت الفاليديشن الجاهز من MVC *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const rolePermsUrl = '@Url.Action("GetRolePermissionsEditable", "UserRoles")';

        document.addEventListener("DOMContentLoaded", function () {
            const roleSelect = document.getElementById("RoleId");
            const box = document.getElementById("role-permissions-box");
            if (!roleSelect || !box) return;

            function loadPermissions() {
                const roleId = roleSelect.value;
                if (!roleId) {
                    box.innerHTML = "اختر دوراً من القائمة لعرض صلاحياته وتعديلها.";
                    return;
                }
                fetch(rolePermsUrl + "?roleId=" + roleId)
                    .then(r => r.text())
                    .then(html => {
                        box.innerHTML = html;
                        initPermTable();
                    })
                    .catch(err => {
                        console.error(err);
                        box.innerHTML = "حدث خطأ أثناء تحميل الصلاحيات.";
                    });
            }

            function initPermTable() {
                const searchInput = document.getElementById("permSearchInput");
                const chkAll = document.getElementById("chkAllPerms");
                const rows = box.querySelectorAll("#permEditableTable tbody tr");

                if (searchInput) {
                    searchInput.value = "";
                    searchInput.oninput = filterRows;
                    searchInput.addEventListener("keydown", e => { if (e.key === "Enter") { e.preventDefault(); filterRows(); } });
                }
                const btnSearch = box.querySelector("#btnPermSearch");
                const btnClear = box.querySelector("#btnPermClear");
                if (btnSearch) btnSearch.addEventListener("click", filterRows);
                if (btnClear) btnClear.addEventListener("click", () => { if (searchInput) { searchInput.value = ""; filterRows(); searchInput.focus(); } });
                function filterRows() {
                    const term = (searchInput?.value || "").trim().toLowerCase();
                    rows.forEach(tr => {
                        const isChild = tr.classList.contains("perm-child-row");
                        const search = (tr.dataset.search || "").toLowerCase();
                        const matchSearch = !term || search.includes(term);
                        if (isChild) {
                            const parent = tr.dataset.parent ? box.querySelector("#" + tr.dataset.parent) : null;
                            const parentCollapsed = parent?.classList.contains("perm-collapsed");
                            const parentMatches = parent && (parent.dataset.search || "").toLowerCase().includes(term);
                            if (term && parentMatches && parentCollapsed) {
                                parent.classList.remove("perm-collapsed");
                                parent.querySelector(".perm-expand").textContent = "−";
                                parent.querySelector(".perm-expand").title = "إغلاق الشجرة";
                            }
                            const show = (matchSearch || parentMatches) && !parent?.classList.contains("perm-collapsed");
                            tr.style.display = show ? "" : "none";
                        } else {
                            const children = box.querySelectorAll(`tr.perm-child-row[data-parent="${tr.id}"]`);
                            const anyChildMatches = !term || Array.from(children).some(ch => (ch.dataset.search || "").toLowerCase().includes(term));
                            tr.style.display = (matchSearch || anyChildMatches) ? "" : "none";
                        }
                    });
                }

                box.querySelectorAll(".perm-expand").forEach(btn => {
                    btn.onclick = function () {
                        const modRow = this.closest("tr");
                        const modId = modRow?.id;
                        const collapsed = modRow?.classList.toggle("perm-collapsed");
                        const children = modId ? box.querySelectorAll(`tr[data-parent="${modId}"]`) : [];
                        children.forEach(ch => { ch.style.display = collapsed ? "none" : ""; });
                        this.textContent = collapsed ? "+" : "−";
                        this.title = collapsed ? "فتح الشجرة" : "إغلاق الشجرة";
                    };
                });

                box.querySelectorAll(".perm-module-cb").forEach(cb => {
                    cb.onchange = function () {
                        const moduleCb = this;
                        const mod = moduleCb.dataset.module;
                        const isChecked = moduleCb.checked;
                        const children = box.querySelectorAll(`tr.perm-child-row[data-module="${mod}"]`);
                        children.forEach(tr => {
                            const chCb = tr.querySelector(".perm-cb");
                            if (chCb) { chCb.checked = isChecked; updateStatus(chCb); }
                        });
                        updateModuleStatus(moduleCb.closest("tr"));
                    };
                });

                if (chkAll) {
                    chkAll.onchange = function () {
                        box.querySelectorAll(".perm-cb").forEach(cb => {
                            if (cb.closest("tr")?.style.display !== "none") {
                                cb.checked = chkAll.checked;
                                updateStatus(cb);
                            }
                        });
                        box.querySelectorAll(".perm-module-row").forEach(modRow => {
                            if (modRow.style.display !== "none") updateModuleStatus(modRow);
                        });
                    };
                }
                box.querySelectorAll(".perm-cb").forEach(cb => {
                    cb.onchange = function () {
                        updateStatus(this);
                        const modRow = this.closest("tbody")?.querySelector(`tr.perm-module-row[data-module="${this.closest("tr")?.dataset.module}"]`);
                        if (modRow) updateModuleStatus(modRow);
                    };
                });
            }

            function updateModuleStatus(modRow) {
                if (!modRow) return;
                const modId = modRow.id;
                const children = box.querySelectorAll(`tr.perm-child-row[data-parent="${modId}"] .perm-cb`);
                const allChecked = children.length > 0 && Array.from(children).every(c => c.checked);
                const modCb = modRow.querySelector(".perm-module-cb");
                const span = modRow.querySelector(".perm-module-status");
                if (modCb) modCb.checked = allChecked;
                if (span) { span.textContent = allChecked ? "✔" : "✖"; span.className = "perm-module-status " + (allChecked ? "text-success" : "text-danger"); }
            }

            function updateStatus(cb) {
                const tr = cb.closest("tr");
                if (!tr) return;
                const span = tr.querySelector(".perm-status");
                if (span) {
                    span.textContent = cb.checked ? "✔" : "✖";
                    span.className = "perm-status " + (cb.checked ? "text-success" : "text-danger");
                }
            }

            roleSelect.addEventListener("change", loadPermissions);

            const urForm = document.getElementById("userRoleCreateForm");
            if (urForm) {
                urForm.addEventListener("submit", function () {
                    const h = document.getElementById("SelectedRoleAccountIds");
                    if (!h) return;
                    const ids = [];
                    urForm.querySelectorAll(".role-account-visibility-cb:checked").forEach(function (c) { if (c.value) ids.push(c.value); });
                    h.value = ids.join(",");
                });
            }
        });
    </script>
}
