@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.ViewModels
@model PagedResult<UserRoleListRow>

@{
    ViewData["Title"] = "أدوار المستخدمين";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "UserRoles";

    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var searchMode = ((string?)ViewBag.SearchMode ?? "contains").ToLowerInvariant();
    if (searchMode != "starts" && searchMode != "ends") searchMode = "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "UserName";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = Model.StartIndex;
    int end = Model.EndIndex;

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;
    var dateField = (string?)ViewBag.DateField ?? "AssignedAt";

    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_user = ViewBag.FilterCol_User as string;
    string? filterCol_role = ViewBag.FilterCol_Role as string;
    string? filterCol_primary = ViewBag.FilterCol_Primary as string;
    string? filterCol_assigned = ViewBag.FilterCol_Assigned as string;
    int usersCount = ViewBag.UsersCount is int uc ? uc : 0;
    int assignedCount = ViewBag.AssignedCount is int asc ? asc : 0;
    int primaryCount = ViewBag.PrimaryCount is int pc ? pc : 0;
    var n2 = System.Globalization.CultureInfo.InvariantCulture;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        dateField,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_idExpr,
        filterCol_user,
        filterCol_role,
        filterCol_primary,
        filterCol_assigned
    })!;

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = colKey == "id" ? (!string.IsNullOrWhiteSpace(filterCol_idExpr) ? filterCol_idExpr : filterCol_id) : colKey == "user" ? filterCol_user : colKey == "role" ? filterCol_role : colKey == "primary" ? filterCol_primary : colKey == "assigned" ? filterCol_assigned : null;
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"" style=""position:relative;z-index:2;"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor""><path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/><path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/></svg>
                </button>
            </div>");
    };
}

@section Styles {
    <style>
        .erp-ur-toolbar-btn {
            font-size: 0.85rem;
            padding: 0.30rem 0.65rem;
            line-height: 1.25;
            white-space: nowrap;
        }
    </style>
}

<div dir="rtl" class="container-fluid">

    @* ===== شريط الفلاتر الموحد ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام (نفس نمط العملاء) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في أدوار المستخدمين</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100" style="overflow-x:auto;">
                        <select name="searchMode" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:110px;min-width:100px">
                            <option value="starts"@Html.Raw(searchMode == "starts" ? " selected" : "")>يبدأ بـ</option>
                            <option value="contains"@Html.Raw(searchMode == "contains" || string.IsNullOrEmpty(searchMode) ? " selected" : "")>يحتوي</option>
                            <option value="ends"@Html.Raw(searchMode == "ends" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                        <input type="text" name="search" class="form-control erp-filter-input flex-shrink-1" placeholder="نص أو رقم..." value="@search" style="min-width:100px;max-width:200px;width:180px;" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:160px;min-width:130px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>البحث في الكل</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>كود السطر</option>
                            <option value="username"@Html.Raw(searchBy == "username" ? " selected" : "")>اسم الدخول</option>
                            <option value="display"@Html.Raw(searchBy == "display" ? " selected" : "")>الاسم الظاهر</option>
                            <option value="rolename"@Html.Raw(searchBy == "rolename" ? " selected" : "")>اسم الدور</option>
                            <option value="userid"@Html.Raw(searchBy == "userid" ? " selected" : "")>كود المستخدم</option>
                            <option value="roleid"@Html.Raw(searchBy == "roleid" ? " selected" : "")>كود الدور</option>
                            <option value="primary"@Html.Raw(searchBy == "primary" ? " selected" : "")>الأدوار الافتراضية فقط</option>
                        </select>
                    </div>
                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-2 w-100">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_role)) { <input type="hidden" name="filterCol_role" value="@filterCol_role" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_primary)) { <input type="hidden" name="filterCol_primary" value="@filterCol_primary" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_assigned)) { <input type="hidden" name="filterCol_assigned" value="@filterCol_assigned" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر الكود --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر الكود</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم (صفان) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-nowrap gap-2 justify-content-center align-items-center">
                        <a class="btn btn-erp btn-erp-success btn-erp-sm erp-ur-toolbar-btn" asp-action="Create" asp-controller="UserRoles">إسناد دور لمستخدم</a>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm erp-ur-toolbar-btn" data-bs-toggle="modal" data-bs-target="#dateFilterModalUR">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm erp-ur-toolbar-btn" data-bs-toggle="modal" data-bs-target="#columnsModalUR">اختيار الأعمدة</button>
                        <button type="button" id="btnPrintUR" class="btn btn-erp btn-erp-secondary btn-erp-sm erp-ur-toolbar-btn">🖨️ طباعة</button>
                    </div>
                    <div class="erp-toolbar-row d-flex flex-nowrap gap-2 justify-content-center align-items-center">
                        <button type="button" id="btnEditUserRole" class="btn btn-erp btn-erp-secondary btn-erp-sm erp-ur-toolbar-btn" disabled title="اختر سطراً ثم اضغط تعديل (سطر له ربط دور)">تعديل</button>
                        <div class="btn-group">
                            <button type="button" class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle erp-ur-toolbar-btn" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnBulkDelete">حذف المحدد</button></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف الجميع</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="UserRoles" class="d-inline-flex flex-nowrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="searchMode" value="@searchMode" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="dateField" value="@dateField" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_role)) { <input type="hidden" name="filterCol_role" value="@filterCol_role" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_primary)) { <input type="hidden" name="filterCol_primary" value="@filterCol_primary" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_assigned)) { <input type="hidden" name="filterCol_assigned" value="@filterCol_assigned" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.85rem;font-weight:500;" title="اختر صيغة التصدير">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm erp-ur-toolbar-btn">تصدير</button>
                        </form>
                    </div>
                    <form id="formBulkDelete" asp-action="BulkDelete" asp-controller="UserRoles" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <div id="bulkDeleteIdsContainer"></div>
                    </form>
                    <form id="formDeleteAll" asp-action="DeleteAll" asp-controller="UserRoles" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>

        </div>
    </div>

    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي السطور</div>
                    <div class="h4 mb-0 text-primary fw-bold">@total.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #15803d !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">المستخدمون بعد الفلترة</div>
                    <div class="h4 mb-0 text-success fw-bold">@usersCount.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #2563eb !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">الأسطر المسندة</div>
                    <div class="h4 mb-0 text-info fw-bold">@assignedCount.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #b45309 !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">الأدوار الافتراضية</div>
                    <div class="h4 mb-0 text-warning fw-bold">@primaryCount.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
    </div>

    @* ===== جدول UserRoles (حاوية تمرير + رأس ثابت + فلتر أعمدة + توسعة) ===== *@
    <div class="erp-table-scroll-container erp-list-table-after-summary mt-3 ps-0 pe-0" dir="rtl">
        <div id="urTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="urTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th class="text-center no-print" data-col="select" data-col-fixed="true" style="width:42px; min-width:42px;" title="تحديد">
                        <input type="checkbox" id="selectAll" class="form-check-input" aria-label="تحديد الكل" />
                    </th>
                    <th data-col="id">@filterableCol("id", "Id", "كود السطر")</th>
                    <th data-col="user">@filterableCol("user", "UserName", "المستخدم")</th>
                    <th data-col="role">@filterableCol("role", "RoleName", "الدور")</th>
                    <th data-col="primary">@filterableCol("primary", "IsPrimary", "دور افتراضي؟")</th>
                    <th data-col="assigned">@filterableCol("assigned", "AssignedAt", "تاريخ الإسناد")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var x in Model.Items)
                    {
                        var userDisplayName = string.IsNullOrWhiteSpace(x.DisplayName) ? x.UserName : x.DisplayName;
                        var hasAssignment = x.UserRoleId.HasValue;
                        var editUrlUr = hasAssignment && x.UserRoleId.HasValue
                            ? Url.Action("Edit", "UserRoles", new { id = x.UserRoleId.Value }) + "?frame=1"
                            : "";

                        <tr class="erp-list-selectable-row"
                            data-user-role-id="@(x.UserRoleId?.ToString() ?? "")"
                            data-edit-url="@editUrlUr"
                            data-edit-tab-title="تعديل إسناد الدور">
                            <td class="text-center no-print" data-col="select">
                                @if (hasAssignment)
                                {
                                    <input type="checkbox"
                                           class="form-check-input row-select"
                                           value="@x.UserRoleId" />
                                }
                                else
                                {
                                    <input type="checkbox"
                                           class="form-check-input row-select"
                                           value=""
                                           disabled
                                           title="لا يوجد سطر ربط للحذف — استخدم «إسناد دور»" />
                                }
                            </td>

                            <td data-col="id">@(x.UserRoleId?.ToString() ?? "—")</td>
                            <td data-col="user">@userDisplayName</td>
                            <td data-col="role">
                                @if (!hasAssignment)
                                {
                                    <span class="text-muted">@UserRoleListRow.NoRoleDisplay</span>
                                }
                                else if (!string.IsNullOrEmpty(x.RoleName))
                                {
                                    <text>@x.RoleName (كود: @x.RoleId)</text>
                                }
                                else if (x.RoleId.HasValue)
                                {
                                    <span class="text-muted">كود الدور: @x.RoleId</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td data-col="primary">
                                @(hasAssignment ? (x.IsPrimary ? "نعم" : "لا") : "—")
                            </td>
                            <td data-col="assigned">
                                @(x.AssignedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        </div>
    </div>

    @* لوحة فلتر الأعمدة *@
    <div id="erpColumnFilterPanelUR" class="erp-column-filter-panel d-none" dir="rtl">
        <div class="erp-column-filter-header">
            <span id="erpColumnFilterTitleUR">ترتيب وفلتر</span>
            <button type="button" class="btn-close btn-sm" id="erpColumnFilterCloseUR" aria-label="إغلاق"></button>
        </div>
        <div class="erp-column-filter-body">
            <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                <label class="form-label small mb-1 fw-bold">الترتيب:</label>
                <div class="d-flex flex-column gap-1">
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
                </div>
            </div>
            <div class="erp-filter-section">
                <div id="erpColumnFilterSearchRowUR">
                    <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                    <input type="text" id="erpColumnFilterSearchUR" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                </div>
                <div id="erpColumnFilterListUR" class="erp-column-filter-list">
                    <div class="text-muted text-center py-3">جاري التحميل...</div>
                </div>
            </div>
            <div class="erp-column-filter-actions">
                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOkUR">تطبيق</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClearUR">مسح الفلتر</button>
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-3 no-print" dir="rtl">
        <small class="text-muted">عرض @start - @end من @total</small>
        <form method="get" action="@Url.Action(action, controller)" class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="searchMode" value="@searchMode" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_role)) { <input type="hidden" name="filterCol_role" value="@filterCol_role" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_primary)) { <input type="hidden" name="filterCol_primary" value="@filterCol_primary" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_assigned)) { <input type="hidden" name="filterCol_assigned" value="@filterCol_assigned" /> }
            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
            </select>
        </form>
    </div>

    <nav class="pagination justify-content-center mt-3 no-print" dir="rtl" aria-label="pagination">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(page == first ? "disabled" : "")"><a class="page-link" href="@Link(first)">الأول</a></li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")"><a class="page-link" href="@Link(prev)">السابق</a></li>
            <li class="page-item disabled"><span class="page-link">صفحة @(page) من @(pages)</span></li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")"><a class="page-link" href="@Link(next)">التالي</a></li>
            <li class="page-item @(page == last ? "disabled" : "")"><a class="page-link" href="@Link(last)">الأخير</a></li>
        </ul>
    </nav>
</div>

@* Modal فلترة التاريخ/الوقت *@
<div class="modal fade no-print"
     id="dateFilterModalUR"
     tabindex="-1"
     aria-labelledby="dateFilterModalURLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalURLabel">
                    فلترة بالتاريخ والوقت (حسب تاريخ الإسناد)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="searchMode" value="@searchMode" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_role)) { <input type="hidden" name="filterCol_role" value="@filterCol_role" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_primary)) { <input type="hidden" name="filterCol_primary" value="@filterCol_primary" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_assigned)) { <input type="hidden" name="filterCol_assigned" value="@filterCol_assigned" /> }

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRangeUR"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRangeUR">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* Modal اختيار الأعمدة *@
<div class="modal fade no-print"
     id="columnsModalUR"
     tabindex="-1"
     aria-labelledby="columnsModalURLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalURLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
            </div>
            <div class="modal-body">
                <div id="columnsListUR"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsUR"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script>
        document.getElementById("btnPrintUR")?.addEventListener("click", function () { window.print(); });

        if (window.ERP && typeof ERP.initListSelection === "function") {
            ERP.initListSelection({
                rowSelector: "#urTable tbody tr.erp-list-selectable-row",
                idAttribute: "data-user-role-id",
                editUrlAttribute: "data-edit-url",
                editTabTitleAttribute: "data-edit-tab-title",
                editButtonId: "btnEditUserRole",
                editTabId: "userrole-edit-tab",
                multiSelectCheckboxes: true
            });
        }

        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanelUR',
            tableId: 'urTable',
            wrapperId: 'urTableScrollWrapper',
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "UserRoles")',
            numericColumns: ['id'],
            defaultSort: 'UserName',
            defaultDir: 'asc'
        });

        // التمرير لأقصى اليمين + مقابض توسعة الأعمدة
        (function () {
            function scrollToRight() {
                var wrapper = document.getElementById("urTableScrollWrapper");
                if (wrapper && wrapper.scrollWidth > wrapper.clientWidth)
                    wrapper.scrollLeft = wrapper.scrollWidth - wrapper.clientWidth;
            }
            scrollToRight();
            window.addEventListener("load", scrollToRight);

            document.addEventListener("DOMContentLoaded", function () {
                var wrapper = document.getElementById("urTableScrollWrapper");
                if (!wrapper) return;
                var table = document.getElementById("urTable");
                if (table) {
                    var ths = table.querySelectorAll("thead th");
                    ths.forEach(function (th) {
                        if (th.hasAttribute("data-col-fixed")) return;
                        th.style.position = "relative";
                        var handle = document.createElement("div");
                        handle.className = "erp-col-resize-handle";
                        th.appendChild(handle);
                        var startX, startWidth;
                        handle.addEventListener("mousedown", function (e) {
                            e.preventDefault();
                            startX = e.pageX;
                            startWidth = th.offsetWidth;
                            function onMouseMove(eMove) {
                                var diffX = eMove.pageX - startX;
                                var newWidth = startWidth + diffX;
                                if (newWidth < 50) newWidth = 50;
                                th.style.minWidth = newWidth + "px";
                                th.style.width = newWidth + "px";
                            }
                            function onMouseUp() {
                                document.removeEventListener("mousemove", onMouseMove);
                                document.removeEventListener("mouseup", onMouseUp);
                            }
                            document.addEventListener("mousemove", onMouseMove);
                            document.addEventListener("mouseup", onMouseUp);
                        });
                    });
                }
                scrollToRight();
            });
        })();

        // اختيار الأعمدة + حفظ في localStorage
        (function () {
            const table = document.getElementById("urTable");
            if (!table) return;

            const storageKey = "userroles-columns-visibility";
            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: (th.querySelector(".erp-col-title") && th.querySelector(".erp-col-title").textContent) || th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListUR");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_ur_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsUR")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalUR");
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // تحديد الكل + الحذف الجماعي + حذف الجميع
        (function () {
            const selectAll = document.getElementById("selectAll");
            const bulkBtn = document.getElementById("btnBulkDelete");
            const bulkForm = document.getElementById("formBulkDelete");
            const deleteAllBtn = document.getElementById("btnDeleteAll");
            const formDeleteAll = document.getElementById("formDeleteAll");
            const bulkDeleteIdsContainer = document.getElementById("bulkDeleteIdsContainer");

            function getRowCheckboxes() {
                return Array.from(document.querySelectorAll(".row-select:not([disabled])"));
            }

            selectAll?.addEventListener("change", function () {
                const checked = this.checked;
                getRowCheckboxes().forEach(cb => { cb.checked = checked; });
            });

            bulkBtn?.addEventListener("click", function () {
                const checks = getRowCheckboxes().filter(cb => cb.checked && cb.value);
                if (checks.length === 0) {
                    alert("من فضلك اختر على الأقل سطر واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف السطور المحددة؟")) {
                    return;
                }

                if (bulkDeleteIdsContainer) {
                    bulkDeleteIdsContainer.innerHTML = "";
                    checks.forEach(cb => {
                        const input = document.createElement("input");
                        input.type = "hidden";
                        input.name = "ids";
                        input.value = cb.value;
                        bulkDeleteIdsContainer.appendChild(input);
                    });
                }

                bulkForm?.submit();
            });

            deleteAllBtn?.addEventListener("click", function () {
                if (!confirm("هل أنت متأكد من حذف جميع أدوار المستخدمين؟")) {
                    return;
                }
                formDeleteAll?.submit();
            });
        })();

        // فلتر الكود من/إلى
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp = document.getElementById("codeFromInput");
            const toInp = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);

                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else url.searchParams.delete("fromCode");

                if (codeTo) url.searchParams.set("toCode", codeTo);
                else url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                const psParam = url.searchParams.get("pageSize");
                if (psParam) url.searchParams.set("pageSize", psParam);
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
