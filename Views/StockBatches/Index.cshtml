@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.StockBatch>

@{
    ViewData["Title"] = "Stock Batch (رصيد التشغيلات)";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "StockBatches";

    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "batchno";
    var searchMode = (string?)ViewBag.SearchMode ?? "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "id";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = (int?)ViewBag.PageSize ?? Model.PageSize;
    if (ps < 0) ps = 10;

    int total = Model.TotalCount;
    int page = Model.PageNumber;
    if (page <= 0) page = 1;

    int pages = Model.TotalPages;
    if (pages <= 0) pages = 1;

    int start = total == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
    int end = (ps == 0 || total == 0) ? total : Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_wh = ViewBag.FilterCol_Wh as string;
    string? filterCol_prod = ViewBag.FilterCol_Prod as string;
    string? filterCol_batchno = ViewBag.FilterCol_BatchNo as string;
    string? filterCol_expiry = ViewBag.FilterCol_Expiry as string;
    string? filterCol_qty = ViewBag.FilterCol_Qty as string;
    string? filterCol_reserved = ViewBag.FilterCol_Reserved as string;
    string? filterCol_updated = ViewBag.FilterCol_Updated as string;
    string? filterCol_note = ViewBag.FilterCol_Note as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_whExpr = ViewBag.FilterCol_WhExpr as string;
    string? filterCol_prodExpr = ViewBag.FilterCol_ProdExpr as string;
    string? filterCol_qtyExpr = ViewBag.FilterCol_QtyExpr as string;
    string? filterCol_reservedExpr = ViewBag.FilterCol_ReservedExpr as string;

    var prodNames = ViewBag.ProdNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var warehouseNames = ViewBag.WarehouseNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var weightedDiscounts = ViewBag.WeightedDiscounts as Dictionary<string, decimal> ?? new Dictionary<string, decimal>();

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_wh,
        filterCol_prod,
        filterCol_batchno,
        filterCol_expiry,
        filterCol_qty,
        filterCol_reserved,
        filterCol_updated,
        filterCol_note,
        filterCol_idExpr,
        filterCol_whExpr,
        filterCol_prodExpr,
        filterCol_qtyExpr,
        filterCol_reservedExpr
    })!;

    string? FilterForCol(string colKey) => colKey switch
    {
        "id" => filterCol_id,
        "wh" => filterCol_wh,
        "prod" => filterCol_prod,
        "batchno" => filterCol_batchno,
        "expiry" => filterCol_expiry,
        "qty" => filterCol_qty,
        "reserved" => filterCol_reserved,
        "updated" => filterCol_updated,
        "note" => filterCol_note,
        _ => null
    };

    string? FilterExprForCol(string colKey) => colKey switch
    {
        "id" => filterCol_idExpr,
        "wh" => filterCol_whExpr,
        "prod" => filterCol_prodExpr,
        "qty" => filterCol_qtyExpr,
        "reserved" => filterCol_reservedExpr,
        _ => null
    };

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        var hasFilter = !string.IsNullOrWhiteSpace(FilterForCol(colKey)) || !string.IsNullOrWhiteSpace(FilterExprForCol(colKey));
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">@ViewData["Title"]</h4>

        <small class="text-muted d-none d-md-inline">
            إجمالي الصفوف: @total
        </small>
    </div>

    @* ===== شريط الفلاتر الموحد (نمط القوائم) *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* القسم الأول: البحث العام *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في مخزون التشغيلات</label>
                    <div class="d-flex flex-wrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <select name="searchMode" class="form-select form-select-arrow erp-filter-input" style="max-width:110px;min-width:100px" title="نوع البحث في الحقول النصية">
                            <option value="starts"@Html.Raw(searchMode == "starts" ? " selected" : "")>يبدأ بـ</option>
                            <option value="contains"@Html.Raw(searchMode == "contains" || string.IsNullOrEmpty(searchMode) ? " selected" : "")>يحتوي</option>
                            <option value="ends"@Html.Raw(searchMode == "ends" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" style="min-width:140px;flex:1 1 140px" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:170px;min-width:120px">
                            <option value="batchno"@Html.Raw(searchBy == "batchno" ? " selected" : "")>رقم التشغيلة</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>كود السجل</option>
                            <option value="prod"@Html.Raw(searchBy == "prod" ? " selected" : "")>كود الصنف</option>
                            <option value="warehouse"@Html.Raw(searchBy == "warehouse" ? " selected" : "")>كود المخزن</option>
                            <option value="expiry"@Html.Raw(searchBy == "expiry" ? " selected" : "")>الصلاحية</option>
                            <option value="qty"@Html.Raw(searchBy == "qty" ? " selected" : "")>الكمية</option>
                            <option value="note"@Html.Raw(searchBy == "note" ? " selected" : "")>ملاحظة</option>
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>الكل</option>
                        </select>
                    </div>
                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-2 w-100">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_wh)) { <input type="hidden" name="filterCol_wh" value="@filterCol_wh" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prod)) { <input type="hidden" name="filterCol_prod" value="@filterCol_prod" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_batchno)) { <input type="hidden" name="filterCol_batchno" value="@filterCol_batchno" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_expiry)) { <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qty)) { <input type="hidden" name="filterCol_qty" value="@filterCol_qty" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_reserved)) { <input type="hidden" name="filterCol_reserved" value="@filterCol_reserved" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_note)) { <input type="hidden" name="filterCol_note" value="@filterCol_note" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_whExpr)) { <input type="hidden" name="filterCol_whExpr" value="@filterCol_whExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prodExpr)) { <input type="hidden" name="filterCol_prodExpr" value="@filterCol_prodExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyExpr)) { <input type="hidden" name="filterCol_qtyExpr" value="@filterCol_qtyExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_reservedExpr)) { <input type="hidden" name="filterCol_reservedExpr" value="@filterCol_reservedExpr" /> }
                </form>
            </div>

            @* القسم الثاني: فلتر الكود من/إلى *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                    <label class="form-label w-100 text-center">فلتر كود السجل</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من كود السجل" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى كود السجل" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* القسم الثالث: أزرار التحكم *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalStockBatch">
                            اختيار الأعمدة
                        </button>

                        <button type="button" id="btnStockBatchMovement" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="اختر صفاً في الجدول أولاً">حركة الصنف</button>

                        <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        <form method="get" asp-action="Export" asp-controller="StockBatches"
                              class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">

                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="searchMode" value="@searchMode" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />

                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_wh)) { <input type="hidden" name="filterCol_wh" value="@filterCol_wh" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_prod)) { <input type="hidden" name="filterCol_prod" value="@filterCol_prod" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_batchno)) { <input type="hidden" name="filterCol_batchno" value="@filterCol_batchno" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_expiry)) { <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_qty)) { <input type="hidden" name="filterCol_qty" value="@filterCol_qty" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_reserved)) { <input type="hidden" name="filterCol_reserved" value="@filterCol_reserved" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_note)) { <input type="hidden" name="filterCol_note" value="@filterCol_note" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_whExpr)) { <input type="hidden" name="filterCol_whExpr" value="@filterCol_whExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_prodExpr)) { <input type="hidden" name="filterCol_prodExpr" value="@filterCol_prodExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_qtyExpr)) { <input type="hidden" name="filterCol_qtyExpr" value="@filterCol_qtyExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_reservedExpr)) { <input type="hidden" name="filterCol_reservedExpr" value="@filterCol_reservedExpr" /> }

                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;padding:0.3rem 0.5rem;" title="اختر صيغة التصدير">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>

    @* نموذج خفي لتطبيق فلتر الأعمدة *@
    <form id="stockBatchesSearchForm" method="get" action="@Url.Action(action, controller)" class="d-none">
        <input type="hidden" name="search" value="@search" />
        <input type="hidden" name="searchBy" value="@searchBy" />
        <input type="hidden" name="searchMode" value="@searchMode" />
        <input type="hidden" name="sort" value="@sort" />
        <input type="hidden" name="dir" value="@dir" />
        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="pageSize" value="@ps" />
        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
        @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
        @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
        @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
        @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_wh)) { <input type="hidden" name="filterCol_wh" value="@filterCol_wh" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_prod)) { <input type="hidden" name="filterCol_prod" value="@filterCol_prod" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_batchno)) { <input type="hidden" name="filterCol_batchno" value="@filterCol_batchno" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_expiry)) { <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_qty)) { <input type="hidden" name="filterCol_qty" value="@filterCol_qty" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_reserved)) { <input type="hidden" name="filterCol_reserved" value="@filterCol_reserved" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_note)) { <input type="hidden" name="filterCol_note" value="@filterCol_note" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_whExpr)) { <input type="hidden" name="filterCol_whExpr" value="@filterCol_whExpr" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_prodExpr)) { <input type="hidden" name="filterCol_prodExpr" value="@filterCol_prodExpr" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_qtyExpr)) { <input type="hidden" name="filterCol_qtyExpr" value="@filterCol_qtyExpr" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_reservedExpr)) { <input type="hidden" name="filterCol_reservedExpr" value="@filterCol_reservedExpr" /> }
    </form>

    @* جدول StockBatch *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0">
        <div id="stockBatchesScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="stockBatchesTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    <th data-col="id">@filterableCol("id", "id", "كود السجل")</th>
                    <th data-col="wh">@filterableCol("wh", "warehouse", "اسم المخزن")</th>
                    <th data-col="prod">@filterableCol("prod", "prod", "كود الصنف")</th>
                    <th data-col="prodname">اسم الصنف</th>
                    <th data-col="wdisc">الخصم المرجح %</th>
                    <th data-col="batchno">@filterableCol("batchno", "batchno", "رقم التشغيلة")</th>
                    <th data-col="expiry">@filterableCol("expiry", "expiry", "الصلاحية")</th>
                    <th data-col="qty">@filterableCol("qty", "onhand", "المتاح")</th>
                    <th data-col="reserved">@filterableCol("reserved", "reserved", "محجوز")</th>
                    <th data-col="updated">@filterableCol("updated", "updated", "آخر تعديل")</th>
                    <th data-col="note">@filterableCol("note", "note", "ملاحظة")</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Items == null || !Model.Items.Any())
                {
                    <tr>
                        <td colspan="12" class="text-center text-muted py-4">لا توجد بيانات.</td>
                    </tr>
                }
                else
                {
                    foreach (var x in Model.Items)
                    {
                        var whName = warehouseNames.TryGetValue(x.WarehouseId, out var w) ? w : x.WarehouseId.ToString();
                        var prodName = prodNames.TryGetValue(x.ProdId, out var p) ? p : x.ProdId.ToString();
                        var wdKey = $"{x.ProdId}|{x.WarehouseId}";
                        weightedDiscounts.TryGetValue(wdKey, out var wdisc);
                        var movementUrl = Url.Action("Show", "Products", new { id = x.ProdId }) + "?frame=1";

                        <tr class="erp-list-selectable-row"
                            data-sb-row="1"
                            data-row-id="@x.ProdId"
                            data-prod-id="@x.ProdId"
                            data-movement-url="@movementUrl">
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox" class="row-select" value="@x.Id" />
                            </td>

                            <td data-col="id">@x.Id</td>
                            <td data-col="wh">@whName</td>
                            <td data-col="prod">@x.ProdId</td>
                            <td data-col="prodname">@prodName</td>
                            <td data-col="wdisc">@wdisc.ToString("N2")</td>
                            <td data-col="batchno">@x.BatchNo</td>
                            <td data-col="expiry">@((x.Expiry.HasValue) ? x.Expiry.Value.ToString("yyyy/MM/dd") : "")</td>
                            <td data-col="qty">@x.QtyOnHand</td>
                            <td data-col="reserved">@x.QtyReserved</td>
                            <td data-col="updated">@x.UpdatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                            <td data-col="note">@(x.Note ?? "")</td>
                        </tr>
                    }

                    <tr class="table-secondary fw-bold">
                        <td colspan="12" class="text-end">عدد الصفوف (حسب الفلتر الحالي): <strong>@total</strong></td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>

    @* لوحة فلتر الأعمدة (بنمط Excel) *@
    <div id="erpColumnFilterPanel" class="erp-column-filter-panel d-none" dir="rtl">
        <div class="erp-column-filter-header">
            <span id="erpColumnFilterTitle">ترتيب وفلتر</span>
            <button type="button" class="btn-close btn-sm" id="erpColumnFilterClose" aria-label="إغلاق"></button>
        </div>
        <div class="erp-column-filter-body">
            <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                <label class="form-label small mb-1 fw-bold">الترتيب:</label>
                <div class="d-flex flex-column gap-1">
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
                </div>
            </div>
            <div class="erp-filter-section">
                <div id="erpColumnFilterSearchRow">
                    <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                    <input type="text" id="erpColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                </div>
                <div id="erpColumnFilterList" class="erp-column-filter-list">
                    <div class="text-muted text-center py-3">جاري التحميل...</div>
                </div>
            </div>
            <div class="erp-column-filter-actions">
                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOk">تطبيق</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClear">مسح الفلتر</button>
            </div>
        </div>
    </div>

    @* الشريط السفلي + الترقيم (محاذاة يمين — نمط القوائم) *@
    <div class="d-flex flex-wrap justify-content-end align-items-center gap-3 mt-2 no-print" dir="rtl">
        <form method="get" action="@Url.Action(action, controller)" class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="searchMode" value="@searchMode" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />

            @if (fromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
            }
            @if (toDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }

            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_wh)) { <input type="hidden" name="filterCol_wh" value="@filterCol_wh" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_prod)) { <input type="hidden" name="filterCol_prod" value="@filterCol_prod" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_batchno)) { <input type="hidden" name="filterCol_batchno" value="@filterCol_batchno" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_expiry)) { <input type="hidden" name="filterCol_expiry" value="@filterCol_expiry" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_qty)) { <input type="hidden" name="filterCol_qty" value="@filterCol_qty" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_reserved)) { <input type="hidden" name="filterCol_reserved" value="@filterCol_reserved" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_note)) { <input type="hidden" name="filterCol_note" value="@filterCol_note" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_whExpr)) { <input type="hidden" name="filterCol_whExpr" value="@filterCol_whExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_prodExpr)) { <input type="hidden" name="filterCol_prodExpr" value="@filterCol_prodExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_qtyExpr)) { <input type="hidden" name="filterCol_qtyExpr" value="@filterCol_qtyExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_reservedExpr)) { <input type="hidden" name="filterCol_reservedExpr" value="@filterCol_reservedExpr" /> }

            <small class="text-muted me-1">عرض @start - @end من @total</small>
            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize" class="form-select form-select-sm" style="width:auto;min-width:5rem;" onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
            </select>
        </form>
    </div>

    @* الترقيم *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-end">
            <li class="page-item @(page == first ? "disabled" : "")"><a class="page-link" href="@Link(first)">الأول</a></li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")"><a class="page-link" href="@Link(prev)">السابق</a></li>
            <li class="page-item disabled"><span class="page-link">صفحة @(page) من @(pages)</span></li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")"><a class="page-link" href="@Link(next)">التالي</a></li>
            <li class="page-item @(page == last ? "disabled" : "")"><a class="page-link" href="@Link(last)">الأخير</a></li>
        </ul>
    </nav>
</div>

@* Modal اختيار الأعمدة *@
<div class="modal fade no-print" id="columnsModalStockBatch" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1">اختيار الأعمدة الظاهرة</h5>
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListStockBatch"></div>
            </div>
            <div class="modal-footer">
                <button type="button" id="btnApplyColumnsStockBatch" class="btn btn-erp btn-erp-primary">تطبيق</button>
                <button type="button" class="btn btn-erp btn-erp-secondary" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script>
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        (function () {
            const table = document.getElementById("stockBatchesTable");
            if (!table) return;
            const chkAll = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");
            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => { cb.checked = chkAll.checked; });
            });
            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });
        })();

        (function () {
            const wrap = document.getElementById("stockBatchesScrollWrapper");
            if (!wrap) return;
            function scrollHorizontalToRight() {
                var maxScroll = wrap.scrollWidth - wrap.clientWidth;
                if (maxScroll > 0) wrap.scrollLeft = maxScroll;
            }
            requestAnimationFrame(function () { requestAnimationFrame(scrollHorizontalToRight); });
        })();

        (function () {
            const table = document.getElementById("stockBatchesTable");
            if (!table) return;
            const storageKey = "stockbatches-columns-v2";
            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({ key: th.getAttribute("data-col"), title: th.innerText.replace(/\s+/g, " ").trim() }));
            if (columns.length === 0) return;
            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }
            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => cell.classList.toggle("d-none", isHidden));
                });
            }
            applyVisibility();
            const listContainer = document.getElementById("columnsListStockBatch");
            if (listContainer) {
                listContainer.innerHTML = "";
                const selectAllWrap = document.createElement("div");
                selectAllWrap.className = "form-check mb-2 border-bottom pb-2";
                const selectAllId = "sb_col_select_all";
                selectAllWrap.innerHTML = '<input type="checkbox" class="form-check-input ms-2" id="' + selectAllId + '" checked><label class="form-check-label fw-bold" for="' + selectAllId + '">اختيار الكل</label>';
                listContainer.appendChild(selectAllWrap);
                const selectAllCb = document.getElementById(selectAllId);
                columns.forEach(col => {
                    const id = "sb_col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";
                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;
                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;
                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
                function syncSelectAll() {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    if (!selectAllCb || !checks.length) return;
                    const allOn = Array.from(checks).every(c => c.checked);
                    selectAllCb.checked = allOn;
                    selectAllCb.indeterminate = !allOn && Array.from(checks).some(c => c.checked);
                }
                selectAllCb?.addEventListener("change", function () {
                    const on = this.checked;
                    listContainer.querySelectorAll("input[type='checkbox'][data-col-key]").forEach(c => { c.checked = on; });
                });
                listContainer.querySelectorAll("input[type='checkbox'][data-col-key]").forEach(c => {
                    c.addEventListener("change", syncSelectAll);
                });
                syncSelectAll();
            }
            document.getElementById("btnApplyColumnsStockBatch")?.addEventListener("click", function () {
                const listContainer = document.getElementById("columnsListStockBatch");
                const checks = listContainer?.querySelectorAll("input[type='checkbox'][data-col-key]") || [];
                hidden = [];
                checks.forEach(cb => {
                    if (!cb.checked) hidden.push(cb.dataset.colKey);
                });
                try { localStorage.setItem(storageKey, JSON.stringify(hidden)); } catch { }
                applyVisibility();
                const modalEl = document.getElementById("columnsModalStockBatch");
                const modal = bootstrap.Modal.getInstance(modalEl);
                modal?.hide();
            });
        })();

        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp = document.getElementById("codeFromInput");
            const toInp = document.getElementById("codeToInput");
            const defaultPs = "@ps";

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else url.searchParams.delete("fromCode");
                if (codeTo) url.searchParams.set("toCode", codeTo);
                else url.searchParams.delete("toCode");
                url.searchParams.set("page", "1");
                if (!url.searchParams.get("pageSize"))
                    url.searchParams.set("pageSize", defaultPs);
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = (fromInp?.value || "").trim();
                const ct = (toInp?.value || "").trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                if (fromInp) fromInp.value = "";
                if (toInp) toInp.value = "";
                const url = new URL(window.location.href);
                url.searchParams.delete("fromCode");
                url.searchParams.delete("toCode");
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            });
        })();

        document.addEventListener("DOMContentLoaded", function () {
            if (window.ERP && typeof ERP.initListColumnFilter === "function") {
                ERP.initListColumnFilter({
                    panelId: "erpColumnFilterPanel",
                    tableId: "stockBatchesTable",
                    wrapperId: "stockBatchesScrollWrapper",
                    getColumnValuesUrl: '@Url.Action("GetColumnValues", "StockBatches")',
                    defaultSort: "id",
                    defaultDir: "asc",
                    numericColumns: ["id", "wh", "prod", "qty", "reserved"]
                });
            }
            if (window.ERP && typeof ERP.initListSelection === "function") {
                ERP.initListSelection({
                    rowSelector: "tr[data-sb-row].erp-list-selectable-row",
                    movementButtonId: "btnStockBatchMovement",
                    movementUrlAttribute: "data-movement-url",
                    movementTabId: "product-movement-tab",
                    movementTabTitle: "حركة الصنف",
                    idAttribute: "data-prod-id"
                });
            }
        });
    </script>
}
