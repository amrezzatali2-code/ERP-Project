@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.StockBatch>

@{
    ViewData["Title"] = "Stock Batch (رصيد التشغيلات)";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "StockBatches";

    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "batchno";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "expiry";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    // =========================
    // ✅ أمان للـ Paging
    // =========================
    int ps = Model.PageSize;
    if (ps <= 0) ps = 25;

    int total = Model.TotalCount;
    int page = Model.PageNumber;
    if (page <= 0) page = 1;

    int pages = Model.TotalPages;
    if (pages <= 0) pages = 1;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    // خرائط أسماء (اختيارية) جاية من الكنترولر لو موجودة
    // لو مش موجودة هنرجّع الأكواد بدل الأسماء
    var prodMap = ViewBag.ProdMap as Dictionary<int, string> ?? new Dictionary<int, string>();
    var whMap = ViewBag.WhMap as Dictionary<int, string> ?? new Dictionary<int, string>();

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        fromCode,
        toCode
    })!;

    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var safePageSize = ps <= 0 ? 25 : ps;

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = safePageSize,
            useDateRange,
            fromDate,
            toDate,
            fromCode,
            toCode
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };
}

<div dir="rtl" class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">@ViewData["Title"]</h4>

        <small class="text-muted d-none d-md-inline">
            إجمالي الصفوف: @total
        </small>
    </div>

    @* الكارت العلوي: بحث + فلتر كود + أزرار *@
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* البحث *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث</label>
                        </div>

                        <div class="col-sm-7">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-5">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                <option value="batchno" selected="@(searchBy == "batchno" ? "selected" : null)">رقم التشغيلة</option>
                                <option value="id" selected="@(searchBy == "id" ? "selected" : null)">كود السجل</option>
                                <option value="prod" selected="@(searchBy == "prod" ? "selected" : null)">كود الصنف</option>
                                <option value="wh" selected="@(searchBy == "wh" ? "selected" : null)">كود المخزن</option>
                                <option value="expiry" selected="@(searchBy == "expiry" ? "selected" : null)">الصلاحية</option>
                                <option value="qty" selected="@(searchBy == "qty" ? "selected" : null)">الكمية</option>
                                <option value="note" selected="@(searchBy == "note" ? "selected" : null)">ملاحظة</option>
                                <option value="all" selected="@(searchBy == "all" ? "selected" : null)">الكل</option>
                            </select>
                        </div>

                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />

                        @if (fromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                        }
                        @if (toDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                        }
                        @if (fromCode.HasValue)
                        {
                            <input type="hidden" name="fromCode" value="@fromCode" />
                        }
                        @if (toCode.HasValue)
                        {
                            <input type="hidden" name="toCode" value="@toCode" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">بحث</button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm" href="@Url.Action(action, controller)">إلغاء</a>
                        </div>
                    </form>
                </div>

                @* فلتر كود من/إلى *@
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-semibold">من كود</span>
                        <input id="codeFromInput" type="number" class="form-control form-control-sm" style="width:110px"
                               value="@(fromCode?.ToString() ?? "")" />

                        <span class="fw-semibold">إلى كود</span>
                        <input id="codeToInput" type="number" class="form-control form-control-sm" style="width:110px"
                               value="@(toCode?.ToString() ?? "")" />

                        <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق فلتر الكود</button>
                        <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                    </div>
                </div>

                @* أزرار *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalStockBatch">
                            اختيار الأعمدة
                        </button>

                        <form id="bulkDeleteForm" asp-action="BulkDelete" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            @* مهم: خلينا الاسم ids علشان يقبل int[] ids بسهولة *@
                            <input type="hidden" name="ids" id="selectedIdsInput" />
                            <button type="button" id="btnDeleteSelected" class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف المحدد
                            </button>
                        </form>

                        <form id="deleteAllForm" asp-action="DeleteAll" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="button" id="btnDeleteAll" class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف الكل
                            </button>
                        </form>

                        <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        <form method="get" asp-action="Export" asp-controller="StockBatches"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />

                            @if (fromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                            }
                            @if (toDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                            }
                            @if (fromCode.HasValue)
                            {
                                <input type="hidden" name="fromCode" value="@fromCode" />
                            }
                            @if (toCode.HasValue)
                            {
                                <input type="hidden" name="toCode" value="@toCode" />
                            }

                            <select name="format" class="form-select form-select-sm" style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">تصدير</button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

    @* جدول StockBatch *@
    <div class="erp-table-wrapper erp-print-area">
        <table id="stockBatchesTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    <th data-col="id">@sortLink("id", "الكود")</th>
                    <th data-col="wh">@sortLink("wh", "المخزن")</th>
                    <th data-col="prod">@sortLink("prod", "الصنف")</th>
                    <th data-col="batchno">رقم التشغيلة</th>
                    <th data-col="expiry">@sortLink("expiry", "الصلاحية")</th>
                    <th data-col="qty">@sortLink("qty", "المتاح")</th>
                    <th data-col="reserved">محجوز</th>
                    <th data-col="updated">@sortLink("updated", "آخر تعديل")</th>
                    <th data-col="note">ملاحظة</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Items == null || !Model.Items.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted py-4">لا توجد بيانات.</td>
                    </tr>
                }
                else
                {
                    foreach (var x in Model.Items)
                    {
                        // اسم المخزن / الصنف من الخرائط (لو موجودة) وإلا الأكواد
                        var whName = whMap.TryGetValue(x.WarehouseId, out var w) ? w : x.WarehouseId.ToString();
                        var prodName = prodMap.TryGetValue(x.ProdId, out var p) ? p : x.ProdId.ToString();

                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox" class="row-select" value="@x.Id" />
                            </td>

                            <td data-col="id">@x.Id</td>
                            <td data-col="wh">@whName</td>
                            <td data-col="prod">@prodName</td>
                            <td data-col="batchno">@x.BatchNo</td>
                            <td data-col="expiry">@((x.Expiry.HasValue) ? x.Expiry.Value.ToString("yyyy/MM/dd") : "")</td>
                            <td data-col="qty">@x.QtyOnHand</td>
                            <td data-col="reserved">@x.QtyReserved</td>
                            <td data-col="updated">@x.UpdatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                            <td data-col="note">@(x.Note ?? "")</td>
                        </tr>
                    }

                    <tr class="table-secondary fw-bold">
                        <td colspan="9" class="text-end">عدد الصفوف (حسب الفلتر الحالي):</td>
                        <td class="text-end">@total</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* الشريط السفلي *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">عرض @start - @end من @total</small>

        <form method="get" action="@Url.Action(action, controller)" class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />

            @if (fromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
            }
            @if (toDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="25" selected="@(ps == 25 ? "selected" : null)">25</option>
                <option value="50" selected="@(ps == 50 ? "selected" : null)">50</option>
                <option value="100" selected="@(ps == 100 ? "selected" : null)">100</option>
                <option value="200" selected="@(ps == 200 ? "selected" : null)">200</option>
            </select>
        </form>
    </div>

    @* الترقيم *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")"><a class="page-link" href="@Link(first)">الأول</a></li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")"><a class="page-link" href="@Link(prev)">السابق</a></li>
            <li class="page-item disabled"><span class="page-link">صفحة @(page) من @(pages)</span></li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")"><a class="page-link" href="@Link(next)">التالي</a></li>
            <li class="page-item @(page == last ? "disabled" : "")"><a class="page-link" href="@Link(last)">الأخير</a></li>
        </ul>
    </nav>
</div>

@* Modal اختيار الأعمدة *@
<div class="modal fade no-print" id="columnsModalStockBatch" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1">اختيار الأعمدة الظاهرة</h5>
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListStockBatch"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-erp btn-erp-secondary" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" id="btnApplyColumnsStockBatch" class="btn btn-erp btn-erp-primary">تطبيق</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // زر الطباعة
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // تحديد الصفوف / حذف المحدد / حذف الكل
        (function () {
            const table = document.getElementById("stockBatchesTable");
            if (!table) return;

            const chkAll = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected");
            const bulkForm = document.getElementById("bulkDeleteForm");
            const selectedInput = document.getElementById("selectedIdsInput");

            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل صف واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف الصفوف المحددة؟")) return;

                // مهم: لو الأكشن يستقبل int[] ids
                // بنبعتها كـ ids=1&ids=2... الأفضل
                // لكن بما أننا مستخدمين hidden واحد: نخليها CSV ونفكها في الكنترولر لو محتاج
                // أو ببساطة غيّر الكنترولر ليستقبل string idsCsv ويعمل Split.
                selectedInput.value = ids.join(",");

                bulkForm.submit();
            });

            const btnDeleteAll = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("deleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع البيانات. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // اختيار الأعمدة + localStorage
        (function () {
            const table = document.getElementById("stockBatchesTable");
            if (!table) return;

            const storageKey = "stockbatches-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({ key: th.getAttribute("data-col"), title: th.innerText.trim() }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => cell.classList.toggle("d-none", isHidden));
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListStockBatch");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "sb_col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsStockBatch")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try { localStorage.setItem(storageKey, JSON.stringify(hidden)); } catch { }
                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalStockBatch");
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // فلتر الكود من/إلى
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp = document.getElementById("codeFromInput");
            const toInp = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);

                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else url.searchParams.delete("fromCode");

                if (codeTo) url.searchParams.set("toCode", codeTo);
                else url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");

                if (!url.searchParams.get("pageSize"))
                    url.searchParams.set("pageSize", "@ps");

                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = (fromInp?.value || "").trim();
                const ct = (toInp?.value || "").trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                if (fromInp) fromInp.value = "";
                if (toInp) toInp.value = "";

                const url = new URL(window.location.href);
                url.searchParams.delete("fromCode");
                url.searchParams.delete("toCode");
                url.searchParams.set("page", "1");

                window.location.href = url.toString();
            });
        })();
    </script>
}
