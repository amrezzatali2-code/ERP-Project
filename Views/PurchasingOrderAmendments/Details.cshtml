@model ERP.Models.PurchasingOrderAmendment
@{
    ViewData["Title"] = "تفاصيل سجل التأكيد/التعديل";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container-fluid mt-3" dir="rtl">
    <h4 class="mb-3">@ViewData["Title"]</h4>
    <dl class="row">
        <dt class="col-sm-3">كود</dt><dd class="col-sm-9">@Model.Id</dd>
        <dt class="col-sm-3">طلب الشراء</dt><dd class="col-sm-9">@Model.PurchasingOrderId</dd>
        <dt class="col-sm-3">نوع التعديل</dt><dd class="col-sm-9">@Model.AmendmentType</dd>
        <dt class="col-sm-3">تاريخ التعديل</dt><dd class="col-sm-9">@Model.AmendmentDate.ToString("yyyy-MM-dd HH:mm")</dd>
        <dt class="col-sm-3">ملاحظات</dt><dd class="col-sm-9">@Model.Notes</dd>
        <dt class="col-sm-3">تاريخ الإنشاء</dt><dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    </dl>
    <a asp-action="Index" class="btn btn-erp btn-erp-secondary">العودة للقائمة</a>
</div>
