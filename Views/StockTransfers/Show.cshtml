@using Microsoft.AspNetCore.Mvc.Rendering
@using System.Net
@model ERP.Models.StockTransfer

@{
    ViewData["Title"] = Model.Id == 0
        ? "تحويل مخزني جديد"
        : $"تحويل مخزني — رقم {Model.Id}";
    var stLines = Model.Lines?.OrderBy(l => l.LineNo).ToList() ?? new List<StockTransferLine>();
    var stLineCount = stLines.Count;
    var stDistinctItems = stLines.Select(l => l.ProductId).Distinct().Count();
    var stTotalQtyD = stLines.Sum(l => (decimal)l.Qty);
    var stTotalCostD = stLines.Sum(l => l.Qty * l.UnitCost);
    var stTotalRetailD = stLines.Sum(l => l.Qty * (l.PriceRetail ?? 0m));
}

@section Styles {
    <link rel="stylesheet" href="~/css/invoice-cards.css" />
    <style>
        .invoice-page.transfer-page {
            background-color: #f3f6fb;
            min-height: 100vh;
            padding-bottom: 2rem;
        }
        .invoice-page.transfer-page .container-fluid { max-width: 100%; }
        div.card.invoice-side-card,
        div.card.invoice-header-card,
        div.card.invoice-Add-card,
        div.card.invoice-lines-card,
        div.card.invoice-totals-card {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
            overflow: hidden;
        }
        .invoice-header-card .invoice-card-line,
        .invoice-Add-card .invoice-card-line,
        .invoice-lines-card .invoice-card-line,
        .invoice-totals-card .invoice-card-line {
            height: 3px;
            background: linear-gradient(90deg, #6366f1, #0ea5e9);
        }
        #ST_BodyHost .invoice-totals-card .invoice-summary-item.invoice-summary-box {
            border: 1px solid #94a3b8 !important;
            border-radius: 10px !important;
            padding: 0.5rem 0.75rem !important;
            min-width: 7rem;
        }
        .si-print-dropdown-menu {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 8px 28px rgba(99, 102, 241, 0.22) !important;
        }
        .st-add-row .pi-input[type="number"]::-webkit-outer-spin-button,
        .st-add-row .pi-input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        .st-add-row .pi-input[type="number"] { -moz-appearance: textfield; }
        input[type="date"],
        input[type="datetime-local"],
        input[type="time"] { direction: ltr !important; text-align: left !important; }
        input[type="date"]::-webkit-calendar-picker-indicator,
        input[type="datetime-local"]::-webkit-calendar-picker-indicator { cursor: pointer; }
        #TransferLinesTbody tr.erp-list-selectable-row { cursor: pointer; }
        #TransferLinesTbody tr.table-active { outline: 2px solid #6366f1; outline-offset: -2px; }
        /* بوكس اسم الصنف — مطابقة فاتورة المبيعات (حدود بنفسجي + قائمة fixed) */
        #ST_BodyHost .invoice-Add-card .card-body { overflow: visible !important; }
        #ST_BodyHost .invoice-Add-card #stProductDropdownWrap {
            border: 2px solid #4f46e5 !important;
            border-radius: 0.55rem !important;
            padding: 3px !important;
        }
        #ST_BodyHost .invoice-Add-card #stProductDropdownWrap:focus-within {
            border-color: #4338ca !important;
            box-shadow: none !important;
        }
        #ST_BodyHost .invoice-Add-card #stProductDropdownWrap .product-dropdown-onebox {
            border: 0 !important;
            background: transparent !important;
            border-radius: 0.45rem !important;
        }
        #ST_BodyHost .invoice-Add-card #stProductDropdownWrap .product-dropdown-onebox:focus-within {
            box-shadow: none !important;
            border-color: transparent !important;
        }
        #ST_BodyHost .invoice-Add-card #ProdNameInput.pi-product-name-input,
        #ST_BodyHost .invoice-Add-card #ProdNameInput.product-dropdown-input {
            border: 0 !important;
            border-radius: 0.55rem;
            background: transparent !important;
        }
        .transfer-page .product-dropdown-onebox {
            position: relative;
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
            background: #fff;
        }
        .transfer-page .product-dropdown-arrow-inside {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #495057;
            cursor: pointer;
            user-select: none;
            font-size: 0.6rem;
            z-index: 1;
        }
        .transfer-page .product-dropdown-arrow-inside:hover { background-color: #e9ecef; }
        .transfer-page .product-dropdown-onebox .product-dropdown-input {
            width: 100%;
            border: none !important;
            background: transparent !important;
            padding-left: 2.25rem !important;
        }
        .transfer-page .product-dropdown-onebox .product-dropdown-input:focus {
            box-shadow: none !important;
            outline: none !important;
        }
        .transfer-page .product-dropdown-list {
            position: fixed !important;
            max-height: 220px;
            min-height: 40px;
            overflow-y: auto;
            z-index: 10060;
            margin-top: 2px;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            background: #fff;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        }
        .transfer-page .product-dropdown-list[data-open="false"] { display: none !important; }
        .transfer-page .product-dropdown-list[data-open="true"] { display: block !important; }
        .transfer-page .product-dropdown-item {
            cursor: pointer;
            border-bottom: 1px solid #f0f0f0;
        }
        .transfer-page .product-dropdown-item:hover { background-color: #f8f9fa; }
        .transfer-page .product-dropdown-item:last-child { border-bottom: none; }
        .transfer-page .product-dropdown-item-active {
            background-color: #0d6efd !important;
            color: #fff !important;
        }
    </style>
}

<div class="invoice-page transfer-page" dir="rtl">
    <div class="container-fluid pt-3">
        <form id="__AntiForgeryForm" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>

        <div class="row g-3">
            @* العمود الجانبي *@
            <div class="col-12 col-lg-2 order-1 order-lg-2">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات التحويل المخزني</h6>
                    </div>

                    <input type="hidden" id="TransferId" value="@Model.Id" />
                    <input type="hidden" id="TransferIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />
                    <input type="hidden" id="SelectedLineId" value="" />

                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">
                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button" id="btnFirstTransfer" class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>⏮</button>
                            <button type="button" id="btnPrevTransfer" class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>◀</button>
                            <button type="button" id="btnNextTransfer" class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>▶</button>
                            <button type="button" id="btnLastTransfer" class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>⏭</button>
                        </div>

                        <hr class="my-1" />

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm w-100"
                           asp-action="Show"
                           asp-route-id="0"
                           asp-route-frame="1">
                            ➕ تحويل جديد
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnSaveTransferHeader"
                                data-lock-posted="1">
                            💾 حفظ التحويل
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnPostTransfer"
                                data-lock-posted="1">
                            📤 ترحيل التحويل
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnOpenTransfer">
                            ⏪ فتح التحويل
                        </button>

                        <div class="dropdown w-100 st-print-dropdown">
                            <button type="button" id="btnPrintTransferDropdown"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100 dropdown-toggle si-print-dropdown-btn"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    disabled
                                    title="يتاح بعد ترحيل التحويل">
                                🖨️ طباعة التحويل
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end w-100 si-print-dropdown-menu" aria-labelledby="btnPrintTransferDropdown">
                                <li class="si-print-dropdown-header px-3 py-2 small text-muted border-bottom mb-0">اختر نوع الطباعة</li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-st-print-mode="1"><span class="si-print-opt-icon" aria-hidden="true">📄</span><span class="si-print-opt-text">طباعة صفحة واحدة</span></a></li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-st-print-mode="2"><span class="si-print-opt-icon" aria-hidden="true">📑</span><span class="si-print-opt-text">طباعة أصل وصورة</span></a></li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-st-print-mode="3"><span class="si-print-opt-icon" aria-hidden="true">📚</span><span class="si-print-opt-text">طباعة أصل وصورتين</span></a></li>
                            </ul>
                        </div>

                        <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                           href="#"
                           id="btnProductMovement"
                           data-lock-posted="1"
                           title="حركة الصنف داخل النظام">
                            📊 حركة الصنف
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnDeleteSelectedLine"
                                disabled
                                title="يُفعّل بعد اختيار سطر من الجدول">
                            🗑️ مسح السطر المحدد
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnClearTransferLines"
                                data-lock-posted="1">
                            🗑️ مسح كل السطور
                        </button>
                    </div>
                </div>
            </div>

            @* العمود الرئيسي — كتلة واحدة بنمط فاتورة المبيعات *@
            <div class="col-12 col-lg-10 order-2 order-lg-1">
                <div id="ST_BodyHost">
                @* كارت بيانات التحويل *@
                <div class="card shadow-sm mb-2 invoice-header-card">
                    <div class="invoice-card-line"></div>
                    <div class="card-body pt-3">
                        <h5 class="mb-3 fw-semibold text-secondary border-bottom pb-2">تحويل مخزني</h5>
                        <div>
                            <div class="row g-3 align-items-end">
                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">رقم التحويل</label>
                                    <input id="TransferNumberDisplay" class="form-control form-control-sm text-center" value="@(Model.Id > 0 ? Model.Id.ToString() : "")" readonly />
                                </div>

                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">تاريخ التحويل</label>
                                    <input id="TransferDateInput" type="datetime-local" class="form-control form-control-sm" value="@Model.TransferDate.ToString("yyyy-MM-ddTHH:mm")" data-lock-posted="1" dir="ltr" style="text-align: left;" />
                                </div>

                                <div class="col-lg-3">
                                    <label class="form-label form-label-sm">من مخزن</label>
                                    <select asp-for="FromWarehouseId" asp-items="@(ViewData["FromWarehouseId"] as SelectList)" class="form-select form-select-sm" data-lock-posted="1">
                                        <option value="">اختر المخزن المصدر</option>
                                    </select>
                                </div>

                                <div class="col-lg-3">
                                    <label class="form-label form-label-sm">إلى مخزن</label>
                                    <select asp-for="ToWarehouseId" asp-items="@(ViewData["ToWarehouseId"] as SelectList)" class="form-select form-select-sm" data-lock-posted="1">
                                        <option value="">اختر المخزن الوجهة</option>
                                    </select>
                                </div>

                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">الحالة</label>
                                    <input id="TransferStatusDisplay" class="form-control form-control-sm text-center" value="@(string.IsNullOrWhiteSpace(Model.Status) ? "مسودة" : Model.Status)" readonly />
                                </div>
                            </div>

                            <div class="row g-3 mt-2">
                                <div class="col-12">
                                    <label class="form-label form-label-sm">ملاحظات</label>
                                    <textarea asp-for="Note" class="form-control form-control-sm" rows="2" data-lock-posted="1"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* كارت إدخال السطر *@
                <div class="card shadow-sm mb-2 invoice-Add-card">
                    <div class="invoice-card-line"></div>
                    <div class="card-body">
                        <div class="row g-2 align-items-end st-add-row">
                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">كود الصنف</label>
                                <input type="number" id="ProdCodeInput" class="form-control form-control-sm text-center pi-input" placeholder="بحث بالكود..." data-lock-posted="1" />
                            </div>

                            <div class="col-lg-3">
                                <label class="form-label form-label-sm">اسم الصنف</label>
                                <div class="position-relative" id="stProductDropdownWrap">
                                    <div class="product-dropdown-onebox" id="stProductDropdownInputGroup">
                                        <span class="product-dropdown-arrow-inside" id="stProductDropdownArrow" title="افتح القائمة">▼</span>
                                        <input id="ProdNameInput" type="text" class="form-control form-control-sm pi-input pi-product-name-input product-dropdown-input" placeholder="اختر صنفاً..." autocomplete="off" data-lock-posted="1" />
                                    </div>
                                    <div id="stProductDropdownList" class="product-dropdown-list" role="listbox" data-open="false"></div>
                                </div>
                                @* مصدر بيانات الأصناف: قائمة مخفية — بدون datalist لتعطيل قائمة المتصفح الافتراضية *@
                                <select id="productsList" class="d-none" aria-hidden="true" tabindex="-1" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none;">
                                    @if (ViewBag.ProductsAuto != null)
                                    {
                                        foreach (var p in ViewBag.ProductsAuto)
                                        {
                                            <option value="@p.Name"
                                                    data-id="@p.Id"
                                                    data-code="@p.Id"
                                                    data-generic="@p.GenericName"
                                                    data-company="@p.Company"
                                                    data-price="@p.PriceRetail"
                                                    data-hasquota="@(p.HasQuota ? "true" : "false")">@p.Name</option>
                                        }
                                    }
                                </select>
                                <input type="hidden" id="ProdId" />
                            </div>

                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">التشغيلة</label>
                                <select id="BatchSelect" class="form-select form-select-sm" data-lock-posted="1">
                                    <option value="">—</option>
                                </select>
                                <input type="hidden" id="BatchId" />
                                <input type="hidden" id="BatchNoInput" />
                            </div>

                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">الصلاحية</label>
                                <input type="text" id="ExpiryInput" class="form-control form-control-sm text-center pi-input" readonly placeholder="—" data-lock-posted="1" dir="ltr" style="text-align: left;" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الكمية المتوفرة</label>
                                <input type="number" id="QtyAvailableInput" class="form-control form-control-sm text-center pi-input" value="0" readonly data-lock-posted="1" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الكمية</label>
                                <input type="number" id="QtyInput" class="form-control form-control-sm text-center pi-input" value="0" data-lock-posted="1" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">سعر الجمهور</label>
                                <input type="number" id="PriceRetailInput" class="form-control form-control-sm text-center pi-input" step="0.01" readonly data-lock-posted="1" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الخصم المرجح %</label>
                                <input type="number" id="WeightedDiscountInput" class="form-control form-control-sm text-center pi-input" step="0.01" readonly data-lock-posted="1" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الخصم %</label>
                                <input type="number" id="DiscountInput" class="form-control form-control-sm text-center pi-input" step="0.01" placeholder="0" data-lock-posted="1" />
                            </div>

                            <input type="hidden" id="UnitCostInput" />
                        </div>

                        <div class="row g-2 mt-2">
                            <div class="col-lg-2 d-grid">
                                <label class="form-label form-label-sm">&nbsp;</label>
                                <button type="button" id="btnAddTransferLine" class="btn btn-primary btn-sm w-100" data-lock-posted="1">إضافة</button>
                            </div>
                        </div>
                    </div>
                </div>

                @* جدول السطور — ترتيب أعمدة مثل فاتورة المبيعات + الإجمالي للتحويل *@
                <div class="invoice-lines-container mb-2">
                <div class="card shadow-sm invoice-lines-card">
                    <div class="invoice-card-line"></div>
                    <div class="card-body p-0">
                        <div class="erp-table-wrapper">
                            <table class="table table-sm table-striped table-hover mb-0 erp-table" id="TransferLinesTable">
                                <thead class="invoice-lines-header table-light">
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th class="text-center">الموقع</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">التشغيلة</th>
                                        <th class="text-center">الصلاحية</th>
                                        <th class="text-center">الكمية</th>
                                        <th class="text-center">سعر الجمهور</th>
                                        <th class="text-center">الخصم المرجح %</th>
                                        <th class="text-center">الخصم %</th>
                                        <th class="text-center">الإجمالي</th>
                                    </tr>
                                </thead>
                                <tbody id="TransferLinesTbody">
                                    @if (Model.Lines != null && Model.Lines.Any())
                                    {
                                        int lineNo = 1;
                                        foreach (var line in Model.Lines.OrderBy(l => l.LineNo))
                                        {
                                            var locDisp = string.IsNullOrWhiteSpace(line.Product?.Location) ? "—" : line.Product!.Location!;
                                            var batchNoDisp = line.Batch == null ? "" : (line.Batch.Expiry.Date >= new DateTime(2099, 1, 1) ? "" : (line.Batch.BatchNo ?? ""));
                                            var expDisp = line.Batch == null ? "" : (line.Batch.Expiry.Date >= new DateTime(2099, 1, 1) ? "" : line.Batch.Expiry.ToString("yyyy-MM-dd"));
                                            <tr class="erp-list-selectable-row"
                                                data-line-id="@line.Id"
                                                data-prod-id="@line.ProductId"
                                                data-prod-name="@WebUtility.HtmlEncode(line.Product?.ProdName ?? "")"
                                                data-location="@WebUtility.HtmlEncode(locDisp)"
                                                data-batch-id="@(line.BatchId?.ToString() ?? "")"
                                                data-batch-no="@WebUtility.HtmlEncode(batchNoDisp)"
                                                data-expiry="@WebUtility.HtmlEncode(expDisp)"
                                                data-qty="@line.Qty"
                                                data-price-retail="@(line.PriceRetail?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                                data-weighted="@(line.WeightedDiscountPct?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                                data-discount="@(line.DiscountPct?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                                data-unit-cost="@line.UnitCost.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                                <td class="text-center">@lineNo</td>
                                                <td class="text-center text-muted small">@locDisp</td>
                                                <td>
                                                    <strong>@(line.Product?.ProdName ?? $"صنف #{line.ProductId}")</strong>
                                                    <span class="text-muted small"> | كود: @line.ProductId</span>
                                                </td>
                                                <td class="text-center">@(string.IsNullOrEmpty(batchNoDisp) ? "—" : batchNoDisp)</td>
                                                <td class="text-center">@(string.IsNullOrEmpty(expDisp) ? "—" : expDisp)</td>
                                                <td class="text-center">@line.Qty</td>
                                                <td class="text-center">@(line.PriceRetail?.ToString("0.00") ?? "-")</td>
                                                <td class="text-center">@(line.WeightedDiscountPct?.ToString("0.00") ?? "-")</td>
                                                <td class="text-center">@(line.DiscountPct?.ToString("0.00") ?? "-")</td>
                                                <td class="text-center">@((line.Qty * line.UnitCost).ToString("0.00"))</td>
                                            </tr>
                                            lineNo++;
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="10" class="text-center text-muted py-4">لا توجد سطور بعد.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                </div>

                @* كارت الإجماليات — بنمط فاتورة المبيعات *@
                <div class="card shadow-sm mb-2 invoice-totals-card">
                    <div class="invoice-card-line"></div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-boxes">
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">عدد السطور</span>
                                <span id="StTotalLinesValue" class="invoice-summary-value">@stLineCount</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">عدد الأصناف</span>
                                <span id="StTotalItemsValue" class="invoice-summary-value">@stDistinctItems</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">إجمالي الكمية</span>
                                <span id="StTotalQtyValue" class="invoice-summary-value">@stTotalQtyD.ToString("0.##")</span>
                            </div>
                        </div>
                        <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-totals mt-3">
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">إجمالي سعر الجمهور</span>
                                <span id="StTotalRetailValue" class="invoice-summary-value">@stTotalRetailD.ToString("0.00")</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box">
                                <span class="invoice-summary-label">إجمالي التكلفة</span>
                                <span id="StTotalCostValue" class="invoice-summary-value">@stTotalCostD.ToString("0.00")</span>
                            </div>
                            <div class="invoice-summary-item invoice-summary-box invoice-summary-box-main">
                                <span class="invoice-summary-label">الإجمالي</span>
                                <span id="StGrandTotalValue" class="invoice-summary-value invoice-summary-value-main fw-bold">@stTotalCostD.ToString("0.00")</span>
                            </div>
                        </div>
                    </div>
                </div>

                </div>
