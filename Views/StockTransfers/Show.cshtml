@section Scripts {
    <script>
        // Anti-forgery token
        function getAntiForgeryToken() {
            const form = document.getElementById('__AntiForgeryForm');
            return form?.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        let productInfoCache = null;
        /** استعادة تشغيلة/كميات بعد جلب GetTransferProductInfo (عند النقر على سطر) */
        let pendingRowRestore = null;

        function updateDeleteSelectedButton() {
            const btn = document.getElementById('btnDeleteSelectedLine');
            if (!btn) return;
            if (typeof isTransferPosted === 'function' && isTransferPosted()) {
                btn.disabled = true;
                return;
            }
            const sid = document.getElementById('SelectedLineId')?.value;
            btn.disabled = !sid;
        }

        function clearLineSelection() {
            const hid = document.getElementById('SelectedLineId');
            if (hid) hid.value = '';
            document.querySelectorAll('#TransferLinesTbody tr.table-active').forEach(tr => tr.classList.remove('table-active'));
            updateDeleteSelectedButton();
        }

        function resequenceTransferLineNumbers() {
            const tbody = document.getElementById('TransferLinesTbody');
            if (!tbody) return;
            tbody.querySelectorAll('tr[data-line-id]').forEach((tr, i) => {
                const firstTd = tr.querySelector('td');
                if (firstTd) firstTd.textContent = String(i + 1);
            });
        }

        function recalcTransferTotals() {
            const rows = document.querySelectorAll('#TransferLinesTbody tr[data-line-id]');
            const prodIds = new Set();
            let totalQty = 0, totalCost = 0, totalRetail = 0;
            rows.forEach(tr => {
                if (tr.dataset.prodId) prodIds.add(String(tr.dataset.prodId));
                const q = parseFloat(tr.dataset.qty || '0') || 0;
                const pr = parseFloat(tr.dataset.priceRetail || '0') || 0;
                const uc = parseFloat(tr.dataset.unitCost || '0') || 0;
                totalQty += q;
                totalCost += q * uc;
                totalRetail += q * pr;
            });
            const setTxt = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
            setTxt('StTotalLinesValue', String(rows.length));
            setTxt('StTotalItemsValue', String(prodIds.size));
            setTxt('StTotalQtyValue', Number.isInteger(totalQty) ? String(totalQty) : totalQty.toFixed(2));
            setTxt('StTotalRetailValue', totalRetail.toFixed(2));
            setTxt('StTotalCostValue', totalCost.toFixed(2));
            setTxt('StGrandTotalValue', totalCost.toFixed(2));
        }

        /** نفس أسلوب فاتورة المبيعات — erp-ui-feedback.js */
        function showToast(text, type, durationMs) {
            if (typeof ERP !== 'undefined' && typeof ERP.showToast === 'function') {
                ERP.showToast(text, type || 'info', durationMs != null ? durationMs : 4500);
            } else {
                alert(text);
            }
        }
        function erpToast(msg, type) {
            showToast(msg, type || 'danger', 4500);
        }

        // قفل الأزرار والحقول عند الترحيل (مثل تسوية الجرد)
        function isTransferPosted() {
            const flag = document.getElementById('TransferIsPostedFlag');
            return flag && flag.value === '1';
        }
        function setTransferPosted(posted) {
            const flag = document.getElementById('TransferIsPostedFlag');
            if (flag) flag.value = posted ? '1' : '0';
        }
        function applyPostedUiLock() {
            const posted = isTransferPosted();
            const lockables = document.querySelectorAll('[data-lock-posted="1"]');
            lockables.forEach(el => {
                if (el.dataset.lockInit !== '1') {
                    el.dataset.lockInit = '1';
                    el.dataset.origDisabled = el.disabled ? '1' : '0';
                    el.dataset.origReadonly = el.readOnly ? '1' : '0';
                    el.dataset.origTabIndex = el.getAttribute('tabindex') ?? '';
                }
                const tag = (el.tagName || '').toUpperCase();
                if (posted) {
                    if (tag === 'BUTTON') { el.disabled = true; return; }
                    if (tag === 'A') { el.classList.add('disabled', 'pe-none'); el.setAttribute('aria-disabled', 'true'); el.setAttribute('tabindex', '-1'); return; }
                    if (tag === 'INPUT' || tag === 'TEXTAREA') { el.readOnly = true; el.classList.add('bg-light', 'text-muted'); return; }
                    if (tag === 'SELECT') { el.disabled = true; return; }
                    return;
                }
                const origDisabled = el.dataset.origDisabled === '1';
                const origReadonly = el.dataset.origReadonly === '1';
                const origTabIndex = el.dataset.origTabIndex;
                if (tag === 'BUTTON') { el.disabled = origDisabled; return; }
                if (tag === 'A') { el.classList.remove('disabled', 'pe-none'); el.removeAttribute('aria-disabled'); if (origTabIndex === '') el.removeAttribute('tabindex'); else el.setAttribute('tabindex', origTabIndex); return; }
                if (tag === 'INPUT' || tag === 'TEXTAREA') { el.readOnly = origReadonly; el.classList.remove('bg-light', 'text-muted'); return; }
                if (tag === 'SELECT') { el.disabled = origDisabled; return; }
            });
            const btnPost = document.getElementById('btnPostTransfer');
            if (btnPost) { btnPost.disabled = posted; btnPost.innerHTML = posted ? '✅ تم ترحيل التحويل' : '📤 ترحيل التحويل'; }
            const btnOpen = document.getElementById('btnOpenTransfer');
            if (btnOpen) btnOpen.disabled = !posted;
            const btnPrint = document.getElementById('btnPrintTransferDropdown');
            if (btnPrint) {
                btnPrint.disabled = !posted;
                btnPrint.title = posted ? 'اختر نوع الطباعة' : 'يتاح بعد ترحيل التحويل';
            }
            updateDeleteSelectedButton();
        }
        (function() {
            const serverIsPosted = @Model.IsPosted.ToString().ToLower();
            if (serverIsPosted) { setTransferPosted(true); applyPostedUiLock(); }
            else {
                const btnPrint = document.getElementById('btnPrintTransferDropdown');
                if (btnPrint) btnPrint.disabled = true;
            }
            recalcTransferTotals();
        })();

        function clearAddLineFormAndFocus() {
            clearLineSelection();
            document.getElementById('ProdId').value = '';
            document.getElementById('ProdCodeInput').value = '';
            document.getElementById('ProdNameInput').value = '';
            document.getElementById('BatchSelect').innerHTML = '<option value="">—</option>';
            document.getElementById('BatchId').value = '';
            document.getElementById('BatchNoInput').value = '';
            document.getElementById('ExpiryInput').value = '';
            document.getElementById('QtyAvailableInput').value = '0';
            document.getElementById('QtyInput').value = '0';
            document.getElementById('PriceRetailInput').value = '';
            document.getElementById('WeightedDiscountInput').value = '';
            document.getElementById('DiscountInput').value = '';
            document.getElementById('UnitCostInput').value = '';
            productInfoCache = null;
            pendingRowRestore = null;
            const prodNameInput = document.getElementById('ProdNameInput');
            prodNameInput?.focus();
            prodNameInput?.select?.();
        }
        function clearAddLineForm() {
            clearAddLineFormAndFocus();
        }

        function escapeHtml(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
        function attrEncode(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }

        // ===== أوتوكومبليت اسم الصنف — نفس منطق فاتورة المبيعات (بحث متعدد الكلمات + قائمة مخصصة) =====
        let stSuppressProductDropdownOnce = false;
        (function stInitProductDropdown() {
            const prodDataList = document.getElementById('productsList');
            const prodNameInput = document.getElementById('ProdNameInput');
            const prodCodeInput = document.getElementById('ProdCodeInput');
            const prodHiddenId = document.getElementById('ProdId');
            if (!prodDataList || !prodNameInput) return;

            function normalizeDigits(txt) {
                if (!txt) return '';
                const map = { '\u0660': '0', '\u0661': '1', '\u0662': '2', '\u0663': '3', '\u0664': '4',
                    '\u0665': '5', '\u0666': '6', '\u0667': '7', '\u0668': '8', '\u0669': '9' };
                let out = '';
                for (let i = 0; i < txt.length; i++) {
                    const c = txt[i];
                    out += map[c] !== undefined ? map[c] : c;
                }
                return out;
            }
            function normalizeWord(w) {
                return normalizeDigits((w || '').trim().toLowerCase()).replace(/^[اأإآ]/u, '');
            }
            function normalizeText(txt) {
                return (txt || '').trim().toLowerCase().split(/\s+/).filter(Boolean)
                    .map(function (w) { return normalizeWord(w); }).filter(Boolean).join(' ').replace(/\s+/g, ' ');
            }
            function wordMatchesQueryWord(nameWord, queryWord) {
                const nw0 = normalizeDigits((nameWord || '').trim().toLowerCase());
                const qw0 = normalizeDigits((queryWord || '').trim().toLowerCase());
                const nw = nw0.replace(/^[اأإآ]/u, '');
                const qw = qw0.replace(/^[اأإآ]/u, '');
                if (!qw) return true;
                return nw === qw || nw.startsWith(qw);
            }
            function productNameMatchesSearch(productName, rawSearch) {
                const raw = (rawSearch || '').trim();
                if (!raw) return true;
                const qWords = raw.split(/\s+/).filter(Boolean);
                const nWords = (productName || '').trim().split(/\s+/).filter(Boolean);
                if (qWords.length === 0) return true;
                return qWords.every(function (qw) {
                    return nWords.some(function (nw) { return wordMatchesQueryWord(nw, qw); });
                });
            }
            function productSearchRank(name, rawSearch) {
                const raw = (rawSearch || '').trim();
                const nm = (name || '').trim();
                if (!raw) return 50;
                if (nm === raw) return 0;
                if (nm.startsWith(raw)) return 1;
                const rawWords = raw.split(/\s+/).filter(Boolean);
                const firstQ = rawWords[0] || '';
                const nmWords = nm.split(/\s+/).filter(Boolean);
                if (firstQ && nmWords.length) {
                    if (nmWords[0].startsWith(firstQ)) return 2;
                    const nw0 = normalizeDigits(nmWords[0].toLowerCase());
                    const qw0 = normalizeDigits(firstQ.toLowerCase());
                    const nw = nw0.replace(/^[اأإآ]/u, '');
                    const qw = qw0.replace(/^[اأإآ]/u, '');
                    if (qw && (nw === qw || nw.startsWith(qw))) return 3;
                }
                return 4;
            }
            function findProductByName(name) {
                const raw = (name || '').trim();
                const search = normalizeText(raw);
                if (!search) return null;
                const opts = prodDataList.options;
                for (let i = 0; i < opts.length; i++) {
                    if (normalizeText(opts[i].value) === search) return opts[i];
                }
                for (let i = 0; i < opts.length; i++) {
                    if ((opts[i].value || '').trim() === raw) return opts[i];
                }
                return null;
            }
            function findProductByCode(code) {
                const search = (code || '').toString().trim();
                if (!search) return null;
                const opts = prodDataList.options;
                for (let i = 0; i < opts.length; i++) {
                    const idAttr = (opts[i].getAttribute('data-id') || '').toString();
                    const codeAttr = (opts[i].getAttribute('data-code') || '').toString();
                    if (idAttr === search || codeAttr === search) return opts[i];
                }
                return null;
            }
            function getProductDropdownFilterQuery(rawTrim) {
                const raw = (rawTrim || '').trim();
                if (!raw || !prodDataList.options) return raw;
                const nRaw = normalizeText(raw);
                let canonical = '';
                const opts = prodDataList.options;
                for (let i = 0; i < opts.length; i++) {
                    const v = (opts[i].value || '').trim();
                    if (!v) continue;
                    if (v === raw) { canonical = v; break; }
                    if (nRaw && normalizeText(v) === nRaw) { canonical = v; break; }
                }
                if (!canonical) return raw;
                const parts = canonical.split(/\s+/).filter(Boolean);
                return parts[0] || raw;
            }
            const PRODUCT_LIST_MAX = 15;
            function getFilteredProductOptions(search, max, pinDisplayName) {
                if (!prodDataList.options) return [];
                const limit = max || PRODUCT_LIST_MAX;
                const opts = prodDataList.options;
                const rawTrim = (search || '').trim();
                if (!rawTrim) {
                    const out = [];
                    for (let i = 0; i < opts.length && out.length < limit; i++) out.push(opts[i]);
                    return out;
                }
                const qNorm = normalizeText(rawTrim);
                const words = rawTrim.split(/\s+/).filter(Boolean);
                const matched = [];
                for (let i = 0; i < opts.length; i++) {
                    const opt = opts[i];
                    const nameVal = (opt.value || '').trim();
                    const code = (opt.getAttribute('data-code') || '').toString().trim();
                    const idAttr = (opt.getAttribute('data-id') || '').toString().trim();
                    const codeOrId = code || idAttr;
                    const nameOk = qNorm ? productNameMatchesSearch(nameVal, rawTrim) : true;
                    const idOk = words.length > 0 && words.some(function (w) { return codeOrId.indexOf(w) !== -1; });
                    const codeRawOk = codeOrId && codeOrId.indexOf(rawTrim) !== -1;
                    if (nameOk || idOk || codeRawOk) matched.push(opt);
                }
                matched.sort(function (a, b) {
                    const ra = productSearchRank((a.value || '').trim(), rawTrim);
                    const rb = productSearchRank((b.value || '').trim(), rawTrim);
                    if (ra !== rb) return ra - rb;
                    return (a.value || '').localeCompare(b.value || '', 'ar');
                });
                let result = matched.slice(0, limit);
                const pinRaw = (pinDisplayName || '').trim();
                if (pinRaw) {
                    const nPin = normalizeText(pinRaw);
                    let pinOpt = null;
                    for (let j = 0; j < opts.length; j++) {
                        const v = (opts[j].value || '').trim();
                        if (v === pinRaw || (nPin && normalizeText(v) === nPin)) { pinOpt = opts[j]; break; }
                    }
                    if (pinOpt && matched.indexOf(pinOpt) >= 0) {
                        const inResult = result.some(function (o) { return o === pinOpt; });
                        if (!inResult) {
                            result = matched.slice(0, limit - 1);
                            result.push(pinOpt);
                        }
                    }
                }
                return result;
            }
            let stProductDropdownHighlightedIndex = -1;
            let stProductDropdownSelectableItems = [];
            function positionStProductDropdownList() {
                const panel = document.getElementById('stProductDropdownList');
                const wrap = document.getElementById('stProductDropdownWrap');
                if (!panel || !wrap || panel.getAttribute('data-open') !== 'true') return;
                const r = wrap.getBoundingClientRect();
                panel.style.position = 'fixed';
                panel.style.width = r.width + 'px';
                panel.style.top = r.bottom + 'px';
                panel.style.left = r.left + 'px';
            }
            function closeStProductDropdown() {
                const panel = document.getElementById('stProductDropdownList');
                if (panel) {
                    panel.style.display = 'none';
                    panel.setAttribute('data-open', 'false');
                }
                stProductDropdownHighlightedIndex = -1;
                stProductDropdownSelectableItems = [];
            }
            function setStProductDropdownHighlight(idx) {
                if (idx < 0 || idx >= stProductDropdownSelectableItems.length) return;
                stProductDropdownSelectableItems.forEach(function (el, i) {
                    el.classList.toggle('product-dropdown-item-active', i === idx);
                });
                stProductDropdownHighlightedIndex = idx;
                stProductDropdownSelectableItems[idx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
            }
            function stFillProductFromOption(opt) {
                if (!opt) {
                    if (prodHiddenId) prodHiddenId.value = '';
                    if (prodCodeInput) prodCodeInput.value = '';
                    if (prodNameInput) prodNameInput.value = '';
                    productInfoCache = null;
                    return;
                }
                const id = opt.getAttribute('data-id') || '';
                const code = opt.getAttribute('data-code') || id;
                const name = (opt.value || '').trim();
                if (prodHiddenId) prodHiddenId.value = id;
                if (prodCodeInput) prodCodeInput.value = code;
                if (prodNameInput) prodNameInput.value = name;
                loadTransferProductInfo();
            }
            function openStProductDropdown() {
                const panel = document.getElementById('stProductDropdownList');
                const inp = document.getElementById('ProdNameInput');
                if (!panel || !inp) return;
                const searchTerm = (inp.value || '').trim();
                const filterQuery = getProductDropdownFilterQuery(searchTerm);
                const list = getFilteredProductOptions(filterQuery, PRODUCT_LIST_MAX, searchTerm);
                panel.innerHTML = '';
                stProductDropdownSelectableItems = [];
                let highlightIdx = 0;
                const currentVal = (inp.value || '').trim();
                if (list.length > 0) {
                    for (let i = 0; i < list.length; i++) {
                        if (normalizeText((list[i].value || '').trim()) === normalizeText(currentVal)) { highlightIdx = i; break; }
                    }
                }
                if (list.length === 0) {
                    const empty = document.createElement('div');
                    empty.className = 'product-dropdown-item text-muted py-2 px-3 small';
                    empty.textContent = inp.value ? 'لا توجد نتائج' : ('اكتب للبحث ثم انزل بالسهم ▼ واختر (' + PRODUCT_LIST_MAX + ' كحد أقصى)');
                    panel.appendChild(empty);
                } else {
                    list.forEach(function (opt, idx) {
                        const id = (opt.getAttribute('data-id') || '').toString();
                        const name = (opt.value || '').trim();
                        const it = document.createElement('div');
                        it.className = 'product-dropdown-item py-2 px-3' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                        it.setAttribute('role', 'option');
                        it.setAttribute('data-id', id);
                        it.textContent = name;
                        it.addEventListener('click', function (e) {
                            e.preventDefault();
                            const o = findProductByCode(id);
                            if (o) stFillProductFromOption(o);
                            closeStProductDropdown();
                        });
                        panel.appendChild(it);
                        stProductDropdownSelectableItems.push(it);
                    });
                    stProductDropdownHighlightedIndex = highlightIdx;
                }
                panel.style.display = 'block';
                panel.setAttribute('data-open', 'true');
                positionStProductDropdownList();
            }
            function selectHighlightedStProduct() {
                if (stProductDropdownHighlightedIndex < 0 || stProductDropdownHighlightedIndex >= stProductDropdownSelectableItems.length) return false;
                const el = stProductDropdownSelectableItems[stProductDropdownHighlightedIndex];
                const id = el.getAttribute('data-id');
                const o = findProductByCode(id);
                if (o) stFillProductFromOption(o);
                closeStProductDropdown();
                return true;
            }
            prodNameInput.addEventListener('input', function () {
                if (stSuppressProductDropdownOnce) {
                    stSuppressProductDropdownOnce = false;
                    closeStProductDropdown();
                    return;
                }
                openStProductDropdown();
            });
            prodNameInput.addEventListener('blur', function () {
                setTimeout(function () {
                    closeStProductDropdown();
                    stFillProductFromOption(findProductByName(prodNameInput.value));
                }, 180);
            });
            prodNameInput.addEventListener('keydown', function (e) {
                const panel = document.getElementById('stProductDropdownList');
                const isOpen = panel && panel.getAttribute('data-open') === 'true';
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    if (isOpen && stProductDropdownSelectableItems.length > 0) {
                        const next = Math.min(stProductDropdownHighlightedIndex + 1, stProductDropdownSelectableItems.length - 1);
                        setStProductDropdownHighlight(next);
                    } else openStProductDropdown();
                    return;
                }
                if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    if (isOpen && stProductDropdownSelectableItems.length > 0) {
                        const prev = Math.max(stProductDropdownHighlightedIndex - 1, 0);
                        setStProductDropdownHighlight(prev);
                    }
                    return;
                }
                if (e.key === 'Enter') {
                    e.preventDefault();
                    if (isOpen && stProductDropdownSelectableItems.length > 0) {
                        selectHighlightedStProduct();
                        return;
                    }
                    stFillProductFromOption(findProductByName(prodNameInput.value));
                    document.getElementById('BatchSelect')?.focus();
                }
            });
            document.addEventListener('click', function (ev) {
                const wrap = document.getElementById('stProductDropdownWrap');
                if (wrap && !wrap.contains(ev.target)) closeStProductDropdown();
            });
            window.addEventListener('resize', function () { positionStProductDropdownList(); });
            window.addEventListener('scroll', function () { positionStProductDropdownList(); }, true);
            const stArrow = document.getElementById('stProductDropdownArrow');
            const stWrap = document.getElementById('stProductDropdownWrap');
            if (stWrap) {
                stWrap.addEventListener('click', function (ev) {
                    if (!ev.target.closest('#stProductDropdownList')) {
                        const inp = document.getElementById('ProdNameInput');
                        if (inp) inp.focus();
                    }
                });
            }
            if (stArrow) {
                stArrow.addEventListener('click', function (ev) {
                    ev.preventDefault();
                    const inp = document.getElementById('ProdNameInput');
                    if (inp) { inp.focus(); openStProductDropdown(); }
                });
            }
            if (prodCodeInput) {
                prodCodeInput.addEventListener('input', function () {
                    const code = this.value;
                    if (code && parseInt(code, 10) > 0) {
                        const selectedOption = findProductByCode(code);
                        if (selectedOption) stFillProductFromOption(selectedOption);
                    }
                });
            }
            window.stTransferApplyProductByName = function (rawName) {
                const opt = findProductByName(rawName);
                if (opt) stFillProductFromOption(opt);
            };
            window.stTransferApplyProductByCode = function (code) {
                const opt = findProductByCode(code);
                if (opt) stFillProductFromOption(opt);
            };
        })();

        function upsertTransferRow(result, lineNo) {
            const tbody = document.getElementById('TransferLinesTbody');
            const placeholder = tbody.querySelector('tr td[colspan="10"]');
            if (placeholder) placeholder.closest('tr').remove();
            const existingRow = tbody.querySelector(`tr[data-line-id="${result.lineId}"]`);
            const priceStr = result.priceRetail != null ? parseFloat(result.priceRetail).toFixed(2) : '-';
            const wdStr = result.weightedDiscountPct != null ? parseFloat(result.weightedDiscountPct).toFixed(2) : '-';
            const dStr = result.discountPct != null ? parseFloat(result.discountPct).toFixed(2) : '-';
            const totalStr = result.total != null ? parseFloat(result.total).toFixed(2) : '-';
            const pid = result.productId ?? result.ProductId ?? '';
            const loc = result.productLocation != null ? String(result.productLocation) : '—';
            const batchNo = (result.batchNo != null && String(result.batchNo).trim() !== '') ? String(result.batchNo) : '';
            const exp = (result.expiryDisplay != null && String(result.expiryDisplay).trim() !== '') ? String(result.expiryDisplay) : '';
            const batchDisp = batchNo ? escapeHtml(batchNo) : '—';
            const expDisp = exp ? escapeHtml(exp) : '—';
            const locEsc = escapeHtml(loc);
            const nameEsc = escapeHtml(result.productName || '');
            const pr = result.priceRetail != null ? String(result.priceRetail) : '';
            const wd = result.weightedDiscountPct != null ? String(result.weightedDiscountPct) : '';
            const dc = result.discountPct != null ? String(result.discountPct) : '';
            const uc = result.unitCost != null ? String(result.unitCost) : '';
            const bid = (result.batchId != null && result.batchId > 0) ? String(result.batchId) : '';
            const rowHtml = `<tr class="erp-list-selectable-row" data-line-id="${result.lineId}" data-prod-id="${pid}" data-prod-name="${attrEncode(result.productName || '')}" data-location="${attrEncode(loc)}" data-batch-id="${bid}" data-batch-no="${attrEncode(batchNo)}" data-expiry="${attrEncode(exp)}" data-qty="${result.qty}" data-price-retail="${attrEncode(pr)}" data-weighted="${attrEncode(wd)}" data-discount="${attrEncode(dc)}" data-unit-cost="${attrEncode(uc)}">
                <td class="text-center">${lineNo}</td>
                <td class="text-center text-muted small">${locEsc}</td>
                <td><strong>${nameEsc}</strong><span class="text-muted small"> | كود: ${pid}</span></td>
                <td class="text-center">${batchDisp}</td>
                <td class="text-center">${expDisp}</td>
                <td class="text-center">${result.qty}</td>
                <td class="text-center">${priceStr}</td>
                <td class="text-center">${wdStr}</td>
                <td class="text-center">${dStr}</td>
                <td class="text-center">${totalStr}</td>
            </tr>`;
            if (existingRow) existingRow.outerHTML = rowHtml;
            else tbody.insertAdjacentHTML('beforeend', rowHtml);
            if (tbody.querySelectorAll('tr[data-line-id]').length === 0)
                tbody.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-4">لا توجد سطور بعد.</td></tr>';
            resequenceTransferLineNumbers();
            recalcTransferTotals();
        }

        async function loadTransferProductInfo() {
            const prodId = parseInt(document.getElementById('ProdId').value || '0', 10);
            const fromWh = parseInt(document.querySelector('[name="FromWarehouseId"]')?.value || '0', 10);
            if (!prodId || prodId <= 0 || !fromWh || fromWh <= 0) {
                document.getElementById('BatchSelect').innerHTML = '<option value="">—</option>';
                document.getElementById('BatchId').value = '';
                document.getElementById('BatchNoInput').value = '';
                document.getElementById('ExpiryInput').value = '';
                document.getElementById('QtyAvailableInput').value = '0';
                document.getElementById('PriceRetailInput').value = '';
                document.getElementById('WeightedDiscountInput').value = '';
                document.getElementById('UnitCostInput').value = '';
                productInfoCache = null;
                return;
            }
            try {
                const res = await fetch(`@Url.Action("GetTransferProductInfo", "StockTransfers")?prodId=${prodId}&fromWarehouseId=${fromWh}`);
                if (!res.ok) return;
                const data = await res.json();
                if (!data.ok) return;
                const batches = data.batches || [];
                productInfoCache = data;

                const sel = document.getElementById('BatchSelect');
                sel.innerHTML = '<option value="">—</option>';
                batches.forEach((b) => {
                    const opt = document.createElement('option');
                    const bid = b.batchId ?? b.BatchId;
                    if (!bid || bid <= 0) return;
                    const bno = (b.batchNo ?? b.BatchNo ?? '').toString();
                    const exp = (b.expiryText ?? b.ExpiryText ?? '').toString();
                    opt.value = String(bid);
                    opt.textContent = (bno || '—') + ' | ' + (exp || '—');
                    opt.dataset.batchNo = bno;
                    opt.dataset.expiry = exp;
                    opt.dataset.priceRetail = b.priceRetailBatch ?? b.PriceRetailBatch ?? '';
                    opt.dataset.unitCost = b.unitCost ?? b.UnitCost ?? '';
                    opt.dataset.qty = (b.qty ?? b.Qty ?? 0).toString();
                    sel.appendChild(opt);
                });

                const totalQ = Number(data.totalQtyOnHand ?? 0);
                document.getElementById('PriceRetailInput').value = data.priceRetail ?? '';
                document.getElementById('WeightedDiscountInput').value = data.weightedDiscount ?? '';
                document.getElementById('UnitCostInput').value = data.unitCost ?? '';
                document.getElementById('QtyAvailableInput').value = String(totalQ);

                // لا اختيار تلقائي للتشغيلة — التشغيلة والصلاحية تبقى فارغة حتى يختار المستخدم
                document.getElementById('BatchId').value = '';
                document.getElementById('BatchNoInput').value = '';
                document.getElementById('ExpiryInput').value = '';
                sel.value = '';

                const restore = pendingRowRestore;
                pendingRowRestore = null;
                if (restore) {
                    const wantBid = restore.batchId ? String(restore.batchId) : '';
                    if (wantBid && sel.querySelector(`option[value="${wantBid}"]`)) {
                        sel.value = wantBid;
                        const opt = sel.options[sel.selectedIndex];
                        if (opt && opt.value) {
                            document.getElementById('BatchId').value = opt.value;
                            document.getElementById('BatchNoInput').value = opt.dataset.batchNo || '';
                            document.getElementById('ExpiryInput').value = opt.dataset.expiry || '';
                            document.getElementById('PriceRetailInput').value = opt.dataset.priceRetail || '';
                            document.getElementById('UnitCostInput').value = opt.dataset.unitCost || '';
                            document.getElementById('QtyAvailableInput').value = opt.dataset.qty || '0';
                        }
                    }
                    if (restore.qty != null && restore.qty !== '') document.getElementById('QtyInput').value = String(restore.qty);
                    if (restore.priceRetail != null && restore.priceRetail !== '') document.getElementById('PriceRetailInput').value = String(restore.priceRetail);
                    if (restore.weighted != null && restore.weighted !== '') document.getElementById('WeightedDiscountInput').value = String(restore.weighted);
                    if (restore.discount != null && restore.discount !== '') document.getElementById('DiscountInput').value = String(restore.discount);
                    if (restore.unitCost != null && restore.unitCost !== '') document.getElementById('UnitCostInput').value = String(restore.unitCost);
                }
            } catch (e) {
                console.warn('loadTransferProductInfo:', e);
            }
        }

        document.querySelector('[name="FromWarehouseId"]')?.addEventListener('change', function() {
            if (document.getElementById('ProdId').value) loadTransferProductInfo();
