@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.StockTransfer

@{
    ViewData["Title"] = Model.Id == 0
        ? "تحويل مخزني جديد"
        : $"تحويل مخزني — رقم {Model.Id}";
}

@section Styles {
    <style>
        .transfer-page {
            background-color: #f3f6fb;
            min-height: 100vh;
            padding-bottom: 2rem;
        }

        .transfer-header-card,
        .transfer-lines-card,
        .transfer-add-card {
            border-radius: 1rem;
            overflow: hidden;
        }

        .transfer-header-bar {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.4rem 1rem;
        }
        .transfer-header-bar h5 {
            margin-bottom: 0;
            font-size: 1rem;
        }

        /* خط ملون بدل عنوان الكارت */
        .transfer-card-line {
            height: 4px;
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            border-radius: 2px;
            margin-bottom: 0.4rem;
        }

        /* إخفاء حدود وظل الكروت */
        .transfer-header-card,
        .transfer-add-card,
        .transfer-lines-card {
            border: none !important;
            box-shadow: none !important;
        }

        .transfer-add-card .card-header,
        .transfer-lines-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.55rem 1rem;
        }

        .invoice-actions-sticky {
            position: sticky;
            top: 58px;
            z-index: 3000;
            background: #ffffff;
            border: 1px solid rgba(13,110,253,.12);
            padding: 10px 10px;
            border-radius: 14px;
            box-shadow: 0 10px 24px rgba(0,0,0,.05);
        }

        .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
        }

        .erp-table-wrapper {
            max-height: 360px;
            overflow: auto;
        }

        /* إصلاح مشكلة اتجاه النص في حقول التاريخ */
        input[type="date"],
        input[type="datetime-local"],
        input[type="time"] {
            direction: ltr !important;
            text-align: left !important;
        }

        input[type="date"]::-webkit-calendar-picker-indicator,
        input[type="datetime-local"]::-webkit-calendar-picker-indicator {
            cursor: pointer;
        }
    </style>
}

<div class="transfer-page" dir="rtl">
    <div class="container-fluid pt-3">
        <form id="__AntiForgeryForm" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>

        <div class="row g-3">
            @* العمود الجانبي *@
            <div class="col-12 col-lg-2 order-1 order-lg-2">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات التحويل المخزني</h6>
                    </div>

                    <input type="hidden" id="TransferId" value="@Model.Id" />
                    <input type="hidden" id="TransferIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />

                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">
                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button" id="btnFirstTransfer" class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>⏮</button>
                            <button type="button" id="btnPrevTransfer" class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>◀</button>
                            <button type="button" id="btnNextTransfer" class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>▶</button>
                            <button type="button" id="btnLastTransfer" class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>⏭</button>
                        </div>

                        <hr class="my-1" />

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm w-100"
                           asp-action="Show"
                           asp-route-id="0"
                           asp-route-frame="1">
                            ➕ تحويل جديد
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnSaveTransferHeader"
                                data-lock-posted="1">
                            💾 حفظ التحويل
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnPostTransfer"
                                data-lock-posted="1">
                            📤 ترحيل التحويل
                        </button>

                        <div id="postTransferMsg" class="small mt-2"></div>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnOpenTransfer">
                            ⏪ فتح التحويل
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnClearTransferLines"
                                data-lock-posted="1">
                            🗑️ مسح كل السطور
                        </button>
                    </div>
                </div>
            </div>

            @* العمود الرئيسي *@
            <div class="col-12 col-lg-10 order-2 order-lg-1">
                @* كارت بيانات التحويل *@
                <div class="card shadow-sm mb-2 transfer-header-card">
                    <div class="transfer-header-bar">
                        <h5 class="mb-0">تحويل مخزني</h5>
                    </div>

                    <div>
                        <div class="card-body">
                            <div class="row g-3 align-items-end">
                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">رقم التحويل</label>
                                    <input id="TransferNumberDisplay" class="form-control form-control-sm text-center" value="@(Model.Id > 0 ? Model.Id.ToString() : "")" readonly />
                                </div>

                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">تاريخ التحويل</label>
                                    <input id="TransferDateInput" type="datetime-local" class="form-control form-control-sm" value="@Model.TransferDate.ToString("yyyy-MM-ddTHH:mm")" data-lock-posted="1" dir="ltr" style="text-align: left;" />
                                </div>

                                <div class="col-lg-3">
                                    <label class="form-label form-label-sm">من مخزن</label>
                                    <select asp-for="FromWarehouseId" asp-items="@(ViewData["FromWarehouseId"] as SelectList)" class="form-select form-select-sm" data-lock-posted="1">
                                        <option value="">اختر المخزن المصدر</option>
                                    </select>
                                </div>

                                <div class="col-lg-3">
                                    <label class="form-label form-label-sm">إلى مخزن</label>
                                    <select asp-for="ToWarehouseId" asp-items="@(ViewData["ToWarehouseId"] as SelectList)" class="form-select form-select-sm" data-lock-posted="1">
                                        <option value="">اختر المخزن الوجهة</option>
                                    </select>
                                </div>

                                <div class="col-lg-2">
                                    <label class="form-label form-label-sm">الحالة</label>
                                    <input id="TransferStatusDisplay" class="form-control form-control-sm text-center" value="@(string.IsNullOrWhiteSpace(Model.Status) ? "مسودة" : Model.Status)" readonly />
                                </div>
                            </div>

                            <div class="row g-3 mt-2">
                                <div class="col-12">
                                    <label class="form-label form-label-sm">ملاحظات</label>
                                    <textarea asp-for="Note" class="form-control form-control-sm" rows="2" data-lock-posted="1"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* كارت إدخال السطر *@
                <div class="card shadow-sm mb-2 transfer-add-card">
                    <div class="transfer-card-line"></div>
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">كود الصنف</label>
                                <input type="number" id="ProdCodeInput" class="form-control form-control-sm text-center" placeholder="بحث بالكود..." data-lock-posted="1" />
                            </div>

                            <div class="col-lg-3">
                                <label class="form-label form-label-sm">اسم الصنف</label>
                                <input id="ProdNameInput" list="productsList" class="form-control form-control-sm" placeholder="اكتب اسم الصنف..." autocomplete="off" data-lock-posted="1" />
                                <datalist id="productsList">
                                    @if (ViewBag.ProductsAuto != null)
                                    {
                                        foreach (var p in ViewBag.ProductsAuto)
                                        {
                                            <option value="@p.Name"
                                                    data-id="@p.Id"
                                                    data-code="@p.Id"
                                                    data-generic="@p.GenericName"
                                                    data-company="@p.Company"
                                                    data-price="@p.PriceRetail"
                                                    data-hasquota="@(p.HasQuota ? "true" : "false")">
                                            </option>
                                        }
                                    }
                                </datalist>
                                <input type="hidden" id="ProdId" />
                            </div>

                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">التشغيلة</label>
                                <select id="BatchSelect" class="form-select form-select-sm" data-lock-posted="1">
                                    <option value="">-- اختر --</option>
                                </select>
                                <input type="hidden" id="BatchId" />
                                <input type="hidden" id="BatchNoInput" />
                            </div>

                            <div class="col-lg-2">
                                <label class="form-label form-label-sm">التاريخ</label>
                                <input type="text" id="ExpiryInput" class="form-control form-control-sm text-center" readonly placeholder="يظهر عند اختيار التشغيلة" data-lock-posted="1" dir="ltr" style="text-align: left;" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الكمية المتوفرة</label>
                                <input type="number" id="QtyAvailableInput" class="form-control form-control-sm text-center" value="0" readonly data-lock-posted="1" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الكمية</label>
                                <input type="number" id="QtyInput" class="form-control form-control-sm text-center" value="0" data-lock-posted="1" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">سعر الجمهور</label>
                                <input type="number" id="PriceRetailInput" class="form-control form-control-sm text-center" step="0.01" readonly data-lock-posted="1" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الخصم المرجح %</label>
                                <input type="number" id="WeightedDiscountInput" class="form-control form-control-sm text-center" step="0.01" readonly data-lock-posted="1" />
                            </div>

                            <div class="col-lg-1">
                                <label class="form-label form-label-sm">الخصم %</label>
                                <input type="number" id="DiscountInput" class="form-control form-control-sm text-center" step="0.01" placeholder="0" data-lock-posted="1" />
                            </div>

                            <input type="hidden" id="UnitCostInput" />
                        </div>

                        <div class="row g-2 mt-2">
                            <div class="col-lg-2 d-grid">
                                <label class="form-label form-label-sm">&nbsp;</label>
                                <button type="button" id="btnAddTransferLine" class="btn btn-erp btn-erp-primary btn-erp-sm w-100" data-lock-posted="1">إضافة</button>
                            </div>
                        </div>
                    </div>
                </div>

                @* جدول السطور *@
                <div class="card shadow-sm mb-2 transfer-lines-card">
                    <div class="transfer-card-line"></div>
                    <div class="card-body p-0">
                        <div class="erp-table-wrapper">
                            <table class="table table-sm table-striped table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">التشغيلة</th>
                                        <th class="text-center">التاريخ</th>
                                        <th class="text-center">الكمية</th>
                                        <th class="text-center">سعر الجمهور</th>
                                        <th class="text-center">الخصم المرجح %</th>
                                        <th class="text-center">الخصم %</th>
                                        <th class="text-center">الإجمالي</th>
                                        <th class="text-center no-print">مسح</th>
                                    </tr>
                                </thead>
                                <tbody id="TransferLinesTbody">
                                    @if (Model.Lines != null && Model.Lines.Any())
                                    {
                                        int lineNo = 1;
                                        foreach (var line in Model.Lines.OrderBy(l => l.LineNo))
                                        {
                                            <tr data-line-id="@line.Id">
                                                <td class="text-center">@lineNo</td>
                                                <td>@(line.Product?.ProdName ?? $"صنف #{line.ProductId}")</td>
                                                <td class="text-center">@(line.Batch?.BatchNo ?? "-")</td>
                                                <td class="text-center">@(line.Batch?.Expiry.ToString("yyyy-MM-dd") ?? "-")</td>
                                                <td class="text-center">@line.Qty</td>
                                                <td class="text-center">@(line.PriceRetail?.ToString("0.00") ?? "-")</td>
                                                <td class="text-center">@(line.WeightedDiscountPct?.ToString("0.00") ?? "-")</td>
                                                <td class="text-center">@(line.DiscountPct?.ToString("0.00") ?? "-")</td>
                                                <td class="text-center">@((line.Qty * line.UnitCost).ToString("0.00"))</td>
                                                <td class="text-center no-print">
                                                    <button type="button" class="btn btn-sm btn-danger btn-delete-line" data-line-id="@line.Id" data-lock-posted="1">🗑️</button>
                                                </td>
                                            </tr>
                                            lineNo++;
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="10" class="text-center text-muted py-4">لا توجد سطور بعد.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Anti-forgery token
        function getAntiForgeryToken() {
            const form = document.getElementById('__AntiForgeryForm');
            return form?.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        let productInfoCache = null;

        // قفل الأزرار والحقول عند الترحيل (مثل تسوية الجرد)
        function isTransferPosted() {
            const flag = document.getElementById('TransferIsPostedFlag');
            return flag && flag.value === '1';
        }
        function setTransferPosted(posted) {
            const flag = document.getElementById('TransferIsPostedFlag');
            if (flag) flag.value = posted ? '1' : '0';
        }
        function applyPostedUiLock() {
            const posted = isTransferPosted();
            const lockables = document.querySelectorAll('[data-lock-posted="1"]');
            lockables.forEach(el => {
                if (el.dataset.lockInit !== '1') {
                    el.dataset.lockInit = '1';
                    el.dataset.origDisabled = el.disabled ? '1' : '0';
                    el.dataset.origReadonly = el.readOnly ? '1' : '0';
                    el.dataset.origTabIndex = el.getAttribute('tabindex') ?? '';
                }
                const tag = (el.tagName || '').toUpperCase();
                if (posted) {
                    if (tag === 'BUTTON') { el.disabled = true; return; }
                    if (tag === 'A') { el.classList.add('disabled', 'pe-none'); el.setAttribute('aria-disabled', 'true'); el.setAttribute('tabindex', '-1'); return; }
                    if (tag === 'INPUT' || tag === 'TEXTAREA') { el.readOnly = true; el.classList.add('bg-light', 'text-muted'); return; }
                    if (tag === 'SELECT') { el.disabled = true; return; }
                    return;
                }
                const origDisabled = el.dataset.origDisabled === '1';
                const origReadonly = el.dataset.origReadonly === '1';
                const origTabIndex = el.dataset.origTabIndex;
                if (tag === 'BUTTON') { el.disabled = origDisabled; return; }
                if (tag === 'A') { el.classList.remove('disabled', 'pe-none'); el.removeAttribute('aria-disabled'); if (origTabIndex === '') el.removeAttribute('tabindex'); else el.setAttribute('tabindex', origTabIndex); return; }
                if (tag === 'INPUT' || tag === 'TEXTAREA') { el.readOnly = origReadonly; el.classList.remove('bg-light', 'text-muted'); return; }
                if (tag === 'SELECT') { el.disabled = origDisabled; return; }
            });
            const btnPost = document.getElementById('btnPostTransfer');
            if (btnPost) { btnPost.disabled = posted; btnPost.innerHTML = posted ? '✅ تم ترحيل التحويل' : '📤 ترحيل التحويل'; }
            const btnOpen = document.getElementById('btnOpenTransfer');
            if (btnOpen) btnOpen.disabled = !posted;
        }
        (function() {
            const serverIsPosted = @Model.IsPosted.ToString().ToLower();
            if (serverIsPosted) { setTransferPosted(true); applyPostedUiLock(); }
        })();

        function clearAddLineFormAndFocus() {
            document.getElementById('ProdId').value = '';
            document.getElementById('ProdCodeInput').value = '';
            document.getElementById('ProdNameInput').value = '';
            document.getElementById('BatchSelect').innerHTML = '<option value="">-- اختر --</option>';
            document.getElementById('BatchId').value = '';
            document.getElementById('BatchNoInput').value = '';
            document.getElementById('ExpiryInput').value = '';
            document.getElementById('QtyAvailableInput').value = '0';
            document.getElementById('QtyInput').value = '0';
            document.getElementById('PriceRetailInput').value = '';
            document.getElementById('WeightedDiscountInput').value = '';
            document.getElementById('DiscountInput').value = '';
            document.getElementById('UnitCostInput').value = '';
            productInfoCache = null;
            const prodNameInput = document.getElementById('ProdNameInput');
            prodNameInput?.focus();
            prodNameInput?.select?.();
        }
        function clearAddLineForm() {
            clearAddLineFormAndFocus();
        }

        function escapeHtml(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

        function upsertTransferRow(result, lineNo) {
            const tbody = document.getElementById('TransferLinesTbody');
            const placeholder = tbody.querySelector('tr td[colspan="10"]');
            if (placeholder) placeholder.closest('tr').remove();
            const existingRow = tbody.querySelector(`tr[data-line-id="${result.lineId}"]`);
            const priceStr = result.priceRetail != null ? parseFloat(result.priceRetail).toFixed(2) : '-';
            const wdStr = result.weightedDiscountPct != null ? parseFloat(result.weightedDiscountPct).toFixed(2) : '-';
            const dStr = result.discountPct != null ? parseFloat(result.discountPct).toFixed(2) : '-';
            const totalStr = result.total != null ? parseFloat(result.total).toFixed(2) : '-';
            const rowHtml = `<tr data-line-id="${result.lineId}">
                <td class="text-center">${lineNo}</td>
                <td>${escapeHtml(result.productName)}</td>
                <td class="text-center">${escapeHtml(result.batchNo)}</td>
                <td class="text-center">${escapeHtml(result.expiryDisplay)}</td>
                <td class="text-center">${result.qty}</td>
                <td class="text-center">${priceStr}</td>
                <td class="text-center">${wdStr}</td>
                <td class="text-center">${dStr}</td>
                <td class="text-center">${totalStr}</td>
                <td class="text-center no-print">
                    <button type="button" class="btn btn-sm btn-danger btn-delete-line" data-line-id="${result.lineId}" data-lock-posted="1">🗑️</button>
                </td>
            </tr>`;
            if (existingRow) existingRow.outerHTML = rowHtml;
            else tbody.insertAdjacentHTML('beforeend', rowHtml);
            if (tbody.querySelectorAll('tr[data-line-id]').length === 0)
                tbody.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-4">لا توجد سطور بعد.</td></tr>';
        }

        async function loadTransferProductInfo() {
            const prodId = parseInt(document.getElementById('ProdId').value || '0', 10);
            const fromWh = parseInt(document.querySelector('[name="FromWarehouseId"]')?.value || '0', 10);
            if (!prodId || prodId <= 0 || !fromWh || fromWh <= 0) {
                document.getElementById('BatchSelect').innerHTML = '<option value="">-- اختر --</option>';
                document.getElementById('BatchId').value = '';
                document.getElementById('BatchNoInput').value = '';
                document.getElementById('ExpiryInput').value = '';
                document.getElementById('QtyAvailableInput').value = '0';
                document.getElementById('PriceRetailInput').value = '';
                document.getElementById('WeightedDiscountInput').value = '';
                document.getElementById('UnitCostInput').value = '';
                productInfoCache = null;
                return;
            }
            try {
                const res = await fetch(`@Url.Action("GetTransferProductInfo", "StockTransfers")?prodId=${prodId}&fromWarehouseId=${fromWh}`);
                if (!res.ok) return;
                const data = await res.json();
                if (!data.ok) return;
                const batches = data.batches || [];
                productInfoCache = data;

                const sel = document.getElementById('BatchSelect');
                sel.innerHTML = '<option value="">-- اختر --</option>';
                batches.forEach((b, idx) => {
                    const opt = document.createElement('option');
                    const bid = b.batchId ?? b.BatchId ?? idx;
                    const bno = (b.batchNo ?? b.BatchNo ?? '').toString();
                    const exp = (b.expiryText ?? b.ExpiryText ?? '-').toString();
                    opt.value = bid;
                    opt.textContent = (bno || '-') + ' | ' + (exp || '-');
                    opt.dataset.batchNo = bno;
                    opt.dataset.expiry = exp;
                    opt.dataset.priceRetail = b.priceRetailBatch ?? b.PriceRetailBatch ?? '';
                    opt.dataset.unitCost = b.unitCost ?? b.UnitCost ?? '';
                    opt.dataset.qty = (b.qty ?? b.Qty ?? 0).toString();
                    sel.appendChild(opt);
                });

                document.getElementById('PriceRetailInput').value = data.priceRetail ?? '';
                document.getElementById('WeightedDiscountInput').value = data.weightedDiscount ?? '';
                document.getElementById('UnitCostInput').value = data.unitCost ?? '';
                document.getElementById('QtyAvailableInput').value = '0';

                // FIFO: اختيار أول تشغيلة تلقائياً (مرتبة حسب الصلاحية)
                if (batches.length >= 1) {
                    const first = batches[0];
                    const firstId = first.batchId ?? first.BatchId ?? 0;
                    sel.value = firstId;
                    document.getElementById('BatchId').value = firstId;
                    document.getElementById('BatchNoInput').value = (first.batchNo ?? first.BatchNo ?? '').toString();
                    document.getElementById('ExpiryInput').value = (first.expiryText ?? first.ExpiryText ?? '').toString();
                    document.getElementById('PriceRetailInput').value = first.priceRetailBatch ?? first.PriceRetailBatch ?? data.priceRetail ?? '';
                    document.getElementById('UnitCostInput').value = first.unitCost ?? first.UnitCost ?? data.unitCost ?? '';
                    document.getElementById('QtyAvailableInput').value = (first.qty ?? first.Qty ?? 0).toString();
                }
            } catch (e) {
                console.warn('loadTransferProductInfo:', e);
            }
        }

        function onProductSelected() {
            const val = document.getElementById('ProdNameInput')?.value?.trim();
            if (!val) return;
            const selectedOption = document.querySelector(`#productsList option[value="${val}"]`);
            if (selectedOption) {
                const id = selectedOption.getAttribute('data-id');
                document.getElementById('ProdId').value = id;
                document.getElementById('ProdCodeInput').value = id;
                loadTransferProductInfo();
            }
        }

        document.getElementById('ProdNameInput')?.addEventListener('input', onProductSelected);
        document.getElementById('ProdNameInput')?.addEventListener('change', onProductSelected);

        document.getElementById('ProdCodeInput')?.addEventListener('input', function() {
            const code = this.value;
            if (code && code > 0) {
                const selectedOption = document.querySelector(`#productsList option[data-id="${code}"]`);
                if (selectedOption) {
                    document.getElementById('ProdId').value = code;
                    document.getElementById('ProdNameInput').value = selectedOption.value;
                    loadTransferProductInfo();
                }
            }
        });

        document.querySelector('[name="FromWarehouseId"]')?.addEventListener('change', function() {
            if (document.getElementById('ProdId').value) loadTransferProductInfo();
        });

        document.getElementById('BatchSelect')?.addEventListener('change', function() {
            const opt = this.options[this.selectedIndex];
            if (opt && opt.value) {
                document.getElementById('BatchId').value = opt.value;
                document.getElementById('BatchNoInput').value = opt.dataset.batchNo || '';
                document.getElementById('ExpiryInput').value = opt.dataset.expiry || '';
                document.getElementById('PriceRetailInput').value = opt.dataset.priceRetail || '';
                document.getElementById('UnitCostInput').value = opt.dataset.unitCost || '';
                document.getElementById('QtyAvailableInput').value = opt.dataset.qty || '0';
            } else {
                document.getElementById('BatchId').value = '';
                document.getElementById('BatchNoInput').value = '';
                document.getElementById('ExpiryInput').value = '';
                document.getElementById('QtyAvailableInput').value = '0';
                if (productInfoCache) {
                    document.getElementById('PriceRetailInput').value = productInfoCache.priceRetail || '';
                    document.getElementById('UnitCostInput').value = productInfoCache.unitCost || '';
                }
            }
        });

        // Add line
        document.getElementById('btnAddTransferLine')?.addEventListener('click', async function() {
            if (typeof isTransferPosted === 'function' && isTransferPosted()) return;
            const transferId = parseInt(document.getElementById('TransferId').value || '0', 10);
            if (!transferId || transferId <= 0) {
                alert('لا يمكن إضافة سطور قبل حفظ التحويل. اضغط "حفظ التحويل" أولاً.');
                return;
            }

            const prodId = parseInt(document.getElementById('ProdId').value || '0', 10);
            const qty = parseInt(document.getElementById('QtyInput').value || '0', 10);
            const batchId = document.getElementById('BatchId').value ? parseInt(document.getElementById('BatchId').value, 10) : null;
            const batchNo = document.getElementById('BatchNoInput').value?.trim() || '';
            const unitCost = parseFloat(document.getElementById('UnitCostInput').value || '0');
            const priceRetail = document.getElementById('PriceRetailInput').value ? parseFloat(document.getElementById('PriceRetailInput').value) : null;
            const weightedDiscountPct = document.getElementById('WeightedDiscountInput').value ? parseFloat(document.getElementById('WeightedDiscountInput').value) : null;
            const discountPct = document.getElementById('DiscountInput').value ? parseFloat(document.getElementById('DiscountInput').value) : null;

            if (!prodId || prodId <= 0) {
                alert('من فضلك اختر صنفاً صحيحاً.');
                return;
            }

            if (!qty || qty <= 0) {
                alert('الكمية يجب أن تكون أكبر من صفر.');
                return;
            }

            const dto = {
                stockTransferId: transferId,
                productId: prodId,
                batchId: batchId,
                batchNo: batchNo,
                qty: qty,
                unitCost: unitCost,
                priceRetail: priceRetail,
                weightedDiscountPct: weightedDiscountPct,
                discountPct: discountPct,
                note: ''
            };

            const token = getAntiForgeryToken();
            this.disabled = true;

            try {
                const response = await fetch('@Url.Action("AddLineJson", "StockTransfers")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(dto)
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    alert('حدث خطأ أثناء إضافة السطر: ' + errorText);
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    const tbody = document.getElementById('TransferLinesTbody');
                    const currentRows = tbody.querySelectorAll('tr[data-line-id]');
                    const lineNo = currentRows.length + 1;
                    upsertTransferRow(result, lineNo);
                    clearAddLineFormAndFocus();
                } else {
                    alert(result.message || 'حدث خطأ أثناء إضافة السطر.');
                }
            } catch (error) {
                console.error('Error adding line:', error);
                alert('حدث خطأ أثناء إضافة السطر.');
            } finally {
                this.disabled = false;
            }
        });

        // Delete line (event delegation للصفوف المضافة ديناميكياً)
        document.getElementById('TransferLinesTbody')?.addEventListener('click', async function(e) {
            const btn = e.target.closest('.btn-delete-line');
            if (!btn) return;
            if (btn.disabled) return;
            const lineId = parseInt(btn.getAttribute('data-line-id') || '0', 10);
            if (!lineId || lineId <= 0) return;
            if (typeof isTransferPosted === 'function' && isTransferPosted()) return;

            if (!confirm('هل أنت متأكد من حذف هذا السطر؟')) return;

            const token = getAntiForgeryToken();
            btn.disabled = true;

            try {
                const response = await fetch(`@Url.Action("DeleteLineJson", "StockTransfers")?id=${lineId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });

                if (!response.ok) {
                    alert('حدث خطأ أثناء حذف السطر.');
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    const row = btn.closest('tr');
                    if (row) row.remove();
                    const tbody = document.getElementById('TransferLinesTbody');
                    if (tbody && tbody.querySelectorAll('tr[data-line-id]').length === 0) {
                        tbody.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-4">لا توجد سطور بعد.</td></tr>';
                    }
                } else {
                    alert(result.message || 'حدث خطأ أثناء حذف السطر.');
                }
            } catch (error) {
                console.error('Error deleting line:', error);
                alert('حدث خطأ أثناء حذف السطر.');
            } finally {
                btn.disabled = false;
            }
        });

        // Save header
        document.getElementById('btnSaveTransferHeader')?.addEventListener('click', async function() {
            const transferId = parseInt(document.getElementById('TransferId').value || '0', 10);
            const transferDate = document.getElementById('TransferDateInput').value;
            const fromWarehouseId = document.querySelector('[name="FromWarehouseId"]').value;
            const toWarehouseId = document.querySelector('[name="ToWarehouseId"]').value;
            const note = document.querySelector('[name="Note"]').value;

            if (!fromWarehouseId || fromWarehouseId <= 0) {
                alert('من فضلك اختر المخزن المصدر.');
                return;
            }

            if (!toWarehouseId || toWarehouseId <= 0) {
                alert('من فضلك اختر المخزن الوجهة.');
                return;
            }

            if (fromWarehouseId == toWarehouseId) {
                alert('لا يمكن أن يكون المخزن المصدر هو نفس المخزن الوجهة.');
                return;
            }

            const dto = {
                id: transferId,
                transferDate: transferDate,
                fromWarehouseId: parseInt(fromWarehouseId, 10),
                toWarehouseId: parseInt(toWarehouseId, 10),
                note: note
            };

            const token = getAntiForgeryToken();
            this.disabled = true;

            try {
                const url = transferId > 0 
                    ? '@Url.Action("UpdateHeaderJson", "StockTransfers")'
                    : '@Url.Action("CreateHeaderJson", "StockTransfers")';

                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(dto)
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    alert('حدث خطأ أثناء حفظ التحويل: ' + errorText);
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    if (result.id && result.id > 0) {
                        document.getElementById('TransferId').value = result.id;
                        document.getElementById('TransferNumberDisplay').value = result.id;
                        const baseUrl = '@Url.Action("Show", "StockTransfers")';
                        const newPath = baseUrl + '/' + result.id + (window.location.search || '');
                        window.history.replaceState({}, '', newPath);
                        document.title = 'تحويل مخزني — رقم ' + result.id;
                    }
                    const ProdNameInput = document.getElementById('ProdNameInput');
                    ProdNameInput?.focus();
                    ProdNameInput?.select?.();
                } else {
                    alert(result.message || 'حدث خطأ أثناء حفظ التحويل.');
                }
            } catch (error) {
                console.error('Error saving transfer:', error);
                alert('حدث خطأ أثناء حفظ التحويل.');
            } finally {
                this.disabled = false;
            }
        });

        // Post transfer — تحديث الواجهة دون إعادة تحميل
        document.getElementById('btnPostTransfer')?.addEventListener('click', async function() {
            const transferId = parseInt(document.getElementById('TransferId').value || '0', 10);
            if (!transferId || transferId <= 0) {
                alert('يجب حفظ التحويل أولاً قبل الترحيل.');
                return;
            }

            if (!confirm('هل أنت متأكد من ترحيل هذا التحويل؟')) return;

            const token = getAntiForgeryToken();
            const msgDiv = document.getElementById('postTransferMsg');
            const btnPost = this;
            const oldHtml = btnPost.innerHTML;
            btnPost.disabled = true;
            btnPost.innerHTML = '⏳ جاري الترحيل...';
            if (msgDiv) { msgDiv.textContent = 'يتم حفظ التعديلات ثم الترحيل...'; msgDiv.className = 'small mt-2 text-muted'; }

            try {
                // حفظ الهيدر أولاً (لتطبيق أي تعديل)
                const transferDate = document.getElementById('TransferDateInput')?.value;
                const fromWarehouseId = parseInt(document.querySelector('[name="FromWarehouseId"]')?.value || '0', 10);
                const toWarehouseId = parseInt(document.querySelector('[name="ToWarehouseId"]')?.value || '0', 10);
                const note = document.querySelector('[name="Note"]')?.value || '';
                if (fromWarehouseId > 0 && toWarehouseId > 0 && fromWarehouseId !== toWarehouseId) {
                    const saveDto = { id: transferId, transferDate: transferDate, fromWarehouseId: fromWarehouseId, toWarehouseId: toWarehouseId, note: note };
                    const saveRes = await fetch('@Url.Action("UpdateHeaderJson", "StockTransfers")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                        body: JSON.stringify(saveDto)
                    });
                    if (!saveRes.ok) {
                        const errTxt = await saveRes.text();
                        if (msgDiv) { msgDiv.textContent = 'تعذر حفظ التعديلات: ' + errTxt; msgDiv.className = 'small mt-2 text-danger'; }
                        btnPost.disabled = false; btnPost.innerHTML = oldHtml;
                        return;
                    }
                    const saveResult = await saveRes.json();
                    if (!saveResult || !saveResult.ok) {
                        if (msgDiv) { msgDiv.textContent = (saveResult && saveResult.message) ? saveResult.message : 'تعذر حفظ التعديلات قبل الترحيل.'; msgDiv.className = 'small mt-2 text-danger'; }
                        btnPost.disabled = false; btnPost.innerHTML = oldHtml;
                        return;
                    }
                }
                if (msgDiv) { msgDiv.textContent = 'جاري الترحيل...'; msgDiv.className = 'small mt-2 text-muted'; }

                const response = await fetch(`@Url.Action("PostTransfer", "StockTransfers")?id=${transferId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    if (msgDiv) { msgDiv.textContent = 'خطأ: ' + errorText; msgDiv.className = 'small mt-2 text-danger'; }
                    btnPost.disabled = false;
                    btnPost.innerHTML = oldHtml;
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    setTransferPosted(true);
                    applyPostedUiLock();
                    const statusDisplay = document.getElementById('TransferStatusDisplay');
                    if (statusDisplay) statusDisplay.value = 'مترحل';
                    const btnOpen = document.getElementById('btnOpenTransfer');
                    if (btnOpen) btnOpen.disabled = false;
                    btnPost.innerHTML = '✅ تم ترحيل التحويل';
                    btnPost.disabled = true;
                    if (msgDiv) { msgDiv.textContent = result.message || 'تم الترحيل بنجاح.'; msgDiv.className = 'small mt-2 text-success'; }
                } else {
                    if (msgDiv) { msgDiv.textContent = result.message || 'حدث خطأ أثناء الترحيل.'; msgDiv.className = 'small mt-2 text-danger'; }
                    btnPost.disabled = false;
                    btnPost.innerHTML = oldHtml;
                }
            } catch (error) {
                console.error('Error posting transfer:', error);
                if (msgDiv) { msgDiv.textContent = 'حدث خطأ أثناء الترحيل.'; msgDiv.className = 'small mt-2 text-danger'; }
                btnPost.disabled = false;
                btnPost.innerHTML = oldHtml;
            }
        });

        // Open transfer — تحديث الواجهة دون إعادة تحميل
        document.getElementById('btnOpenTransfer')?.addEventListener('click', async function() {
            const transferId = parseInt(document.getElementById('TransferId').value || '0', 10);
            if (!transferId || transferId <= 0) {
                alert('لا توجد تحويل لفتحه.');
                return;
            }

            if (!confirm('هل أنت متأكد من فتح هذا التحويل؟')) return;

            const token = getAntiForgeryToken();
            this.disabled = true;

            try {
                const response = await fetch(`@Url.Action("OpenTransfer", "StockTransfers")?id=${transferId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });

                if (!response.ok) {
                    alert('حدث خطأ أثناء فتح التحويل.');
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    setTransferPosted(false);
                    applyPostedUiLock();
                    const statusDisplay = document.getElementById('TransferStatusDisplay');
                    if (statusDisplay) statusDisplay.value = 'مسودة';
                    const btnPost = document.getElementById('btnPostTransfer');
                    if (btnPost) { btnPost.disabled = false; btnPost.innerHTML = '📤 ترحيل التحويل'; }
                    const btnOpen = document.getElementById('btnOpenTransfer');
                    if (btnOpen) btnOpen.disabled = true;
                    alert('تم فتح التحويل بنجاح.');
                } else {
                    alert(result.message || 'حدث خطأ أثناء فتح التحويل.');
                }
            } catch (error) {
                console.error('Error opening transfer:', error);
                alert('حدث خطأ أثناء فتح التحويل.');
            } finally {
                this.disabled = false;
            }
        });

        // Clear lines — مسح السطور يغيّر بنية الجدول — إعادة تحميل
        document.getElementById('btnClearTransferLines')?.addEventListener('click', async function() {
            if (typeof isTransferPosted === 'function' && isTransferPosted()) return;
            const transferId = parseInt(document.getElementById('TransferId').value || '0', 10);
            if (!transferId || transferId <= 0) {
                alert('لا توجد تحويل لمسح سطوره.');
                return;
            }

            if (!confirm('هل أنت متأكد من مسح كل سطور التحويل؟')) return;

            const token = getAntiForgeryToken();
            this.disabled = true;

            try {
                const response = await fetch(`@Url.Action("ClearLinesJson", "StockTransfers")?id=${transferId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });

                if (!response.ok) {
                    alert('حدث خطأ أثناء مسح السطور.');
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    alert('تم مسح السطور بنجاح.');
                    window.location.reload();
                } else {
                    alert(result.message || 'حدث خطأ أثناء مسح السطور.');
                }
            } catch (error) {
                console.error('Error clearing lines:', error);
                alert('حدث خطأ أثناء مسح السطور.');
            } finally {
                this.disabled = false;
            }
        });

        // الانتقال بـ Enter بين الحقول وزر الإضافة
        const enterNavFields = [
            document.getElementById('ProdCodeInput'),
            document.getElementById('ProdNameInput'),
            document.getElementById('BatchSelect'),
            document.getElementById('ExpiryInput'),
            document.getElementById('QtyInput'),
            document.getElementById('DiscountInput'),
            document.getElementById('btnAddTransferLine')
        ].filter(Boolean);

        enterNavFields.forEach((el, idx) => {
            if (el.dataset.boundEnterNav === '1') return;
            el.dataset.boundEnterNav = '1';
            el.addEventListener('keydown', function(e) {
                if (e.key !== 'Enter') return;
                e.preventDefault();
                if (el === document.getElementById('ProdNameInput')) {
                    const opt = document.querySelector(`#productsList option[value="${el.value}"]`);
                    if (opt) {
                        document.getElementById('ProdId').value = opt.getAttribute('data-id');
                        document.getElementById('ProdCodeInput').value = opt.getAttribute('data-id');
                        loadTransferProductInfo();
                    }
                }
                if (el === document.getElementById('ProdCodeInput')) {
                    const code = el.value;
                    if (code) {
                        const opt = document.querySelector(`#productsList option[data-id="${code}"]`);
                        if (opt) {
                            document.getElementById('ProdId').value = code;
                            document.getElementById('ProdNameInput').value = opt.value;
                            loadTransferProductInfo();
                        }
                    }
                }
                const next = enterNavFields[idx + 1];
                if (el === document.getElementById('btnAddTransferLine') || el === document.getElementById('DiscountInput')) {
                    document.getElementById('btnAddTransferLine')?.click();
                } else if (next) {
                    next.focus();
                    if (typeof next.select === 'function') next.select?.();
                }
            });
        });
    </script>
}
