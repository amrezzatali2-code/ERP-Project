        // Clear lines — مسح السطور يغيّر بنية الجدول — إعادة تحميل
        document.getElementById('btnClearTransferLines')?.addEventListener('click', async function() {
            if (typeof isTransferPosted === 'function' && isTransferPosted()) return;
            const transferId = parseInt(document.getElementById('TransferId').value || '0', 10);
            if (!transferId || transferId <= 0) {
                alert('لا توجد تحويل لمسح سطوره.');
                return;
            }

            if (!confirm('هل أنت متأكد من مسح كل سطور التحويل؟')) return;

            const token = getAntiForgeryToken();
            this.disabled = true;

            try {
                const response = await fetch(`@Url.Action("ClearLinesJson", "StockTransfers")?id=${transferId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });

                if (!response.ok) {
                    alert('حدث خطأ أثناء مسح السطور.');
                    return;
                }

                const result = await response.json();
                if (result.ok) {
                    alert('تم مسح السطور بنجاح.');
                    window.location.reload();
                } else {
                    alert(result.message || 'حدث خطأ أثناء مسح السطور.');
                }
            } catch (error) {
                console.error('Error clearing lines:', error);
                alert('حدث خطأ أثناء مسح السطور.');
            } finally {
                this.disabled = false;
            }
        });

        // الانتقال بـ Enter بين الحقول وزر الإضافة
        const enterNavFields = [
            document.getElementById('ProdCodeInput'),
            document.getElementById('ProdNameInput'),
            document.getElementById('BatchSelect'),
            document.getElementById('ExpiryInput'),
            document.getElementById('QtyInput'),
            document.getElementById('DiscountInput'),
            document.getElementById('btnAddTransferLine')
        ].filter(Boolean);

        enterNavFields.forEach((el, idx) => {
            if (el.dataset.boundEnterNav === '1') return;
            el.dataset.boundEnterNav = '1';
            el.addEventListener('keydown', function(e) {
                if (e.key !== 'Enter') return;
                e.preventDefault();
                if (el === document.getElementById('ProdNameInput') && typeof window.stTransferApplyProductByName === 'function') {
                    window.stTransferApplyProductByName(el.value);
                }
                if (el === document.getElementById('ProdCodeInput') && typeof window.stTransferApplyProductByCode === 'function') {
                    window.stTransferApplyProductByCode(el.value);
                }
                const next = enterNavFields[idx + 1];
                if (el === document.getElementById('btnAddTransferLine') || el === document.getElementById('DiscountInput')) {
                    document.getElementById('btnAddTransferLine')?.click();
                } else if (next) {
                    next.focus();
                    if (typeof next.select === 'function') next.select?.();
                }
            });
        });

        // طباعة التحويل — نفس فكرة فاتورة المبيعات (أصل / أصل+صورة / أصل+صورتين)
        document.addEventListener('DOMContentLoaded', function() {
            let printing = false;
            let printWrapperParent = null;
            let printWrapperNext = null;

            function prepareStockTransferPrint() {
                const linesWrap = document.getElementById('stPrintLinesWrap');
                const totalsWrap = document.getElementById('stPrintTotalsWrap');
                if (!linesWrap || !totalsWrap) return false;

                const setTxt = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val || ''; };
                setTxt('stPrintNow', new Date().toLocaleString('ar-EG'));
                setTxt('stPrintTransferNo', document.getElementById('TransferNumberDisplay')?.value || '');
                setTxt('stPrintTransferDate', document.getElementById('TransferDateInput')?.value || '');
                const fromSel = document.querySelector('[name="FromWarehouseId"]');
                const toSel = document.querySelector('[name="ToWarehouseId"]');
                setTxt('stPrintFromWh', fromSel && fromSel.selectedIndex >= 0 ? (fromSel.options[fromSel.selectedIndex].text || '').trim() : '');
                setTxt('stPrintToWh', toSel && toSel.selectedIndex >= 0 ? (toSel.options[toSel.selectedIndex].text || '').trim() : '');
                setTxt('stPrintStatus', document.getElementById('TransferStatusDisplay')?.value || '');
                const note = (document.querySelector('[name="Note"]')?.value || '').trim();
                setTxt('stPrintNote', note || '—');

                const table = document.getElementById('TransferLinesTable');
                linesWrap.innerHTML = '';
                if (table) {
                    const clone = table.cloneNode(true);
                    clone.querySelectorAll('tr.table-active').forEach(tr => tr.classList.remove('table-active'));
                    clone.querySelectorAll('button, a').forEach(x => x.remove());
                    linesWrap.appendChild(clone);
                } else {
                    linesWrap.innerHTML = '<div class="text-muted small p-2">لا توجد سطور للطباعة.</div>';
                }

                const tl = document.getElementById('StTotalLinesValue')?.textContent?.trim() || '0';
                const ti = document.getElementById('StTotalItemsValue')?.textContent?.trim() || '0';
                const tq = document.getElementById('StTotalQtyValue')?.textContent?.trim() || '0';
                const trv = document.getElementById('StTotalRetailValue')?.textContent?.trim() || '0';
                const tc = document.getElementById('StTotalCostValue')?.textContent?.trim() || '0';
                const tg = document.getElementById('StGrandTotalValue')?.textContent?.trim() || '0';

                totalsWrap.innerHTML = `
                    <table class="table table-sm table-bordered w-100 mb-0">
                        <thead><tr><th class="text-center" colspan="4">الإجماليات</th></tr></thead>
                        <tbody>
                            <tr><td>عدد السطور</td><td><strong>${tl}</strong></td><td>عدد الأصناف</td><td><strong>${ti}</strong></td></tr>
                            <tr><td>إجمالي الكمية</td><td><strong>${tq}</strong></td><td>إجمالي سعر الجمهور</td><td><strong>${trv}</strong></td></tr>
                            <tr><td>إجمالي التكلفة</td><td><strong>${tc}</strong></td><td>الإجمالي</td><td><strong>${tg}</strong></td></tr>
                        </tbody>
                    </table>`;
                return true;
            }

            function doStockPrint(mode) {
                const transferId = parseInt(document.getElementById('TransferId')?.value || '0', 10) || 0;
                if (transferId <= 0) {
                    erpToast('⚠️ لا يمكن طباعة التحويل قبل حفظه.', 'warning');
                    return;
                }
                if (typeof isTransferPosted === 'function' && !isTransferPosted()) {
                    erpToast('❌ يجب ترحيل التحويل قبل الطباعة.', 'danger');
                    document.getElementById('btnPostTransfer')?.focus();
                    return;
                }
                if (printing) return;
                printing = true;
                if (!prepareStockTransferPrint()) {
                    printing = false;
                    erpToast('تعذر تجهيز الطباعة.', 'danger');
                    return;
                }

                const wrapper = document.getElementById('stPrintWrapper');
                const printArea = document.getElementById('stPrintArea');
                if (!wrapper || !printArea) { printing = false; return; }

                wrapper.classList.remove('print-mode-1', 'print-mode-2', 'print-mode-3');
                wrapper.querySelectorAll('.st-print-copy:not(#stPrintArea)').forEach(c => c.remove());

                if (mode === 2 || mode === 3) {
                    const copies = mode === 2 ? 2 : 3;
                    for (let i = 1; i < copies; i++) {
                        const clone = printArea.cloneNode(true);
                        clone.id = '';
                        clone.classList.add('st-print-copy');
                        clone.querySelectorAll('[id]').forEach(el => el.removeAttribute('id'));
                        wrapper.appendChild(clone);
                    }
                    wrapper.classList.add('print-mode-' + mode);
                } else {
                    wrapper.classList.add('print-mode-1');
                }

                printWrapperParent = null;
                printWrapperNext = null;
                if (wrapper.parentNode !== document.body) {
                    printWrapperParent = wrapper.parentNode;
                    printWrapperNext = wrapper.nextSibling;
                    document.body.appendChild(wrapper);
                }

                document.body.classList.add('printing-invoice');
                setTimeout(() => window.print(), 50);
            }

            document.querySelectorAll('[data-st-print-mode]').forEach(item => {
                item.addEventListener('click', function(e) {
                    e.preventDefault();
                    const mode = parseInt(this.getAttribute('data-st-print-mode') || '1', 10);
                    doStockPrint(mode);
                });
            });

            window.addEventListener('afterprint', function() {
                document.body.classList.remove('printing-invoice');
                printing = false;
                const wrapper = document.getElementById('stPrintWrapper');
                if (wrapper) {
                    wrapper.classList.remove('print-mode-1', 'print-mode-2', 'print-mode-3');
                    wrapper.querySelectorAll('.st-print-copy:not(#stPrintArea)').forEach(c => c.remove());
                    if (printWrapperParent) {
                        if (printWrapperNext) {
                            printWrapperParent.insertBefore(wrapper, printWrapperNext);
                        } else {
                            printWrapperParent.appendChild(wrapper);
                        }
                        printWrapperParent = null;
                        printWrapperNext = null;
                    }
                }
            });
        });

        updateDeleteSelectedButton();
    </script>
}
