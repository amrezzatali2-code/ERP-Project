@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<ERP.Models.StockTransfer>

@{
    ViewData["Title"] = "التحويلات بين المخازن";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "StockTransfers";

    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (Model.SearchBy ?? (string?)ViewBag.SearchBy ?? "all").ToLowerInvariant();
    var searchMode = ((string?)ViewBag.SearchMode ?? "contains").ToLowerInvariant();
    if (searchMode != "starts" && searchMode != "ends") searchMode = "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "id";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = (int?)ViewBag.PageSize ?? Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
    int end = (ps == 0 || total == 0) ? total : Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;

    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_date = ViewBag.FilterCol_Date as string;
    string? filterCol_fromwarehouse = ViewBag.FilterCol_FromWarehouse as string;
    string? filterCol_fromwarehouseExpr = ViewBag.FilterCol_FromWarehouseExpr as string;
    string? filterCol_towarehouse = ViewBag.FilterCol_ToWarehouse as string;
    string? filterCol_towarehouseExpr = ViewBag.FilterCol_ToWarehouseExpr as string;
    string? filterCol_note = ViewBag.FilterCol_Note as string;
    string? filterCol_created = ViewBag.FilterCol_Created as string;
    string? filterCol_updated = ViewBag.FilterCol_Updated as string;

    int totalPosted = ViewBag.TotalPostedFiltered != null ? (int)ViewBag.TotalPostedFiltered : 0;
    int totalUnposted = ViewBag.TotalUnpostedFiltered != null ? (int)ViewBag.TotalUnpostedFiltered : 0;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_idExpr,
        filterCol_date,
        filterCol_fromwarehouse,
        filterCol_fromwarehouseExpr,
        filterCol_towarehouse,
        filterCol_towarehouseExpr,
        filterCol_note,
        filterCol_created,
        filterCol_updated
    })!;

    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            searchMode,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate,
            fromCode,
            toCode,
            filterCol_id,
            filterCol_idExpr,
            filterCol_date,
            filterCol_fromwarehouse,
            filterCol_fromwarehouseExpr,
            filterCol_towarehouse,
            filterCol_towarehouseExpr,
            filterCol_note,
            filterCol_created,
            filterCol_updated
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    string? FilterForCol(string colKey) =>
        colKey == "id" ? (!string.IsNullOrWhiteSpace(filterCol_idExpr) ? filterCol_idExpr : filterCol_id)
        : colKey == "fromwarehouse" ? (!string.IsNullOrWhiteSpace(filterCol_fromwarehouseExpr) ? filterCol_fromwarehouseExpr : filterCol_fromwarehouse)
        : colKey == "towarehouse" ? (!string.IsNullOrWhiteSpace(filterCol_towarehouseExpr) ? filterCol_towarehouseExpr : filterCol_towarehouse)
        : colKey == "date" ? filterCol_date
        : colKey == "note" ? filterCol_note
        : colKey == "created" ? filterCol_created
        : colKey == "updated" ? filterCol_updated
        : null;

    // عمود قابل للفلترة (بنمط Excel)
    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    @* رسائل النجاح/الخطأ تُعرض من _Layout.cshtml *@

    @* ===== شريط الفلاتر الموحد (نمط القوائم) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في التحويلات</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100" style="overflow-x:auto;">
                        <select name="searchMode" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:110px;min-width:100px" title="نوع البحث في الحقول النصية">
                            <option value="starts"@Html.Raw(searchMode == "starts" ? " selected" : "")>يبدأ بـ</option>
                            <option value="contains"@Html.Raw(searchMode == "contains" || string.IsNullOrEmpty(searchMode) ? " selected" : "")>يحتوي</option>
                            <option value="ends"@Html.Raw(searchMode == "ends" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                        <input type="text" name="search" class="form-control erp-filter-input flex-shrink-1" placeholder="نص أو رقم..." value="@search" style="min-width:100px;max-width:200px;width:180px;" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:190px;min-width:130px">
                            <option value="all" @Html.Raw(searchBy == "all" ? " selected" : "")>كل الحقول</option>
                            <option value="id" @Html.Raw(searchBy == "id" ? " selected" : "")>كود التحويل</option>
                            <option value="fromwarehouse" @Html.Raw(searchBy == "fromwarehouse" ? " selected" : "")>من مخزن</option>
                            <option value="towarehouse" @Html.Raw(searchBy == "towarehouse" ? " selected" : "")>إلى مخزن</option>
                            <option value="note" @Html.Raw(searchBy == "note" ? " selected" : "")>الملاحظات</option>
                            <option value="date" @Html.Raw(searchBy == "date" ? " selected" : "")>بتاريخ التحويل</option>
                        </select>
                    </div>
                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-2 w-100">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>

                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_fromwarehouse)) { <input type="hidden" name="filterCol_fromwarehouse" value="@filterCol_fromwarehouse" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_fromwarehouseExpr)) { <input type="hidden" name="filterCol_fromwarehouseExpr" value="@filterCol_fromwarehouseExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_towarehouse)) { <input type="hidden" name="filterCol_towarehouse" value="@filterCol_towarehouse" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_towarehouseExpr)) { <input type="hidden" name="filterCol_towarehouseExpr" value="@filterCol_towarehouseExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_note)) { <input type="hidden" name="filterCol_note" value="@filterCol_note" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر كود من/إلى --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر كود التحويل</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="stCodeFromInput"
                           type="number"
                           class="form-control erp-filter-input"
                           placeholder="من"
                           value="@(fromCode?.ToString() ?? "")" />

                    <input id="stCodeToInput"
                           type="number"
                           class="form-control erp-filter-input"
                           placeholder="إلى"
                           value="@(toCode?.ToString() ?? "")" />

                    <button type="button"
                            id="btnStApplyCodeFilter"
                            class="btn btn-erp btn-erp-primary btn-erp-sm">
                        تطبيق
                    </button>

                    <button type="button"
                            id="btnStClearCodeFilter"
                            class="btn btn-erp btn-erp-secondary btn-erp-sm">
                        مسح
                    </button>
                </div>
            </div>

            @* --- القسم الثالث: نفس ترتيب قائمة المبيعات — صف1: تاريخ / أعمدة / طباعة / عرض — صف2: حذف + Excel + تصدير --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#stDateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#stColumnsModal">اختيار الأعمدة</button>
                        <button type="button" id="btnStPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <span class="erp-list-toolbar-selected-actions d-inline-flex flex-wrap gap-2 align-items-center" role="group" aria-label="إجراءات السطر المحدد">
                            <button type="button" id="btnShowSt" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="عرض التحويل المحدد">عرض</button>
                        </span>
                    </div>
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center" dir="rtl">
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnStDeleteSelected">حذف التحويلات المحددة</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnStDeleteAll">حذف كل التحويلات</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="StockTransfers" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="searchMode" value="@searchMode" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_fromwarehouse)) { <input type="hidden" name="filterCol_fromwarehouse" value="@filterCol_fromwarehouse" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_fromwarehouseExpr)) { <input type="hidden" name="filterCol_fromwarehouseExpr" value="@filterCol_fromwarehouseExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_towarehouse)) { <input type="hidden" name="filterCol_towarehouse" value="@filterCol_towarehouse" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_towarehouseExpr)) { <input type="hidden" name="filterCol_towarehouseExpr" value="@filterCol_towarehouseExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_note)) { <input type="hidden" name="filterCol_note" value="@filterCol_note" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:70px;min-width:70px;font-size:0.8rem;padding:0.25rem 0.4rem;">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                </div>
                <form id="stBulkDeleteForm" asp-action="BulkDelete" method="post" class="d-none">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="selectedIds" id="stSelectedIdsInput" />
                </form>
                <form id="stDeleteAllForm" asp-action="DeleteAll" method="post" class="d-none">
                    @Html.AntiForgeryToken()
                </form>
            </div>
        </div>
    </div>

    @* كروت الإجماليات — مباشرة فوق الجدول (نمط قائمة فواتير المبيعات) *@
    @{
        var nSum = System.Globalization.CultureInfo.InvariantCulture;
    }
    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row mb-2" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي العدد</div>
                    <div class="h4 mb-0 text-primary fw-bold">@total.ToString("N0", nSum)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #15803d !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">مُرحّل</div>
                    <div class="h4 mb-0 fw-bold" style="color:#15803d">@totalPosted.ToString("N0", nSum)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #b45309 !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">غير مُرحّل</div>
                    <div class="h4 mb-0 fw-bold" style="color:#b45309">@totalUnposted.ToString("N0", nSum)</div>
                </div>
            </div>
        </div>
    </div>

    @* ===== جدول التحويلات داخل حاوية تمرير ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0">
        <div id="stTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="stTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                        <input type="checkbox" id="stChkAllRows" />
                    </th>

                    <th data-col="id">@filterableCol("id", "id", "كود التحويل")</th>
                    <th data-col="date">@filterableCol("date", "date", "تاريخ التحويل")</th>
                    <th data-col="fromwarehouse">@filterableCol("fromwarehouse", "fromwarehouse", "من مخزن")</th>
                    <th data-col="towarehouse">@filterableCol("towarehouse", "towarehouse", "إلى مخزن")</th>
                    <th data-col="note">@filterableCol("note", "note", "الملاحظات")</th>
                    <th data-col="created">@filterableCol("created", "created", "تاريخ الإنشاء")</th>
                    <th data-col="updated">@filterableCol("updated", "updated", "آخر تعديل")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var t in Model.Items)
                    {
                        var showU = Url.Action("Show", "StockTransfers", new { id = t.Id, frame = 1 });
                        <tr class="erp-list-selectable-row"
                            data-row-id="@t.Id"
                            data-show-url="@showU"
                            data-tab-title="تحويل مخزني"
                            data-transfer-id="@t.Id"
                            data-is-posted="@(t.IsPosted ? "1" : "0")">
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox" class="row-select" value="@t.Id" />
                            </td>

                            <td data-col="id">@t.Id</td>
                            <td data-col="date">@t.TransferDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td data-col="fromwarehouse">@t.FromWarehouseId</td>
                            <td data-col="towarehouse">@t.ToWarehouseId</td>
                            <td data-col="note">@((string.IsNullOrWhiteSpace(t.Note) ? "-" : t.Note))</td>
                            <td data-col="created">@t.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td data-col="updated">
                                @(t.UpdatedAt.HasValue
                                                        ? t.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")
                                                        : "-")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        </div>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة (نفس قائمة المبيعات) ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print" dir="rtl">
        <small class="text-muted text-start">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="searchMode" value="@searchMode" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_fromwarehouse)) { <input type="hidden" name="filterCol_fromwarehouse" value="@filterCol_fromwarehouse" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_fromwarehouseExpr)) { <input type="hidden" name="filterCol_fromwarehouseExpr" value="@filterCol_fromwarehouseExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_towarehouse)) { <input type="hidden" name="filterCol_towarehouse" value="@filterCol_towarehouse" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_towarehouseExpr)) { <input type="hidden" name="filterCol_towarehouseExpr" value="@filterCol_towarehouseExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_note)) { <input type="hidden" name="filterCol_note" value="@filterCol_note" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
            </select>
        </form>
    </div>

    @* ===== الترقيم (Pagination) بنفس شكل قائمة المبيعات ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== لوحة فلتر العمود (سكربت مشترك) ===== *@
<div id="erpColumnFilterPanelSt" class="erp-column-filter-panel d-none" dir="rtl">
    <div class="erp-column-filter-header">
        <span>ترتيب وفلتر</span>
        <button type="button" class="btn-close btn-sm" aria-label="إغلاق"></button>
    </div>
    <div class="erp-column-filter-body">
        <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
            <div class="d-flex flex-column gap-1">
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc"><span class="erp-sort-arrow">▲</span> ترتيب تصاعدي</button>
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc"><span class="erp-sort-arrow">▼</span> ترتيب تنازلي</button>
            </div>
        </div>
        <div class="erp-filter-section">
            <div id="erpColumnFilterSearchRow">
                <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                <input type="text" id="erpColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
            </div>
            <div class="erp-column-filter-list">
                <div class="text-muted text-center py-3">جاري التحميل...</div>
            </div>
        </div>
        <div class="erp-column-filter-actions">
            <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
            <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح الفلتر</button>
        </div>
    </div>
</div>

@* ===== Modal فلترة التاريخ/الوقت ===== *@
<div class="modal fade no-print"
     id="stDateFilterModal"
     tabindex="-1"
     aria-labelledby="stDateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="stDateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ التحويل)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="searchMode" value="@searchMode" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_fromwarehouse)) { <input type="hidden" name="filterCol_fromwarehouse" value="@filterCol_fromwarehouse" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_fromwarehouseExpr)) { <input type="hidden" name="filterCol_fromwarehouseExpr" value="@filterCol_fromwarehouseExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_towarehouse)) { <input type="hidden" name="filterCol_towarehouse" value="@filterCol_towarehouse" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_towarehouseExpr)) { <input type="hidden" name="filterCol_towarehouseExpr" value="@filterCol_towarehouseExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_note)) { <input type="hidden" name="filterCol_note" value="@filterCol_note" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="stUseDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />
                            <label class="form-check-label" for="stUseDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة (نمط erp-columns-modal — كقائمة فواتير المبيعات) ===== *@
<div class="modal fade no-print erp-columns-modal"
     id="stColumnsModal"
     tabindex="-1"
     aria-labelledby="stColumnsModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="stColumnsModalLabel">
                    اختيار الأعمدة الظاهرة في قائمة التحويلات بين المخازن
                </h5>
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <label class="form-label small mb-1">بحث في أسماء الأعمدة</label>
                <input type="text" id="stColumnsSearch" class="form-control form-control-sm mb-2" placeholder="فلترة القائمة..." autocomplete="off" />
                <div class="form-check mb-2 erp-columns-select-all-row">
                    <input type="checkbox" class="form-check-input" id="stColumnsSelectAll" />
                    <label class="form-check-label" for="stColumnsSelectAll">تحديد الكل</label>
                </div>
                <div id="stColumnsList" class="erp-columns-modal-list"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-erp btn-erp-secondary" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" id="btnStApplyColumns" class="btn btn-erp btn-erp-primary">تطبيق</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        (function () {
            var wrapper = document.getElementById("stTableScrollWrapper");
            if (wrapper) {
                function scrollToRtlStart() {
                    var maxScroll = wrapper.scrollWidth - wrapper.clientWidth;
                    wrapper.scrollLeft = maxScroll > 0 ? maxScroll : 0;
                }
                scrollToRtlStart();
                window.addEventListener("load", function () { setTimeout(scrollToRtlStart, 50); });
            }
        })();

        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanelSt',
            tableId: 'stTable',
            wrapperId: 'stTableScrollWrapper',
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "StockTransfers")',
            defaultSort: 'id',
            defaultDir: 'asc',
            numericColumns: ['id', 'fromwarehouse', 'towarehouse']
        });

        ERP.initListSelection({
            showButtonId: 'btnShowSt',
            showTabId: 'stock-transfer-show',
            idAttribute: 'data-row-id',
            showUrlAttribute: 'data-show-url',
            tabTitleAttribute: 'data-tab-title',
            multiSelectCheckboxes: true
        });

        document.getElementById("btnStPrint")?.addEventListener("click", function () { window.print(); });

        (function () {
            const table = document.getElementById("stTable");
            if (!table) return;
            const chkAll = document.getElementById("stChkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");
            const bulkForm = document.getElementById("stBulkDeleteForm");
            const selectedEl = document.getElementById("stSelectedIdsInput");
            chkAll?.addEventListener("change", function () { rowsChk().forEach(cb => { cb.checked = chkAll.checked; }); });
            table.addEventListener("change", function (e) {
                const t = e.target;
                if (t && t.classList.contains("row-select") && !t.checked && chkAll) chkAll.checked = false;
            });
            document.getElementById("btnStDeleteSelected")?.addEventListener("click", function () {
                const ids = Array.from(rowsChk()).filter(cb => cb.checked).map(cb => cb.value);
                if (ids.length === 0) { alert("من فضلك اختر على الأقل تحويل واحد للحذف."); return; }
                if (!confirm("هل أنت متأكد من حذف التحويلات المحددة؟")) return;
                selectedEl.value = ids.join(",");
                bulkForm.submit();
            });
            document.getElementById("btnStDeleteAll")?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع التحويلات. هل أنت متأكد؟")) return;
                document.getElementById("stDeleteAllForm").submit();
            });
        })();

        (function () {
            const table = document.getElementById("stTable");
            if (!table) return;
            const storageKey = "stocktransfer-columns-visibility";
            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells.filter(th => !th.hasAttribute("data-col-fixed")).map(th => {
                const t = th.querySelector(".erp-col-title");
                return {
                    key: th.getAttribute("data-col"),
                    title: (t ? t.innerText : th.innerText).replace(/\s+/g, " ").trim()
                };
            });
            if (columns.length === 0) return;
            let hidden = [];
            try { const saved = localStorage.getItem(storageKey); if (saved) hidden = JSON.parse(saved); } catch { hidden = []; }
            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']").forEach(cell => cell.classList.toggle("d-none", isHidden));
                });
            }
            applyVisibility();
            const listContainer = document.getElementById("stColumnsList");
            const searchInp = document.getElementById("stColumnsSearch");
            const selAll = document.getElementById("stColumnsSelectAll");
            function renderColumnList(filterText) {
                if (!listContainer) return;
                const ft = (filterText || "").trim().toLowerCase();
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    if (ft && col.title.toLowerCase().indexOf(ft) < 0) return;
                    const id = "st_col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1 st-col-item";
                    const cb = document.createElement("input");
                    cb.type = "checkbox"; cb.className = "form-check-input ms-2"; cb.id = id;
                    cb.checked = !hidden.includes(col.key); cb.dataset.colKey = col.key;
                    const label = document.createElement("label"); label.className = "form-check-label"; label.setAttribute("for", id); label.innerText = col.title;
                    wrapper.appendChild(cb); wrapper.appendChild(label); listContainer.appendChild(wrapper);
                });
                syncSelectAll();
            }
            function syncSelectAll() {
                if (!selAll || !listContainer) return;
                const boxes = listContainer.querySelectorAll("input[type=checkbox][data-col-key]");
                const n = boxes.length, c = Array.from(boxes).filter(b => b.checked).length;
                selAll.checked = n > 0 && c === n;
                selAll.indeterminate = c > 0 && c < n;
            }
            renderColumnList("");
            searchInp?.addEventListener("input", function () { renderColumnList(this.value); });
            selAll?.addEventListener("change", function () {
                listContainer?.querySelectorAll("input[data-col-key]").forEach(cb => { cb.checked = this.checked; });
            });
            listContainer?.addEventListener("change", function (e) {
                if (e.target && e.target.matches("input[data-col-key]")) syncSelectAll();
            });
            document.getElementById("btnStApplyColumns")?.addEventListener("click", function () {
                hidden = [];
                listContainer?.querySelectorAll("input[type='checkbox'][data-col-key]").forEach(cb => {
                    if (!cb.checked) hidden.push(cb.dataset.colKey);
                });
                try { localStorage.setItem(storageKey, JSON.stringify(hidden)); } catch { }
                applyVisibility();
                const modalEl = document.getElementById("stColumnsModal");
                bootstrap.Modal.getInstance(modalEl)?.hide();
            });
        })();

        (function () {
            const btnApply = document.getElementById("btnStApplyCodeFilter");
            const btnClear = document.getElementById("btnStClearCodeFilter");
            const fromInp = document.getElementById("stCodeFromInput");
            const toInp = document.getElementById("stCodeToInput");
            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom); else url.searchParams.delete("fromCode");
                if (codeTo) url.searchParams.set("toCode", codeTo); else url.searchParams.delete("toCode");
                url.searchParams.set("page", "1");
                return url.toString();
            }
            btnApply?.addEventListener("click", function () { window.location.href = buildUrl(fromInp.value.trim(), toInp.value.trim()); });
            btnClear?.addEventListener("click", function () { fromInp.value = ""; toInp.value = ""; window.location.href = buildUrl("", ""); });
        })();
    </script>
}
