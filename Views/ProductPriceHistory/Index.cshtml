@using Microsoft.AspNetCore.Html
                                    <!-- لاستخدام HtmlString في sortLink -->
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<ProductPriceHistory>

@{
    ViewData["Title"] = "سجل تغييرات سعر الجمهور";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "ProductPriceHistory";

    // القيم القادمة من الموديل / ViewBag
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "prod";     // افتراضيًا نبحث بالصنف
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "date";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلترة بالتاريخ/الوقت (تاريخ تغيير السعر) من PagedResult
    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;

    // دالة توليد لينك مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate
    })!;

    // دالة إنشاء لينك الترتيب مع السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString(
            $@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>"
        );
    };
}

<div dir="rtl" class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">@ViewData["Title"]</h4>

        <small class="text-muted d-none d-md-inline">
            إجمالي الحركات: @total
        </small>
    </div>

    @* ===== الكارت العلوي: بحث + أزرار التحكم ===== *@
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* العمود الأول: البحث *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث</label>
                        </div>

                        <div class="col-sm-7">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-5">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                <option value="all"
                                       @Html.Raw(searchBy == "all" ? " selected" : "")>
                                    الكل
                                </option>

                                <option value="prod"
                                       @Html.Raw(searchBy == "prod" ? " selected" : "")>
                                    الصنف
                                </option>

                                <option value="user"
                                       @Html.Raw(searchBy == "user" ? " selected" : "")>
                                    المستخدم
                                </option>

                                <option value="reason"
                                       @Html.Raw(searchBy == "reason" ? " selected" : "")>
                                    السبب
                                </option>

                                <option value="date"
                                       @Html.Raw(searchBy == "date" ? " selected" : "")>
                                    تاريخ التغيير
                                </option>
                            </select>
                        </div>

                        @* الحفاظ على باقي الفلاتر *@
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                        @if (fromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                        }
                        @if (toDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm px-3">
                                بحث
                            </button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm"
                               href="@Url.Action(action, controller)">
                                إلغاء
                            </a>
                        </div>
                    </form>
                </div>


                @* العمود الثاني: من كود / إلى كود + الأزرار *@
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-semibold">من كود</span>
                        <input id="codeFromInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(ViewBag.CodeFrom?.ToString() ?? "")" />

                        <span class="fw-semibold">إلى كود</span>
                        <input id="codeToInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(ViewBag.CodeTo?.ToString() ?? "")" />

                        <button type="button"
                                id="btnApplyCodeFilter"
                                class="btn btn-erp btn-erp-primary btn-erp-sm">
                            تطبيق فلتر الكود
                        </button>

                        <button type="button"
                                id="btnClearCodeFilter"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            مسح
                        </button>
                    </div>
                </div>


                @* العمود الثالث: التولبار (فلترة تاريخ / أعمدة / حذف / طباعة / تصدير) *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        @* فلترة بالتاريخ/الوقت *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#dateFilterModal">
                            فلترة بالتاريخ/الوقت
                        </button>

                        @* اختيار الأعمدة *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModal">
                            اختيار الأعمدة
                        </button>

                        @* حذف المحدد *@
                        <form id="bulkDeleteForm"
                              asp-action="BulkDelete"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="selectedIds" id="selectedIdsInput" />
                            <button type="button"
                                    id="btnDeleteSelected"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف المحدد
                            </button>
                        </form>

                        @* حذف كل السجلات *@
                        <form id="deleteAllForm"
                              asp-action="DeleteAll"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="button"
                                    id="btnDeleteAll"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف جميع السجلات
                            </button>
                        </form>

                        @* طباعة الجدول *@
                        <button type="button"
                                id="btnPrint"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        @* تصدير *@
                        <form method="get"
                              asp-action="Export"
                              asp-controller="ProductPriceHistory"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                            }
                            @if (toDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                            }

                            <select name="format"
                                    class="form-select form-select-sm"
                                    style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm">
                                تصدير
                            </button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

    @* ===== جدول سجل تغييرات الأسعار ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="pphTable"
               class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    @* عمود الاختيار المتعدد *@
                    <th class="text-center no-print"
                        style="width:40px;"
                        data-col="select"
                        data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    <th style="width:140px;" data-col="PriceChangeId">
                        @sortLink("PriceChangeId", "كود التغيير")
                    </th>

                    <th style="width:140px;" data-col="date">
                        @sortLink("date", "تاريخ التغيير")
                    </th>
                    <th data-col="prod">
                        @sortLink("prod", "الصنف")
                    </th>
                    <th class="text-end" data-col="oldprice">
                        @sortLink("oldprice", "السعر القديم")
                    </th>
                    <th class="text-end" data-col="newprice">
                        @sortLink("newprice", "السعر الجديد")
                    </th>
                    <th data-col="user">
                        @sortLink("user", "المستخدم")
                    </th>
                    <th data-col="reason">
                        @sortLink("reason", "السبب")
                    </th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model.Items)
                    {
                        var prodName = r.Product?.ProdName;
                        var prodText = !string.IsNullOrWhiteSpace(prodName)
                        ? prodName
                        : $"كود الصنف: {r.ProdId}";

                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@r.PriceChangeId" />
                            </td>

                            <td data-col="date">
                                @r.ChangeDate.ToString("yyyy/MM/dd HH:mm")
                            </td>

                            <td data-col="prod">
                                <div class="fw-semibold">@prodText</div>
                            </td>

                            <td data-col="oldprice" class="text-end">
                                @r.OldPrice.ToString("N2")
                            </td>

                            <td data-col="newprice" class="text-end">
                                @r.NewPrice.ToString("N2")
                            </td>

                            <td data-col="user">
                                @(string.IsNullOrWhiteSpace(r.ChangedBy) ? "-" : r.ChangedBy)
                            </td>

                            <td data-col="reason">
                                @(string.IsNullOrWhiteSpace(r.Reason) ? "-" : r.Reason)
                            </td>
                        </tr>
                    }

                    @* صف الإجمالي في نهاية الجدول *@
                    <tr class="table-secondary fw-bold">
                        <td colspan="6" class="text-end">
                            عدد الحركات (حسب الفلتر الحالي):
                        </td>
                        <td class="text-end">
                            @total
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              asp-action="@action"
              asp-controller="@controller"
              class="d-flex align-items-center gap-2">

            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
            }
            @if (toDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    @* ===== الترقيم ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>

            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>

            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة بالتاريخ/الوقت (تاريخ تغيير السعر) ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ تغيير السعر)
                </h5>

                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />

                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="columnsModal"
     tabindex="-1"
     aria-labelledby="columnsModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalLabel">
                    اختيار الأعمدة المعروضة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <div class="modal-body">
                <p class="text-muted small">
                    اختر الأعمدة التي تريد عرضها في جدول سجل تغييرات السعر.
                </p>

                <div class="row">
                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="col_date"
                                   data-col-toggle="date"
                                   checked />
                            <label class="form-check-label" for="col_date">
                                تاريخ التغيير
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="col_prod"
                                   data-col-toggle="prod"
                                   checked />
                            <label class="form-check-label" for="col_prod">
                                الصنف
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="col_oldprice"
                                   data-col-toggle="oldprice"
                                   checked />
                            <label class="form-check-label" for="col_oldprice">
                                السعر القديم
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="col_newprice"
                                   data-col-toggle="newprice"
                                   checked />
                            <label class="form-check-label" for="col_newprice">
                                السعر الجديد
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="col_user"
                                   data-col-toggle="user"
                                   checked />
                            <label class="form-check-label" for="col_user">
                                المستخدم
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="col_reason"
                                   data-col-toggle="reason"
                                   checked />
                            <label class="form-check-label" for="col_reason">
                                السبب
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    تم
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // زر الطباعة — يطبع الجدول فقط
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table = document.getElementById("pphTable");
            if (!table) return;

            const chkAll = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected");
            const bulkForm          = document.getElementById("bulkDeleteForm");
            const selectedInput     = document.getElementById("selectedIdsInput");

            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر حركة واحدة على الأقل للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف الحركات المحددة من سجل تغييرات السعر؟")) return;

                selectedInput.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("deleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير هام: سيتم حذف جميع سجلات سجل تغييرات الأسعار. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("pphTable");
            if (!table) return;

            const storageKey = "pph-columns-visibility";

            function setColumnVisible(colKey, visible) {
                table.querySelectorAll("[data-col='" + colKey + "']")
                    .forEach(cell => {
                        cell.classList.toggle("d-none", !visible);
                    });
            }

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            const colCheckboxes = document.querySelectorAll("[data-col-toggle]");

            colCheckboxes.forEach(chk => {
                const key      = chk.getAttribute("data-col-toggle");
                const isHidden = hidden.includes(key);

                chk.checked = !isHidden;
                setColumnVisible(key, !isHidden);

                chk.addEventListener("change", function () {
                    const checks = document.querySelectorAll("[data-col-toggle]");
                    hidden = [];
                    checks.forEach(cb => {
                        const k = cb.getAttribute("data-col-toggle");
                        if (!cb.checked) hidden.push(k);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    setColumnVisible(key, chk.checked);
                });
            });
        })();
    </script>
}
