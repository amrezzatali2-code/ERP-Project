@using Microsoft.AspNetCore.Html
                                    <!-- لاستخدام HtmlString في sortLink -->
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<ProductPriceHistory>

@{
    ViewData["Title"] = "سجل تغييرات سعر الجمهور";
    ViewData["ErpListPage"] = true;

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "ProductPriceHistory";

    // القيم القادمة من الموديل / ViewBag
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "prod";     // افتراضيًا نبحث بالصنف
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "date";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;

    // فلاتر أعمدة (بنمط Excel)
    string? filterCol_code = ViewBag.FilterCol_Code as string;
    string? filterCol_date = ViewBag.FilterCol_Date as string;
    string? filterCol_prod = ViewBag.FilterCol_Prod as string;
    string? filterCol_oldprice = ViewBag.FilterCol_OldPrice as string;
    string? filterCol_newprice = ViewBag.FilterCol_NewPrice as string;
    string? filterCol_user = ViewBag.FilterCol_User as string;
    string? filterCol_reason = ViewBag.FilterCol_Reason as string;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        filterCol_code,
        filterCol_date,
        filterCol_prod,
        filterCol_oldprice,
        filterCol_newprice,
        filterCol_user,
        filterCol_reason
    })!;

    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";
        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate,
            filterCol_code,
            filterCol_date,
            filterCol_prod,
            filterCol_oldprice,
            filterCol_newprice,
            filterCol_user,
            filterCol_reason
        }) ?? "#";
        string icon = "⇅";
        if (isCurrent) icon = dir == "asc" ? "▲" : "▼";
        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    // عمود قابل للفلترة (بنمط Excel)
    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        var currentFilter = colKey == "code" ? filterCol_code : colKey == "date" ? filterCol_date : colKey == "prod" ? filterCol_prod :
            colKey == "oldprice" ? filterCol_oldprice : colKey == "newprice" ? filterCol_newprice : colKey == "user" ? filterCol_user : colKey == "reason" ? filterCol_reason : null;
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid erp-list-page">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <small class="text-muted d-none d-md-inline">إجمالي الحركات: @total</small>
    </div>

    @* ===== شريط الفلاتر الموحد (مثل قائمة الأصناف) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في السجل</label>
                    <div class="d-flex flex-wrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:150px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>الكل</option>
                            <option value="prod"@Html.Raw(searchBy == "prod" ? " selected" : "")>الصنف</option>
                            <option value="user"@Html.Raw(searchBy == "user" ? " selected" : "")>المستخدم</option>
                            <option value="reason"@Html.Raw(searchBy == "reason" ? " selected" : "")>السبب</option>
                            <option value="date"@Html.Raw(searchBy == "date" ? " selected" : "")>تاريخ التغيير</option>
                        </select>
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">بحث</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_code)) { <input type="hidden" name="filterCol_code" value="@filterCol_code" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prod)) { <input type="hidden" name="filterCol_prod" value="@filterCol_prod" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_oldprice)) { <input type="hidden" name="filterCol_oldprice" value="@filterCol_oldprice" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_newprice)) { <input type="hidden" name="filterCol_newprice" value="@filterCol_newprice" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_reason)) { <input type="hidden" name="filterCol_reason" value="@filterCol_reason" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر الكود --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر الكود</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(ViewBag.CodeFrom?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(ViewBag.CodeTo?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModal">اختيار الأعمدة</button>
                        <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteSelected">حذف المحدد</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف جميع السجلات</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="ProductPriceHistory" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_code)) { <input type="hidden" name="filterCol_code" value="@filterCol_code" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_prod)) { <input type="hidden" name="filterCol_prod" value="@filterCol_prod" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_oldprice)) { <input type="hidden" name="filterCol_oldprice" value="@filterCol_oldprice" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_newprice)) { <input type="hidden" name="filterCol_newprice" value="@filterCol_newprice" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_reason)) { <input type="hidden" name="filterCol_reason" value="@filterCol_reason" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:70px;min-width:70px;font-size:0.8rem;padding:0.25rem 0.4rem;">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                    <form id="bulkDeleteForm" asp-action="BulkDelete" asp-controller="ProductPriceHistory" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="selectedIds" id="selectedIdsInput" />
                    </form>
                    <form id="deleteAllForm" asp-action="DeleteAll" asp-controller="ProductPriceHistory" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>

        </div>
    </div>

    @* فورم خفي لتطبيق فلتر الأعمدة (يُملأ من السكربت) *@
    <form id="pphSearchForm" method="get" action="@Url.Action(action, controller)" class="d-none">
        <input type="hidden" name="search" value="@search" />
        <input type="hidden" name="searchBy" value="@searchBy" />
        <input type="hidden" name="sort" value="@sort" />
        <input type="hidden" name="dir" value="@dir" />
        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="pageSize" value="@ps" />
        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
        @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
        @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_code)) { <input type="hidden" name="filterCol_code" value="@filterCol_code" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_prod)) { <input type="hidden" name="filterCol_prod" value="@filterCol_prod" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_oldprice)) { <input type="hidden" name="filterCol_oldprice" value="@filterCol_oldprice" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_newprice)) { <input type="hidden" name="filterCol_newprice" value="@filterCol_newprice" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_reason)) { <input type="hidden" name="filterCol_reason" value="@filterCol_reason" /> }
    </form>

    @* ===== جدول سجل تغييرات الأسعار ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0">
        <div class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="pphTable"
               class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    @* عمود الاختيار المتعدد *@
                    <th class="text-center no-print"
                        style="width:40px;"
                        data-col="select"
                        data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    <th style="width:100px;" data-col="code">@filterableCol("code", "id", "كود التغيير")</th>
                    <th style="width:140px;" data-col="date">@filterableCol("date", "date", "تاريخ التغيير")</th>
                    <th data-col="prod">@filterableCol("prod", "prod", "الصنف")</th>
                    <th class="text-end" data-col="oldprice">@filterableCol("oldprice", "old", "السعر القديم")</th>
                    <th class="text-end" data-col="newprice">@filterableCol("newprice", "new", "السعر الجديد")</th>
                    <th data-col="user">@filterableCol("user", "user", "المستخدم")</th>
                    <th data-col="reason">@filterableCol("reason", "reason", "السبب")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model.Items)
                    {
                        var prodName = r.Product?.ProdName;
                        var prodText = !string.IsNullOrWhiteSpace(prodName)
                        ? prodName
                        : $"كود الصنف: {r.ProdId}";

                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@r.PriceChangeId" />
                            </td>
                            <td data-col="code">@r.PriceChangeId</td>
                            <td data-col="date">@r.ChangeDate.ToString("yyyy/MM/dd HH:mm")</td>
                            <td data-col="prod"><div class="fw-semibold">@prodText</div></td>
                            <td data-col="oldprice" class="text-end">@r.OldPrice.ToString("N2")</td>
                            <td data-col="newprice" class="text-end">@r.NewPrice.ToString("N2")</td>
                            <td data-col="user">@(string.IsNullOrWhiteSpace(r.ChangedBy) ? "-" : r.ChangedBy)</td>
                            <td data-col="reason">@(string.IsNullOrWhiteSpace(r.Reason) ? "-" : r.Reason)</td>
                        </tr>
                    }

                    <tr class="table-secondary fw-bold">
                        <td colspan="7" class="text-end">عدد الحركات (حسب الفلتر الحالي):</td>
                        <td class="text-end">@total</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>

    @* لوحة فلتر العمود (بنمط Excel) *@
    <div id="erpColumnFilterPanel" class="erp-column-filter-panel d-none" dir="rtl">
        <div class="erp-column-filter-header">
            <span id="erpColumnFilterTitle">ترتيب وفلتر</span>
            <button type="button" class="btn-close btn-sm" id="erpColumnFilterClose" aria-label="إغلاق"></button>
        </div>
        <div class="erp-column-filter-body">
            <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                <label class="form-label small mb-1 fw-bold">الترتيب:</label>
                <div class="d-flex flex-column gap-1">
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
                </div>
            </div>
            <div class="erp-filter-section">
                <div id="erpColumnFilterSearchRow">
                    <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                    <input type="text" id="erpColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                </div>
                <div id="erpColumnFilterList" class="erp-column-filter-list">
                    <div class="text-muted text-center py-3">جاري التحميل...</div>
                </div>
            </div>
            <div class="erp-column-filter-actions">
                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOk">تطبيق</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClear">مسح الفلتر</button>
            </div>
        </div>
    </div>
    <form id="erpColumnFilterApplyForm" method="get" action="@Url.Action("Index", "ProductPriceHistory")" class="d-none" style="display:none !important;"></form>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get" asp-action="@action" asp-controller="@controller" class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="pageSize" value="@ps" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_code)) { <input type="hidden" name="filterCol_code" value="@filterCol_code" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_prod)) { <input type="hidden" name="filterCol_prod" value="@filterCol_prod" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_oldprice)) { <input type="hidden" name="filterCol_oldprice" value="@filterCol_oldprice" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_newprice)) { <input type="hidden" name="filterCol_newprice" value="@filterCol_newprice" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_reason)) { <input type="hidden" name="filterCol_reason" value="@filterCol_reason" /> }
            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    @* ===== الترقيم ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>

            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>

            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة بالتاريخ/الوقت (تاريخ تغيير السعر) ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ تغيير السعر)
                </h5>

                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    @if (!string.IsNullOrWhiteSpace(filterCol_code)) { <input type="hidden" name="filterCol_code" value="@filterCol_code" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_prod)) { <input type="hidden" name="filterCol_prod" value="@filterCol_prod" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_oldprice)) { <input type="hidden" name="filterCol_oldprice" value="@filterCol_oldprice" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_newprice)) { <input type="hidden" name="filterCol_newprice" value="@filterCol_newprice" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_user)) { <input type="hidden" name="filterCol_user" value="@filterCol_user" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_reason)) { <input type="hidden" name="filterCol_reason" value="@filterCol_reason" /> }
                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />

                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print erp-columns-modal"
     id="columnsModal"
     tabindex="-1"
     aria-labelledby="columnsModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalLabel">
                    اختيار الأعمدة المعروضة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <div class="modal-body">
                <p class="text-muted small">
                    اختر الأعمدة التي تريد عرضها في جدول سجل تغييرات السعر.
                </p>

                <div class="row">
                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="col_code" data-col-toggle="code" checked />
                            <label class="form-check-label" for="col_code">كود التغيير</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="col_date" data-col-toggle="date" checked />
                            <label class="form-check-label" for="col_date">تاريخ التغيير</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="col_prod" data-col-toggle="prod" checked />
                            <label class="form-check-label" for="col_prod">
                                الصنف
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="col_oldprice"
                                   data-col-toggle="oldprice"
                                   checked />
                            <label class="form-check-label" for="col_oldprice">
                                السعر القديم
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="col_newprice"
                                   data-col-toggle="newprice"
                                   checked />
                            <label class="form-check-label" for="col_newprice">
                                السعر الجديد
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="col_user"
                                   data-col-toggle="user"
                                   checked />
                            <label class="form-check-label" for="col_user">
                                المستخدم
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="col_reason"
                                   data-col-toggle="reason"
                                   checked />
                            <label class="form-check-label" for="col_reason">
                                السبب
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    تم
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // زر الطباعة — يطبع الجدول فقط
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table = document.getElementById("pphTable");
            if (!table) return;

            const chkAll = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected");
            const bulkForm          = document.getElementById("bulkDeleteForm");
            const selectedInput     = document.getElementById("selectedIdsInput");

            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر حركة واحدة على الأقل للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف الحركات المحددة من سجل تغييرات السعر؟")) return;

                selectedInput.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("deleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير هام: سيتم حذف جميع سجلات سجل تغييرات الأسعار. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("pphTable");
            if (!table) return;

            const storageKey = "pph-columns-visibility";

            function setColumnVisible(colKey, visible) {
                table.querySelectorAll("[data-col='" + colKey + "']")
                    .forEach(cell => {
                        cell.classList.toggle("d-none", !visible);
                    });
            }

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            const colCheckboxes = document.querySelectorAll("[data-col-toggle]");

            colCheckboxes.forEach(chk => {
                const key      = chk.getAttribute("data-col-toggle");
                const isHidden = hidden.includes(key);

                chk.checked = !isHidden;
                setColumnVisible(key, !isHidden);

                chk.addEventListener("change", function () {
                    const checks = document.querySelectorAll("[data-col-toggle]");
                    hidden = [];
                    checks.forEach(cb => {
                        const k = cb.getAttribute("data-col-toggle");
                        if (!cb.checked) hidden.push(k);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    setColumnVisible(key, chk.checked);
                });
            });
        })();

        // =========================
        // فلتر الأعمدة بنمط Excel (ترتيب + فلترة)
        // =========================
        (function () {
            var panel = document.getElementById("erpColumnFilterPanel");
            if (!panel) return;
            var titleEl = document.getElementById("erpColumnFilterTitle");
            var searchInp = document.getElementById("erpColumnFilterSearch");
            var listEl = document.getElementById("erpColumnFilterList");
            var btnOk = document.getElementById("erpColumnFilterOk");
            var btnClear = document.getElementById("erpColumnFilterClear");
            var btnClose = document.getElementById("erpColumnFilterClose");
            var applyForm = document.getElementById("erpColumnFilterApplyForm") || document.getElementById("pphSearchForm");

            var currentCol = null, currentSortKey = null, allItems = [], currentSelected = new Set(), anchorRect = null;

            function getCurrentFilterValue(col) {
                return new URL(window.location.href).searchParams.get("filterCol_" + col) || "";
            }
            function getCurrentSort() {
                var url = new URL(window.location.href);
                return { sort: url.searchParams.get("sort") || "date", dir: url.searchParams.get("dir") || "desc" };
            }
            function adjustPanelPosition() {
                if (!panel || !anchorRect) return;
                setTimeout(function () {
                    var r = panel.getBoundingClientRect();
                    var top = anchorRect.bottom + 4, left = anchorRect.left;
                    if (top + r.height > window.innerHeight - 8) top = Math.max(8, window.innerHeight - 8 - r.height);
                    if (left + r.width > window.innerWidth - 8) left = Math.max(8, window.innerWidth - 8 - r.width);
                    panel.style.top = top + "px";
                    panel.style.left = left + "px";
                }, 50);
            }

            function showPanel(btn) {
                currentCol = btn.dataset.col;
                currentSortKey = btn.dataset.sortKey || currentCol;
                titleEl.textContent = "ترتيب وفلتر: " + (btn.dataset.colTitle || currentCol);
                searchInp.value = "";
                currentSelected = new Set((getCurrentFilterValue(currentCol) || "").split("|").filter(Boolean));
                anchorRect = btn.getBoundingClientRect();
                panel.style.minWidth = Math.max(250, anchorRect.width) + "px";
                panel.classList.remove("d-none");

                var currentSort = getCurrentSort();
                var isCurrent = currentSort.sort.toLowerCase() === (currentSortKey || "").toLowerCase();
                var currentDir = isCurrent ? currentSort.dir : "asc";
                panel.querySelectorAll(".erp-sort-btn").forEach(function (b) {
                    if (isCurrent && b.dataset.sortDir === currentDir) {
                        b.classList.add("active", "btn-primary");
                        b.classList.remove("btn-outline-secondary");
                    } else {
                        b.classList.remove("active", "btn-primary");
                        b.classList.add("btn-outline-secondary");
                    }
                });
                adjustPanelPosition();
                document.getElementById("erpColumnFilterSearchRow").classList.remove("d-none");
                listEl.innerHTML = '<div class="text-muted text-center py-3">جاري التحميل...</div>';
                var url = "/ProductPriceHistory/GetColumnValues?column=" + encodeURIComponent(currentCol);
                var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                if (searchVal) url += "&search=" + encodeURIComponent(searchVal);
                fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                    allItems = items;
                    renderList(searchInp ? searchInp.value : "");
                }).catch(function () { listEl.innerHTML = '<div class="text-danger text-center py-2">فشل التحميل</div>'; });
            }

            function renderList(search) {
                var term = (search || "").toLowerCase();
                var filtered = term ? allItems.filter(function (x) { return (x.display || x.value || "").toLowerCase().indexOf(term) >= 0; }) : allItems;
                var allChecked = filtered.length > 0 && filtered.every(function (x) { return currentSelected.has(String(x.value)); });
                var someChecked = filtered.some(function (x) { return currentSelected.has(String(x.value)); });
                listEl.innerHTML = '<div class="form-check mb-1"><input type="checkbox" class="form-check-input" id="erpFilterSelectAll" ' + (allChecked ? "checked" : "") + '><label class="form-check-label small" for="erpFilterSelectAll">(تحديد الكل)</label></div><div class="erp-filter-items" style="max-height:200px;overflow-y:auto;">' + filtered.map(function (x) {
                    var v = String(x.value);
                    var checked = currentSelected.has(v);
                    return '<div class="form-check"><input type="checkbox" class="form-check-input erp-filter-item" value="' + v.replace(/"/g, "&quot;") + '" ' + (checked ? "checked" : "") + '><label class="form-check-label small">' + (x.display || v).replace(/</g, "&lt;") + '</label></div>';
                }).join("") + "</div>";
                var selectAllCb = listEl.querySelector("#erpFilterSelectAll");
                if (selectAllCb) {
                    selectAllCb.indeterminate = someChecked && !allChecked;
                    selectAllCb.onchange = function () {
                        filtered.forEach(function (x) { if (this.checked) currentSelected.add(String(x.value)); else currentSelected.delete(String(x.value)); }.bind(this));
                        renderList(searchInp.value);
                    };
                }
                listEl.querySelectorAll(".erp-filter-item").forEach(function (cb) {
                    cb.onchange = function () { if (this.checked) currentSelected.add(this.value); else currentSelected.delete(this.value); renderList(searchInp.value); };
                });
                adjustPanelPosition();
            }

            function applyFilter(applySort, sortDir) {
                if (!currentCol) return;
                var url = new URL(window.location.href);
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.delete("filterCol_" + currentCol + "Expr");
                if (applySort !== undefined && sortDir !== undefined) {
                    url.searchParams.set("sort", applySort);
                    url.searchParams.set("dir", sortDir);
                } else if (currentSortKey) {
                    var cur = getCurrentSort();
                    url.searchParams.set("sort", cur.sort);
                    url.searchParams.set("dir", cur.dir);
                }
                var val = Array.from(currentSelected).filter(Boolean).join("|");
                if (val) url.searchParams.set("filterCol_" + currentCol, val);
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }
            function clearFilter() {
                if (!currentCol) return;
                var url = new URL(window.location.href);
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }

            document.querySelectorAll(".erp-col-filter-btn").forEach(function (btn) {
                btn.addEventListener("click", function (e) { e.stopPropagation(); showPanel(this); });
            });
            document.addEventListener("click", function (e) {
                if (e.target.closest(".erp-sort-btn")) {
                    var sortBtn = e.target.closest(".erp-sort-btn");
                    if (currentSortKey) applyFilter(currentSortKey, sortBtn.dataset.sortDir);
                }
            });
            var fetchDebounce = null;
            searchInp && searchInp.addEventListener("input", function () {
                renderList(this.value);
                if (fetchDebounce) clearTimeout(fetchDebounce);
                fetchDebounce = setTimeout(function () {
                    fetchDebounce = null;
                    if (!currentCol) return;
                    var url = "/ProductPriceHistory/GetColumnValues?column=" + encodeURIComponent(currentCol);
                    var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                    if (searchVal) url += "&search=" + encodeURIComponent(searchVal);
                    fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                        allItems = items;
                        renderList(searchInp ? searchInp.value : "");
                    });
                }, 400);
            });
            searchInp && searchInp.addEventListener("keydown", function (e) { if (e.key === "Enter") { e.preventDefault(); applyFilter(); } });
            btnOk && btnOk.addEventListener("click", function (e) { e.preventDefault(); e.stopPropagation(); applyFilter(); });
            btnClear && btnClear.addEventListener("click", clearFilter);
            btnClose && btnClose.addEventListener("click", function () { panel.classList.add("d-none"); });
            document.addEventListener("click", function (e) {
                if (panel && !panel.classList.contains("d-none") && !panel.contains(e.target) && !e.target.closest(".erp-col-filter-btn"))
                    panel.classList.add("d-none");
            });
        })();
    </script>
}
