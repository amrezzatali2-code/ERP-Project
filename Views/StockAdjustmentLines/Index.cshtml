        <div class="erp-column-filter-actions">
            <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
            <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح الفلتر</button>
        </div>
    </div>
</div>

@* ===== Modal فلترة التاريخ/الوقت ===== *@
