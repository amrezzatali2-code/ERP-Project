@using Microsoft.AspNetCore.Html          
@using ERP.Infrastructure                 
@model PagedResult<ERP.Models.StockAdjustmentLine>

@{
    ViewData["Title"] = "أصناف التسويات الجردية";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "StockAdjustmentLines";

    // القيم القادمة من الموديل / ViewBag (نفس نمط قائمة تسويات الجرد)
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (Model.SearchBy ?? (string?)ViewBag.SearchBy ?? "all");
    if (string.IsNullOrWhiteSpace(searchBy)) searchBy = "all";
    searchBy = searchBy.ToLowerInvariant();
    var searchMode = ((string?)ViewBag.SearchMode ?? "contains").ToLowerInvariant();
    if (searchMode != "starts" && searchMode != "ends") searchMode = "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "Id";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = (int?)ViewBag.PageSize ?? Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
    int end = (ps == 0 || total == 0) ? total : Math.Min(total, page * ps);

    int first = 1;
    int last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلتر كود من/إلى (هنا Id للسطر)
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    // حقل التاريخ المستخدم في الفلترة (لو حابب تربطه بتاريخ التسوية من الرأس لاحقاً)
    var dateField = (string?)ViewBag.DateField ?? "CreatedAt";

    // فلاتر الأعمدة (بنمط Excel)
    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_stock = ViewBag.FilterCol_Stock as string;
    string? filterCol_product = ViewBag.FilterCol_Product as string;
    string? filterCol_productName = ViewBag.FilterCol_ProductName as string;
    string? filterCol_batch = ViewBag.FilterCol_Batch as string;
    string? filterCol_qtyBefore = ViewBag.FilterCol_QtyBefore as string;
    string? filterCol_qtyAfter = ViewBag.FilterCol_QtyAfter as string;
    string? filterCol_qtyDiff = ViewBag.FilterCol_QtyDiff as string;
    string? filterCol_costUnit = ViewBag.FilterCol_CostUnit as string;
    string? filterCol_costDiff = ViewBag.FilterCol_CostDiff as string;
    string? filterCol_note = ViewBag.FilterCol_Note as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_stockExpr = ViewBag.FilterCol_StockExpr as string;
    string? filterCol_productExpr = ViewBag.FilterCol_ProductExpr as string;
    string? filterCol_batchExpr = ViewBag.FilterCol_BatchExpr as string;
    string? filterCol_qtyBeforeExpr = ViewBag.FilterCol_QtyBeforeExpr as string;
    string? filterCol_qtyAfterExpr = ViewBag.FilterCol_QtyAfterExpr as string;
    string? filterCol_qtyDiffExpr = ViewBag.FilterCol_QtyDiffExpr as string;
    string? filterCol_costUnitExpr = ViewBag.FilterCol_CostUnitExpr as string;
    string? filterCol_costDiffExpr = ViewBag.FilterCol_CostDiffExpr as string;

    int? stockAdjId = ViewBag.StockAdjustmentId as int?;

    // دالة توليد لينكات الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField,
        fromCode,
        toCode,
        stockAdjustmentId = stockAdjId,
        filterCol_id,
        filterCol_stock,
        filterCol_product,
        filterCol_productName,
        filterCol_batch,
        filterCol_qtyBefore,
        filterCol_qtyAfter,
        filterCol_qtyDiff,
        filterCol_costUnit,
        filterCol_costDiff,
        filterCol_note,
        filterCol_idExpr,
        filterCol_stockExpr,
        filterCol_productExpr,
        filterCol_batchExpr,
        filterCol_qtyBeforeExpr,
        filterCol_qtyAfterExpr,
        filterCol_qtyDiffExpr,
        filterCol_costUnitExpr,
        filterCol_costDiffExpr
    })!;

    // دالة إنشاء لينك الترتيب في رأس الجدول + أيقونة السهم (تستخدم عند الحاجة)
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            searchMode,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange = Model.UseDateRange,
            fromDate = Model.FromDate,
            toDate = Model.ToDate,
            dateField,
            fromCode,
            toCode,
            stockAdjustmentId = stockAdjId,
            filterCol_id,
            filterCol_stock,
            filterCol_product,
            filterCol_productName,
            filterCol_batch,
            filterCol_qtyBefore,
            filterCol_qtyAfter,
            filterCol_qtyDiff,
            filterCol_costUnit,
            filterCol_costDiff,
            filterCol_note,
            filterCol_idExpr,
            filterCol_stockExpr,
            filterCol_productExpr,
            filterCol_batchExpr,
            filterCol_qtyBeforeExpr,
            filterCol_qtyAfterExpr,
            filterCol_qtyDiffExpr,
            filterCol_costUnitExpr,
            filterCol_costDiffExpr
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    string? FilterForCol(string colKey) =>
        colKey == "id" ? (!string.IsNullOrWhiteSpace(filterCol_idExpr) ? filterCol_idExpr : filterCol_id)
        : colKey == "stock" ? (!string.IsNullOrWhiteSpace(filterCol_stockExpr) ? filterCol_stockExpr : filterCol_stock)
        : colKey == "product" ? (!string.IsNullOrWhiteSpace(filterCol_productExpr) ? filterCol_productExpr : filterCol_product)
        : colKey == "productName" ? filterCol_productName
        : colKey == "batch" ? (!string.IsNullOrWhiteSpace(filterCol_batchExpr) ? filterCol_batchExpr : filterCol_batch)
        : colKey == "qtyBefore" ? (!string.IsNullOrWhiteSpace(filterCol_qtyBeforeExpr) ? filterCol_qtyBeforeExpr : filterCol_qtyBefore)
        : colKey == "qtyAfter" ? (!string.IsNullOrWhiteSpace(filterCol_qtyAfterExpr) ? filterCol_qtyAfterExpr : filterCol_qtyAfter)
        : colKey == "qtyDiff" ? (!string.IsNullOrWhiteSpace(filterCol_qtyDiffExpr) ? filterCol_qtyDiffExpr : filterCol_qtyDiff)
        : colKey == "costUnit" ? (!string.IsNullOrWhiteSpace(filterCol_costUnitExpr) ? filterCol_costUnitExpr : filterCol_costUnit)
        : colKey == "costDiff" ? (!string.IsNullOrWhiteSpace(filterCol_costDiffExpr) ? filterCol_costDiffExpr : filterCol_costDiff)
        : colKey == "note" ? filterCol_note
        : null;

    // عمود قابل للفلترة (بنمط Excel)
    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };

    var n2 = System.Globalization.CultureInfo.InvariantCulture;
    int totalQtyBeforeFiltered = (int?)ViewBag.TotalQtyBeforeFiltered ?? 0;
    int totalQtyAfterFiltered = (int?)ViewBag.TotalQtyAfterFiltered ?? 0;
    int totalQtyDiffFiltered = (int?)ViewBag.TotalQtyDiffFiltered ?? 0;
    decimal totalCostDiffFiltered = (decimal?)ViewBag.TotalCostDiffFiltered ?? 0m;
}

<div dir="rtl" class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <small class="text-muted d-none d-md-inline">إجمالي السطور (بعد الفلتر): @total</small>
    </div>

    @* ===== شريط الفلاتر الموحد (نمط القوائم) — بحث مطابق لتسويات الجرد ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* بحث في سطور التسويات (نفس تخطيط قائمة التسويات الجردية) *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في سطور التسويات</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100" style="overflow-x:auto;">
                        <select name="searchMode" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:110px;min-width:100px" title="نوع البحث في الحقول النصية">
                            <option value="starts"@Html.Raw(searchMode == "starts" ? " selected" : "")>يبدأ بـ</option>
                            <option value="contains"@Html.Raw(searchMode == "contains" || string.IsNullOrEmpty(searchMode) ? " selected" : "")>يحتوي</option>
                            <option value="ends"@Html.Raw(searchMode == "ends" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                        <input type="text" name="search" class="form-control erp-filter-input flex-shrink-1" placeholder="نص أو رقم..." value="@search" style="min-width:100px;max-width:200px;width:180px;" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:170px;min-width:120px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>الكل</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>كود السطر</option>
                            <option value="stock"@Html.Raw(searchBy == "stock" ? " selected" : "")>رقم التسوية</option>
                            <option value="product"@Html.Raw(searchBy == "product" ? " selected" : "")>كود الصنف</option>
                            <option value="productname"@Html.Raw(searchBy == "productname" ? " selected" : "")>اسم الصنف</option>
                            <option value="batch"@Html.Raw(searchBy == "batch" ? " selected" : "")>كود التشغيلة</option>
                            <option value="note"@Html.Raw(searchBy == "note" ? " selected" : "")>الملاحظات</option>
                        </select>
                    </div>
                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-2 w-100">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>

                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                    @if (Model.FromDate.HasValue)
                    {
                        <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                    }
                    @if (Model.ToDate.HasValue)
                    {
                        <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                    }
                    @if (fromCode.HasValue)
                    {
                        <input type="hidden" name="fromCode" value="@fromCode" />
                    }
                    @if (toCode.HasValue)
                    {
                        <input type="hidden" name="toCode" value="@toCode" />
                    }
                    @if (stockAdjId.HasValue)
                    {
                        <input type="hidden" name="stockAdjustmentId" value="@stockAdjId.Value" />
                    }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_stock)) { <input type="hidden" name="filterCol_stock" value="@filterCol_stock" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_product)) { <input type="hidden" name="filterCol_product" value="@filterCol_product" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_productName)) { <input type="hidden" name="filterCol_productName" value="@filterCol_productName" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_batch)) { <input type="hidden" name="filterCol_batch" value="@filterCol_batch" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyBefore)) { <input type="hidden" name="filterCol_qtyBefore" value="@filterCol_qtyBefore" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyAfter)) { <input type="hidden" name="filterCol_qtyAfter" value="@filterCol_qtyAfter" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyDiff)) { <input type="hidden" name="filterCol_qtyDiff" value="@filterCol_qtyDiff" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_costUnit)) { <input type="hidden" name="filterCol_costUnit" value="@filterCol_costUnit" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_costDiff)) { <input type="hidden" name="filterCol_costDiff" value="@filterCol_costDiff" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_note)) { <input type="hidden" name="filterCol_note" value="@filterCol_note" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_stockExpr)) { <input type="hidden" name="filterCol_stockExpr" value="@filterCol_stockExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_productExpr)) { <input type="hidden" name="filterCol_productExpr" value="@filterCol_productExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_batchExpr)) { <input type="hidden" name="filterCol_batchExpr" value="@filterCol_batchExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyBeforeExpr)) { <input type="hidden" name="filterCol_qtyBeforeExpr" value="@filterCol_qtyBeforeExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyAfterExpr)) { <input type="hidden" name="filterCol_qtyAfterExpr" value="@filterCol_qtyAfterExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_qtyDiffExpr)) { <input type="hidden" name="filterCol_qtyDiffExpr" value="@filterCol_qtyDiffExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_costUnitExpr)) { <input type="hidden" name="filterCol_costUnitExpr" value="@filterCol_costUnitExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_costDiffExpr)) { <input type="hidden" name="filterCol_costDiffExpr" value="@filterCol_costDiffExpr" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر كود من/إلى --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر كود السطر</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="salCodeFromInput"
                           type="number"
                           class="form-control erp-filter-input"
                           placeholder="من"
                           value="@(ViewBag.CodeFrom?.ToString() ?? "")" />

                    <input id="salCodeToInput"
                           type="number"
                           class="form-control erp-filter-input"
                           placeholder="إلى"
                           value="@(ViewBag.CodeTo?.ToString() ?? "")" />

                    <button type="button"
                            id="btnSalApplyCodeFilter"
                            class="btn btn-erp btn-erp-primary btn-erp-sm">
                        تطبيق
                    </button>

                    <button type="button"
                            id="btnSalClearCodeFilter"
                            class="btn btn-erp btn-erp-secondary btn-erp-sm">
                        مسح
                    </button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم (تاريخ/أعمدة/طباعة + صف ثانٍ: حركة صنف/تصدير) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#salDateFilterModal">
                            فلترة بالتاريخ/الوقت
                        </button>
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#salColumnsModal">
                            اختيار الأعمدة
                        </button>
                        <button type="button"
                                id="btnSalPrint"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>
                        <span class="erp-list-toolbar-selected-actions erp-list-toolbar-selected-actions--plain d-inline-flex flex-wrap gap-2 align-items-center" role="group" aria-label="إجراءات السطر المحدد">
                            <button type="button" id="btnShowSalLine" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="عرض التسوية">عرض</button>
                        </span>
                    </div>
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center" dir="rtl">
                        <div class="d-inline-flex flex-wrap gap-2 align-items-center" dir="rtl">
                            <button type="button" id="btnMovementSalLine" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="حركة الصنف">حركة الصنف</button>
                            <form method="get"
                                  asp-action="Export"
                                  asp-controller="StockAdjustmentLines"
                                  class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form" dir="rtl">
                                <input type="hidden" name="search" value="@search" />
                                <input type="hidden" name="searchBy" value="@searchBy" />
                                <input type="hidden" name="searchMode" value="@searchMode" />
                                <input type="hidden" name="sort" value="@sort" />
                                <input type="hidden" name="dir" value="@dir" />
                                <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                                @if (Model.FromDate.HasValue)
                                {
                                    <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                                }
                                @if (Model.ToDate.HasValue)
                                {
                                    <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                                }
                                @if (ViewBag.CodeFrom != null)
                                {
                                    <input type="hidden" name="codeFrom" value="@ViewBag.CodeFrom" />
                                }
                                @if (ViewBag.CodeTo != null)
                                {
                                    <input type="hidden" name="codeTo" value="@ViewBag.CodeTo" />
                                }
                                @if (stockAdjId.HasValue)
                                {
                                    <input type="hidden" name="stockAdjustmentId" value="@stockAdjId.Value" />
                                }
                                @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_stock)) { <input type="hidden" name="filterCol_stock" value="@filterCol_stock" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_product)) { <input type="hidden" name="filterCol_product" value="@filterCol_product" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_productName)) { <input type="hidden" name="filterCol_productName" value="@filterCol_productName" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_batch)) { <input type="hidden" name="filterCol_batch" value="@filterCol_batch" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_qtyBefore)) { <input type="hidden" name="filterCol_qtyBefore" value="@filterCol_qtyBefore" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_qtyAfter)) { <input type="hidden" name="filterCol_qtyAfter" value="@filterCol_qtyAfter" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_qtyDiff)) { <input type="hidden" name="filterCol_qtyDiff" value="@filterCol_qtyDiff" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_costUnit)) { <input type="hidden" name="filterCol_costUnit" value="@filterCol_costUnit" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_costDiff)) { <input type="hidden" name="filterCol_costDiff" value="@filterCol_costDiff" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_note)) { <input type="hidden" name="filterCol_note" value="@filterCol_note" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_stockExpr)) { <input type="hidden" name="filterCol_stockExpr" value="@filterCol_stockExpr" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_productExpr)) { <input type="hidden" name="filterCol_productExpr" value="@filterCol_productExpr" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_batchExpr)) { <input type="hidden" name="filterCol_batchExpr" value="@filterCol_batchExpr" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_qtyBeforeExpr)) { <input type="hidden" name="filterCol_qtyBeforeExpr" value="@filterCol_qtyBeforeExpr" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_qtyAfterExpr)) { <input type="hidden" name="filterCol_qtyAfterExpr" value="@filterCol_qtyAfterExpr" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_qtyDiffExpr)) { <input type="hidden" name="filterCol_qtyDiffExpr" value="@filterCol_qtyDiffExpr" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_costUnitExpr)) { <input type="hidden" name="filterCol_costUnitExpr" value="@filterCol_costUnitExpr" /> }
                                @if (!string.IsNullOrWhiteSpace(filterCol_costDiffExpr)) { <input type="hidden" name="filterCol_costDiffExpr" value="@filterCol_costDiffExpr" /> }
                                <select name="format"
                                        class="form-select form-select-arrow erp-filter-input"
                                        style="width:70px;min-width:70px;font-size:0.8rem;padding:0.25rem 0.4rem;">
                                    <option value="excel" selected>Excel</option>
                                    <option value="pdf">PDF</option>
                                </select>
                                <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    @* ===== كروت التجميعات (بعد الفلترة) ===== *@
    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row mt-2" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي السطور</div>
                    <div class="h4 mb-0 text-primary fw-bold">@total.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي الكمية قبل</div>
                    <div class="h4 mb-0 text-primary fw-bold">@totalQtyBeforeFiltered.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي الكمية بعد</div>
                    <div class="h4 mb-0 text-primary fw-bold">@totalQtyAfterFiltered.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي فرق الكمية</div>
                    <div class="h4 mb-0 text-primary fw-bold">@totalQtyDiffFiltered.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي فرق التكلفة</div>
                    <div class="h4 mb-0 text-primary fw-bold">@totalCostDiffFiltered.ToString("N2", n2)</div>
                </div>
            </div>
        </div>
    </div>

    @* ===== جدول سطور التسويات داخل حاوية تمرير ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0">
        <div id="salTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="salTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th data-col="id">@filterableCol("id", "id", "كود السطر")</th>
                    <th data-col="stock">@filterableCol("stock", "header", "رقم التسوية")</th>
                    <th data-col="warehouseCode">كود المخزن</th>
                    <th data-col="warehouseName">اسم المخزن</th>
                    <th data-col="product">@filterableCol("product", "product", "كود الصنف")</th>
                    <th data-col="productName">@filterableCol("productName", "productname", "اسم الصنف")</th>
                    <th data-col="batch">@filterableCol("batch", "batch", "كود التشغيلة")</th>
                    <th data-col="qtyBefore">@filterableCol("qtyBefore", "qtyBefore", "الكمية قبل")</th>
                    <th data-col="qtyAfter">@filterableCol("qtyAfter", "qtyAfter", "الكمية بعد")</th>
                    <th data-col="qtyDiff">@filterableCol("qtyDiff", "qtyDiff", "فرق الكمية")</th>
                    <th data-col="costUnit">@filterableCol("costUnit", "costPer", "تكلفة الوحدة")</th>
                    <th data-col="costDiff">@filterableCol("costDiff", "costDiff", "فرق التكلفة")</th>
                    <th data-col="note">@filterableCol("note", "note", "ملاحظات")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="13" class="text-center text-muted py-4">
                            لا توجد سطور تسوية حتى الآن.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var line in Model.Items)
                    {
                        var showUrl = Url.Action("Show", "StockAdjustments", new { id = line.StockAdjustmentId, frame = 1 });
                        var movementUrl = Url.Action("Show", "Products", new { id = line.ProductId, frame = 1 });
                        var rowId = line.Id + "_" + line.StockAdjustmentId;

                        <tr class="erp-list-selectable-row"
                            data-row-id="@rowId"
                            data-show-url="@showUrl"
                            data-movement-url="@movementUrl"
                            data-tab-title="تسوية جردية">
                            <td data-col="id">@line.Id</td>
                            <td data-col="stock">@line.StockAdjustmentId</td>
                            <td data-col="warehouseCode">@(line.StockAdjustment?.WarehouseId.ToString() ?? "-")</td>
                            <td data-col="warehouseName">@(line.StockAdjustment?.Warehouse?.WarehouseName ?? "-")</td>
                            <td data-col="product">@line.ProductId</td>
                            <td data-col="productName">@(line.Product?.ProdName ?? "-")</td>
                            <td data-col="batch">@line.BatchId</td>
                            <td data-col="qtyBefore">@line.QtyBefore</td>
                            <td data-col="qtyAfter">@line.QtyAfter</td>
                            <td data-col="qtyDiff">@line.QtyDiff</td>
                            <td data-col="costUnit">
                                @(line.CostPerUnit.HasValue? line.CostPerUnit.Value.ToString("0.0000") : "")
                            </td>
                            <td data-col="costDiff">
                                @(line.CostDiff.HasValue? line.CostDiff.Value.ToString("0.00") : "")
                            </td>
                            <td data-col="note">@line.Note</td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr class="table-secondary fw-bold">
                    <td colspan="7" class="text-start">إجمالي بعد الفلترة</td>
                    <td class="text-start">@totalQtyBeforeFiltered.ToString("N0", n2)</td>
                    <td class="text-start">@totalQtyAfterFiltered.ToString("N0", n2)</td>
                    <td class="text-start">@totalQtyDiffFiltered.ToString("N0", n2)</td>
                    <td class="text-start">-</td>
                    <td class="text-start">@totalCostDiffFiltered.ToString("N2", n2)</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
        </div>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print w-100" dir="rtl">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>
        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="searchMode" value="@searchMode" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            @if (Model.FromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
            }
            @if (Model.ToDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }
            @if (stockAdjId.HasValue)
            {
                <input type="hidden" name="stockAdjustmentId" value="@stockAdjId.Value" />
            }
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_stock)) { <input type="hidden" name="filterCol_stock" value="@filterCol_stock" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_product)) { <input type="hidden" name="filterCol_product" value="@filterCol_product" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_productName)) { <input type="hidden" name="filterCol_productName" value="@filterCol_productName" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_batch)) { <input type="hidden" name="filterCol_batch" value="@filterCol_batch" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_qtyBefore)) { <input type="hidden" name="filterCol_qtyBefore" value="@filterCol_qtyBefore" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_qtyAfter)) { <input type="hidden" name="filterCol_qtyAfter" value="@filterCol_qtyAfter" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_qtyDiff)) { <input type="hidden" name="filterCol_qtyDiff" value="@filterCol_qtyDiff" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_costUnit)) { <input type="hidden" name="filterCol_costUnit" value="@filterCol_costUnit" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_costDiff)) { <input type="hidden" name="filterCol_costDiff" value="@filterCol_costDiff" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_note)) { <input type="hidden" name="filterCol_note" value="@filterCol_note" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_stockExpr)) { <input type="hidden" name="filterCol_stockExpr" value="@filterCol_stockExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_productExpr)) { <input type="hidden" name="filterCol_productExpr" value="@filterCol_productExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_batchExpr)) { <input type="hidden" name="filterCol_batchExpr" value="@filterCol_batchExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_qtyBeforeExpr)) { <input type="hidden" name="filterCol_qtyBeforeExpr" value="@filterCol_qtyBeforeExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_qtyAfterExpr)) { <input type="hidden" name="filterCol_qtyAfterExpr" value="@filterCol_qtyAfterExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_qtyDiffExpr)) { <input type="hidden" name="filterCol_qtyDiffExpr" value="@filterCol_qtyDiffExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_costUnitExpr)) { <input type="hidden" name="filterCol_costUnitExpr" value="@filterCol_costUnitExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_costDiffExpr)) { <input type="hidden" name="filterCol_costDiffExpr" value="@filterCol_costDiffExpr" /> }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
            </select>
        </form>
        <script>
            (function () {
                var sel = document.querySelector('form select[name="pageSize"]');
                if (!sel) return;
                var params = new URLSearchParams(window.location.search);
                var all = params.getAll("pageSize");
                if (all.length > 0) sel.value = all[all.length - 1];
            })();
        </script>
    </div>

    @* ===== الترقيم (Pagination) ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== لوحة فلتر العمود (سكربت مشترك erp-list-column-filter.js) ===== *@
<div id="erpColumnFilterPanelSal" class="erp-column-filter-panel d-none" dir="rtl">
    <div class="erp-column-filter-header">
        <span>ترتيب وفلتر</span>
        <button type="button" class="btn-close btn-sm" aria-label="إغلاق"></button>
    </div>
    <div class="erp-column-filter-body">
        <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
