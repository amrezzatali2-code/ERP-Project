@using Microsoft.AspNetCore.Html          
@using ERP.Infrastructure                 
@model PagedResult<ERP.Models.StockAdjustmentLine>

@{
    ViewData["Title"] = "اختيار سطور التسويات";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "StockAdjustmentLines";

    // القيم القادمة من الموديل / ViewBag
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "stock";      // البحث الافتراضي برقم التسوية
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "Id";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    // نطاق العرض السفلي (عرض X–Y من Z)
    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1;
    int last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلتر كود من/إلى (هنا Id للسطر)
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    // حقل التاريخ المستخدم في الفلترة (لو حابب تربطه بتاريخ التسوية من الرأس لاحقاً)
    var dateField = (string?)ViewBag.DateField ?? "CreatedAt";

    // دالة توليد لينكات الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField,
        fromCode,
        toCode
    })!;

    // دالة إنشاء لينك الترتيب في رأس الجدول + أيقونة السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange = Model.UseDateRange,
            fromDate = Model.FromDate,
            toDate = Model.ToDate,
            dateField,
            fromCode,
            toCode
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    // متغيرات إجمالي الكميات (الصفحة الحالية فقط)
    int totalQtyBefore = 0;
    int totalQtyAfter = 0;
    int totalQtyDiff = 0;
}

<div dir="rtl" class="container-fluid">

   

    @* ===== الكارت العلوي: بحث + فلتر كود + أزرار التحكم ===== *@
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* العمود الأول: البحث *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث</label>
                        </div>

                        <div class="col-sm-4">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-4">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                @* البحث برقم السطر *@
                                <option value="id"
                                       @Html.Raw(searchBy == "id" ? " selected" : "")>
                                    كود السطر
                                </option>

                                @* البحث برقم التسوية *@
                                <option value="stock"
                                       @Html.Raw(searchBy == "stock" ? " selected" : "")>
                                    رقم التسوية
                                </option>

                                @* البحث بكود الصنف *@
                                <option value="product"
                                       @Html.Raw(searchBy == "product" ? " selected" : "")>
                                    كود الصنف
                                </option>

                                @* البحث بكود الباتش *@
                                <option value="batch"
                                       @Html.Raw(searchBy == "batch" ? " selected" : "")>
                                    كود التشغيلة
                                </option>

                                @* البحث بالملاحظات *@
                                <option value="note"
                                       @Html.Raw(searchBy == "note" ? " selected" : "")>
                                    الملاحظات
                                </option>
                            </select>
                        </div>

                        @* الحفاظ على باقي الفلاتر *@
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="dateField" value="@dateField" />
                        <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                        @if (Model.FromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                        }
                        @if (Model.ToDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                        }
                        @if (fromCode.HasValue)
                        {
                            <input type="hidden" name="fromCode" value="@fromCode" />
                        }
                        @if (toCode.HasValue)
                        {
                            <input type="hidden" name="toCode" value="@toCode" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm px-3">
                                بحث
                            </button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm"
                               href="@Url.Action(action, controller)">
                                إلغاء
                            </a>
                        </div>
                    </form>
                </div>

                @* العمود الثاني: فلتر كود من/إلى *@
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-semibold">من كود</span>
                        <input id="salCodeFromInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(ViewBag.CodeFrom?.ToString() ?? "")" />

                        <span class="fw-semibold">إلى كود</span>
                        <input id="salCodeToInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(ViewBag.CodeTo?.ToString() ?? "")" />

                        <button type="button"
                                id="btnSalApplyCodeFilter"
                                class="btn btn-erp btn-erp-primary btn-erp-sm">
                            تطبيق فلتر الكود
                        </button>

                        <button type="button"
                                id="btnSalClearCodeFilter"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            مسح
                        </button>
                    </div>
                </div>

                @* العمود الثالث: أزرار الفلاتر / الحذف / الطباعة / التصدير *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        @* فلترة بالتاريخ/الوقت *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#salDateFilterModal">
                            فلترة بالتاريخ/الوقت
                        </button>

                        @* اختيار الأعمدة *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#salColumnsModal">
                            اختيار الأعمدة
                        </button>

                        @* زر إضافة سطر جديد *@
                        <a asp-action="Create"
                           class="btn btn-erp btn-erp-primary btn-erp-sm">
                            إضافة سطر جديد
                        </a>

                        @* حذف المحدد *@
                        <form id="salBulkDeleteForm"
                              asp-action="BulkDelete"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="selectedIds" id="salSelectedIdsInput" />
                            <button type="button"
                                    id="btnSalDeleteSelected"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف السطور المحددة
                            </button>
                        </form>

                        @* حذف كل السطور (استخدمه بحذر) *@
                        <form id="salDeleteAllForm"
                              asp-action="DeleteAll"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="button"
                                    id="btnSalDeleteAll"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف جميع السطور
                            </button>
                        </form>

                        @* طباعة *@
                        <button type="button"
                                id="btnSalPrint"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        @* تصدير *@
                        <form method="get"
                              asp-action="Export"
                              asp-controller="StockAdjustmentLines"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                            @if (Model.FromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                            }
                            @if (Model.ToDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                            }
                            @if (ViewBag.CodeFrom != null)
                            {
                                <input type="hidden" name="codeFrom" value="@ViewBag.CodeFrom" />
                            }
                            @if (ViewBag.CodeTo != null)
                            {
                                <input type="hidden" name="codeTo" value="@ViewBag.CodeTo" />
                            }

                            <select name="format"
                                    class="form-select form-select-sm"
                                    style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm">
                                تصدير
                            </button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

    @* ===== جدول سطور التسويات ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="salTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    @* اختيار الصف *@
                    <th class="text-center no-print"
                        style="width:40px;"
                        data-col="select"
                        data-col-fixed="true">
                        <input type="checkbox" id="salChkAllRows" />
                    </th>

                    <th data-col="id">@sortLink("Id", "كود السطر")</th>
                    <th data-col="stock">@sortLink("StockAdjustmentId", "رقم التسوية")</th>
                    <th data-col="product">@sortLink("ProductId", "كود الصنف")</th>
                    <th data-col="batch">@sortLink("BatchId", "كود التشغيلة")</th>
                    <th data-col="qtyBefore">@sortLink("QtyBefore", "الكمية قبل")</th>
                    <th data-col="qtyAfter">@sortLink("QtyAfter", "الكمية بعد")</th>
                    <th data-col="qtyDiff">@sortLink("QtyDiff", "فرق الكمية")</th>
                    <th data-col="costUnit">@sortLink("CostPerUnit", "تكلفة الوحدة")</th>
                    <th data-col="costDiff">@sortLink("CostDiff", "فرق التكلفة")</th>
                    <th data-col="note">@sortLink("Note", "ملاحظات")</th>

                    <th class="text-nowrap no-print"
                        data-col="actions"
                        data-col-fixed="true"
                        style="width:220px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="12" class="text-center text-muted py-4">
                            لا توجد سطور تسوية حتى الآن.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var line in Model.Items)
                    {
                        totalQtyBefore += line.QtyBefore;
                        totalQtyAfter += line.QtyAfter;
                        totalQtyDiff += line.QtyDiff;

                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select-sal"
                                       value="@line.Id" />
                            </td>

                            <td data-col="id">@line.Id</td>
                            <td data-col="stock">@line.StockAdjustmentId</td>
                            <td data-col="product">@line.ProductId</td>
                            <td data-col="batch">@line.BatchId</td>
                            <td data-col="qtyBefore">@line.QtyBefore</td>
                            <td data-col="qtyAfter">@line.QtyAfter</td>
                            <td data-col="qtyDiff">@line.QtyDiff</td>
                            <td data-col="costUnit">
                                @(line.CostPerUnit.HasValue? line.CostPerUnit.Value.ToString("0.0000") : "")
                            </td>
                            <td data-col="costDiff">
                                @(line.CostDiff.HasValue? line.CostDiff.Value.ToString("0.00") : "")
                            </td>
                            <td data-col="note">@line.Note</td>

                            <td class="text-nowrap no-print" data-col="actions">
                                <a class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                   asp-action="Details"
                                   asp-route-id="@line.Id">
                                    تفاصيل
                                </a>
                                <a class="btn btn-erp btn-erp-primary btn-erp-sm"
                                   asp-action="Edit"
                                   asp-route-id="@line.Id">
                                    تعديل
                                </a>
                                <a class="btn btn-erp btn-erp-danger btn-erp-sm"
                                   asp-action="Delete"
                                   asp-route-id="@line.Id">
                                    حذف
                                </a>
                            </td>
                        </tr>
                    }

                    @* صف إجمالي الكميات للصفحة الحالية *@
                    <tr class="table-secondary fw-bold">
                        <td colspan="5" class="text-center">
                            إجمالي الكميات في الصفحة الحالية
                        </td>
                        <td>@totalQtyBefore</td>
                        <td>@totalQtyAfter</td>
                        <td>@totalQtyDiff</td>
                        <td colspan="4"></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            @if (Model.FromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
            }
            @if (Model.ToDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    <div class="mt-1">
        <small class="text-muted">
            إجمالي سطور التسويات: @total
        </small>
    </div>

    @* ===== الترقيم (Pagination) ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة التاريخ/الوقت ===== *@
<div class="modal fade no-print"
     id="salDateFilterModal"
     tabindex="-1"
     aria-labelledby="salDateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="salDateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ التسوية / الإنشاء)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="salUseDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(Model.UseDateRange ? "checked" : "") />
                            <label class="form-check-label" for="salUseDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="salColumnsModal"
     tabindex="-1"
     aria-labelledby="salColumnsModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="salColumnsModalLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="salColumnsList"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnSalApplyColumns"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط
        // =========================
        document.getElementById("btnSalPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table  = document.getElementById("salTable");              // جدول السطور
            if (!table) return;

            const chkAll     = document.getElementById("salChkAllRows");     // تشيك بوكس الكل
            const rowsChk    = () => table.querySelectorAll("tbody .row-select-sal"); // تشيك بوكسات الصفوف
            const bulkForm   = document.getElementById("salBulkDeleteForm"); // فورم الحذف الجماعي
            const selectedEl = document.getElementById("salSelectedIdsInput");// الحقل المخفي لتجميع الأكواد

            // اختيار/إلغاء اختيار كل الصفوف
            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            // لو لغينا صف مفرد، نفصل تشيك الكل
            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select-sal")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnSalDeleteSelected");
            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل سطر واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف السطور المحددة؟")) return;

                selectedEl.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnSalDeleteAll");
            const deleteAllForm = document.getElementById("salDeleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع سطور التسويات. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("salTable");    // جدول السطور
            if (!table) return;

            const storageKey = "sal-columns-visibility";          // مفتاح التخزين في المتصفح

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            // تطبيق الإخفاء/الإظهار على الأعمدة
            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("salColumnsList");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "sal_col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnSalApplyColumns")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("salColumnsModal");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر الكود من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnSalApplyCodeFilter");
            const btnClear = document.getElementById("btnSalClearCodeFilter");
            const fromInp  = document.getElementById("salCodeFromInput");
            const toInp    = document.getElementById("salCodeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                // نرجع لأول صفحة مع الحفاظ على باقي الفلاتر
                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
