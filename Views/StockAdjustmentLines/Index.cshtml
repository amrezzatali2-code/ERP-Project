@section Scripts {
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        document.getElementById("btnSalPrint")?.addEventListener("click", function () {
            window.print();
        });

        ERP.initListSelection({
            showButtonId: 'btnShowSalLine',
            movementButtonId: 'btnMovementSalLine',
            movementUrlAttribute: 'data-movement-url',
            movementTabTitle: 'حركة الصنف',
            movementTabId: 'product-movement-tab',
            idAttribute: 'data-row-id',
            showUrlAttribute: 'data-show-url',
            tabTitleAttribute: 'data-tab-title',
            showTabId: 'stock-adjustment-show'
        });

        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanelSal',
            tableId: 'salTable',
            wrapperId: 'salTableScrollWrapper',
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "StockAdjustmentLines")',
            defaultSort: 'id',
            defaultDir: 'asc',
            numericColumns: ['id', 'stock', 'product', 'batch', 'qtyBefore', 'qtyAfter', 'qtyDiff', 'costUnit', 'costDiff']
        });

        (function () {
            const table = document.getElementById("salTable");
            if (!table) return;

            const storageKey = "sal-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => {
                    const t = th.querySelector(".erp-col-title");
                    return {
                        key: th.getAttribute("data-col"),
                        title: (t ? t.innerText : th.innerText).trim()
                    };
                });

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("salColumnsList");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "sal_col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnSalApplyColumns")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("salColumnsModal");
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        (function () {
            const btnApply = document.getElementById("btnSalApplyCodeFilter");
            const btnClear = document.getElementById("btnSalClearCodeFilter");
            const fromInp = document.getElementById("salCodeFromInput");
            const toInp = document.getElementById("salCodeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else url.searchParams.delete("fromCode");

                if (codeTo) url.searchParams.set("toCode", codeTo);
                else url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
