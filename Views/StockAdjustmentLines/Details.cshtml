@model ERP.Models.StockAdjustmentLine

@{
    ViewData["Title"] = "تفاصيل سطر تسوية";
}

<div class="container" dir="rtl">
    <h2 class="mt-3 mb-3">تفاصيل سطر التسوية — @Model.Id</h2>

    <div class="card mb-3">
        <div class="card-body">
            <table class="table table-bordered">
                <tr>
                    <th>كود السطر</th>
                    <td>@Model.Id</td>
                </tr>
                <tr>
                    <th>رقم التسوية</th>
                    <td>@Model.StockAdjustmentId</td>
                </tr>
                <tr>
                    <th>كود الصنف</th>
                    <td>@Model.ProductId</td>
                </tr>
                <tr>
                    <th>كود الباتش</th>
                    <td>@Model.BatchId</td>
                </tr>
                <tr>
                    <th>الكمية قبل</th>
                    <td>@Model.QtyBefore</td>
                </tr>
                <tr>
                    <th>الكمية بعد</th>
                    <td>@Model.QtyAfter</td>
                </tr>
                <tr>
                    <th>فرق الكمية</th>
                    <td>@Model.QtyDiff</td>
                </tr>
                <tr>
                    <th>تكلفة الوحدة</th>
                    <td>@Model.CostPerUnit?.ToString("0.0000")</td>
                </tr>
                <tr>
                    <th>فرق التكلفة</th>
                    <td>@Model.CostDiff?.ToString("0.00")</td>
                </tr>
                <tr>
                    <th>ملاحظات</th>
                    <td>@Model.Note</td>
                </tr>
            </table>

            <div class="d-flex gap-2">
                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-erp btn-erp-primary">
                    تعديل
                </a>
                <a asp-action="Index"
                   asp-route-stockAdjustmentId="@Model.StockAdjustmentId"
                   class="btn btn-erp btn-erp-secondary">
                    رجوع للقائمة
                </a>
            </div>
        </div>
    </div>
</div>
