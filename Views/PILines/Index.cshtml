@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.PILine>

@{
    ViewData["Title"] = "سطور فواتير الشراء";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "PILines";

    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "piid";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    var dateField = (string?)ViewBag.DateField ?? "PIDate";

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField,
        fromCode,
        toCode
    })!;

    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange = Model.UseDateRange,
            fromDate = Model.FromDate,
            toDate = Model.ToDate,
            dateField,
            fromCode,
            toCode
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };
}

<div dir="rtl" class="container-fluid">

    @* ===== الكارت العلوي: بحث + فلتر رقم فاتورة + أزرار التحكم ===== *@
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* العمود الأول: البحث *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث في السطور</label>
                        </div>

                        <div class="col-sm-4">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-4">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                <option value="all"
                                       @Html.Raw(searchBy == "all" ? " selected" : "")>
                                    البحث في الكل
                                </option>
                                <option value="piid"
                                       @Html.Raw(searchBy == "piid" ? " selected" : "")>
                                    رقم الفاتورة
                                </option>
                                <option value="prod"
                                       @Html.Raw(searchBy == "prod" ? " selected" : "")>
                                    كود الصنف
                                </option>
                                <option value="batch"
                                       @Html.Raw(searchBy == "batch" ? " selected" : "")>
                                    التشغيلة
                                </option>
                                <option value="expiry"
                                       @Html.Raw(searchBy == "expiry" ? " selected" : "")>
                                    الصلاحية
                                </option>
                            </select>
                        </div>

                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="dateField" value="@dateField" />
                        <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                        @if (Model.FromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                        }
                        @if (Model.ToDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                        }
                        @if (fromCode.HasValue)
                        {
                            <input type="hidden" name="fromCode" value="@fromCode" />
                        }
                        @if (toCode.HasValue)
                        {
                            <input type="hidden" name="toCode" value="@toCode" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">
                                بحث
                            </button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm"
                               href="@Url.Action(action, controller)">
                                إلغاء
                            </a>
                        </div>
                    </form>
                </div>

                @* العمود الثاني: فلتر من/إلى رقم فاتورة *@
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-semibold">من رقم فاتورة</span>
                        <input id="codeFromInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:120px"
                               value="@(ViewBag.CodeFrom?.ToString() ?? "")" />

                        <span class="fw-semibold">إلى رقم فاتورة</span>
                        <input id="codeToInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:120px"
                               value="@(ViewBag.CodeTo?.ToString() ?? "")" />

                        <button type="button"
                                id="btnApplyCodeFilter"
                                class="btn btn-erp btn-erp-primary btn-erp-sm">
                            تطبيق
                        </button>

                        <button type="button"
                                id="btnClearCodeFilter"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            مسح
                        </button>
                    </div>
                </div>

                @* العمود الثالث: فلترة التاريخ / الحذف / الطباعة / التصدير *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#dateFilterModal">
                            فلترة بتاريخ الفاتورة
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalPIL">
                            اختيار الأعمدة
                        </button>

                        <form id="bulkDeleteForm"
                              asp-action="BulkDelete"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="selectedKeys" id="selectedKeysInput" />
                            <button type="button"
                                    id="btnDeleteSelected"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف السطور المحددة
                            </button>
                        </form>

                        <form id="deleteAllForm"
                              asp-action="DeleteAll"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="button"
                                    id="btnDeleteAll"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف جميع السطور
                            </button>
                        </form>

                        <button type="button"
                                id="btnPrint"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        <form method="get"
                              asp-action="Export"
                              asp-controller="PILines"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                            @if (Model.FromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                            }
                            @if (Model.ToDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                            }
                            @if (ViewBag.CodeFrom != null)
                            {
                                <input type="hidden" name="codeFrom" value="@ViewBag.CodeFrom" />
                            }
                            @if (ViewBag.CodeTo != null)
                            {
                                <input type="hidden" name="codeTo" value="@ViewBag.CodeTo" />
                            }

                            <select name="format"
                                    class="form-select form-select-sm"
                                    style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm">
                                تصدير
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>

    @* ===== جدول سطور فواتير الشراء ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="pilTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    <th data-col="piid">@sortLink("piid", "رقم الفاتورة")</th>
                    <th data-col="lineno">@sortLink("lineno", "رقم السطر")</th>

                    <th data-col="prod">@sortLink("prod", "كود الصنف")</th>

                    @* تعليق عربي: اسم الصنف (محتاج Include(Product)) *@
                    <th data-col="prodname">@sortLink("prodname", "اسم الصنف")</th>

                    <th data-col="qty">@sortLink("qty", "الكمية")</th>
                    <th data-col="unitcost">@sortLink("unitcost", "تكلفة الوحدة")</th>
                    <th data-col="disc">@sortLink("disc", "خصم الشراء %")</th>
                    <th data-col="retail">@sortLink("retail", "سعر الجمهور")</th>

                    @* تعليق عربي: قيمة السطر (محسوبة) *@
                    <th data-col="linevalue">@sortLink("linevalue", "قيمة السطر")</th>

                    <th data-col="batch">@sortLink("batch", "التشغيلة")</th>
                    <th data-col="expiry">@sortLink("expiry", "الصلاحية")</th>
                    <th data-col="date">@sortLink("date", "تاريخ الفاتورة")</th>
                    <th class="text-center no-print" data-col="actions">إجراءات</th>
                    <th class="text-center no-print" data-col="actions">إجراءات</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="13" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var l in Model.Items)
                    {
                        // تعليق عربي: تاريخ الفاتورة من الهيدر
                        var invoiceDate = l.PurchaseInvoice?.PIDate.ToString("yyyy-MM-dd") ?? "";

                        // تعليق عربي: اسم الصنف من جدول Products
                        var prodName = l.Product?.ProdName ?? "";

                        // تعليق عربي: حساب قيمة السطر = (Qty * PriceRetail) بعد خصم الشراء %
                        decimal lineValue = (l.Qty * l.PriceRetail) * (1m - (l.PurchaseDiscountPct / 100m));

                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@($"{l.PIId}:{l.LineNo}")" />
                            </td>

                            <td data-col="piid">@l.PIId</td>
                            <td data-col="lineno">@l.LineNo</td>

                            <td data-col="prod">@l.ProdId</td>
                            <td data-col="prodname">@prodName</td>

                            <td data-col="qty">@l.Qty</td>

                            <td data-col="unitcost">@l.UnitCost.ToString("0.00")</td>
                            <td data-col="disc">@l.PurchaseDiscountPct.ToString("0.00")</td>
                            <td data-col="retail">@l.PriceRetail.ToString("0.00")</td>

                            <td data-col="linevalue">@lineValue.ToString("0.00")</td>

                            <td data-col="batch">@l.BatchNo</td>
                            <td data-col="expiry">@l.Expiry?.ToString("yyyy-MM-dd")</td>
                            <td data-col="date">@invoiceDate</td>
                            <td class="text-center no-print" data-col="actions">
                                @* زر فتح فاتورة الشراء (داخل تاب) *@
                                <a class="btn btn-primary btn-sm open-tab"
                                   data-tab-id="pi-show-tab"
                                   data-tab-title="فاتورة المشتريات"
                                   href="@Url.Action("Show", "PurchaseInvoices", new { id = l.PIId, frame = 1 })">
                                    عرض الفاتورة
                                </a>

                            </td>
                            <td class="text-center no-print" data-col="actions">

                                @* زر حركة الصنف (داخل تاب) *@
                                <a class="btn btn-outline-dark btn-sm open-tab"
                                   data-tab-id="product-movement-tab"
                                   data-tab-title="حركة الصنف"
                                   href="@Url.Action("Show", "Products", new { prodId = l.ProdId, frame = 1 })">
                                    حركة الصنف
                                </a>

                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="table-light">
                <tr class="fw-bold">
                    @* عمود التشيك بوكس *@
                    <td class="text-center no-print" data-col="select"></td>

                    @* رقم الفاتورة *@
                    <td data-col="piid" class="text-muted">إجمالي</td>

                    @* رقم السطر *@
                    <td data-col="lineno"></td>

                    @* كود الصنف *@
                    <td data-col="prod"></td>

                    @* اسم الصنف *@
                    <td data-col="prodname"></td>

                    @* الكمية *@
                    <td data-col="qty"></td>

                    @* تكلفة الوحدة *@
                    <td data-col="unitcost"></td>

                    @* خصم الشراء % *@
                    <td data-col="disc"></td>

                    @* سعر الجمهور *@
                    <td data-col="retail"></td>

                    @* ✅ قيمة السطر *@
                    <td data-col="linevalue">@((ViewBag.TotalLineValue != null ? (decimal)ViewBag.TotalLineValue : 0m).ToString("0.00"))</td>

                    @* التشغيلة *@
                    <td data-col="batch"></td>

                    @* الصلاحية *@
                    <td data-col="expiry"></td>

                    @* تاريخ الفاتورة *@
                    <td data-col="date"></td>

                    @* الأكشن (عمودين) *@
                    <td class="text-center no-print" data-col="actions"></td>
                    <td class="text-center no-print" data-col="actions"></td>
                </tr>
            </tfoot>
        </table>

    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            @if (Model.FromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
            }
            @if (Model.ToDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    <div>
        <small class="text-muted d-none d-md-inline">
            إجمالي عدد السطور: @total
        </small>
    </div>

    @* ===== الترقيم (Pagination) ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة التاريخ ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بتاريخ الفاتورة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(Model.UseDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من تاريخ</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى تاريخ</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="columnsModalPIL"
     tabindex="-1"
     aria-labelledby="columnsModalPILLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalPILLabel">
                    اختيار الأعمدة 
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListPIL"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsPIL"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // زر الطباعة
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // تحديد السطور وحذف المحدد / الكل
        (function () {
            const table = document.getElementById("pilTable");
            if (!table) return;

            const chkAll  = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected");
            const bulkForm          = document.getElementById("bulkDeleteForm");
            const selectedInput     = document.getElementById("selectedKeysInput");

            btnDeleteSelected?.addEventListener("click", function () {
                const keys = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (keys.length === 0) {
                    alert("من فضلك اختر على الأقل سطر واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف السطور المحددة؟")) return;

                selectedInput.value = keys.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("deleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع سطور فواتير الشراء. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // اختيار الأعمدة + حفظ في localStorage
        (function () {
            const table = document.getElementById("pilTable");
            if (!table) return;

            const storageKey = "pil-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells.map(th => ({
                key: th.getAttribute("data-col"),
                title: th.innerText.trim()
            }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => cell.classList.toggle("d-none", isHidden));
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListPIL");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsPIL")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalPIL");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // فلتر من/إلى رقم فاتورة
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
