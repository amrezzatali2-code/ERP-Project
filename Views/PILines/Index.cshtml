    @* ===== جدول سطور فواتير الشراء ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0" dir="rtl">
        <div id="pilTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="pilTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>
                    <th data-col="piid">@filterableCol("piid", "piid", "رقم الفاتورة")</th>
                    <th data-col="lineno">@filterableCol("lineno", "lineno", "رقم السطر")</th>
                    <th data-col="prod">@filterableCol("prod", "prod", "كود الصنف")</th>
                    <th data-col="prodname">@filterableCol("prodname", "prodname", "اسم الصنف")</th>
                    <th data-col="qty">@filterableCol("qty", "qty", "الكمية")</th>
                    <th data-col="unitcost">@filterableCol("unitcost", "unitcost", "تكلفة الوحدة")</th>
                    <th data-col="disc">@filterableCol("disc", "disc", "خصم الشراء %")</th>
                    <th data-col="retail">@filterableCol("retail", "retail", "سعر الجمهور")</th>
                    <th data-col="linevalue">@filterableCol("linevalue", "linevalue", "قيمة السطر")</th>
                    <th data-col="batch">@filterableCol("batch", "batch", "التشغيلة")</th>
                    <th data-col="expiry">@filterableCol("expiry", "expiry", "الصلاحية")</th>
                    <th data-col="date">@filterableCol("date", "date", "تاريخ الفاتورة")</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="13" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var l in Model.Items)
                    {
                        // تعليق عربي: تاريخ الفاتورة من الهيدر
                        var invoiceDate = l.PurchaseInvoice?.PIDate.ToString("yyyy-MM-dd") ?? "";

                        // تعليق عربي: اسم الصنف من جدول Products
                        var prodName = l.Product?.ProdName ?? "";

                        // تعليق عربي: حساب قيمة السطر = (Qty * PriceRetail) بعد خصم الشراء %
                        decimal lineValue = (l.Qty * l.PriceRetail) * (1m - (l.PurchaseDiscountPct / 100m));
                        var showUrl = Url.Action("Show", "PurchaseInvoices", new { id = l.PIId, frame = 1 });
                        var volUrl = (l.PurchaseInvoice != null && l.PurchaseInvoice.CustomerId > 0)
                            ? Url.Action("Show", "Customers", new { id = l.PurchaseInvoice.CustomerId, frame = 1 })
                            : "";

                        <tr class="erp-list-selectable-row" data-pi-id="@l.PIId"
                            data-show-url="@showUrl"
                            data-tab-title="فاتورة مشتريات"
                            data-customer-volume-url="@volUrl">
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@($"{l.PIId}:{l.LineNo}")" />
                            </td>

                            <td data-col="piid">@l.PIId</td>
                            <td data-col="lineno">@l.LineNo</td>

                            <td data-col="prod">@l.ProdId</td>
                            <td data-col="prodname">@prodName</td>

                            <td data-col="qty">@l.Qty</td>

                            <td data-col="unitcost">@l.UnitCost.ToString("0.00")</td>
                            <td data-col="disc">@l.PurchaseDiscountPct.ToString("0.00")</td>
                            <td data-col="retail">@l.PriceRetail.ToString("0.00")</td>

                            <td data-col="linevalue">@lineValue.ToString("0.00")</td>

                            <td data-col="batch">@l.BatchNo</td>
                            <td data-col="expiry">@l.Expiry?.ToString("yyyy-MM-dd")</td>
                            <td data-col="date">@invoiceDate</td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="table-light">
                <tr class="fw-bold text-start">
                    <td class="text-center no-print" data-col="select"></td>

                    @* رقم الفاتورة *@
                    <td data-col="piid" class="text-muted">إجمالي</td>

                    @* رقم السطر *@
                    <td data-col="lineno"></td>

                    @* كود الصنف *@
                    <td data-col="prod"></td>

                    @* اسم الصنف *@
                    <td data-col="prodname"></td>

                    @* الكمية *@
                    <td data-col="qty"></td>

                    @* تكلفة الوحدة *@
                    <td data-col="unitcost"></td>

                    @* خصم الشراء % *@
                    <td data-col="disc"></td>

                    @* سعر الجمهور *@
                    <td data-col="retail"></td>

                    @* ✅ قيمة السطر *@
                    <td data-col="linevalue">@((ViewBag.TotalLineValue != null ? (decimal)ViewBag.TotalLineValue : 0m).ToString("0.00"))</td>

                    @* التشغيلة *@
                    <td data-col="batch"></td>

                    @* الصلاحية *@
                    <td data-col="expiry"></td>

                    @* تاريخ الفاتورة *@
                    <td data-col="date"></td>
                </tr>
            </tfoot>
        </table>
        </div>
    </div>

    @* لوحة فلتر العمود (بنمط Excel) — معرفات موحّدة مع erp-list-column-filter.js *@
