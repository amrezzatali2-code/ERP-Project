    @* ===== جدول الأصناف (هو الذى يتطبع) - مع هيدر ثابت ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0">
        <div class="erp-table-wrapper erp-print-area" style="position: relative; max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="productsTable" class="table table-striped table-hover erp-table erp-table-sortable erp-products-table">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    @* اختيار الصف *@
                    <th class="text-center no-print"
                        style="width:40px;"
                        data-col="select"
                        data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    @* كل الأعمدة الآن قابلة للفلترة بنمط Excel *@
                    <th style="width:110px;" data-col="id">@filterableCol("id", "id", "كود الصنف")</th>
                    <th data-col="col-name">@filterableCol("name", "name", "اسم الصنف")</th>
                    <th data-col="barcode">@filterableCol("barcode", "code", "الباركود")</th>
                    <th data-col="generic">@filterableCol("generic", "gen", "الاسم العلمي")</th>
                    <th data-col="category">@filterableCol("category", "category", "الفئة")</th>
                    <th data-col="classification">@filterableCol("classification", "classification", "التصنيف")</th>

                    @* 🔹 مجموعة الصنف + مجموعة البونص *@
                    <th data-col="productGroup">@filterableCol("productGroup", "productgroup", "مجموعة الصنف")</th>
                    <th data-col="bonusGroup">@filterableCol("bonusGroup", "bonusgroup", "مجموعة البونص")</th>

                    <th data-col="company">@filterableCol("company", "comp", "الشركة")</th>
                    <th data-col="location">@filterableCol("location", "location", "الموقع")</th>
                    <th data-col="warehouse">@filterableCol("warehouse", "warehouse", "المخزن")</th>
                    <th class="text-end" data-col="price">@filterableCol("price", "price", "سعر الجمهور")</th>
                    <th data-col="imported">@filterableCol("imported", "imported", "محلي/مستورد")</th>
                    <th data-col="isactive">@filterableCol("isactive", "isactive", "الحالة")</th>
                    <th style="width:150px;" data-col="created">@filterableCol("created", "created", "تاريخ الإنشاء")</th>
                    <th style="width:150px;" data-col="modified">@filterableCol("modified", "modified", "آخر تعديل")</th>
                    <th style="width:150px;" data-col="lastprice">@filterableCol("lastprice", "updated", "آخر تغيير سعر")</th>

                    @* 🔹 أعمدة الكوتة *@
                    <th data-col="hasQuota">@filterableCol("hasQuota", "hasquota", "له كوتة؟")</th>
                    <th data-col="quotaQuantity">@filterableCol("quotaQuantity", "quotaquantity", "كمية الكوتة")</th>

                    <th data-col="descShort">@filterableCol("descShort", "descshort", "الوصف المختصر")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        @* عدد الأعمدة = 21 (تحديد + كود + اسم + … + الوصف المختصر) *@
                        <td colspan="21" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var p in Model.Items)
                    {
                        var desc = p.Description ?? "";                                  // متغير: الوصف الكامل
                        var descShort = desc.Length > 120 ? desc.Substring(0, 120) + "…" : desc; // متغير: وصف مختصر
                        var groupName = p.ProductGroup?.Name ?? "";                      // متغير: اسم مجموعة الصنف
                        var bonusName = p.ProductBonusGroup?.Name ?? "";                 // متغير: اسم مجموعة البونص
                        var editUrl = Url.Action("Edit", "Products", new { id = p.ProdId }) + "?frame=1";
                        var movementUrl = Url.Action("Show", "Products", new { id = p.ProdId }) + "?frame=1";

                        <tr class="erp-list-selectable-row"
                            data-prod-id="@p.ProdId"
                            @if (ViewBag.CanEdit == true) { <text>data-show-url="@editUrl"</text> }
                            @if (ViewBag.CanShow == true) { <text>data-movement-url="@movementUrl"</text> }
                            data-tab-title="صنف @p.ProdId">
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@p.ProdId" />
                            </td>

                            <td data-col="id">@p.ProdId</td>
                            <td data-col="col-name">@p.ProdName</td>
                            <td data-col="barcode">@p.Barcode</td>
                            <td data-col="generic">@p.GenericName</td>
                            <td data-col="category">@p.CategoryId</td>
                            <td data-col="classification">@(p.Classification?.Name)</td>

                            @* 🔹 مجموعة الصنف + مجموعة البونص *@
                            <td data-col="productGroup">@groupName</td>
                            <td data-col="bonusGroup">@bonusName</td>

                            <td data-col="company">@p.Company</td>
                            <td data-col="location">@p.Location</td>
                            <td data-col="warehouse">@(p.Warehouse?.WarehouseName)</td>
                            <td data-col="price" class="text-end">@p.PriceRetail.ToString("N2")</td>
                            <td data-col="imported">@p.Imported</td>
                            <td data-col="isactive">@((p.IsActive) ? "نشط" : "موقوف")</td>
                            <td data-col="created">@p.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                            <td data-col="modified">@p.UpdatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                            <td data-col="lastprice">
                                @(p.LastPriceChangeDate.HasValue
                                                        ? p.LastPriceChangeDate.Value.ToString("yyyy/MM/dd")
                                                        : "")
                            </td>

                            @* 🔹 بيانات الكوتة *@
                            <td data-col="hasQuota">
                                @(p.HasQuota ? "نعم" : "لا")
                            </td>
                            <td data-col="quotaQuantity">
                                @(p.HasQuota && p.QuotaQuantity.HasValue
                                                        ? p.QuotaQuantity.Value.ToString()
                                                        : "-")
                            </td>

                            <td data-col="descShort" title="@desc">@descShort</td>
                        </tr>
                    }

                }
            </tbody>
        </table>
        </div>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
