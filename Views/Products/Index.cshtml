@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<Product>

@{
    ViewData["Title"] = "قائمة الأصناف";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "Products";

    // القيم القادمة من الموديل / ViewBag (نفس نمط المحافظات / العملاء)
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "name";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلترة بالتاريخ/الوقت (تاريخ إنشاء الصنف) من PagedResult
    bool useDateRange = Model.UseDateRange;
    var fromDate = Model.FromDate;
    var toDate = Model.ToDate;

    // فلاتر متراكبة
    int? filterProductGroupId = ViewBag.FilterProductGroupId as int?;
    string? filterCompany = ViewBag.FilterCompany as string;
    string? filterImported = ViewBag.FilterImported as string;
    int? codeFrom = ViewBag.CodeFrom as int?;
    int? codeTo = ViewBag.CodeTo as int?;

    // دالة توليد لينك مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        filterProductGroupId,
        filterCompany,
        filterImported,
        codeFrom,
        codeTo
    })!;

    // دالة إنشاء لينك الترتيب مع السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate,
            filterProductGroupId,
            filterCompany,
            filterImported,
            codeFrom,
            codeTo
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString(
            $@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>"
        );
    };
}
<div dir="rtl" class="container-fluid">

    @* ===== شريط الفلاتر الموحد (مثل العملاء) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في الأصناف</label>
                    <div class="d-flex flex-wrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:150px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>البحث في الكل</option>
                            <option value="name"@Html.Raw(searchBy == "name" ? " selected" : "")>اسم الصنف</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>كود الصنف</option>
                            <option value="code"@Html.Raw(searchBy == "code" ? " selected" : "")>الباركود</option>
                            <option value="gen"@Html.Raw(searchBy == "gen" ? " selected" : "")>الاسم العلمي</option>
                            <option value="comp"@Html.Raw(searchBy == "comp" ? " selected" : "")>الشركة</option>
                            <option value="category"@Html.Raw(searchBy == "category" ? " selected" : "")>الفئة</option>
                            <option value="price"@Html.Raw(searchBy == "price" ? " selected" : "")>سعر الجمهور</option>
                            <option value="imported"@Html.Raw(searchBy == "imported" ? " selected" : "")>محلي/مستورد</option>
                            <option value="active"@Html.Raw(searchBy == "active" ? " selected" : "")>نشط/موقوف</option>
                            <option value="updated"@Html.Raw(searchBy == "updated" ? " selected" : "")>آخر تعديل</option>
                        </select>
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">بحث</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (filterProductGroupId.HasValue) { <input type="hidden" name="filterProductGroupId" value="@filterProductGroupId.Value" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCompany)) { <input type="hidden" name="filterCompany" value="@filterCompany" /> }
                    @if (!string.IsNullOrWhiteSpace(filterImported)) { <input type="hidden" name="filterImported" value="@filterImported" /> }
                    @if (codeFrom.HasValue) { <input type="hidden" name="codeFrom" value="@codeFrom" /> }
                    @if (codeTo.HasValue) { <input type="hidden" name="codeTo" value="@codeTo" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر الكود + فلاتر إضافية --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر الكود</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(codeFrom?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(codeTo?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
                <div class="d-flex flex-wrap gap-2 mt-2 justify-content-center w-100">
                    <select name="filterProductGroupId" id="filterProductGroupId" class="form-select erp-filter-input" style="max-width:140px" form="productsSearchForm">
                        <option value="">جميع الفئات</option>
                        @if (ViewBag.ProductGroups != null)
                        {
                            @foreach (var pg in (SelectList)ViewBag.ProductGroups)
                            {
                                <option value="@pg.Value"@Html.Raw(pg.Selected ? " selected" : "")>@pg.Text</option>
                            }
                        }
                    </select>
                    <input type="text" name="filterCompany" id="filterCompany" class="form-control erp-filter-input" list="companiesList" placeholder="الشركة" value="@filterCompany" style="max-width:120px" form="productsSearchForm" />
                    <datalist id="companiesList">
                        @if (ViewBag.Companies != null)
                        {
                            @foreach (var comp in (List<string>)ViewBag.Companies)
                            {
                                <option value="@comp">@comp</option>
                            }
                        }
                    </datalist>
                    <select name="filterImported" id="filterImported" class="form-select erp-filter-input" style="max-width:100px" form="productsSearchForm">
                        <option value="">الكل</option>
                        <option value="محلي"@Html.Raw(filterImported == "محلي" ? " selected" : "")>محلي</option>
                        <option value="مستورد"@Html.Raw(filterImported == "مستورد" ? " selected" : "")>مستورد</option>
                    </select>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <a class="btn btn-erp btn-erp-success btn-erp-sm" asp-action="Create">إضافة صنف</a>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalProducts">اختيار الأعمدة</button>
                        <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteSelected">حذف المحدد</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف الجميع</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="Products" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (filterProductGroupId.HasValue) { <input type="hidden" name="filterProductGroupId" value="@filterProductGroupId.Value" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCompany)) { <input type="hidden" name="filterCompany" value="@filterCompany" /> }
                            @if (!string.IsNullOrWhiteSpace(filterImported)) { <input type="hidden" name="filterImported" value="@filterImported" /> }
                            @if (codeFrom.HasValue) { <input type="hidden" name="codeFrom" value="@codeFrom" /> }
                            @if (codeTo.HasValue) { <input type="hidden" name="codeTo" value="@codeTo" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:70px;min-width:70px;font-size:0.8rem;padding:0.25rem 0.4rem;">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                    <form id="bulkDeleteForm" asp-action="BulkDelete" asp-controller="Products" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="selectedIds" id="selectedIdsInput" />
                    </form>
                    <form id="deleteAllForm" asp-action="DeleteAll" asp-controller="Products" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>

        </div>
    </div>

    @* فورم للفلاتر الإضافية (ProductGroup, Company, Imported) - يُستخدم عند تغيير الفلاتر *@
    <form id="productsSearchForm" method="get" action="@Url.Action(action, controller)" class="d-none">
        <input type="hidden" name="search" value="@search" />
        <input type="hidden" name="searchBy" value="@searchBy" />
        <input type="hidden" name="sort" value="@sort" />
        <input type="hidden" name="dir" value="@dir" />
        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="pageSize" value="@ps" />
        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
        @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
        @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
        @if (codeFrom.HasValue) { <input type="hidden" name="codeFrom" value="@codeFrom" /> }
        @if (codeTo.HasValue) { <input type="hidden" name="codeTo" value="@codeTo" /> }
    </form>

    @* ===== جدول الأصناف (هو الذى يتطبع) - مع هيدر ثابت ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area" style="position: relative; max-height: 70vh; overflow-y: auto;">
        <table id="productsTable" class="table table-striped table-hover erp-table erp-table-sortable erp-products-table">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #f8f9fa !important;">
                <tr>
                    @* اختيار الصف *@
                    <th class="text-center no-print"
                        style="width:40px;"
                        data-col="select"
                        data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    <th style="width:110px;" data-col="id">@sortLink("id", "كود الصنف")</th>
                    <th data-col="col-name">@sortLink("name", "اسم الصنف")</th>
                    <th data-col="barcode">@sortLink("code", "الباركود")</th>
                    <th data-col="generic">@sortLink("gen", "الاسم العلمي")</th>
                    <th data-col="category">@sortLink("category", "الفئة")</th>

                    @* 🔹 مجموعة الصنف + مجموعة البونص *@
                    <th data-col="productGroup">@sortLink("productgroup", "مجموعة الصنف")</th>
                    <th data-col="bonusGroup">@sortLink("bonusgroup", "مجموعة البونص")</th>

                    <th data-col="company">@sortLink("comp", "الشركة")</th>
                    <th class="text-end" data-col="price">@sortLink("price", "سعر الجمهور")</th>
                    <th data-col="imported">@sortLink("imported", "محلي/مستورد")</th>
                    <th data-col="isactive">@sortLink("isactive", "الحالة")</th>
                    <th style="width:150px;" data-col="created">@sortLink("created", "تاريخ الإنشاء")</th>
                    <th style="width:150px;" data-col="modified">@sortLink("modified", "آخر تعديل")</th>
                    <th style="width:150px;" data-col="lastprice">@sortLink("updated", "آخر تغيير سعر")</th>

                    @* 🔹 أعمدة الكوتة *@
                    <th data-col="hasQuota">@sortLink("hasquota", "له كوتة؟")</th>
                    <th data-col="quotaQuantity">@sortLink("quotaquantity", "كمية الكوتة")</th>

                    <th data-col="descShort">@sortLink("descshort", "الوصف المختصر")</th>

                    <th class="text-nowrap no-print"
                        style="width:220px;"
                        data-col="actions"
                        data-col-fixed="true">
                    </th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        @* عدد الأعمدة = 19 *@
                        <td colspan="19" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var p in Model.Items)
                    {
                        var desc = p.Description ?? "";                                  // متغير: الوصف الكامل
                        var descShort = desc.Length > 120 ? desc.Substring(0, 120) + "…" : desc; // متغير: وصف مختصر
                        var groupName = p.ProductGroup?.Name ?? "";                      // متغير: اسم مجموعة الصنف
                        var bonusName = p.ProductBonusGroup?.Name ?? "";                 // متغير: اسم مجموعة البونص

                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@p.ProdId" />
                            </td>

                            <td data-col="id">@p.ProdId</td>
                            <td data-col="col-name">@p.ProdName</td>
                            <td data-col="barcode">@p.Barcode</td>
                            <td data-col="generic">@p.GenericName</td>
                            <td data-col="category">@p.CategoryId</td>

                            @* 🔹 مجموعة الصنف + مجموعة البونص *@
                            <td data-col="productGroup">@groupName</td>
                            <td data-col="bonusGroup">@bonusName</td>

                            <td data-col="company">@p.Company</td>
                            <td data-col="price" class="text-end">@p.PriceRetail.ToString("N2")</td>
                            <td data-col="imported">@p.Imported</td>
                            <td data-col="isactive">@((p.IsActive) ? "نشط" : "موقوف")</td>
                            <td data-col="created">@p.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                            <td data-col="modified">@p.UpdatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                            <td data-col="lastprice">
                                @(p.LastPriceChangeDate.HasValue
                                                        ? p.LastPriceChangeDate.Value.ToString("yyyy/MM/dd")
                                                        : "")
                            </td>

                            @* 🔹 بيانات الكوتة *@
                            <td data-col="hasQuota">
                                @(p.HasQuota ? "نعم" : "لا")
                            </td>
                            <td data-col="quotaQuantity">
                                @(p.HasQuota && p.QuotaQuantity.HasValue
                                                        ? p.QuotaQuantity.Value.ToString()
                                                        : "-")
                            </td>

                            <td data-col="descShort" title="@desc">@descShort</td>

                            <td class="text-nowrap no-print" data-col="actions">
                                @* زر حركة الصنف يفتح شاشة Show فى تاب مستقل *@
                                <a class="btn btn-erp btn-erp-secondary btn-erp-sm app-menu-link"
                                   asp-action="Show"
                                   asp-route-id="@p.ProdId"
                                   data-tab-id="product-movement"
                                   data-tab-title="حركة صنف - @p.ProdName">
                                    حركة الصنف
                                </a>
                                <a class="btn btn-erp btn-erp-primary btn-erp-sm"
                                   asp-action="Edit"
                                   asp-route-id="@p.ProdId">
                                    تعديل
                                </a>
                                <a class="btn btn-erp btn-erp-danger btn-erp-sm"
                                   asp-action="Delete"
                                   asp-route-id="@p.ProdId">
                                    حذف
                                </a>
                            </td>
                        </tr>
                    }

                    @* صف إجمالي عدد الأصناف (حسب الفلتر الحالي) *@
                    <tr class="table-secondary fw-bold">
                        <td colspan="18" class="text-end">
                            عدد الأصناف (حسب الفلتر الحالي):
                        </td>
                        <td class="text-end">
                            @total
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              asp-action="@action"
              asp-controller="@controller"
              class="d-flex align-items-center gap-2">

            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
            @if (filterProductGroupId.HasValue) { <input type="hidden" name="filterProductGroupId" value="@filterProductGroupId.Value" /> }
            @if (!string.IsNullOrWhiteSpace(filterCompany)) { <input type="hidden" name="filterCompany" value="@filterCompany" /> }
            @if (!string.IsNullOrWhiteSpace(filterImported)) { <input type="hidden" name="filterImported" value="@filterImported" /> }
            @if (codeFrom.HasValue) { <input type="hidden" name="codeFrom" value="@codeFrom" /> }
            @if (codeTo.HasValue) { <input type="hidden" name="codeTo" value="@codeTo" /> }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    @* ===== الترقيم ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>

            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>

            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة بالتاريخ/الوقت ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ إنشاء الصنف)
                </h5>

                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    @if (filterProductGroupId.HasValue) { <input type="hidden" name="filterProductGroupId" value="@filterProductGroupId.Value" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCompany)) { <input type="hidden" name="filterCompany" value="@filterCompany" /> }
                    @if (!string.IsNullOrWhiteSpace(filterImported)) { <input type="hidden" name="filterImported" value="@filterImported" /> }
                    @if (codeFrom.HasValue) { <input type="hidden" name="codeFrom" value="@codeFrom" /> }
                    @if (codeTo.HasValue) { <input type="hidden" name="codeTo" value="@codeTo" /> }

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />

                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة (ديناميكي بنفس فكرة المحافظات) ===== *@
@* نافذة اختيار الأعمدة الخاصة بجدول الأصناف *@
<div class="modal fade no-print"
     id="columnsModalProducts"
     tabindex="-1"
     aria-labelledby="columnsModalProductsLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        @* modal-lg علشان فيه أعمدة كثيرة *@
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalProductsLabel">
                    اختيار الأعمدة الظاهرة في قائمة الأصناف
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <div class="modal-body">
                @* وصف بسيط للمستخدم *@
                <div class="small text-muted mb-2">
                    ضع علامة ✓ أمام الأعمدة التي تريد ظهورها في الجدول.
                </div>

                @* هنا الجافاسكريبت بيولّد قائمة الأعمدة من th[data-col] في جدول productsTable *@
                <div id="columnsListProducts"></div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>

                <button type="button"
                        id="btnApplyColumnsProducts"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط
        // =========================
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table  = document.getElementById("productsTable");    // متغير: جدول الأصناف
            if (!table) return;

            const chkAll = document.getElementById("chkAllRows");       // متغير: تشيك بوكس اختيار كل الصفوف
            const rowsChk = () => table.querySelectorAll("tbody .row-select"); // دالة: ترجع كل تشيك بوكسات الصفوف

            // تحديد/إلغاء تحديد كل الصفوف
            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            // لو شيلنا التحديد من صف واحد نشيل التحديد من "الكل"
            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected"); // زر حذف المحدد
            const bulkForm          = document.getElementById("bulkDeleteForm");    // فورم حذف المحدد
            const selectedInput     = document.getElementById("selectedIdsInput");  // متغير: هيدن فيه الـ Ids

            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل صنف واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف الأصناف المحددة؟")) return;

                selectedInput.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnDeleteAll");   // زر حذف الجميع
            const deleteAllForm = document.getElementById("deleteAllForm");  // فورم حذف الجميع

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع الأصناف. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("productsTable"); // متغير: جدول الأصناف
            if (!table) return;

            const storageKey = "products-columns-visibility";       // مفتاح التخزين في المتصفح

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]")); // رؤوس الأعمدة
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))   // استبعاد الأعمدة الثابتة
                .map(th => ({
                    key: th.getAttribute("data-col"),               // اسم العمود (المفتاح)
                    title: th.innerText.trim()                      // عنوان العمود الظاهر
                }));

            if (columns.length === 0) return;

            let hidden = [];                                        // متغير: قائمة الأعمدة المخفية
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            // دالة: تطبيق الإظهار/الإخفاء على الجدول
            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListProducts"); // مكان تشيك بوكس الأعمدة في المودال
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;

                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);         // متغير: هل العمود ظاهر أم لا
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            // زر تطبيق الأعمدة من المودال
            document.getElementById("btnApplyColumnsProducts")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalProducts");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // كروت البحث + فلتر الأكواد (واجهة جديدة)
        // =========================
        // فلتر الكود من/إلى (مثل العملاء)
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");
            const filterPg = document.getElementById("filterProductGroupId");
            const filterComp = document.getElementById("filterCompany");
            const filterImp = document.getElementById("filterImported");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("codeFrom", codeFrom);
                else          url.searchParams.delete("codeFrom");
                if (codeTo)   url.searchParams.set("codeTo", codeTo);
                else          url.searchParams.delete("codeTo");
                if (filterPg?.value) url.searchParams.set("filterProductGroupId", filterPg.value);
                if (filterComp?.value) url.searchParams.set("filterCompany", filterComp.value);
                if (filterImp?.value) url.searchParams.set("filterImported", filterImp.value);
                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp?.value?.trim() || "";
                const ct = toInp?.value?.trim() || "";
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                if (fromInp) fromInp.value = "";
                if (toInp) toInp.value = "";
                window.location.href = buildUrl("", "");
            });

            [filterPg, filterComp, filterImp].forEach(el => {
                el?.addEventListener("change", function () {
                    const form = document.getElementById("productsSearchForm");
                    if (form) {
                        const cf = fromInp?.value?.trim() || "";
                        const ct = toInp?.value?.trim() || "";
                        const url = new URL(form.action);
                        url.searchParams.set("search", form.querySelector('[name="search"]')?.value || "");
                        url.searchParams.set("searchBy", form.querySelector('[name="searchBy"]')?.value || "all");
                        url.searchParams.set("sort", form.querySelector('[name="sort"]')?.value || "name");
                        url.searchParams.set("dir", form.querySelector('[name="dir"]')?.value || "asc");
                        if (cf) url.searchParams.set("codeFrom", cf);
                        if (ct) url.searchParams.set("codeTo", ct);
                        if (filterPg?.value) url.searchParams.set("filterProductGroupId", filterPg.value);
                        if (filterComp?.value) url.searchParams.set("filterCompany", filterComp.value);
                        if (filterImp?.value) url.searchParams.set("filterImported", filterImp.value);
                        window.location.href = url.toString();
                    }
                });
            });
        })();

        // =========================
        // توسيع/تصغير عرض الأعمدة (نفس نظام المحافظات/مجموعات الأصناف)
        // =========================
        document.addEventListener("DOMContentLoaded", function () {
            var wrapper = document.querySelector(".erp-table-wrapper");
            if (!wrapper) return;
            var table = wrapper.querySelector("table.erp-table");
            if (!table) return;
            var ths = table.querySelectorAll("thead th");
            ths.forEach(function (th) {
                th.style.position = "relative";
                var handle = document.createElement("div");
                handle.className = "erp-col-resize-handle";
                th.appendChild(handle);
                var startX, startWidth;
                handle.addEventListener("mousedown", function (e) {
                    e.preventDefault();
                    startX = e.pageX;
                    startWidth = th.offsetWidth;
                    function onMouseMove(eMove) {
                        var diffX = eMove.pageX - startX;
                        var newWidth = startWidth + diffX;
                        if (newWidth < 50) newWidth = 50;
                        th.style.width = newWidth + "px";
                        th.style.minWidth = newWidth + "px";
                    }
                    function onMouseUp() {
                        document.removeEventListener("mousemove", onMouseMove);
                        document.removeEventListener("mouseup", onMouseUp);
                    }
                    document.addEventListener("mousemove", onMouseMove);
                    document.addEventListener("mouseup", onMouseUp);
                });
            });
        });
    </script>
}

