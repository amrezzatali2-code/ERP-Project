                     style="background: linear-gradient(90deg, #4b5563, #64748b);">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold">إجراءات الأصناف</span>
                    </div>
                </div>

                <div class="card-body py-2">
                    <div class="d-grid gap-1">

                        @* إضافة صنف جديد *@
