                           asp-action="Create">
                            + إضافة صنف جديد
                        </a>

                        @* فلترة بالتاريخ/الوقت *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-lg"
                                data-bs-toggle="modal"
                                data-bs-target="#dateFilterModal">
                            فلترة بالتاريخ/الوقت
                        </button>

                        @* اختيار الأعمدة *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-lg"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalProducts">
                            اختيار الأعمدة
                        </button>

                        @* فورم حذف المحدد *@
                        <form id="bulkDeleteForm"
                              asp-action="BulkDelete"
                              method="post"
                              class="d-grid">
                            @Html.AntiForgeryToken()
