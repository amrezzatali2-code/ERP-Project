                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة (ديناميكي بنفس فكرة المحافظات) ===== *@
@* نافذة اختيار الأعمدة الخاصة بجدول الأصناف *@
<div class="modal fade no-print erp-columns-modal"
     id="columnsModalProducts"
     tabindex="-1"
     aria-labelledby="columnsModalProductsLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        @* modal-lg علشان فيه أعمدة كثيرة *@
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalProductsLabel">
                    اختيار الأعمدة الظاهرة في قائمة الأصناف
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <div class="modal-body">
                @* وصف بسيط للمستخدم *@
                <div class="small text-muted mb-2">
                    ضع علامة ✓ أمام الأعمدة التي تريد ظهورها في الجدول.
                </div>

                @* هنا الجافاسكريبت بيولّد قائمة الأعمدة من th[data-col] في جدول productsTable *@
                <div id="columnsListProducts" class="erp-columns-modal-list"></div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>

                <button type="button"
                        id="btnApplyColumnsProducts"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script>
        // جعل الشريط الأفقي يفتح من جهة اليمين (بداية الجدول في RTL)
        (function () {
            var table = document.getElementById("productsTable");
            if (!table) return;
            var wrapper = table.closest(".erp-table-wrapper");
            if (!wrapper) return;
            wrapper.scrollLeft = wrapper.scrollWidth - wrapper.clientWidth;
        })();

        // =========================
        // زر الطباعة — يفتح صفحة طباعة بكل الأصناف المفلترة وكل الأعمدة
        // =========================
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            var url = new URL(window.location.href);
            url.searchParams.set("print", "true");
            url.searchParams.set("pageSize", "0");
            url.searchParams.set("page", "1");
            window.open(url.toString(), "_blank", "noopener");
        });

        @if (ViewBag.Print == true)
        {
            <text>
            window.onload = function () { window.print(); };
            window.onafterprint = function () { window.close(); };
            </text>
        }

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table  = document.getElementById("productsTable");    // متغير: جدول الأصناف
            if (!table) return;

            const chkAll = document.getElementById("chkAllRows");       // متغير: تشيك بوكس اختيار كل الصفوف
            const rowsChk = () => table.querySelectorAll("tbody .row-select"); // دالة: ترجع كل تشيك بوكسات الصفوف

            // تحديد/إلغاء تحديد كل الصفوف
            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            // لو شيلنا التحديد من صف واحد نشيل التحديد من "الكل"
            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected"); // زر حذف المحدد
            const bulkForm          = document.getElementById("bulkDeleteForm");    // فورم حذف المحدد
            const selectedInput     = document.getElementById("selectedIdsInput");  // متغير: هيدن فيه الـ Ids

            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل صنف واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف الأصناف المحددة؟")) return;

                selectedInput.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnDeleteAll");   // زر حذف الجميع
            const deleteAllForm = document.getElementById("deleteAllForm");  // فورم حذف الجميع

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع الأصناف. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        @if (ViewBag.CanEdit == true && ViewBag.CanShow == true)
        {
            <text>
        ERP.initListSelection({
            showButtonId: 'btnShowProduct',
            showTabId: 'product-edit-tab',
            movementButtonId: 'btnProductMovement',
            movementUrlAttribute: 'data-movement-url',
            movementTabTitle: 'حركة الصنف',
            movementTabId: 'product-movement-tab',
            idAttribute: 'data-prod-id',
            showUrlAttribute: 'data-show-url',
            tabTitleAttribute: 'data-tab-title'
        });
            </text>
        }
        else if (ViewBag.CanEdit == true)
        {
            <text>
        ERP.initListSelection({
            showButtonId: 'btnShowProduct',
            showTabId: 'product-edit-tab',
            movementUrlAttribute: 'data-movement-url',
            movementTabTitle: 'حركة الصنف',
            movementTabId: 'product-movement-tab',
            idAttribute: 'data-prod-id',
            showUrlAttribute: 'data-show-url',
            tabTitleAttribute: 'data-tab-title'
        });
            </text>
        }
        else if (ViewBag.CanShow == true)
        {
            <text>
        ERP.initListSelection({
            movementButtonId: 'btnProductMovement',
            movementUrlAttribute: 'data-movement-url',
            movementTabTitle: 'حركة الصنف',
            movementTabId: 'product-movement-tab',
            idAttribute: 'data-prod-id',
            showUrlAttribute: 'data-show-url',
            tabTitleAttribute: 'data-tab-title'
        });
            </text>
        }

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("productsTable"); // متغير: جدول الأصناف
            if (!table) return;

            const storageKey = "products-columns-visibility";       // مفتاح التخزين في المتصفح

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]")); // رؤوس الأعمدة
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))   // استبعاد الأعمدة الثابتة
                .map(th => ({
                    key: th.getAttribute("data-col"),               // اسم العمود (المفتاح)
                    title: th.innerText.trim()                      // عنوان العمود الظاهر
                }));

            if (columns.length === 0) return;

            let hidden = [];                                        // متغير: قائمة الأعمدة المخفية
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            // دالة: تطبيق الإظهار/الإخفاء على الجدول
            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListProducts"); // مكان تشيك بوكس الأعمدة في المودال
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;

                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);         // متغير: هل العمود ظاهر أم لا
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            // زر تطبيق الأعمدة من المودال
            document.getElementById("btnApplyColumnsProducts")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalProducts");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // كروت البحث + فلتر الأكواد (واجهة جديدة)
        // =========================
        // فلتر الكود من/إلى (مثل العملاء)
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");
            const filterPg = document.getElementById("filterProductGroupId");
            const filterComp = document.getElementById("filterCompany");
            const filterImp = document.getElementById("filterImported");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("codeFrom", codeFrom);
                else          url.searchParams.delete("codeFrom");
                if (codeTo)   url.searchParams.set("codeTo", codeTo);
                else          url.searchParams.delete("codeTo");
                if (filterPg?.value) url.searchParams.set("filterProductGroupId", filterPg.value);
                else url.searchParams.delete("filterProductGroupId");
                if (filterComp?.value) url.searchParams.set("filterCompany", filterComp.value);
                else url.searchParams.delete("filterCompany");
                if (filterImp?.value) url.searchParams.set("filterImported", filterImp.value);
                else url.searchParams.delete("filterImported");
                ["filterCol_productGroup","filterCol_bonusGroup","filterCol_company","filterCol_location","filterCol_imported","filterCol_isactive",
                 "filterCol_id","filterCol_name","filterCol_barcode","filterCol_generic","filterCol_category","filterCol_classification","filterCol_price",
                 "filterCol_created","filterCol_modified","filterCol_lastprice","filterCol_hasQuota","filterCol_quotaQuantity","filterCol_descShort",
                 "filterCol_idExpr","filterCol_priceExpr"].forEach(k => {
                    const v = new URL(window.location.href).searchParams.get(k);
                    if (v) url.searchParams.set(k, v);
                });
                url.searchParams.set("page", "1");
                const currentPs = new URL(window.location.href).searchParams.get("pageSize");
                if (currentPs !== null && currentPs !== "") url.searchParams.set("pageSize", currentPs);
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp?.value?.trim() || "";
                const ct = toInp?.value?.trim() || "";
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                if (fromInp) fromInp.value = "";
                if (toInp) toInp.value = "";
                window.location.href = buildUrl("", "");
            });

            [filterPg, filterComp, filterImp].forEach(el => {
                el?.addEventListener("change", function () {
                    const form = document.getElementById("productsSearchForm");
                    if (form) {
                        const cf = fromInp?.value?.trim() || "";
                        const ct = toInp?.value?.trim() || "";
                        const url = new URL(form.action);
                        url.searchParams.set("search", form.querySelector('[name="search"]')?.value || "");
                        url.searchParams.set("searchBy", form.querySelector('[name="searchBy"]')?.value || "all");
                        url.searchParams.set("sort", form.querySelector('[name="sort"]')?.value || "name");
                        url.searchParams.set("dir", form.querySelector('[name="dir"]')?.value || "asc");
                        url.searchParams.set("page", "1");
                        var psVal = form.querySelector('[name="pageSize"]')?.value;
                        if (!psVal) psVal = new URL(window.location.href).searchParams.get("pageSize");
                        url.searchParams.set("pageSize", psVal || "50");
                        url.searchParams.set("useDateRange", form.querySelector('[name="useDateRange"]')?.value || "false");
                        const fd = form.querySelector('[name="fromDate"]')?.value;
                        const td = form.querySelector('[name="toDate"]')?.value;
                        if (fd) url.searchParams.set("fromDate", fd);
                        if (td) url.searchParams.set("toDate", td);
                        if (cf) url.searchParams.set("codeFrom", cf);
                        if (ct) url.searchParams.set("codeTo", ct);
                        if (filterPg?.value) url.searchParams.set("filterProductGroupId", filterPg.value);
                        if (filterComp?.value) url.searchParams.set("filterCompany", filterComp.value);
                        if (filterImp?.value) url.searchParams.set("filterImported", filterImp.value);
                        ["filterCol_productGroup","filterCol_bonusGroup","filterCol_company","filterCol_location","filterCol_imported","filterCol_isactive",
                         "filterCol_id","filterCol_name","filterCol_barcode","filterCol_generic","filterCol_category","filterCol_classification","filterCol_price",
                         "filterCol_created","filterCol_modified","filterCol_lastprice","filterCol_hasQuota","filterCol_quotaQuantity","filterCol_descShort",
                         "filterCol_idExpr","filterCol_priceExpr"].forEach(k => {
                            const v = new URL(window.location.href).searchParams.get(k);
                            if (v) url.searchParams.set(k, v);
                        });
                        window.location.href = url.toString();
                    }
                });
            });
        })();

        // =========================
        // فلتر الأعمدة بنمط Excel (قائمة منسدلة + بحث + اختيار عناصر)
        // =========================
        (function () {
            const panel = document.getElementById("erpColumnFilterPanel");
            const titleEl = document.getElementById("erpColumnFilterTitle");
            const searchInp = document.getElementById("erpColumnFilterSearch");
            const searchRowEl = document.getElementById("erpColumnFilterSearchRow");
            const listEl = document.getElementById("erpColumnFilterList");
            const btnOk = document.getElementById("erpColumnFilterOk");
            const btnClear = document.getElementById("erpColumnFilterClear");
            const btnClose = document.getElementById("erpColumnFilterClose");

            let currentCol = null;
            let currentSortKey = null;
            let currentSortDir = null;
            let allItems = [];
            let currentSelected = new Set();
            let filterListLoading = false;
            let anchorRect = null;
            const numericColumns = ["id", "price"];
            // تحويل مفتاح العمود إلى searchBy (بحث عام) لاستخدامه عند الكتابة في "بحث في العناصر"
            const columnToSearchBy = {
                name: "name", barcode: "code", generic: "gen", company: "comp", category: "category",
                productGroup: "productgroup", bonusGroup: "bonusgroup", price: "price",
                imported: "imported", isactive: "active", created: "updated", modified: "updated", lastprice: "updated",
                hasQuota: "all", quotaQuantity: "all", descShort: "all"
            };

            function getCurrentFilterValue(col) {
                if (numericColumns.includes(col)) {
                    var url = new URL(window.location.href);
                    return url.searchParams.get("filterCol_" + col + "Expr") || url.searchParams.get("filterCol_" + col) || "";
                }
                return new URL(window.location.href).searchParams.get("filterCol_" + col) || "";
            }

            function getCurrentSort() {
                const url = new URL(window.location.href);
                return {
                    sort: url.searchParams.get("sort") || "name",
                    dir: url.searchParams.get("dir") || "asc"
                };
            }

            function adjustPanelPosition() {
                if (!panel || !anchorRect) return;
                
                // انتظر قليلاً حتى يتم حساب الـ height الصحيح
                setTimeout(() => {
                    const panelRect = panel.getBoundingClientRect();
                    const actionsEl = panel.querySelector(".erp-column-filter-actions");
                    const actionsHeight = actionsEl ? actionsEl.offsetHeight + 20 : 80; // هامش إضافي

                    let top = anchorRect.bottom + 4;
                    let left = anchorRect.left;

                    const margin = 8;
                    const maxBottom = window.innerHeight - margin;
                    const maxRight = window.innerWidth - margin;

                    // التأكد من أن الأزرار ظاهرة دائماً
                    if (top + panelRect.height > maxBottom) {
                        top = Math.max(margin, maxBottom - panelRect.height);
                        // لو الـ panel كبير جداً، نحدد الـ max-height للقائمة
                        if (top + panelRect.height > maxBottom) {
                            const filterSection = panel.querySelector(".erp-filter-section");
                            if (filterSection) {
                                const availableHeight = maxBottom - top - actionsHeight - 100; // 100 للهيدر والمسافات
                                filterSection.style.maxHeight = Math.max(150, availableHeight) + "px";
                            }
                        }
                    }
                    if (left + panelRect.width > maxRight) {
                        left = Math.max(margin, maxRight - panelRect.width);
                    }

                    panel.style.top = top + "px";
                    panel.style.left = left + "px";
                }, 50);
            }

            function showPanel(btn) {
                currentCol = btn.dataset.col;
                currentSortKey = btn.dataset.sortKey || currentCol;
                const colTitle = btn.dataset.colTitle || currentCol;
                titleEl.textContent = "ترتيب وفلتر: " + colTitle;
                searchInp.value = "";
                currentSelected = new Set();
                anchorRect = btn.getBoundingClientRect();
                panel.style.minWidth = Math.max(250, anchorRect.width) + "px";
                panel.classList.remove("d-none");
                
                // تحديث حالة أزرار الترتيب
                const currentSort = getCurrentSort();
                const isCurrent = currentSort.sort.toLowerCase() === currentSortKey.toLowerCase();
                const currentDir = isCurrent ? currentSort.dir : "asc";
                
                document.querySelectorAll(".erp-sort-btn").forEach(sortBtn => {
                    const btnDir = sortBtn.dataset.sortDir;
                    if (isCurrent && btnDir === currentDir) {
                        sortBtn.classList.add("active");
                        sortBtn.classList.remove("btn-outline-secondary");
                        sortBtn.classList.add("btn-primary");
                    } else {
                        sortBtn.classList.remove("active");
                        sortBtn.classList.remove("btn-primary");
                        sortBtn.classList.add("btn-outline-secondary");
                    }
                });
                
                adjustPanelPosition();

                // للأعمدة الرقمية (كود الصنف، سعر الجمهور): إخفاء بوكس الفلترة وإظهار "بحث رقمي" فقط
                if (numericColumns.includes(currentCol)) {
                    if (searchRowEl) searchRowEl.style.display = "none";
                    const currentExpr = getCurrentFilterValue(currentCol);
                    listEl.innerHTML = `
                        <div class="mb-2">
                            <label class="form-label small mb-1">بحث رقمي:</label>
                            <input type="text" id="erpNumericExpr" class="form-control form-control-sm" 
                                   placeholder="اكتب الكود مباشرة أو استخدم: &lt;10, &gt;100, 10:100" 
                                   value="${(currentExpr || "").replace(/</g, "&lt;").replace(/>/g, "&gt;")}">
                            <small class="text-muted d-block mt-1">مثال: 53812 أو &lt;10 أو &gt;100 أو 10:100</small>
                        </div>`;
                    adjustPanelPosition();
                    setTimeout(() => {
                        const exprInput = document.getElementById("erpNumericExpr");
                        if (exprInput) {
                            exprInput.addEventListener("keydown", function(e) {
                                if (e.key === "Enter") {
                                    e.preventDefault();
                                    applyFilter();
                                }
                            });
                            exprInput.focus();
                        }
                    }, 100);
                    return;
                }

                // للأعمدة النصية: إظهار بوكس الفلترة وتحميل قائمة القيم
                if (searchRowEl) searchRowEl.style.display = "";
                listEl.innerHTML = '<div class="text-muted text-center py-3">جاري التحميل...</div>';
                currentSelected = new Set((getCurrentFilterValue(currentCol) || "").split("|").filter(Boolean));
                
                function fetchColumnValues(searchText) {
                    var url = "/Products/GetColumnValues?column=" + encodeURIComponent(currentCol);
                    if (searchText) url += "&search=" + encodeURIComponent(searchText);
                    fetch(url)
                        .then(r => r.json())
                        .then(items => {
                            allItems = items;
                            renderList("");
                        })
                        .catch(() => {
                            listEl.innerHTML = '<div class="text-danger text-center py-2">فشل التحميل</div>';
                        });
                }
                fetchColumnValues((searchInp && searchInp.value) ? searchInp.value.trim() : "");
            }

            function renderList(search) {
                const term = (search || "").toLowerCase();
                const filtered = term ? allItems.filter(x => (x.display || x.value || "").toLowerCase().includes(term)) : allItems;
                const allChecked = filtered.length > 0 && filtered.every(x => currentSelected.has(String(x.value)));
                const someChecked = filtered.some(x => currentSelected.has(String(x.value)));
                const showLoading = filterListLoading && filtered.length === 0 && term;

                listEl.innerHTML = `
                    <div class="form-check mb-1">
                        <input type="checkbox" class="form-check-input" id="erpFilterSelectAll" ${allChecked ? "checked" : ""}>
                        <label class="form-check-label small" for="erpFilterSelectAll">(تحديد الكل)</label>
                    </div>
                    <div class="erp-filter-items" style="max-height:200px;overflow-y:auto;">
                        ${showLoading ? '<div class="small text-muted py-2">جاري البحث...</div>' : filtered.map(x => {
                            const v = String(x.value);
                            const checked = currentSelected.has(v);
                            return `<div class="form-check">
                                <input type="checkbox" class="form-check-input erp-filter-item" value="${v.replace(/"/g, "&quot;")}" ${checked ? "checked" : ""} data-display="${(x.display || v).replace(/"/g, "&quot;")}">
                                <label class="form-check-label small">${(x.display || v).replace(/</g, "&lt;")}</label>
                            </div>`;
                        }).join("")}
                    </div>`;
                if (showLoading) {
                    adjustPanelPosition();
                    return;
                }
                const selectAllCb = listEl.querySelector("#erpFilterSelectAll");
                if (selectAllCb) {
                    selectAllCb.indeterminate = someChecked && !allChecked;
                    selectAllCb.addEventListener("change", function () {
                        filtered.forEach(x => {
                            if (this.checked) currentSelected.add(String(x.value));
                            else currentSelected.delete(String(x.value));
                        });
                        renderList(searchInp.value);
                    });
                }
                listEl.querySelectorAll(".erp-filter-item").forEach(cb => {
                    cb.addEventListener("change", function () {
                        if (this.checked) currentSelected.add(this.value);
                        else currentSelected.delete(this.value);
                        renderList(searchInp.value);
                    });
                });
                adjustPanelPosition();
            }

            function applyFilter(applySort = null, sortDir = null) {
                if (!currentCol) return;
                const url = new URL(window.location.href);
                // تحديث فلتر العمود الحالي فقط — إبقاء فلاتر الأعمدة الأخرى (AND)
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.delete("filterCol_" + currentCol + "_contains");
                url.searchParams.delete("filterCol_" + currentCol + "Expr");
                if (applySort !== null && sortDir !== null) {
                    url.searchParams.set("sort", applySort);
                    url.searchParams.set("dir", sortDir);
                } else if (currentSortKey) {
                    const currentSort = getCurrentSort();
                    url.searchParams.set("sort", currentSort.sort);
                    url.searchParams.set("dir", currentSort.dir);
                }
                
                if (numericColumns.includes(currentCol)) {
                    const exprInput = document.getElementById("erpNumericExpr");
                    const expr = exprInput ? String(exprInput.value || "").trim() : "";
                    if (expr) url.searchParams.set("filterCol_" + currentCol + "Expr", expr);
                } else {
                    // أولوية القيم المحددة (تشيك بوكسات): تطبيق فلتر عمود فقط — لا نستخدم بوكس البحث داخل اللوحة كـ search عام
                    const val = Array.from(currentSelected).filter(Boolean).join("|");
                    if (val) {
                        url.searchParams.set("filterCol_" + currentCol, val);
                        url.searchParams.delete("search");
                        url.searchParams.delete("searchBy");
                    } else {
                        const filterBoxText = (searchInp && searchInp.value) ? String(searchInp.value).trim() : "";
                        if (filterBoxText) {
                            url.searchParams.set("search", filterBoxText);
                            url.searchParams.set("searchBy", columnToSearchBy[currentCol] || "all");
                        }
                    }
                }
                
                url.searchParams.set("page", "1");
                
                // الانتقال المباشر بالرابط لضمان وصول كل المعاملات (بما فيها البحث الرقمي filterCol_*Expr)
                window.location.href = url.toString();
            }

            function clearFilter() {
                if (!currentCol) return;
                const url = new URL(window.location.href);
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.delete("filterCol_" + currentCol + "Expr");
                // إذا كان الفلتر مطبّقاً عبر "بحث في العناصر" (search + searchBy) نزيلهما أيضاً
                var searchByVal = url.searchParams.get("searchBy") || "";
                if (columnToSearchBy[currentCol] && searchByVal === columnToSearchBy[currentCol]) {
                    url.searchParams.delete("search");
                    url.searchParams.delete("searchBy");
                }
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }

            document.querySelectorAll(".erp-col-filter-btn").forEach(btn => {
                btn.addEventListener("click", function (e) {
                    e.stopPropagation();
                    showPanel(this);
                });
            });

            // معالجة أزرار الترتيب داخل الـ panel
            document.addEventListener("click", function(e) {
                if (e.target.closest(".erp-sort-btn")) {
                    const sortBtn = e.target.closest(".erp-sort-btn");
                    const sortDir = sortBtn.dataset.sortDir;
                    if (currentSortKey) {
                        applyFilter(currentSortKey, sortDir);
                    }
                }
            });

            var fetchListDebounce = null;
            searchInp?.addEventListener("input", function () {
                if (numericColumns.includes(currentCol)) return;
                var inp = this;
                var keepFocus = (document.activeElement === inp);
                var term = (inp.value || "");
                // تأخير التحديث حتى لا تُسرق الكتابة ولا يختفي الحرف
                setTimeout(function() {
                    renderList(term);
                    if (keepFocus && searchInp) searchInp.focus();
                }, 0);
                if (fetchListDebounce) clearTimeout(fetchListDebounce);
                fetchListDebounce = setTimeout(function() {
                    fetchListDebounce = null;
                    if (!currentCol) return;
                    var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                    filterListLoading = true;
                    renderList(searchInp ? searchInp.value : "");
                    var url = "/Products/GetColumnValues?column=" + encodeURIComponent(currentCol);
                    if (searchVal) url += "&search=" + encodeURIComponent(searchVal);
                    fetch(url).then(r => r.json()).then(function(items) {
                        filterListLoading = false;
                        allItems = items;
                        renderList(searchInp ? searchInp.value : "");
                        if (searchInp) searchInp.focus();
                    }).catch(function() {
                        filterListLoading = false;
                        renderList(searchInp ? searchInp.value : "");
                    });
                }, 400);
            });

            searchInp?.addEventListener("keydown", function(e) {
                if (e.key !== "Enter") return;
                e.preventDefault();
                applyFilter();
            });

            btnOk?.addEventListener("click", function(e) {
                e.preventDefault();
                e.stopPropagation();
                applyFilter();
            });
            btnClear?.addEventListener("click", clearFilter);
            btnClose?.addEventListener("click", () => panel.classList.add("d-none"));

            document.addEventListener("click", function (e) {
                if (panel && !panel.classList.contains("d-none") && !panel.contains(e.target) && !e.target.closest(".erp-col-filter-btn"))
                    panel.classList.add("d-none");
            });

            // بعد التحميل: إذا كان الرابط فيه openFilter و search نفتح اللوحة ونظهر بوكس البحث ولا نخفيه
            (function checkOpenFilter() {
                var url = new URL(window.location.href);
                var openFilterCol = url.searchParams.get("openFilter");
                var searchVal = url.searchParams.get("search") || "";
                if (!openFilterCol || numericColumns.indexOf(openFilterCol) >= 0) return;
                window.scrollTo(0, 0);
                var btn = document.querySelector('.erp-col-filter-btn[data-col="' + openFilterCol + '"]');
                if (btn) {
                    setTimeout(function() {
                        showPanel(btn);
                        if (searchInp) searchInp.value = searchVal;
                        url.searchParams.delete("openFilter");
                        var newUrl = url.pathname + (url.searchParams.toString() ? "?" + url.searchParams.toString() : "");
                        window.history.replaceState({}, "", newUrl);
                    }, 100);
                }
            })();
        })();

        // =========================
        // توسيع/تصغير عرض الأعمدة (نفس نظام المحافظات/مجموعات الأصناف)
        // =========================
        document.addEventListener("DOMContentLoaded", function () {
            var wrapper = document.querySelector(".erp-table-wrapper");
            if (!wrapper) return;
            var table = wrapper.querySelector("table.erp-table");
            if (!table) return;
            var ths = table.querySelectorAll("thead th");
            ths.forEach(function (th) {
                th.style.position = "relative";
                var handle = document.createElement("div");
                handle.className = "erp-col-resize-handle";
                th.appendChild(handle);
                var startX, startWidth;
                handle.addEventListener("mousedown", function (e) {
                    e.preventDefault();
                    startX = e.pageX;
                    startWidth = th.offsetWidth;
                    function onMouseMove(eMove) {
                        var diffX = eMove.pageX - startX;
                        var newWidth = startWidth + diffX;
                        if (newWidth < 50) newWidth = 50;
                        th.style.width = newWidth + "px";
                        th.style.minWidth = newWidth + "px";
                    }
                    function onMouseUp() {
                        document.removeEventListener("mousemove", onMouseMove);
                        document.removeEventListener("mouseup", onMouseUp);
                    }
                    document.addEventListener("mousemove", onMouseMove);
                    document.addEventListener("mouseup", onMouseUp);
                });
            });
        });
    </script>
}

