@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<Product>

@{
    ViewData["Title"] = "قائمة الأصناف";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "Products";

    // القيم القادمة من الموديل / ViewBag (نفس نمط المحافظات / العملاء)
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "name";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلترة بالتاريخ/الوقت (تاريخ إنشاء الصنف) من PagedResult
    bool useDateRange = Model.UseDateRange;
    var fromDate = Model.FromDate;
    var toDate = Model.ToDate;

    // فلاتر متراكبة (مع fallback من الـ Request لو فشل ViewBag)
    int? filterProductGroupId = ViewBag.FilterProductGroupId as int?;
    if (!filterProductGroupId.HasValue && int.TryParse(Context.Request.Query["filterProductGroupId"].ToString(), out var qPg))
        filterProductGroupId = qPg;
    string? filterCompany = ViewBag.FilterCompany as string;
    string? filterImported = ViewBag.FilterImported as string;
    int? codeFrom = ViewBag.CodeFrom as int?;
    int? codeTo = ViewBag.CodeTo as int?;

    // فلاتر أعمدة Excel
    string? filterCol_productGroup = ViewBag.FilterCol_ProductGroup as string;
    string? filterCol_bonusGroup = ViewBag.FilterCol_BonusGroup as string;
    string? filterCol_company = ViewBag.FilterCol_Company as string;
    string? filterCol_imported = ViewBag.FilterCol_Imported as string;
    string? filterCol_isactive = ViewBag.FilterCol_IsActive as string;
    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_name = ViewBag.FilterCol_Name as string;
    string? filterCol_barcode = ViewBag.FilterCol_Barcode as string;
    string? filterCol_generic = ViewBag.FilterCol_Generic as string;
    string? filterCol_category = ViewBag.FilterCol_Category as string;
    string? filterCol_price = ViewBag.FilterCol_Price as string;
    string? filterCol_created = ViewBag.FilterCol_Created as string;
    string? filterCol_modified = ViewBag.FilterCol_Modified as string;
    string? filterCol_lastprice = ViewBag.FilterCol_LastPrice as string;
    string? filterCol_hasQuota = ViewBag.FilterCol_HasQuota as string;
    string? filterCol_quotaQuantity = ViewBag.FilterCol_QuotaQuantity as string;
    string? filterCol_descShort = ViewBag.FilterCol_DescShort as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_priceExpr = ViewBag.FilterCol_PriceExpr as string;

    // دالة توليد لينك مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        filterProductGroupId,
        filterCompany,
        filterImported,
        filterCol_productGroup,
        filterCol_bonusGroup,
        filterCol_company,
        filterCol_imported,
        filterCol_isactive,
        filterCol_id,
        filterCol_name,
        filterCol_barcode,
        filterCol_generic,
        filterCol_category,
        filterCol_price,
        filterCol_created,
        filterCol_modified,
        filterCol_lastprice,
        filterCol_hasQuota,
        filterCol_quotaQuantity,
        filterCol_descShort,
        filterCol_idExpr,
        filterCol_priceExpr,
        codeFrom,
        codeTo
    })!;

    // دالة إنشاء لينك الترتيب مع السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate,
            filterProductGroupId,
            filterCompany,
            filterImported,
            filterCol_productGroup,
            filterCol_bonusGroup,
            filterCol_company,
            filterCol_imported,
            filterCol_isactive,
            filterCol_id,
            filterCol_name,
            filterCol_barcode,
            filterCol_generic,
            filterCol_category,
            filterCol_price,
            filterCol_created,
            filterCol_modified,
            filterCol_lastprice,
            filterCol_hasQuota,
            filterCol_quotaQuantity,
            filterCol_descShort,
            filterCol_idExpr,
            filterCol_priceExpr,
            codeFrom,
            codeTo
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString(
            $@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>"
        );
    };

    // دالة عمود قابل للفلترة (بنمط Excel)
    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        var currentFilter = colKey == "productGroup" ? filterCol_productGroup :
                            colKey == "bonusGroup" ? filterCol_bonusGroup :
                            colKey == "company" ? filterCol_company :
                            colKey == "imported" ? filterCol_imported :
                            colKey == "isactive" ? filterCol_isactive :
                            colKey == "id" ? (filterCol_id ?? filterCol_idExpr) :
                            colKey == "name" ? filterCol_name :
                            colKey == "barcode" ? filterCol_barcode :
                            colKey == "generic" ? filterCol_generic :
                            colKey == "category" ? filterCol_category :
                            colKey == "price" ? (filterCol_price ?? filterCol_priceExpr) :
                            colKey == "created" ? filterCol_created :
                            colKey == "modified" ? filterCol_modified :
                            colKey == "lastprice" ? filterCol_lastprice :
                            colKey == "hasQuota" ? filterCol_hasQuota :
                            colKey == "quotaQuantity" ? filterCol_quotaQuantity :
                            colKey == "descShort" ? filterCol_descShort : null;

        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var btnStateClass = hasFilter ? "text-primary" : "text-muted";

        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-sort"">{sortLink(sortKey, caption)}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-col-title=""{caption}"" title=""فلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""14"" height=""14"" viewBox=""0 0 24 24"" fill=""currentColor""><path d=""M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z""/></svg>
                </button>
            </div>");
    };
}
<div dir="rtl" class="container-fluid">

    @* ===== شريط الفلاتر الموحد (مثل العملاء) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في الأصناف</label>
                    <div class="d-flex flex-wrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:150px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>البحث في الكل</option>
                            <option value="name"@Html.Raw(searchBy == "name" ? " selected" : "")>اسم الصنف</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>كود الصنف</option>
                            <option value="code"@Html.Raw(searchBy == "code" ? " selected" : "")>الباركود</option>
                            <option value="gen"@Html.Raw(searchBy == "gen" ? " selected" : "")>الاسم العلمي</option>
                            <option value="comp"@Html.Raw(searchBy == "comp" ? " selected" : "")>الشركة</option>
                            <option value="category"@Html.Raw(searchBy == "category" ? " selected" : "")>الفئة</option>
                            <option value="productgroup"@Html.Raw(searchBy == "productgroup" ? " selected" : "")>مجموعة الصنف</option>
                            <option value="bonusgroup"@Html.Raw(searchBy == "bonusgroup" ? " selected" : "")>مجموعة البونص</option>
                            <option value="price"@Html.Raw(searchBy == "price" ? " selected" : "")>سعر الجمهور</option>
                            <option value="imported"@Html.Raw(searchBy == "imported" ? " selected" : "")>محلي/مستورد</option>
                            <option value="active"@Html.Raw(searchBy == "active" ? " selected" : "")>نشط/موقوف</option>
                            <option value="updated"@Html.Raw(searchBy == "updated" ? " selected" : "")>آخر تعديل</option>
                        </select>
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">بحث</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (filterProductGroupId.HasValue) { <input type="hidden" name="filterProductGroupId" value="@filterProductGroupId.Value" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCompany)) { <input type="hidden" name="filterCompany" value="@filterCompany" /> }
                    @if (!string.IsNullOrWhiteSpace(filterImported)) { <input type="hidden" name="filterImported" value="@filterImported" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_productGroup)) { <input type="hidden" name="filterCol_productGroup" value="@filterCol_productGroup" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_bonusGroup)) { <input type="hidden" name="filterCol_bonusGroup" value="@filterCol_bonusGroup" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_company)) { <input type="hidden" name="filterCol_company" value="@filterCol_company" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_imported)) { <input type="hidden" name="filterCol_imported" value="@filterCol_imported" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_isactive)) { <input type="hidden" name="filterCol_isactive" value="@filterCol_isactive" /> }
                    @if (codeFrom.HasValue) { <input type="hidden" name="codeFrom" value="@codeFrom" /> }
                    @if (codeTo.HasValue) { <input type="hidden" name="codeTo" value="@codeTo" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر الكود + فلاتر إضافية --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر الكود</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(codeFrom?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(codeTo?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
                <div class="d-flex flex-wrap gap-2 mt-2 justify-content-center w-100 align-items-end">
                    <div class="d-flex flex-column">
                        <label class="form-label small mb-0 text-center">مجموعات الاصناف</label>
                        <select name="filterProductGroupId" id="filterProductGroupId" class="form-select erp-filter-input" style="max-width:140px" form="productsSearchForm">
                            <option value=""@Html.Raw(!filterProductGroupId.HasValue ? " selected" : "")>الكل</option>
                            @if (ViewBag.ProductGroups != null)
                            {
                                @foreach (var pg in (SelectList)ViewBag.ProductGroups)
                                {
                                    var isSelected = filterProductGroupId.HasValue && pg.Value == filterProductGroupId.Value.ToString();
                                    <option value="@pg.Value"@Html.Raw(isSelected ? " selected" : "")>@pg.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="d-flex flex-column">
                        <label class="form-label small mb-0 text-center">الشركة</label>
                        <input type="text" name="filterCompany" id="filterCompany" class="form-control erp-filter-input" list="companiesList" placeholder="الكل" value="@filterCompany" style="max-width:120px" form="productsSearchForm" />
                        <datalist id="companiesList">
                            @if (ViewBag.Companies != null)
                            {
                                @foreach (var comp in (List<string>)ViewBag.Companies)
                                {
                                    <option value="@comp">@comp</option>
                                }
                            }
                        </datalist>
                    </div>
                    <div class="d-flex flex-column">
                        <label class="form-label small mb-0 text-center">محلى او مستورد</label>
                        <select name="filterImported" id="filterImported" class="form-select erp-filter-input" style="max-width:110px" form="productsSearchForm">
                            <option value="">الكل</option>
                            <option value="محلي"@Html.Raw(filterImported == "محلي" ? " selected" : "")>محلي</option>
                            <option value="مستورد"@Html.Raw(filterImported == "مستورد" ? " selected" : "")>مستورد</option>
                        </select>
                    </div>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <a class="btn btn-erp btn-erp-success btn-erp-sm" asp-action="Create">إضافة صنف</a>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalProducts">اختيار الأعمدة</button>
                        <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteSelected">حذف المحدد</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف الجميع</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="Products" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (filterProductGroupId.HasValue) { <input type="hidden" name="filterProductGroupId" value="@filterProductGroupId.Value" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCompany)) { <input type="hidden" name="filterCompany" value="@filterCompany" /> }
                            @if (!string.IsNullOrWhiteSpace(filterImported)) { <input type="hidden" name="filterImported" value="@filterImported" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_productGroup)) { <input type="hidden" name="filterCol_productGroup" value="@filterCol_productGroup" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_bonusGroup)) { <input type="hidden" name="filterCol_bonusGroup" value="@filterCol_bonusGroup" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_company)) { <input type="hidden" name="filterCol_company" value="@filterCol_company" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_imported)) { <input type="hidden" name="filterCol_imported" value="@filterCol_imported" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_isactive)) { <input type="hidden" name="filterCol_isactive" value="@filterCol_isactive" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_barcode)) { <input type="hidden" name="filterCol_barcode" value="@filterCol_barcode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_generic)) { <input type="hidden" name="filterCol_generic" value="@filterCol_generic" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_category)) { <input type="hidden" name="filterCol_category" value="@filterCol_category" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_price)) { <input type="hidden" name="filterCol_price" value="@filterCol_price" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_modified)) { <input type="hidden" name="filterCol_modified" value="@filterCol_modified" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_lastprice)) { <input type="hidden" name="filterCol_lastprice" value="@filterCol_lastprice" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_hasQuota)) { <input type="hidden" name="filterCol_hasQuota" value="@filterCol_hasQuota" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_quotaQuantity)) { <input type="hidden" name="filterCol_quotaQuantity" value="@filterCol_quotaQuantity" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_descShort)) { <input type="hidden" name="filterCol_descShort" value="@filterCol_descShort" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_priceExpr)) { <input type="hidden" name="filterCol_priceExpr" value="@filterCol_priceExpr" /> }
                            @if (codeFrom.HasValue) { <input type="hidden" name="codeFrom" value="@codeFrom" /> }
                            @if (codeTo.HasValue) { <input type="hidden" name="codeTo" value="@codeTo" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:70px;min-width:70px;font-size:0.8rem;padding:0.25rem 0.4rem;">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                    <form id="bulkDeleteForm" asp-action="BulkDelete" asp-controller="Products" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="selectedIds" id="selectedIdsInput" />
                    </form>
                    <form id="deleteAllForm" asp-action="DeleteAll" asp-controller="Products" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>

        </div>
    </div>

    @* فورم للفلاتر الإضافية (ProductGroup, Company, Imported) - يُستخدم عند تغيير الفلاتر *@
