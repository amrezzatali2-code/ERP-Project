    <script>
        (function () {
            var params = new URLSearchParams(window.location.search);
            var ps = params.get('pageSize');
            var sel = document.querySelector('form select[name="pageSize"]');
            if (sel && ps !== null && ps !== '') sel.value = ps;
        })();
    </script>

    @* ===== الترقيم ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
