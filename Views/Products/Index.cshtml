@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<Product>

@{
    ViewData["Title"] = "قائمة الأصناف";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "Products";

    // القيم القادمة من الموديل / ViewBag (نفس نمط المحافظات / العملاء)
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "name";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلترة بالتاريخ/الوقت (تاريخ إنشاء الصنف) من PagedResult
    bool useDateRange = Model.UseDateRange;
    var fromDate = Model.FromDate;
    var toDate = Model.ToDate;

    // دالة توليد لينك مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate
    })!;

    // دالة إنشاء لينك الترتيب مع السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange,
            fromDate,
            toDate
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString(
            $@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>"
        );
    };
}

<div dir="rtl" class="container-fluid">

    @* عنوان الصفحة + إجمالي الأصناف *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">@ViewData["Title"]</h4>

        <small class="text-muted d-none d-md-inline">
            إجمالي الأصناف: @total
        </small>
    </div>

    @* ===== الكارت العلوي: بحث + أزرار التحكم (نفس ستايل المحافظات) ===== *@
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* العمود الأول: البحث *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث</label>
                        </div>

                        <div class="col-sm-5">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-5">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                <option value="all" selected="@(searchBy == "all" ? "selected" : null)">
                                    الكل
                                </option>
                                <option value="name" selected="@(searchBy == "name" ? "selected" : null)">
                                    اسم الصنف
                                </option>
                                <option value="id" selected="@(searchBy == "id" ? "selected" : null)">
                                    كود الصنف
                                </option>
                                <option value="barcode" selected="@(searchBy == "barcode" ? "selected" : null)">
                                    الباركود
                                </option>
                                <option value="generic" selected="@(searchBy == "generic" ? "selected" : null)">
                                    الاسم العلمي
                                </option>
                                <option value="company" selected="@(searchBy == "company" ? "selected" : null)">
                                    الشركة
                                </option>
                                <option value="category" selected="@(searchBy == "category" ? "selected" : null)">
                                    الفئة
                                </option>
                                <option value="active" selected="@(searchBy == "active" ? "selected" : null)">
                                    الحالة
                                </option>
                            </select>
                        </div>

                        @* الحفاظ على باقي الفلاتر *@
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                        @if (fromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                        }
                        @if (toDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm px-3">
                                بحث
                            </button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm"
                               href="@Url.Action(action, controller)">
                                إلغاء
                            </a>
                        </div>
                    </form>
                </div>

                @* العمود الثاني: (ممكن نستخدمه لاحقاً لفلاتر إضافية إن حبيت) *@
                <!-- العمود الثاني: فلتر كود من/إلى (مثل المحافظات) -->
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">

                        <span class="fw-semibold">من كود</span>
                        <input id="codeFromInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(ViewBag.CodeFrom?.ToString() ?? "")" />   @* كود البداية *@

                        <span class="fw-semibold">إلى كود</span>
                        <input id="codeToInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(ViewBag.CodeTo?.ToString() ?? "")" />     @* كود النهاية *@

                        <button type="button"
                                id="btnApplyCodeFilter"
                                class="btn btn-erp btn-erp-primary btn-erp-sm">
                            تطبيق فلتر الكود
                        </button>

                        <button type="button"
                                id="btnClearCodeFilter"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            مسح
                        </button>
                    </div>
                </div>


                @* العمود الثالث: أزرار الإضافة / الفلاتر / الحذف / الطباعة / التصدير *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        @* إضافة صنف جديد *@
                        <a class="btn btn-erp btn-erp-success"
                           asp-action="Create">
                            + إضافة صنف جديد
                        </a>

                        @* فلترة بالتاريخ/الوقت *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#dateFilterModal">
                            فلترة بالتاريخ/الوقت
                        </button>

                        @* اختيار الأعمدة *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalProducts">
                            اختيار الأعمدة
                        </button>

                        @* حذف المحدد *@
                        <form id="bulkDeleteForm"
                              asp-action="BulkDelete"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="selectedIds" id="selectedIdsInput" />
                            <button type="button"
                                    id="btnDeleteSelected"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف المحدد
                            </button>
                        </form>

                        @* حذف جميع الأصناف *@
                        <form id="deleteAllForm"
                              asp-action="DeleteAll"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="button"
                                    id="btnDeleteAll"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف جميع الأصناف
                            </button>
                        </form>

                        @* طباعة (الجدول فقط) *@
                        <button type="button"
                                id="btnPrint"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        @* تصدير *@
                        <form method="get"
                              asp-action="Export"
                              asp-controller="Products"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
                            }
                            @if (toDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
                            }

                            <select name="format"
                                    class="form-select form-select-sm"
                                    style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm">
                                تصدير
                            </button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

    @* ===== جدول الأصناف (هو الذى يتطبع) ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="productsTable" class="table table-striped table-hover erp-table erp-table-sortable erp-products-table">
            <thead class="table-light">
                <tr>
                    @* اختيار الصف *@
                    <th class="text-center no-print"
                        style="width:40px;"
                        data-col="select"
                        data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    <th style="width:110px;" data-col="id">@sortLink("id", "كود الصنف")</th>
                    <th data-col="col-name">@sortLink("name", "اسم الصنف")</th>
                    <th data-col="barcode">@sortLink("code", "الباركود")</th>
                    <th data-col="generic">@sortLink("gen", "الاسم العلمي")</th>
                    <th data-col="category">@sortLink("category", "الفئة")</th>

                    @* 🔹 مجموعة الصنف + مجموعة البونص *@
                    <th data-col="productGroup">مجموعة الصنف</th>
                    <th data-col="bonusGroup">مجموعة البونص</th>

                    <th data-col="company">@sortLink("comp", "الشركة")</th>
                    <th class="text-end" data-col="price">@sortLink("price", "سعر الجمهور")</th>
                    <th data-col="imported">@sortLink("imported", "محلي/مستورد")</th>
                    <th data-col="isactive">@sortLink("isactive", "الحالة")</th>
                    <th style="width:150px;" data-col="created">@sortLink("created", "تاريخ الإنشاء")</th>
                    <th style="width:150px;" data-col="modified">@sortLink("modified", "آخر تعديل")</th>
                    <th style="width:150px;" data-col="lastprice">@sortLink("updated", "آخر تغيير سعر")</th>

                    @* 🔹 أعمدة الكوتة *@
                    <th data-col="hasQuota">له كوتة؟</th>
                    <th data-col="quotaQuantity">كمية الكوتة</th>

                    <th data-col="descShort">الوصف المختصر</th>

                    <th class="text-nowrap no-print"
                        style="width:220px;"
                        data-col="actions"
                        data-col-fixed="true">
                    </th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        @* عدد الأعمدة = 19 *@
                        <td colspan="19" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var p in Model.Items)
                    {
                        var desc = p.Description ?? "";                                  // متغير: الوصف الكامل
                        var descShort = desc.Length > 120 ? desc.Substring(0, 120) + "…" : desc; // متغير: وصف مختصر
                        var groupName = p.ProductGroup?.Name ?? "";                      // متغير: اسم مجموعة الصنف
                        var bonusName = p.ProductBonusGroup?.Name ?? "";                 // متغير: اسم مجموعة البونص

                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@p.ProdId" />
                            </td>

                            <td data-col="id">@p.ProdId</td>
                            <td data-col="col-name">@p.ProdName</td>
                            <td data-col="barcode">@p.Barcode</td>
                            <td data-col="generic">@p.GenericName</td>
                            <td data-col="category">@p.CategoryId</td>

                            @* 🔹 مجموعة الصنف + مجموعة البونص *@
                            <td data-col="productGroup">@groupName</td>
                            <td data-col="bonusGroup">@bonusName</td>

                            <td data-col="company">@p.Company</td>
                            <td data-col="price" class="text-end">@p.PriceRetail.ToString("N2")</td>
                            <td data-col="imported">@p.Imported</td>
                            <td data-col="isactive">@((p.IsActive) ? "نشط" : "موقوف")</td>
                            <td data-col="created">@p.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                            <td data-col="modified">@p.UpdatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                            <td data-col="lastprice">
                                @(p.LastPriceChangeDate.HasValue
                                                        ? p.LastPriceChangeDate.Value.ToString("yyyy/MM/dd")
                                                        : "")
                            </td>

                            @* 🔹 بيانات الكوتة *@
                            <td data-col="hasQuota">
                                @(p.HasQuota ? "نعم" : "لا")
                            </td>
                            <td data-col="quotaQuantity">
                                @(p.HasQuota && p.QuotaQuantity.HasValue
                                                        ? p.QuotaQuantity.Value.ToString()
                                                        : "-")
                            </td>

                            <td data-col="descShort" title="@desc">@descShort</td>

                            <td class="text-nowrap no-print" data-col="actions">
                                @* زر حركة الصنف يفتح شاشة Show فى تاب مستقل *@
                                <a class="btn btn-erp btn-erp-secondary btn-erp-sm app-menu-link"
                                   asp-action="Show"
                                   asp-route-id="@p.ProdId" @* كود الصنف *@
                                   data-tab-id="product-movement" @* نفس المعرف المستخدم فى اللينك العام *@
                                   data-tab-title="حركة صنف - @p.ProductName">
                                    @* عنوان التاب *@
                                    حركة الصنف
                                </a>
                                <a class="btn btn-erp btn-erp-primary btn-erp-sm"
                                   asp-action="Edit"
                                   asp-route-id="@p.ProdId">
                                    تعديل
                                </a>
                                <a class="btn btn-erp btn-erp-danger btn-erp-sm"
                                   asp-action="Delete"
                                   asp-route-id="@p.ProdId">
                                    حذف
                                </a>
                            </td>
                        </tr>
                    }

                    @* صف إجمالي عدد الأصناف (حسب الفلتر الحالي) *@
                    <tr class="table-secondary fw-bold">
                        <td colspan="18" class="text-end">
                            عدد الأصناف (حسب الفلتر الحالي):
                        </td>
                        <td class="text-end">
                            @total
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              asp-action="@action"
              asp-controller="@controller"
              class="d-flex align-items-center gap-2">

            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" />
            }
            @if (toDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25" selected="@(ps == 25 ? "selected" : null)">25</option>
                <option value="50" selected="@(ps == 50 ? "selected" : null)">50</option>
                <option value="100" selected="@(ps == 100 ? "selected" : null)">100</option>
                <option value="200" selected="@(ps == 200 ? "selected" : null)">200</option>
            </select>
        </form>
    </div>

    @* ===== الترقيم ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>

            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>

            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة بالتاريخ/الوقت ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ إنشاء الصنف)
                </h5>

                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />

                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة (ديناميكي بنفس فكرة المحافظات) ===== *@
@* نافذة اختيار الأعمدة الخاصة بجدول الأصناف *@
<div class="modal fade no-print"
     id="columnsModalProducts"
     tabindex="-1"
     aria-labelledby="columnsModalProductsLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        @* modal-lg علشان فيه أعمدة كثيرة *@
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalProductsLabel">
                    اختيار الأعمدة الظاهرة في قائمة الأصناف
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <div class="modal-body">
                @* وصف بسيط للمستخدم *@
                <div class="small text-muted mb-2">
                    ضع علامة ✓ أمام الأعمدة التي تريد ظهورها في الجدول.
                </div>

                @* هنا الجافاسكريبت بيولّد قائمة الأعمدة من th[data-col] في جدول productsTable *@
                <div id="columnsListProducts"></div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>

                <button type="button"
                        id="btnApplyColumnsProducts"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط
        // =========================
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table  = document.getElementById("productsTable");
            if (!table) return;

            const chkAll = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            // تحديد/إلغاء تحديد كل الصفوف
            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            // لو شيلنا التحديد من صف واحد نشيل التحديد من "الكل"
            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected");
            const bulkForm          = document.getElementById("bulkDeleteForm");
            const selectedInput     = document.getElementById("selectedIdsInput");

            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل صنف واحد للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف الأصناف المحددة؟")) return;

                selectedInput.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("deleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع الأصناف. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("productsTable");
            if (!table) return;

            const storageKey = "products-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListProducts");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsProducts")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalProducts");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();
    </script>
}
