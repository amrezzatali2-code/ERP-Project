        @if (!string.IsNullOrWhiteSpace(filterCol_company)) { <input type="hidden" name="filterCol_company" value="@filterCol_company" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_imported)) { <input type="hidden" name="filterCol_imported" value="@filterCol_imported" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_isactive)) { <input type="hidden" name="filterCol_isactive" value="@filterCol_isactive" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_barcode)) { <input type="hidden" name="filterCol_barcode" value="@filterCol_barcode" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_generic)) { <input type="hidden" name="filterCol_generic" value="@filterCol_generic" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_category)) { <input type="hidden" name="filterCol_category" value="@filterCol_category" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_price)) { <input type="hidden" name="filterCol_price" value="@filterCol_price" /> }
        @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
