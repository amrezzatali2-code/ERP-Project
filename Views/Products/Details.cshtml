@model ERP.Models.Product
@{
    ViewData["Title"] = "تفاصيل الصنف";
}
<div class="container" dir="rtl">
    <h3 class="mb-3">@ViewData["Title"]</h3>

    <dl class="row">
        <dt class="col-sm-3">المعرّف</dt>
        <dd class="col-sm-9">@Model.ProdId</dd>
        <dt class="col-sm-3">كود الإكسل</dt>
        <dd class="col-sm-9">@Model.ExternalCode</dd>
        <dt class="col-sm-3">الاسم</dt>
        <dd class="col-sm-9">@Model.ProdName</dd>
        <dt class="col-sm-3">الباركود</dt>
        <dd class="col-sm-9">@Model.Barcode</dd>
        <dt class="col-sm-3">العلمي</dt>
        <dd class="col-sm-9">@Model.GenericName</dd>
        <dt class="col-sm-3">التركيز</dt>
        <dd class="col-sm-9">@Model.Strength</dd>
        <dt class="col-sm-3">الفئة</dt>
        <dd class="col-sm-9">@Model.CategoryId</dd>
        <dt class="col-sm-3">سعر الجمهور</dt>
        <dd class="col-sm-9">@Model.PriceRetail.ToString("N2")</dd>
        <dt class="col-sm-3">الشركة</dt>
        <dd class="col-sm-9">@Model.Company</dd>
        <dt class="col-sm-3">الموقع</dt>
        <dd class="col-sm-9">@Model.Location</dd>
        <dt class="col-sm-3">المخزن</dt>
        <dd class="col-sm-9">@(Model.Warehouse?.WarehouseName)</dd>
        <dt class="col-sm-3">مستورد</dt>
        <dd class="col-sm-9">@Model.Imported</dd>
        <dt class="col-sm-3">نشِط (نص)</dt>
        
        <dt class="col-sm-3">فعال</dt>
        <dd class="col-sm-9">@(Model.IsActive ? "نعم" : "لا")</dd>
        <dt class="col-sm-3">آخر تغيير سعر</dt>
        <dd class="col-sm-9">@Model.LastPriceChangeDate?.ToString("yyyy-MM-dd")</dd>
        <dt class="col-sm-3">الوصف</dt>
        <dd class="col-sm-9">@Model.Description</dd>
        <dt class="col-sm-3">الشكل الدوائي</dt>
        <dd class="col-sm-9">@Model.DosageForm</dd>
    </dl>

    <div class="mt-3">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.ProdId">تعديل</a>
        <a class="btn btn-secondary" asp-action="Index">رجوع للقائمة</a>
    </div>
</div>
