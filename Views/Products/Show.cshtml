@model ERP.Models.Product?

@using Microsoft.AspNetCore.Mvc.Rendering
@using System.Text.Json

@{
    ViewData["Title"] = "حركة صنف";

    // اسم الصنف المختار
    string selectedProdName = ViewBag.SelectedProdName as string ?? "";

    // الطرف (عميل/مورد)
    string selectedCustomerName = ViewBag.SelectedCustomerName as string ?? "";
    string partyKind = ViewBag.PartyKind as string ?? "all";

    // المخازن
    var warehousesList = ViewBag.Warehouses as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();

    // قيم البحث الحالية
    int? selectedProdId = ViewBag.SelectedProdId as int?;
    int? selectedWarehouseId = ViewBag.SelectedWarehouseId as int?;
    int? selectedCustomerId = ViewBag.SelectedCustomerId as int?;
    bool filterByCustomer = ViewBag.FilterByCustomer as bool? ?? false;

    DateTime? from = ViewBag.From as DateTime?;
    DateTime? to = ViewBag.To as DateTime?;

    // أرقام الملخص (نستخدم dynamic من ViewBag عشان ما يحصلش كاستنج غلط)
    var priceRetail = ViewBag.PriceRetail ?? 0m;                  // سعر الجمهور
    var weightedDiscount = ViewBag.WeightedDiscount ?? 0m;        // الخصم المرجح

    var totalQtyPurchased = ViewBag.TotalQtyPurchased ?? 0;                      // كمية المشتريات
    var totalAmountPurchased = ViewBag.TotalAmountPurchased ?? 0m;              // مبلغ المشتريات
    var totalQtyPurchaseReturned = ViewBag.TotalQtyPurchaseReturned ?? 0;       // كمية مرتجعات المشتريات
    var totalAmountPurchaseReturned = ViewBag.TotalAmountPurchaseReturned ?? 0m;// مبلغ مرتجعات المشتريات

    var totalQtySold = ViewBag.TotalQtySold ?? 0;                 // كمية المبيعات
    var totalAmountSold = ViewBag.TotalAmountSold ?? 0m;          // مبلغ المبيعات
    var totalQtyReturned = ViewBag.TotalQtyReturned ?? 0;         // كمية مردودات المبيعات
    var totalAmountReturned = ViewBag.TotalAmountReturned ?? 0m;  // مبلغ مردودات المبيعات

    var totalQtyAll = ViewBag.TotalQtyAll ?? 0;                   // إجمالى الكمية
    var netQty = ViewBag.NetQty ?? 0;                             // صافى الكمية
    var netAmount = ViewBag.NetAmount ?? 0m;                      // صافى المبلغ

    // تفاصيل الحركة والملخصات
    var lines = ViewBag.Lines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();                         // حركة مجمعة
    var salesLines = ViewBag.SalesLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();               // فواتير المبيعات
    var salesReturnLines = ViewBag.SalesReturnLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();   // مرتجعات المبيعات
    var purchaseLines = ViewBag.PurchaseLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();         // فواتير المشتريات
    var purchaseReturnLines = ViewBag.PurchaseReturnLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>(); // مرتجعات المشتريات

    var adjustmentLines = ViewBag.AdjustmentLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();     // تسويات جردية
    var purchaseRequestLines = ViewBag.PurchaseRequestLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>(); // طلبات الشراء
    var transferLines = ViewBag.TransferLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();         // تحويلات بين المخازن

    var yearlySummary = ViewBag.YearlySummary as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();         // ملخص سنوات
    var warehouseSummary = ViewBag.WarehouseSummary as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();   // ملخص مخازن
}

<style>
    /* تحسينات التصميم لشاشة بدون سكرول - نفس نمط حجم التعامل */
    .product-dashboard {
        max-height: calc(100vh - 120px);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    
    .dashboard-header {
        flex-shrink: 0;
        padding: 0.5rem 0;
    }
    
    .dashboard-content {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
    }
    
    .compact-card {
        padding: 0.75rem;
        margin-bottom: 0.5rem;
    }
    
    .compact-stat {
        font-size: 1.1rem;
        font-weight: 600;
        line-height: 1.2;
    }
    
    .compact-label {
        font-size: 0.75rem;
        margin-bottom: 0.25rem;
    }
    
    .product-info-compact {
        font-size: 0.85rem;
    }
    
    .table-compact {
        font-size: 0.85rem;
    }
    
    .table-compact th,
    .table-compact td {
        padding: 0.35rem 0.5rem;
    }
    
    .nav-tabs-compact {
        font-size: 0.8rem;
        padding: 0.25rem 0.5rem;
    }
    
    /* ✅ إصلاح عرض التبويبات مع Flexbox */
    #productMovementTabsContent.tab-content {
        position: relative;
        min-height: 0;
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    
    #productMovementTabsContent .tab-pane {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        min-height: 0;
        display: none !important;
    }
    
    /* ✅ Bootstrap tabs يعيد display: block للـ .tab-pane.active، لذا نستخدم !important */
    #productMovementTabsContent .tab-pane:not(.active):not(.show) {
        display: none !important;
        visibility: hidden;
    }
    
    #productMovementTabsContent .tab-pane.active,
    #productMovementTabsContent .tab-pane.active.show {
        display: flex !important;
        flex-direction: column;
        visibility: visible;
        position: relative;
    }
    
    /* ✅ تخصيص عرض الكروت لتدخل كلها في سطر واحد */
    .stats-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    
    .stat-card {
        flex: 1 1 calc(14.28% - 0.5rem); /* 7 كروت في الصف - 14.28% لكل واحد */
        min-width: 100px;
    }
    
    @@media (max-width: 1200px) {
        .stat-card {
            flex: 1 1 calc(33.33% - 0.5rem); /* 3 كروت في الصف */
        }
    }
    
    @@media (max-width: 768px) {
        .stat-card {
            flex: 1 1 calc(50% - 0.5rem); /* كرتان في الصف */
        }
    }
</style>

<div class="container-fluid product-dashboard" dir="rtl">

    @* =====================================================
       1) شريط اختيار الصنف + فترة التاريخ (مدمج ومضغوط)
       ===================================================== *@
    <div class="dashboard-header">
        <div class="card compact-card shadow-sm mb-2">
            <div class="card-body p-2">
                <form id="productMovementForm"
                      method="get"
                      asp-action="Show"
                      asp-controller="Products"
                      class="row g-2 align-items-end">

                    <input type="hidden" id="productSearchId" name="prodId" value="@(selectedProdId?.ToString() ?? "")" />
                    <input type="hidden" id="customerSearchId" name="customerId" value="@(selectedCustomerId?.ToString() ?? "")" />

                    <div class="col-lg-3 col-md-4">
                        <label class="form-label compact-label mb-1">بحث بالكود أو الاسم</label>
                        <input id="productSearchInput"
                               list="productsList"
                               type="text"
                               class="form-control form-control-sm"
                               placeholder="اكتب اسم الصنف أو جزء منه..."
                               value="@selectedProdName"
                               autocomplete="off" />
                        <datalist id="productsList">
                            @if (ViewBag.ProductsAuto != null)
                            {
                                foreach (var p in ViewBag.ProductsAuto)
                                {
                                    <option value="@p.Name"
                                            data-id="@p.Id"
                                            data-code="@p.Id"
                                            data-generic="@p.GenericName"
                                            data-company="@p.Company"
                                            data-price="@p.PriceRetail"
                                            data-hasquota="@(p.HasQuota ? "true" : "false")">
                                    </option>
                                }
                            }
                        </datalist>
                    </div>

                    <div class="col-lg-2 col-md-3">
                        <label class="form-label compact-label mb-1">المخزن</label>
                        <select name="warehouseId" class="form-select form-select-sm">
                            <option value="">كل المخازن</option>
                            @foreach (var w in warehousesList)
                            {
                                var selected = (selectedWarehouseId.HasValue && w.Value == selectedWarehouseId.Value.ToString()) ? "selected" : null;
                                <option value="@w.Value" selected="@selected">@w.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-lg-2 col-md-3">
                        <label class="form-label compact-label mb-1">من تاريخ</label>
                        <input type="date"
                               name="from"
                               class="form-control form-control-sm"
                               value="@(from?.ToString("yyyy-MM-dd") ?? "")" />
                    </div>

                    <div class="col-lg-2 col-md-3">
                        <label class="form-label compact-label mb-1">إلى تاريخ</label>
                        <input type="date"
                               name="to"
                               class="form-control form-control-sm"
                               value="@(to?.ToString("yyyy-MM-dd") ?? "")" />
                    </div>

                    <div class="col-lg-2 col-md-2">
                        <label class="form-label compact-label mb-1 d-none d-md-block">&nbsp;</label>
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            عرض
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* =====================================================
       2) لو لم يتم اختيار صنف بعد
       ===================================================== *@
    @if (Model == null)
    {
        <div class="alert alert-light border text-muted text-center">
            برجاء اختيار صنف من أعلى الصفحة ثم اضغط زر <strong>عرض</strong>.
        </div>
    }
    else
    {
    <div class="dashboard-content">
        @* =====================================================
           3) معلومات الصنف الأساسية (مدمجة في صف واحد)
           ===================================================== *@
        <div class="card compact-card shadow-sm mb-2">
            <div class="card-body p-2">
                <div class="row g-2 align-items-center">
                    <div class="col-lg-4 col-md-4">
                        <h5 class="mb-0 product-info-compact">@Model.ProdName</h5>
                        <small class="text-muted">كود: @Model.ProdId @(Model.Category != null ? $"| التصنيف: {Model.Category.CategoryName}" : "")</small>
                    </div>
                    <div class="col-lg-4 col-md-4 product-info-compact">
                        <div><strong>سعر الجمهور:</strong> @((decimal)priceRetail).ToString("N2")</div>
                    </div>
                    <div class="col-lg-4 col-md-12">
                        <div class="d-flex flex-wrap gap-1">
                            <a asp-action="Edit" asp-route-id="@Model.ProdId" 
                               class="btn btn-outline-secondary btn-sm action-btn-compact app-menu-link"
                               data-tab-id="product-edit-tab"
                               data-tab-title="تعديل صنف">✏️ تعديل</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* =====================================================
           4) بطاقات الملخص الإجمالية (كلها في سطر واحد مضغوط)
           ===================================================== *@
        <div class="stats-row mb-2">
            <div class="stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">كمية المبيعات</div>
                        <div class="compact-stat text-success" style="font-size: 0.95rem;">@totalQtySold</div>
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">مبلغ المبيعات</div>
                        <div class="compact-stat text-success" style="font-size: 0.85rem;">@(((decimal)totalAmountSold).ToString("N2"))</div>
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">كمية المشتريات</div>
                        <div class="compact-stat text-primary" style="font-size: 0.95rem;">@totalQtyPurchased</div>
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">مبلغ المشتريات</div>
                        <div class="compact-stat text-primary" style="font-size: 0.85rem;">@(((decimal)totalAmountPurchased).ToString("N2"))</div>
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">المرتجعات</div>
                        <div class="compact-stat text-danger" style="font-size: 0.95rem;">@(totalQtyReturned + totalQtyPurchaseReturned)</div>
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">الخصم المرجّح</div>
                        <div class="compact-stat text-info" style="font-size: 0.95rem;">@(((decimal)weightedDiscount).ToString("0.00"))%</div>
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="card compact-card text-center shadow-sm" style="border: 3px solid #ff9800 !important; box-shadow: 0 2px 8px rgba(255, 152, 0, 0.3) !important;">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">صافى الكمية</div>
                        <div class="compact-stat" style="font-size: 1.1rem;">@netQty</div>
                    </div>
                </div>
            </div>
        </div>

        @* =====================================================
           5) التبويبات والجداول (مدمجة ومضغوطة)
           ===================================================== *@
        <div class="card compact-card shadow-sm mb-2" style="flex: 1; display: flex; flex-direction: column; min-height: 0;">
            <div class="card-header p-2" style="flex-shrink: 0;">
                <div class="d-flex justify-content-between align-items-center">
                    <strong class="small">حركة الصنف</strong>
                    <div style="overflow-x: auto; white-space: nowrap;">
                        <ul class="nav nav-pills nav-sm flex-nowrap" id="productMovementTabs" role="tablist">
                            <li class="nav-item"><button class="nav-link active nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-sales">المبيعات</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-purchases">المشتريات</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-salesReturns">مرتجعات البيع</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-purchaseReturns">مرتجعات الشراء</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-adjustments">تسويات جردية</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-purchaseRequests">طلب شراء</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-transfers">تحويل بين المخازن</button></li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="card-body p-2" style="flex: 1; overflow: hidden; display: flex; flex-direction: column; min-height: 0;">
                <div class="tab-content h-100" id="productMovementTabsContent" style="overflow: hidden; display: flex; flex-direction: column;">
                    @* --- تبويب: المبيعات --- *@
                    <div class="tab-pane fade show active h-100" id="tab-sales" role="tabpanel" style="display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                        <div class="table-responsive" style="flex: 1; overflow-y: auto; min-height: 0;">
                            <table class="table table-sm table-striped table-compact mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>التاريخ</th>
                                        <th>رقم الفاتورة</th>
                                        <th>العميل</th>
                                        <th class="text-end">الكمية</th>
                                        <th class="text-end">سعر الوحدة</th>
                                        <th class="text-end">الخصم %</th>
                                        <th class="text-end">صافى القيمة</th>
                                        <th>إجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (salesLines.Any())
                                    {
                                        foreach (var s in salesLines)
                                        {
                                            <tr>
                                                <td>@s.Date.ToString("yyyy/MM/dd")</td>
                                                <td><a class="open-same-tab text-primary text-decoration-none" href="@(Url.Action("Show", "SalesInvoices", new { id = s.InvoiceNo }))?frame=1" data-tab-id="si-show-tab" data-tab-title="فاتورة مبيعات" data-url="@(Url.Action("Show", "SalesInvoices", new { id = s.InvoiceNo }))?frame=1">@s.InvoiceNo</a></td>
                                                <td>@s.Customer</td>
                                                <td class="text-end">@s.Qty</td>
                                                <td class="text-end">@(((decimal)s.UnitPrice).ToString("0.00"))</td>
                                                <td class="text-end">@(((decimal)s.DiscountPercent).ToString("0.00"))</td>
                                                <td class="text-end">@(((decimal)s.NetAmount).ToString("0.00"))</td>
                                                <td><a class="btn btn-sm btn-primary open-same-tab" href="@(Url.Action("Show", "SalesInvoices", new { id = s.InvoiceNo }))?frame=1" data-tab-id="si-show-tab" data-tab-title="فاتورة مبيعات" data-url="@(Url.Action("Show", "SalesInvoices", new { id = s.InvoiceNo }))?frame=1">عرض</a></td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="8" class="text-center text-muted py-3"><small>لم يتم تحميل تفاصيل فواتير المبيعات بعد.</small></td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* --- تبويب: مرتجعات المبيعات --- *@
                    <div class="tab-pane fade h-100" id="tab-salesReturns" role="tabpanel" style="display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                        <div class="table-responsive" style="flex: 1; overflow-y: auto; min-height: 0;">
                            <table class="table table-sm table-striped table-compact mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>التاريخ</th>
                                        <th>رقم الإشعار</th>
                                        <th>العميل</th>
                                        <th class="text-end">الكمية</th>
                                        <th class="text-end">سعر الوحدة</th>
                                        <th class="text-end">قيمة المرتجع</th>
                                        <th>إجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (salesReturnLines.Any())
                                    {
                                        foreach (var s in salesReturnLines)
                                        {
                                            <tr>
                                                <td>@s.Date.ToString("yyyy/MM/dd")</td>
                                                <td><a class="open-same-tab text-primary text-decoration-none" href="@(Url.Action("Edit", "SalesReturns", new { id = s.DocNo }))?frame=1" data-tab-id="sr-show-tab" data-tab-title="مرتجع مبيعات" data-url="@(Url.Action("Edit", "SalesReturns", new { id = s.DocNo }))?frame=1">@s.DocNo</a></td>
                                                <td>@s.Customer</td>
                                                <td class="text-end">@s.Qty</td>
                                                <td class="text-end">@(((decimal)s.UnitPrice).ToString("0.00"))</td>
                                                <td class="text-end">@(((decimal)s.Amount).ToString("0.00"))</td>
                                                <td><a class="btn btn-sm btn-primary open-same-tab" href="@(Url.Action("Edit", "SalesReturns", new { id = s.DocNo }))?frame=1" data-tab-id="sr-show-tab" data-tab-title="مرتجع مبيعات" data-url="@(Url.Action("Edit", "SalesReturns", new { id = s.DocNo }))?frame=1">عرض</a></td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="7" class="text-center text-muted py-2"><small>لا توجد مرتجعات مبيعات محمّلة حتى الآن.</small></td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* --- تبويب: المشتريات --- *@
                    <div class="tab-pane fade h-100" id="tab-purchases" role="tabpanel" style="display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                        <div class="table-responsive" style="flex: 1; overflow-y: auto; min-height: 0;">
                            <table class="table table-sm table-striped table-compact mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>التاريخ</th>
                                        <th>رقم الفاتورة</th>
                                        <th>المورد</th>
                                        <th class="text-end">الكمية</th>
                                        <th class="text-end">سعر الشراء</th>
                                        <th class="text-end">قيمة الفاتورة</th>
                                        <th>إجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (purchaseLines.Any())
                                    {
                                        foreach (var p in purchaseLines)
                                        {
                                            <tr>
                                                <td>@p.Date.ToString("yyyy/MM/dd")</td>
                                                <td><a class="open-same-tab text-primary text-decoration-none" href="@(Url.Action("Show", "PurchaseInvoices", new { id = p.InvoiceNo }))?frame=1" data-tab-id="pi-show-tab" data-tab-title="فاتورة مشتريات" data-url="@(Url.Action("Show", "PurchaseInvoices", new { id = p.InvoiceNo }))?frame=1">@p.InvoiceNo</a></td>
                                                <td>@p.Supplier</td>
                                                <td class="text-end">@p.Qty</td>
                                                <td class="text-end">@(((decimal)p.UnitCost).ToString("0.00"))</td>
                                                <td class="text-end">@(((decimal)p.Amount).ToString("0.00"))</td>
                                                <td><a class="btn btn-sm btn-primary open-same-tab" href="@(Url.Action("Show", "PurchaseInvoices", new { id = p.InvoiceNo }))?frame=1" data-tab-id="pi-show-tab" data-tab-title="فاتورة مشتريات" data-url="@(Url.Action("Show", "PurchaseInvoices", new { id = p.InvoiceNo }))?frame=1">عرض</a></td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="7" class="text-center text-muted py-3"><small>لم يتم تحميل تفاصيل فواتير المشتريات بعد.</small></td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* --- تبويب: مرتجعات المشتريات --- *@
                    <div class="tab-pane fade h-100" id="tab-purchaseReturns" role="tabpanel" style="display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                        <div class="table-responsive" style="flex: 1; overflow-y: auto; min-height: 0;">
                            <table class="table table-sm table-striped table-compact mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>التاريخ</th>
                                        <th>رقم الإشعار</th>
                                        <th>المورد</th>
                                        <th class="text-end">الكمية</th>
                                        <th class="text-end">سعر الشراء</th>
                                        <th class="text-end">قيمة المرتجع</th>
                                        <th>إجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (purchaseReturnLines.Any())
                                    {
                                        foreach (var p in purchaseReturnLines)
                                        {
                                            <tr>
                                                <td>@p.Date.ToString("yyyy/MM/dd")</td>
                                                <td><a class="open-same-tab text-primary text-decoration-none" href="@(Url.Action("Edit", "PurchaseReturns", new { id = p.DocNo }))?frame=1" data-tab-id="pr-ret-show-tab" data-tab-title="مرتجع مشتريات" data-url="@(Url.Action("Edit", "PurchaseReturns", new { id = p.DocNo }))?frame=1">@p.DocNo</a></td>
                                                <td>@p.Supplier</td>
                                                <td class="text-end">@p.Qty</td>
                                                <td class="text-end">@(((decimal)p.UnitCost).ToString("0.00"))</td>
                                                <td class="text-end">@(((decimal)p.Amount).ToString("0.00"))</td>
                                                <td><a class="btn btn-sm btn-primary open-same-tab" href="@(Url.Action("Edit", "PurchaseReturns", new { id = p.DocNo }))?frame=1" data-tab-id="pr-ret-show-tab" data-tab-title="مرتجع مشتريات" data-url="@(Url.Action("Edit", "PurchaseReturns", new { id = p.DocNo }))?frame=1">عرض</a></td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="7" class="text-center text-muted py-2"><small>لا توجد مرتجعات مشتريات محمّلة حتى الآن.</small></td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* --- تبويب: تسويات جردية --- *@
                    <div class="tab-pane fade h-100" id="tab-adjustments" role="tabpanel" style="display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                        <div class="table-responsive" style="flex: 1; overflow-y: auto; min-height: 0;">
                            <table class="table table-sm table-striped table-compact mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>التاريخ</th>
                                        <th>رقم التسوية</th>
                                        <th>المخزن</th>
                                        <th class="text-end">الكمية قبل</th>
                                        <th class="text-end">الكمية بعد</th>
                                        <th class="text-end">الفرق</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (adjustmentLines.Any())
                                    {
                                        foreach (var a in adjustmentLines)
                                        {
                                            <tr>
                                                <td>@a.Date.ToString("yyyy/MM/dd")</td>
                                                <td>@a.DocNo</td>
                                                <td>@a.Warehouse</td>
                                                <td class="text-end">@a.QtyBefore</td>
                                                <td class="text-end">@a.QtyAfter</td>
                                                <td class="text-end">@a.QtyDiff</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="6" class="text-center text-muted py-2"><small>لا توجد تسويات جردية محمّلة حتى الآن.</small></td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* --- تبويب: طلب شراء --- *@
                    <div class="tab-pane fade h-100" id="tab-purchaseRequests" role="tabpanel" style="display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                        <div class="table-responsive" style="flex: 1; overflow-y: auto; min-height: 0;">
                            <table class="table table-sm table-striped table-compact mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>التاريخ</th>
                                        <th>رقم الطلب</th>
                                        <th>المورد</th>
                                        <th class="text-end">الكمية المطلوبة</th>
                                        <th class="text-end">الكمية المستلمة</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (purchaseRequestLines.Any())
                                    {
                                        foreach (var pr in purchaseRequestLines)
                                        {
                                            <tr>
                                                <td>@pr.Date.ToString("yyyy/MM/dd")</td>
                                                <td>@pr.DocNo</td>
                                                <td>@pr.Supplier</td>
                                                <td class="text-end">@pr.QtyRequested</td>
                                                <td class="text-end">@pr.QtyReceived</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="5" class="text-center text-muted py-2"><small>لا توجد طلبات شراء محمّلة حتى الآن.</small></td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* --- تبويب: تحويل بين المخازن --- *@
                    <div class="tab-pane fade h-100" id="tab-transfers" role="tabpanel" style="display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                        <div class="table-responsive" style="flex: 1; overflow-y: auto; min-height: 0;">
                            <table class="table table-sm table-striped table-compact mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>التاريخ</th>
                                        <th>رقم التحويل</th>
                                        <th>من مخزن</th>
                                        <th>إلى مخزن</th>
                                        <th class="text-end">الكمية</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (transferLines.Any())
                                    {
                                        foreach (var t in transferLines)
                                        {
                                            <tr>
                                                <td>@t.Date.ToString("yyyy/MM/dd")</td>
                                                <td>@t.DocNo</td>
                                                <td>@t.FromWarehouse</td>
                                                <td>@t.ToWarehouse</td>
                                                <td class="text-end">@t.Qty</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="5" class="text-center text-muted py-2"><small>لا توجد تحويلات بين المخازن محمّلة حتى الآن.</small></td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* =====================================================
           6) الرسوم البيانية والتقارير (تحت الجدول)
           ===================================================== *@
        @if (Model != null && salesLines.Any())
        {
            <div class="row g-2 mb-2">
                <div class="col-12 col-lg-6">
                    <div class="card shadow-sm">
                        <div class="card-header">
                            <strong class="small">توزيع المبيعات حسب التاريخ</strong>
                        </div>
                        <div class="card-body">
                            <canvas id="salesByDateChart" height="150"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="card shadow-sm">
                        <div class="card-header">
                            <strong class="small">مقارنة المبيعات والمشتريات</strong>
                        </div>
                        <div class="card-body">
                            <canvas id="salesPurchasesComparisonChart" height="150"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    }
</div>

@section Scripts {
    @* Chart.js Library *@
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            // =========================================================
            // بوكس البحث عن الصنف باستخدام datalist (مثل فاتورة المبيعات)
            // =========================================================
            const prodNameInput = document.getElementById('productSearchInput');
            const prodIdHidden = document.getElementById('productSearchId');
            const form = document.getElementById('productMovementForm');

            if (!prodNameInput || !prodIdHidden || !form) return;

            // الحصول على datalist الخاصة بالأصناف
            const prodDataList = prodNameInput && prodNameInput.list ? prodNameInput.list : null;

            if (!prodDataList) {
                console.warn('⚠️ Products datalist not found for productSearchInput');
                return;
            }

            // تعليق: توحيد النص (وتجاهل الألف في أول الكلمة)
            function normalizeText(txt) {
                return (txt || '')
                    .trim()
                    .toLowerCase()
                    .replace(/^[اأإآ]/, '')
                    .replace(/\s+/g, ' ');
            }

            // تعليق: بحث بالاسم (تطابق تام أو يبدأ بـ — StartsWith فقط، لا Contains)
            function findProductByName(name) {
                const search = normalizeText(name);
                if (!search) return null;

                const opts = prodDataList.options;

                // 1) تطابق تام
                for (let i = 0; i < opts.length; i++) {
                    if (normalizeText(opts[i].value) === search) return opts[i];
                }

                // 2) يبدأ بـ
                for (let i = 0; i < opts.length; i++) {
                    if (normalizeText(opts[i].value).startsWith(search)) return opts[i];
                }

                return null;
            }

            // تعليق: بحث بالكود (data-id أو data-code)
            function findProductByCode(code) {
                const search = (code || '').toString().trim();
                if (!search) return null;

                const opts = prodDataList.options;
                for (let i = 0; i < opts.length; i++) {
                    const idAttr = (opts[i].getAttribute('data-id') || '').toString();
                    const codeAttr = (opts[i].getAttribute('data-code') || '').toString();
                    if (idAttr === search || codeAttr === search) return opts[i];
                }
                return null;
            }

            // عند تغيير اسم الصنف (من datalist أو يدوياً)
            prodNameInput.addEventListener('input', function () {
                const txt = prodNameInput.value.trim();

                // لو المستخدم حذف كل شيء → نفرّغ الكود
                if (!txt) {
                    prodIdHidden.value = '';
                    return;
                }

                // محاولة 1: البحث بالاسم
                const optByName = findProductByName(txt);
                if (optByName) {
                    const prodId = optByName.getAttribute('data-id');
                    prodIdHidden.value = prodId || '';
                    return;
                }

                // محاولة 2: لو المستخدم كتب رقم فقط → بحث بالكود
                if (/^\d+$/.test(txt)) {
                    const optByCode = findProductByCode(txt);
                    if (optByCode) {
                        prodIdHidden.value = optByCode.getAttribute('data-id') || '';
                        prodNameInput.value = optByCode.value; // نعرض الاسم الكامل
                        return;
                    }
                }

                // لو لم نجد تطابق → نفرّغ الكود
                prodIdHidden.value = '';
            });

            // عند تغيير الكود مباشرة (لو كان هناك بوكس كود منفصل لاحقاً)
            // يمكن إضافة ذلك لاحقاً

            // منع إرسال الفورم لو مفيش كود صنف
            form.addEventListener('submit', function (e) {
                if (!prodIdHidden.value) {
                    e.preventDefault();
                    alert('من فضلك اختر صنف من قائمة الاقتراحات أو أدخل كوده الرقمى.');
                    prodNameInput.focus();
                }
            });

            // ✅ Focus على بوكس البحث عند تحميل الصفحة (لو مفيش صنف مختار)
            @if (Model == null)
            {
                <text>
                setTimeout(function() {
                    if (prodNameInput) {
                        prodNameInput.focus();
                    }
                }, 100);
                </text>
            }
        })();

        // =========================================================
        // الرسوم البيانية (Chart.js)
        // =========================================================
        @if (Model != null && salesLines.Any())
        {
            <text>
            document.addEventListener('DOMContentLoaded', function() {
                // بيانات المبيعات
                var salesData = @Html.Raw(Json.Serialize(salesLines.Select(s => new { Date = s.Date.ToString("yyyy-MM-dd"), Amount = (decimal)s.NetAmount })));
                
                // رسم بياني: توزيع المبيعات حسب التاريخ
                var ctx1 = document.getElementById('salesByDateChart');
                if (ctx1) {
                    var dates = salesData.map(s => s.Date);
                    var amounts = salesData.map(s => s.Amount);
                    
                    new Chart(ctx1, {
                        type: 'line',
                        data: {
                            labels: dates,
                            datasets: [{
                                label: 'المبيعات',
                                data: amounts,
                                borderColor: 'rgb(40, 167, 69)',
                                backgroundColor: 'rgba(40, 167, 69, 0.1)',
                                tension: 0.4,
                                fill: true
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    display: true,
                                    position: 'top'
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    ticks: {
                                        callback: function(value) {
                                            return value.toFixed(2);
                                        }
                                    }
                                }
                            }
                        }
                    });
                }

                // رسم بياني: مقارنة المبيعات والمشتريات
                var ctx2 = document.getElementById('salesPurchasesComparisonChart');
                if (ctx2) {
                    new Chart(ctx2, {
                        type: 'bar',
                        data: {
                            labels: ['المبيعات', 'المشتريات', 'المرتجعات'],
                            datasets: [{
                                label: 'المبلغ',
                                data: [
                                    @((decimal)totalAmountSold),
                                    @((decimal)totalAmountPurchased),
                                    @((decimal)(totalAmountReturned + totalAmountPurchaseReturned))
                                ],
                                backgroundColor: [
                                    'rgba(40, 167, 69, 0.7)',
                                    'rgba(0, 123, 255, 0.7)',
                                    'rgba(220, 53, 69, 0.7)'
                                ],
                                borderColor: [
                                    'rgb(40, 167, 69)',
                                    'rgb(0, 123, 255)',
                                    'rgb(220, 53, 69)'
                                ],
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    display: false
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    ticks: {
                                        callback: function(value) {
                                            return value.toFixed(2);
                                        }
                                    }
                                }
                            }
                        }
                    });
                }
            });
            </text>
        }
    </script>
}
