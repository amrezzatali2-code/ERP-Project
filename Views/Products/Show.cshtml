@section Scripts {
    <script>
        // =========================
        // أوتوكمبليت بحث عن الصنف + تحكم بالأسهم
        // =========================
        document.addEventListener('DOMContentLoaded', function () {
            const input = document.getElementById('productSearchInput');   // متغير: بوكس كتابة اسم الصنف
            const hiddenId = document.getElementById('productSearchId');   // متغير: الهيدن اللى فيه كود الصنف
            const box = document.getElementById('productSuggestions');     // متغير: صندوق الاقتراحات
            const form = document.getElementById('productMovementForm');   // متغير: فورم حركة الصنف

            if (!input || !hiddenId || !box || !form) return;

            let timer = null;                // متغير: تايمر لتأخير طلب السيرفر
            let currentIndex = -1;           // متغير: رقم العنصر المحدد حالياً فى الليست
            let currentItems = [];           // متغير: مصفوفة عناصر الاقتراحات (buttons)

            // دالة: مسح الاقتراحات وإخفاء الليست
            function clearSuggestions() {
                box.innerHTML = '';
                box.style.display = 'none';
                currentIndex = -1;
                currentItems = [];
            }

            // دالة: تظليل عنصر معين وتحريك الـ scroll لو خارج الجزء الظاهر
            function highlightItem(index) {
                if (!currentItems.length) return;

                // التأكد من أن الفهرس داخل الحدود
                if (index < 0) index = 0;
                if (index >= currentItems.length) index = currentItems.length - 1;

                // تمييز العنصر الفعال
                currentItems.forEach((el, i) => {
                    if (i === index) {
                        el.classList.add('active');    // Bootstrap يلوّن العنصر المختار
                    } else {
                        el.classList.remove('active');
                    }
                });

                currentIndex = index;

                // -------- تحريك الـ scroll بحيث العنصر المختار يبقى داخل الجزء الظاهر --------
                const item = currentItems[currentIndex];        // متغير: العنصر المحدد
                const itemTop = item.offsetTop;                 // موضع العنصر من أعلى الليست
                const itemBottom = itemTop + item.offsetHeight; // أسفل العنصر
                const boxScrollTop = box.scrollTop;             // الموضع الحالى للـ scroll
                const boxHeight = box.clientHeight;             // ارتفاع الجزء الظاهر من الليست

                // لو العنصر فوق الجزء الظاهر → نطلع الـ scroll لفوق
                if (itemTop < boxScrollTop) {
                    box.scrollTop = itemTop;
                }
                // لو العنصر تحت الجزء الظاهر → ننزل الـ scroll لتحت
                else if (itemBottom > boxScrollTop + boxHeight) {
                    box.scrollTop = itemBottom - boxHeight;
                }
            }

            // دالة: اختيار عنصر (سواء بالسهم + Enter أو بالماوس)
            function chooseItem(index) {
                if (!currentItems.length) return;
                if (index < 0 || index >= currentItems.length) return;

                const btn = currentItems[index];                  // متغير: العنصر المختار
                const prodId = btn.getAttribute('data-id');       // متغير: كود الصنف
                const prodName = btn.getAttribute('data-name');   // متغير: اسم الصنف

                input.value = prodName;       // نعرض اسم الصنف فى البوكس
                hiddenId.value = prodId;      // نخزن الكود فى الهيدن
                clearSuggestions();           // نقفل الليست

                // تركيز على بوكس الطرف (العميل/المورد) لو موجود لتسريع الإدخال
                const partyInput = document.getElementById('partySearchInput');  // متغير: بوكس بحث الطرف
                if (partyInput) {
                    partyInput.focus();
                    partyInput.select();
                }
            }

            // ======= جلب الاقتراحات أثناء الكتابة =======
            input.addEventListener('input', function () {
                const term = input.value.trim();
                hiddenId.value = '';   // نفرّغ الكود لحد ما المستخدم يختار صنف فعلاً

                if (term.length < 2) {
                    clearSuggestions();
                    return;
                }

                if (timer) clearTimeout(timer);

                timer = setTimeout(function () {
                    const url = '@Url.Action("SearchProducts", "Products")' + '?term=' + encodeURIComponent(term);

                    fetch(url)
                        .then(r => r.ok ? r.json() : [])
                        .then(data => {
                            box.innerHTML = '';
                            currentItems = [];
                            currentIndex = -1;

                            if (!data || !data.length) {
                                clearSuggestions();
                                return;
                            }

                            data.forEach(item => {
                                const btn = document.createElement('button');
                                btn.type = 'button';
                                btn.className = 'list-group-item list-group-item-action';
                                btn.textContent = item.name + ' — (' + item.id + ')';
                                btn.setAttribute('data-id', item.id);
                                btn.setAttribute('data-name', item.name);

                                // كليك بالماوس يختار الصنف
                                btn.addEventListener('click', function () {
                                    chooseItem(currentItems.indexOf(btn));
                                });

                                box.appendChild(btn);
                                currentItems.push(btn);
                            });

                            box.style.display = 'block';
                            box.scrollTop = 0;   // نرجّع السكرول لفوق أول الليست
                        })
                        .catch(() => {
                            clearSuggestions();
                        });
                }, 250);   // تأخير بسيط علشان ما نكترش الـ Requests على السيرفر
            });

            // ======= التحكم بلوحة المفاتيح على بوكس الصنف =======
            input.addEventListener('keydown', function (e) {
                // لو الليست مش ظاهرة نسيب الكيز تشتغل عادى
                if (box.style.display !== 'block' || !currentItems.length) {
                    return;
                }

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    if (currentIndex < currentItems.length - 1) {
                        highlightItem(currentIndex + 1);
                    } else {
                        highlightItem(0);  // لو وصلنا لآخر عنصر نرجع لأول واحد
                    }
                }
                else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    if (currentIndex > 0) {
                        highlightItem(currentIndex - 1);
                    } else {
                        highlightItem(currentItems.length - 1);  // من أول واحد لآخر واحد
                    }
                }
                else if (e.key === 'Enter') {
                    // Enter يختار العنصر الحالى
                    if (currentIndex >= 0) {
                        e.preventDefault();
                        chooseItem(currentIndex);
                    }
                }
                else if (e.key === 'Escape') {
                    // Esc يقفل الليست
                    clearSuggestions();
                }
            });

            // إخفاء الليست لو ضغطنا خارجها
            document.addEventListener('click', function (e) {
                if (!box.contains(e.target) && e.target !== input) {
                    clearSuggestions();
                }
            });

            // منع إرسال الفورم لو مفيش كود صنف
            form.addEventListener('submit', function (e) {
                if (!hiddenId.value) {
                    e.preventDefault();
                    alert('من فضلك اختر صنف من قائمة الاقتراحات.');
                    input.focus();
                }
            });
        });
    </script>
}

