@section Scripts {
    <script>
        (function () {
            // datalist + قائمة مخصّصة — نفس منطق فاتورة المبيعات (بحث متعدد الكلمات + تطبيع)
            var prodDataList = document.getElementById('productsMovementList');
            var input = document.getElementById('productSearchInput');
            var hiddenId = document.getElementById('productSearchId');
            var dropdownWrap = document.getElementById('productMovementDropdownWrap');
            var dropdownList = document.getElementById('productMovementDropdownList');
            var dropdownArrow = document.getElementById('productMovementDropdownArrow');
            var form = document.getElementById('productMovementForm');

            // حد النتائج كما في فاتورة المبيعات (PRODUCT_LIST_MAX)
            var PRODUCT_MOVEMENT_MAX = 15;
            var activeIndex = -1;
            var selectableOpts = [];
            var isSelectingProduct = false;

            function normalizeDigits(txt) {
                if (!txt) return '';
                var map = { '\u0660': '0', '\u0661': '1', '\u0662': '2', '\u0663': '3', '\u0664': '4',
                    '\u0665': '5', '\u0666': '6', '\u0667': '7', '\u0668': '8', '\u0669': '9' };
                var out = '';
                for (var i = 0; i < txt.length; i++) {
                    var c = txt[i];
                    out += map[c] !== undefined ? map[c] : c;
                }
                return out;
            }

            function normalizeWord(w) {
                return normalizeDigits((w || '').trim().toLowerCase()).replace(/^[اأإآ]/u, '');
            }

            function normalizeText(txt) {
                return (txt || '')
                    .trim()
                    .toLowerCase()
                    .split(/\s+/)
                    .filter(Boolean)
                    .map(function (w) { return normalizeWord(w); })
                    .filter(Boolean)
                    .join(' ')
                    .replace(/\s+/g, ' ');
            }

            function wordMatchesQueryWord(nameWord, queryWord) {
                var nw0 = normalizeDigits((nameWord || '').trim().toLowerCase());
                var qw0 = normalizeDigits((queryWord || '').trim().toLowerCase());
                var nw = nw0.replace(/^[اأإآ]/u, '');
                var qw = qw0.replace(/^[اأإآ]/u, '');
                if (!qw) return true;
                return nw === qw || nw.startsWith(qw);
            }

            function productNameMatchesSearch(productName, rawSearch) {
                var raw = (rawSearch || '').trim();
                if (!raw) return true;
                var qWords = raw.split(/\s+/).filter(Boolean);
                var nWords = (productName || '').trim().split(/\s+/).filter(Boolean);
                if (qWords.length === 0) return true;
                return qWords.every(function (qw) {
                    return nWords.some(function (nw) { return wordMatchesQueryWord(nw, qw); });
                });
            }

            function productSearchRank(name, rawSearch) {
                var raw = (rawSearch || '').trim();
                var nm = (name || '').trim();
                if (!raw) return 50;
                if (nm === raw) return 0;
                if (nm.startsWith(raw)) return 1;
                var rawWords = raw.split(/\s+/).filter(Boolean);
                var firstQ = rawWords[0] || '';
                var nmWords = nm.split(/\s+/).filter(Boolean);
                if (firstQ && nmWords.length) {
                    if (nmWords[0].startsWith(firstQ)) return 2;
                    var nw0 = normalizeDigits(nmWords[0].toLowerCase());
                    var qw0 = normalizeDigits(firstQ.toLowerCase());
                    var nw = nw0.replace(/^[اأإآ]/u, '');
                    var qw = qw0.replace(/^[اأإآ]/u, '');
                    if (qw && (nw === qw || nw.startsWith(qw))) return 3;
                }
                return 4;
            }

            function getProductDropdownFilterQuery(rawTrim) {
                var raw = (rawTrim || '').trim();
                if (!raw || !prodDataList || !prodDataList.options) return raw;
                var nRaw = normalizeText(raw);
                var canonical = '';
                var opts = prodDataList.options;
                for (var i = 0; i < opts.length; i++) {
                    var v = (opts[i].value || '').trim();
                    if (!v) continue;
                    if (v === raw) { canonical = v; break; }
                    if (nRaw && normalizeText(v) === nRaw) { canonical = v; break; }
                }
                if (!canonical) return raw;
                var parts = canonical.split(/\s+/).filter(Boolean);
                return parts[0] || raw;
            }

            function getFilteredProductOptions(search, max, pinDisplayName) {
                if (!prodDataList || !prodDataList.options) return [];
                var limit = max || PRODUCT_MOVEMENT_MAX;
                var opts = prodDataList.options;
                var rawTrim = (search || '').trim();
                if (!rawTrim) {
                    var out0 = [];
                    for (var a = 0; a < opts.length && out0.length < limit; a++) out0.push(opts[a]);
                    return out0;
                }
                var qNorm = normalizeText(rawTrim);
                var words = rawTrim.split(/\s+/).filter(Boolean);
                var matched = [];
                for (var i = 0; i < opts.length; i++) {
                    var opt = opts[i];
                    var nameVal = (opt.value || '').trim();
                    var code = (opt.getAttribute('data-code') || '').toString().trim();
                    var idAttr = (opt.getAttribute('data-id') || '').toString().trim();
                    var codeOrId = code || idAttr;
                    var nameOk = qNorm ? productNameMatchesSearch(nameVal, rawTrim) : true;
                    var idOk = words.length > 0 && words.some(function (w) { return codeOrId.indexOf(w) !== -1; });
                    var codeRawOk = codeOrId && codeOrId.indexOf(rawTrim) !== -1;
                    if (nameOk || idOk || codeRawOk) matched.push(opt);
                }
                matched.sort(function (a, b) {
                    var ra = productSearchRank((a.value || '').trim(), rawTrim);
                    var rb = productSearchRank((b.value || '').trim(), rawTrim);
                    if (ra !== rb) return ra - rb;
                    return (a.value || '').localeCompare(b.value || '', 'ar');
                });
                var result = matched.slice(0, limit);
                var pinRaw = (pinDisplayName || '').trim();
                if (pinRaw) {
                    var nPin = normalizeText(pinRaw);
                    var pinOpt = null;
                    for (var j = 0; j < opts.length; j++) {
                        var v = (opts[j].value || '').trim();
                        if (v === pinRaw || (nPin && normalizeText(v) === nPin)) { pinOpt = opts[j]; break; }
                    }
                    if (pinOpt && matched.indexOf(pinOpt) >= 0) {
                        var inResult = result.some(function (o) { return o === pinOpt; });
                        if (!inResult) {
                            result = matched.slice(0, limit - 1);
                            result.push(pinOpt);
                        }
                    }
                }
                return result;
            }

            function findProductByName(name) {
                var raw = (name || '').trim();
                var search = normalizeText(raw);
                if (!search) return null;
                var opts = prodDataList ? prodDataList.options : [];
                for (var i = 0; i < opts.length; i++) {
                    if (normalizeText(opts[i].value) === search) return opts[i];
                }
                for (var k = 0; k < opts.length; k++) {
                    if ((opts[k].value || '').trim() === raw) return opts[k];
                }
                return null;
            }

            function findProductByCode(code) {
                var search = (code || '').toString().trim();
                if (!search) return null;
                var opts = prodDataList ? prodDataList.options : [];
                for (var i = 0; i < opts.length; i++) {
                    var idAttr = (opts[i].getAttribute('data-id') || '').toString();
                    var codeAttr = (opts[i].getAttribute('data-code') || '').toString();
                    if (idAttr === search || codeAttr === search) return opts[i];
                }
                return null;
            }

            function fillFromProductOpt(opt) {
                if (!opt) {
                    if (hiddenId) hiddenId.value = '';
                    if (input) input.value = '';
                    return;
                }
                var id = (opt.getAttribute('data-id') || '').toString();
                var name = (opt.value || '').trim();
                if (hiddenId) hiddenId.value = id;
                if (input) input.value = name;
            }

            function closeProductDropdown() {
                if (dropdownList) {
                    dropdownList.setAttribute('data-open', 'false');
                    dropdownList.innerHTML = '';
                }
                activeIndex = -1;
                selectableOpts = [];
            }

            function positionProductDropdownList() {
                if (!dropdownList || !dropdownWrap) return;
                if (dropdownList.getAttribute('data-open') !== 'true') return;
                var r = dropdownWrap.getBoundingClientRect();
                dropdownList.style.width = r.width + 'px';
                dropdownList.style.top = r.bottom + 'px';
                dropdownList.style.left = r.left + 'px';
            }

            function setProductDropdownHighlight(idx) {
                if (!dropdownList) return;
                if (idx < 0 || idx >= selectableOpts.length) return;
                var children = dropdownList.querySelectorAll('.product-dropdown-item');
                children.forEach(function (el, i) {
                    el.classList.toggle('product-dropdown-item-active', i === idx);
                });
                activeIndex = idx;
                try { children[idx]?.scrollIntoView({ block: 'nearest', behavior: 'smooth' }); } catch { }
            }

            function openProductDropdown() {
                if (!dropdownList || !dropdownWrap || !input) return;
                var searchTerm = (input.value || '').trim();
                var filterQuery = getProductDropdownFilterQuery(searchTerm);
                var list = getFilteredProductOptions(filterQuery, PRODUCT_MOVEMENT_MAX, searchTerm);

                dropdownList.innerHTML = '';
                selectableOpts = [];

                var highlightIdx = 0;
                var currentVal = (input.value || '').trim();
                if (list.length > 0) {
                    for (var i = 0; i < list.length; i++) {
                        if (normalizeText((list[i].value || '').trim()) === normalizeText(currentVal)) {
                            highlightIdx = i;
                            break;
                        }
                    }
                }

                if (list.length === 0) {
                    var empty = document.createElement('div');
                    empty.className = 'product-dropdown-item text-muted py-2 px-3 small';
                    empty.textContent = searchTerm ? 'لا توجد نتائج' : ('اكتب للبحث ثم انزل بالسهم ▼ واختر (' + PRODUCT_MOVEMENT_MAX + ' كحد أقصى)');
                    dropdownList.appendChild(empty);
                    activeIndex = -1;
                } else {
                    list.forEach(function (opt, idx) {
                        var id = (opt.getAttribute('data-id') || '').toString();
                        var name = (opt.value || '').trim();
                        var it = document.createElement('div');
                        it.className = 'product-dropdown-item py-2 px-3' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                        it.setAttribute('role', 'option');
                        it.setAttribute('data-id', id);
                        it.textContent = name;
                        it.addEventListener('mouseenter', function () {
                            activeIndex = idx;
                            setProductDropdownHighlight(idx);
                        });
                        it.addEventListener('click', function (e) {
                            e.preventDefault();
                            e.stopPropagation();
                            isSelectingProduct = true;
                            fillFromProductOpt(opt);
                            closeProductDropdown();
                            setTimeout(function () {
                                try {
                                    if (input) {
                                        input.focus();
                                        input.setSelectionRange(input.value.length, input.value.length);
                                    }
                                } catch { }
                                isSelectingProduct = false;
                            }, 80);
                        });
                        dropdownList.appendChild(it);
                        selectableOpts.push(opt);
                    });
                    activeIndex = highlightIdx;
                }

                dropdownList.setAttribute('data-open', 'true');
                positionProductDropdownList();
            }

            if (input) setTimeout(function () { input.focus(); }, 150);

            if (prodDataList && input && hiddenId && dropdownList && dropdownWrap && form) {
                if (dropdownWrap && !dropdownWrap.dataset.boundProductMovementClick) {
                    dropdownWrap.dataset.boundProductMovementClick = '1';
                    dropdownWrap.addEventListener('click', function (ev) {
                        if (ev.target && ev.target.closest('#productMovementDropdownList')) return;
                    });
                }

                input.addEventListener('input', function () {
                    if (isSelectingProduct) return;
                    activeIndex = -1;
                    hiddenId.value = '';
                    openProductDropdown();
                });

                if (dropdownArrow) {
                    dropdownArrow.addEventListener('click', function (ev) {
                        ev.preventDefault();
                        input.focus();
                        openProductDropdown();
                    });
                }

                input.addEventListener('keydown', function (e) {
                    var isOpen = dropdownList && dropdownList.getAttribute('data-open') === 'true';
                    var len = selectableOpts.length || 0;

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        if (!isOpen) openProductDropdown();
                        if (!len) return;
                        var next = activeIndex < 0 ? 0 : Math.min(activeIndex + 1, len - 1);
                        setProductDropdownHighlight(next);
                        return;
                    }
                    if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        if (isOpen && len > 0) {
                            var prev = activeIndex < 0 ? 0 : Math.max(activeIndex - 1, 0);
                            setProductDropdownHighlight(prev);
                        }
                        return;
                    }
                    if (e.key === 'Enter') {
                        if (isOpen && len > 0) {
                            e.preventDefault();
                            var sel = activeIndex >= 0 && activeIndex < len ? selectableOpts[activeIndex] : selectableOpts[0];
                            if (sel) {
                                isSelectingProduct = true;
                                fillFromProductOpt(sel);
                                closeProductDropdown();
                                setTimeout(function () {
                                    try {
                                        if (input) {
                                            input.focus();
                                            input.setSelectionRange(input.value.length, input.value.length);
                                        }
                                    } catch { }
                                    isSelectingProduct = false;
                                }, 80);
                            }
                            return;
                        }
                        return;
                    }
                    if (e.key === 'Escape') closeProductDropdown();
                });

                document.addEventListener('click', function (e) {
                    if (!dropdownWrap) return;
                    if (!dropdownWrap.contains(e.target)) closeProductDropdown();
                });

                if (hiddenId && hiddenId.value) {
                    var initOpt = findProductByCode(hiddenId.value);
                    if (initOpt) fillFromProductOpt(initOpt);
                }

                form.addEventListener('submit', function (e) {
                    var txt = (input.value || '').trim();
                    if (!hiddenId.value && txt.length > 0) {
                        if (/^\d+$/.test(txt)) {
                            hiddenId.value = txt;
                        } else {
                            var exactOpt = findProductByName(txt);
                            if (!exactOpt && txt.indexOf('—') !== -1) {
                                var part = txt.split('—')[0].trim();
                                exactOpt = findProductByCode(part);
                            }
                            if (exactOpt) fillFromProductOpt(exactOpt);
                            else {
                                var fq = getProductDropdownFilterQuery(txt);
                                var cand = getFilteredProductOptions(fq, PRODUCT_MOVEMENT_MAX, txt);
                                if (cand.length === 1) fillFromProductOpt(cand[0]);
                            }
                        }
                    }

                    if (!hiddenId.value) {
                        e.preventDefault();
                        alert('من فضلك اختر صنفاً من القائمة أو أدخل كوده الرقمى ثم اضغط عرض.');
                        input.focus();
                    }
                });
            }
        })();

        (function () {
            function openPmDocInTab(tabId, url, title) {
                if (!url) return;
                try {
                    if (window.top !== window) {
                        window.top.postMessage({ type: 'erp-open-tab', tabId: tabId, url: url, title: title || 'تبويب' }, '*');
                        return;
                    }
                    if (window.erpTabs && typeof window.erpTabs.openTab === 'function') {
                        window.erpTabs.openTab(tabId, url, title || 'تبويب');
                    } else {
                        window.location.href = url;
                    }
                } catch (e) {
                    window.location.href = url;
                }
            }
            var btnView = document.getElementById('productMovementBtnView');
            var container = document.getElementById('productMovementTabsContent');
            if (!btnView || !container) return;
            function clearPmSelection() {
                container.querySelectorAll('.erp-list-selectable-row.selected').forEach(function (r) { r.classList.remove('selected'); });
                btnView.disabled = true;
            }
            container.addEventListener('click', function (e) {
                var row = e.target.closest('.erp-list-selectable-row');
                if (!row || !container.contains(row)) return;
                if (e.target.closest('a')) return;
                container.querySelectorAll('.erp-list-selectable-row').forEach(function (r) { r.classList.remove('selected'); });
                row.classList.add('selected');
                btnView.disabled = !row.getAttribute('data-show-url');
            });
            btnView.addEventListener('click', function () {
                var row = container.querySelector('.erp-list-selectable-row.selected');
                if (!row) return;
                var url = row.getAttribute('data-show-url');
                if (!url) return;
                var tabId = row.getAttribute('data-tab-id') || 'doc-show-tab';
                var title = row.getAttribute('data-tab-title') || 'عرض';
                openPmDocInTab(tabId, url, title);
            });
            document.querySelectorAll('#productMovementTabs button[data-bs-toggle="tab"]').forEach(function (b) {
                b.addEventListener('shown.bs.tab', function () { clearPmSelection(); });
            });
        })();
    </script>
}
