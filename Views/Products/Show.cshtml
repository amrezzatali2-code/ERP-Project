@model ERP.Models.Product?

@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "حركة صنف";

    // اسم الصنف المختار
    string selectedProdName = ViewBag.SelectedProdName as string ?? "";

    // الطرف (عميل/مورد)
    string selectedCustomerName = ViewBag.SelectedCustomerName as string ?? "";
    string partyKind = ViewBag.PartyKind as string ?? "all";

    // المخازن
    var warehousesList = ViewBag.Warehouses as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();

    // قيم البحث الحالية
    int? selectedProdId = ViewBag.SelectedProdId as int?;
    int? selectedWarehouseId = ViewBag.SelectedWarehouseId as int?;
    int? selectedCustomerId = ViewBag.SelectedCustomerId as int?;
    bool filterByCustomer = ViewBag.FilterByCustomer as bool? ?? false;

    DateTime? from = ViewBag.From as DateTime?;
    DateTime? to = ViewBag.To as DateTime?;

    // أرقام الملخص (نستخدم dynamic من ViewBag عشان ما يحصلش كاستنج غلط)
    var priceRetail = ViewBag.PriceRetail ?? 0m;                  // سعر الجمهور
    var weightedDiscount = ViewBag.WeightedDiscount ?? 0m;        // الخصم المرجح

    var totalQtyPurchased = ViewBag.TotalQtyPurchased ?? 0;                      // كمية المشتريات
    var totalAmountPurchased = ViewBag.TotalAmountPurchased ?? 0m;              // مبلغ المشتريات
    var totalQtyPurchaseReturned = ViewBag.TotalQtyPurchaseReturned ?? 0;       // كمية مرتجعات المشتريات
    var totalAmountPurchaseReturned = ViewBag.TotalAmountPurchaseReturned ?? 0m;// مبلغ مرتجعات المشتريات

    var totalQtySold = ViewBag.TotalQtySold ?? 0;                 // كمية المبيعات
    var totalAmountSold = ViewBag.TotalAmountSold ?? 0m;          // مبلغ المبيعات
    var totalQtyReturned = ViewBag.TotalQtyReturned ?? 0;         // كمية مردودات المبيعات
    var totalAmountReturned = ViewBag.TotalAmountReturned ?? 0m;  // مبلغ مردودات المبيعات

    var totalQtyAll = ViewBag.TotalQtyAll ?? 0;                   // إجمالى الكمية
    var netQty = ViewBag.NetQty ?? 0;                             // صافى الكمية
    var netAmount = ViewBag.NetAmount ?? 0m;                      // صافى المبلغ

    // تفاصيل الحركة والملخصات
    var lines = ViewBag.Lines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();                         // حركة مجمعة
    var salesLines = ViewBag.SalesLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();               // فواتير المبيعات
    var salesReturnLines = ViewBag.SalesReturnLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();   // مرتجعات المبيعات
    var purchaseLines = ViewBag.PurchaseLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();         // فواتير المشتريات
    var purchaseReturnLines = ViewBag.PurchaseReturnLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>(); // مرتجعات المشتريات

    var yearlySummary = ViewBag.YearlySummary as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();         // ملخص سنوات
    var warehouseSummary = ViewBag.WarehouseSummary as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();   // ملخص مخازن
}

<div class="container-fluid mt-3" dir="rtl">

    <!-- ================== شريط اختيار الصنف / المخزن / التاريخ / الطرف ================== -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h4 class="mb-3">اختيار صنف لعرض حركته</h4>

            <form method="get"
                  asp-action="Show"
                  asp-controller="Products"
                  id="productMovementForm"
                  class="row g-3 align-items-end">

                <!-- اختيار الصنف (اسم + كود) -->
                <div class="col-12 col-lg-4">
                    <label class="form-label">الصنف</label>

                    <!-- هيدن لكود الصنف -->
                    <input type="hidden"
                           name="prodId"
                           id="productSearchId"
                           value="@(selectedProdId?.ToString() ?? "")" />

                    <!-- بحث باسم الصنف -->
                    <div class="mb-1 position-relative">
                        <input type="text"
                               id="productSearchInput"
                               class="form-control form-control-sm"
                               placeholder="اكتب جزء من اسم الصنف ثم اختر من الاقتراحات..."
                               value="@selectedProdName"
                               autocomplete="off" />

                        <!-- قائمة الاقتراحات بالاسم -->
                        <div id="productSuggestions"
                             class="list-group position-absolute w-100 z-3"
                             style="max-height:260px; overflow-y:auto; display:none; top:100%;">
                        </div>
                    </div>

                    <!-- بحث بكود الصنف / الباركود -->
                    <div class="position-relative">
                        <input type="text"
                               id="productCodeInput"
                               class="form-control form-control-sm"
                               placeholder="كود الصنف / الباركود..."
                               value="@(selectedProdId?.ToString() ?? "")"
                               autocomplete="off" />

                        <!-- قائمة الاقتراحات للكود/الباركود -->
                        <div id="productCodeSuggestions"
                             class="list-group position-absolute w-100 z-3"
                             style="max-height:260px; overflow-y:auto; display:none; top:100%;">
                        </div>
                    </div>
                </div>

                <!-- فلتر الطرف (عميل / مورد) -->
                <div class="col-12 col-lg-4">
                    <label class="form-label">الطرف</label>

                    <!-- هيدن لكود الطرف -->
                    <input type="hidden"
                           name="customerId"
                           id="customerSearchId"
                           value="@(selectedCustomerId?.ToString() ?? "")" />

                    <div class="d-flex align-items-center gap-2">
                        <div class="flex-grow-1 position-relative">
                            <input type="text"
                                   id="customerSearchInput"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب اسم العميل أو المورد..."
                                   value="@selectedCustomerName"
                                   autocomplete="off" />

                            <!-- قائمة الاقتراحات للطرف -->
                            <div id="customerSuggestions"
                                 class="list-group position-absolute w-100 z-3"
                                 style="max-height:260px; overflow-y:auto; display:none; top:100%;">
                            </div>
                        </div>

                        <!-- نوع الطرف: عميل / مورد / الكل -->
                      <select name="partyKind"
        class="form-select form-select-sm"
        style="width:120px;">
    <option value="all"
            selected="@(partyKind == "all" ? "selected" : null)">
        الكل
    </option>

    <option value="customer"
            selected="@(partyKind == "customer" ? "selected" : null)">
        عميل
    </option>

    <option value="supplier"
            selected="@(partyKind == "supplier" ? "selected" : null)">
        مورد
    </option>
</select>



                        <!-- تفعيل الفلتر -->
                        <div class="form-check mt-1">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="chkFilterByCustomer"
                                   name="filterByCustomer"
                                   value="true"
                                   @(filterByCustomer && selectedCustomerId.HasValue ? "checked" : null) />
                            <label class="form-check-label small" for="chkFilterByCustomer">
                                فلتر
                            </label>
                        </div>
                    </div>
                </div>

                <!-- المخزن -->
                <div class="col-12 col-lg-4">
                    <label class="form-label">المخزن</label>
                    <select name="warehouseId"
                            class="form-select form-select-sm">
                        <option value="">كل المخازن</option>
                        @foreach (var w in warehousesList)
                        {
                            var selected = (selectedWarehouseId.HasValue && w.Value == selectedWarehouseId.Value.ToString())
                                ? "selected"
                                : null;

                            <option value="@w.Value" selected="@selected">@w.Text</option>
                        }
                    </select>
                </div>

                <!-- من تاريخ -->
                <div class="col-6 col-md-3 col-lg-2">
                    <label class="form-label">من تاريخ</label>
                    <input type="date"
                           name="from"
                           value="@(from.HasValue ? from.Value.ToString("yyyy-MM-dd") : "")"
                           class="form-control form-control-sm" />
                </div>

                <!-- إلى تاريخ -->
                <div class="col-6 col-md-3 col-lg-2">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date"
                           name="to"
                           value="@(to.HasValue ? to.Value.ToString("yyyy-MM-dd") : "")"
                           class="form-control form-control-sm" />
                </div>

                <!-- زر عرض -->
                <div class="col-12 col-md-3 col-lg-2 d-grid">
                    <button class="btn btn-erp btn-erp-primary btn-erp-sm">
                        عرض
                    </button>
                </div>

            </form>
        </div>
    </div>

    @* لو مفيش صنف مختار *@
    @if (Model == null)
    {
        <div class="alert alert-light border text-muted">
            برجاء اختيار صنف من أعلى الصفحة ثم الضغط على زر <strong>عرض</strong> لظهور حركة الصنف.
        </div>
    }
    else
    {
        <!-- ================== بطاقة بيانات الصنف ================== -->
        <div class="card mb-3 shadow-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h3 class="mb-1">@Model.ProdName</h3>
                        <p class="text-muted mb-2">
                            كود الصنف:
                            <strong>@Model.ProdId</strong>
                            @if (Model.Category != null)
                            {
                                @: &nbsp;|&nbsp;
                                @:التصنيف:
                                <strong>@Model.Category.CategoryName</strong>
                            }
                        </p>
                    </div>

                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                       
                    </div>
                </div>
            </div>
        </div>

        <!-- ================== كروت الملخص (سعر/خصم/مشتريات/مبيعات...) ================== -->

        <!-- سعر الجمهور + الخصم المرجح -->
        <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">سعر الجمهور</div>
                        <div class="fs-4 fw-bold">
                            @((decimal)priceRetail)
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">الخصم المرجّح</div>
                        <div class="fs-4 fw-bold">
                            @(((decimal)weightedDiscount).ToString("0.00")) %
                        </div>
                        <div class="small text-muted mt-1">
                            (سيتم حسابه لاحقاً من بيانات المبيعات)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- مشتريات + مرتجعات مشتريات -->
        <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">كمية المشتريات</div>
                        <div class="fs-4 fw-bold">@totalQtyPurchased</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">مبلغ المشتريات</div>
                        <div class="fs-4 fw-bold">
                            @(((decimal)totalAmountPurchased).ToString("0.00"))
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">كمية مرتجعات المشتريات</div>
                        <div class="fs-4 fw-bold">@totalQtyPurchaseReturned</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">مبلغ مرتجعات المشتريات</div>
                        <div class="fs-4 fw-bold">
                            @(((decimal)totalAmountPurchaseReturned).ToString("0.00"))
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- مبيعات + مرتجعات مبيعات -->
        <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">كمية المبيعات</div>
                        <div class="fs-4 fw-bold">@totalQtySold</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">مبلغ المبيعات</div>
                        <div class="fs-4 fw-bold">
                            @(((decimal)totalAmountSold).ToString("0.00"))
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">كمية مرتجعات المبيعات</div>
                        <div class="fs-4 fw-bold text-danger">@totalQtyReturned</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">مبلغ مرتجعات المبيعات</div>
                        <div class="fs-4 fw-bold text-danger">
                            @(((decimal)totalAmountReturned).ToString("0.00"))
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- إجمالى وصافى -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-4">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">إجمالى الكمية</div>
                        <div class="fs-4 fw-bold">@totalQtyAll</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-4">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">صافى الكمية</div>
                        <div class="fs-4 fw-bold">@netQty</div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-4">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <div class="text-muted small mb-1">صافى المبلغ</div>
                        <div class="fs-4 fw-bold">
                            @(((decimal)netAmount).ToString("0.00"))
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ================== التابات: حركة / مبيعات / مشتريات ================== -->
        <ul class="nav nav-tabs mb-3" id="movementTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active"
                        id="tab-all-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#tab-all"
                        type="button"
                        role="tab">
                    الحركة المجمّعة
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link"
                        id="tab-sales-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#tab-sales"
                        type="button"
                        role="tab">
                    فواتير المبيعات
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link"
                        id="tab-salesret-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#tab-salesret"
                        type="button"
                        role="tab">
                    مرتجعات المبيعات
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link"
                        id="tab-purch-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#tab-purch"
                        type="button"
                        role="tab">
                    فواتير المشتريات
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link"
                        id="tab-purchret-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#tab-purchret"
                        type="button"
                        role="tab">
                    مرتجعات المشتريات
                </button>
            </li>
        </ul>

        <div class="tab-content mb-4" id="movementTabsContent">
            <!-- تبويب: الحركة المجمعة -->
            <div class="tab-pane fade show active" id="tab-all" role="tabpanel">
                <div class="card shadow-sm mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong>تفاصيل الحركة المجمّعة</strong>
                        <small class="text-muted">
                            @(from.HasValue ? from.Value.ToString("yyyy/MM/dd") : "بداية المدة")
                            -
                            @(to.HasValue ? to.Value.ToString("yyyy/MM/dd") : "نهاية المدة")
                        </small>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive mb-0">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:130px;">التاريخ</th>
                                        <th style="width:140px;">رقم المستند</th>
                                        <th>الطرف</th>
                                        <th class="text-end" style="width:130px;">الكمية</th>
                                        <th class="text-end" style="width:150px;">المبلغ</th>
                                        <th style="width:100px;">نوع الحركة</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (lines.Any())
                                    {
                                        foreach (var r in lines)
                                        {
                                            <tr>
                                                <td>@r.Date.ToString("yyyy/MM/dd")</td>
                                                <td>@r.DocNo</td>
                                                <td>@r.Customer</td>
                                                <td class="text-end">@r.Qty</td>
                                                <td class="text-end">
                                                    @(((decimal)r.Amount).ToString("0.00"))
                                                </td>
                                                <td>@r.Kind</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-4">
                                                لا توجد بيانات حركة فى المدى المحدد.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ملخصات السنوات والمخازن داخل نفس التاب -->
                <div class="row g-3">
                    <div class="col-12 col-lg-7">
                        <div class="card shadow-sm h-100">
                            <div class="card-header">
                                ملخص الحركة حسب السنوات
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive mb-0">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>السنة</th>
                                                <th class="text-end">كمية المبيعات</th>
                                                <th class="text-end">كمية المرتجعات</th>
                                                <th class="text-end">صافى الكمية</th>
                                                <th class="text-end">صافى المبلغ</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (yearlySummary.Any())
                                            {
                                                foreach (var y in yearlySummary)
                                                {
                                                    <tr>
                                                        <td>@y.Year</td>
                                                        <td class="text-end">@y.QtySold</td>
                                                        <td class="text-end">@y.QtyReturned</td>
                                                        <td class="text-end">@y.NetQty</td>
                                                        <td class="text-end">
                                                            @(((decimal)y.NetAmount).ToString("0.00"))
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="5" class="text-center text-muted py-3">
                                                        لم يتم إعداد ملخص السنوات بعد.
                                                        <br />
                                                        <small>سيتم ربطه لاحقاً من بيانات StockLedger.</small>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-lg-5">
                        <div class="card shadow-sm h-100">
                            <div class="card-header">
                                رصيد الصنف حسب المخازن
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive mb-0">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>المخزن</th>
                                                <th class="text-end">الكمية</th>
                                                <th class="text-end">صافى المبلغ</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (warehouseSummary.Any())
                                            {
                                                foreach (var w in warehouseSummary)
                                                {
                                                    <tr>
                                                        <td>@w.WarehouseName</td>
                                                        <td class="text-end">@w.NetQty</td>
                                                        <td class="text-end">
                                                            @(((decimal)w.NetAmount).ToString("0.00"))
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="3" class="text-center text-muted py-3">
                                                        لم يتم إعداد ملخص المخازن بعد.
                                                        <br />
                                                        <small>لاحقاً سيُحسب من StockLedger / StockBatch.</small>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- تبويب: فواتير المبيعات -->
            <div class="tab-pane fade" id="tab-sales" role="tabpanel">
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong>فواتير المبيعات لهذا الصنف</strong>
                        <small class="text-muted">
                            @(from.HasValue ? from.Value.ToString("yyyy/MM/dd") : "بداية المدة")
                            -
                            @(to.HasValue ? to.Value.ToString("yyyy/MM/dd") : "نهاية المدة")
                        </small>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive mb-0">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:130px;">التاريخ</th>
                                        <th style="width:140px;">رقم الفاتورة</th>
                                        <th>العميل</th>
                                        <th class="text-end" style="width:110px;">الكمية</th>
                                        <th class="text-end" style="width:110px;">سعر الوحدة</th>
                                        <th class="text-end" style="width:110px;">الخصم %</th>
