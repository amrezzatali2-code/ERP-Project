@section Scripts {
    <script>
        (function () {
            // =========================================================
            // أوتوكومبليت الأصناف (مثل حجم التعامل)
            // =========================================================
            var productsData = @Html.Raw(productsJson);
            var input = document.getElementById('productSearchInput');
            var hiddenId = document.getElementById('productSearchId');
            var list = document.getElementById('productSuggestions');
            var form = document.getElementById('productMovementForm');
            var activeIndex = -1;

            if (input) setTimeout(function () { input.focus(); }, 150);

            if (input && hiddenId && list && form) {
                input.addEventListener('input', function () {
                    var term = input.value.trim();
                    hiddenId.value = "";
                    activeIndex = -1;

                    if (term.length < 1) {
                        list.style.display = 'none';
                        list.innerHTML = '';
                        return;
                    }

                    var termLower = term.toLowerCase();
                    var results = productsData.filter(function (item) {
                        var codeMatch = item.code && item.code.indexOf(term) !== -1;
                        var nameMatch = item.name && item.name.toLowerCase().indexOf(termLower) !== -1;
                        return codeMatch || nameMatch;
                    });

                    list.innerHTML = '';

                    if (!results || results.length === 0) {
                        list.style.display = 'none';
                        return;
                    }

                    results.slice(0, 30).forEach(function (item) {
                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'list-group-item list-group-item-action';
                        btn.dataset.id = item.id;
                        btn.textContent = item.code + ' — ' + item.name;

                        btn.addEventListener('click', function () {
                            hiddenId.value = item.id;
                            input.value = item.code + ' — ' + item.name;
                            list.style.display = 'none';
                        });

                        list.appendChild(btn);
                    });

                    list.style.display = 'block';
                });

                input.addEventListener('keydown', function (e) {
                    var items = list.querySelectorAll('button');
                    if (list.style.display !== 'block' || items.length === 0) return;

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        activeIndex = (activeIndex + 1) % items.length;
                        items.forEach(function (el) { el.classList.remove('active'); });
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            items[activeIndex].classList.add('active');
                            items[activeIndex].scrollIntoView({ block: 'nearest' });
                        }
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        activeIndex = (activeIndex - 1 + items.length) % items.length;
                        items.forEach(function (el) { el.classList.remove('active'); });
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            items[activeIndex].classList.add('active');
                            items[activeIndex].scrollIntoView({ block: 'nearest' });
                        }
                    } else if (e.key === 'Enter') {
                        if (activeIndex >= 0 && activeIndex < items.length) {
                            e.preventDefault();
                            items[activeIndex].click();
                        }
                    } else if (e.key === 'Escape') {
                        list.style.display = 'none';
                    }
                });

                document.addEventListener('click', function (e) {
                    if (!list.contains(e.target) && e.target !== input) {
                        list.style.display = 'none';
                    }
                });

                form.addEventListener('submit', function (e) {
                    if (!hiddenId.value) {
                        var txt = input.value.trim();
                        if (/^\d+$/.test(txt)) {
                            hiddenId.value = txt;
                        } else if (txt.length > 0) {
                            var exactMatch = productsData.find(function (item) {
                                return item.name.toLowerCase() === txt.toLowerCase() ||
                                    item.code === txt ||
                                    (item.code + ' — ' + item.name) === txt;
                            });
                            if (exactMatch) {
                                hiddenId.value = exactMatch.id.toString();
                                input.value = exactMatch.code + ' — ' + exactMatch.name;
                            } else {
                                var matches = productsData.filter(function (item) {
                                    var codeMatch = item.code && item.code.indexOf(txt) !== -1;
                                    var nameMatch = item.name && item.name.toLowerCase().indexOf(txt.toLowerCase()) !== -1;
                                    return codeMatch || nameMatch;
                                });
                                if (matches.length === 1) {
                                    hiddenId.value = matches[0].id.toString();
                                    input.value = matches[0].code + ' — ' + matches[0].name;
                                }
                            }
                        }
                    }

                    if (!hiddenId.value) {
                        e.preventDefault();
                        alert('من فضلك اختر صنف من قائمة الاقتراحات أو أدخل كوده الرقمى.');
                        input.focus();
                    }
                });
            }
        })();
    </script>
}
