@model ERP.Models.Product?

@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "حركة صنف";

    // نفس فاتورة المبيعات: حقل البحث يعرض اسم الصنف فقط (الكود في hidden)
    var selectedProductDisplay = Model?.ProdName ?? "";

    // الطرف (عميل/مورد)
    string selectedCustomerName = ViewBag.SelectedCustomerName as string ?? "";
    string partyKind = ViewBag.PartyKind as string ?? "all";

    // المخازن
    var warehousesList = ViewBag.Warehouses as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();

    // قيم البحث الحالية
    int? selectedProdId = ViewBag.SelectedProdId as int?;
    int? selectedWarehouseId = ViewBag.SelectedWarehouseId as int?;
    int? selectedCustomerId = ViewBag.SelectedCustomerId as int?;
    bool filterByCustomer = ViewBag.FilterByCustomer as bool? ?? false;

    DateTime? from = ViewBag.From as DateTime?;
    DateTime? to = ViewBag.To as DateTime?;

    // أرقام الملخص (نستخدم dynamic من ViewBag عشان ما يحصلش كاستنج غلط)
    var priceRetail = ViewBag.PriceRetail ?? 0m;                  // سعر الجمهور
    var weightedDiscount = ViewBag.WeightedDiscount ?? 0m;        // الخصم المرجح

    var totalQtyPurchased = ViewBag.TotalQtyPurchased ?? 0;                      // كمية المشتريات
    var totalAmountPurchased = ViewBag.TotalAmountPurchased ?? 0m;              // مبلغ المشتريات
    var totalQtyPurchaseReturned = ViewBag.TotalQtyPurchaseReturned ?? 0;       // كمية مرتجعات المشتريات
    var totalAmountPurchaseReturned = ViewBag.TotalAmountPurchaseReturned ?? 0m;// مبلغ مرتجعات المشتريات

    var totalQtySold = ViewBag.TotalQtySold ?? 0;                 // كمية المبيعات
    var totalAmountSold = ViewBag.TotalAmountSold ?? 0m;          // مبلغ المبيعات
    var totalQtyReturned = ViewBag.TotalQtyReturned ?? 0;         // كمية مردودات المبيعات
    var totalAmountReturned = ViewBag.TotalAmountReturned ?? 0m;  // مبلغ مردودات المبيعات

    var totalQtyAll = ViewBag.TotalQtyAll ?? 0;                   // إجمالى الكمية
    var netQty = Math.Max(0, (int)(ViewBag.NetQty ?? 0));       // صافي الكمية — لا يُعرض سالب
    var netAmount = ViewBag.NetAmount ?? 0m;                      // صافى المبلغ
    var openingQty = (int)(ViewBag.OpeningQty ?? 0);             // كمية رصيد أول المدة (Opening)

    // تفاصيل الحركة والملخصات
    var lines = ViewBag.Lines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();                         // حركة مجمعة
    var salesLines = ViewBag.SalesLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();               // فواتير المبيعات
    var salesReturnLines = ViewBag.SalesReturnLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();   // مرتجعات المبيعات
    var purchaseLines = ViewBag.PurchaseLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();         // فواتير المشتريات
    var purchaseReturnLines = ViewBag.PurchaseReturnLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>(); // مرتجعات المشتريات

    var adjustmentLines = ViewBag.AdjustmentLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();     // تسويات جردية
    var purchaseRequestLines = ViewBag.PurchaseRequestLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>(); // طلبات الشراء
    var transferLines = ViewBag.TransferLines as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();         // تحويلات بين المخازن

    var yearlySummary = ViewBag.YearlySummary as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();         // ملخص سنوات
    var warehouseSummary = ViewBag.WarehouseSummary as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();   // ملخص مخازن

    // إجماليات أسفل جداول حركة الصنف (نفس الفترة المعروضة)
    int pmSalesQtyTotal = 0; decimal pmSalesNetTotal = 0;
    foreach (var x in salesLines) { pmSalesQtyTotal += (int)x.Qty; pmSalesNetTotal += (decimal)x.NetAmount; }
    int pmPurQtyTotal = 0; decimal pmPurAmtTotal = 0;
    foreach (var x in purchaseLines) { pmPurQtyTotal += (int)x.Qty; pmPurAmtTotal += (decimal)x.Amount; }
    int pmSrQtyTotal = 0; decimal pmSrAmtTotal = 0;
    foreach (var x in salesReturnLines) { pmSrQtyTotal += (int)x.Qty; pmSrAmtTotal += (decimal)x.Amount; }
    int pmPrQtyTotal = 0; decimal pmPrAmtTotal = 0;
    foreach (var x in purchaseReturnLines) { pmPrQtyTotal += (int)x.Qty; pmPrAmtTotal += (decimal)x.Amount; }
    int pmAdjDiffTotal = 0;
    foreach (var x in adjustmentLines) { pmAdjDiffTotal += (int)x.QtyDiff; }
    decimal pmPrReqQtyR = 0, pmPrReqQtyRc = 0;
    foreach (var x in purchaseRequestLines) { pmPrReqQtyR += Convert.ToDecimal(x.QtyRequested); pmPrReqQtyRc += Convert.ToDecimal(x.QtyReceived); }
    int pmTrQtyTotal = 0;
    foreach (var x in transferLines) { pmTrQtyTotal += (int)x.Qty; }
}

<style>
    /* تحسينات التصميم — نفس حجم التعامل */
    .product-dashboard {
        min-height: calc(100vh - 120px);
        display: flex;
        flex-direction: column;
    }
    
    .dashboard-header {
        flex-shrink: 0;
        padding: 0.5rem 0;
    }
    
    .dashboard-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }
    
    .compact-card {
        padding: 0.75rem;
        margin-bottom: 0.5rem;
    }
    
    .compact-stat {
        font-size: 1.1rem;
        font-weight: 600;
        line-height: 1.2;
    }
    
    .compact-label {
        font-size: 0.75rem;
        margin-bottom: 0.25rem;
    }
    
    .product-info-compact {
        font-size: 0.85rem;
    }
    
    .table-compact {
        font-size: 0.85rem;
    }
    
    .table-compact th,
    .table-compact td {
        padding: 0.35rem 0.5rem;
    }

    /* هيدر الجداول ثابت عند التمرير */
    #productMovementTabsContent .table-responsive thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #f8f9fa !important;
        box-shadow: 0 1px 0 0 #dee2e6;
    }
    
    .nav-tabs-compact {
        font-size: 0.8rem;
        padding: 0.25rem 0.5rem;
    }
    
    /* ✅ إصلاح عرض التبويبات مع Flexbox */
    #productMovementTabsContent.tab-content {
        position: relative;
        min-height: 0;
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    
    #productMovementTabsContent .tab-pane {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        min-height: 0;
        display: none !important;
    }
    
    /* ✅ Bootstrap tabs يعيد display: block للـ .tab-pane.active، لذا نستخدم !important */
    #productMovementTabsContent .tab-pane:not(.active):not(.show) {
        display: none !important;
        visibility: hidden;
    }
    
    #productMovementTabsContent .tab-pane.active,
    #productMovementTabsContent .tab-pane.active.show {
        display: flex !important;
        flex-direction: column;
        visibility: visible;
        position: relative;
    }

    .product-movement-unified-card {
        border: 1px solid #6366f1 !important;
        border-radius: 12px !important;
        box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
    }

    /* شارة كود الصنف — نفس حجم التعامل (كود العميل) */
    .customer-code-badge {
        border: 2px solid currentColor !important;
        border-radius: 0.55rem !important;
        padding: 0.35rem 0.6rem !important;
        box-shadow: none !important;
        background: transparent !important;
        color: inherit !important;
        font-weight: 700;
        font-size: 0.95rem;
        white-space: nowrap;
        line-height: 1.1;
    }
    #productMovementTabsContent .erp-list-selectable-row { cursor: pointer; }
    #productMovementTabsContent .erp-list-selectable-row.selected > td {
        background: rgba(99, 102, 241, 0.12) !important;
    }
    
    /* بطاقات الملخص: نفس حجم التعامل */
    .product-summary-cards {
        display: flex;
        flex-wrap: nowrap;
        justify-content: center;
        align-items: stretch;
        direction: rtl;
        gap: 0.5rem;
    }
    .product-summary-cards .customer-stat-card {
        flex: 0 0 130px;
        min-width: 130px;
        max-width: 130px;
    }
    .product-summary-cards .customer-stat-card .card {
        width: 100%;
        min-width: 130px;
    }
    .product-summary-cards .compact-label { font-size: 0.75rem !important; }
    .product-summary-cards .compact-stat { font-size: 1.05rem !important; }

    /* بطاقة صافي الكمية: حدود مميزة وأكبر مثل حجم التعامل */
    .product-balance-card {
        flex: 0 0 160px !important;
        min-width: 160px !important;
        max-width: 160px !important;
    }
    .product-balance-card .card {
        min-width: 160px !important;
    }
    .customer-balance-card {
        border: 2px solid #0d6efd !important;
        box-shadow: 0 2px 8px rgba(13, 110, 253, 0.25) !important;
        background: linear-gradient(to bottom, #f8fafc 0%, #fff 100%) !important;
    }
    .customer-balance-value {
        font-size: 1.25rem !important;
        font-weight: 700 !important;
        letter-spacing: 0.02em;
    }

    /* دروب داون الصنف — نفس نمط حجم التعامل / فاتورة المبيعات */
    #productMovementDropdownWrap {
        border: 2px solid #4f46e5 !important;
        border-radius: 0.55rem !important;
        padding: 3px !important;
        box-shadow: none !important;
    }
    #productMovementDropdownWrap:focus-within {
        border-color: #4338ca !important;
        box-shadow: none !important;
    }
    #productMovementDropdownWrap .product-dropdown-onebox {
        border: 0 !important;
        background: transparent !important;
        border-radius: 0.45rem !important;
    }
    #productMovementDropdownWrap .product-dropdown-onebox {
        position: relative;
    }
    #productMovementDropdownWrap .product-dropdown-arrow-inside {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #495057;
        cursor: pointer;
        user-select: none;
        font-size: 0.6rem;
        z-index: 1;
    }
    #productMovementDropdownWrap .product-dropdown-onebox .product-dropdown-input {
        width: 100%;
        border: none !important;
        background: transparent !important;
        padding-left: 2.25rem !important;
    }
    #productMovementDropdownWrap .product-dropdown-onebox .product-dropdown-input:focus {
        box-shadow: none !important;
        outline: none !important;
    }
    #productMovementDropdownList.product-dropdown-list {
        position: fixed;
        max-height: 220px;
        min-height: 40px;
        overflow-y: auto;
        z-index: 9999;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        background: #fff;
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
    }
    #productMovementDropdownList[data-open="false"] {
        display: none !important;
    }
    #productMovementDropdownList[data-open="true"] {
        display: block !important;
    }
    #productMovementDropdownList .product-dropdown-item {
        cursor: pointer;
        border-bottom: 1px solid #f0f0f0;
        padding: 0.35rem 0.55rem;
    }
    #productMovementDropdownList .product-dropdown-item:hover {
        background-color: #f8f9fa;
    }
    #productMovementDropdownList .product-dropdown-item:last-child {
        border-bottom: none;
    }
    #productMovementDropdownList .product-dropdown-item-active {
        background-color: #0d6efd !important;
        color: #fff !important;
    }
</style>

<div class="container-fluid product-dashboard" dir="rtl">

    @* =====================================================
       1) شريط اختيار الصنف + فترة التاريخ (نفس حجم التعامل)
       ===================================================== *@
    <div class="dashboard-header">
        <div class="erp-list-filter-bar d-print-none mt-2">
            <form id="productMovementForm"
                  method="get"
                  asp-action="Show"
                  asp-controller="Products"
                  class="row g-3 align-items-end"
                  autocomplete="off">

                <input type="hidden" id="productSearchId" name="prodId" value="@(selectedProdId?.ToString() ?? "")" />
                <input type="hidden" id="customerSearchId" name="customerId" value="@(selectedCustomerId?.ToString() ?? "")" />

                <div class="col-12 col-lg-4 erp-filter-section">
                    <label class="form-label">بحث بالكود أو الاسم</label>
                    <div class="position-relative" id="productMovementDropdownWrap">
                        <div class="product-dropdown-onebox" id="productMovementDropdownInputGroup">
                            <span class="product-dropdown-arrow-inside" id="productMovementDropdownArrow" title="افتح القائمة">▼</span>
                            <input id="productSearchInput"
                                   type="text"
                                   class="form-control erp-filter-input product-dropdown-input"
                                   placeholder="اكتب اسم الصنف"
                                   autocomplete="off"
                                   title="بحث مثل فاتورة المبيعات: عدة كلمات، أرقام عربية، تطبيع الألف"
                                   value="@selectedProductDisplay" />
                        </div>
                        <div id="productMovementDropdownList"
                             class="product-dropdown-list"
                             role="listbox"
                             data-open="false"></div>
                    </div>
                    <datalist id="productsMovementList" hidden aria-hidden="true">
                        @if (ViewBag.ProductsAuto != null)
                        {
                            foreach (var p in ViewBag.ProductsAuto)
                            {
                                <option value="@p.Name"
                                        data-id="@p.Id"
                                        data-code="@p.Id"
                                        data-generic="@p.GenericName"></option>
                            }
                        }
                    </datalist>
                </div>

                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">المخزن</label>
                    <select name="warehouseId" class="form-select erp-filter-input">
                        <option value="">كل المخازن</option>
                        @foreach (var w in warehousesList)
                        {
                            var sel = selectedWarehouseId.HasValue && w.Value == selectedWarehouseId.Value.ToString();
                            <option value="@w.Value" @(sel ? "selected" : null)>@w.Text</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">من تاريخ</label>
                    <input type="date"
                           name="from"
                           dir="ltr"
                           class="form-control erp-filter-input"
                           placeholder="yyyy-mm-dd"
                           value="@(from?.ToString("yyyy-MM-dd") ?? "")" />
                </div>

                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date"
                           name="to"
                           dir="ltr"
                           class="form-control erp-filter-input"
                           placeholder="yyyy-mm-dd"
                           value="@(to?.ToString("yyyy-MM-dd") ?? "")" />
                </div>

                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label d-none d-md-block" style="visibility:hidden">عرض</label>
                    <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm w-100">
                        عرض
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* =====================================================
       2) لو لم يتم اختيار صنف بعد
       ===================================================== *@
    @if (Model == null)
    {
        <div class="alert alert-light border text-muted text-center">
            برجاء اختيار صنف من أعلى الصفحة ثم اضغط زر <strong>عرض</strong>.
        </div>
    }
    else
    {
    <div class="dashboard-content">
        @* =====================================================
           3) كارت علوي — اسم الصنف + كود الصنف + الأزرار (مثل حجم التعامل)
           ===================================================== *@
        <div class="card product-movement-unified-card mb-2 flex-shrink-0">
            <div class="card-body p-2 p-md-3 d-flex flex-column gap-2">
        <div class="flex-shrink-0">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div>
                    <div class="d-flex flex-wrap align-items-center gap-3">
                        <h4 class="mb-0 fw-bold" style="font-size: 1.4rem;">@Model.ProdName</h4>
                        <div class="customer-code-badge" title="كود الصنف">
                            كود: @Model.ProdId
                        </div>
                    </div>
                    @if (Model.Classification != null)
                    {
                        <small class="text-muted">التصنيف: @Model.Classification.Name</small>
                    }
                </div>
                <div class="d-flex flex-wrap gap-2 flex-nowrap align-items-center" dir="rtl">
                    <button type="button" id="productMovementBtnView" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="عرض المستند المحدد">عرض</button>
                    <a asp-action="Edit" asp-route-id="@Model.ProdId"
                       class="btn btn-erp btn-outline-primary btn-erp-sm app-menu-link"
                       data-tab-id="product-edit-tab"
                       data-tab-title="تعديل صنف">✏️ تعديل</a>
                    <a asp-action="Index" class="btn btn-erp btn-outline-info btn-erp-sm">
                        قائمة الأصناف
                    </a>
                </div>
            </div>
        </div>

            </div>
        </div>

        @* =====================================================
           4) كارت وسط — بطاقات الملخص فقط (بين الهيدر والجداول)
           ===================================================== *@
        <div class="card product-movement-unified-card mb-2 flex-shrink-0">
            <div class="card-body p-2 p-md-3">
        <div class="row g-1 flex-nowrap product-summary-cards flex-shrink-0" style="overflow-x: auto; direction: rtl;">
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">كمية أول المدة</div>
                        <div class="compact-stat text-secondary" style="font-size: 0.95rem;">@openingQty</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">كمية المبيعات</div>
                        <div class="compact-stat text-success" style="font-size: 0.95rem;">@totalQtySold</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">مبلغ المبيعات</div>
                        <div class="compact-stat text-success" style="font-size: 0.85rem;">@(((decimal)totalAmountSold).ToString("N2"))</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">كمية المشتريات</div>
                        <div class="compact-stat text-primary" style="font-size: 0.95rem;">@totalQtyPurchased</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">مبلغ المشتريات</div>
                        <div class="compact-stat text-primary" style="font-size: 0.85rem;">@(((decimal)totalAmountPurchased).ToString("N2"))</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">مرتجعات البيع</div>
                        <div class="compact-stat text-success" style="font-size: 0.95rem;">@totalQtyReturned</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">مرتجعات الشراء</div>
                        <div class="compact-stat text-primary" style="font-size: 0.95rem;">@totalQtyPurchaseReturned</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">سعر الجمهور</div>
                        <div class="compact-stat" style="font-size: 0.95rem; color: #6366f1;">@(((decimal)priceRetail).ToString("N2"))</div>
                    </div>
                </div>
            </div>
            <div class="col-auto customer-stat-card">
                <div class="card compact-card text-center shadow-sm">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">الخصم المرجّح</div>
                        <div class="compact-stat text-info" style="font-size: 0.95rem;">@(((decimal)weightedDiscount).ToString("0.00"))%</div>
                    </div>
                </div>
            </div>
            <div class="col-auto product-balance-card">
                <div class="card compact-card text-center shadow-sm customer-balance-card">
                    <div class="card-body p-1">
                        <div class="compact-label text-muted" style="font-size: 0.65rem;">صافى الكمية</div>
                        <div class="compact-stat customer-balance-value" style="font-size: 1.25rem;">@netQty</div>
                    </div>
                </div>
            </div>
        </div>

            </div>
        </div>

        @* =====================================================
           5) كارت سفلي — التبويبات والجداول
           ===================================================== *@
        <div class="card product-movement-unified-card mb-2 flex-grow-1 d-flex flex-column" style="min-height: 280px;">
            <div class="card-body p-2 p-md-3 d-flex flex-column gap-2" style="min-height: 0;">
        <div class="flex-grow-1 d-flex flex-column mt-1" style="min-height: 280px;">
            <div class="p-2 w-100" style="flex-shrink: 0;">
                <div class="d-flex justify-content-start align-items-center w-100" style="direction: rtl;">
                    <div class="overflow-x-auto" style="white-space: nowrap; max-width: 100%;">
                        <ul class="nav nav-pills nav-sm flex-nowrap" id="productMovementTabs" role="tablist" style="direction: rtl;">
                            <li class="nav-item"><button class="nav-link active nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-sales">المبيعات</button></li>
                            <li class="nav-item"><button class="nav-link nav-tabs-compact" data-bs-toggle="tab" data-bs-target="#tab-purchases">المشتريات</button></li>
