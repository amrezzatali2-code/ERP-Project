<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    @* ===== الأساسيات ===== *@
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - ERP</title>

    @* Bootstrap + CSS الرئيسي *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @* خط عربي *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap"
          rel="stylesheet">

    @* سيكشن ستايل إضافي من أى View *@
    @RenderSection("Styles", required: false)

    @* كود صغير يضيف كلاس in-frame لو الصفحة داخل IFRAME *@
    <script>
        (function () {
            try {
                if (window.self !== window.top) {
                    document.documentElement.classList.add('in-frame');
                }
            } catch (e) { }
        })();
    </script>

    <style>
        /* خط عربي عام */
        body {
            font-family: "Cairo", system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
        }

        .nowrap {
            white-space: nowrap;
        }

        /* ===== تثبيت النافبار أعلى الشاشة ===== */
        header {
            position: sticky; /* يثبت أعلى الصفحة عند الاسكرول */
            top: 0;
            z-index: 1050; /* فوق أى عناصر أخرى */
        }

        /* ===== شريط التابات — أصغر + التابات في المنتصف + radius أقل ===== */
        .app-tabs-bar {
            display: flex;
            direction: rtl;
            flex-direction: row;
            justify-content: flex-start;
            align-items: center;
            gap: 0.35rem;
            border-bottom: 1px solid #e5e7eb;
            padding: 0.2rem 0;
            margin-bottom: 0;
            overflow-x: auto;
            min-height: 36px;
        }

        .app-tab {
            display: inline-flex;
            align-items: center;
            gap: 0.2rem;
            border-radius: 0.3rem;
            padding-inline: 0.6rem;
            padding-block: 0.2rem;
            white-space: nowrap;
            border: 1px solid #e5e7eb;
            background-color: #f9fafb;
            font-size: 0.8rem;
        }

            .app-tab.active {
                background-color: #0d6efd;
                color: #ffffff;
                border-color: #0d6efd;
            }

        .app-tab-close {
            font-size: 0.85rem;
            cursor: pointer;
        }

        /* حاوية الإطارات: تبدأ بارتفاع صفر (لا فراغ) */
        .app-tabs-container {
            position: relative;
            height: 0;
            margin-bottom: 0;
            overflow: hidden;
        }

        /* عندما يكون هناك تابات (body.has-tabs) نعرض مساحة للإطارات */
        body.has-tabs .app-tabs-container {
            height: calc(100vh - 120px); /* ارتفاع الشاشة ناقص النافبار والتابات */
            margin-bottom: 0.5rem;
        }

        .app-tab-frame {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            border: none;
            background-color: #ffffff;
        }

        /* عندما تكون الصفحة داخل IFRAME: نخفي النافبار والتابات نهائياً */
        html.in-frame header {
            display: none;
        }

        html.in-frame #appTabsBar,
        html.in-frame #appTabsContainer {
            display: none !important;
        }

        html.in-frame main {
            padding-top: 1rem;
        }
    </style>
</head>

