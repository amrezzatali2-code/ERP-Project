    @* ================= التابات + محتوى الصفحة الرئيسية ================= *@
    <main role="main" class="container-fluid py-3">
        <div id="appTabsBar" class="app-tabs-bar">
            @* يتم ملؤه من site.js *@
        </div>

        <div id="appTabsContainer" class="app-tabs-container">
        </div>


        @* =========================================================
   رسائل عامة (TempData) تظهر في كل الصفحات
   - SuccessMessage: رسالة نجاح
   - ErrorMessage  : رسالة خطأ
   - WarningMessage: تحذير (اختياري)
   ========================================================= *@
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert" dir="rtl">
                <strong>خطأ:</strong> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mt-2" role="alert" dir="rtl">
                <strong>تم:</strong> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show mt-2" role="alert" dir="rtl">
                <strong>تنبيه:</strong> @TempData["WarningMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }



        <div id="homeContent" class="mt-1">
            @RenderBody()
        </div>
    </main>

    @* ================= سكربتات JS ================= *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>








    <script>
        (function () {

            // =========================
            // (A) أدوات مساعدة
            // =========================
            function setOrReplaceParam(url, key, value) {
                try {
                    const u = new URL(url, window.location.origin);
                    u.searchParams.set(key, value);
                    return u.toString();
                } catch {
                    const sep = url.includes('?') ? '&' : '?';
                    const has = new RegExp('[?&]' + key + '=').test(url);
                    if (has) return url.replace(new RegExp('([?&]' + key + '=)[^&]*'), '$1' + encodeURIComponent(value));
                    return url + sep + key + '=' + encodeURIComponent(value);
                }
            }

            // =========================
            // (B) إيجاد iframe الخاص بالتاب النشط (الأزرق)
            // =========================
            function getActiveTabIframe() {
                // ✅ الطريقة الصحيحة: البحث عن iframe التاب النشط حسب نظام site.js
                // التاب النشط: .app-tab.active في appTabsBar
                // الإطار النشط: .app-tab-frame:not(.d-none) في appTabsContainer

                // 1) البحث عن التاب النشط في شريط التابات
                const activeTab = document.querySelector('#appTabsBar .app-tab.active');
                if (activeTab) {
                    const tabId = activeTab.getAttribute('data-tab-id');
                    if (tabId) {
                        // البحث عن الإطار المقابل لهذا التاب
                        const frame = document.querySelector(`#appTabsContainer .app-tab-frame[data-tab-id="${tabId}"]:not(.d-none)`);
                        if (frame) return frame;
                    }
                }

                // 2) fallback: البحث عن أي iframe نشط (بدون d-none)
                const activeFrame = document.querySelector('#appTabsContainer .app-tab-frame:not(.d-none)');
                if (activeFrame) return activeFrame;

                // 3) fallback أخير: أي iframe داخل محتوى التابات
                const any = document.querySelector('#appTabsContainer .app-tab-frame');
                return any || null;
            }

            // =========================
            // (C) تحديث التاب النشط فقط (بدون إغلاق التابات أو تأثر الصفحة الرئيسية)
            // =========================
            function refreshIframe(iframe) {
                if (!iframe) return;

                const src = (iframe.getAttribute && iframe.getAttribute('src')) || iframe.src || '';
                if (!src) return;

                try {
                    const frameWindow = iframe.contentWindow;
                    // محاولة تحديث ناعم إن وُجدت دالة داخل الصفحة
                    if (frameWindow && typeof frameWindow.__ERP_REFRESH__ === 'function') {
                        try {
                            frameWindow.__ERP_REFRESH__();
                            return;
                        } catch (e) { /* نكمل لإعادة التحميل */ }
                    }
                } catch (e) { /* cross-origin أو خطأ → نعيد التحميل */ }

                // الطريقة المضمونة: إعادة تحميل محتوى التاب النشط فقط (ts يكسر الكاش)
                iframe.setAttribute('src', setOrReplaceParam(src, 'ts', Date.now()));
            }

            function refreshActiveTab() {
                const iframe = getActiveTabIframe();
                if (!iframe) {
                    console.warn('Refresh: لم يتم العثور على iframe للتاب النشط.');
                    const hasTabs = document.querySelector('#appTabsBar .app-tab');
                    if (hasTabs && typeof alert === 'function') alert('لم يتم العثور على تاب نشط. انقر على التاب الذي تريد تحديثه ثم اضغط «تحديث» مرة أخرى.');
                    return false;
                }
                refreshIframe(iframe);
                return true;
            }

            // ✅ جعل الدالة متاحة عالمياً للاستخدام من أي مكان
            window.ERP_refreshActiveTab = refreshActiveTab;

            // =========================
            // (D) ربط زر الريفريش بطريقة تشتغل حتى لو DOMContentLoaded خلص
            // =========================
            function bindRefreshButton() {
                const btn = document.getElementById('btnRefreshActiveTab');
                if (!btn) {
                    console.warn('Refresh: زر btnRefreshActiveTab غير موجود في الـ Layout.');
                    return;
                }

                // امنع تكرار الربط لو اتنفّذ مرتين
                if (btn.dataset.bound === '1') return;
                btn.dataset.bound = '1';

                btn.addEventListener('click', function (ev) {
                    ev.preventDefault();
                    ev.stopPropagation();
                    refreshActiveTab();
                });

                console.log('Refresh: تم ربط زر تحديث التاب النشط بنجاح ✅');
            }

            // لو الصفحة لسه بتحمّل استنى، لو خلصت اربط فوراً
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', bindRefreshButton);
            } else {
                bindRefreshButton();
            }

        })();
    </script>



    @RenderSection("Scripts", required: false)
</body>
</html>
