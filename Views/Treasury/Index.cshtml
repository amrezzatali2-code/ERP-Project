@using ERP.Models
@{
    ViewData["Title"] = "الخزينة الرئيسية";

    decimal totalBalance = ViewBag.TotalTreasuryBalance is decimal b ? b : 0m;
    var receipts = ViewBag.Receipts as List<CashReceipt> ?? new List<CashReceipt>();
    var payments = ViewBag.Payments as List<CashPayment> ?? new List<CashPayment>();
    decimal totalReceiptsAmount = ViewBag.TotalReceiptsAmount is decimal r ? r : 0m;
    decimal totalPaymentsAmount = ViewBag.TotalPaymentsAmount is decimal p ? p : 0m;

    DateTime? fromDate = ViewBag.FromDate as DateTime?;
    DateTime? toDate = ViewBag.ToDate as DateTime?;

    int pageReceipts = ViewBag.PageReceipts is int pr ? pr : 1;
    int pagePayments = ViewBag.PagePayments is int pp ? pp : 1;
    int pageSize = ViewBag.PageSize is int ps ? ps : 20;
    int totalReceipts = ViewBag.TotalReceipts is int tr ? tr : 0;
    int totalPayments = ViewBag.TotalPayments is int tp ? tp : 0;
    int totalPagesReceipts = ViewBag.TotalPagesReceipts is int tpr ? tpr : 0;
    int totalPagesPayments = ViewBag.TotalPagesPayments is int tpp ? tpp : 0;

    var treasuryCreators = ViewBag.TreasuryCreators as List<string> ?? new List<string>();
    string? selectedCreatedBy = ViewBag.CreatedBy as string;
    bool treasuryBalanceIsLedgerTotal = ViewBag.TreasuryBalanceIsLedgerTotal as bool? ?? true;
    var treasuryCashBoxSelect = ViewBag.TreasuryCashBoxSelect as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    int? selectedTreasuryCashId = ViewBag.TreasuryCashAccountId as int?;
}

<style>
    /* كروت الخزينة — حدود موحدة مع نمط الفواتير */
    .treasury-summary-card {
        border: 1px solid #6366f1;
        border-radius: 12px;
        box-shadow: 0 1px 3px rgba(99, 102, 241, 0.25);
        overflow: hidden;
    }
    .treasury-vouchers-card {
        border: 1px solid #6366f1;
        border-radius: 12px;
        box-shadow: 0 1px 3px rgba(99, 102, 241, 0.25);
        overflow: hidden;
    }
    .treasury-voucher-row {
        cursor: pointer;
        transition: background-color 0.15s ease;
    }
    .treasury-voucher-row:hover {
        background-color: rgba(99, 102, 241, 0.08);
    }
    .treasury-voucher-row.selected {
        background-color: rgba(99, 102, 241, 0.2);
        border-left: 3px solid #6366f1;
    }
</style>

<div dir="rtl" class="container-fluid mt-3">

    @* ===== عنوان الصفحة ===== *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">الخزينة الرئيسية</h2>
    </div>

    @* ===== فلتر التاريخ ===== *@
    <div class="card treasury-summary-card mb-3 d-print-none">
        <div class="card-body">
            <form method="get" action="@Url.Action("Index", "Treasury")" class="row g-3 align-items-end">
                <div class="col-md-2 col-lg-2">
                    <label class="form-label fw-semibold">من تاريخ</label>
                    <input type="date"
                           name="fromDate"
                           class="form-control"
                           value="@(fromDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-2 col-lg-2">
                    <label class="form-label fw-semibold">إلى تاريخ</label>
                    <input type="date"
                           name="toDate"
                           class="form-control"
                           value="@(toDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-4 col-lg-3">
                    <label class="form-label fw-semibold">الخزينة / الصندوق</label>
                    <select name="cashAccountId" class="form-select" asp-items="treasuryCashBoxSelect"></select>
                </div>
                <div class="col-md-4 col-lg-3">
                    <label class="form-label fw-semibold">المستخدم (من أنشأ الإذن)</label>
                    <select name="createdBy" class="form-select">
                        @if (string.IsNullOrEmpty(selectedCreatedBy))
                        {
                            <option value="" selected="selected">— كل المستخدمين —</option>
                        }
                        else
                        {
                            <option value="">— كل المستخدمين —</option>
                        }
                        @foreach (var u in treasuryCreators)
                        {
                            if (selectedCreatedBy != null && string.Equals(selectedCreatedBy, u, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@u" selected="selected">@u</option>
                            }
                            else
                            {
                                <option value="@u">@u</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-4 d-flex flex-wrap gap-2 align-items-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> بحث
                    </button>
                    <a href="@Url.Action("Index", "Treasury")" class="btn btn-secondary">
                        <i class="bi bi-arrow-counterclockwise"></i> إعادة تعيين
                    </a>
                </div>
            </form>
        </div>
    </div>

    @* ===== بطاقات الرصيد والإجماليات ===== *@
    <div class="row mb-4">
        <div class="col-md-4 order-3">
            <div class="card treasury-summary-card h-100">
                <div class="card-header border-bottom text-center" style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); color: #fff;">
                    <h5 class="mb-0">إجمالي أذون الدفع</h5>
                </div>
                <div class="card-body text-center">
                    <h2 class="text-secondary mb-0">@totalPaymentsAmount.ToString("N2")</h2>
                    <small class="text-muted">جنيه مصري</small>
                </div>
            </div>
        </div>
        <div class="col-md-4 order-2">
            <div class="card treasury-summary-card h-100" style="border-width: 2px;">
                <div class="card-header border-bottom text-center" style="background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%); color: #fff;">
                    <h5 class="mb-0">@(treasuryBalanceIsLedgerTotal ? "الرصيد الإجمالي للخزينة" : "صافي حركة المستخدم")</h5>
                    <small class="opacity-90">@(treasuryBalanceIsLedgerTotal ? (selectedTreasuryCashId.HasValue ? "رصيد دفتر هذه الخزينة فقط" : "من دفتر الأستاذ — جميع الخزائن المرئية") : "إجمالي الاستلام − إجمالي الدفع في الفترة")</small>
                </div>
                <div class="card-body text-center">
                    <h2 class="mb-0 @(totalBalance >= 0 ? "text-primary" : "text-danger")">@totalBalance.ToString("N2")</h2>
                    <small class="text-muted">جنيه مصري</small>
                </div>
            </div>
        </div>
        <div class="col-md-4 order-1">
            <div class="card treasury-summary-card h-100">
                <div class="card-header border-bottom text-center" style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); color: #fff;">
                    <h5 class="mb-0">إجمالي أذون الاستلام</h5>
                </div>
                <div class="card-body text-center">
                    <h2 class="text-secondary mb-0">@totalReceiptsAmount.ToString("N2")</h2>
                    <small class="text-muted">جنيه مصري</small>
                </div>
            </div>
        </div>
    </div>

    @* ===== شريط أزرار الإذن المختار (عرض + حجم تعامل) ===== *@
    <div class="card treasury-vouchers-card mb-3">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap align-items-center gap-3">
                <span class="text-muted small">اختر إذناً من الجدول أدناه ثم:</span>
                <button type="button" id="btnShowVoucher" class="btn btn-erp btn-erp-primary btn-sm" disabled title="عرض تفاصيل الإذن">
                    <i class="bi bi-eye"></i> عرض الإذن
                </button>
                <button type="button" id="btnVolumeCustomer" class="btn btn-erp btn-erp-success btn-sm" disabled title="حجم تعامل الطرف">
                    <i class="bi bi-bar-chart"></i> حجم تعامل
                </button>
            </div>
        </div>
    </div>

    @* ===== أذون الاستلام والدفع ===== *@
    <div class="row g-3 mb-4">
        @* ===== أذون الاستلام ===== *@
        <div class="col-12 col-md-6">
            <div class="card treasury-vouchers-card h-100">
                <div class="card-header border-bottom" style="background: rgba(99, 102, 241, 0.1);">
                    <h5 class="mb-0 text-secondary">
                        <i class="bi bi-arrow-down-circle"></i> أذون الاستلام
                        <span class="badge bg-secondary text-white">@totalReceipts</span>
                    </h5>
                </div>
                <div class="card-body p-0">
            @if (receipts.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light" style="position: sticky; top: 0; z-index: 5;">
                            <tr>
                                <th>رقم الإذن</th>
                                <th>التاريخ</th>
                                <th>حساب الصندوق</th>
                                <th>حساب الطرف</th>
                                <th>الطرف</th>
                                <th>المبلغ</th>
                                <th>حالة الترحيل</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var receipt in receipts)
                            {
                                var showUrl = Url.Action("Show", "CashReceipts", new { id = receipt.CashReceiptId });
                                var volumeUrl = receipt.CustomerId.HasValue ? Url.Action("Show", "Customers", new { id = receipt.CustomerId, frame = 1 }) : "";
                                <tr class="treasury-voucher-row js-voucher-row"
                                    data-type="receipt"
                                    data-voucher-id="@receipt.CashReceiptId"
                                    data-tab-title="إذن استلام @receipt.ReceiptNumber"
                                    data-show-url="@showUrl"
                                    data-volume-url="@volumeUrl"
                                    data-customer-id="@(receipt.CustomerId?.ToString() ?? "")">
                                    <td>@receipt.ReceiptNumber</td>
                                    <td>@receipt.ReceiptDate.ToString("yyyy-MM-dd")</td>
                                    <td>@(receipt.CashAccount?.AccountName ?? "-")</td>
                                    <td>@(receipt.CounterAccount?.AccountName ?? "-")</td>
                                    <td>@(receipt.Customer?.CustomerName ?? "-")</td>
                                    <td class="fw-bold">@receipt.Amount.ToString("N2")</td>
                                    <td>
                                        @if (receipt.IsPosted)
                                        { <span class="badge bg-secondary">مرحلة 1</span> }
                                        else
                                        { <span class="badge bg-warning text-dark">غير مرحلة</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="5" class="text-end">الإجمالي:</th>
                                <th class="fw-bold">@receipts.Sum(r => r.Amount).ToString("N2")</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                @if (totalPagesReceipts > 1)
                {
                    <div class="p-2 border-top">
                        <ul class="pagination pagination-sm justify-content-center mb-0">
                            @if (pageReceipts > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Index", "Treasury", new { fromDate, toDate, cashAccountId = selectedTreasuryCashId, createdBy = selectedCreatedBy, pageReceipts = pageReceipts - 1, pagePayments, pageSize })">السابق</a>
                                </li>
                            }
                            @for (int i = 1; i <= totalPagesReceipts; i++)
                            {
                                <li class="page-item @(i == pageReceipts ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", "Treasury", new { fromDate, toDate, cashAccountId = selectedTreasuryCashId, createdBy = selectedCreatedBy, pageReceipts = i, pagePayments, pageSize })">@i</a>
                                </li>
                            }
                            @if (pageReceipts < totalPagesReceipts)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Index", "Treasury", new { fromDate, toDate, cashAccountId = selectedTreasuryCashId, createdBy = selectedCreatedBy, pageReceipts = pageReceipts + 1, pagePayments, pageSize })">التالي</a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-light border m-3">لا توجد أذون استلام في الفترة المحددة</div>
            }
                </div>
            </div>
        </div>

        @* ===== أذون الدفع ===== *@
        <div class="col-12 col-md-6">
            <div class="card treasury-vouchers-card h-100">
                <div class="card-header border-bottom" style="background: rgba(99, 102, 241, 0.1);">
                    <h5 class="mb-0 text-secondary">
                        <i class="bi bi-arrow-up-circle"></i> أذون الدفع
                        <span class="badge bg-secondary text-white">@totalPayments</span>
                    </h5>
                </div>
                <div class="card-body p-0">
            @if (payments.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light" style="position: sticky; top: 0; z-index: 5;">
                            <tr>
                                <th>رقم الإذن</th>
                                <th>التاريخ</th>
                                <th>حساب الصندوق</th>
                                <th>حساب الطرف</th>
                                <th>الطرف</th>
                                <th>المبلغ</th>
                                <th>حالة الترحيل</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var payment in payments)
                            {
                                var payShowUrl = Url.Action("Show", "CashPayments", new { id = payment.CashPaymentId });
                                var payVolumeUrl = payment.CustomerId.HasValue ? Url.Action("Show", "Customers", new { id = payment.CustomerId, frame = 1 }) : "";
                                <tr class="treasury-voucher-row js-voucher-row"
                                    data-type="payment"
                                    data-voucher-id="@payment.CashPaymentId"
                                    data-tab-title="إذن دفع @payment.PaymentNumber"
                                    data-show-url="@payShowUrl"
                                    data-volume-url="@payVolumeUrl"
                                    data-customer-id="@(payment.CustomerId?.ToString() ?? "")">
                                    <td>@payment.PaymentNumber</td>
                                    <td>@payment.PaymentDate.ToString("yyyy-MM-dd")</td>
                                    <td>@(payment.CashAccount?.AccountName ?? "-")</td>
                                    <td>@(payment.CounterAccount?.AccountName ?? "-")</td>
                                    <td>@(payment.Customer?.CustomerName ?? "-")</td>
                                    <td class="fw-bold">@payment.Amount.ToString("N2")</td>
                                    <td>
                                        @if (payment.IsPosted)
                                        { <span class="badge bg-secondary">مرحلة 1</span> }
                                        else
                                        { <span class="badge bg-warning text-dark">غير مرحلة</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="5" class="text-end">الإجمالي:</th>
                                <th class="fw-bold">@payments.Sum(p => p.Amount).ToString("N2")</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                @if (totalPagesPayments > 1)
                {
                    <div class="p-2 border-top">
                        <ul class="pagination pagination-sm justify-content-center mb-0">
                            @if (pagePayments > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Index", "Treasury", new { fromDate, toDate, cashAccountId = selectedTreasuryCashId, createdBy = selectedCreatedBy, pageReceipts, pagePayments = pagePayments - 1, pageSize })">السابق</a>
                                </li>
                            }
                            @for (int i = 1; i <= totalPagesPayments; i++)
                            {
                                <li class="page-item @(i == pagePayments ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", "Treasury", new { fromDate, toDate, cashAccountId = selectedTreasuryCashId, createdBy = selectedCreatedBy, pageReceipts, pagePayments = i, pageSize })">@i</a>
                                </li>
                            }
                            @if (pagePayments < totalPagesPayments)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Index", "Treasury", new { fromDate, toDate, cashAccountId = selectedTreasuryCashId, createdBy = selectedCreatedBy, pageReceipts, pagePayments = pagePayments + 1, pageSize })">التالي</a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-light border m-3">لا توجد أذون دفع في الفترة المحددة</div>
            }
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
(function () {
    var btnShow = document.getElementById('btnShowVoucher');
    var btnVolume = document.getElementById('btnVolumeCustomer');
    var rows = document.querySelectorAll('.js-voucher-row');
    var selectedRow = null;

    function ensureFrameParam(url) {
        if (!url) return url;
        var sep = url.indexOf('?') >= 0 ? '&' : '?';
        return url + sep + 'frame=1';
    }

    function openInTab(tabId, url, title) {
        if (!url) return;
        url = ensureFrameParam(url);
        var inFrame = (window.top !== window);
        try {
            if (inFrame) {
                window.top.postMessage({ type: 'erp-open-tab', tabId: tabId, url: url, title: title || 'تبويب' }, '*');
                return;
            }
            if (window.erpTabs && typeof window.erpTabs.openTab === 'function') {
                window.erpTabs.openTab(tabId, url, title || 'تبويب');
            } else {
                window.location.href = url;
            }
        } catch (e) {
            if (!inFrame) window.location.href = url;
        }
    }

    function updateButtons() {
        if (!selectedRow) {
            btnShow.disabled = true;
            btnVolume.disabled = true;
            return;
        }
        var showUrl = selectedRow.getAttribute('data-show-url');
        var volumeUrl = selectedRow.getAttribute('data-volume-url') || '';
        btnShow.disabled = !showUrl;
        btnVolume.disabled = !volumeUrl;
    }

    rows.forEach(function (row) {
        row.addEventListener('click', function (e) {
            if (e.target.tagName === 'A') return;
            document.querySelectorAll('.js-voucher-row').forEach(function (r) { r.classList.remove('selected'); });
            row.classList.add('selected');
            selectedRow = row;
            updateButtons();
        });
    });

    if (btnShow) {
        btnShow.addEventListener('click', function (e) {
            e.preventDefault();
            if (!selectedRow) return;
            var url = selectedRow.getAttribute('data-show-url');
            if (!url) return;
            var type = selectedRow.getAttribute('data-type') || 'voucher';
            var id = selectedRow.getAttribute('data-voucher-id') || '';
            var title = selectedRow.getAttribute('data-tab-title') || 'عرض الإذن';
            var tabId = 'voucher-' + type + '-' + id;
            openInTab(tabId, url, title);
        });
    }
    if (btnVolume) {
        btnVolume.addEventListener('click', function (e) {
            e.preventDefault();
            if (!selectedRow) return;
            var url = selectedRow.getAttribute('data-volume-url');
            if (!url) return;
            var customerId = selectedRow.getAttribute('data-customer-id') || '';
            var tabId = 'treasury-customer-volume-' + customerId;
            var title = 'حجم تعامل';
            openInTab(tabId, url, title);
        });
    }
})();
</script>
}
