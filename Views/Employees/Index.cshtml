@using ERP.Infrastructure
@model PagedResult<ERP.Models.Employee>
@{
    ViewData["Title"] = "قائمة الموظفين";
    var action = nameof(ERP.Controllers.EmployeesController.Index);
    var controller = "Employees";
    var search = Model?.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "name";
    var sort = Model?.SortColumn ?? (string?)ViewBag.Sort ?? "FullName";
    var dir = Model?.SortDescending == true ? "desc" : ((string?)ViewBag.Dir ?? "asc");
    int ps = Model?.PageSize ?? 25;
    int total = Model?.TotalCount ?? 0;
    int page = Model?.PageNumber ?? 1;
    int pages = Model?.TotalPages ?? 0;
}
<div dir="rtl" class="container-fluid">
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Ok"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Err"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Err"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <div class="d-flex align-items-center gap-2">
            @if (ViewBag.SalesBonusPeriod != null)
            {
                <small class="text-muted">المبيعات والبونص لشهر: @ViewBag.SalesBonusPeriod</small>
            }
            <small class="text-muted">إجمالي الموظفين: @total</small>
        </div>
    </div>

    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap">
            <div class="col-12 col-lg-4">
                <form method="get" asp-action="Index" asp-controller="@controller" class="d-flex flex-wrap gap-2 align-items-end">
                    <label class="form-label mb-0">بحث</label>
                    <input type="text" name="search" class="form-control form-control-sm" placeholder="نص البحث..." value="@search" style="max-width:180px" />
                    <select name="searchBy" class="form-select form-select-sm" style="max-width:120px">
                        @foreach (var opt in (IEnumerable<SelectListItem>)ViewBag.SearchOptions)
                        {
                            <option value="@opt.Value" selected="@opt.Selected">@opt.Text</option>
                        }
                    </select>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">عرض</button>
                    <a class="btn btn-erp btn-erp-secondary btn-erp-sm" asp-action="Index" asp-controller="@controller">إلغاء</a>
                </form>
            </div>
            <div class="col-12 col-lg-4 d-flex justify-content-center">
                <a class="btn btn-erp btn-erp-success btn-erp-sm" asp-action="Create">+ إضافة موظف</a>
            </div>
        </div>
    </div>

    <div class="erp-table-scroll-container mt-3">
        <div class="erp-table-wrapper">
            <table class="table table-striped table-hover table-sm erp-table mb-0">
                <thead class="table-light" style="position: sticky; top: 0; z-index: 10;">
                    <tr>
                        <th class="text-center" style="width:60px">كود</th>
                        <th>الاسم</th>
                        <th>القسم</th>
                        <th>الوظيفة</th>
                        <th>هاتف</th>
                        <th class="text-center" style="width:90px">تاريخ التعيين</th>
                        <th class="text-end" style="width:100px">المبيعات</th>
                        <th class="text-end" style="width:90px">البونص</th>
                        <th class="text-center" style="width:70px">نشط</th>
                        <th class="no-print" style="width:200px">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model?.Items == null || !Model.Items.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">لا يوجد موظفون.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                @{
                                    var salesByEmp = ViewBag.SalesByEmployeeId as System.Collections.Generic.Dictionary<int, decimal>;
                                    var bonusByEmp = ViewBag.BonusByEmployeeId as System.Collections.Generic.Dictionary<int, decimal>;
                                    var empSales = 0m;
                                    var empBonus = 0m;
                                    if (salesByEmp != null && salesByEmp.TryGetValue(item.Id, out var sv)) empSales = sv;
                                    if (bonusByEmp != null && bonusByEmp.TryGetValue(item.Id, out var bv)) empBonus = bv;
                                }
                                <td class="text-center">@item.Id</td>
                                <td>@item.FullName</td>
                                <td>@(item.Department?.Name ?? "-")</td>
                                <td>@(item.Job?.Name ?? "-")</td>
                                <td>@(item.Phone1 ?? item.Phone2 ?? "-")</td>
                                <td class="text-center">@(item.HireDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td class="text-end">@(empSales.ToString("N2"))</td>
                                <td class="text-end">@(empBonus.ToString("N2"))</td>
                                <td class="text-center">@(item.IsActive ? "نعم" : "لا")</td>
                                <td class="no-print">
                                    <a class="btn btn-erp btn-erp-primary btn-erp-sm" asp-action="Show" asp-route-id="@item.Id">عرض</a>
                                    <a class="btn btn-erp btn-erp-primary btn-erp-sm" asp-action="Edit" asp-route-id="@item.Id">تعديل</a>
                                    <a class="btn btn-erp btn-erp-danger btn-erp-sm" asp-action="Delete" asp-route-id="@item.Id">حذف</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
                <tfoot class="table-secondary">
                    <tr>
                        <td colspan="9" class="text-end">عدد الموظفين:</td>
                        <td class="text-center">@total</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    @if (pages > 1)
    {
        <nav class="d-flex justify-content-end align-items-center gap-2 mt-2" dir="rtl">
            <span class="text-muted small">عرض @(total == 0 ? 0 : ((page - 1) * ps) + 1)–@Math.Min(total, page * ps) من @total</span>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action(action, controller, new { search, searchBy, sort, dir, page = page - 1, pageSize = ps })">السابق</a>
                </li>
                <li class="page-item @(page >= pages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action(action, controller, new { search, searchBy, sort, dir, page = page + 1, pageSize = ps })">التالي</a>
                </li>
            </ul>
        </nav>
    }
</div>
