@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<Role>

@{
    ViewData["Title"] = "الأدوار";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "Roles";

    // القيم القادمة من الموديل / ViewBag
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = Model.SearchBy ?? (string?)ViewBag.SearchBy ?? "all";
    var searchMode = ((string?)ViewBag.SearchMode ?? "contains").ToLowerInvariant();
    if (searchMode != "starts" && searchMode != "ends") searchMode = "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "RoleId";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = Model.StartIndex;
    int end = Model.EndIndex;

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    bool useDateRange = Model.UseDateRange;
    DateTime? fromDate = Model.FromDate;
    DateTime? toDate = Model.ToDate;
    var dateField = (string?)ViewBag.DateField ?? "CreatedAt";

    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_name = ViewBag.FilterCol_Name as string;
    string? filterCol_description = ViewBag.FilterCol_Description as string;
    string? filterCol_system = ViewBag.FilterCol_System as string;
    string? filterCol_active = ViewBag.FilterCol_Active as string;
    string? filterCol_created = ViewBag.FilterCol_Created as string;
    string? filterCol_updated = ViewBag.FilterCol_Updated as string;
    int activeCount = ViewBag.ActiveCount is int ac ? ac : 0;
    int systemCount = ViewBag.SystemCount is int sc ? sc : 0;
    var n2 = System.Globalization.CultureInfo.InvariantCulture;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange,
        fromDate,
        toDate,
        dateField,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_idExpr,
        filterCol_name,
        filterCol_description,
        filterCol_system,
        filterCol_active,
        filterCol_created,
        filterCol_updated
    })!;

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = colKey == "id" ? (!string.IsNullOrWhiteSpace(filterCol_idExpr) ? filterCol_idExpr : filterCol_id) : colKey == "name" ? filterCol_name : colKey == "description" ? filterCol_description : colKey == "system" ? filterCol_system : colKey == "active" ? filterCol_active : colKey == "created" ? filterCol_created : colKey == "updated" ? filterCol_updated : null;
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"" style=""position:relative;z-index:2;"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

@section Styles {
    <style>
        .erp-roles-toolbar-btn {
            font-size: 0.9rem;
            padding: 0.38rem 0.8rem;
            line-height: 1.25;
            white-space: nowrap;
        }

        .erp-roles-export-select {
            width: 78px;
            min-width: 78px;
            font-size: 0.88rem;
            font-weight: 500;
        }
    </style>
}

<div dir="rtl" class="container-fluid">

    @* ===== شريط الفلاتر الموحد (بنفس تصميم المستخدمين) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في الأدوار</label>
                    <div class="d-flex flex-nowrap align-items-center gap-2 erp-list-search-row justify-content-center w-100" style="overflow-x:auto;">
                        <select name="searchMode" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:110px;min-width:100px">
                            <option value="starts"@Html.Raw(searchMode == "starts" ? " selected" : "")>يبدأ بـ</option>
                            <option value="contains"@Html.Raw(searchMode == "contains" ? " selected" : "")>يحتوي</option>
                            <option value="ends"@Html.Raw(searchMode == "ends" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                        <input type="text" name="search" class="form-control erp-filter-input flex-shrink-1" placeholder="اكتب نص البحث..." value="@search" style="min-width:100px;max-width:220px;width:190px;" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input flex-shrink-0" style="max-width:160px;min-width:135px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>البحث في الكل</option>
                            <option value="name"@Html.Raw(searchBy == "name" ? " selected" : "")>اسم الدور</option>
                            <option value="description"@Html.Raw(searchBy == "description" ? " selected" : "")>الوصف</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>كود الدور</option>
                        </select>
                    </div>
                    <div class="d-flex flex-wrap justify-content-center gap-2 mt-2 w-100">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                    @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                    @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_description)) { <input type="hidden" name="filterCol_description" value="@filterCol_description" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_system)) { <input type="hidden" name="filterCol_system" value="@filterCol_system" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_active)) { <input type="hidden" name="filterCol_active" value="@filterCol_active" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر الكود --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر الكود</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم (صفان: علوي ثانوي، سفلي حذف + Excel + تصدير) --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-nowrap gap-2 justify-content-center align-items-center">
                        <a class="btn btn-erp btn-erp-success btn-erp-sm erp-roles-toolbar-btn" asp-action="Create" asp-controller="Roles">دور جديد</a>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm erp-roles-toolbar-btn" data-bs-toggle="modal" data-bs-target="#dateFilterModalRoles">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm erp-roles-toolbar-btn" data-bs-toggle="modal" data-bs-target="#columnsModalRoles">اختيار الأعمدة</button>
                        <button type="button" id="btnPrintRoles" class="btn btn-erp btn-erp-secondary btn-erp-sm erp-roles-toolbar-btn">🖨️ طباعة</button>
                    </div>
                    <div class="erp-toolbar-row d-flex flex-nowrap gap-2 justify-content-center align-items-center">
                        <button type="button" id="btnEditRole" class="btn btn-erp btn-erp-secondary btn-erp-sm erp-roles-toolbar-btn" disabled title="تعديل الدور">تعديل</button>
                        <div class="btn-group">
                            <button type="button" class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle erp-roles-toolbar-btn" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnBulkDelete">حذف المحدد</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف الجميع</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="Roles" class="d-inline-flex flex-nowrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="searchMode" value="@searchMode" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="dateField" value="@dateField" />
                            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
                            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
                            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_description)) { <input type="hidden" name="filterCol_description" value="@filterCol_description" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_system)) { <input type="hidden" name="filterCol_system" value="@filterCol_system" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_active)) { <input type="hidden" name="filterCol_active" value="@filterCol_active" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input erp-roles-export-select" title="اختر صيغة التصدير">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm erp-roles-toolbar-btn">تصدير</button>
                        </form>
                    </div>
                    <form id="formBulkDelete" asp-action="BulkDelete" asp-controller="Roles" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <div id="bulkDeleteIdsContainer"></div>
                    </form>
                    <form id="formDeleteAll" asp-action="DeleteAll" asp-controller="Roles" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>

        </div>
    </div>

    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي الأدوار</div>
                    <div class="h4 mb-0 text-primary fw-bold">@total.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #15803d !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">الأدوار النشطة</div>
                    <div class="h4 mb-0 text-success fw-bold">@activeCount.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #b45309 !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">الأدوار النظامية</div>
                    <div class="h4 mb-0 text-warning fw-bold">@systemCount.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
    </div>

    @* ===== جدول الأدوار (حاوية تمرير + رأس ثابت + فلتر أعمدة + توسعة) ===== *@
    <div class="erp-table-scroll-container erp-list-table-after-summary mt-3 ps-0 pe-0" dir="rtl">
        <div id="rolesTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="rolesTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th class="text-center no-print" data-col="select" data-col-fixed="true" style="width:42px; min-width:42px;" title="تحديد">
                        <input type="checkbox" id="selectAll" class="form-check-input" aria-label="تحديد الكل" />
                    </th>
                    <th data-col="id">@filterableCol("id", "RoleId", "كود الدور")</th>
                    <th data-col="name">@filterableCol("name", "Name", "اسم الدور")</th>
                    <th data-col="description">@filterableCol("description", "Description", "الوصف")</th>
                    <th data-col="system">@filterableCol("system", "IsSystemRole", "دور نظامي؟")</th>
                    <th data-col="active">@filterableCol("active", "IsActive", "نشط؟")</th>
                    <th data-col="created">@filterableCol("created", "CreatedAt", "تاريخ الإنشاء")</th>
                    <th data-col="updated">@filterableCol("updated", "UpdatedAt", "آخر تعديل")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model.Items)
                    {
                        var showUrl = Url.Action("Details", "Roles", new { id = r.RoleId }) ?? "#";
                        var editUrl = Url.Action("Edit", "Roles", new { id = r.RoleId }) ?? "#";
                        <tr class="erp-list-selectable-row"
                            data-role-id="@r.RoleId"
                            data-show-url="@showUrl"
                            data-edit-url="@editUrl"
                            data-tab-title="دور @r.RoleId — @r.Name">
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="form-check-input row-select"
                                       value="@r.RoleId" />
                            </td>

                            <td data-col="id">@r.RoleId</td>
                            <td data-col="name">@r.Name</td>
                            <td data-col="description">
                                @(string.IsNullOrWhiteSpace(r.Description) ? "-" : r.Description)
                            </td>
                            <td data-col="system">
                                @(r.IsSystemRole ? "نعم" : "لا")
                            </td>
                            <td data-col="active">
                                @(r.IsActive ? "نعم" : "لا")
                            </td>
                            <td data-col="created">
                                @r.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                            </td>
                            <td data-col="updated">
                                @(r.UpdatedAt.HasValue ? r.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        </div>
    </div>

    @* لوحة فلتر العمود *@
    <div id="erpColumnFilterPanelRoles" class="erp-column-filter-panel d-none" dir="rtl">
        <div class="erp-column-filter-header">
            <span id="erpColumnFilterTitleRoles">ترتيب وفلتر</span>
            <button type="button" class="btn-close btn-sm" id="erpColumnFilterCloseRoles" aria-label="إغلاق"></button>
        </div>
        <div class="erp-column-filter-body">
            <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                <label class="form-label small mb-1 fw-bold">الترتيب:</label>
                <div class="d-flex flex-column gap-1">
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
                </div>
            </div>
            <div class="erp-filter-section">
                <div id="erpColumnFilterSearchRow">
                    <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                    <input type="text" id="erpColumnFilterSearchRoles" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                </div>
                <div id="erpColumnFilterListRoles" class="erp-column-filter-list">
                    <div class="text-muted text-center py-3">جاري التحميل...</div>
                </div>
            </div>
            <div class="erp-column-filter-actions">
                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOkRoles">تطبيق</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClearRoles">مسح الفلتر</button>
            </div>
        </div>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة (RTL) ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print" dir="rtl">
        <small class="text-muted text-start">عرض @start - @end من @total</small>
        <form method="get" action="@Url.Action(action, controller)" class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="searchMode" value="@searchMode" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(useDateRange ? "true" : "false")" />
            @if (fromDate.HasValue) { <input type="hidden" name="fromDate" value="@fromDate.Value.ToString("o")" /> }
            @if (toDate.HasValue) { <input type="hidden" name="toDate" value="@toDate.Value.ToString("o")" /> }
            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_description)) { <input type="hidden" name="filterCol_description" value="@filterCol_description" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_system)) { <input type="hidden" name="filterCol_system" value="@filterCol_system" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_active)) { <input type="hidden" name="filterCol_active" value="@filterCol_active" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
            </select>
        </form>
    </div>

    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")"><a class="page-link" href="@Link(first)">الأول</a></li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")"><a class="page-link" href="@Link(prev)">السابق</a></li>
            <li class="page-item disabled"><span class="page-link">صفحة @(page) من @(pages)</span></li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")"><a class="page-link" href="@Link(next)">التالي</a></li>
            <li class="page-item @(page == last ? "disabled" : "")"><a class="page-link" href="@Link(last)">الأخير</a></li>
        </ul>
    </nav>
</div>

@* Modal فلترة التاريخ/الوقت *@
<div class="modal fade no-print"
     id="dateFilterModalRoles"
     tabindex="-1"
     aria-labelledby="dateFilterModalRolesLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalRolesLabel">
                    فلترة بالتاريخ والوقت (تاريخ إنشاء الدور)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="searchMode" value="@searchMode" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_description)) { <input type="hidden" name="filterCol_description" value="@filterCol_description" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_system)) { <input type="hidden" name="filterCol_system" value="@filterCol_system" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_active)) { <input type="hidden" name="filterCol_active" value="@filterCol_active" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRangeRoles"
                                   name="useDateRange"
                                   value="true"
                                   @(useDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRangeRoles">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(fromDate.HasValue? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(toDate.HasValue? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* Modal اختيار الأعمدة *@
<div class="modal fade no-print erp-columns-modal"
     id="columnsModalRoles"
     tabindex="-1"
     aria-labelledby="columnsModalRolesLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalRolesLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
            </div>
            <div class="modal-body">
                <div id="columnsListRoles" class="erp-columns-modal-list"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsRoles"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script>
        document.getElementById("btnPrintRoles")?.addEventListener("click", function () { window.print(); });

        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanelRoles',
            tableId: 'rolesTable',
            wrapperId: 'rolesTableScrollWrapper',
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "Roles")',
            defaultSort: 'RoleId',
            defaultDir: 'asc',
            numericColumns: ['id']
        });

        // اختيار الأعمدة + حفظ في localStorage
        (function () {
            const table = document.getElementById("rolesTable");
            if (!table) return;

            const storageKey = "roles-columns-visibility";
            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: (th.querySelector(".erp-col-title") && th.querySelector(".erp-col-title").textContent) || th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListRoles");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_roles_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsRoles")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalRoles");
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // تحديد الكل + الحذف الجماعي + حذف الكل
        (function () {
            const table = document.getElementById("rolesTable");
            const selectAll = document.getElementById("selectAll");
            const bulkBtn = document.getElementById("btnBulkDelete");
            const bulkForm = document.getElementById("formBulkDelete");
            const deleteAllBtn = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("formDeleteAll");

            function getRowCheckboxes() {
                return Array.from(document.querySelectorAll(".row-select"));
            }

            selectAll?.addEventListener("change", function () {
                getRowCheckboxes().forEach(cb => cb.checked = this.checked);
            });

            table?.addEventListener("change", function (e) {
                const target = e.target;
                if (!(target instanceof HTMLInputElement) || !target.classList.contains("row-select") || !selectAll) {
                    return;
                }

                const rowCheckboxes = getRowCheckboxes();
                const allChecked = rowCheckboxes.length > 0 && rowCheckboxes.every(cb => cb.checked);
                const noneChecked = rowCheckboxes.every(cb => !cb.checked);

                selectAll.checked = allChecked;
                selectAll.indeterminate = !allChecked && !noneChecked;
            });

            function submitForm(form) {
                if (!form) return;
                if (typeof form.requestSubmit === "function") form.requestSubmit();
                else form.submit();
            }

            function handleBulkDelete(e) {
                e.preventDefault();
                e.stopPropagation();

                let idValues = getRowCheckboxes().filter(cb => cb.checked).map(cb => cb.value);
                if (idValues.length === 0) {
                    const sel = document.querySelector("#rolesTable tbody tr.erp-list-selectable-row.selected");
                    const id = sel && sel.getAttribute("data-role-id");
                    if (id) idValues = [id];
                }
                if (idValues.length === 0) {
                    alert("من فضلك اختر على الأقل دورًا واحدًا للحذف.");
                    return;
                }
                if (!confirm("هل أنت متأكد من حذف الأدوار المحددة؟")) return;

                const idsContainer = document.getElementById("bulkDeleteIdsContainer");
                if (!bulkForm || !idsContainer) {
                    alert("تعذر إرسال الطلب.");
                    return;
                }
                idsContainer.innerHTML = "";
                idValues.forEach(v => {
                    const input = document.createElement("input");
                    input.type = "hidden";
                    input.name = "selectedIds";
                    input.value = v;
                    idsContainer.appendChild(input);
                });
                submitForm(bulkForm);
            }

            function handleDeleteAll(e) {
                e.preventDefault();
                e.stopPropagation();
                if (!confirm("هل أنت متأكد من حذف جميع الأدوار؟ يُنصح باستخدام هذا في بيئة تجريبية فقط.")) return;
                submitForm(deleteAllForm);
            }

            bulkBtn?.addEventListener("click", handleBulkDelete);
            deleteAllBtn?.addEventListener("click", handleDeleteAll);
        })();

        if (window.ERP && typeof ERP.initListSelection === "function") {
            ERP.initListSelection({
                rowSelector: "#rolesTable tbody tr.erp-list-selectable-row",
                idAttribute: "data-role-id",
                editButtonId: "btnEditRole",
                editUrlAttribute: "data-edit-url",
                tabTitleAttribute: "data-tab-title",
                editTabTitleAttribute: "data-tab-title",
                editTabId: "role-edit-tab",
                multiSelectCheckboxes: true
            });
        }

        // فلتر الكود من/إلى
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp = document.getElementById("codeFromInput");
            const toInp = document.getElementById("codeToInput");

            function applyCodeToUrl(url, codeFrom, codeTo) {
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else url.searchParams.delete("fromCode");
                if (codeTo) url.searchParams.set("toCode", codeTo);
                else url.searchParams.delete("toCode");
                url.searchParams.set("page", "1");
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp?.value.trim() ?? "";
                const ct = toInp?.value.trim() ?? "";
                const url = new URL(window.location.href);
                applyCodeToUrl(url, cf, ct);
                window.location.href = url.toString();
            });

            btnClear?.addEventListener("click", function () {
                if (fromInp) fromInp.value = "";
                if (toInp) toInp.value = "";
                const url = new URL(window.location.href);
                applyCodeToUrl(url, "", "");
                window.location.href = url.toString();
            });
        })();
    </script>
}
