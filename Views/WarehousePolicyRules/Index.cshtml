@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.WarehousePolicyRule>

@{
    ViewData["Title"] = "قواعد سياسات المخازن";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "WarehousePolicyRules";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = Model.SearchBy ?? (string?)ViewBag.SearchBy ?? "id";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "id";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    // بيانات الترقيم
    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    // نطاق العرض السفلي (عرض X–Y من Z)
    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلتر كود من/إلى (هنا كود القاعدة Id)
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    // حقل التاريخ المستخدم في الفلترة (CreatedAt)
    var dateField = (string?)ViewBag.DateField ?? "CreatedAt";

    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_warehouse = ViewBag.FilterCol_Warehouse as string;
    string? filterCol_warehousename = ViewBag.FilterCol_Warehousename as string;
    string? filterCol_policy = ViewBag.FilterCol_Policy as string;
    string? filterCol_policyname = ViewBag.FilterCol_Policyname as string;
    string? filterCol_profit = ViewBag.FilterCol_Profit as string;
    string? filterCol_maxdisc = ViewBag.FilterCol_Maxdisc as string;
    string? filterCol_created = ViewBag.FilterCol_Created as string;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField = dateField,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_warehouse,
        filterCol_warehousename,
        filterCol_policy,
        filterCol_policyname,
        filterCol_profit,
        filterCol_maxdisc,
        filterCol_created
    })!;

    string? FilterForCol(string colKey) => colKey == "id" ? filterCol_id : colKey == "warehouse" ? filterCol_warehouse : colKey == "warehousename" ? filterCol_warehousename : colKey == "policy" ? filterCol_policy : colKey == "policyname" ? filterCol_policyname : colKey == "profit" ? filterCol_profit : colKey == "maxdisc" ? filterCol_maxdisc : colKey == "created" ? filterCol_created : null;

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    @* ===== شريط الفلاتر الموحد (بنفس تصميم السياسات) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في سياسات المخازن</label>
                    <div class="d-flex flex-wrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:150px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>البحث في الكل</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>كود القاعدة</option>
                            <option value="warehouse"@Html.Raw(searchBy == "warehouse" ? " selected" : "")>كود المخزن</option>
                            <option value="policy"@Html.Raw(searchBy == "policy" ? " selected" : "")>كود السياسة</option>
                            <option value="profit"@Html.Raw(searchBy == "profit" ? " selected" : "")>نسبة الربح %</option>
                            <option value="maxdisc"@Html.Raw(searchBy == "maxdisc" ? " selected" : "")>أقصى خصم للعميل %</option>
                            <option value="created"@Html.Raw(searchBy == "created" ? " selected" : "")>تاريخ الإنشاء</option>
                        </select>
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">بحث</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                    @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
                    @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_warehousename)) { <input type="hidden" name="filterCol_warehousename" value="@filterCol_warehousename" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_policy)) { <input type="hidden" name="filterCol_policy" value="@filterCol_policy" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_policyname)) { <input type="hidden" name="filterCol_policyname" value="@filterCol_policyname" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_profit)) { <input type="hidden" name="filterCol_profit" value="@filterCol_profit" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_maxdisc)) { <input type="hidden" name="filterCol_maxdisc" value="@filterCol_maxdisc" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر الكود --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر الكود</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <a class="btn btn-erp btn-erp-success btn-erp-sm" asp-action="Create">إضافة قاعدة جديدة</a>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#wrDateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#wrColumnsModal">اختيار الأعمدة</button>
                        <button type="button" id="btnWrPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnBulkDelete">حذف المحدد</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف الجميع</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="WarehousePolicyRules" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="dateField" value="@dateField" />
                            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                            @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
                            @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_warehousename)) { <input type="hidden" name="filterCol_warehousename" value="@filterCol_warehousename" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_policy)) { <input type="hidden" name="filterCol_policy" value="@filterCol_policy" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_policyname)) { <input type="hidden" name="filterCol_policyname" value="@filterCol_policyname" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_profit)) { <input type="hidden" name="filterCol_profit" value="@filterCol_profit" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_maxdisc)) { <input type="hidden" name="filterCol_maxdisc" value="@filterCol_maxdisc" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:70px;min-width:70px;font-size:0.8rem;padding:0.25rem 0.4rem;">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                    <form id="formBulkDelete" asp-action="BulkDelete" asp-controller="WarehousePolicyRules" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="selectedIds" id="selectedIdsInput" />
                    </form>
                    <form id="formDeleteAll" asp-action="DeleteAll" asp-controller="WarehousePolicyRules" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>

        </div>
    </div>

    @* ===== جدول قواعد السياسات ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="wrTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    @* اختيار الصف *@
                    <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                        <input type="checkbox" id="selectAll" class="form-check-input" />
                    </th>

                    <th data-col="id">@filterableCol("id", "id", "المعرف")</th>
                    <th data-col="warehouse">@filterableCol("warehouse", "warehouse", "كود المخزن")</th>
                    <th data-col="warehousename">@filterableCol("warehousename", "warehousename", "اسم المخزن")</th>
                    <th data-col="policy">@filterableCol("policy", "policy", "كود السياسة")</th>
                    <th data-col="policyname">@filterableCol("policyname", "policyname", "اسم السياسة")</th>
                    <th data-col="profit">@filterableCol("profit", "profit", "نسبة الربح %")</th>
                    <th data-col="maxdisc">@filterableCol("maxdisc", "maxdisc", "أقصى خصم للعميل %")</th>
                    <th data-col="created">@filterableCol("created", "created", "تاريخ الإنشاء")</th>

                    <th class="text-nowrap no-print" data-col="actions" data-col-fixed="true" style="width:220px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model.Items)
                    {
                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="form-check-input row-select"
                                       value="@r.Id" />
                            </td>

                            <td data-col="id">@r.Id</td>
                            <td data-col="warehouse">@r.WarehouseId</td>
                            <td data-col="warehousename">@(r.Warehouse?.WarehouseName ?? "-")</td>
                            <td data-col="policy">@r.PolicyId</td>
                            <td data-col="policyname">@(r.Policy?.Name ?? "-")</td>
                            <td data-col="profit">@r.ProfitPercent.ToString("0.00")</td>
                            <td data-col="maxdisc">
                                @(r.MaxDiscountToCustomer.HasValue
                                                        ? r.MaxDiscountToCustomer.Value.ToString("0.00")
                                                        : "")
                            </td>
                            <td data-col="created">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                            <td class="text-nowrap no-print" data-col="actions">
                                <a class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                   asp-action="Details"
                                   asp-route-id="@r.Id">
                                    تفاصيل
                                </a>
                                <a class="btn btn-erp btn-erp-primary btn-erp-sm"
                                   asp-action="Edit"
                                   asp-route-id="@r.Id">
                                    تعديل
                                </a>
                                <a class="btn btn-erp btn-erp-danger btn-erp-sm"
                                   asp-action="Delete"
                                   asp-route-id="@r.Id">
                                    حذف
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @* ===== لوحة فلتر العمود (بنمط Excel) ===== *@
    <div id="erpColumnFilterPanelWarehousePolicyRules" class="erp-column-filter-panel d-none" dir="rtl">
        <div class="erp-column-filter-header">
            <span id="erpColumnFilterTitleWarehousePolicyRules">ترتيب وفلتر</span>
            <button type="button" class="btn-close btn-sm" id="erpColumnFilterCloseWarehousePolicyRules" aria-label="إغلاق"></button>
        </div>
        <div class="erp-column-filter-body">
            <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                <label class="form-label small mb-1 fw-bold">الترتيب:</label>
                <div class="d-flex flex-column gap-1">
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
                </div>
            </div>
            <div class="erp-filter-section">
                <div id="erpColumnFilterSearchRowWarehousePolicyRules">
                    <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                    <input type="text" id="erpColumnFilterSearchWarehousePolicyRules" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                </div>
                <div id="erpColumnFilterListWarehousePolicyRules" class="erp-column-filter-list">
                    <div class="text-muted text-center py-3">جاري التحميل...</div>
                </div>
            </div>
            <div class="erp-column-filter-actions">
                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOkWarehousePolicyRules">تطبيق</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClearWarehousePolicyRules">مسح الفلتر</button>
            </div>
        </div>
    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            @if (Model.FromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
            }
            @if (Model.ToDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_warehousename)) { <input type="hidden" name="filterCol_warehousename" value="@filterCol_warehousename" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_policy)) { <input type="hidden" name="filterCol_policy" value="@filterCol_policy" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_policyname)) { <input type="hidden" name="filterCol_policyname" value="@filterCol_policyname" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_profit)) { <input type="hidden" name="filterCol_profit" value="@filterCol_profit" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_maxdisc)) { <input type="hidden" name="filterCol_maxdisc" value="@filterCol_maxdisc" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
        </form>
    </div>

    <div>
        <small class="text-muted d-none d-md-inline">
            إجمالي القواعد: @total
        </small>
    </div>

    @* ===== الترقيم (Pagination) ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة التاريخ/الوقت ===== *@
<div class="modal fade no-print"
     id="wrDateFilterModal"
     tabindex="-1"
     aria-labelledby="wrDateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="wrDateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ الإنشاء)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_warehousename)) { <input type="hidden" name="filterCol_warehousename" value="@filterCol_warehousename" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_policy)) { <input type="hidden" name="filterCol_policy" value="@filterCol_policy" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_policyname)) { <input type="hidden" name="filterCol_policyname" value="@filterCol_policyname" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_profit)) { <input type="hidden" name="filterCol_profit" value="@filterCol_profit" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_maxdisc)) { <input type="hidden" name="filterCol_maxdisc" value="@filterCol_maxdisc" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="wrUseDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(Model.UseDateRange ? "checked" : "") />
                            <label class="form-check-label" for="wrUseDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="wrColumnsModal"
     tabindex="-1"
     aria-labelledby="wrColumnsModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="wrColumnsModalLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="wrColumnsList"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnWrApplyColumns"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط
        // =========================
        document.getElementById("btnWrPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const selectAll = document.getElementById("selectAll");
            const bulkBtn = document.getElementById("btnBulkDelete");
            const bulkForm = document.getElementById("formBulkDelete");
            const deleteAllBtn = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("formDeleteAll");
            const selectedIdsInput = document.getElementById("selectedIdsInput");
            function getRowCheckboxes() { return Array.from(document.querySelectorAll(".row-select")); }

            selectAll?.addEventListener("change", function () { getRowCheckboxes().forEach(cb => cb.checked = this.checked); });
            bulkBtn?.addEventListener("click", function () {
                const checks = getRowCheckboxes().filter(cb => cb.checked);
                if (checks.length === 0) { alert("من فضلك اختر على الأقل قاعدة واحدة للحذف."); return; }
                if (!confirm("هل أنت متأكد من حذف القواعد المحددة؟")) return;
                if (selectedIdsInput) selectedIdsInput.value = checks.map(cb => cb.value).join(",");
                bulkForm?.submit();
            });
            deleteAllBtn?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع قواعد سياسات المخازن. هل أنت متأكد؟")) return;
                deleteAllForm?.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("wrTable");    // جدول القواعد
            if (!table) return;

            const storageKey = "wr-columns-visibility";          // مفتاح التخزين في المتصفح

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            // تطبيق الإخفاء/الإظهار على الأعمدة
            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("wrColumnsList");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "wr_col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnWrApplyColumns")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("wrColumnsModal");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر الكود من/إلى
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                // نرجع لأول صفحة مع الحفاظ على باقي الفلاتر
                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp?.value.trim() ?? "";
                const ct = toInp?.value.trim() ?? "";
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                if (fromInp) fromInp.value = "";
                if (toInp) toInp.value = "";
                window.location.href = buildUrl("", "");
            });
        })();

        // فلتر الأعمدة بنمط Excel
        (function () {
            var panel = document.getElementById("erpColumnFilterPanelWarehousePolicyRules");
            if (!panel) return;
            var titleEl = document.getElementById("erpColumnFilterTitleWarehousePolicyRules");
            var searchInp = document.getElementById("erpColumnFilterSearchWarehousePolicyRules");
            var listEl = document.getElementById("erpColumnFilterListWarehousePolicyRules");
            var btnOk = document.getElementById("erpColumnFilterOkWarehousePolicyRules");
            var btnClear = document.getElementById("erpColumnFilterClearWarehousePolicyRules");
            var btnClose = document.getElementById("erpColumnFilterCloseWarehousePolicyRules");
            var currentCol = null, currentSortKey = null, allItems = [], currentSelected = new Set(), anchorRect = null;

            function getCurrentFilterValue(col) { return new URL(window.location.href).searchParams.get("filterCol_" + col) || ""; }
            function getCurrentSort() {
                var url = new URL(window.location.href);
                return { sort: url.searchParams.get("sort") || "id", dir: url.searchParams.get("dir") || "asc" };
            }
            function adjustPanelPosition() {
                if (!panel || !anchorRect) return;
                setTimeout(function () {
                    var r = panel.getBoundingClientRect();
                    var top = anchorRect.bottom + 4, left = anchorRect.left;
                    if (top + r.height > window.innerHeight - 8) top = Math.max(8, window.innerHeight - 8 - r.height);
                    if (left + r.width > window.innerWidth - 8) left = Math.max(8, window.innerWidth - 8 - r.width);
                    panel.style.top = top + "px";
                    panel.style.left = left + "px";
                }, 50);
            }

            function showPanel(btn) {
                currentCol = btn.dataset.col;
                currentSortKey = btn.dataset.sortKey || currentCol;
                titleEl.textContent = "ترتيب وفلتر: " + (btn.dataset.colTitle || currentCol);
                searchInp.value = "";
                currentSelected = new Set((getCurrentFilterValue(currentCol) || "").split(/[|,;]/).filter(Boolean));
                anchorRect = btn.getBoundingClientRect();
                panel.style.minWidth = Math.max(250, anchorRect.width) + "px";
                panel.classList.remove("d-none");

                var currentSort = getCurrentSort();
                var isCurrent = currentSort.sort.toLowerCase() === (currentSortKey || "").toLowerCase();
                var currentDir = isCurrent ? currentSort.dir : "asc";
                panel.querySelectorAll(".erp-sort-btn").forEach(function (b) {
                    if (isCurrent && b.dataset.sortDir === currentDir) {
                        b.classList.add("active", "btn-primary");
                        b.classList.remove("btn-outline-secondary");
                    } else {
                        b.classList.remove("active", "btn-primary");
                        b.classList.add("btn-outline-secondary");
                    }
                });
                adjustPanelPosition();
                document.getElementById("erpColumnFilterSearchRowWarehousePolicyRules").classList.remove("d-none");
                listEl.innerHTML = '<div class="text-muted text-center py-3">جاري التحميل...</div>';
                var url = "/WarehousePolicyRules/GetColumnValues?column=" + encodeURIComponent(currentCol);
                var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                if (searchVal) url += "&search=" + encodeURIComponent(searchVal);
                fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                    allItems = items;
                    renderList(searchInp ? searchInp.value : "");
                }).catch(function () { listEl.innerHTML = '<div class="text-danger text-center py-2">فشل التحميل</div>'; });
            }

            function renderList(search) {
                var term = (search || "").toLowerCase();
                var filtered = term ? allItems.filter(function (x) { return (x.display || x.value || "").toLowerCase().indexOf(term) >= 0; }) : allItems;
                var allChecked = filtered.length > 0 && filtered.every(function (x) { return currentSelected.has(String(x.value)); });
                var someChecked = filtered.some(function (x) { return currentSelected.has(String(x.value)); });
                listEl.innerHTML = '<div class="form-check mb-1"><input type="checkbox" class="form-check-input" id="erpFilterSelectAllWr" ' + (allChecked ? "checked" : "") + '><label class="form-check-label small" for="erpFilterSelectAllWr">(تحديد الكل)</label></div><div class="erp-filter-items" style="max-height:200px;overflow-y:auto;">' + filtered.map(function (x) {
                    var v = String(x.value);
                    var checked = currentSelected.has(v);
                    return '<div class="form-check"><input type="checkbox" class="form-check-input erp-filter-item" value="' + v.replace(/"/g, "&quot;") + '" ' + (checked ? "checked" : "") + '><label class="form-check-label small">' + (x.display || v).replace(/</g, "&lt;") + '</label></div>';
                }).join("") + "</div>";
                var selectAllCb = listEl.querySelector("#erpFilterSelectAllWr");
                if (selectAllCb) {
                    selectAllCb.indeterminate = someChecked && !allChecked;
                    selectAllCb.onchange = function () {
                        filtered.forEach(function (x) { if (this.checked) currentSelected.add(String(x.value)); else currentSelected.delete(String(x.value)); }.bind(this));
                        renderList(searchInp.value);
                    };
                }
                listEl.querySelectorAll(".erp-filter-item").forEach(function (cb) {
                    cb.onchange = function () {
                        if (this.checked) currentSelected.add(this.value); else currentSelected.delete(this.value);
                        var term2 = (searchInp && searchInp.value ? searchInp.value : "").toLowerCase();
                        var filteredHere = term2 ? allItems.filter(function (x) { return (x.display || x.value || "").toLowerCase().indexOf(term2) >= 0; }) : allItems;
                        var allCheckedHere = filteredHere.length > 0 && filteredHere.every(function (x) { return currentSelected.has(String(x.value)); });
                        var someCheckedHere = filteredHere.some(function (x) { return currentSelected.has(String(x.value)); });
                        var selectAllCbHere = listEl.querySelector("#erpFilterSelectAllWr");
                        if (selectAllCbHere) {
                            selectAllCbHere.checked = allCheckedHere;
                            selectAllCbHere.indeterminate = someCheckedHere && !allCheckedHere;
                        }
                    };
                });
                adjustPanelPosition();
            }

            function applyFilter(applySort, sortDir) {
                if (!currentCol) return;
                var url = new URL(window.location.href);
                url.searchParams.delete("filterCol_" + currentCol);
                if (applySort !== undefined && sortDir !== undefined) {
                    url.searchParams.set("sort", applySort);
                    url.searchParams.set("dir", sortDir);
                }
                var val = Array.from(currentSelected).filter(Boolean).join("|");
                if (val) url.searchParams.set("filterCol_" + currentCol, val);
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }
            function clearFilter() {
                if (!currentCol) return;
                var url = new URL(window.location.href);
                url.searchParams.delete("filterCol_" + currentCol);
                url.searchParams.set("page", "1");
                window.location.href = url.toString();
            }

            document.querySelectorAll("#wrTable .erp-col-filter-btn").forEach(function (btn) {
                btn.addEventListener("click", function (e) { e.stopPropagation(); showPanel(this); });
            });
            document.addEventListener("click", function (e) {
                var sortBtn = e.target.closest(".erp-sort-btn");
                if (sortBtn && panel && !panel.classList.contains("d-none") && panel.contains(sortBtn) && currentSortKey)
                    applyFilter(currentSortKey, sortBtn.dataset.sortDir);
            });
            var fetchDebounce = null;
            searchInp && searchInp.addEventListener("input", function () {
                renderList(this.value);
                if (fetchDebounce) clearTimeout(fetchDebounce);
                fetchDebounce = setTimeout(function () {
                    fetchDebounce = null;
                    if (!currentCol) return;
                    var url = "/WarehousePolicyRules/GetColumnValues?column=" + encodeURIComponent(currentCol);
                    var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                    if (searchVal) url += "&search=" + encodeURIComponent(searchVal);
                    fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                        allItems = items;
                        renderList(searchInp ? searchInp.value : "");
                    });
                }, 400);
            });
            searchInp && searchInp.addEventListener("keydown", function (e) { if (e.key === "Enter") { e.preventDefault(); applyFilter(); } });
            btnOk && btnOk.addEventListener("click", function (e) { e.preventDefault(); e.stopPropagation(); applyFilter(); });
            btnClear && btnClear.addEventListener("click", clearFilter);
            btnClose && btnClose.addEventListener("click", function () { panel.classList.add("d-none"); });
            document.addEventListener("click", function (e) {
                if (panel && !panel.classList.contains("d-none") && !panel.contains(e.target) && !e.target.closest(".erp-col-filter-btn"))
                    panel.classList.add("d-none");
            });
        })();

        // تكبير/تصغير عرض الأعمدة (ما عدا عمودي التحديد والإجراءات)
        document.addEventListener("DOMContentLoaded", function () {
            var wrapper = document.querySelector(".erp-table-wrapper");
            if (!wrapper) return;
            var table = wrapper.querySelector("table.erp-table");
            if (!table) return;
            var ths = table.querySelectorAll("thead th");
            ths.forEach(function (th) {
                if (th.getAttribute("data-col-fixed") === "true") return;
                th.style.position = "relative";
                var handle = document.createElement("div");
                handle.className = "erp-col-resize-handle";
                th.appendChild(handle);
                var startX, startWidth;
                handle.addEventListener("mousedown", function (e) {
                    e.preventDefault();
                    startX = e.pageX;
                    startWidth = th.offsetWidth;
                    function onMouseMove(eMove) {
                        var diffX = eMove.pageX - startX;
                        var newWidth = startWidth + diffX;
                        if (newWidth < 50) newWidth = 50;
                        th.style.width = newWidth + "px";
                    }
                    function onMouseUp() {
                        document.removeEventListener("mousemove", onMouseMove);
                        document.removeEventListener("mouseup", onMouseUp);
                    }
                    document.addEventListener("mousemove", onMouseMove);
                    document.addEventListener("mouseup", onMouseUp);
                });
            });
        });
    </script>
}
