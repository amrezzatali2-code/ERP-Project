                </div>
            </div>

        </div>
    </div>

    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي القواعد</div>
                    <div class="h4 mb-0 text-primary fw-bold">@total.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #15803d !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">القواعد المفعّلة</div>
                    <div class="h4 mb-0 text-success fw-bold">@activeCount.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #b91c1c !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">القواعد غير المفعّلة</div>
                    <div class="h4 mb-0 text-danger fw-bold">@inactiveCount.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="erp-table-scroll-container erp-list-table-after-summary mt-3 ps-0 pe-0" dir="rtl">
        <div id="wrTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
            <table id="wrTable" class="table table-striped table-hover erp-table erp-table-sortable">
                <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                    <tr>
                        <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                            <input type="checkbox" id="selectAll" class="form-check-input" />
                        </th>
                        <th data-col="id">@filterableCol("id", "id", "المعرف")</th>
                        <th data-col="warehouse">@filterableCol("warehouse", "warehouse", "كود المخزن")</th>
                        <th data-col="warehousename">@filterableCol("warehousename", "warehousename", "اسم المخزن")</th>
                        <th data-col="policy">@filterableCol("policy", "policy", "كود السياسة")</th>
                        <th data-col="policyname">@filterableCol("policyname", "policyname", "اسم السياسة")</th>
                        <th data-col="profit">@filterableCol("profit", "profit", "نسبة الربح %")</th>
                        <th data-col="maxdisc">@filterableCol("maxdisc", "maxdisc", "أقصى خصم للعميل %")</th>
                        <th data-col="created">@filterableCol("created", "created", "تاريخ الإنشاء")</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">لا توجد بيانات.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var r in Model.Items)
                        {
                            var editUrl = Url.Action("Edit", "WarehousePolicyRules", new { id = r.Id }) ?? "#";
                            <tr class="erp-list-selectable-row"
                                data-rule-id="@r.Id"
                                data-edit-url="@editUrl"
                                data-tab-title="تعديل قاعدة @r.Id">
                                <td class="text-center no-print" data-col="select">
                                    <input type="checkbox" class="form-check-input row-select" value="@r.Id" />
                                </td>
                                <td data-col="id">@r.Id</td>
                                <td data-col="warehouse">@r.WarehouseId</td>
                                <td data-col="warehousename">@(r.Warehouse?.WarehouseName ?? "-")</td>
                                <td data-col="policy">@r.PolicyId</td>
                                <td data-col="policyname">@(r.Policy?.Name ?? "-")</td>
                                <td data-col="profit">@r.ProfitPercent.ToString("0.00")%</td>
                                <td data-col="maxdisc">@(r.MaxDiscountToCustomer.HasValue ? r.MaxDiscountToCustomer.Value.ToString("0.00") + "%" : "-")</td>
                                <td data-col="created">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
