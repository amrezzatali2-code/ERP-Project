    @* ===== لوحة فلتر العمود (بنمط Excel) ===== *@
    <div id="erpColumnFilterPanelWarehousePolicyRules" class="erp-column-filter-panel d-none" dir="rtl">
        <div class="erp-column-filter-header">
            <span id="erpColumnFilterTitleWarehousePolicyRules">ترتيب وفلتر</span>
            <button type="button" class="btn-close btn-sm" id="erpColumnFilterCloseWarehousePolicyRules" aria-label="إغلاق"></button>
        </div>
        <div class="erp-column-filter-body">
