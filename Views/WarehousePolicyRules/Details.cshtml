@model ERP.Models.WarehousePolicyRule

@{
    ViewData["Title"] = "تفاصيل قاعدة سياسة لمخزن";
}

<div class="container" dir="rtl">
    <h2 class="mt-3 mb-3">تفاصيل قاعدة سياسة — @Model.Id</h2>

    <div class="card mb-3">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">كود القاعدة</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">كود المخزن</dt>
                <dd class="col-sm-9">@Model.WarehouseId</dd>

                <dt class="col-sm-3">كود السياسة</dt>
                <dd class="col-sm-9">@Model.PolicyId</dd>

                <dt class="col-sm-3">نسبة الربح %</dt>
                <dd class="col-sm-9">@Model.ProfitPercent.ToString("0.00")</dd>

                <dt class="col-sm-3">أقصى خصم للعميل %</dt>
                <dd class="col-sm-9">
                    @(Model.MaxDiscountToCustomer.HasValue
                                        ? Model.MaxDiscountToCustomer.Value.ToString("0.00")
                                        : "-")
                </dd>

                <dt class="col-sm-3">تاريخ الإنشاء</dt>
                <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

                <dt class="col-sm-3">آخر تعديل</dt>
                <dd class="col-sm-9">
                    @(Model.UpdatedAt.HasValue
                                        ? Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")
                                        : "-")
                </dd>
            </dl>

            <div class="d-flex gap-2 mt-3">
                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-erp btn-erp-primary">
                    تعديل
                </a>

                <a asp-action="Index"
                   class="btn btn-erp btn-erp-secondary">
                    رجوع للقائمة
                </a>
            </div>
        </div>
    </div>
</div>
