@model ERP.Models.WarehousePolicyRule

@{
    ViewData["Title"] = "إضافة قاعدة سياسة لمخزن";
}

<div class="container" dir="rtl">
    <h2 class="mt-3 mb-3">إضافة قاعدة سياسة لمخزن</h2>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="card mb-3">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                @* اختيار المخزن أولاً، ثم تظهر فقط السياسات التي لم يُحدد ربح لها لهذا المخزن *@
                <div class="mb-3">
                    <label asp-for="WarehouseId" class="form-label">المخزن</label>
                    <select asp-for="WarehouseId"
                            class="form-select"
                            asp-items="@(ViewBag.WarehouseList as SelectList)"
                            id="WarehouseId">
                        <option value="">-- اختر المخزن --</option>
                    </select>
                    <span asp-validation-for="WarehouseId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PolicyId" class="form-label">السياسة</label>
                    <select asp-for="PolicyId"
                            class="form-select"
                            asp-items="@(ViewBag.PolicyList as SelectList)"
                            id="PolicyId">
                        <option value="">-- اختر السياسة --</option>
                    </select>
                    <span asp-validation-for="PolicyId" class="text-danger"></span>
                    <small class="form-text text-muted">تظهر فقط السياسات التي لم يُحدد لها ربح لهذا المخزن بعد.</small>
                </div>

                @* نسبة الربح % *@
                <div class="mb-3">
                    <label asp-for="ProfitPercent" class="form-label">نسبة الربح %</label>
                    <input asp-for="ProfitPercent" class="form-control" />
                    <span asp-validation-for="ProfitPercent" class="text-danger"></span>
                </div>

                @* أقصى خصم للعميل % (اختياري) *@
                <div class="mb-3">
                    <label asp-for="MaxDiscountToCustomer" class="form-label">
                        أقصى خصم للعميل % (اختياري)
                    </label>
                    <input asp-for="MaxDiscountToCustomer" class="form-control" />
                    <span asp-validation-for="MaxDiscountToCustomer" class="text-danger"></span>
                </div>

                @* لو عندك حقل IsActive في الموديل *@
                
                <div class="mb-3 form-check">
                    <input asp-for="IsActive" class="form-check-input ms-2" />
                    <label asp-for="IsActive" class="form-check-label">مفعّلة؟</label>
                </div>
               

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        حفظ
                    </button>
                    <a asp-action="Index" class="btn btn-erp btn-erp-secondary">
                        رجوع للقائمة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var warehouseSelect = document.getElementById('WarehouseId');
            var policySelect = document.getElementById('PolicyId');
            if (!warehouseSelect || !policySelect) return;

            var placeholder = '-- اختر السياسة --';
            var urlPolicies = '@Url.Action("GetPoliciesNotUsedForWarehouse", "WarehousePolicyRules")';

            function fillPolicyOptions(warehouseId) {
                policySelect.innerHTML = '<option value="">' + placeholder + '</option>';
                policySelect.value = '';
                if (!warehouseId) return;
                fetch(urlPolicies + '?warehouseId=' + encodeURIComponent(warehouseId))
                    .then(function (r) { return r.ok ? r.json() : []; })
                    .then(function (arr) {
                        (arr || []).forEach(function (p) {
                            var opt = document.createElement('option');
                            opt.value = p.id;
                            opt.textContent = p.name;
                            policySelect.appendChild(opt);
                        });
                    })
                    .catch(function (err) { console.error('Error loading policies:', err); });
            }

            warehouseSelect.addEventListener('change', function () {
                fillPolicyOptions(this.value || null);
            });

            // عند تحميل الصفحة إذا كان المخزن معبّأ (بعد خطأ فاليديشن) نملأ السياسات ونحافظ على المختار
            var initialPolicyId = '@(Model?.PolicyId.ToString() ?? "")';
            if (warehouseSelect.value) {
                fillPolicyOptions(warehouseSelect.value);
                setTimeout(function () {
                    if (initialPolicyId && policySelect.querySelector('option[value="' + initialPolicyId + '"]')) {
                        policySelect.value = initialPolicyId;
                    }
                }, 100);
            }
        });
    </script>
}
