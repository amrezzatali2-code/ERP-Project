    </div>
    </div>








    <script>
                         function showToast(text, type) {
                             if (!text) return;
                             var container = document.getElementById('prToastContainer');
                             if (!container) return;
                             type = type || 'muted';
                             var el = document.createElement('div');
                             el.className = 'pr-toast text-' + type;
                             el.textContent = text;
                             container.appendChild(el);
                             setTimeout(function () {
                                 el.style.opacity = '0';
                                 el.style.transition = 'opacity 0.25s ease';
                                 setTimeout(function () {
                                     if (el.parentNode) el.parentNode.removeChild(el);
                                 }, 250);
                             }, 4000);
                         }
                         // ✅ إظهار المحتوى ككتلة واحدة بعد اكتمال الـ DOM (بدون ظهور تدريجي)
                         (function () {
                             function showContent() {
                                 document.body.classList.add('pr-content-ready');
                             }
                             if (document.readyState === 'complete' || document.readyState === 'interactive') {
                                 showContent();
                             } else {
                                 document.addEventListener('DOMContentLoaded', showContent);
                             }
                         })();
                         // ✅ رابط عرض طلب الشراء (من السيرفر) — لاستخدامه عند تحميل body بالأسهم/بحث
                         window.__PR_ShowBaseUrl__ = '@(Url.Action("Show", "PurchaseRequests", new { frame = 1 }))';

                         // =========================================================
                         // (0.5) إعدادات واجهة طلب الشراء — مثل فاتورة المبيعات
                         // =========================================================
                         const SI_UI_SETTINGS_DEFAULTS = { showClearAll: true, maxItems: 35, sortMode: 'location' };
                         const SI_THEME_STORAGE_KEY = 'erp.purchaserequest.page.theme.v2';
                         const SI_THEME_DEFAULT = 'dark-plum';
                         function normalizeInvoiceTheme(value) {
                             const theme = (value || '').toString().toLowerCase();
                             return (theme === 'dark-slate' || theme === 'dark-plum' || theme === 'dark-navy')
                                 ? theme
                                 : SI_THEME_DEFAULT;
                         }
                         function readStoredInvoiceTheme() {
                             try {
                                 return normalizeInvoiceTheme(localStorage.getItem(SI_THEME_STORAGE_KEY));
                             } catch {
                                 return SI_THEME_DEFAULT;
                             }
                         }
                         function writeStoredInvoiceTheme(theme) {
                             try {
                                 localStorage.setItem(SI_THEME_STORAGE_KEY, normalizeInvoiceTheme(theme));
                             } catch {
                             }
                         }
                         function applyInvoiceTheme(theme) {
                             const invoicePage = document.querySelector('.invoice-page');
                             if (!invoicePage) return;
                             invoicePage.classList.remove('theme-dark-navy', 'theme-dark-slate', 'theme-dark-plum');
                             const themeSelect = document.getElementById('siThemeSelect');
                             if (themeSelect) themeSelect.value = 'dark-navy';
                         }
                         let siUiSettingsMemory = { ...SI_UI_SETTINGS_DEFAULTS };
                         function readSiUiSettings() {
                             const sortModeRaw = (siUiSettingsMemory.sortMode || '').toString().toLowerCase();
                             const sortMode = (sortModeRaw === 'alpha' || sortModeRaw === 'location' || sortModeRaw === 'auto')
                                 ? sortModeRaw
                                 : 'location';
                             return {
                                 showClearAll: siUiSettingsMemory.showClearAll !== false,
                                 maxItems: (Number(siUiSettingsMemory.maxItems) > 0 ? Number(siUiSettingsMemory.maxItems) : 35),
                                 sortMode: sortMode
                             };
                         }
                         function writeSiUiSettings(s) {
                             const maxItems = (Number(s.maxItems) > 0 ? Number(s.maxItems) : 35);
                             const sortModeRaw = (s.sortMode || '').toString().toLowerCase();
                             const sortMode = (sortModeRaw === 'alpha' || sortModeRaw === 'location' || sortModeRaw === 'auto')
                                 ? sortModeRaw
                                 : 'location';
                             siUiSettingsMemory = {
                                 showClearAll: !!s.showClearAll,
                                 maxItems: maxItems,
                                 sortMode: sortMode
                             };
                         }
                         function getInvoiceMaxItemsFromSettings() {
                             return readSiUiSettings().maxItems || 35;
                         }
                         function getInvoiceSortModeFromSettings() {
                             return readSiUiSettings().sortMode || 'location';
                         }
                         function applySiUiSettings() {
                             const s = readSiUiSettings();
                             const clearBtn = document.getElementById('btnClearInvoiceLines');
                             const chk = document.getElementById('siShowClearAllChk');
                             const maxItemsInput = document.getElementById('siMaxItemsInput');
                             const sortModeSelect = document.getElementById('siSortModeSelect');
                             if (chk) chk.checked = s.showClearAll;
                             if (maxItemsInput) maxItemsInput.value = String(s.maxItems || 35);
                             if (sortModeSelect) sortModeSelect.value = (s.sortMode === 'alpha' ? 'alpha' : (s.sortMode === 'auto' ? 'auto' : 'location'));
                             if (clearBtn) clearBtn.classList.toggle('d-none', !s.showClearAll);
                         }
                         document.addEventListener('DOMContentLoaded', function () {
                             const toggleBtn = document.getElementById('btnInvoiceSettingsToggle');
                             const panel = document.getElementById('siInvoiceSettingsPanel');
                             const saveBtn = document.getElementById('btnSaveInvoiceSettingsInline');
                             const chk = document.getElementById('siShowClearAllChk');
                             const maxItemsInput = document.getElementById('siMaxItemsInput');
                             const sortModeSelect = document.getElementById('siSortModeSelect');
                             const themeSelect = document.getElementById('siThemeSelect');
                             if (toggleBtn && panel) {
                                 toggleBtn.addEventListener('click', function () {
                                     panel.classList.toggle('show');
                                 });
                             }
                             if (themeSelect) {
                                 themeSelect.addEventListener('change', function () {
                                     applyInvoiceTheme(themeSelect.value);
                                 });
                             }
                             if (saveBtn && chk) {
                                 saveBtn.addEventListener('click', function () {
                                     const maxItems = maxItemsInput ? parseInt(maxItemsInput.value || '35', 10) : 35;
                                     const sortMode = sortModeSelect ? sortModeSelect.value : 'location';
                                     writeStoredInvoiceTheme(themeSelect ? themeSelect.value : SI_THEME_DEFAULT);
                                     writeSiUiSettings({
                                         showClearAll: chk.checked,
                                         maxItems: (isNaN(maxItems) ? 35 : maxItems),
                                         sortMode: sortMode
                                     });
                                     applySiUiSettings();
                                     if (window.__piLinesCache && typeof window.renderGroupedLines === 'function') {
                                         window.renderGroupedLines(window.__piLinesCache);
                                     }
                                     showToast('تم حفظ إعدادات الفاتورة.', 'success', 2000);
                                 });
                             }
                             applyInvoiceTheme(readStoredInvoiceTheme());
                             applySiUiSettings();
                         });

                         // رسالة قابلة للإغلاق (زر موافق يزيل النافذة — بديل عن alert)
                         (function () {
                             var overlay = document.getElementById('erpPrMessageOverlay');
                             var textEl = document.getElementById('erpPrMessageText');
                             var btnOk = document.getElementById('erpPrMessageOk');
                             if (btnOk) {
                                 btnOk.addEventListener('click', function () {
                                     if (overlay) { overlay.style.display = 'none'; overlay.classList.add('d-none'); }
                                 });
                             }
                             window.showDismissibleMessage = function (msg) {
                                 if (!overlay || !textEl) return;
                                 textEl.textContent = msg || '';
                                 overlay.classList.remove('d-none');
                                 overlay.style.display = 'flex';
                                 if (btnOk) btnOk.focus();
                             };
                         })();

                         // =========================================================
                         // (A) أوتوكومبليت المورد (اسم ⇐⇒ كود + بيانات)
                         // — تُستدعى عند أول تحميل وبعد loadInvoiceBody لأن عناصر الهيدر والـ datalist تُستبدل
                         // =========================================================
                         function initSupplierAutocompletePr() {

                             // بوكسات بيانات المورد
                             const custNameInput      = document.getElementById('CustomerNameInput');    // متغير: اسم المورد
                             const custCodeInput      = document.getElementById('CustomerCodeDisplay');  // متغير: كود المورد الظاهر
                             const custPhoneInput     = document.getElementById('CustomerPhone');        // متغير: الهاتف
                             const custGovInput       = document.getElementById('CustomerGovernorate');  // متغير: المحافظة
                             const custDistrictInput  = document.getElementById('CustomerDistrict');     // متغير: الحي
                             const custAreaInput      = document.getElementById('CustomerArea');         // متغير: المنطقة
                             const custAddressInput   = document.getElementById('CustomerAddress');      // متغير: العنوان
                             const custCreditInput    = document.getElementById('CustomerCredit');       // متغير: الحد الائتماني
                             const custHiddenId       = document.getElementById('CustomerId');           // متغير: CustomerId (مخفي)

                            // الـ datalist الخاصة بالموردين (مخفي كمصدر بيانات فقط)
                            const custDataList = document.getElementById('customersList');

                             if (!custDataList) {
                                 console.warn('⚠️ Supplier datalist not found for CustomerNameInput');
                                 return; // نخرج من جزء المورد فقط
                             }

                            // نفس منطق فاتورة المبيعات: بحث متعدد الكلمات + ترتيب + حد أقصى للعرض (docs + invoice-entity-search-box-pattern)
                            const CUSTOMER_LIST_MAX = 80;

                            const allSuppliers = Array.from(custDataList.options || []).map(function (opt) {
                                return {
                                    id: (opt.getAttribute('data-id') || '').toString(),
                                    name: (opt.value || '').toString(),
                                    phone: (opt.getAttribute('data-phone') || '').toString(),
                                    address: (opt.getAttribute('data-address') || '').toString(),
                                    gov: (opt.getAttribute('data-gov') || '').toString(),
                                    district: (opt.getAttribute('data-district') || opt.getAttribute('data-District') || '').toString(),
                                    area: (opt.getAttribute('data-area') || opt.getAttribute('data-Area') || '').toString(),
                                    credit: (opt.getAttribute('data-credit') || opt.getAttribute('data-Credit') || '').toString()
                                };
                            });

                            function normalizeDigits(s) {
                                if (!s) return '';
                                const map = { '\u0660': '0', '\u0661': '1', '\u0662': '2', '\u0663': '3', '\u0664': '4',
                                    '\u0665': '5', '\u0666': '6', '\u0667': '7', '\u0668': '8', '\u0669': '9' };
                                let out = '';
                                for (let i = 0; i < s.length; i++) {
                                    const c = s[i];
                                    out += map[c] !== undefined ? map[c] : c;
                                }
                                return out;
                            }

                            function normalizeWord(w) {
                                return normalizeDigits((w || '').trim().toLowerCase()).replace(/^[اأإآ]/u, '');
                            }

                            function normalizeText(txt) {
                                return (txt || '')
                                    .trim()
                                    .toLowerCase()
                                    .split(/\s+/)
                                    .filter(Boolean)
                                    .map(function (w) { return normalizeWord(w); })
                                    .filter(Boolean)
                                    .join(' ')
                                    .replace(/\s+/g, ' ');
                            }

                            function wordMatchesQueryWord(nameWord, queryWord) {
                                const nw0 = normalizeDigits((nameWord || '').trim().toLowerCase());
                                const qw0 = normalizeDigits((queryWord || '').trim().toLowerCase());
                                const nw = nw0.replace(/^[اأإآ]/u, '');
                                const qw = qw0.replace(/^[اأإآ]/u, '');
                                if (!qw) return true;
                                return nw === qw || nw.startsWith(qw);
                            }

                            function supplierNameMatchesSearch(supplierName, rawSearch) {
                                const raw = (rawSearch || '').trim();
                                if (!raw) return true;
                                const qWords = raw.split(/\s+/).filter(Boolean);
                                const nWords = (supplierName || '').trim().split(/\s+/).filter(Boolean);
                                if (qWords.length === 0) return true;
                                return qWords.every(function (qw) {
                                    return nWords.some(function (nw) { return wordMatchesQueryWord(nw, qw); });
                                });
                            }

                            function supplierSearchRank(name, rawSearch) {
                                const raw = (rawSearch || '').trim();
                                const nm = (name || '').trim();
                                if (!raw) return 50;
                                if (nm === raw) return 0;
                                if (nm.startsWith(raw)) return 1;
                                const rawWords = raw.split(/\s+/).filter(Boolean);
                                const firstQ = rawWords[0] || '';
                                const nmWords = nm.split(/\s+/).filter(Boolean);
                                if (firstQ && nmWords.length) {
                                    if (nmWords[0].startsWith(firstQ)) return 2;
                                    const nw0 = normalizeDigits(nmWords[0].toLowerCase());
                                    const qw0 = normalizeDigits(firstQ.toLowerCase());
                                    const nw = nw0.replace(/^[اأإآ]/u, '');
                                    const qw = qw0.replace(/^[اأإآ]/u, '');
                                    if (qw && (nw === qw || nw.startsWith(qw))) return 3;
                                }
                                return 4;
                            }

                            function findSupplierByName(name) {
                                const raw = (name || '').trim();
                                const search = normalizeText(raw);
                                if (!search) return null;
                                for (let i = 0; i < allSuppliers.length; i++) {
                                    if (normalizeText(allSuppliers[i].name) === search) return allSuppliers[i];
                                }
                                for (let i = 0; i < allSuppliers.length; i++) {
                                    if ((allSuppliers[i].name || '').trim() === raw) return allSuppliers[i];
                                }
                                return null;
                            }

                            function findSupplierByCode(code) {
                                const search = (code || '').toString().trim();
                                if (!search) return null;
                                for (let i = 0; i < allSuppliers.length; i++) {
                                    if ((allSuppliers[i].id || '').toString() === search) return allSuppliers[i];
                                }
                                return null;
                            }

                            function fillSupplierFromRecord(rec) {
                                if (!rec) {
                                    if (custHiddenId)      custHiddenId.value      = '';
                                    if (custCodeInput)     custCodeInput.value     = '';
                                    if (custNameInput)     custNameInput.value     = '';
                                    if (custPhoneInput)    custPhoneInput.value    = '';
                                    if (custGovInput)      custGovInput.value      = '';
                                    if (custDistrictInput) custDistrictInput.value = '';
                                    if (custAreaInput)     custAreaInput.value     = '';
                                    if (custAddressInput)  custAddressInput.value  = '';
                                    if (custCreditInput)   custCreditInput.value   = '';
                                    var btnVol = document.getElementById('btnSupplierVolume');
                                    if (btnVol) { btnVol.href = '#'; btnVol.setAttribute('data-url', ''); }
                                    return;
                                }
                                const id       = (rec.id || '').toString();
                                const name     = (rec.name || '').toString();
                                const phone    = (rec.phone || '').toString();
                                const address  = (rec.address || '').toString();
                                const gov      = (rec.gov || '').toString();
                                const district = (rec.district || '').toString();
                                const area     = (rec.area || '').toString();
                                const credit   = (rec.credit || '').toString();

                                if (custHiddenId)  custHiddenId.value  = id;
                                if (custCodeInput) custCodeInput.value = id;
                                if (custNameInput)     custNameInput.value     = name;
                                if (custPhoneInput)    custPhoneInput.value    = phone;
                                if (custGovInput)      custGovInput.value      = gov;
                                if (custDistrictInput) custDistrictInput.value = district;
                                if (custAreaInput)     custAreaInput.value     = area;
                                if (custAddressInput)  custAddressInput.value  = address;
                                if (custCreditInput)   custCreditInput.value   = credit;

                                var btnVol = document.getElementById('btnSupplierVolume');
                                if (btnVol) {
                                    var cid = parseInt(id || '0', 10) || 0;
                                    var volBase = btnVol.getAttribute('data-base-url') || '';
                                    var volUrl = cid > 0 ? (volBase + (volBase.indexOf('?') >= 0 ? '&' : '?') + 'id=' + cid) : '#';
                                    btnVol.href = volUrl;
                                    btnVol.setAttribute('data-url', volUrl);
                                }
                            }

                            function fillSupplierFromOption(opt) {
                                if (!opt) { fillSupplierFromRecord(null); return; }
                                if (typeof opt.getAttribute === 'function') {
                                    fillSupplierFromRecord({
                                        id: (opt.getAttribute('data-id') || '').toString(),
                                        name: (opt.value || '').toString(),
                                        phone: (opt.getAttribute('data-phone') || '').toString(),
                                        address: (opt.getAttribute('data-address') || '').toString(),
                                        gov: (opt.getAttribute('data-gov') || '').toString(),
                                        district: (opt.getAttribute('data-district') || opt.getAttribute('data-District') || '').toString(),
                                        area: (opt.getAttribute('data-area') || opt.getAttribute('data-Area') || '').toString(),
                                        credit: (opt.getAttribute('data-credit') || opt.getAttribute('data-Credit') || '').toString()
                                    });
                                } else {
                                    fillSupplierFromRecord(opt);
                                }
                            }

                            const supplierDropdownWrap = document.getElementById('prSupplierDropdownWrap');
                            const supplierDropdownList = document.getElementById('prSupplierDropdownList');
                            const supplierDropdownArrow = document.getElementById('prSupplierDropdownArrow');

                            let supplierDropdownHighlightedIndex = -1;
                            let supplierDropdownSelectableSuppliers = [];
                            let isSelectingSupplier = false;

                            function positionSupplierDropdownList() {
                                if (!supplierDropdownList || !supplierDropdownWrap) return;
                                if (supplierDropdownList.getAttribute('data-open') !== 'true') return;

                                const r = supplierDropdownWrap.getBoundingClientRect();
                                supplierDropdownList.style.width = r.width + 'px';
                                supplierDropdownList.style.top = r.bottom + 'px';
                                supplierDropdownList.style.left = r.left + 'px';
                            }

                            function closeSupplierDropdown() {
                                if (supplierDropdownList) {
                                    supplierDropdownList.setAttribute('data-open', 'false');
                                    supplierDropdownList.innerHTML = '';
                                }
                                supplierDropdownHighlightedIndex = -1;
                                supplierDropdownSelectableSuppliers = [];
                            }

                            function setSupplierDropdownHighlight(idx) {
                                if (!supplierDropdownList) return;
                                if (idx < 0 || idx >= supplierDropdownSelectableSuppliers.length) return;

                                const children = supplierDropdownList.querySelectorAll('.product-dropdown-item');
                                children.forEach(function (el, i) {
                                    el.classList.toggle('product-dropdown-item-active', i === idx);
                                });
                                supplierDropdownHighlightedIndex = idx;

                                try {
                                    children[idx]?.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                                } catch { }
                            }

                            function getFilteredSupplierOptions(search, max) {
                                if (!allSuppliers || !allSuppliers.length) return [];
                                const limit = max || CUSTOMER_LIST_MAX;
                                const rawTrim = (search || '').trim();
                                if (!rawTrim) return allSuppliers.slice(0, limit);

                                const qNorm = normalizeText(rawTrim);
                                const words = rawTrim.split(/\s+/).filter(Boolean);
                                const matched = [];
                                for (let i = 0; i < allSuppliers.length; i++) {
                                    const s = allSuppliers[i];
                                    const idStr = (s.id || '').toString().trim();
                                    const nameOk = qNorm ? supplierNameMatchesSearch(s.name || '', rawTrim) : true;
                                    const idOk = words.length > 0 && words.some(function (w) { return idStr.indexOf(w) !== -1; });
                                    const codeRawOk = idStr && idStr.indexOf(rawTrim) !== -1;
                                    if (nameOk || idOk || codeRawOk) matched.push(s);
                                }
                                matched.sort(function (a, b) {
                                    const ra = supplierSearchRank(a.name || '', rawTrim);
                                    const rb = supplierSearchRank(b.name || '', rawTrim);
                                    if (ra !== rb) return ra - rb;
                                    return (a.name || '').localeCompare(b.name || '', 'ar');
                                });
                                return matched.slice(0, limit);
                            }

                            function openSupplierDropdown() {
                                if (!supplierDropdownList || !supplierDropdownWrap || !custNameInput) return;

                                const raw = (custNameInput.value || '').trim();
                                const list = getFilteredSupplierOptions(raw, CUSTOMER_LIST_MAX);

                                supplierDropdownList.innerHTML = '';
                                supplierDropdownSelectableSuppliers = [];

                                let highlightIdx = 0;
                                const currentVal = (custNameInput.value || '').trim();
                                if (list.length > 0) {
                                    for (let i = 0; i < list.length; i++) {
                                        if (normalizeText(list[i].name || '').trim() === normalizeText(currentVal)) {
                                            highlightIdx = i;
                                            break;
                                        }
                                    }
                                }

                                if (!list.length) {
                                    const empty = document.createElement('div');
                                    empty.className = 'product-dropdown-item text-muted py-2 px-3 small';
                                    empty.textContent = raw ? 'لا توجد نتائج' : ('اكتب للبحث ثم انزل بالسهم ▼ واختر (' + CUSTOMER_LIST_MAX + ' كحد أقصى)');
                                    supplierDropdownList.appendChild(empty);
                                    supplierDropdownHighlightedIndex = -1;
                                } else {
                                    list.forEach(function (c, idx) {
                                        const it = document.createElement('div');
                                        it.className = 'product-dropdown-item py-2 px-3' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                                        it.setAttribute('role', 'option');
                                        it.textContent = (c.name || '').trim();
                                        it.addEventListener('mousedown', function (ev) { ev.preventDefault(); });
                                        it.addEventListener('click', function (ev) {
                                            ev.preventDefault();
                                            isSelectingSupplier = true;
                                            fillSupplierFromRecord(c);
                                            custNameInput.value = (c.name || '').trim();
                                            closeSupplierDropdown();
                                            setTimeout(function () {
                                                custNameInput?.focus();
                                                isSelectingSupplier = false;
                                            }, 0);
                                        });
                                        supplierDropdownList.appendChild(it);
                                        supplierDropdownSelectableSuppliers.push(c);
                                    });
                                    supplierDropdownHighlightedIndex = highlightIdx;
                                }

                                supplierDropdownList.setAttribute('data-open', 'true');
                                positionSupplierDropdownList();
                            }

                            function selectHighlightedSupplier(keepOpen) {
                                if (supplierDropdownHighlightedIndex < 0) return false;
                                if (supplierDropdownHighlightedIndex >= supplierDropdownSelectableSuppliers.length) return false;

                                const selected = supplierDropdownSelectableSuppliers[supplierDropdownHighlightedIndex];
                                if (!selected) return false;

                                isSelectingSupplier = true;
                                fillSupplierFromRecord(selected);
                                custNameInput.value = (selected.name || '').trim();
                                if (!keepOpen) closeSupplierDropdown();

                                setTimeout(function () {
                                    custNameInput?.focus();
                                    isSelectingSupplier = false;
                                }, 0);
                                return true;
                            }

                            // change: للتعامل مع حالة اختيار نصّي/تلقائي
                            if (custNameInput) {
                                custNameInput.addEventListener('change', () => {
                                    fillSupplierFromOption(findSupplierByName(custNameInput.value));
                                });

                                // open على الكتابة فقط (input event)
                                custNameInput.addEventListener('input', function () {
                                    if (isSelectingSupplier) return;
                                    openSupplierDropdown();
                                });
                            }

