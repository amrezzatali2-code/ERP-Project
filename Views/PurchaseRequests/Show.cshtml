                                         <td class="text-center">
                                             <input type="number" 
                                                    class="form-control form-control-sm text-center editable-line-field" 
                                                    data-field="discount" 
                                                    data-line-no="${lineNo}"
                                                    data-prod-id="${g.prodId}"
                                                    value="${fmt2(discPct)}" 
                                                    min="0"
                                                    max="100"
                                                    step="0.01"
                                                    autocomplete="off"
