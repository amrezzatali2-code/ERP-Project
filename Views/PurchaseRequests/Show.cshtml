                         // ===============================
                         // Helper: تنسيق تاريخ MM/yyyy من yyyy-MM-dd أو DateTime
                         // ===============================
                         function formatDateYMD(value) {
                             try {
                                 if (!value) return '';
                                 
                                 // لو القيمة بصيغة MM/yyyy بالفعل، نرجعها كما هي
                                 if (typeof value === 'string' && /^\d{2}\/\d{4}$/.test(value)) {
                                     return value;
                                 }
                                 
                                 // لو القيمة بصيغة yyyy-MM-dd أو DateTime
                                 const d = new Date(value);
                                 if (isNaN(d.getTime())) return '';
                                 const yyyy = d.getFullYear();
                                 const mm = String(d.getMonth() + 1).padStart(2, '0');
                                 return `${mm}/${yyyy}`;
                             } catch {
                                 return '';
                             }
                         }


