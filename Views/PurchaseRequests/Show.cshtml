                                     // =========================
                                    // نظام تنقّل فواتير المشتريات (تحميل جزئي + أسهم جانبية + منع فتح تبويبات + إدارة Tooltips)
                                   // =========================


                                 (function () {

                             // =========================================================
                             // ✅ Guard: يمنع تركيب نفس السكربت أكثر من مرة
                             // =========================================================
                             if (window.__PI_NAV_SCRIPT_LOADED__) return;
