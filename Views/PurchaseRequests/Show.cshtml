                             const n = parseFloat(s);
                             return isNaN(n) ? 0 : n;
                         };

                         // دالة: إضافة الشرطة تلقائياً لتاريخ الصلاحية (شهر+سنة بدون شرطة -> شهر/سنة)
                         // مثال: 529 -> شهر 5 سنة 2029 -> 05/2029
                         window.formatExpiryWithSlash = window.formatExpiryWithSlash || function (val) {
                             const s = (val || '').toString().trim().replace(/\s/g, '');
                             if (!s) return '';
                             const digits = s.replace(/\D/g, '');
                             if (digits.length === 3) { const m = digits[0]; const yy = digits.slice(1, 3); return ('0' + m).slice(-2) + '/' + '20' + yy; }   // 529 -> 05/2029
                             if (digits.length === 4) { const mm = digits.slice(0, 2); const yy = digits.slice(2, 4); return mm + '/' + '20' + yy; }         // 1225 -> 12/2025
                             if (digits.length === 5) { const m = digits[0]; const yyyy = digits.slice(1, 5); return ('0' + m).slice(-2) + '/' + yyyy; }     // 52029 -> 05/2029
                             if (digits.length >= 6) { const mm = digits.slice(0, 2); const yyyy = digits.slice(2, 6); return mm + '/' + yyyy; }             // 122025 -> 12/2025
                             return s;
                         };

