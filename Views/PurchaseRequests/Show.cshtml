                             // ✅ مثل فاتورة المبيعات: تحديث الطلب الحالي فقط (بدون فتح طلب آخر)
                             window.__ERP_REFRESH__ = function () {
                                 const currentId = parseInt((document.getElementById('NavCurrentId')?.value || '0'), 10) || 0;
                                 const baseUrl = document.getElementById('btnNavInvoiceSearch')?.getAttribute('data-base-url') || '@Url.Action("Show", "PurchaseRequests", new { frame = 1 })';
                                 const load = window.loadInvoiceBody;
                                 if (currentId > 0 && typeof load === 'function') {
                                     try {
                                         const u = new URL(baseUrl, window.location.origin);
                                         u.searchParams.set('id', currentId);
                                         load(u.toString());
                                     } catch (e) { console.warn('__ERP_REFRESH__:', e); }
                                 }
                             };

                            // =========================
                            // اعتراض الضغط على الأسهم/بحث الطلب على مستوى document (Capture)
                            // =========================
                            async function docCaptureHandler(ev) {

                                // متغير: العنصر الذي تم الضغط عليه
                                const t = ev.target;

                                // حماية: لو target مش Element (نادرًا) نخرج
                                if (!(t instanceof Element)) return;

                                // ✅ الأسهم + البحث: نتعامل معهم هنا (عند فتح الصفحة داخل iframe لا يصل النقر إلى site.js)
                                // لا نرجع هنا؛ نترك الكود يصل إلى معالج (1) الأسهم + البحث لتنفيذ loadInvoiceBody





                              // =========================
                             // (0) مسح سطر محدد من كارت الإجراءات
                             // =========================
                             const removeSelectedBtn = (t.id === 'btnRemoveSelectedLine' || t.closest('#btnRemoveSelectedLine'))
                                 ? document.getElementById('btnRemoveSelectedLine')
                                 : null;
                             if (removeSelectedBtn) {

                                 ev.preventDefault();
                                 ev.stopPropagation();
                                 ev.stopImmediatePropagation();

                                 const selRow = document.querySelector('#PILinesTbody tr.pi-row-selected[data-line-no]');
                                 if (!selRow) {
                                     alert('اختر سطراً من جدول الأصناف أولاً (اضغط على السطر غير خانات التعديل).');
                                     return;
                                 }

                                 const lineNo = parseInt(selRow.getAttribute('data-line-no') || '0', 10);

                                               // ✅ رقم الطلب (لازم يتقري وقت الضغط من الـ DOM لأنه بيتغير مع الـ Reload الجزئي)
                             const PRId = parseInt((document.getElementById('InvoiceId')?.value || '0'), 10) || 0;


                                 if (!PRId || PRId <= 0) { alert('لا يمكن مسح سطر: رقم الطلب غير معروف.'); return; }
                                 if (!lineNo || lineNo <= 0) { alert('لا يمكن مسح سطر: رقم السطر غير صحيح.'); return; }

                                 let okDelete = false;
                                 if (typeof ERP !== 'undefined' && typeof ERP.showConfirmModal === 'function') {
                                     okDelete = await ERP.showConfirmModal({
                                         title: 'مسح سطر من الطلب',
                                         message: `هل تريد مسح السطر رقم (${lineNo})؟`,
                                         confirmText: 'مسح',
                                         cancelText: 'إلغاء'
                                     });
                                 } else {
                                     okDelete = confirm(`هل تريد مسح السطر رقم (${lineNo})؟`);
                                 }
                                 if (!okDelete) return;

                                 // منع الضغط المتكرر أثناء التنفيذ
                                 removeSelectedBtn.disabled = true;

                                 // ✅ متغير: توكن AntiForgery (من الدالة المثبتة عندك في Show)
                                 const antiToken = (window.getAntiForgeryToken ? window.getAntiForgeryToken() : '');

                                 // متغير: تايم آوت علشان ما يفضلش معلق
                                 const controller = new AbortController();
                                 const timeoutId = setTimeout(() => controller.abort(), 30000); // 30 ثانية

                                 try {
                                     // ✅ استدعاء الأكشن الصحيح: RemoveLineJson
                                     const res = await fetch('@Url.Action("RemoveLineJson", "PurchaseRequests")', {
                                         method: 'POST',
                                         credentials: 'same-origin',
                                         signal: controller.signal,
                                         headers: {
                                             'Content-Type': 'application/json',
                                             'X-Requested-With': 'XMLHttpRequest',
                                             ...(antiToken ? { 'RequestVerificationToken': antiToken } : {})
                                         },
                                         // ✅ لازم نفس أسماء الـ DTO
                                         body: JSON.stringify({ PRId: PRId, LineNo: lineNo })
                                     });

                                     // متغير: نحاول نفهم الرد سواء JSON أو نص
                                     let data = null;
                                     const contentType = (res.headers.get('content-type') || '').toLowerCase();

                                     if (contentType.includes('application/json')) {
                                         data = await res.json().catch(() => null);
                                     } else {
                                         const txt = await res.text().catch(() => '');
                                         data = { ok: false, message: txt ? 'فشل مسح السطر (رد غير متوقع من السيرفر).' : 'فشل مسح السطر.' };
                                     }

                                     if (!res.ok || !data || data.ok !== true) {
                                         const msg = (data && data.message) ? data.message : 'فشل مسح السطر.';
                                         alert(msg);
                                         return;
                                     }

                                     // ✅ تحديث الجدول والإجماليات مباشرة من رد السيرفر (بدون Reload)
                                     const lines = (data.lines || []).map(l => ({
                                         ...l,
                                         preferredBatchNo: l.batchNo ?? l.preferredBatchNo,
                                         preferredExpiry: l.expiry ?? l.preferredExpiry,
                                         qtyRequested: l.qty ?? l.qtyRequested,
                                         purchaseDiscountPct: l.discPct ?? l.purchaseDiscountPct
                                     }));
                                     if (typeof renderGroupedLines === 'function') renderGroupedLines(lines);
                                     if (data.totals && typeof window.updateSummaryBadges === 'function') {
                                         window.updateSummaryBadges(data.totals);
                                     } else if (typeof window.recalcTotalsFromPage === 'function') {
                                         window.recalcTotalsFromPage();
                                     }
                                     if (typeof bindEditableLineFields === 'function') setTimeout(() => bindEditableLineFields(), 50);

                                     showToast(data.message || 'تم حذف السطر.', 'success');

                                 } catch (e) {
                                     console.error(e);

                                     if (e && e.name === 'AbortError') {
                                         alert('التنفيذ أخذ وقت طويل. حاول مرة أخرى.');
                                     } else {
                                         alert('حدث خطأ أثناء مسح السطر.');
                                     }
                                 } finally {
                                     clearTimeout(timeoutId);

                                     if (document.contains(removeSelectedBtn)) {
                                         removeSelectedBtn.disabled = false;
                                     }
                                 }

                                 return; // مهم: منع استمرار التعامل كأنه زر أسهم
                             }






                                // =========================
                                // (1) الأسهم + البحث
                                // =========================
                                const btn = t.closest('#btnFirstInvoice, #btnPrevInvoice, #btnNextInvoice, #btnLastInvoice, #btnNavInvoiceSearch');
                                if (!btn) return;

                                if (btn.hasAttribute('disabled')) return;

                                // ✅ امنع أي نظام تابات/لينكات
                                ev.preventDefault();
                                ev.stopPropagation();
                                ev.stopImmediatePropagation();

                                // ✅ مهم: اقفل Tooltip + شيل فوكس بعد الضغط
                                hideTooltipAndBlur(btn);

                                if (btn.id === 'btnNavInvoiceSearch') {
                                    const input = document.getElementById('NavInvoiceSearchInput');
                                    const val = input ? parseInt(input.value || '0', 10) : 0;
                                    if (!val || val <= 0) return;
                                    loadInvoiceBody(val);
                                    return;
                                }

                                // ✅ للأزرار: نقرأ data-id (رقم الطلب المستهدف) ونحمّل body من المسار الحالي
                                refreshSideNavButtons();
                                const btnId = btn.getAttribute('data-id');
                                const targetId = btnId ? parseInt(btnId, 10) : 0;
                                if (!targetId || targetId <= 0) return;
                                loadInvoiceBody(targetId);
                             }








                 // =========================================================
                 // ERP — زر طباعة طلب الشراء (قائمة منسدلة: صفحة واحدة / أصل وصورة / أصل وصورتين)
                 // =========================================================
                 document.addEventListener("DOMContentLoaded", function () {

                     const btnPrint = document.getElementById("btnPrintInvoice");
                     if (!btnPrint) return;
                     if (btnPrint.dataset.boundPrint) return;
                     btnPrint.dataset.boundPrint = "1";

                     if (typeof isInvoicePosted === "function" && !isInvoicePosted()) {
                         btnPrint.disabled = true;
                     }

                     let printing = false;
                     let printWrapperParent = null;
                     let printWrapperNext = null;

                     function preparePurchaseRequestPrint() {
                         const printArea = document.getElementById("piPrintArea");
                         if (!printArea) return false;

                         const invoiceId = (document.getElementById("InvoiceId")?.value || "").trim();
                         const invoiceDate = (document.getElementById("InvoiceDateDisplay")?.value || document.getElementById("PIDate")?.value || "").trim();
                         const supplierName = (document.getElementById("CustomerNameInput")?.value || "").trim();
                         let warehouseName = "";
                         const whSel = document.getElementById("WarehouseId");
                         if (whSel && whSel.options && whSel.selectedIndex >= 0) {
                             warehouseName = (whSel.options[whSel.selectedIndex].text || "").trim();
                         }

                         const el = (id) => document.getElementById(id);
                         if (el("piPrintNow")) el("piPrintNow").textContent = new Date().toLocaleString();
                         if (el("piPrintInvoiceNo")) el("piPrintInvoiceNo").textContent = invoiceId || "";
                         if (el("piPrintInvoiceDate")) el("piPrintInvoiceDate").textContent = invoiceDate || "";
                         if (el("piPrintSupplier")) el("piPrintSupplier").textContent = supplierName || "";
                         if (el("piPrintWarehouse")) el("piPrintWarehouse").textContent = warehouseName || "";
                         const supplierPhone = (el("CustomerPhone") && el("CustomerPhone").value) ? el("CustomerPhone").value.trim() : "";
                         if (el("piPrintCustomerPhone")) el("piPrintCustomerPhone").textContent = supplierPhone || "—";
                         const supplierAddress = (el("CustomerAddress") && el("CustomerAddress").value) ? el("CustomerAddress").value.trim() : "";
                         if (el("piPrintCustomerAddress")) el("piPrintCustomerAddress").textContent = supplierAddress || "—";
                         const createdBy = (el("InvoiceCreatedByDisplay") && el("InvoiceCreatedByDisplay").value) ? el("InvoiceCreatedByDisplay").value.trim() : "";
                         if (el("piPrintAuthor")) el("piPrintAuthor").textContent = createdBy || "—";

                         const destTbody = el("piPrintMasterTbody");
                         if (!destTbody) return false;
                         destTbody.innerHTML = "";
                         const srcTbody = document.getElementById("PILinesTbody");
                         if (!srcTbody) {
                             destTbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-2">لا توجد سطور للطباعة.</td></tr>';
                         } else {
                             const rows = srcTbody.querySelectorAll("tr");
                             if (!rows.length) {
                                 destTbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-2">لا توجد سطور للطباعة.</td></tr>';
                             } else {
                                 rows.forEach(function (tr) {
                                     const c = tr.cloneNode(true);
                                     c.querySelectorAll("button, a, .no-print").forEach(x => x.remove());
                                     c.querySelectorAll("th.no-print, td.no-print").forEach(x => x.remove());
                                     destTbody.appendChild(c);
                                 });
                             }
                         }

                         const totalsWrap = el("piPrintTotalsWrap");
                         if (!totalsWrap) return false;
                         const totalItems = el("TotalItemsValue")?.textContent?.trim() || "0";
                         const totalQty = el("TotalQtyValue")?.textContent?.trim() || "0";
                         const totalRetail = el("TotalRetailValue")?.textContent?.trim() || "0";
                         const totalAfterDiscount = el("TotalAfterDiscountValue")?.textContent?.trim() || "0";
                         const taxPct = (el("TaxPercentInput") && el("TaxPercentInput").value) ? el("TaxPercentInput").value.trim() : "0";
                         const tax = (el("TaxAmountValue")?.textContent || "").trim() || (el("TaxAmountInput")?.value || "").trim() || "0";
                         const totalAfterDiscountAndTax = el("TotalAfterDiscountAndTaxValue")?.textContent?.trim() || "0";
                         const netTotal = el("NetTotalValue")?.textContent?.trim() || "0";
                         const grandWithPrev = el("GrandTotalWithPreviousValue")?.textContent?.trim() || totalAfterDiscountAndTax || totalAfterDiscount || netTotal;
                         const prevBalance = el("CustomerPreviousBalanceValue")?.textContent?.trim() || "0";

                         totalsWrap.innerHTML = `
<div class="card shadow-sm invoice-totals-card mb-0">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-boxes">
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">عدد الأصناف</span><span class="invoice-summary-value">${totalItems}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي الكمية</span><span class="invoice-summary-value">${totalQty}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">الحساب السابق للمورد</span><span class="invoice-summary-value">${prevBalance}</span></div>
        </div>
        <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-totals mt-2">
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">اجمالي الجمهور</span><span class="invoice-summary-value">${totalRetail}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">إجمالي الطلب</span><span class="invoice-summary-value">${totalAfterDiscount}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">نسبة الضريبة %</span><span class="invoice-summary-value">${taxPct}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">قيمة الضريبة</span><span class="invoice-summary-value">${tax}</span></div>
            <div class="invoice-summary-item invoice-summary-box"><span class="invoice-summary-label">الإجمالي</span><span class="invoice-summary-value fw-bold">${grandWithPrev}</span></div>
        </div>
    </div>
</div>`;
                         return true;
                     }

                     function doPurchaseRequestPrint(mode) {
                         const invoiceId = parseInt((document.getElementById("InvoiceId")?.value || "0"), 10) || 0;
                         if (invoiceId <= 0) {
                             showToast("⚠️ لا يمكن طباعة طلب قبل حفظه.", "warning");
                             return;
                         }
                         if (typeof isInvoicePosted === "function" && !isInvoicePosted()) {
                             showToast("❌ لا يمكن طباعة الطلب إلا بعد التحويل.", "danger");
                             document.getElementById("btnPostInvoice")?.focus();
                             return;
                         }
                         if (printing) return;
                         printing = true;

                         if (!preparePurchaseRequestPrint()) {
                             printing = false;
                             showToast("تعذر تجهيز الطباعة.", "danger");
                             return;
                         }

                         const wrapper = document.getElementById("piPrintWrapper");
                         const printArea = document.getElementById("piPrintArea");
                         if (!wrapper || !printArea) { printing = false; return; }

                         wrapper.classList.remove("print-mode-1", "print-mode-2", "print-mode-3");
                         wrapper.querySelectorAll(".pi-print-copy:not(#piPrintArea)").forEach(c => c.remove());

                         if (mode === 2 || mode === 3) {
                             const copies = mode === 2 ? 2 : 3;
                             for (let i = 1; i < copies; i++) {
                                 const clone = printArea.cloneNode(true);
                                 clone.id = "";
                                 clone.classList.add("pi-print-copy");
                                 clone.querySelectorAll("[id]").forEach(el => el.removeAttribute("id"));
                                 wrapper.appendChild(clone);
                             }
                             wrapper.classList.add("print-mode-" + mode);
                         } else {
                             wrapper.classList.add("print-mode-1");
                         }

                         printWrapperParent = null;
                         printWrapperNext = null;
                         if (wrapper.parentNode !== document.body) {
                             printWrapperParent = wrapper.parentNode;
                             printWrapperNext = wrapper.nextSibling;
                             document.body.appendChild(wrapper);
                         }

                         document.body.classList.add("printing-invoice");
                         setTimeout(() => window.print(), 50);
                     }

                     document.querySelectorAll("[data-pr-print-mode]").forEach(item => {
                         item.addEventListener("click", function (e) {
                             e.preventDefault();
                             const mode = parseInt(this.getAttribute("data-pr-print-mode") || "1", 10);
                             doPurchaseRequestPrint(mode);
                         });
                     });

                     window.addEventListener("afterprint", function () {
                         document.body.classList.remove("printing-invoice");
                         printing = false;
                         const wrapper = document.getElementById("piPrintWrapper");
                         if (wrapper) {
                             wrapper.classList.remove("print-mode-1", "print-mode-2", "print-mode-3");
                             wrapper.querySelectorAll(".pi-print-copy:not(#piPrintArea)").forEach(c => c.remove());
                             if (printWrapperParent) {
                                 if (printWrapperNext) {
                                     printWrapperParent.insertBefore(wrapper, printWrapperNext);
                                 } else {
                                     printWrapperParent.appendChild(wrapper);
                                 }
                                 printWrapperParent = null;
                                 printWrapperNext = null;
                             }
                         }
                     });
                 });










                             // =========================
                             // تشغيل
                             // =========================
                             document.addEventListener('click', docCaptureHandler, true);

                             document.addEventListener('DOMContentLoaded', function () {

                                 // ✅ أول ما الصفحة تفتح: نضبط الأزرار (فوراً)
                                 refreshSideNavButtons();

                                 // ✅ أول ما الصفحة تفتح: نضبط Tooltips (الأسهم فقط)
                                 setupTooltips();
                                 
                                 // ✅ تأكد من تحديث data-url مرة أخرى بعد تأخير بسيط (لضمان التحديث)
                                 setTimeout(function() {
                                     refreshSideNavButtons();
                                 }, 100);

                                 // ✅ إزالة Tooltip من البحث نهائيًا (Placeholder فقط)
                                 const input = document.getElementById('NavInvoiceSearchInput');
                                 if (input) {
                                     input.removeAttribute('title');
                                     // تعليق: placeholder هو اللي هيوضح وظيفة البحث
                                     if (!input.getAttribute('placeholder')) input.setAttribute('placeholder', 'بحث برقم الطلب');
                                 }

                                 const btn = document.getElementById('btnNavInvoiceSearch');
                                 if (btn) btn.removeAttribute('title');

                                 // ✅ لو طلب جديد (PRId = 0): نعمل focus على حقل اسم المورد
                                 const invoiceIdInput = document.getElementById('InvoiceId');
                                 const invoiceId = invoiceIdInput ? parseInt(invoiceIdInput.value || '0', 10) : 0;
                                 
                                 if (invoiceId === 0) {
                                     setTimeout(function() {
                                         const customerNameInput = document.getElementById('CustomerNameInput');
                                         if (customerNameInput) {
                                             customerNameInput.focus();
                                             customerNameInput.select();
                                         }
                                     }, 300);
                                 }
                             });

                         })();









    </script>
