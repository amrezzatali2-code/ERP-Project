                             function initPostInvoice() {
                                 console.log('🔄 تهيئة زر التحويل...');

                                 const btnPost = document.getElementById("btnPostInvoice");              // متغير: زر التحويل
                                 const isPostedBox = document.getElementById("InvoiceIsPostedDisplay");  // متغير: خانة "محوّل؟" (عرض فقط)

                                 if (!btnPost) {
                                     console.warn('⚠️ زر الترحيل غير موجود');
                                     return;
                                 }

                                 // ✅ منع إعادة ربط الـ event listener إذا كان مربوطاً بالفعل
                                 if (btnPost.dataset.boundPostInvoice) {
                                     console.log('✅ زر الترحيل مربوط بالفعل');
                                     return;
                                 }
                                 btnPost.dataset.boundPostInvoice = '1';

                                 // متغير: حالة الترحيل من السيرفر وقت فتح الصفحة (Boolean حقيقي)
                                 const serverIsPosted = @Model.IsConverted.ToString().ToLower(); // true/false

                                 // ✅ لو محوّل من البداية: اقفل زر التحويل وطبق القفل
                                 if (serverIsPosted) {
                                     btnPost.disabled = true;
