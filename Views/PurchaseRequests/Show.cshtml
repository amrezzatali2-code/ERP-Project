@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.PurchaseRequest

@section Styles {
    <style>
        /* =========================================================
           تصميم طلب الشراء مثل فاتورة الشراء (نفس التنسيق)
           ========================================================= */
        .pi-input[type="number"]::-webkit-outer-spin-button,
        .pi-input[type="number"]::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        .pi-input[type="number"] {
            -moz-appearance: textfield;
        }

        html, body {
            min-height: 100%;
            background: #ffffff !important;
        }
        .invoice-page {
            background: #ffffff !important;
            min-height: 100vh;
            padding-bottom: 1rem;
        }
        html.in-frame .invoice-page {
            min-height: 100vh;
        }
        .invoice-page .container-fluid > .row.g-3 {
            align-items: stretch;
            min-height: calc(100vh - 3.25rem);
        }

        .invoice-header-card,
        .invoice-details-card,
        .invoice-totals-card,
        .invoice-side-card,
        .invoice-Add-card,
        .invoice-product-card {
            border-radius: 1rem;
            overflow: hidden;
        }

        .invoice-actions-sticky {
            position: sticky;
            top: 58px;
            z-index: 3000;
            background: #ffffff;
            border: 1px solid #6366f1;
            padding: 10px 10px;
            border-radius: 14px;
            box-shadow: 0 10px 24px rgba(0,0,0,.08);
        }
        @@media (max-width: 992px) {
            .invoice-actions-sticky { top: 56px; }
        }

        .invoice-header-bar {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.4rem 1rem;
        }
        .invoice-header-bar h5, .invoice-header-bar h6 {
            margin-bottom: 0;
            font-size: 1rem;
        }

        .invoice-details-card .card-header,
        .invoice-Add-card .card-header,
        .invoice-product-card .card-header,
        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.55rem 1rem;
        }

        .form-label-sm { font-size: 0.85rem; }
        .invoice-small-input { max-width: 150px; }
        .customer-summary-line { font-size: 0.82rem; }

        .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
            border: 1px solid #64748b !important;
        }
        .invoice-side-card .btn-erp + .btn-erp { margin-top: 0.25rem; }
        .invoice-side-card .invoice-actions-bar hr { display: none !important; }
        .invoice-page .invoice-side-card { min-width: 220px; }
        .si-print-dropdown-menu {
            border-radius: 12px;
            border: 1px solid #cbd5e1;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.14);
            padding: 0.25rem 0;
        }
        .si-print-dropdown-header {
            font-weight: 600;
            color: #64748b;
            background: #f8fafc;
        }
        .si-print-dropdown-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
        }
        .si-print-dropdown-item:hover,
        .si-print-dropdown-item:focus {
            background: #eef2ff;
            color: #1e293b;
        }
        .si-print-opt-icon {
            width: 1.15rem;
            text-align: center;
            font-size: 0.95rem;
            opacity: 0.9;
        }
        .si-print-opt-text { flex: 1; }
        .si-print-dropdown-btn.dropdown-toggle::after {
            margin-inline-start: 0.5rem;
        }
        .si-settings-panel {
            display: none;
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            padding: 0.6rem;
            background: #f8fafc;
            margin-top: 0.25rem;
        }
        .si-settings-panel.show { display: block; }
        /* هيدر جدول السطور — أبيض + ثابت عند التمرير (مثل فاتورة المبيعات) */
        .invoice-lines-container .erp-table-wrapper table thead.invoice-lines-header th {
            position: sticky;
            top: 0;
            z-index: 10;
            background-color: #fff !important;
            color: #0f172a !important;
            font-weight: 600;
            padding: 0.5rem 0.55rem;
            border: 1px solid #dee2e6 !important;
            box-shadow: 0 1px 0 0 #dee2e6;
        }
        /* جدول السطور: أرضية فاتحة داخل المنطقة الملونة */
        .invoice-lines-container .erp-table-wrapper .erp-table tbody tr,
        .invoice-lines-container .erp-table-wrapper .erp-table tbody td {
            background-color: rgba(255, 255, 255, 0.72) !important;
        }
        .invoice-lines-container .erp-table-wrapper .erp-table tbody tr:hover td {
            background-color: rgba(248, 250, 252, 0.95) !important;
        }

        /* اختيار سطر من جدول السطور (بدون أزرار في الصف) */
        #PILinesTbody tr[data-line-no] {
            cursor: pointer;
        }
        #PILinesTbody tr.pi-group-row {
            cursor: pointer;
        }
        #PILinesTbody tr.pi-row-selected > td {
            background-color: #eef2ff !important;
            box-shadow: inset 0 0 0 1px rgba(99, 102, 241, 0.45);
        }

        /* إزالة الخط الفاصل بين الكروت */
        .invoice-card-line {
            display: none;
        }

        /* حدود كل الكروت: لون أغمق (#6366f1) — نفس نمط فاتورة المشتريات/المبيعات */
        div.card.invoice-side-card,
        div.card.invoice-header-card,
        div.card.invoice-product-card.invoice-product-card-list-style,
        div.card.invoice-Add-card,
        div.card.invoice-totals-card {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
            overflow: hidden;
        }
        .invoice-product-card.invoice-product-card-list-style .card-body {
            padding: 0.75rem 1rem 1rem;
        }
        /* لون النص أغمق داخل كروت الطلب */
        .invoice-header-card .card-body .form-label,
        .invoice-header-card .card-body .form-label-sm,
        .invoice-header-card .card-body label {
            color: #0f172a !important;
            font-weight: 500;
        }
        .invoice-header-card .card-body .form-control,
        .invoice-header-card .card-body .form-control-sm,
        .invoice-header-card .card-body .form-select,
        .invoice-header-card .card-body .form-select-sm {
            color: #020617 !important;
        }
        .invoice-product-card .card-body .form-label,
        .invoice-product-card .card-body .form-label-sm,
        .invoice-product-card .card-body label,
        .invoice-product-card .pr-card-field label {
            color: #0f172a !important;
            font-weight: 500;
        }
        .invoice-product-card .card-body .form-control,
        .invoice-product-card .card-body .form-control-sm,
        .invoice-product-card .pr-card-field .form-control-sm,
        .invoice-product-card .pr-card-field .form-select-sm {
            color: #020617 !important;
        }
        .invoice-Add-card .card-body .form-label,
        .invoice-Add-card .card-body .form-label-sm,
        .invoice-Add-card .card-body label {
            color: #0f172a !important;
            font-weight: 500;
        }
        .invoice-Add-card .card-body .form-control,
        .invoice-Add-card .card-body .form-control-sm,
        .invoice-Add-card .card-body .form-select,
        .invoice-Add-card .card-body .form-select-sm {
            color: #020617 !important;
        }
        .invoice-lines-container .erp-table-wrapper .erp-table tbody td,
        .invoice-lines-container .erp-table-wrapper .erp-table tbody th {
            color: #0f172a !important;
        }
        .invoice-totals-card .card-body,
        .invoice-totals-card .card-body .form-label,
        .invoice-totals-card .invoice-summary-item label,
        .invoice-totals-card .invoice-summary-item .small {
            color: #0f172a !important;
        }
        .invoice-totals-card .invoice-summary-badge {
            color: #020617 !important;
        }
        /* كارت الإجماليات — مثل فاتورة المبيعات (بوكسات بحدود) */
        .invoice-summary-row.invoice-summary-row-boxes,
        .invoice-summary-row.invoice-summary-row-totals {
            flex-wrap: wrap;
            gap: 0.5rem 0.85rem;
            align-items: stretch;
            justify-content: space-between;
        }
        /* طلب الشراء: صف واحد فقط — بوكسات مصغّرة لتناسب الصف */
        .invoice-summary-row.invoice-summary-row-single {
            flex-wrap: nowrap;
            gap: 0.35rem 0.5rem;
            align-items: stretch;
            overflow-x: auto;
            min-width: 0;
        }
        .invoice-summary-row.invoice-summary-row-single .invoice-summary-item.invoice-summary-box {
            flex: 1 1 0;
            min-width: 0;
            padding: 0.25rem 0.35rem;
            gap: 0.15rem;
        }
        .invoice-summary-row.invoice-summary-row-single .invoice-summary-label {
            font-size: 0.65rem;
            line-height: 1.2;
        }
        .invoice-summary-row.invoice-summary-row-single .invoice-summary-value {
            font-size: 0.8rem;
        }
        .invoice-summary-row.invoice-summary-row-single .invoice-summary-value-main {
            font-size: 0.85rem;
        }
        .invoice-summary-item.invoice-summary-box {
            flex: 1 1 0;
            min-width: 90px;
            max-width: 100%;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            align-items: center;
            justify-content: flex-start;
            padding: 0.4rem 0.6rem;
            background: #f8fafc;
            border: 1px solid #94a3b8;
            border-radius: 6px;
        }
        .invoice-summary-label {
            font-size: 0.78rem;
            color: #64748b;
            margin-bottom: 0;
        }
        .invoice-summary-value {
            font-size: 0.95rem;
            font-weight: 500;
            color: #0f172a;
        }
        .invoice-summary-box-main {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%) !important;
            border-color: #0284c7 !important;
        }
        .invoice-summary-box-main .invoice-summary-label {
            color: rgba(255,255,255,.9);
        }
        .invoice-summary-value-main {
            font-size: 1.05rem;
            color: #fff !important;
        }

        /* العمود الرئيسي — شفاف وبدون حد (مثل فاتورة المشتريات/المبيعات) — docs/فتح الفواتير ككتلة واحدة.md */
        .invoice-page .col-12.col-lg-10.order-2.order-lg-1,
        .invoice-page .col-lg-10.order-2 {
            background: transparent !important;
            padding: 0.5rem 1rem;
            border: none !important;
            box-shadow: none !important;
            display: flex;
            flex-direction: column;
            min-height: 0;
        }
        /* حاوية المحتوى — عمود مرن يمتد لأسفل (مثل فاتورة المبيعات) */
        #PI_BodyHost,
        div#PI_BodyHost,
        .invoice-page div#PI_BodyHost {
            display: flex !important;
            flex-direction: column;
            flex: 1 1 auto;
            min-height: 0;
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            outline: none !important;
            padding: 0 !important;
        }
        /* كروت أعلى الصفحة لا تُضغط؛ جدول السطور يمتص المساحة */
        .invoice-page #PI_BodyHost .invoice-header-card,
        .invoice-page #PI_BodyHost .invoice-product-card,
        .invoice-page #PI_BodyHost .invoice-Add-card {
            flex: 0 0 auto;
        }
        .invoice-page #PI_BodyHost .invoice-totals-card {
            flex: 0 0 auto;
        }
        /* حاوية جدول السطور — تمتد + تدرج لوني (مثل فاتورة المبيعات) */
        .invoice-page .invoice-lines-container {
            display: flex;
            flex-direction: column;
            flex: 1 1 auto;
            min-height: 14rem;
            margin-top: 0.85rem;
            margin-bottom: 0.85rem !important;
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
            overflow: hidden;
            background: linear-gradient(165deg, #eef2ff 0%, #e0e7ff 42%, #dbeafe 78%, #cffafe 100%);
        }
        .invoice-page .invoice-lines-container .erp-table-wrapper {
            flex: 1 1 auto;
            min-height: 16rem;
            max-height: none !important;
            overflow: auto;
            border: none;
            border-radius: 0;
            background: rgba(255, 255, 255, 0.42);
        }
        .invoice-page .container-fluid,
        .invoice-page .row {
            border: none !important;
            box-shadow: none !important;
        }

        #PI_BodyHost .invoice-header-card .form-control,
        #PI_BodyHost .invoice-header-card .form-select,
        #PI_BodyHost .invoice-product-card .form-control,
        #PI_BodyHost .invoice-product-card .form-select,
        #PI_BodyHost .invoice-lines-container .form-control,
        #PI_BodyHost .invoice-lines-container .form-select,
        #PI_BodyHost .invoice-totals-card .form-control,
        #PI_BodyHost .invoice-totals-card .form-select {
            border-color: #94a3b8 !important;
        }
        #PI_BodyHost .invoice-lines-container .editable-line-field {
            border-color: #94a3b8 !important;
        }
        /* انبوت اسم الصنف: حدود مميزة بدون لون داخلي */
        #ProdNameInput.pi-product-name-input,
        .invoice-Add-card .pi-product-name-input {
            border: 0 !important; /* حد الـ wrapper هو اللي هيبان */
            border-radius: 0.375rem;
            background-color: transparent !important;
        }
        .invoice-Add-card .pi-product-name-input:focus {
            border-color: transparent !important;
            box-shadow: none !important;
        }

        /* ===== دروب داون مخصص (حدود + سهم داخل البوكس) ===== */
        .product-dropdown-onebox {
            position: relative;
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
            background: #fff;
        }
        .product-dropdown-arrow-inside {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #495057;
            cursor: pointer;
            user-select: none;
            font-size: 0.6rem;
            z-index: 1;
        }
        .product-dropdown-arrow-inside:hover {
            background-color: #e9ecef;
        }
        .product-dropdown-onebox .product-dropdown-input {
            width: 100%;
            border: none !important;
            background: transparent !important;
            padding-left: 2.25rem !important;
        }
        .product-dropdown-onebox .product-dropdown-input:focus {
            box-shadow: none !important;
            outline: none !important;
        }
        .product-dropdown-onebox:focus-within {
            border-color: #0d6efd !important;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
        }
        /* القائمة المنسدلة — تظهر تحت البوكس (position fixed) */
        .product-dropdown-list {
            position: fixed;
            max-height: 220px;
            min-height: 40px;
            overflow-y: auto;
            overscroll-behavior: contain; /* امنع انتقال سكرول القائمة إلى الصفحة */
            z-index: 9999;
            margin-top: 2px;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            background: #fff;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        }
        .product-dropdown-list[data-open="false"] {
            display: none !important;
        }
        .product-dropdown-list[data-open="true"] {
            display: block !important;
        }
        .product-dropdown-item {
            cursor: pointer;
            border-bottom: 1px solid #f0f0f0;
            padding: 0.35rem 0.55rem;
        }
        .product-dropdown-item:hover {
            background-color: #f8f9fa;
        }
        .product-dropdown-item:last-child {
            border-bottom: none;
        }
        .product-dropdown-item-active {
            background-color: #0d6efd !important;
            color: #fff !important;
        }

        /* ===== إبراز بوكس اسم المورد (حد فقط) ===== */
        #PI_BodyHost .invoice-header-card #prSupplierDropdownWrap {
            border: 2px solid #4f46e5 !important;
            border-radius: 0.55rem !important;
            padding: 3px !important;
        }
        #PI_BodyHost .invoice-header-card #prSupplierDropdownWrap:focus-within {
            border-color: #4338ca !important;
            box-shadow: none !important;
        }
        #PI_BodyHost .invoice-header-card #prSupplierDropdownWrap .product-dropdown-onebox {
            border: 0 !important;
            background: transparent !important;
            border-radius: 0.45rem !important;
        }
        #PI_BodyHost .invoice-header-card #prSupplierDropdownWrap .product-dropdown-onebox:focus-within {
            box-shadow: none !important;
            border-color: transparent !important;
        }

        /* ===== إبراز بوكس اسم الصنف (حد فقط) ===== */
        #PI_BodyHost .invoice-Add-card #prProductDropdownWrap {
            border: 2px solid #4f46e5 !important;
            border-radius: 0.55rem !important;
            padding: 3px !important;
        }
        #PI_BodyHost .invoice-Add-card #prProductDropdownWrap:focus-within {
            border-color: #4338ca !important;
            box-shadow: none !important;
        }
        #PI_BodyHost .invoice-Add-card #prProductDropdownWrap .product-dropdown-onebox {
            border: 0 !important;
            background: transparent !important;
            border-radius: 0.45rem !important;
        }
        #PI_BodyHost .invoice-Add-card #prProductDropdownWrap .product-dropdown-onebox:focus-within {
            box-shadow: none !important;
            border-color: transparent !important;
        }
        /* الكارت الثالث (إدخال الصنف): حدود مثل الثاني + إعادة تنسيق البوكسات */
        .invoice-Add-card .card-body {
            padding: 0.85rem 1rem 1rem;
        }
        .invoice-Add-card .card-body .row.g-1 {
            --bs-gutter-x: 0.6rem;
            --bs-gutter-y: 0.85rem;
        }
        .invoice-Add-card .form-label-sm {
            font-size: 0.8rem;
            color: #374151;
            margin-bottom: 0.3rem;
            font-weight: 500;
        }
        .invoice-Add-card .card-body .form-control-sm,
        .invoice-Add-card .card-body .form-select-sm {
            border-radius: 0.4rem;
            border: 1px solid #94a3b8;
            padding: 0.4rem 0.55rem;
            font-size: 0.875rem;
            background-color: #fff;
        }
        .invoice-Add-card .card-body .form-control-sm:focus,
        .invoice-Add-card .card-body .form-select-sm:focus {
            border-color: #64748b;
            box-shadow: 0 0 0 0.2rem rgba(100,116,139,.2);
        }
        .invoice-Add-card .card-body .btn-primary {
            border-radius: 0.4rem;
            padding: 0.4rem 0.75rem;
        }

        /* رسائل عابرة (Toast) — بدل صندوق الرسائل داخل كارت الأزرار */
        #prToastContainer {
            position: fixed;
            top: 70px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
        }
        #prToastContainer .pr-toast {
            padding: 0.6rem 1.2rem;
            border-radius: 8px;
            font-size: 0.9rem;
            box-shadow: 0 4px 12px rgba(0,0,0,.15);
            animation: prToastIn 0.25s ease;
            pointer-events: auto;
        }
        #prToastContainer .pr-toast.text-success { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
        #prToastContainer .pr-toast.text-warning { background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; }
        #prToastContainer .pr-toast.text-danger { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
        #prToastContainer .pr-toast.text-muted { background: #f1f5f9; color: #475569; border: 1px solid #94a3b8; }
        @@keyframes prToastIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ===== كارت بيانات الصنف (الثاني): تحسين التصميم والتوزيع ===== */
        .invoice-product-card.invoice-product-card-list-style .pr-card-fields-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 0.75rem 1rem;
            align-items: end;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-card-field {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-card-field label {
            font-size: 0.8rem;
            color: #495057;
            margin-bottom: 0;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-card-field .form-control-sm,
        .invoice-product-card.invoice-product-card-list-style .pr-card-field .form-select-sm {
            font-size: 0.875rem;
            padding: 0.35rem 0.5rem;
            border-radius: 0.375rem;
        }
        /* جداول الكارت الثاني: في سطر واحد وحجم متساوٍ */
        .invoice-product-card.invoice-product-card-list-style .pr-card-tables-row {
            margin-top: 0.75rem;
            gap: 1rem;
            display: flex;
            flex-wrap: nowrap;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-card-tables-row > div {
            flex: 1 1 0;
            min-width: 0;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-card-table-wrap {
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #dee2e6;
            background: #fff;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-card-table-title {
            font-size: 0.85rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.35rem;
            padding-inline: 0.25rem;
            min-height: 2.5rem;
            display: flex;
            align-items: flex-end;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-card-table-wrap .table {
            margin-bottom: 0;
            font-size: 0.8rem;
        }
        /* هيدر الجدولين: نفس تصميم هيدر السطور (erp-table) */
        .invoice-product-card.invoice-product-card-list-style .pr-card-table-wrap .table thead th {
            background-color: #fafbfc !important;
            color: #374151;
            font-weight: 600;
            padding: 0.4rem 0.5rem;
            border: none;
            box-shadow: 0 2px 0 0 #adb5bd;
            white-space: nowrap;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-card-table-wrap .table tbody td {
            padding: 0.35rem 0.5rem;
            vertical-align: middle;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-card-table-wrap .table tbody tr:nth-child(even) {
            background-color: #f8fafc;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-card-table-wrap .table tbody tr:hover {
            background-color: #eef2ff;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-card-table-wrap .table-responsive {
            max-height: 140px;
            overflow-y: auto;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-sales-date-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.35rem 0.5rem;
            margin-bottom: 0.35rem;
            min-height: 2.5rem;
        }
        .invoice-product-card.invoice-product-card-list-style .pr-sales-date-row label { margin-bottom: 0; font-size: 0.8rem; }
        .invoice-product-card.invoice-product-card-list-style .pr-sales-date-row input[type="date"] {
            max-width: 130px;
        }

        .summary-badge {
            min-width: 80px;
            text-align: center;
        }

        /* كارت الإجماليات — إعادة تنسيق */
        .invoice-totals-card .card-body {
            padding: 0.9rem 1rem;
        }
        .invoice-summary-row {
            flex-wrap: wrap;
            gap: 0.85rem 1.5rem !important;
            align-items: flex-end;
        }
        .invoice-summary-item {
            flex: 1 1 0;
            min-width: 85px;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            align-items: center;
        }
        .invoice-summary-item .small,
        .invoice-summary-item label {
            font-size: 0.75rem;
            color: #6b7280;
            margin-bottom: 0;
        }
        .invoice-summary-item.invoice-summary-total {
            flex: 0 0 auto;
            margin-inline-start: auto;
        }
        .invoice-summary-badge {
            font-size: 0.9rem;
            padding: 0.35rem 0.7rem;
            min-width: 70px;
            text-align: center;
            display: inline-block;
            border-radius: 0.4rem;
            font-weight: 500;
        }
        .invoice-totals-card .invoice-summary-badge.bg-light {
            background-color: #f1f5f9 !important;
            color: #334155 !important;
            border: 1px solid #e2e8f0;
        }
        .invoice-totals-card .invoice-summary-badge.bg-primary {
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%) !important;
            border: none;
            color: #fff !important;
        }
        .invoice-summary-tax {
            max-width: 90px;
            font-size: 0.875rem;
            text-align: center;
        }

        /* حقل اسم المورد/العميل مميز بحدود دائماً */
        .customer-name-input {
            border: 0 !important;
            border-radius: 0.375rem;
            background-color: transparent !important;
            box-shadow: none !important;
        }
        .customer-name-input:focus {
            border-color: transparent !important;
            box-shadow: none !important;
        }

        /* كارت طلب الشراء (الأول): توزيع أفضل للحقول */
        .invoice-header-card .invoice-header-bar {
            padding: 0.4rem 1rem;
        }
        .invoice-header-card .card-body.pr-request-card-body {
            padding: 0.75rem 1rem 1rem;
        }
        .invoice-header-card .pr-request-card-body .form-label-sm {
            margin-bottom: 0.25rem;
            font-size: 0.8rem;
        }
        .invoice-header-card .pr-request-card-body .form-control-sm,
        .invoice-header-card .pr-request-card-body .form-select-sm {
            width: 100%;
            padding: 0.3rem 0.5rem;
            font-size: 0.875rem;
            min-height: 2rem;
        }
        .invoice-header-card .pr-request-card-body .row.g-3 {
            --bs-gutter-x: 0.75rem;
            --bs-gutter-y: 0.75rem;
        }

        @@media print {
            .invoice-page .invoice-lines-container .erp-table-wrapper {
                max-height: none !important;
                overflow: visible !important;
            }
        }
    </style>
}

<div class="invoice-page" dir="rtl">
    <div id="prToastContainer" aria-live="polite"></div>
    <div class="container-fluid pt-3">

        @* فورم مخفي لتوليد Anti-Forgery Token لاستخدامه في نداءات AJAX *@
        <form id="__AntiForgeryForm" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>

        <div class="row g-3">



            @* =========================
               العمود الجانبي (أزرار الحركة) — ثابت برا الـ BodyHost
               ========================= *@
            <div class="col-12 col-lg-2 order-1 order-lg-2">

                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="invoice-header-bar d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h6 class="mb-0">إجراءات طلب الشراء</h6>
                        </div>
                    </div>


                    <!-- مثل فاتورة المبيعات: رقم الطلب وعلم التحويل في الشريط الجانبي، ويُحدّثان من الـ body بعد كل تحميل -->
                    <input type="hidden" id="InvoiceId" value="@(Model?.PRId ?? 0)" />
                    <input type="hidden" id="InvoiceIsPostedFlag" value="@(Model?.IsConverted == true ? "1" : "0")" />

                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">

                        @{
                            int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
                            int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
                            int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
                            int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;

                            int currentId = Model?.PRId ?? 0;

                            bool hasAnyInvoices =
                            navFirst.HasValue && navLast.HasValue &&
                            navFirst.Value > 0 && navLast.Value > 0;

                            int? prevEffective = (currentId == 0) ? navLast : navPrev;
                            int? nextEffective = (currentId == 0) ? navFirst : navNext;

                            bool canFirst = hasAnyInvoices && navFirst.HasValue && navFirst.Value > 0 && navFirst.Value != currentId;
                            bool canLast = hasAnyInvoices && navLast.HasValue && navLast.Value > 0 && navLast.Value != currentId;
                            bool canPrev = hasAnyInvoices && prevEffective.HasValue && prevEffective.Value > 0 && prevEffective.Value != currentId;
                            bool canNext = hasAnyInvoices && nextEffective.HasValue && nextEffective.Value > 0 && nextEffective.Value != currentId;
                        }

                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button"
                                    id="btnFirstInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pr-show-tab"
                                    data-tab-title="طلب  الشراء"
                                    data-url="@Url.Action("Show", "PurchaseRequests", new { id = (navFirst ?? 0), frame = 1 })"
                                    data-base-url="@Url.Action("Show", "PurchaseRequests", new { frame = 1 })"
                                    data-id="@(navFirst ?? 0)"
                                    title="أول طلب شراء"
                                    @(canFirst ? "" : "disabled")>
                                ⏮
                            </button>

                            <button type="button"
                                    id="btnPrevInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pr-show-tab"
                                    data-tab-title="طلب  الشراء"
                                    data-url="@Url.Action("Show", "PurchaseRequests", new { id = (prevEffective ?? 0), frame = 1 })"
                                    data-base-url="@Url.Action("Show", "PurchaseRequests", new { frame = 1 })"
                                    data-id="@(prevEffective ?? 0)"
                                    title="الطلب السابق"
                                    @(canPrev ? "" : "disabled")>
                                ◀
                            </button>

                            <button type="button"
                                    id="btnNextInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pr-show-tab"
                                    data-tab-title="طلب  الشراء"
                                    data-url="@Url.Action("Show", "PurchaseRequests", new { id = (nextEffective ?? 0), frame = 1 })"
                                    data-base-url="@Url.Action("Show", "PurchaseRequests", new { frame = 1 })"
                                    data-id="@(nextEffective ?? 0)"
                                    title="الطلب التالي"
                                    @(canNext ? "" : "disabled")>
                                ▶
                            </button>

                            <button type="button"
                                    id="btnLastInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pr-show-tab"
                                    data-tab-title="طلب  الشراء"
                                    data-url="@Url.Action("Show", "PurchaseRequests", new { id = (navLast ?? 0), frame = 1 })"
                                    data-base-url="@Url.Action("Show", "PurchaseRequests", new { frame = 1 })"
                                    data-id="@(navLast ?? 0)"
                                    title="آخر طلب شراء"
                                    @(canLast ? "" : "disabled")>
                                ⏭
                            </button>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <input type="number"
                                   id="NavInvoiceSearchInput"
                                   class="form-control form-control-sm"
                                   placeholder="بحث برقم الطلب" />


                            <button type="button"
                                    id="btnNavInvoiceSearch"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-tab-id="pr-show-tab"
                                    data-tab-title="طلب الشراء"
                                    data-base-url="@Url.Action("Show", "PurchaseRequests", new { frame = 1 })">
                                بحث
                            </button>
                        </div>

                        <button type="button"
                                id="btnInvoiceSettingsToggle"
                                class="btn btn-erp btn-erp-outline-secondary btn-erp-sm w-100">
                            ⚙️ إعدادات الفاتورة
                        </button>

                        <div id="siInvoiceSettingsPanel" class="si-settings-panel">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="siShowClearAllChk">
                                <label class="form-check-label" for="siShowClearAllChk">إظهار زر مسح كل الأصناف</label>
                            </div>
                            <div class="mb-2">
                                <label class="form-label form-label-sm mb-1" for="siMaxItemsInput">الحد الأقصى لعدد الأصناف</label>
                                <input type="number" id="siMaxItemsInput" class="form-control form-control-sm text-center" min="1" step="1" value="35" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label form-label-sm mb-1" for="siSortModeSelect">نظام ترتيب السطور</label>
                                <select id="siSortModeSelect" class="form-select form-select-sm">
                                    <option value="location">بالموقع (A → Z)</option>
                                    <option value="auto">تلقائي (حسب ترتيب النزول)</option>
                                    <option value="alpha">أبجدي (حسب اسم الصنف)</option>
                                </select>
                            </div>
                            <div class="mb-2">
                                <label class="form-label form-label-sm mb-1" for="siThemeSelect">لون الخلفية</label>
                                <select id="siThemeSelect" class="form-select form-select-sm">
                                    <option value="dark-navy">كحلي داكن</option>
                                    <option value="dark-slate">فحمي داكن</option>
                                    <option value="dark-plum">برقوقي داكن</option>
                                </select>
                            </div>
                            <button type="button" id="btnSaveInvoiceSettingsInline" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100">
                                حفظ الإعدادات
                            </button>
                        </div>

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           data-tab-id="pr-show-tab"
                           data-tab-title="طلب الشراء"
                           data-url="@Url.Action("Create", "PurchaseRequests", new { frame = 1 })">
                            ➕ طلب جديد
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnSaveInvoiceHeader"
                                data-lock-posted="1">
                            💾 حفظ الطلب
                        </button>

                        <button type="button" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" id="btnPostInvoice" data-lock-posted="1">
                            🔄 تحويل إلى فاتورة مشتريات
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnClearInvoiceLines"
                                data-invoice-id="@(Model?.PRId ?? 0)"
                                data-lock-posted="1">
                            🗑️ مسح كل أصناف الطلب
                        </button>

                        <div>
                            <button type="button" id="btnOpenProductMovement"
                                    class="btn btn-erp btn-erp-outline-secondary btn-erp-sm w-100">
                                📊 حركة الصنف
                            </button>
                        </div>

                        <button type="button"
                                id="btnRemoveSelectedLine"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm w-100"
                                data-lock-posted="1"
                                title="اختر سطراً في الجدول ثم اضغط لمسحه">
                            🗑️ مسح السطر المحدد
                        </button>

                        <div>
                            <button type="button" id="btnOpenProductEdit"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100">
                                ✏️ تعديل بيانات الصنف
                            </button>
                        </div>

                        <a href="@(Model?.CustomerId > 0 ? Url.Action("Show", "Customers", new { id = Model.CustomerId, frame = 1 }) : "#")" id="btnSupplierVolume" class="btn btn-erp btn-erp-outline-secondary btn-erp-sm open-same-tab w-100 text-decoration-none"
                           data-tab-id="customer-engagement"
                           data-tab-title="حجم تعامل عميل"
                           data-base-url="@Url.Action("Show", "Customers", new { frame = 1 })">
                            📊 حجم تعامل
                        </a>

                        @if (Model?.PRId > 0)
                        {
                            <a href="@Url.Action("ExportShowExcel", "PurchaseRequests", new { id = Model.PRId })" target="_blank" rel="noopener" class="btn btn-erp btn-erp-success btn-erp-sm w-100 text-decoration-none">📥 تصدير Excel</a>
                        }

                        <div class="dropdown w-100 si-print-dropdown">
                            <button type="button"
                                    id="btnPrintInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100 dropdown-toggle si-print-dropdown-btn"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    title="اختر نوع الطباعة">
                                🖨️ طباعة الطلب
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end w-100 si-print-dropdown-menu" aria-labelledby="btnPrintInvoice">
                                <li class="si-print-dropdown-header px-3 py-2 small text-muted border-bottom mb-0">اختر نوع الطباعة</li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-pr-print-mode="1"><span class="si-print-opt-icon" aria-hidden="true">📄</span><span class="si-print-opt-text">طباعة صفحة واحدة</span></a></li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-pr-print-mode="2"><span class="si-print-opt-icon" aria-hidden="true">📑</span><span class="si-print-opt-text">طباعة أصل وصورة</span></a></li>
                                <li><a class="dropdown-item si-print-dropdown-item" href="#" data-pr-print-mode="3"><span class="si-print-opt-icon" aria-hidden="true">📚</span><span class="si-print-opt-text">طباعة أصل وصورتين</span></a></li>
                            </ul>
                        </div>



                    </div>
                </div>

            </div> @* نهاية العمود الجانبي *@





            @* =========================
               العمود الرئيسي (الهيدر + المورد + الأصناف + السطور + الإجماليات)
               ========================= *@
            <div class="col-12 col-lg-10 order-2 order-lg-1">

                @* ✅ ده الجزء الوحيد اللي هيتبدّل عند التنقل — data-pr-show-base لبناء رابط التحميل من السيرفر *@
                <div id="PI_BodyHost" data-pr-show-base="@(Url.Action("Show", "PurchaseRequests", new { frame = 1 }))">

                    @* =========================
                       قيم التنقل (لازم تكون داخل الـ BodyHost عشان تتحدّث مع frag=body)
                       ========================= *@
                    <input type="hidden" id="NavFirstId" value="@(ViewBag.NavFirstId ?? 0)" />
                    <input type="hidden" id="NavLastId" value="@(ViewBag.NavLastId ?? 0)" />
                    <input type="hidden" id="NavPrevId" value="@(ViewBag.NavPrevId ?? 0)" />
                    <input type="hidden" id="NavNextId" value="@(ViewBag.NavNextId ?? 0)" />
                    <input type="hidden" id="NavCurrentId" value="@(Model?.PRId ?? 0)" />

                    @* ====================================================
                       1) كارت بيانات العميل ثم كارت بيانات الصنف (تحت بعض مثل فاتورة المشتريات)
                       ==================================================== *@
                    <div class="row g-2 mb-2">
                        <div class="col-12">
                    <div class="card shadow-sm mb-2 invoice-header-card">

                        @{
                            bool isNewInvoice = Model == null || Model.PRId == 0;
                            bool hasInvoice = !isNewInvoice;

                            string invoiceDateText = hasInvoice
                            ? Model.PRDate.ToString("yyyy/MM/dd")
                            : "";

                            string invoiceTimeText = hasInvoice
                            ? (Model.CreatedAt.Kind == DateTimeKind.Utc ? Model.CreatedAt.ToLocalTime().ToString("HH:mm") : Model.CreatedAt.ToString("HH:mm"))
                            : "";
                        }

                        <div class="invoice-header-bar">
                            <h6 class="mb-0">طلب شراء</h6>
                        </div>

                        <div>
                            <div class="card-body pr-request-card-body">

                                <div class="row g-3 align-items-end">
                                    <div class="col-6 col-md-4 col-lg-2">
                                        <label class="form-label form-label-sm">كود المورد</label>
                                        <input id="CustomerCodeDisplay"
                                               class="form-control form-control-sm text-center"
                                               type="number"
                                               autocomplete="one-time-code"
                                               data-lpignore="true"
                                               data-1p-ignore="true"
                                               data-bwignore="true"
                                               data-lock-posted="1"
                                               value="@(Model != null && Model.CustomerId > 0 ? Model.CustomerId.ToString() : "")" />
                                        <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                                    </div>
                                    <div class="col-12 col-md-8 col-lg-4">
                                        <label for="CustomerNameInput" class="form-label form-label-sm">اسم المورد</label>
                                        <div class="position-relative" id="prSupplierDropdownWrap">
                                            <div class="product-dropdown-onebox" id="prSupplierDropdownInputGroup">
                                                <span class="product-dropdown-arrow-inside" id="prSupplierDropdownArrow" title="افتح القائمة">▼</span>
                                                <input id="CustomerNameInput"
                                                       type="text"
                                                       class="form-control form-control-sm customer-name-input product-dropdown-input"
                                                       placeholder="اكتب اسم المورد ثم اختره من القائمة"
                                                       autocomplete="one-time-code"
                                                       autocorrect="off"
                                                       autocapitalize="off"
                                                       spellcheck="false"
                                                       data-lpignore="true"
                                                       data-1p-ignore="true"
                                                       data-bwignore="true"
                                                       value="@ViewBag.SelectedCustomerName"
                                                       data-lock-posted="1" />
                                            </div>
                                            <div id="prSupplierDropdownList" class="product-dropdown-list" role="listbox" data-open="false"></div>
                                        </div>
                                    </div>
                                    <div class="col-4 col-md-2 col-lg-1">
                                        <label class="form-label form-label-sm">رقم الطلب</label>
                                        <input type="hidden" id="InvoiceId" value="@(Model?.PRId ?? 0)" />
                                        <input type="hidden" id="InvoiceIsPostedFlag" value="@(Model?.IsConverted == true ? "1" : "0")" />
                                        <input id="InvoiceNumberDisplay"
                                               class="form-control form-control-sm text-center"
                                               value="@(Model != null && Model.PRId > 0 ? Model.PRId.ToString() : "")"
                                               readonly />
                                    </div>
                                    <div class="col-6 col-md-4 col-lg-2">
                                        <label class="form-label form-label-sm">تاريخ الطلب</label>
                                        <input id="InvoiceDateDisplay"
                                               class="form-control form-control-sm text-center"
                                               value="@invoiceDateText"
                                               readonly />
                                    </div>
                                    <div class="col-4 col-md-2 col-lg-1">
                                        <label class="form-label form-label-sm">وقت الإنشاء</label>
                                        <input id="InvoiceTimeDisplay"
                                               class="form-control form-control-sm text-center"
                                               value="@invoiceTimeText"
                                               readonly />
                                    </div>
                                    <div class="col-6 col-md-4 col-lg-2">
                                        <label class="form-label form-label-sm">حالة الطلب</label>
                                        <input id="InvoiceIsPostedDisplay"
                                               class="form-control form-control-sm text-center"
                                               value="@(Model.IsConverted ? "محول" : (string.IsNullOrWhiteSpace(Model.Status) ? "غير مرحلة" : Model.Status))"
                                               readonly />
                                    </div>
                                </div>

                                <input type="hidden" asp-for="Status" id="InvoiceStatusHidden" />

                                <div class="row g-3 align-items-end mt-0">
                                    <div class="col-12 col-md-4 col-lg-3">
                                        <label class="form-label form-label-sm text-end d-block" for="WarehouseId">المخزن</label>
                                        <select asp-for="WarehouseId"
                                                asp-items="ViewBag.Warehouses"
                                                class="form-select form-select-sm text-center"
                                                data-is-posted="@(Model.IsConverted ? "1" : "0")">
                                            <option value="">اختر المخزن</option>
                                        </select>
                                    </div>
                                    <div class="col-6 col-md-4 col-lg-3">
                                        <label class="form-label form-label-sm">كاتب الطلب</label>
                                        <input id="InvoiceCreatedByDisplay"
                                               class="form-control form-control-sm"
                                               value="@Model.CreatedBy"
                                               readonly />
                                    </div>
                                    <div class="col-6 col-md-4 col-lg-3">
                                        <label class="form-label form-label-sm">الهاتف</label>
                                        <input id="CustomerPhone"
