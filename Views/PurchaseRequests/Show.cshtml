                                                    data-field="expiry" 
                                                    data-line-no="${lineNo}"
                                                    data-prod-id="${g.prodId}"
                                                    value="${expiryText}" 
                                                    placeholder="MM/YYYY"
                                                    pattern="(0[1-9]|1[0-2])/[0-9]{4}"
                                                    autocomplete="off"
                                                    style="min-width: 100px;" />
                                         </td>
                                         <td class="text-center">
                                             <input type="number" 
                                                    class="form-control form-control-sm text-center editable-line-field" 
                                                    data-field="qty" 
                                                    data-line-no="${lineNo}"
                                                    data-prod-id="${g.prodId}"
                                                    value="${qty}" 
                                                    min="1"
                                                    autocomplete="off"
                                                    style="min-width: 80px;" />
                                         </td>
                                         <td class="text-center">${fmt2(priceRetail)}</td>
                                         <td class="text-center">
                                             <input type="number" 
                                                    class="form-control form-control-sm text-center editable-line-field" 
                                                    data-field="discount" 
                                                    data-line-no="${lineNo}"
                                                    data-prod-id="${g.prodId}"
                                                    value="${fmt2(discPct)}" 
                                                    min="0"
                                                    max="100"
                                                    step="0.01"
                                                    autocomplete="off"
                                                    style="min-width: 80px;" />
                                         </td>

                                         <td class="text-center line-value">${fmt2(lineValue)}</td>
