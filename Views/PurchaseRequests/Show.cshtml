                                     const batchNo = line.preferredBatchNo ?? line.batchNo ?? ''; // متغير: التشغيلة

                                     const expiryText = line.preferredExpiry 
                                         ? formatDateYMD(line.preferredExpiry)
                                         : (line.expiryText 
                                             ? line.expiryText 
                                             : (line.expiry ? formatDateYMD(line.expiry) : '')); // متغير: الصلاحية

                                     const qty = Number(line.qty || line.qtyRequested || 0); // متغير: الكمية
                                     const priceRetail = Number(line.priceRetail || 0); // متغير: سعر الجمهور

                                     const discPct = (line.purchaseDiscountPct != null)
                                         ? Number(line.purchaseDiscountPct)
                                         : Number(line.discPct || 0); // متغير: الخصم %

                                     const lineValue = (line.lineValue != null)
                                         ? Number(line.lineValue)
                                         : (qty * priceRetail * (1 - (discPct / 100))); // متغير: قيمة السطر

                                     const tr = document.createElement('tr');
                                     tr.setAttribute('data-line-no', lineNo);
                                     tr.setAttribute('data-prodid', g.prodId);

                                     tr.innerHTML = `
                                         <td class="text-center">${lineNo}</td>

                                         <td class="text-muted small">↳</td>

                                         <td class="text-center">
                                             <input type="text" 
                                                    class="form-control form-control-sm text-center editable-line-field" 
                                                    data-field="batchNo" 
                                                    data-line-no="${lineNo}"
                                                    data-prod-id="${g.prodId}"
                                                    value="${escapeHtml(batchNo)}" 
                                                    placeholder="التشغيلة"
                                                    autocomplete="off"
                                                    style="min-width: 100px;" />
                                         </td>
                                         <td class="text-center">
                                             <input type="text" 
                                                    class="form-control form-control-sm text-center editable-line-field" 
                                                    data-field="expiry" 
                                                    data-line-no="${lineNo}"
                                                    data-prod-id="${g.prodId}"
                                                    value="${expiryText}" 
                                                    placeholder="MM/YYYY"
                                                    pattern="(0[1-9]|1[0-2])/[0-9]{4}"
                                                    autocomplete="off"
                                                    style="min-width: 100px;" />
                                         </td>
                                         <td class="text-center">
                                             <input type="number" 
                                                    class="form-control form-control-sm text-center editable-line-field" 
                                                    data-field="qty" 
                                                    data-line-no="${lineNo}"
                                                    data-prod-id="${g.prodId}"
                                                    value="${qty}" 
                                                    min="1"
                                                    autocomplete="off"
                                                    style="min-width: 80px;" />
                                         </td>
                                         <td class="text-center">${fmt2(priceRetail)}</td>
                                         <td class="text-center">
                                             <input type="number" 
                                                    class="form-control form-control-sm text-center editable-line-field" 
                                                    data-field="discount" 
                                                    data-line-no="${lineNo}"
                                                    data-prod-id="${g.prodId}"
                                                    value="${fmt2(discPct)}" 
                                                    min="0"
                                                    max="100"
                                                    step="0.01"
                                                    autocomplete="off"
                                                    style="min-width: 80px;" />
                                         </td>

                                         <td class="text-center line-value">${fmt2(lineValue)}</td>

                                         <td class="text-center">
                                             <button type="button"
                                                     class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                                     data-line-no="${lineNo}">
                                                 مسح
                                             </button>
                                         </td>
                                     `;

                                     tbody.appendChild(tr);
                                 });
                             });
                             
                             // ===============================
                             // ربط event listeners للحقول القابلة للتعديل بعد رسم السطور
                             // ===============================
                             setTimeout(() => {
                                 bindEditableLineFields();
                             }, 100);
                         }
                         
                         // ===============================
                         // دالة: ربط event listeners للحقول القابلة للتعديل
                         // ===============================
                         function bindEditableLineFields() {
                             // إزالة الـ listeners القديمة أولاً (طريقة أفضل)
                             document.querySelectorAll('.editable-line-field').forEach(field => {
                                 // إزالة جميع الـ event listeners القديمة
                                 const newField = field.cloneNode(true);
                                 field.parentNode.replaceChild(newField, field);
                             });
                             
                             const tbody = document.getElementById('PILinesTbody');
                             if (!tbody) return;
                             const allFields = tbody.querySelectorAll('.editable-line-field');
                             if (allFields.length === 0) return;
                             
                             const fieldOrder = ['batchNo', 'expiry', 'qty', 'discount'];
                             const allRows = Array.from(tbody.querySelectorAll('tr[data-line-no]'));
                             
                             allRows.forEach((row, rowIndex) => {
                                 fieldOrder.forEach((fieldType, fieldIndex) => {
                                     const field = row.querySelector('input[data-field="' + fieldType + '"]');
                                     if (!field) return;
                                     field.setAttribute('tabindex', (rowIndex * fieldOrder.length) + fieldIndex + 1);
                                     
                                     field.addEventListener('keydown', function(e) {
                                         if (e.key !== 'Enter') return;
                                         e.preventDefault();
                                         e.stopPropagation();
                                         this.dataset.skipBlur = '1';
                                         saveLineFieldChange(this).catch(function() {});
                                         var self = this;
                                         var fType = fieldType;
                                         var fIdx = fieldIndex;
                                         setTimeout(function() {
                                             var currentRow = self.closest('tr[data-line-no]');
                                             if (!currentRow) { delete self.dataset.skipBlur; return; }
                                             var rowsList = Array.from(tbody.querySelectorAll('tr[data-line-no]'));
                                             var idx = rowsList.indexOf(currentRow);
                                             var isLastField = (fType === 'discount');
                                             if (isLastField && idx >= 0 && idx < rowsList.length - 1) {
                                                 var nextRow = rowsList[idx + 1];
                                                 for (var f = 0; f < fieldOrder.length; f++) {
                                                     var inp = nextRow.querySelector('input[data-field="' + fieldOrder[f] + '"]');
                                                     if (inp && !inp.readOnly) {
                                                         inp.focus();
                                                         if (typeof inp.select === 'function') inp.select();
                                                         break;
                                                     }
                                                 }
                                             } else if (isLastField) {
                                                 self.blur();
                                                 setTimeout(function() {
                                                     var p = document.getElementById('ProdNameInput');
                                                     if (p) { p.focus(); if (typeof p.select === 'function') p.select(); }
                                                 }, 150);
                                             } else {
                                                 var nextType = fieldOrder[fIdx + 1];
                                                 var nextField = currentRow.querySelector('input[data-field="' + nextType + '"]');
                                                 if (nextField && !nextField.readOnly) {
                                                     nextField.focus();
                                                     if (typeof nextField.select === 'function') nextField.select();
                                                 }
                                             }
                                             delete self.dataset.skipBlur;
                                         }, 120);
                                     });
                                     
                                     // Event listener للـ Blur (حفظ عند الخروج من الحقل - فقط إذا لم يكن Enter)
                                     field.addEventListener('blur', async function() {
                                         if (this.dataset.skipBlur === '1') {
                                             return;
                                         }
                                         // تنسيق تاريخ الصلاحية (شهر+سنة بدون شرطة -> شهر/سنة)
                                         if (fieldType === 'expiry' && this.value && typeof formatExpiryWithSlash === 'function') {
                                             this.value = formatExpiryWithSlash(this.value);
                                         }
                                         await saveLineFieldChange(this);
                                     });
                                     // منع بلبلة الدبل-كليك: تركيز وتحديد النص فقط دون انتقال أو سلوك جانبي
                                     field.addEventListener('dblclick', function(e) {
                                         e.preventDefault();
                                         e.stopPropagation();
                                         this.focus();
                                         if (typeof this.select === 'function') this.select();
                                     });
                                 });
                             });
                             if (typeof applyPostedUiLock === 'function') applyPostedUiLock();
                         }
                         
                         // ===============================
                         // دالة: حفظ تغيير حقل في سطر
                         // ===============================
                         async function saveLineFieldChange(field) {
                             if (typeof isInvoicePosted === 'function' && isInvoicePosted()) {
                                 return;
                             }
                             if (field.dataset.saving === '1') {
                                 return;
                             }
                             field.dataset.saving = '1';
                             
                             try {
                                 const lineNo = parseInt(field.getAttribute('data-line-no') || '0');
                                 const prodId = parseInt(field.getAttribute('data-prod-id') || '0');
                                 
                                 if (lineNo <= 0 || prodId <= 0) {
                                     delete field.dataset.saving;
                                     return;
                                 }
                                 
                                 // قراءة القيم الحالية من السطر
                                 const row = field.closest('tr');
                                 if (!row) {
                                     delete field.dataset.saving;
                                     return;
                                 }
                                 
                                 const qtyInput = row.querySelector('input[data-field="qty"]');
                                 const batchInput = row.querySelector('input[data-field="batchNo"]');
                                 const expiryInput = row.querySelector('input[data-field="expiry"]');
                                 const discountInput = row.querySelector('input[data-field="discount"]');
                                 
                                 const qty = parseInt(qtyInput?.value || '0');
                                 const batchNo = (batchInput?.value || '').trim();
                                 const expiryText = (expiryInput?.value || '').trim();
                                 const discPct = parseFloat(discountInput?.value || '0');
                                 
                                 // قراءة سعر الجمهور من السطر (غير قابل للتعديل)
                                 // البحث عن العمود الذي يحتوي على سعر الجمهور (العمود السادس)
                                 const priceRetailCell = row.querySelector('td:nth-child(6)');
                                 let priceRetail = 0;
                                 if (priceRetailCell) {
                                     // محاولة قراءة من textContent أولاً
                                     const priceText = priceRetailCell.textContent?.trim() || '';
                                     priceRetail = parseFloat(priceText.replace(/[^\d.-]/g, '')) || 0;
                                     
                                     // إذا لم نجد قيمة، نحاول من input إذا كان موجوداً
                                     if (priceRetail === 0) {
                                         const priceInput = priceRetailCell.querySelector('input');
                                         if (priceInput) {
                                             priceRetail = parseFloat(priceInput.value) || 0;
                                         }
                                     }
                                 }
                                 
                                 // إذا لم نجد سعر، نستخدم القيمة من data attribute أو نبحث في السطر
                                 if (priceRetail === 0) {
                                     // محاولة قراءة من data attribute
                                     const priceData = row.getAttribute('data-price-retail');
                                     if (priceData) {
                                         priceRetail = parseFloat(priceData) || 0;
                                     }
                                 }
                                 
                                 // حساب قيمة السطر فوراً لتحديث العرض
                                 const lineValue = qty * priceRetail * (1 - (discPct / 100));
                                 const lineValueCell = row.querySelector('.line-value');
                                 if (lineValueCell) {
                                     lineValueCell.textContent = lineValue.toFixed(2);
                                 }
                                 
                                 if (qty <= 0) {
                                     alert('الكمية يجب أن تكون أكبر من صفر');
                                     qtyInput?.focus();
                                     delete field.dataset.saving;
                                     return;
                                 }
                                 
                                 if (discPct < 0 || discPct > 100) {
                                     alert('الخصم يجب أن يكون بين 0 و 100');
                                     discountInput?.focus();
                                     delete field.dataset.saving;
                                     return;
                                 }
                                 
                                 // قراءة رقم الطلب
                                 const invoiceId = parseInt((document.getElementById("InvoiceId")?.value || "0"), 10) || 0;
                                 if (invoiceId <= 0) {
                                     alert('يجب حفظ الطلب أولاً');
                                     delete field.dataset.saving;
                                     return;
                                 }
                                 
                                 // تحويل تاريخ الصلاحية من MM/YYYY إلى DateTime
                                 // دعم صيغ متعددة: MM/YYYY, MM/YY, MM/DD/YYYY
                                 let preferredExpiry = null;
                                 if (expiryText) {
                                     const parts = expiryText.trim().split('/');
                                     if (parts.length === 2) {
                                         const month = parseInt(parts[0], 10);
                                         const yearPart = parseInt(parts[1], 10);
                                         
                                         // تحديد إذا كان السنة كاملة (4 أرقام) أم مختصرة (2 أرقام)
                                         let year = yearPart;
                                         if (yearPart < 100) {
                                             // إذا كانت السنة 2 أرقام، نضيف 2000
                                             year = 2000 + yearPart;
                                         }
                                         
                                         if (month >= 1 && month <= 12 && year > 0) {
                                             // نستخدم أول يوم من الشهر
                                             preferredExpiry = `${year}-${String(month).padStart(2, '0')}-01`;
                                         }
                                     } else if (parts.length === 3) {
                                         // صيغة MM/DD/YYYY
                                         const month = parseInt(parts[0], 10);
                                         const day = parseInt(parts[1], 10);
                                         const year = parseInt(parts[2], 10);
                                         if (month >= 1 && month <= 12 && year > 0) {
                                             preferredExpiry = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                                         }
                                     }
                                 }
                                 
                                 // تجهيز البيانات
                                 const dto = {
                                     PRId: invoiceId,
                                     prodId: prodId,
                                     qty: qty,
                                     priceRetail: priceRetail,
                                     purchaseDiscountPct: discPct,
                                     PreferredBatchNo: batchNo || null,
                                     PreferredExpiry: preferredExpiry || null
                                 };
                                 
                                 // التحقق من البيانات قبل الإرسال
                                 if (!dto.PRId || !dto.prodId || !dto.qty || !dto.priceRetail) {
                                     console.error('بيانات غير كاملة:', dto);
                                     alert(`بيانات غير كاملة. PRId: ${dto.PRId}, prodId: ${dto.prodId}, qty: ${dto.qty}, priceRetail: ${dto.priceRetail}`);
                                     delete field.dataset.saving;
                                     return;
                                 }
                                 
                                 const url = '@Url.Action("AddLineJson", "PRLines")';
                                 
                                 // التحقق من أن URL صحيح
                                 if (!url || url.includes('@Url')) {
                                     alert('خطأ في عنوان الخادم. يرجى تحديث الصفحة.');
                                     delete field.dataset.saving;
                                     return;
                                 }
                                 
                                 // التحقق من أن البيانات جاهزة للإرسال
                                 if (!dto || !dto.PRId || !dto.prodId) {
                                     alert('خطأ في البيانات. يرجى المحاولة مرة أخرى.');
                                     delete field.dataset.saving;
                                     return;
                                 }
                                 
                                 const response = await fetch(url, {
                                     method: 'POST',
                                     headers: {
                                         'Content-Type': 'application/json',
                                         'X-Requested-With': 'XMLHttpRequest'
                                     },
                                     body: JSON.stringify(dto)
                                 });
                                 
                                 if (!response.ok) {
                                     const errorText = await response.text();
                                     let errorData;
                                     try {
                                         errorData = JSON.parse(errorText);
                                     } catch {
                                         errorData = { message: 'حدث خطأ أثناء الحفظ' };
                                     }
                                     if (typeof showDismissibleMessage === 'function') {
                                         showDismissibleMessage(errorData.message || 'حدث خطأ أثناء الحفظ');
                                     } else { alert(errorData.message || 'حدث خطأ أثناء الحفظ'); }
                                     delete field.dataset.saving;
                                     return;
                                 }
                                 
                                 const responseText = await response.text();
                                 let data;
                                 try {
                                     data = JSON.parse(responseText);
                                 } catch (e) {
                                     alert('خطأ في قراءة الاستجابة من السيرفر');
                                     delete field.dataset.saving;
                                     return;
                                 }
                                 
                                 if (data.ok) {
                                     // حفظ الإجماليات للاستخدام لاحقاً
                                     if (data.totals) {
                                         window.__lastTotals = data.totals;
                                     }
                                     
                                     // تحديث قيمة السطر (تم تحديثها مسبقاً، لكن نحدثها من السيرفر للتأكد)
                                     const lineValueCell = row.querySelector('.line-value');
                                     if (lineValueCell && data.lines) {
                                         const updatedLine = data.lines.find(l => l.lineNo === lineNo);
                                         if (updatedLine) {
                                             const lineValue = updatedLine.expectedCost || (qty * priceRetail * (1 - (discPct / 100)));
                                             lineValueCell.textContent = lineValue.toFixed(2);
                                         }
                                     }
                                     
                                     // تحديث الخصم والكمية في الحقول (لو تم تحديثهما من السيرفر)
                                     if (data.lines) {
                                         const updatedLine = data.lines.find(l => l.lineNo === lineNo);
                                         if (updatedLine) {
                                             if (discountInput) {
                                                 discountInput.value = (updatedLine.purchaseDiscountPct || discPct).toFixed(2);
                                             }
                                             if (qtyInput) {
                                                 qtyInput.value = updatedLine.qty || qty;
                                             }
                                             // تحديث التاريخ إذا كان بصيغة مختلفة
                                             if (expiryInput && updatedLine.preferredExpiry) {
                                                 const expiryDate = new Date(updatedLine.preferredExpiry);
                                                 if (!isNaN(expiryDate.getTime())) {
                                                     const mm = String(expiryDate.getMonth() + 1).padStart(2, '0');
                                                     const yyyy = expiryDate.getFullYear();
                                                     expiryInput.value = `${mm}/${yyyy}`;
                                                 }
                                             }
                                         }
                                     }
                                     
                                     // تحديث الملخص - مهم جداً!
                                     // نحسب الإجماليات من الصفحة دائماً للتأكد من دقتها
                                     // نستخدم setTimeout لضمان تحديث DOM بعد الحفظ
                                     setTimeout(() => {
                                         const allRows = document.querySelectorAll('tr[data-line-no]');
                                         const allLineValues = document.querySelectorAll('.line-value');
                                         
                                         let totalAfterDiscount = 0;
                                         let totalRetail = 0;
                                         
                                         // حساب إجمالي قيمة السطور (بعد الخصم)
                                         allLineValues.forEach(cell => {
                                             const value = parseFloat(cell.textContent.replace(/[^\d.-]/g, '')) || 0;
                                             totalAfterDiscount += value;
                                         });
                                         
                                         // حساب إجمالي سعر الجمهور من السطور
                                         allRows.forEach(row => {
                                             const qtyInput = row.querySelector('input[data-field="qty"]');
                                             const priceRetailCell = row.querySelector('td:nth-child(6)');
                                             const qty = parseFloat(qtyInput?.value || '0') || 0;
                                             let priceRetail = 0;
                                             if (priceRetailCell) {
                                                 const priceText = priceRetailCell.textContent?.trim() || '';
                                                 priceRetail = parseFloat(priceText.replace(/[^\d.-]/g, '')) || 0;
                                             }
                                             totalRetail += qty * priceRetail;
                                         });
                                         
                                         // حساب إجمالي الكمية
                                         const totalQty = Array.from(allRows).reduce((sum, row) => {
                                             const qtyInput = row.querySelector('input[data-field="qty"]');
                                             return sum + (parseFloat(qtyInput?.value || '0') || 0);
                                         }, 0);
                                         
                                         // حساب إجمالي الخصم
                                         const totalDiscount = totalRetail - totalAfterDiscount;
                                         
                                         // قراءة الضريبة من الحقل
                                         const taxInput = document.getElementById('TaxAmountInput');
                                         const taxAmount = parseFloat(taxInput?.value || '0') || 0;
                                         
                                         // حساب الإجمالي بعد الخصم والضريبة
                                         const totalAfterDiscountAndTax = totalAfterDiscount + taxAmount;
                                         
                                         // الصافي النهائي = الإجمالي بعد الخصم والضريبة
                                         const netTotal = totalAfterDiscountAndTax;
                                         
                                         // تحديث الإجماليات
                                        if (typeof updateSummaryBadges === 'function') {
                                            updateSummaryBadges({
                                                totalLines: allRows.length,
                                                totalItems: allRows.length,
                                                totalQty: totalQty,
                                                totalRetail: totalRetail,
                                                totalDiscount: totalDiscount,
                                                totalAfterDiscount: totalAfterDiscount,
                                                taxAmount: taxAmount,
                                                totalAfterDiscountAndTax: totalAfterDiscountAndTax,
                                                netTotal: netTotal
                                            });
                                        }
                                        // لا نستدعي bindEditableLineFields هنا لأنها تستبدل الحقول بنسخ فتفقد الفوكس
                                    }, 150);
                                 } else {
                                     if (typeof showDismissibleMessage === 'function') {
                                         showDismissibleMessage(data.message || 'حدث خطأ أثناء الحفظ');
                                     } else { alert(data.message || 'حدث خطأ أثناء الحفظ'); }
                                 }
                             } catch (error) {
                                 console.error('Error saving line field:', error);
                                 if (typeof showDismissibleMessage === 'function') {
                                     showDismissibleMessage('حدث خطأ أثناء الحفظ: ' + (error.message || ''));
                                 } else { alert('حدث خطأ أثناء الحفظ: ' + error.message); }
                             } finally {
                                 delete field.dataset.saving;
                             }
                         }
                         
                         // ✅ نخلي الدالة Global عشان أي جزء في الصفحة يقدر ينادي عليها
                         window.renderGroupedLines = renderGroupedLines;
                         window.bindEditableLineFields = bindEditableLineFields;
                         window.saveLineFieldChange = saveLineFieldChange;
                         
