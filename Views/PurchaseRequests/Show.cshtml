                                         // ✅ إعادة تحميل body للطلب (بنفس طريقة RemoveLineJson)
                                         const baseUrl = document.getElementById('btnNavInvoiceSearch')?.getAttribute('data-base-url')
                                             || '@Url.Action("Show", "PurchaseRequests", new { frame = 1 })';
                                         const url = setOrReplaceParam(baseUrl, 'id', invoiceId);
                                         await loadInvoiceBody(url);

                                         if (msg) {
                                             msg.textContent = data.message || "تم مسح جميع الأصناف.";
                                             msg.className = "small mt-2 text-success";
                                         }

                                     } catch (err) {

                                         btnClearAll.disabled = false;
                                         btnClearAll.innerHTML = oldHtml;

                                         if (msg) {
                                             msg.textContent = "فشل مسح الأصناف: " + (err.message || "خطأ غير معروف");
                                             msg.className = "small mt-2 text-danger";
                                         }

                                     } finally {
                                         busy = false;
                                         btnClearAll.disabled = false;
                                         btnClearAll.innerHTML = oldHtml;
                                     }
                                 });
                             });







