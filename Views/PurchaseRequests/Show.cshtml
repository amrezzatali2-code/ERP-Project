                            <div class="pi-print-details-grid small w-100" role="presentation">
                                <div>اسم المورد: <strong id="piPrintSupplier"></strong></div>
                                <div>الكاتب: <strong id="piPrintAuthor"></strong></div>
                                <div>المخزن: <strong id="piPrintWarehouse"></strong></div>
