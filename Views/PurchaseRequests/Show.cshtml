                            // =========================
                            // اعتراض الضغط على الأسهم/بحث الطلب على مستوى document (Capture)
                            // =========================
                            async function docCaptureHandler(ev) {

                                // متغير: العنصر الذي تم الضغط عليه
                                const t = ev.target;

                                // حماية: لو target مش Element (نادرًا) نخرج
                                if (!(t instanceof Element)) return;

                                // ✅ الأسهم + البحث: نتعامل معهم هنا (عند فتح الصفحة داخل iframe لا يصل النقر إلى site.js)
                                // لا نرجع هنا؛ نترك الكود يصل إلى معالج (1) الأسهم + البحث لتنفيذ loadInvoiceBody





                              // =========================
                             // (0) زر مسح سطر من الطلب
                             // =========================
                             const removeBtn = t.closest('.btnRemoveLineFromInvoice');
                             if (removeBtn) {

                                 ev.preventDefault();
                                 ev.stopPropagation();
                                 ev.stopImmediatePropagation();

                                 // متغير: رقم السطر داخل الطلب
                                 const lineNo = parseInt(removeBtn.getAttribute('data-line-no') || '0', 10);

                                               // ✅ رقم الطلب (لازم يتقري وقت الضغط من الـ DOM لأنه بيتغير مع الـ Reload الجزئي)
                             const PRId = parseInt((document.getElementById('InvoiceId')?.value || '0'), 10) || 0;


                                 if (!PRId || PRId <= 0) { alert('لا يمكن مسح سطر: رقم الطلب غير معروف.'); return; }
                                 if (!lineNo || lineNo <= 0) { alert('لا يمكن مسح سطر: رقم السطر غير صحيح.'); return; }

                                 // تأكيد بسيط
                                 if (!confirm(`هل تريد مسح السطر رقم (${lineNo})؟`)) return;

                                 // منع الضغط المتكرر أثناء التنفيذ
                                 removeBtn.disabled = true;

                                 // ✅ متغير: توكن AntiForgery (من الدالة المثبتة عندك في Show)
                                 const antiToken = (window.getAntiForgeryToken ? window.getAntiForgeryToken() : '');

                                 // متغير: تايم آوت علشان ما يفضلش معلق
                                 const controller = new AbortController();
                                 const timeoutId = setTimeout(() => controller.abort(), 30000); // 30 ثانية

                                 try {
                                     // ✅ استدعاء الأكشن الصحيح: RemoveLineJson
                                     const res = await fetch('@Url.Action("RemoveLineJson", "PurchaseRequests")', {
                                         method: 'POST',
                                         credentials: 'same-origin',
                                         signal: controller.signal,
                                         headers: {
                                             'Content-Type': 'application/json',
                                             'X-Requested-With': 'XMLHttpRequest',
                                             ...(antiToken ? { 'RequestVerificationToken': antiToken } : {})
                                         },
                                         // ✅ لازم نفس أسماء الـ DTO
                                         body: JSON.stringify({ PRId: PRId, LineNo: lineNo })
                                     });

                                     // متغير: نحاول نفهم الرد سواء JSON أو نص
                                     let data = null;
                                     const contentType = (res.headers.get('content-type') || '').toLowerCase();

                                     if (contentType.includes('application/json')) {
                                         data = await res.json().catch(() => null);
                                     } else {
                                         const txt = await res.text().catch(() => '');
                                         data = { ok: false, message: txt ? 'فشل مسح السطر (رد غير متوقع من السيرفر).' : 'فشل مسح السطر.' };
                                     }

                                     if (!res.ok || !data || data.ok !== true) {
                                         const msg = (data && data.message) ? data.message : 'فشل مسح السطر.';
                                         alert(msg);
                                         return;
                                     }

                                     // ✅ تحديث الجدول والإجماليات مباشرة من رد السيرفر (بدون Reload)
                                     const lines = (data.lines || []).map(l => ({
                                         ...l,
                                         preferredBatchNo: l.batchNo ?? l.preferredBatchNo,
                                         preferredExpiry: l.expiry ?? l.preferredExpiry,
                                         qtyRequested: l.qty ?? l.qtyRequested,
                                         purchaseDiscountPct: l.discPct ?? l.purchaseDiscountPct
                                     }));
                                     if (typeof renderGroupedLines === 'function') renderGroupedLines(lines);
                                     if (data.totals) {
                                         const taxInp = document.getElementById('TaxAmountInput');
                                         if (taxInp) data.totals.taxAmount = parseFloat(taxInp.value) || 0;
                                         if (typeof updateSummaryBadges === 'function') updateSummaryBadges(data.totals);
                                     }
                                     if (typeof bindEditableLineFields === 'function') setTimeout(() => bindEditableLineFields(), 50);

                                     const msgBox = document.getElementById('postInvoiceMsg');
                                     if (msgBox) {
                                         msgBox.textContent = data.message || 'تم حذف السطر.';
                                         msgBox.className = 'small mt-2 text-success';
                                     }

                                 } catch (e) {
                                     console.error(e);

                                     if (e && e.name === 'AbortError') {
                                         alert('التنفيذ أخذ وقت طويل. حاول مرة أخرى.');
                                     } else {
                                         alert('حدث خطأ أثناء مسح السطر.');
                                     }
                                 } finally {
                                     clearTimeout(timeoutId);

                                     if (document.contains(removeBtn)) {
                                         removeBtn.disabled = false;
                                     }
                                 }

                                 return; // مهم: منع استمرار التعامل كأنه زر أسهم
                             }






                                // =========================
                                // (1) الأسهم + البحث
                                // =========================
                                const btn = t.closest('#btnFirstInvoice, #btnPrevInvoice, #btnNextInvoice, #btnLastInvoice, #btnNavInvoiceSearch');
                                if (!btn) return;

                                if (btn.hasAttribute('disabled')) return;

                                // ✅ امنع أي نظام تابات/لينكات
                                ev.preventDefault();
                                ev.stopPropagation();
                                ev.stopImmediatePropagation();

                                // ✅ مهم: اقفل Tooltip + شيل فوكس بعد الضغط
                                hideTooltipAndBlur(btn);

                                if (btn.id === 'btnNavInvoiceSearch') {
                                    const input = document.getElementById('NavInvoiceSearchInput');
                                    const val = input ? parseInt(input.value || '0', 10) : 0;
                                    if (!val || val <= 0) return;
                                    loadInvoiceBody(val);
                                    return;
                                }

                                // ✅ للأزرار: نقرأ data-id (رقم الطلب المستهدف) ونحمّل body من المسار الحالي
                                refreshSideNavButtons();
                                const btnId = btn.getAttribute('data-id');
                                const targetId = btnId ? parseInt(btnId, 10) : 0;
                                if (!targetId || targetId <= 0) return;
                                loadInvoiceBody(targetId);
                             }








                             // =========================================================
                 // ERP — زر طباعة الطلب (Purchase Invoice) [ثابت معتمد]
                 // - ممنوع الطباعة إلا لو الطلب مُرحّلة (مغلقة)
                 // - نقرأ InvoiceId وقت الضغط
                 // - نطبع فقط .erp-print-area (حسب site.css)
                 // - نجهز (الهيدر + السطور + الإجماليات) قبل الطباعة
                 // =========================================================
                 document.addEventListener("DOMContentLoaded", function () {

                     const btnPrint = document.getElementById("btnPrintInvoice"); // متغير: زر طباعة الطلب
                     const msg = document.getElementById("postInvoiceMsg");       // متغير: صندوق الرسائل

                     if (!btnPrint) return;

                     // ✅ ربط مرة واحدة
                     if (btnPrint.dataset.boundPrint) return;
                     btnPrint.dataset.boundPrint = "1";

                     // ✅ عند فتح الصفحة: لو الطلب مش مُرحّلة نقفل زر الطباعة
                     if (typeof isInvoicePosted === "function" && !isInvoicePosted()) {
                         btnPrint.disabled = true;
                     }

                     // متغير: منع فتح نافذة الطباعة مرتين
                     let printing = false;

                     // =========================================================
                     // دالة: تجهيز منطقة الطباعة من القيم الظاهرة في الشاشة
                     // =========================================================
                     function preparePurchaseInvoicePrint() {

                         // متغير: منطقة الطباعة
                         const printArea = document.getElementById("piPrintArea");
                         if (!printArea) return false;

                         // =========================
                         // (1) هيدر الطباعة
                         // =========================

                         // متغير: رقم الطلب
                         const invoiceId = (document.getElementById("InvoiceId")?.value || "").trim();

                         // متغير: تاريخ الطلب (لو عندك input اسمه PIDate)
                         const invoiceDate =
                             (document.getElementById("PIDate")?.value || "").trim() ||
                             "";

                         // متغير: اسم المورد من الـ Select (CustomerId)
                         let supplierName = "";
                         const customerSel = document.getElementById("CustomerId");
                         if (customerSel && customerSel.options && customerSel.selectedIndex >= 0) {
                             supplierName = (customerSel.options[customerSel.selectedIndex].text || "").trim();
                         }

                         // متغير: اسم المخزن من الـ Select (WarehouseId)
                         let warehouseName = "";
                         const whSel = document.getElementById("WarehouseId");
                         if (whSel && whSel.options && whSel.selectedIndex >= 0) {
                             warehouseName = (whSel.options[whSel.selectedIndex].text || "").trim();
                         }

                         // تعبئة عناصر الهيدر
                         document.getElementById("piPrintNow").textContent = new Date().toLocaleString();
                         document.getElementById("piPrintTitle").textContent = `ERP — طلبمشتريات رقم ${invoiceId || ""}`;
                         document.getElementById("piPrintInvoiceNo").textContent = invoiceId || "";
                         document.getElementById("piPrintInvoiceDate").textContent = invoiceDate || "";
                         document.getElementById("piPrintSupplier").textContent = supplierName || "";
                         document.getElementById("piPrintWarehouse").textContent = warehouseName || "";

                         // =========================
                         // (2) السطور: ننسخ جدول السطور الموجود
                         // =========================
                         const linesWrap = document.getElementById("piPrintLinesWrap");
                         if (!linesWrap) return false;

                         linesWrap.innerHTML = "";

                         const tbody = document.getElementById("PILinesTbody"); // متغير: tbody الخاص بسطور الطلب
                         if (!tbody) {
                             linesWrap.innerHTML = `<div class="text-muted small">لا توجد سطور للطباعة.</div>`;
                         } else {
                             const table = tbody.closest("table");
                             if (!table) {
                                 linesWrap.innerHTML = `<div class="text-muted small">تعذر العثور على جدول السطور.</div>`;
                             } else {
                                 // استنساخ الجدول
                                 const clone = table.cloneNode(true);

                                 // إزالة أي أزرار داخل الجدول (مسح/تعديل)
                                 clone.querySelectorAll("button, a").forEach(x => x.remove());

                                 linesWrap.appendChild(clone);
                             }
                         }

                         // =========================
                         // (3) الإجماليات: نقرأها من IDs التي عندك
                         // =========================
                         const totalsWrap = document.getElementById("piPrintTotalsWrap");
                         if (!totalsWrap) return false;

                         const totalLines = document.getElementById("TotalLinesValue")?.textContent?.trim() || "0";
                         const totalItems = document.getElementById("TotalItemsValue")?.textContent?.trim() || "0";
                         const totalQty = document.getElementById("TotalQtyValue")?.textContent?.trim() || "0";
                         const totalRetail = document.getElementById("TotalRetailValue")?.textContent?.trim() || "0";
                         const totalAfterDiscount = document.getElementById("TotalAfterDiscountValue")?.textContent?.trim() || "0";
                         const tax = (document.getElementById("TaxAmountInput")?.value || "").trim() || "0";
                         const totalAfterDiscountAndTax = document.getElementById("TotalAfterDiscountAndTaxValue")?.textContent?.trim() || "0";
                         const netTotal = document.getElementById("NetTotalValue")?.textContent?.trim() || "0";

                         totalsWrap.innerHTML = `
                             <table>
                                 <thead><tr><th colspan="4">الإجماليات</th></tr></thead>
                                 <tbody>
                                     <tr>
                                         <td>عدد السطور</td><td><strong>${totalLines}</strong></td>
                                         <td>عدد الأصناف</td><td><strong>${totalItems}</strong></td>
                                     </tr>
                                     <tr>
                                         <td>إجمالي الكمية</td><td><strong>${totalQty}</strong></td>
                                         <td>إجمالي سعر الجمهور</td><td><strong>${totalRetail}</strong></td>
                                     </tr>
                                     <tr>
                                         <td>الإجمالي بعد الخصم</td><td><strong>${totalAfterDiscount}</strong></td>
                                         <td>قيمة الضريبة</td><td><strong>${tax}</strong></td>
                                     </tr>
                                     <tr>
                                         <td>الإجمالي بعد الخصم والضريبة</td><td><strong>${totalAfterDiscountAndTax}</strong></td>
                                         <td>الصافي النهائي</td><td><strong>${netTotal}</strong></td>
                                     </tr>
                                 </tbody>
                             </table>
                         `;

                         return true;
                     }

                     btnPrint.addEventListener("click", function () {

                         // ✅ اقرأ رقم الطلب وقت الضغط
                         const invoiceId = parseInt((document.getElementById("InvoiceId")?.value || "0"), 10) || 0;

                         if (invoiceId <= 0) {
                             if (msg) {
                                 msg.textContent = "⚠️ لا يمكن طباعة طلبقبل حفظها.";
                                 msg.className = "small mt-2 text-warning";
                             }
                             return;
                         }

                         // ✅ شرط البرنامج: لا طباعة إلا بعد الترحيل
                         if (typeof isInvoicePosted === "function" && !isInvoicePosted()) {
                             if (msg) {
                                 msg.textContent = "❌ لا يمكن طباعة الطلب إلا بعد التحويل.";
                                 msg.className = "small mt-2 text-danger";
                             }
                             document.getElementById("btnPostInvoice")?.focus();
                             return;
                         }

                         // منع تكرار الطباعة
                         if (printing) return;
                         printing = true;

                         // ✅ تجهيز منطقة الطباعة
                         const ok = preparePurchaseInvoicePrint();
                         if (!ok) {
                             printing = false;
                             if (msg) {
                                 msg.textContent = "تعذر تجهيز الطباعة. تأكد من وجود منطقة الطباعة piPrintArea.";
                                 msg.className = "small mt-2 text-danger";
                             }
                             return;
                         }

                                     // =========================
                             // (ERP ثابت) تجهيز بيانات الهيدر داخل منطقة الطباعة قبل التنفيذ
                             // =========================

                             // متغير: اسم المورد من نفس Input في الهيدر
                             const supplierName = (document.getElementById("CustomerNameInput")?.value || "").trim();

                             // متغير: تاريخ الطلب من نفس Input في الهيدر
                             const invoiceDate = (document.getElementById("InvoiceDateDisplay")?.value || "").trim();

                             // دالة صغيرة: تكتب نص في عنصر طباعة لو موجود
                             function setPrintText(id, text) {
                                 const el = document.getElementById(id);
                                 if (el) el.textContent = text || "";
                             }

                             // ✅ املأ القيم داخل الطباعة
                             setPrintText("piPrintSupplier", supplierName);
                             setPrintText("piPrintInvoiceDate", invoiceDate);


                         // ✅ اطبع مرة واحدة
                         setTimeout(() => window.print(), 50);
                     });

                     // بعد إغلاق نافذة الطباعة
                     window.addEventListener("afterprint", function () {
                         printing = false;
                     });
                 });










                             // =========================
                             // تشغيل
                             // =========================
                             document.addEventListener('click', docCaptureHandler, true);

                             document.addEventListener('DOMContentLoaded', function () {

                                 // ✅ أول ما الصفحة تفتح: نضبط الأزرار (فوراً)
                                 refreshSideNavButtons();

                                 // ✅ أول ما الصفحة تفتح: نضبط Tooltips (الأسهم فقط)
                                 setupTooltips();
                                 
                                 // ✅ تأكد من تحديث data-url مرة أخرى بعد تأخير بسيط (لضمان التحديث)
                                 setTimeout(function() {
                                     refreshSideNavButtons();
                                 }, 100);

                                 // ✅ إزالة Tooltip من البحث نهائيًا (Placeholder فقط)
                                 const input = document.getElementById('NavInvoiceSearchInput');
                                 if (input) {
                                     input.removeAttribute('title');
                                     // تعليق: placeholder هو اللي هيوضح وظيفة البحث
                                     if (!input.getAttribute('placeholder')) input.setAttribute('placeholder', 'بحث برقم الطلب');
                                 }

                                 const btn = document.getElementById('btnNavInvoiceSearch');
                                 if (btn) btn.removeAttribute('title');

                                 // ✅ لو طلب جديد (PRId = 0): نعمل focus على حقل اسم المورد
                                 const invoiceIdInput = document.getElementById('InvoiceId');
                                 const invoiceId = invoiceIdInput ? parseInt(invoiceIdInput.value || '0', 10) : 0;
                                 
                                 if (invoiceId === 0) {
                                     setTimeout(function() {
                                         const customerNameInput = document.getElementById('CustomerNameInput');
                                         if (customerNameInput) {
                                             customerNameInput.focus();
                                             customerNameInput.select();
                                         }
                                     }, 300);
                                 }
                             });

                         })();









    </script>
