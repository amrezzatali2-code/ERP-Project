@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.PurchaseRequest

@{
    // عنوان التاب
    ViewData["Title"] = Model.PRId == 0
        ? "طلب شراء جديد"
        : $"طلب شراء — رقم {Model.PRId}";
}

@section Styles {
    <style>
        /* خلفية عامة للصفحة */
        .invoice-page {
            background-color: #f3f6fb; /* لون خفيف مريح للعين */
            min-height: 100vh;
            padding-bottom: 2rem;
        }

        /* الكروت الرئيسية (الهيدر + تفاصيل + إدخال صنف + بيانات الصنف + السطور + الإجماليات + الكارت الجانبي) */
        .invoice-header-card,
        .invoice-details-card,
        .invoice-lines-card,
        .invoice-totals-card,
        .invoice-side-card,
        .invoice-Add-card,
        .invoice-product-card {
            border-radius: 1rem;
            overflow: hidden;
        }

        /* شريط الهيدر الملون للهيدر الرئيسي */
        .invoice-header-bar {
            background: linear-gradient(90deg, #00b4d8 0%,#002b5b 100%);
            color: #ffffff;
            padding: 0.75rem 1.25rem;
        }

            .invoice-header-bar h5 {
                margin-bottom: 0.1rem;
            }

        /* نفس لون الهيدر لباقي الكروت */
        .invoice-details-card .card-header,
        .invoice-Add-card .card-header,
        .invoice-product-card .card-header,
        .invoice-lines-card .card-header,
        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #00b4d8 0%,#002b5b 100%);
            color: #ffffff;
            padding: 0.55rem 1rem;
        }

        .invoice-status-badge {
            font-size: 0.8rem;
            padding: 0.3rem 0.7rem;
        }

        .badge-status-draft {
            background-color: #6f42c1; /* بنفسجي لمسودة */
        }

        .badge-status-notposted {
            background-color: #343a40; /* غامق لعدم الترحيل */
        }

        .form-label-sm {
            font-size: 0.85rem;
        }

        .invoice-small-input {
            max-width: 150px;
        }

        .customer-summary-line {
            font-size: 0.82rem;
        }

        /* كارت الإجراءات الجانبية: أزرار أرفع شوية */
        .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
        }

            .invoice-side-card .btn-erp + .btn-erp {
                margin-top: 0.25rem;
            }

        /* هيدر جدول السطور */
        .invoice-lines-header {
            background: linear-gradient(90deg, #00b4d8 0%,#002b5b 100%);
            color: #fff;
        }

            .invoice-lines-header th {
                border-color: #0b5ed7 !important;
            }

        .erp-table-wrapper {
            max-height: 360px;
            overflow: auto;
        }
    </style>
}




<div class="invoice-page" dir="rtl">
    <div class="container-fluid pt-3">

        <div class="row g-3">

            @* =========================
               العمود الرئيسي (الهيدر + العميل + الأصناف + الإجماليات)
               ========================= *@
            <div class="col-lg-10">

                @* ====================================================
                   1) كارت بيانات طلب الشراء + العميل + المخزن
                   ==================================================== *@
                <div class="card shadow-sm mb-2 invoice-header-card">

                    @{
                        // الطلب جديد لو رقم الطلب = 0
                        bool isNewRequest = Model == null || Model.PRId == 0;

                        // لو الطلب محفوظ نعرض تاريخ/وقت الطلب
                        bool hasRequest = !isNewRequest;

                        string requestDateText = hasRequest
                        ? Model.PRDate.ToString("yyyy/MM/dd")
                        : "";

                        // نستخدم وقت الإنشاء كتوقيت للطلب
                        string requestTimeText = hasRequest
                        ? Model.CreatedAt.ToLocalTime().ToString("HH:mm")
                        : "";
                    }

                    <div class="invoice-header-bar d-flex justify-content-between align-items-center flex-wrap gap-2">
                        @* الجزء الأيسر: عنوان الطلب + المستخدم *@
                        <div>
                            <h5 class="mb-1">
                                @if (isNewRequest)
                                {
                                    @:طلب شراء
                                }
                                else
                                {
                                    @:طلب شراء
                                    <span class="small opacity-100">رقم @Model.PRId</span>
                                }
                            </h5>

                            @* نظهر اسم منشئ الطلب فقط لو محفوظ *@
                            @if (!isNewRequest && !string.IsNullOrWhiteSpace(Model.CreatedBy))
                            {
                                <div class="small opacity-100">
                                    أُنشئ بواسطة:
                                    <span class="fw-semibold">@Model.CreatedBy</span>
                                </div>
                            }
                        </div>

                        @* الجزء الأيمن: حالة الطلب *@
                        <div class="text-end">
                            @if (isNewRequest)
                            {
                                <span class="text-white fw-semibold">
                                    اضغط على طلب جديد   .
                                </span>
                            }
                            else if (string.Equals(Model.Status, "Converted", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="text-white fw-semibold">
                                    تم تحويل الطلب إلى فاتورة شراء
                                </span>
                            }
                            else if (string.Equals(Model.Status, "Cancelled", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="text-white fw-semibold">
                                    طلب ملغي
                                </span>
                            }
                            else
                            {
                                <span class="text-white fw-semibold">
                                    طلب مفتوح
                                </span>
                            }
                        </div>
                    </div>

                    <div class="card-body">

                        <div class="row g-3 align-items-end">

                            @* اسم العميل + أوتوكومبليت *@
                            <div class="col-lg-4 col-md-6">
                                <label for="CustomerNameInput" class="form-label form-label-sm">اسم المورد</label>
                                <input id="CustomerNameInput"
                                       class="form-control form-control-sm"
                                       placeholder="اكتب اسم المورد"
                                       list="customersList"
                                       autocomplete="off" />

                                @* قائمة العملاء للأوتوكومبليت – نفس نظام الفاتورة *@
                                <datalist id="customersList">
                                    @if (ViewBag.Customers != null)
                                    {
                                        foreach (var c in ViewBag.Customers)
                                        {
                                            <option value="@c.Name"
                                                    data-id="@c.Id"
                                                    data-user="@c.UserName"
                                                    data-phone="@c.Phone"
                                                    data-address="@c.Address">
                                            </option>
                                        }
                                    }
                                </datalist>

                                <small id="CustomerSummaryText"
                                       class="text-muted customer-summary-line d-block mt-1">
                                    @* سيتم ملؤه بجملة مختصرة عن العميل *@
                                </small>
                            </div>

                            @* كود العميل في بوكس مستقل *@
                            <div class="col-lg-2 col-md-3">
                                <label class="form-label form-label-sm">كود المورد</label>
                                <input id="CustomerCodeDisplay"
                                       class="form-control form-control-sm text-center invoice-small-input"
                                       readonly />

                                @* هذا هو الحقل الفعلي الذي يُحفظ في الطلب *@
                                <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                            </div>

                            @* المخزن *@
                            <div class="col-lg-3 col-md-2">
                                <label class="form-label form-label-sm" for="WarehouseId">المخزن</label>
                                <select asp-for="WarehouseId"
                                        asp-items="ViewBag.Warehouses"
                                        class="form-select form-select-sm">
                                    <option value="">اختر المخزن</option>
                                </select>
                            </div>

                            @* التاريخ والوقت *@
                            <div class="col-lg-3 col-md-6">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">تاريخ الطلب</label>
                                        <input class="form-control form-control-sm text-center"
                                               value="@requestDateText"
                                               readonly />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label form-label-sm">وقت الطلب</label>
                                        <input class="form-control form-control-sm text-center"
                                               value="@requestTimeText"
                                               readonly />
                                    </div>
                                </div>
                            </div>

                        </div>

                        <br>

                        <div class="row g-3">
                            @* من طلب الأصناف *@
                            <div class="col-lg-6 col-md-2">
                                <label class="form-label form-label-sm">تم الطلب بواسطة</label>
                                <input asp-for="RequestedBy"
                                       class="form-control form-control-sm" />
                            </div>

                            @* ملاحظات الطلب *@
                            <div class="col-lg-6 col-md-10">
                                <label class="form-label form-label-sm">ملاحظات على الطلب</label>
                                <input asp-for="Notes"
                                       class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>

                @* ======================================
                   2) كارت تفاصيل العميل (هاتف / عنوان)
                   ====================================== *@
                <div class="card shadow-sm mb-3 invoice-details-card">
                    <div class="card-header">
                        <h6 class="mb-0">تفاصيل المورد</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-lg-4 col-md-2">
                                <label class="form-label form-label-sm">الهاتف</label>
                                <input id="CustomerPhone"
                                       class="form-control form-control-sm"
                                       readonly />
                            </div>

                            <div class="col-lg-4 col-md-2">
                                <label class="form-label form-label-sm">المحافظة</label>
                                <input id="CustomerPhone"
                                       class="form-control form-control-sm"
                                       readonly />
                            </div>

                            <div class="col-lg-8 col-md-8">
                                <label class="form-label form-label-sm">العنوان</label>
                                <input id="CustomerAddress"
                                       class="form-control form-control-sm"
                                       readonly />
                            </div>
                        </div>
                    </div>
                </div>

                @* =====================================================
   3) كارت بيانات الصنف من المخزون + سياسة شراء
   ===================================================== *@
                <div class="card shadow-sm mb-3 invoice-product-card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">بيانات الصنف (مخزون + سياسة شراء)</h6>
                        <small class="opacity-75">
                            هذه البيانات تخص الصنف الحالي في كارت "إضافة صنف للطلب".
                        </small>
                    </div>

                    <div class="card-body">

                        @* الصف العلوي: أرقام سريعة عن الصنف *@
                        <div class="row g-3 mb-3">
                            @* الكمية المتاحة في هذا المخزن *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الكمية المتاحة في هذا المخزن</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            @* إجمالي الكمية في كل المخازن *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">إجمالي الكمية في كل المخازن</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            @* هل الصنف عليه كوتة أم لا *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الصنف عليه كوتة؟</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="بدون كوتة" @* هنا بعدين نربطها بالداتا *@
                                       readonly />
                            </div>

                            @* الخصم المرجّح للصنف *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الخصم المرجّح للصنف %</label>
                                <input type="text"
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>
                        </div>

                        @* ممكن لاحقاً نرجّع جدول توزيع الكمية على المخازن هنا لو احتجناه *@
                        @*
        <div class="table-responsive mt-2">
            <table class="table table-sm table-striped mb-0">
                <thead>
                    <tr>
                        <th>المخزن</th>
                        <th class="text-center">الكمية المتاحة</th>
                        <th class="text-center">محجوزة لطلبات</th>
                        <th class="text-center">متاح للطلب</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- داتا المخازن هتتحط هنا بعدين -->
                </tbody>
            </table>
        </div>
        *@

                        <br>

                        @* الصف الخاص بفترة الحركة + أزرار التقارير *@
                        <div class="row g-3 align-items-end">
                            @* اختيار فترة من / إلى لحركة الصنف *@
                            <div class="col-md-6">
                                <label class="form-label form-label-sm d-block">فترة حركة الصنف</label>
                                <div class="d-flex gap-2">
                                    <input type="date"
                                           id="prodReportFrom"
                                           class="form-control form-control-sm" />
                                    <input type="date"
                                           id="prodReportTo"
                                           class="form-control form-control-sm" />
                                </div>
                            </div>

                            @* أزرار التقارير الخاصة بالصنف مع مسافة بينهم *@
                            <div class="col-md-6">
                               

                                <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                                    <button type="button"
                                            class="btn btn-outline-secondary btn-sm"
                                            id="btnShowSalesReport">
                                        مبيعات الصنف
                                    </button>

                                    <button type="button"
                                            class="btn btn-outline-secondary btn-sm"
                                            id="btnShowPRReport">
                                        طلبات الشراء للصنف
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>



                @* =====================================================
                   4) كارت إدخال الصنف في طلب الشراء
                   ===================================================== *@
                <div class="card shadow-sm mb-3 invoice-Add-card">
                    <div class="card-header">
                        <h6 class="mb-0">إضافة صنف إلى طلب الشراء</h6>
                    </div>

                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">كود الصنف</label>
                                <input type="text"
                                       id="ItemCodeInput"
                                       class="form-control form-control-sm"
                                       placeholder="بحث بالكود..." />
                            </div>

                            <div class="col-lg-4 col-md-8">
                                <label class="form-label form-label-sm">اسم الصنف</label>
                                <input type="text"
                                       id="ItemNameInput"
                                       class="form-control form-control-sm"
                                       placeholder="اكتب اسم الصنف أو جزء منه..." />
                            </div>

                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">سعر الجمهور المرجعي</label>
                                <input type="number"
                                       class="form-control form-control-sm text-center"
                                       placeholder="0.00" />
                            </div>

                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">الكمية المطلوبة</label>
                                <input type="number"
                                       class="form-control form-control-sm text-center"
                                       placeholder="1" />
                            </div>

                            <div class="col-lg-2 col-md-4">
                                <label class="form-label form-label-sm">خصم الشراء %</label>
                                <input type="number"
                                       class="form-control form-control-sm text-center"
                                       placeholder="0" />
                            </div>
                        </div>

                        <div class="row g-2 align-items-end mt-2">
                            <div class="col-lg-3 col-md-4">
                                <label class="form-label form-label-sm">ملاحظات للسطر</label>
                                <input type="text"
                                       class="form-control form-control-sm"
                                       placeholder="مثال: بديل، عرض خاص..." />
                            </div>

                            <div class="col-lg-3 col-md-4">
                                <label class="form-label form-label-sm">تاريخ مطلوب قبل</label>
                                <input asp-for="NeedByDate"
                                       type="date"
                                       class="form-control form-control-sm text-center" />
                            </div>

                            <div class="col-lg-3 col-md-4">
                                <div class="d-grid gap-1 invoice-item-actions mt-4">
                                    <button type="button"
                                            class="btn btn-erp btn-erp-success btn-erp-sm ">
                                        إضافة الصنف للطلب
                                    </button>
                                </div>
                            </div>

                            <div class="col-lg-3 d-none d-lg-block"></div>
                        </div>
                    </div>
                </div>

                @* ==========================================
                   5) جدول سطور طلب الشراء
                   ========================================== *@
                <div class="card shadow-sm mb-3 invoice-lines-card">
                    <div class="card-header py-2 invoice-lines-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">
                                سطور طلب الشراء
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="erp-table-wrapper mb-0">
                            <table class="table table-sm table-striped table-hover mb-0 erp-table">
                                <thead>
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">الكمية المطلوبة</th>
                                        <th class="text-center">سعر الجمهور المرجعي</th>
                                        <th class="text-center">خصم الشراء %</th>
                                        <th class="text-center">تاريخ الصلاحية</th>
                                        <th class="text-center">رقم التشغيلة</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            لا توجد سطور مسجَّلة لهذا الطلب في هذه المرحلة.
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @* ====================================
                   6) ملخص الطلب (حسب رغبتك)
                   ==================================== *@
                @{
                    // عدد الأصناف (مختلفة) في الطلب
                    int totalItems = Model.Lines != null
                    ? Model.Lines.Select(l => l.ProdId).Distinct().Count()
                    : 0;

                    // إجمالي الكمية المطلوبة
                    int totalQty = Model.Lines?.Sum(l => l.QtyRequested) ?? 0;

                    // القيم المالية – مؤقتاً 0 لحد ما نربطها بحقول الأسعار والخصم والضريبة
                    decimal totalRetail = 0m;                 // إجمالي الجمهور
                    decimal totalAfterDiscount = 0m;          // الإجمالي بعد الخصم
                    decimal taxAmount = 0m;                   // قيمة الضريبة
                    decimal totalAfterDiscountAndTax = 0m;    // الإجمالي بعد الخصم والضريبة
                    decimal netTotal = 0m;                    // الصافي النهائي
                }

                <div class="card shadow-sm invoice-totals-card">
                    <div class="card-body">

                        <div class="row g-3 align-items-center mb-2">

                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">عدد الأصناف في الطلب</span>
                                    <span class="badge bg-light text-dark summary-badge">
                                        @totalItems
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">إجمالي الكمية المطلوبة</span>
                                    <span class="badge bg-light text-dark summary-badge">
                                        @totalQty
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">إجمالي سعر الجمهور</span>
                                    <span class="badge bg-light text-dark summary-badge">
                                        @totalRetail.ToString("0.00")
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">الإجمالي بعد الخصم</span>
                                    <span class="badge bg-light text-dark summary-badge">
                                        @totalAfterDiscount.ToString("0.00")
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">الإجمالي بعد الخصم والضريبة</span>
                                    <span class="badge bg-light text-dark summary-badge">
                                        @totalAfterDiscountAndTax.ToString("0.00")
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="d-flex flex-column">
                                    <span class="small text-muted">قيمة الضريبة</span>
                                    <span class="badge bg-info text-dark summary-badge">
                                        @taxAmount.ToString("0.00")
                                    </span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-3" />

                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <span class="small text-muted d-block">الصافي النهائي للطلب</span>
                                <h3 class="mb-0 text-success">
                                    @netTotal.ToString("0.00")
                                </h3>
                            </div>

                            <div class="text-end small text-muted">
                                @if (Model.UpdatedAt.HasValue)
                                {
                                    <div>
                                        آخر تعديل:
                                        <span class="fw-semibold">
                                            @Model.UpdatedAt.Value.ToLocalTime().ToString("yyyy/MM/dd HH:mm")
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>  @* نهاية العمود الرئيسي *@


            @* =========================
               العمود الجانبي (أزرار الحركة)
               ========================= *@
            <div class="col-lg-2">
                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات طلب الشراء</h6>
                    </div>
                    <div class="card-body d-grid">

                        @* زر إنشاء طلب جديد *@
                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm"
                           asp-action="Create">
                            ➕ طلب جديد
                        </a>

                        @* زر مسح كل الأصناف من سطور الطلب *@
                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm"
                                id="btnClearInvoiceLines"
                                data-request-id="@Model.PRId">
                            🗑️ مسح كل الأصناف
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm">
                            ⏪ فتح الطلب
                        </button>

                        <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                           asp-action="Edit"
                           asp-route-id="@Model.PRId">
                            ✏️ تعديل الطلب
                        </a>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm">
                            📤 تحويل إلى فاتورة شراء
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                onclick="window.print()">
                            🖨️ طباعة الطلب
                        </button>

                        <hr />

                        <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                           asp-action="Index">
                            ⬅️ الرجوع لقائمة طلبات الشراء
                        </a>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>

@section Scripts {
    <script>
        // دالة مساعدة: تملأ الحقول من option معين في الـ datalist
        function fillCustomerFromOption(opt) {
            var idInput = document.getElementById('CustomerId');              // كود العميل (للحفظ في الطلب)
            var codeDisplay = document.getElementById('CustomerCodeDisplay'); // كود العميل المعروض
            var phoneInput = document.getElementById('CustomerPhone');        // الهاتف
            var addressInput = document.getElementById('CustomerAddress');    // العنوان
            var summary = document.getElementById('CustomerSummaryText');     // سطر ملخّص صغير

            if (!opt) {
                idInput.value = '';
                codeDisplay.value = '';
                phoneInput.value = '';
                addressInput.value = '';
                summary.textContent = '';
                return;
            }

            var id = opt.getAttribute('data-id') || '';
            var user = opt.getAttribute('data-user') || '';
            var phone = opt.getAttribute('data-phone') || '';
            var address = opt.getAttribute('data-address') || '';

            idInput.value = id;
            codeDisplay.value = id;
            phoneInput.value = phone;
            addressInput.value = address;

            var parts = [];
            if (user) parts.push('مستخدم مرتبط: ' + user);
            if (phone) parts.push('هاتف: ' + phone);
            summary.textContent = parts.join(' — ');
        }

        document.addEventListener('DOMContentLoaded', function () {

            var customerInput = document.getElementById('CustomerNameInput'); // حقل اسم العميل
            var dataList = document.getElementById('customersList');          // قائمة العملاء

            function findOptionByName(name) {
                if (!name) return null;
                var options = dataList.options;
                for (var i = 0; i < options.length; i++) {
                    if (options[i].value === name) return options[i];
                }
                return null;
            }

            function findOptionById(id) {
                if (!id) return null;
                var options = dataList.options;
                for (var i = 0; i < options.length; i++) {
                    if (options[i].getAttribute('data-id') == id) {
                        return options[i];
                    }
                }
                return null;
            }

            // عند اختيار اسم عميل من الأوتوكومبليت
            customerInput.addEventListener('change', function () {
                var opt = findOptionByName(customerInput.value);
                fillCustomerFromOption(opt);
            });

            // تهيئة الشاشة عند الفتح – لو في كود عميل محفوظ في الطلب
            var initialCustomerId = '@Model.CustomerId';
            if (initialCustomerId) {
                var opt = findOptionById(initialCustomerId);
                if (opt) {
                    customerInput.value = opt.value;
                    fillCustomerFromOption(opt);
                }
            }
        });
    </script>
}
