                        @* =====================================================
                       5) جدول السطور
                       ===================================================== *@
                        <div class="invoice-lines-container">
                        <div class="erp-table-wrapper mb-0">
                            <table class="table table-sm table-hover mb-0 erp-table">
                                <thead class="invoice-lines-header">
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">التشغيلة</th>
                                        <th class="text-center">الصلاحية</th>
                                        <th class="text-center">الكمية</th>
                                        <th class="text-center">سعر الجمهور</th>
                                        <th class="text-center">خصم الشراء %</th>
                                        <th class="text-center">قيمة السطر</th>
                                    </tr>
                                </thead>

                                <tbody id="PILinesTbody">
                                    @{
                                        var linesList = Model.Lines?.OrderBy(l => l.LineNo).ToList()
                                        ?? new List<ERP.Models.PRLine>();

                                        var groups = linesList
                                        .GroupBy(l => new
                                        {
                                            l.ProdId,
                                            ProdName = l.Product?.ProdName ?? ("صنف #" + l.ProdId)
                                        })
                                        .OrderBy(g => g.Key.ProdName);
                                    }

                                    @foreach (var g in groups)
                                        {
                                            int batchCount = g.Count();

                                            if (batchCount == 1)
                                            {
                                                var line = g.First();
                                                decimal lineValue =
                                                line.QtyRequested * line.PriceRetail * (1m - (line.PurchaseDiscountPct / 100m));

                                                <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                    <td class="text-center">@line.LineNo</td>

                                                    <td>
                                                        <strong>@g.Key.ProdName</strong>
                                                        <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                    </td>

                                                    <td class="text-center">
                                                        <input type="text" 
                                                               class="form-control form-control-sm text-center editable-line-field" 
                                                               data-field="batchNo" 
                                                               data-line-no="@line.LineNo"
                                                               data-prod-id="@line.ProdId"
                                                               value="@(line.PreferredBatchNo ?? "")" 
                                                               placeholder="التشغيلة"
                                                               autocomplete="off"
                                                               style="min-width: 100px;" />
                                                    </td>

                                                    <td class="text-center">
                                                        <input type="text" 
                                                               class="form-control form-control-sm text-center editable-line-field" 
                                                               data-field="expiry" 
                                                               data-line-no="@line.LineNo"
                                                               data-prod-id="@line.ProdId"
                                                               value="@(line.PreferredExpiry.HasValue ? line.PreferredExpiry.Value.ToString("MM/yyyy") : "")" 
                                                               placeholder="MM/YYYY"
                                                               pattern="(0[1-9]|1[0-2])/[0-9]{4}"
                                                               autocomplete="off"
                                                               style="min-width: 100px;" />
                                                    </td>

                                                    <td class="text-center">
                                                        <input type="number" 
                                                               class="form-control form-control-sm text-center editable-line-field" 
                                                               data-field="qty" 
                                                               data-line-no="@line.LineNo"
                                                               data-prod-id="@line.ProdId"
                                                               value="@line.QtyRequested" 
                                                               min="1"
                                                               autocomplete="off"
                                                               style="min-width: 80px;" />
                                                    </td>

                                                    <td class="text-center">@line.PriceRetail.ToString("0.00")</td>

                                                    <td class="text-center">
                                                        <input type="number" 
                                                               class="form-control form-control-sm text-center editable-line-field" 
                                                               data-field="discount" 
                                                               data-line-no="@line.LineNo"
                                                               data-prod-id="@line.ProdId"
                                                               value="@line.PurchaseDiscountPct.ToString("0.##")" 
                                                               min="0"
                                                               max="100"
                                                               step="0.01"
                                                               autocomplete="off"
                                                               style="min-width: 80px;" />
                                                    </td>

                                                    <td class="text-center line-value">@lineValue.ToString("0.00")</td>
                                                </tr>
                                            }
                                            else
                                            {
                                                <tr class="table-light pi-group-row" data-prodid="@g.Key.ProdId">
                                                    <td class="text-center">—</td>

                                                    <td>
                                                        <strong>@g.Key.ProdName</strong>
                                                        <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                    </td>

                                                    <td class="text-center text-muted small">تشغيلات: @batchCount</td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                </tr>

                                                foreach (var line in g.OrderBy(x => x.LineNo))
                                                {
                                                    decimal lineValue =
                                                    line.QtyRequested * line.PriceRetail * (1m - (line.PurchaseDiscountPct / 100m));

                                                    <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                        <td class="text-center">@line.LineNo</td>
                                                        <td class="text-muted small">↳</td>
                                                        <td class="text-center">
                                                            <input type="text" 
                                                                   class="form-control form-control-sm text-center editable-line-field" 
                                                                   data-field="batchNo" 
                                                                   data-line-no="@line.LineNo"
                                                                   data-prod-id="@line.ProdId"
                                                                   value="@(line.PreferredBatchNo ?? "")" 
                                                                   placeholder="التشغيلة"
                                                                   autocomplete="off"
                                                                   style="min-width: 100px;" />
                                                        </td>
                                                        <td class="text-center">
                                                            <input type="text" 
                                                                   class="form-control form-control-sm text-center editable-line-field" 
                                                                   data-field="expiry" 
                                                                   data-line-no="@line.LineNo"
                                                                   data-prod-id="@line.ProdId"
                                                                   value="@(line.PreferredExpiry.HasValue ? line.PreferredExpiry.Value.ToString("MM/yyyy") : "")" 
                                                                   placeholder="MM/YYYY"
                                                                   pattern="(0[1-9]|1[0-2])/[0-9]{4}"
                                                                   autocomplete="off"
                                                                   style="min-width: 100px;" />
                                                        </td>
                                                        <td class="text-center">
                                                            <input type="number" 
                                                                   class="form-control form-control-sm text-center editable-line-field" 
                                                                   data-field="qty" 
                                                                   data-line-no="@line.LineNo"
                                                                   data-prod-id="@line.ProdId"
                                                                   value="@line.QtyRequested" 
                                                                   min="1"
                                                                   autocomplete="off"
                                                                   style="min-width: 80px;" />
                                                        </td>
                                                        <td class="text-center">@line.PriceRetail.ToString("0.00")</td>
                                                        <td class="text-center">
                                                            <input type="number" 
                                                                   class="form-control form-control-sm text-center editable-line-field" 
                                                                   data-field="discount" 
                                                                   data-line-no="@line.LineNo"
                                                                   data-prod-id="@line.ProdId"
                                                                   value="@line.PurchaseDiscountPct.ToString("0.##")" 
                                                                   min="0"
                                                                   max="100"
                                                                   step="0.01"
                                                                   autocomplete="off"
                                                                   style="min-width: 80px;" />
                                                        </td>
                                                        <td class="text-center line-value">@lineValue.ToString("0.00")</td>
                                                    </tr>
                                                }
                                            }
                                        }
                                </tbody>
                            </table>
                        </div>
                        </div>

                        @* =====================================================
                       6) ملخص الطلب
                       ===================================================== *@
                        @{
                            var lines = Model.Lines?.ToList() ?? new List<ERP.Models.PRLine>();

                            int totalLines = lines.Count;
                            int totalItems = lines.Select(l => l.ProdId).Distinct().Count();
                            int totalQty = lines.Sum(l => l.QtyRequested);

                            decimal totalRetail = lines.Sum(l => l.QtyRequested * l.PriceRetail);
                            decimal totalAfterDiscount = lines.Sum(l =>
                            l.QtyRequested * l.PriceRetail * (1m - (l.PurchaseDiscountPct / 100m))
                            );

                        }

                        <div class="card shadow-sm mb-2 invoice-totals-card">
                            <div class="card-body">
                                @* كل البوكسات في صف واحد — مصغّرة لتناسب الصف *@
                                <div class="d-flex flex-nowrap align-items-stretch gap-1 invoice-summary-row invoice-summary-row-single">
                                    <div class="invoice-summary-item invoice-summary-box">
                                        <span class="invoice-summary-label">عدد السطور</span>
                                        <span id="TotalLinesValue" class="invoice-summary-value">@totalLines</span>
                                    </div>
                                    <div class="invoice-summary-item invoice-summary-box">
                                        <span class="invoice-summary-label">عدد الأصناف</span>
                                        <span id="TotalItemsValue" class="invoice-summary-value">@totalItems</span>
                                    </div>
                                    <div class="invoice-summary-item invoice-summary-box">
                                        <span class="invoice-summary-label">إجمالي الكمية</span>
                                        <span id="TotalQtyValue" class="invoice-summary-value">@totalQty</span>
                                    </div>
                                    <div class="invoice-summary-item invoice-summary-box">
                                        <span class="invoice-summary-label">إجمالي سعر الجمهور</span>
                                        <span id="TotalRetailValue" class="invoice-summary-value">@totalRetail.ToString("0.00")</span>
                                    </div>
                                    <div class="invoice-summary-item invoice-summary-box invoice-summary-box-main">
                                        <span class="invoice-summary-label">الإجمالي بعد الخصم</span>
                                        <span id="TotalAfterDiscountValue" class="invoice-summary-value invoice-summary-value-main fw-bold">@totalAfterDiscount.ToString("0.00")</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* مصادر أوتوكومبليت الثقيلة — آخر PI_BodyHost حتى يُبنى هيكل الكروت أولاً (docs/فتح الفواتير ككتلة واحدة.md) *@
                        <datalist id="customersList" hidden aria-hidden="true">
                            @if (ViewBag.Customers != null)
                            {
                                foreach (var c in ViewBag.Customers)
                                {
                                    <option value="@c.Name"
                                            data-id="@c.Id"
                                            data-phone="@c.Phone"
                                            data-address="@c.Address"
                                            data-gov="@c.Gov"
                                            data-district="@c.District"
                                            data-area="@c.Area"
                                            data-credit="@c.Credit">
                                    </option>
                                }
                            }
                        </datalist>
                        <datalist id="productsList" hidden aria-hidden="true">
                            @if (ViewBag.ProductsAuto != null)
                            {
                                foreach (var p in ViewBag.ProductsAuto)
                                {
                                    <option value="@p.Name"
                                            data-id="@p.Id"
                                            data-code="@p.Id"
                                            data-generic="@p.GenericName"
                                            data-company="@p.Company"
                                            data-price="@p.PriceRetail"
                                            data-hasquota="@(p.HasQuota ? "true" : "false")">
                                    </option>
                                }
                            }
                        </datalist>
                        <datalist id="productsListEmpty"></datalist>

                    </div> @* ✅ نهاية PI_BodyHost *@

                </div> @* نهاية العمود الرئيسي *@




            </div> @* نهاية row *@
        </div> @* نهاية container *@
    @* نافذة رسالة قابلة للإغلاق (بديل عن alert حتى يعمل زر OK) *@
    <div id="erpPrMessageOverlay" class="d-none" style="position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:9999;display:flex;align-items:center;justify-content:center;padding:1rem;">
        <div style="background:#fff;border-radius:12px;max-width:420px;width:100%;box-shadow:0 10px 40px rgba(0,0,0,.2);padding:1.25rem;text-align:center;">
            <p id="erpPrMessageText" class="mb-3" style="font-size:1rem;color:#333;"></p>
            <button type="button" id="erpPrMessageOk" class="btn btn-primary">موافق</button>
        </div>
    </div>

    </div> @* نهاية invoice-page *@

    <!-- =========================================================
         ERP — منطقة طباعة طلب  الشراء (ثابت معتمد)
         ملاحظة: الـ site.css عندك بيطبع فقط .erp-print-area
    ========================================================= -->
    <div id="piPrintWrapper" class="erp-print-area print-only">
    <div id="piPrintArea" class="pi-print-copy">

        <table class="pi-print-master-table table table-bordered table-sm mb-0 w-100">
            <thead>
                <tr>
                    <td colspan="9" class="p-0 border-0 pi-print-thead-banner-cell">
                        <div class="pi-print-header mb-2">
                            <div class="pi-print-company-row d-flex justify-content-between align-items-center">
                                <div class="pi-print-logo-placeholder">
                                    @if (!string.IsNullOrWhiteSpace(ViewBag.PrintHeaderLogoUrl as string))
                                    {
                                        <img src="@((string)ViewBag.PrintHeaderLogoUrl)" alt="logo" style="max-width:80px; max-height:36px;" />
                                    }
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <h2 class="pi-print-company-name mb-0 fw-bold">@((string?)ViewBag.PrintHeaderCompanyName ?? "شركة الهدى")</h2>
                                    <span class="pi-print-doc-title">ERP — طلب شراء</span>
                                </div>
