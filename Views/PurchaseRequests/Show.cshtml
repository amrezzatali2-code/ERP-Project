                        @* =====================================================
                       5) جدول السطور
                       ===================================================== *@
                        <div class="card shadow-sm mb-2 invoice-lines-card">
                            <div class="invoice-card-line"></div>
                            <div class="card-body p-0">
                        <div class="erp-table-wrapper mb-0">
                            <table class="table table-sm table-hover mb-0 erp-table">
                                <thead>
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>اسم الصنف</th>
                                        <th class="text-center">التشغيلة</th>
                                        <th class="text-center">الصلاحية</th>
                                        <th class="text-center">الكمية</th>
                                        <th class="text-center">سعر الجمهور</th>
                                        <th class="text-center">خصم الشراء %</th>
                                        <th class="text-center">قيمة السطر</th>
                                        <th class="text-center no-print">مسح</th>
                                    </tr>
                                </thead>

                                <tbody id="PILinesTbody">
                                    @{
                                        var linesList = Model.Lines?.OrderBy(l => l.LineNo).ToList()
                                        ?? new List<ERP.Models.PRLine>();

                                        var groups = linesList
                                        .GroupBy(l => new
                                        {
                                            l.ProdId,
                                            ProdName = l.Product?.ProdName ?? ("صنف #" + l.ProdId)
                                        })
                                        .OrderBy(g => g.Key.ProdName);
                                    }

                                    @if (!groups.Any())
                                    {
                                        <tr>
                                            <td colspan="9" class="text-center text-muted py-3">
                                                لا يوجد سطور داخل الطلب حتى الآن.
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var g in groups)
                                        {
                                            int batchCount = g.Count();

                                            if (batchCount == 1)
                                            {
                                                var line = g.First();
                                                decimal lineValue =
                                                line.QtyRequested * line.PriceRetail * (1m - (line.PurchaseDiscountPct / 100m));

                                                <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                    <td class="text-center">@line.LineNo</td>

                                                    <td>
                                                        <strong>@g.Key.ProdName</strong>
                                                        <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                    </td>

                                                    <td class="text-center">
                                                        <input type="text" 
                                                               class="form-control form-control-sm text-center editable-line-field" 
                                                               data-field="batchNo" 
                                                               data-line-no="@line.LineNo"
                                                               data-prod-id="@line.ProdId"
                                                               value="@(line.PreferredBatchNo ?? "")" 
                                                               placeholder="التشغيلة"
                                                               autocomplete="off"
                                                               style="min-width: 100px;" />
                                                    </td>

                                                    <td class="text-center">
                                                        <input type="text" 
                                                               class="form-control form-control-sm text-center editable-line-field" 
                                                               data-field="expiry" 
                                                               data-line-no="@line.LineNo"
                                                               data-prod-id="@line.ProdId"
                                                               value="@(line.PreferredExpiry.HasValue ? line.PreferredExpiry.Value.ToString("MM/yyyy") : "")" 
                                                               placeholder="MM/YYYY"
                                                               pattern="(0[1-9]|1[0-2])/[0-9]{4}"
                                                               autocomplete="off"
                                                               style="min-width: 100px;" />
                                                    </td>

                                                    <td class="text-center">
                                                        <input type="number" 
                                                               class="form-control form-control-sm text-center editable-line-field" 
                                                               data-field="qty" 
                                                               data-line-no="@line.LineNo"
                                                               data-prod-id="@line.ProdId"
                                                               value="@line.QtyRequested" 
                                                               min="1"
                                                               autocomplete="off"
                                                               style="min-width: 80px;" />
                                                    </td>

                                                    <td class="text-center">@line.PriceRetail.ToString("0.00")</td>

                                                    <td class="text-center">
                                                        <input type="number" 
                                                               class="form-control form-control-sm text-center editable-line-field" 
                                                               data-field="discount" 
                                                               data-line-no="@line.LineNo"
                                                               data-prod-id="@line.ProdId"
                                                               value="@line.PurchaseDiscountPct.ToString("0.##")" 
                                                               min="0"
                                                               max="100"
                                                               step="0.01"
                                                               autocomplete="off"
                                                               style="min-width: 80px;" />
                                                    </td>

                                                    <td class="text-center line-value">@lineValue.ToString("0.00")</td>

                                                    <td class="text-center no-print">
                                                        <button type="button"
                                                                class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                                                data-line-no="@line.LineNo" data-lock-posted="1">
                                                            مسح
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                            else
                                            {
                                                <tr class="table-light pi-group-row" data-prodid="@g.Key.ProdId">
                                                    <td class="text-center">—</td>

                                                    <td>
                                                        <strong>@g.Key.ProdName</strong>
                                                        <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                    </td>

                                                    <td class="text-center text-muted small">تشغيلات: @batchCount</td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                    <td class="text-center"></td>
                                                </tr>

                                                foreach (var line in g.OrderBy(x => x.LineNo))
                                                {
                                                    decimal lineValue =
                                                    line.QtyRequested * line.PriceRetail * (1m - (line.PurchaseDiscountPct / 100m));

                                                    <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                        <td class="text-center">@line.LineNo</td>
                                                        <td class="text-muted small">↳</td>
                                                        <td class="text-center">
                                                            <input type="text" 
                                                                   class="form-control form-control-sm text-center editable-line-field" 
                                                                   data-field="batchNo" 
                                                                   data-line-no="@line.LineNo"
                                                                   data-prod-id="@line.ProdId"
                                                                   value="@(line.PreferredBatchNo ?? "")" 
                                                                   placeholder="التشغيلة"
                                                                   autocomplete="off"
                                                                   style="min-width: 100px;" />
                                                        </td>
                                                        <td class="text-center">
                                                            <input type="text" 
                                                                   class="form-control form-control-sm text-center editable-line-field" 
                                                                   data-field="expiry" 
                                                                   data-line-no="@line.LineNo"
                                                                   data-prod-id="@line.ProdId"
                                                                   value="@(line.PreferredExpiry.HasValue ? line.PreferredExpiry.Value.ToString("MM/yyyy") : "")" 
                                                                   placeholder="MM/YYYY"
                                                                   pattern="(0[1-9]|1[0-2])/[0-9]{4}"
                                                                   autocomplete="off"
                                                                   style="min-width: 100px;" />
                                                        </td>
                                                        <td class="text-center">
                                                            <input type="number" 
                                                                   class="form-control form-control-sm text-center editable-line-field" 
                                                                   data-field="qty" 
                                                                   data-line-no="@line.LineNo"
                                                                   data-prod-id="@line.ProdId"
                                                                   value="@line.QtyRequested" 
                                                                   min="1"
                                                                   autocomplete="off"
                                                                   style="min-width: 80px;" />
                                                        </td>
                                                        <td class="text-center">@line.PriceRetail.ToString("0.00")</td>
                                                        <td class="text-center">
                                                            <input type="number" 
                                                                   class="form-control form-control-sm text-center editable-line-field" 
                                                                   data-field="discount" 
                                                                   data-line-no="@line.LineNo"
                                                                   data-prod-id="@line.ProdId"
                                                                   value="@line.PurchaseDiscountPct.ToString("0.##")" 
                                                                   min="0"
                                                                   max="100"
                                                                   step="0.01"
                                                                   autocomplete="off"
                                                                   style="min-width: 80px;" />
                                                        </td>
                                                        <td class="text-center line-value">@lineValue.ToString("0.00")</td>
                                                        <td class="text-center no-print">
                                                            <button type="button"
                                                                    class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                                                    data-line-no="@line.LineNo">
                                                                مسح
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                            </div>
                        </div>

                        @* =====================================================
                       6) ملخص الطلب
                       ===================================================== *@
                        @{
                            var lines = Model.Lines?.ToList() ?? new List<ERP.Models.PRLine>();

                            int totalLines = lines.Count;
                            int totalItems = lines.Select(l => l.ProdId).Distinct().Count();
                            int totalQty = lines.Sum(l => l.QtyRequested);

                            decimal totalRetail = lines.Sum(l => l.QtyRequested * l.PriceRetail);
                            decimal totalAfterDiscount = lines.Sum(l =>
                            l.QtyRequested * l.PriceRetail * (1m - (l.PurchaseDiscountPct / 100m))
                            );

                            // PurchaseRequest لا يحتوي على TaxTotal، نستخدم ExpectedItemsTotal
                            decimal expectedTotal = Model.ExpectedItemsTotal;
                            decimal taxAmount = 0m; // PurchaseRequest لا يحتوي على ضريبة
                            decimal totalAfterDiscountAndTax = totalAfterDiscount + taxAmount;
                            decimal netTotal = expectedTotal; // أو totalAfterDiscountAndTax حسب المتطلبات
                        }

                        <div class="card shadow-sm invoice-totals-card">
                            <div class="card-body">

                                <div class="d-flex flex-wrap align-items-center invoice-summary-row">
                                    <div class="invoice-summary-item">
                                        <span class="small text-muted d-block">عدد السطور</span>
                                        <span id="TotalLinesValue" class="badge bg-light text-dark invoice-summary-badge">@totalLines</span>
                                    </div>
                                    <div class="invoice-summary-item">
                                        <span class="small text-muted d-block">عدد الأصناف</span>
                                        <span id="TotalItemsValue" class="badge bg-light text-dark invoice-summary-badge">@totalItems</span>
                                    </div>
