                            });

                            // Enter/Arrow navigation
                            let isSaveButtonFocused = false; // متغير: هل زر الحفظ في حالة focus

                            custNameInput?.addEventListener('keydown', function (e) {
                                const isOpen = supplierDropdownList && supplierDropdownList.getAttribute('data-open') === 'true';

                                if (e.key === 'ArrowDown') {
                                    e.preventDefault();
                                    isSaveButtonFocused = false;

                                    if (!isOpen) openSupplierDropdown();
                                    const len = supplierDropdownSelectableSuppliers.length;
                                    if (len > 0) {
                                        const next = supplierDropdownHighlightedIndex < 0 ? 0 : Math.min(supplierDropdownHighlightedIndex + 1, len - 1);
                                        setSupplierDropdownHighlight(next);
                                    }
                                    return;
                                }

                                if (e.key === 'ArrowUp') {
                                    e.preventDefault();
                                    isSaveButtonFocused = false;

                                    if (!isOpen) openSupplierDropdown();
                                    const len = supplierDropdownSelectableSuppliers.length;
                                    if (len > 0) {
                                        const prev = supplierDropdownHighlightedIndex < 0 ? 0 : Math.max(supplierDropdownHighlightedIndex - 1, 0);
                                        setSupplierDropdownHighlight(prev);
                                    }
                                    return;
                                }

                                if (e.key === 'Enter') {
                                    e.preventDefault();

                                    if (isOpen && supplierDropdownHighlightedIndex >= 0 && supplierDropdownSelectableSuppliers.length > 0) {
                                        // أول Enter: اختيار عميل + إغلاق الدروب بدون تحريك زر الحفظ
                                        selectHighlightedSupplier(false);
                                        isSaveButtonFocused = false;
                                        return;
                                    }

                                    // الدروب مقفول: تعبئة من النص ثم سلوك زر الحفظ القديم
                                    fillSupplierFromOption(findSupplierByName(custNameInput.value));

                                    const saveBtn = document.getElementById('btnSaveInvoiceHeader');
                                    if (!saveBtn) return;

                                    if (!isSaveButtonFocused) {
                                        isSaveButtonFocused = true;
                                        saveBtn.focus();
                                    } else {
                                        isSaveButtonFocused = false;
                                        saveBtn.click();
                                    }
                                    return;
                                }

                                isSaveButtonFocused = false;
                            });

                            custNameInput?.addEventListener('blur', function () {
                                isSaveButtonFocused = false;
                                // تأخير بسيط عشان حدث click على عناصر الدروب يشتغل
                                setTimeout(function () {
                                    if (!isSelectingSupplier) closeSupplierDropdown();
                                }, 150);
                            });

                             // كود المورد: change + Enter
                             if (custCodeInput) {
                                 custCodeInput.addEventListener('change', () => {
                                     fillSupplierFromOption(findSupplierByCode(custCodeInput.value));
                                 });

                                 custCodeInput.addEventListener('keydown', (e) => {
                                     if (e.key === 'Enter') {
                                         e.preventDefault();
                                         fillSupplierFromOption(findSupplierByCode(custCodeInput.value));
                                     }
                                 });
                             }

                             // عند فتح طلبقديمة: CustomerId موجود → املأ البيانات
                             if (custHiddenId && custHiddenId.value) {
                                 fillSupplierFromOption(findSupplierByCode(custHiddenId.value));
                             }

                         }

                         initSupplierAutocompletePr();
                         window.__initSupplierAutocompletePr = initSupplierAutocompletePr;

                         // =========================================================
                         // (B) أوتوكومبليت الصنف + كارت بياناته + التابات + إضافة سطر
                         // =========================================================
                         function initProductSearch() {
                             console.log('🚀 بدء تحميل/إعادة تحميل كود الأصناف...');

                             // 1) عناصر سطر الصنف في الطلب
                             const prodCodeInput   = document.getElementById('ProdCodeInput');     // متغير: كود الصنف للبحث
                             const prodNameInput   = document.getElementById('ProdNameInput');     // متغير: اسم الصنف (أوتوكومبليت)
                             const prodPriceInput  = document.getElementById('ProdPriceInput');    // متغير: سعر الجمهور
                             const prodQtyInput    = document.getElementById('ProdQtyInput');      // متغير: الكمية
                             const prodDisc1Input  = document.getElementById('ProdDisc1Input');    // متغير: خصم الشراء %
                             const prodBatchInput  = document.getElementById('ProdBatchInput');    // متغير: الباتش
                             const prodExpiryInput = document.getElementById('ProdExpiryInput');   // متغير: تاريخ الصلاحية
                             const prodHiddenId    = document.getElementById('ProdId');            // متغير: المعرّف الداخلي للصنف
                             const btnAddLine      = document.getElementById('btnAddInvoiceLine'); // متغير: زر إضافة السطر

                             console.log('📋 العناصر:', {
                                 prodCodeInput: !!prodCodeInput,
                                 prodNameInput: !!prodNameInput,
                                 prodPriceInput: !!prodPriceInput,
                                 prodQtyInput: !!prodQtyInput,
                                 prodHiddenId: !!prodHiddenId,
                                 btnAddLine: !!btnAddLine
                             });

                             // 2) عناصر كارت بيانات الصنف
                             const prodQtyWarehouse = document.getElementById('ProdQtyCurrentWarehouse'); // متغير: كمية هذا المخزن
                             const prodQtyAll       = document.getElementById('ProdQtyAllWarehouses');   // متغير: إجمالي الكمية
                             const prodQuotaText    = document.getElementById('ProdQuotaText');          // متغير: هل له كوتة؟
                             const prodWeightedDisc = document.getElementById('ProdWeightedDiscount');   // متغير: الخصم المرجّح
                             const prodAltSelect    = document.getElementById('AlternativeProducts');    // متغير: قائمة البدائل

                            // 3) datalist الخاصة بالأصناف (مخفي كمصدر بيانات فقط)
                            const prodDataList = document.getElementById('productsList');

                             if (!prodDataList) {
                                 console.error('❌ لم يتم العثور على قائمة الأصناف (datalist) المرتبطة بـ ProdNameInput.');
                                 console.log('prodNameInput:', prodNameInput);
                                 console.log('prodNameInput.list:', prodNameInput?.list);
                                 // لا نخرج - نستمر في محاولة العمل بدون datalist
                             } else {
                                 console.log('✅ تم العثور على datalist، عدد الأصناف:', prodDataList.options.length);
                             }

                             // =========================================================
                             // دوال مساعدة — نفس فاتورة المبيعات (بحث متعدد كلمات + ترتيب + كود)
                             // =========================================================

                             function normalizeDigits(txt) {
                                 if (!txt) return '';
                                 const map = { '\u0660': '0', '\u0661': '1', '\u0662': '2', '\u0663': '3', '\u0664': '4',
                                     '\u0665': '5', '\u0666': '6', '\u0667': '7', '\u0668': '8', '\u0669': '9' };
                                 let out = '';
                                 for (let i = 0; i < txt.length; i++) {
                                     const c = txt[i];
                                     out += map[c] !== undefined ? map[c] : c;
                                 }
                                 return out;
                             }

                             function normalizeWord(w) {
                                 return normalizeDigits((w || '').trim().toLowerCase()).replace(/^[اأإآ]/u, '');
                             }

                             function normalizeText(txt) {
                                 return (txt || '')
                                     .trim()
                                     .toLowerCase()
                                     .split(/\s+/)
                                     .filter(Boolean)
                                     .map(function (w) { return normalizeWord(w); })
                                     .filter(Boolean)
                                     .join(' ')
                                     .replace(/\s+/g, ' ');
                             }

                             function wordMatchesQueryWord(nameWord, queryWord) {
                                 const nw0 = normalizeDigits((nameWord || '').trim().toLowerCase());
                                 const qw0 = normalizeDigits((queryWord || '').trim().toLowerCase());
                                 const nw = nw0.replace(/^[اأإآ]/u, '');
                                 const qw = qw0.replace(/^[اأإآ]/u, '');
                                 if (!qw) return true;
                                 return nw === qw || nw.startsWith(qw);
                             }

                             function productNameMatchesSearch(productName, rawSearch) {
                                 const raw = (rawSearch || '').trim();
                                 if (!raw) return true;
                                 const qWords = raw.split(/\s+/).filter(Boolean);
                                 const nWords = (productName || '').trim().split(/\s+/).filter(Boolean);
                                 if (qWords.length === 0) return true;
                                 return qWords.every(function (qw) {
                                     return nWords.some(function (nw) { return wordMatchesQueryWord(nw, qw); });
                                 });
                             }

                             function productSearchRank(name, rawSearch) {
                                 const raw = (rawSearch || '').trim();
                                 const nm = (name || '').trim();
                                 if (!raw) return 50;
                                 if (nm === raw) return 0;
                                 if (nm.startsWith(raw)) return 1;
                                 const rawWords = raw.split(/\s+/).filter(Boolean);
                                 const firstQ = rawWords[0] || '';
                                 const nmWords = nm.split(/\s+/).filter(Boolean);
                                 if (firstQ && nmWords.length) {
                                     if (nmWords[0].startsWith(firstQ)) return 2;
                                     const nw0 = normalizeDigits(nmWords[0].toLowerCase());
                                     const qw0 = normalizeDigits(firstQ.toLowerCase());
                                     const nw = nw0.replace(/^[اأإآ]/u, '');
                                     const qw = qw0.replace(/^[اأإآ]/u, '');
                                     if (qw && (nw === qw || nw.startsWith(qw))) return 3;
                                 }
                                 return 4;
                             }

                             function parseDecimalSafe(val) {
                                 const s = (val || '').toString().trim().replace(',', '.');
                                 const n = parseFloat(s);
                                 return isNaN(n) ? 0 : n;
                             }

                             function fmt2(val) {
                                 return parseDecimalSafe(val).toFixed(2);
                             }

                             function getProductDropdownFilterQuery(rawTrim) {
                                 const raw = (rawTrim || '').trim();
                                 if (!raw || !prodDataList || !prodDataList.options) return raw;
                                 const nRaw = normalizeText(raw);
                                 let canonical = '';
                                 const opts = prodDataList.options;
                                 for (let i = 0; i < opts.length; i++) {
                                     const v = (opts[i].value || '').trim();
                                     if (!v) continue;
                                     if (v === raw) { canonical = v; break; }
                                     if (nRaw && normalizeText(v) === nRaw) { canonical = v; break; }
                                 }
                                 if (!canonical) return raw;
                                 const parts = canonical.split(/\s+/).filter(Boolean);
                                 return parts[0] || raw;
                             }

                            // =========================================================
                            // دروب داون لاسم الصنف — نفس فاتورة المبيعات (حد 15 نتيجة)
                            // =========================================================
                            const PRODUCT_LIST_MAX_DEFAULT = 15;

                            const productDropdownWrap = document.getElementById('prProductDropdownWrap');
                            const productDropdownList = document.getElementById('prProductDropdownList');
                            const productDropdownArrow = document.getElementById('prProductDropdownArrow');

                            let productDropdownHighlightedIndex = -1;
                            let productDropdownSelectableProducts = [];
                            let productDropdownPendingMoveToQty = false;
                            let isSelectingProduct = false;

                            function positionProductDropdownList() {
                                if (!productDropdownList || !productDropdownWrap) return;
                                if (productDropdownList.getAttribute('data-open') !== 'true') return;

                                const r = productDropdownWrap.getBoundingClientRect();
                                const viewportH = window.innerHeight || document.documentElement.clientHeight || 0;
                                const safeGap = 6;
                                const defaultMax = 220;
                                const minVisible = 140;
                                const spaceBelow = Math.max(0, viewportH - r.bottom - safeGap);
                                const spaceAbove = Math.max(0, r.top - safeGap);

                                // اختَر الاتجاه الأكثر اتساعًا: أسفل الحقل أولًا، ثم أعلى الحقل إذا المساحة أقل.
                                const shouldOpenUp = spaceBelow < minVisible && spaceAbove > spaceBelow;
                                const available = shouldOpenUp ? spaceAbove : spaceBelow;
                                const dynamicMaxHeight = Math.max(80, Math.min(defaultMax, available));

                                productDropdownList.style.width = r.width + 'px';
                                productDropdownList.style.left = r.left + 'px';
                                productDropdownList.style.maxHeight = dynamicMaxHeight + 'px';
                                productDropdownList.style.top = shouldOpenUp
                                    ? Math.max(safeGap, (r.top - dynamicMaxHeight - 2)) + 'px'
                                    : (r.bottom + 2) + 'px';
                            }

                            function closeProductDropdown() {
                                if (productDropdownList) {
                                    productDropdownList.setAttribute('data-open', 'false');
                                    productDropdownList.innerHTML = '';
                                }
                                productDropdownHighlightedIndex = -1;
                                productDropdownSelectableProducts = [];
                            }

                            function setProductDropdownHighlight(idx) {
                                if (!productDropdownList) return;
                                if (idx < 0 || idx >= productDropdownSelectableProducts.length) return;

                                const children = productDropdownList.querySelectorAll('.product-dropdown-item');
                                children.forEach(function (el, i) {
                                    el.classList.toggle('product-dropdown-item-active', i === idx);
                                });
                                productDropdownHighlightedIndex = idx;

                                try {
                                    children[idx]?.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                                } catch { }
                            }

                            function getFilteredProductOptions(search, max, pinDisplayName) {
                                if (!prodDataList || !prodDataList.options) return [];
                                const limit = max || getInvoiceMaxItemsFromSettings() || PRODUCT_LIST_MAX_DEFAULT;
                                const opts = prodDataList.options;
                                const rawTrim = (search || '').trim();
                                if (!rawTrim) {
                                    const out = [];
                                    for (let i = 0; i < opts.length && out.length < limit; i++) out.push(opts[i]);
                                    return out;
                                }
                                const qNorm = normalizeText(rawTrim);
                                const words = rawTrim.split(/\s+/).filter(Boolean);
                                const matched = [];
                                for (let i = 0; i < opts.length; i++) {
                                    const opt = opts[i];
                                    const nameVal = (opt.value || '').trim();
                                    const code = (opt.getAttribute('data-code') || '').toString().trim();
                                    const idAttr = (opt.getAttribute('data-id') || '').toString().trim();
                                    const codeOrId = code || idAttr;
                                    const nameOk = qNorm ? productNameMatchesSearch(nameVal, rawTrim) : true;
                                    const idOk = words.length > 0 && words.some(function (w) { return codeOrId.indexOf(w) !== -1; });
                                    const codeRawOk = codeOrId && codeOrId.indexOf(rawTrim) !== -1;
                                    if (nameOk || idOk || codeRawOk) matched.push(opt);
                                }
                                matched.sort(function (a, b) {
                                    const ra = productSearchRank((a.value || '').trim(), rawTrim);
                                    const rb = productSearchRank((b.value || '').trim(), rawTrim);
                                    if (ra !== rb) return ra - rb;
                                    return (a.value || '').localeCompare(b.value || '', 'ar');
                                });
                                let result = matched.slice(0, limit);
                                const pinRaw = (pinDisplayName || '').trim();
                                if (pinRaw) {
                                    const nPin = normalizeText(pinRaw);
                                    let pinOpt = null;
                                    for (let j = 0; j < opts.length; j++) {
                                        const v = (opts[j].value || '').trim();
                                        if (v === pinRaw || (nPin && normalizeText(v) === nPin)) { pinOpt = opts[j]; break; }
                                    }
                                    if (pinOpt && matched.indexOf(pinOpt) >= 0) {
                                        const inResult = result.some(function (o) { return o === pinOpt; });
                                        if (!inResult) {
                                            result = matched.slice(0, limit - 1);
                                            result.push(pinOpt);
                                        }
                                    }
                                }
                                return result;
                            }

                            function openProductDropdown() {
                                if (!productDropdownList || !productDropdownWrap || !prodNameInput) return;

                                const searchTerm = (prodNameInput.value || '').trim();
                                const filterQuery = getProductDropdownFilterQuery(searchTerm);
                                const uiMax = getInvoiceMaxItemsFromSettings() || PRODUCT_LIST_MAX_DEFAULT;
                                const list = getFilteredProductOptions(filterQuery, uiMax, searchTerm);

                                productDropdownList.innerHTML = '';
                                productDropdownSelectableProducts = [];

                                let highlightIdx = 0;
                                const currentVal = (prodNameInput.value || '').trim();
                                if (list.length > 0) {
                                    for (let i = 0; i < list.length; i++) {
                                        if (normalizeText((list[i].value || '').trim()) === normalizeText(currentVal)) {
                                            highlightIdx = i;
                                            break;
                                        }
                                    }
                                }

                                if (!list.length) {
                                    const empty = document.createElement('div');
                                    empty.className = 'product-dropdown-item text-muted py-2 px-3 small';
                                    empty.textContent = searchTerm ? 'لا توجد نتائج' : ('اكتب للبحث ثم انزل بالسهم ▼ واختر (' + uiMax + ' كحد أقصى)');
                                    productDropdownList.appendChild(empty);
                                    productDropdownHighlightedIndex = -1;
                                } else {
                                    list.forEach(function (opt, idx) {
                                        const it = document.createElement('div');
                                        it.className = 'product-dropdown-item py-2 px-3' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                                        it.setAttribute('role', 'option');
                                        it.textContent = (opt.value || '').trim();
                                        it.addEventListener('click', function (ev) {
                                            ev.preventDefault();
                                            isSelectingProduct = true;
                                            prodNameInput.dataset.skipBlurEnter = '1';
                                            fillProductFromOption(opt, { skipCard: true });
                                            closeProductDropdown();
                                            productDropdownPendingMoveToQty = true;
                                            setTimeout(function () {
                                                delete prodNameInput.dataset.skipBlurEnter;
                                                isSelectingProduct = false;
                                            }, 400);
                                        });
                                        productDropdownList.appendChild(it);
                                        productDropdownSelectableProducts.push(opt);
                                    });
                                    productDropdownHighlightedIndex = highlightIdx;
                                }

                                productDropdownList.setAttribute('data-open', 'true');
                                positionProductDropdownList();
                            }

                            function selectHighlightedProduct(keepOpen) {
                                if (productDropdownHighlightedIndex < 0) return false;
                                if (productDropdownHighlightedIndex >= productDropdownSelectableProducts.length) return false;

                                const selectedOpt = productDropdownSelectableProducts[productDropdownHighlightedIndex];
                                if (!selectedOpt) return false;

                                isSelectingProduct = true;
                                prodNameInput.dataset.skipBlurEnter = '1';
                                fillProductFromOption(selectedOpt, { skipCard: true });

                                if (!keepOpen) closeProductDropdown();
                                productDropdownPendingMoveToQty = true;

                                setTimeout(function () {
                                    delete prodNameInput.dataset.skipBlurEnter;
                                    isSelectingProduct = false;
                                }, 400);
                                return true;
                            }

                            if (productDropdownArrow) {
                                productDropdownArrow.addEventListener('click', function (ev) {
                                    ev.preventDefault();
                                    prodNameInput?.focus();
                                    openProductDropdown();
                                });
                            }

                            // أثناء فتح القائمة: أي Scroll/Resize يعيد تموضعها أسفل خانة الصنف مباشرة
                            if (productDropdownWrap && !productDropdownWrap.dataset.boundReposition) {
                                productDropdownWrap.dataset.boundReposition = '1';
                                const repositionProductDropdown = function () {
                                    if (!productDropdownList) return;
                                    if (productDropdownList.getAttribute('data-open') === 'true') {
                                        positionProductDropdownList();
                                    }
                                };
                                window.addEventListener('scroll', repositionProductDropdown, true);
                                window.addEventListener('resize', repositionProductDropdown);
                                if (window.visualViewport) {
                                    window.visualViewport.addEventListener('resize', repositionProductDropdown);
                                    window.visualViewport.addEventListener('scroll', repositionProductDropdown);
                                }
                            }

                            // منع سكرول الصفحة عند تمرير عجلة الماوس داخل القائمة نفسها
                            if (productDropdownList && !productDropdownList.dataset.boundWheel) {
                                productDropdownList.dataset.boundWheel = '1';
                                productDropdownList.addEventListener('wheel', function (ev) {
                                    const target = ev.currentTarget;
                                    const delta = ev.deltaY || 0;
                                    if (delta === 0) return;

                                    const atTop = target.scrollTop <= 0;
                                    const atBottom = Math.ceil(target.scrollTop + target.clientHeight) >= target.scrollHeight;

                                    if ((delta < 0 && !atTop) || (delta > 0 && !atBottom)) {
                                        target.scrollTop += delta;
                                        ev.preventDefault();
                                    }
                                    ev.stopPropagation();
                                }, { passive: false });

                                let lastTouchY = 0;
                                productDropdownList.addEventListener('touchstart', function (ev) {
                                    if (!ev.touches || !ev.touches.length) return;
                                    lastTouchY = ev.touches[0].clientY;
                                }, { passive: true });

                                productDropdownList.addEventListener('touchmove', function (ev) {
                                    if (!ev.touches || !ev.touches.length) return;
                                    const target = ev.currentTarget;
                                    const currentY = ev.touches[0].clientY;
                                    const delta = lastTouchY - currentY;
                                    lastTouchY = currentY;

                                    const atTop = target.scrollTop <= 0;
                                    const atBottom = Math.ceil(target.scrollTop + target.clientHeight) >= target.scrollHeight;
                                    const tryingUp = delta < 0;
                                    const tryingDown = delta > 0;

                                    if ((tryingUp && atTop) || (tryingDown && atBottom)) {
                                        ev.preventDefault();
                                    }
                                    ev.stopPropagation();
                                }, { passive: false });
                            }

                            // إغلاق عند الضغط خارج البوكس (مرة واحدة)
                            if (productDropdownWrap && !productDropdownWrap.dataset.boundOutsideClick) {
                                productDropdownWrap.dataset.boundOutsideClick = '1';
                                document.body.addEventListener('click', function (ev) {
                                    if (!productDropdownWrap.contains(ev.target)) closeProductDropdown();
                                });
                            }

                             // =========================================================
                             // البحث عن صنف بالاسم / بالكود داخل datalist
                             // =========================================================

                             function findProductByName(name) {
                                 const raw = (name || '').trim();
                                 const search = normalizeText(raw);
                                 if (!search) return null;

                                 const opts = prodDataList.options;
                                 if (!opts || opts.length === 0) return null;

                                 for (let i = 0; i < opts.length; i++) {
                                     if (normalizeText(opts[i].value) === search) return opts[i];
                                 }
                                 for (let i = 0; i < opts.length; i++) {
                                     if ((opts[i].value || '').trim() === raw) return opts[i];
                                 }
                                 return null;
                             }

                             function findProductByCode(code) {
                                 const search = (code || '').toString().trim();
                                 if (!search) return null;

                                 const opts = prodDataList.options;
                                 for (let i = 0; i < opts.length; i++) {
                                     const idAttr   = (opts[i].getAttribute('data-id')   || '').toString();
                                     const codeAttr = (opts[i].getAttribute('data-code') || '').toString();
                                     if (idAttr === search || codeAttr === search) return opts[i];
                                 }
                                 return null;
                             }

                             // =========================================================
                             // تعبئة بيانات الصنف من <option>
                             // skipCard: true = تعبئة سطر الإضافة فقط (بدون كارت الصنف والبدائل والجداول) لتفادي إعادة تحميل مرئية
                             // =========================================================
                             function fillProductFromOption(opt, options) {
                                 const skipCard = options && options.skipCard === true;
                                 console.log('🔄 fillProductFromOption called with:', opt ? opt.value : 'null', skipCard ? '(سطر الإضافة فقط)' : '');

                                 if (!opt) {
                                     if (prodHiddenId)    prodHiddenId.value    = '';
                                     if (prodCodeInput)   prodCodeInput.value   = '';
                                     if (prodPriceInput)  prodPriceInput.value = '';
                                     if (!skipCard) {
                                         if (prodQuotaText)    prodQuotaText.value    = 'بدون كوتة';
                                         if (prodWeightedDisc) prodWeightedDisc.value = '0';
                                         if (prodQtyWarehouse) prodQtyWarehouse.value = '0';
                                         if (prodQtyAll)       prodQtyAll.value       = '0';
                                         if (prodAltSelect)    prodAltSelect.innerHTML = '<option value="">لا توجد بدائل</option>';
                                         clearProductDemandTables();
                                     }
                                     return;
                                 }

                                 const id       = opt.getAttribute('data-id')      || '';
                                 const code     = opt.getAttribute('data-code')    || id;
                                 const name     = opt.value                        || '';
                                 const generic  = opt.getAttribute('data-generic') || '';
                                 const hasQuota = (opt.getAttribute('data-hasquota') === 'true');
                                 let priceRaw   = (opt.getAttribute('data-price')   || '0').toString().replace(',', '.');
                                 let price      = parseFloat(priceRaw);
                                 if (isNaN(price)) price = 0;

                                 if (prodHiddenId)  prodHiddenId.value  = id;
                                 if (prodCodeInput) prodCodeInput.value = code;
                                 if (prodNameInput) prodNameInput.value = name;
                                 if (prodPriceInput) {
                                     prodPriceInput.value = price.toFixed(2);
                                     prodPriceInput.dispatchEvent(new Event('input', { bubbles: true }));
                                     prodPriceInput.dispatchEvent(new Event('change', { bubbles: true }));
                                 }

                                 if (skipCard) return;

                                 if (prodQuotaText)   prodQuotaText.value   = hasQuota ? 'له كوتة' : 'بدون كوتة';
                                 if (prodWeightedDisc) prodWeightedDisc.value = '0';
                                 if (prodQtyWarehouse) prodQtyWarehouse.value = '0';
                                 if (prodQtyAll)       prodQtyAll.value       = '0';
                                 if (prodAltSelect && generic) {
                                     loadAlternativeProducts(id);
                                 } else if (prodAltSelect) {
                                     prodAltSelect.innerHTML = '<option value="">لا توجد بدائل</option>';
                                 }
                                 if (id) {
                                     loadProductCardInfo(id);
                                     const currentPRId = parseInt(document.getElementById('InvoiceId')?.value || '0', 10) || 0;
                                     loadProductDemandInfo(id, currentPRId);
                                     const toEl = document.getElementById('SalesToDate');
                                     const fromEl = document.getElementById('SalesFromDate');
                                     if (toEl && fromEl) {
                                         const today = new Date();
                                         toEl.value = today.toISOString().slice(0, 10);
                                         const fromDate = new Date(today);
                                         fromDate.setMonth(fromDate.getMonth() - 1);
                                         fromEl.value = fromDate.toISOString().slice(0, 10);
                                         loadProductSalesInPeriod(id, fromEl.value, toEl.value);
                                     }
                                 } else {
                                     clearProductDemandTables();
                                 }
                             }

                             // =========================================================
                             // تحميل بيانات كارت الصنف (الكمية في المخزن، إجمالي الكمية، الخصم المرجح %)
                             // =========================================================
                             function loadProductCardInfo(prodId) {
                                 if (!prodId || (!prodQtyWarehouse && !prodQtyAll && !prodWeightedDisc)) return;
                                 var whId = (document.getElementById('WarehouseId') && document.getElementById('WarehouseId').value) ? document.getElementById('WarehouseId').value : '';
                                 var url = '@Url.Action("GetProductCardInfo", "PurchaseRequests")' + '?prodId=' + encodeURIComponent(prodId) + (whId ? '&warehouseId=' + encodeURIComponent(whId) : '');
                                 fetch(url)
                                     .then(function(r) { return r.ok ? r.json() : null; })
                                     .then(function(data) {
                                         if (data && data.ok) {
                                             if (prodQtyWarehouse) prodQtyWarehouse.value = (data.qtyInWarehouse != null) ? data.qtyInWarehouse : '0';
                                             if (prodQtyAll)       prodQtyAll.value       = (data.qtyAllWarehouses != null) ? data.qtyAllWarehouses : '0';
                                             if (prodWeightedDisc) prodWeightedDisc.value = (data.weightedDiscount != null) ? Number(data.weightedDiscount).toFixed(2) : '0';
                                         } else {
                                             if (prodQtyWarehouse) prodQtyWarehouse.value = '0';
                                             if (prodQtyAll)       prodQtyAll.value       = '0';
                                             if (prodWeightedDisc) prodWeightedDisc.value = '0';
                                         }
                                     })
                                     .catch(function() {
                                         if (prodQtyWarehouse) prodQtyWarehouse.value = '0';
                                         if (prodQtyAll)       prodQtyAll.value       = '0';
                                         if (prodWeightedDisc) prodWeightedDisc.value = '0';
                                     });
                             }

                             // =========================================================
                             // تحميل بيانات المطلوب والكمية المباعة والوسيط
                             // =========================================================
                             function loadProductDemandInfo(prodId, currentPRId) {
                                 if (!prodId) {
                                     clearProductDemandTables();
                                     return;
                                 }
                                 currentPRId = currentPRId || 0;
                                 const url = '@Url.Action("GetProductDemandInfo", "PurchaseRequests")'
                                     + '?prodId=' + encodeURIComponent(prodId)
                                     + '&currentPRId=' + encodeURIComponent(currentPRId);

                                 const requiredTableBody = document.getElementById('RequiredTableBody');

                                 if (requiredTableBody) requiredTableBody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">... جاري التحميل</td></tr>';

                                 fetch(url)
                                     .then(r => r.ok ? r.json() : null)
                                     .then(data => {
                                         if (data && data.ok) {
                                             // تحديث جدول المطلوب
                                             if (requiredTableBody) {
                                                 if (data.required && data.required.length > 0) {
                                                     requiredTableBody.innerHTML = data.required.map(item => {
                                                         const date = new Date(item.date);
                                                         const dateStr = date.toLocaleDateString('ar-EG', { year: 'numeric', month: '2-digit', day: '2-digit' });
                                                         return `<tr>
                                                             <td>${item.customerName || ''}</td>
                                                             <td class="text-center">${dateStr}</td>
                                                             <td class="text-center">${item.qty || 0}</td>
                                                             <td class="text-center">${(item.weightedDiscount || 0).toFixed(2)}</td>
                                                         </tr>`;
                                                     }).join('');
                                                 } else {
                                                     requiredTableBody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">لا توجد بيانات</td></tr>';
                                                 }
                                             }
                                             // جدول المبيعات يُحمّل من loadProductSalesInPeriod حسب التاريخ من/إلى
                                             const prodIdForSales = parseInt(document.getElementById('ProdId')?.value || '0', 10);
                                             const fromD = document.getElementById('SalesFromDate')?.value || '';
                                             const toD = document.getElementById('SalesToDate')?.value || '';
                                             if (prodIdForSales) loadProductSalesInPeriod(prodIdForSales, fromD, toD);
                                         } else {
                                             clearProductDemandTables();
                                         }
                                     })
                                     .catch(err => {
                                         console.error('❌ خطأ في تحميل بيانات المطلوب والكمية المباعة والوسيط:', err);
                                         clearProductDemandTables();
                                     });
                             }

                             function clearProductDemandTables() {
                                 const requiredTableBody = document.getElementById('RequiredTableBody');
                                 const salesIntermediaryTableBody = document.getElementById('SalesIntermediaryTableBody');

                                 if (requiredTableBody) requiredTableBody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">لا توجد بيانات</td></tr>';
                                 if (salesIntermediaryTableBody) salesIntermediaryTableBody.innerHTML = '<tr><td colspan="2" class="text-center text-muted small">لا توجد بيانات</td></tr>';
                             }

                             // تحميل إجمالي الكمية المبيعة والوسيط للصنف في الفترة (من - إلى)
                             function loadProductSalesInPeriod(prodId, fromDate, toDate) {
                                 const salesIntermediaryTableBody = document.getElementById('SalesIntermediaryTableBody');
                                 if (!salesIntermediaryTableBody) return;
                                 if (!prodId) {
                                     salesIntermediaryTableBody.innerHTML = '<tr><td colspan="2" class="text-center text-muted small">لا توجد بيانات</td></tr>';
                                     return;
                                 }
                                 const url = '@Url.Action("GetProductSalesInPeriod", "PurchaseRequests")'
                                     + '?prodId=' + encodeURIComponent(prodId)
                                     + '&fromDate=' + encodeURIComponent(fromDate || '')
                                     + '&toDate=' + encodeURIComponent(toDate || '');
                                 salesIntermediaryTableBody.innerHTML = '<tr><td colspan="2" class="text-center text-muted small">... جاري التحميل</td></tr>';
                                 fetch(url)
                                     .then(r => r.ok ? r.json() : null)
                                     .then(data => {
                                         if (data && data.ok) {
                                             const totalQty = data.totalQty || 0;
                                             const medianQty = Number(data.medianQty || 0).toFixed(1);
                                             salesIntermediaryTableBody.innerHTML = '<tr><td class="text-center small">' + totalQty + '</td><td class="text-center small">' + medianQty + '</td></tr>';
                                         } else {
                                             salesIntermediaryTableBody.innerHTML = '<tr><td colspan="2" class="text-center text-muted small">لا توجد بيانات</td></tr>';
                                         }
                                     })
                                     .catch(function () {
                                         salesIntermediaryTableBody.innerHTML = '<tr><td colspan="2" class="text-center text-muted small">لا توجد بيانات</td></tr>';
                                     });
                             }

                             // الجدول يتحدث تلقائياً عند تغيير التاريخ (من/إلى) أو الصنف
                             (function () {
                                 const salesFromEl = document.getElementById('SalesFromDate');
                                 const salesToEl = document.getElementById('SalesToDate');
                                 function refreshSalesTable() {
                                     const prodId = parseInt(document.getElementById('ProdId')?.value || '0', 10);
                                     if (!prodId) return;
                                     loadProductSalesInPeriod(prodId, salesFromEl?.value || '', salesToEl?.value || '');
                                 }
                                 if (salesFromEl) salesFromEl.addEventListener('change', refreshSalesTable);
                                 if (salesToEl) salesToEl.addEventListener('change', refreshSalesTable);
                             })();

                             // =========================================================
                             // تحميل البدائل من الكنترولر
                             // =========================================================
                             function loadAlternativeProducts(prodId) {
                                 if (!prodId || !prodAltSelect) return;

                                 const url = '@Url.Action("GetAlternativeProducts", "PurchaseRequests")'
                                     + '?prodId=' + encodeURIComponent(prodId);

                                 prodAltSelect.innerHTML = '<option value="">... جاري تحميل البدائل</option>';

                                 fetch(url)
                                     .then(r => r.ok ? r.json() : [])
                                     .then(data => {
                                         prodAltSelect.innerHTML = '<option value="">اختر بديلاً (للمشاهدة فقط)</option>';

                                         if (!data || !data.length) {
                                             prodAltSelect.innerHTML += '<option value="">لا توجد بدائل</option>';
                                             return;
                                         }

                                         data.forEach(p => {
                                             const op = document.createElement('option');
                                             op.value = p.id;
                                             op.textContent = `${p.name || ''} — ${p.company || ''} — ${p.price || 0}`;
                                             op.setAttribute('data-id', p.id);
                                             op.setAttribute('data-price', p.price || 0);
                                             prodAltSelect.appendChild(op);
                                         });
                                     })
                                     .catch(err => {
                                         console.error('❌ خطأ في تحميل بدائل الصنف:', err);
                                         prodAltSelect.innerHTML = '<option value="">خطأ في تحميل البدائل</option>';
                                     });
                             }

                             // =========================================================
                             // Events: اسم الصنف / كود الصنف
                             // =========================================================
                             if (prodNameInput) {
                                 console.log('✅ تم ربط event listeners لحقل اسم الصنف');

                                // فتح الدروب داون عند الكتابة فقط — لا تفتح عند التعبئة من جدول السطور (مثل فاتورة المبيعات)
                                prodNameInput.addEventListener('input', function () {
                                    if (this.dataset.skipBlurEnter === '1') return;
                                    if (isSelectingProduct) return;
                                    if (window.suppressProductDropdownOnce) {
                                        window.suppressProductDropdownOnce = false;
                                        closeProductDropdown();
                                        return;
                                    }
                                    productDropdownPendingMoveToQty = false;
                                    openProductDropdown();
                                });

                                // فتح + تنقل داخل الدروب داون بالأسهم
                                prodNameInput.addEventListener('keydown', function (e) {
                                    if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;

                                    e.preventDefault();
                                    productDropdownPendingMoveToQty = false;

                                    const isOpen = productDropdownList && productDropdownList.getAttribute('data-open') === 'true';
                                    if (!isOpen) openProductDropdown();

                                    const len = productDropdownSelectableProducts.length;
                                    if (!len) return;

                                    if (e.key === 'ArrowDown') {
                                        const next = productDropdownHighlightedIndex < 0 ? 0 : Math.min(productDropdownHighlightedIndex + 1, len - 1);
                                        setProductDropdownHighlight(next);
                                    } else {
                                        const prev = productDropdownHighlightedIndex < 0 ? 0 : Math.max(productDropdownHighlightedIndex - 1, 0);
                                        setProductDropdownHighlight(prev);
                                    }
                                });

                                 prodNameInput.addEventListener('change', function (e) {
                                     if (this.dataset.skipBlurEnter === '1') return;
                                     try {
                                         const found = findProductByName(this.value);
                                         fillProductFromOption(found);
                                     } catch (err) {
                                         console.error('❌ خطأ في change event:', err);
                                     }
                                 });

                                prodNameInput.addEventListener('blur', function () {
                                    if (this.dataset.skipBlurEnter === '1') return;
                                    productDropdownPendingMoveToQty = false;

                                    setTimeout(function () {
                                        try {
                                            const found = findProductByName(prodNameInput.value);
                                            if (found) fillProductFromOption(found);
                                        } catch (err) {
                                            console.error('❌ خطأ في blur event:', err);
                                        }

                                        if (productDropdownWrap && !productDropdownWrap.contains(document.activeElement)) {
                                            closeProductDropdown();
                                        }
                                    }, 150);
                                });
                             } else {
                                 console.error('❌ prodNameInput غير موجود!');
                             }

                             if (prodCodeInput) {
                                 prodCodeInput.addEventListener('change', function () {
                                     const found = findProductByCode(this.value);
                                     fillProductFromOption(found);
                                 });
                                 prodCodeInput.addEventListener('blur', function () {
                                     const found = findProductByCode(this.value);
                                     fillProductFromOption(found);
                                 });
                             }

                             // تنسيق تاريخ الصلاحية عند الخروج من الحقل (شهر+سنة بدون شرطة -> شهر/سنة)
                             if (prodExpiryInput && typeof formatExpiryWithSlash === 'function') {
                                 prodExpiryInput.addEventListener('blur', function () {
                                     if (this.value) this.value = formatExpiryWithSlash(this.value);
                                 });
                             }

                             // =========================================================
                             // قفل / فتح سعر الجمهور (بالضغط على اللابل)
                             // =========================================================
                             const priceLabel     = document.getElementById('ProdPriceLabel');       // متغير: Label السعر
                             const priceLockState = document.getElementById('ProdPriceLockState');   // متغير: (مغلق/مفتوح)
                             let priceLocked = true; // متغير: حالة قفل السعر

                             function applyPriceLockUI() {
                                 if (!prodPriceInput) return;

                                 prodPriceInput.readOnly = priceLocked;

                                 if (priceLocked) {
                                     prodPriceInput.classList.add('bg-light', 'text-muted');
                                     if (priceLockState) priceLockState.textContent = '(مغلق)';
                                 } else {
                                     prodPriceInput.classList.remove('bg-light', 'text-muted');
                                     if (priceLockState) priceLockState.textContent = '(مفتوح)';
                                 }
                             }

                             applyPriceLockUI();

                             if (priceLabel) {
                                 priceLabel.style.cursor = 'pointer';
                                 priceLabel.addEventListener('click', function () {
                                     priceLocked = !priceLocked;
                                     applyPriceLockUI();
                                 });
                             }

                             // =========================================================
                             // قفل / فتح خصم الشراء (بالضغط على اللابل)
                             // =========================================================
                             const disc1Label     = document.getElementById('ProdDisc1Label');      // متغير: Label الخصم
                             const disc1LockState = document.getElementById('ProdDisc1LockState');  // متغير: (مغلق/مفتوح)
                             let disc1Locked = false; // متغير: حالة قفل الخصم

                             function applyDisc1LockUI() {
                                 if (!prodDisc1Input) return;

                                 prodDisc1Input.readOnly = disc1Locked;

                                 if (disc1Locked) {
                                     prodDisc1Input.classList.add('bg-light', 'text-muted');
                                     if (disc1LockState) disc1LockState.textContent = '(مغلق)';
                                 } else {
                                     prodDisc1Input.classList.remove('bg-light', 'text-muted');
                                     if (disc1LockState) disc1LockState.textContent = '(مفتوح)';
                                 }
                             }

                             applyDisc1LockUI();

                             if (disc1Label) {
                                 disc1Label.style.cursor = 'pointer';
                                 disc1Label.addEventListener('click', function () {
                                     disc1Locked = !disc1Locked;
                                     applyDisc1LockUI();
                                 });
                             }

                             // =========================================================
                             // التنقل بالإنتر (داخل كارت إضافة الصنف)
                             // =========================================================
                             const lineInputs = [
                                 prodCodeInput,
                                 prodNameInput,
                                 prodPriceInput,
                                 prodQtyInput,
                                 prodDisc1Input,
                                 prodBatchInput,
                                 prodExpiryInput
                             ].filter(Boolean);

                             lineInputs.forEach((input, index) => {

                                 // أول ما يدخل الفوكس → تحديد النص
                                 input.addEventListener('focus', function () {
                                     if (typeof this.select === 'function') {
                                         setTimeout(() => this.select(), 0);
                                     }
                                 });

                                 // Enter → يروح للحقل اللي بعده
                                 input.addEventListener('keydown', function (e) {
                                     if (e.key !== 'Enter') return;

                                     e.preventDefault();
                                     console.log('⌨️ Enter pressed on:', input.id || input.className);

                                     try {
                                         // تخطي الحقول المقفلة (مثل السعر) — تحديد الحقل التالي أولاً (مثل سلوك اسم المورد)
                                         let nextIndex = index + 1;
                                         let next = null;
                                         while (nextIndex < lineInputs.length) {
                                             const cand = lineInputs[nextIndex];
                                             if (cand && !cand.readOnly) { next = cand; break; }
                                             nextIndex++;
                                         }

                                         function moveToNext() {
                                             if (next) {
                                                 next.focus();
                                                 if (typeof next.select === 'function') next.select();
                                             } else if (btnAddLine) {
                                                 btnAddLine.focus();
                                             }
                                         }

                                        // اسم الصنف: 1st Enter يختار ويقفل الدروب (بدون نقل تركيز)،
                                        // 2nd Enter ينقل التركيز إلى حقل الكمية
                                        if (input === prodNameInput) {
                                            if (productDropdownPendingMoveToQty) {
                                                productDropdownPendingMoveToQty = false;
                                                moveToNext();
                                                return;
                                            }

                                            const isOpen = productDropdownList && productDropdownList.getAttribute('data-open') === 'true';
                                            let optToSelect = null;

                                            if (isOpen && productDropdownHighlightedIndex >= 0 && productDropdownSelectableProducts.length > 0) {
                                                optToSelect = productDropdownSelectableProducts[productDropdownHighlightedIndex];
                                            } else {
                                                optToSelect = findProductByName(prodNameInput.value);
                                            }

                                            // لو مفيش تطابق: سلوك قديم (تنقل للكمية بدون اختيار)
                                            if (!optToSelect) {
                                                closeProductDropdown();
                                                moveToNext();
                                                return;
                                            }

                                            prodNameInput.dataset.skipBlurEnter = '1';
                                            setTimeout(function () { delete prodNameInput.dataset.skipBlurEnter; }, 400);

                                            fillProductFromOption(optToSelect, { skipCard: true });
                                            closeProductDropdown();

                                            productDropdownPendingMoveToQty = true;
                                            return;
                                        }

                                         if (input === prodCodeInput) {
                                             const found = findProductByCode(prodCodeInput.value);
                                             fillProductFromOption(found);
                                         }

                                         moveToNext();
                                     } catch (err) {
                                         console.error('❌ خطأ في معالجة Enter:', err);
                                     }
                                 });
                             });

                             // زر الإضافة: Enter يعمل Click
                             if (btnAddLine) {
                                 btnAddLine.addEventListener('keydown', function (e) {
                                     if (e.key === 'Enter') {
                                         e.preventDefault();
                                         btnAddLine.click();
                                     }
                                 });
                             }








                         // ===============================
                         // رسم جدول السطور (هجين)
                         // - لو الصنف غير مكرر: سطر واحد + بيانات
                         // - لو الصنف مكرر (تشغيلات): سطر عنوان للصنف + سطور تشغيلات
                         // ===============================
                         function renderGroupedLines(lines) {

                             // متغير: tbody الخاص بجدول السطور
                             const tbody = document.getElementById('PILinesTbody');
                             if (!tbody) return;

                             // تفريغ الجدول قبل الرسم
                             tbody.innerHTML = '';

                             if (!Array.isArray(lines) || lines.length === 0) {
                                 return;
                             }

                             // ===============================
                             // 1) تجميع السطور حسب prodId + prodName
                             // ===============================
                             const map = new Map(); // متغير: Map لتجميع السطور

                             lines.forEach(l => {
                                 const prodId = Number(l.prodId || 0); // متغير: كود الصنف
                                 const prodName = (l.prodName || (`صنف #${prodId}`)).toString(); // متغير: اسم الصنف
                                 const key = `${prodId}||${prodName}`; // متغير: مفتاح التجميع

                                 if (!map.has(key)) {
                                     map.set(key, { prodId, prodName, lines: [] });
                                 }
                                 map.get(key).lines.push(l);
                             });

                             // ترتيب المجموعات حسب الإعدادات (مثل فاتورة المبيعات)
                             const sortMode = getInvoiceSortModeFromSettings();
                             const minLineNo = (group) => {
                                 const arr = Array.isArray(group?.lines) ? group.lines : [];
                                 if (!arr.length) return Number.MAX_SAFE_INTEGER;
                                 return arr.reduce((min, x) => {
                                     const v = Number(x?.lineNo || 0);
                                     if (!Number.isFinite(v) || v <= 0) return min;
                                     return Math.min(min, v);
                                 }, Number.MAX_SAFE_INTEGER);
                             };

                             const groups = Array.from(map.values());
                             if (sortMode === 'auto') {
                                 groups.sort((a, b) => minLineNo(a) - minLineNo(b));
                             } else {
                                 groups.sort((a, b) => (a.prodName || '').localeCompare(b.prodName || '', 'ar'));
                             }

                             // ===============================
                             // 2) رسم كل مجموعة حسب عدد التشغيلات
                             // ===============================
                             groups.forEach(g => {

                                 // ترتيب تشغيلات الصنف حسب lineNo
                                 const sortedLines = (g.lines || [])
                                     .slice()
                                     .sort((x, y) => (Number(x.lineNo || 0) - Number(y.lineNo || 0)));

                                 const isMultiBatch = sortedLines.length > 1; // متغير: هل الصنف له أكثر من تشغيلة؟

                                 // =========================================================
                                 // الحالة (1): الصنف غير مكرر => سطر واحد فقط (اسم + بيانات + مسح)
                                 // =========================================================
                                 if (!isMultiBatch) {

                                     const line = sortedLines[0];

                                     const lineNo = line.lineNo ?? ''; // متغير: رقم السطر
                                     const batchNo = line.preferredBatchNo ?? line.batchNo ?? ''; // متغير: التشغيلة

                                     const expiryText = line.preferredExpiry 
                                         ? formatDateYMD(line.preferredExpiry)
                                         : (line.expiryText 
                                             ? line.expiryText 
                                             : (line.expiry ? formatDateYMD(line.expiry) : '')); // متغير: الصلاحية

                                     const qty = Number(line.qty || line.qtyRequested || 0); // متغير: الكمية
                                     const priceRetail = Number(line.priceRetail || 0); // متغير: سعر الجمهور

                                     const discPct = (line.purchaseDiscountPct != null)
                                         ? Number(line.purchaseDiscountPct)
                                         : Number(line.discPct || 0); // متغير: الخصم %

                                     const lineValue = (line.lineValue != null)
                                         ? Number(line.lineValue)
                                         : (qty * priceRetail * (1 - (discPct / 100))); // متغير: قيمة السطر

                                     const tr = document.createElement('tr');
                                     tr.setAttribute('data-line-no', lineNo);
                                     tr.setAttribute('data-prodid', g.prodId);

