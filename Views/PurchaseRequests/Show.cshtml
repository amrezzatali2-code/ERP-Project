                                                    data-line-no="${lineNo}"
                                                    data-prod-id="${g.prodId}"
                                                    value="${escapeHtml(batchNo)}" 
                                                    placeholder="التشغيلة"
                                                    autocomplete="off"
                                                    style="min-width: 100px;" />
                                         </td>
                                         <td class="text-center">
                                             <input type="text" 
