                                         showToast("فشل التحويل: " + (err.message || "خطأ غير معروف"), "danger");
                                         console.error('❌ خطأ في التحويل:', err);
                                     }
                                 });

                                 console.log('✅ تم ربط event listener لزر التحويل');
                             } // نهاية دالة initPostInvoice

                             // ✅ تنفيذ الدالة عند تحميل الصفحة
                             if (document.readyState === 'loading') {
