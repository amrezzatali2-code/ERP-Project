                                 (function () {

                             // =========================================================
                             // ✅ Guard: يمنع تركيب نفس السكربت أكثر من مرة — علم خاص بطلب الشراء فقط
                             // (لا تستخدم __PI_NAV_SCRIPT_LOADED__: مشترك مع فاتورة المشتريات/المبيعات ويمنع تهيئة هذه الصفحة)
