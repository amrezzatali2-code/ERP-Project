                             // =========================================================
                             // ثابت: تطبيق القفل على أي عنصر عليه data-lock-posted="1"
                             // =========================================================
                             function applyPostedUiLock() {

                                 const posted = isInvoicePosted(); // متغير: هل الطلب مُرحّلة؟
                                 const lockables = document.querySelectorAll('[data-lock-posted="1"]'); // متغير: العناصر المطلوب قفلها

                                 lockables.forEach(el => {

                                     // حفظ الحالة الأصلية مرة واحدة
                                     if (el.dataset.lockInit !== "1") {
                                         el.dataset.lockInit = "1";
                                         el.dataset.origDisabled = el.disabled ? "1" : "0";           // متغير: disabled الأصلي
                                         el.dataset.origReadonly = el.readOnly ? "1" : "0";           // متغير: readonly الأصلي
                                         el.dataset.origTabIndex = el.getAttribute("tabindex") ?? ""; // متغير: tabindex الأصلي
                                     }

                                     const tag = (el.tagName || "").toUpperCase(); // متغير: نوع العنصر

                                     // -------------------------
                                     // حالة: مُرحّلة (قفل)
                                     // -------------------------
                                     if (posted) {

                                         if (tag === "BUTTON") {
                                             el.disabled = true;
                                             return;
                                         }

                                         if (tag === "A") {
                                             el.classList.add("disabled", "pe-none");
                                             el.setAttribute("aria-disabled", "true");
                                             el.setAttribute("tabindex", "-1");
                                             return;
                                         }

                                         if (tag === "INPUT" || tag === "TEXTAREA") {
                                             el.readOnly = true;
                                             el.classList.add("bg-light", "text-muted");
                                             return;
                                         }

                                         if (tag === "SELECT") {
                                             el.disabled = true;
                                             return;
                                         }

                                         return;
                                     }

                                     // -------------------------
                                     // حالة: مفتوحة (ارجاع الأصل)
                                     // -------------------------
                                     const origDisabled = el.dataset.origDisabled === "1";
                                     const origReadonly = el.dataset.origReadonly === "1";
                                     const origTabIndex = el.dataset.origTabIndex;

                                     if (tag === "BUTTON") {
                                         el.disabled = origDisabled;
                                         return;
                                     }

                                     if (tag === "A") {
                                         el.classList.remove("disabled", "pe-none");
                                         el.removeAttribute("aria-disabled");
                                         if (origTabIndex === "") el.removeAttribute("tabindex");
                                         else el.setAttribute("tabindex", origTabIndex);
                                         return;
                                     }

                                     if (tag === "INPUT" || tag === "TEXTAREA") {
                                         el.readOnly = origReadonly;
                                         el.classList.remove("bg-light", "text-muted");
                                         return;
                                     }

                                     if (tag === "SELECT") {
                                         el.disabled = origDisabled;
                                         return;
                                     }
                                 });

                                 // قفل حقول السطور (التشغيلة، الصلاحية، الكمية، الخصم) عند الترحيل — تُنشأ ديناميكياً فلا تحتوي data-lock-posted
                                 document.querySelectorAll('.editable-line-field').forEach(el => {
                                     if (posted) {
                                         el.readOnly = true;
                                         el.classList.add("bg-light", "text-muted");
                                     } else {
                                         el.readOnly = false;
                                         el.classList.remove("bg-light", "text-muted");
                                     }
                                 });
                             }

