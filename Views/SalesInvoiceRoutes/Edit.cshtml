@model ERP.Controllers.SalesInvoiceRouteEditVm
@{
    ViewData["Title"] = "تعديل بيانات خط السير — فاتورة " + Model.SIId;
}
<div class="container" dir="rtl">
    <h2 class="mb-3">تعديل بيانات خط السير — فاتورة @Model.SIId</h2>
    <p class="text-muted">التاريخ: @Model.SIDate.ToString("yyyy-MM-dd") | العميل: @Model.CustomerName | خط السير: @Model.RouteName | المخزن: @Model.WarehouseName</p>

    <form asp-action="Edit" method="post" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="SIId" />
        <div class="col-md-2">
            <label asp-for="BagsCount" class="form-label">عدد الشنط</label>
            <input asp-for="BagsCount" class="form-control" type="number" min="0" />
        </div>
        <div class="col-md-2">
            <label asp-for="PacketsCount" class="form-label">عدد البواكي</label>
            <input asp-for="PacketsCount" class="form-control" type="number" min="0" />
        </div>
        <div class="col-md-2">
            <label asp-for="CartonsCount" class="form-label">عدد الكراتين</label>
            <input asp-for="CartonsCount" class="form-control" type="number" min="0" />
        </div>
        <div class="col-md-2">
            <label asp-for="FridgeItemsCount" class="form-label">أصناف الثلاجة</label>
            <input asp-for="FridgeItemsCount" class="form-control" type="number" min="0" />
        </div>
        <div class="col-md-2">
            <label asp-for="FridgeBoxesCount" class="form-label">علب الثلاجة</label>
            <input asp-for="FridgeBoxesCount" class="form-control" type="number" min="0" />
        </div>
        <div class="col-12">
            <label asp-for="Notes" class="form-label">ملاحظات</label>
            <textarea asp-for="Notes" class="form-control" rows="2" maxlength="500"></textarea>
        </div>
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">حفظ</button>
            <a class="btn btn-secondary" asp-action="Index">إلغاء</a>
            <a class="btn btn-outline-secondary" asp-controller="SalesInvoices" asp-action="Show" asp-route-id="@Model.SIId">عرض الفاتورة</a>
        </div>
    </form>
</div>
