@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.Area>

@{
    ViewData["Title"] = "المناطق";

    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "Areas";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "name";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "name";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    // نطاق العرض السفلي
    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;
    int? governorateId = ViewBag.GovFilter as int?;
    int? districtId = ViewBag.DistrictFilter as int?;
    var dateField = (string?)ViewBag.DateField ?? "created";

    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_name = ViewBag.FilterCol_Name as string;
    string? filterCol_dist = ViewBag.FilterCol_Dist as string;
    string? filterCol_gov = ViewBag.FilterCol_Gov as string;
    string? filterCol_isactive = ViewBag.FilterCol_IsActive as string;
    string? filterCol_created = ViewBag.FilterCol_Created as string;
    string? filterCol_updated = ViewBag.FilterCol_Updated as string;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField,
        fromCode,
        toCode,
        governorateId,
        districtId,
        filterCol_id,
        filterCol_name,
        filterCol_dist,
        filterCol_gov,
        filterCol_isactive,
        filterCol_created,
        filterCol_updated
    })!;

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = colKey == "id" ? filterCol_id : colKey == "name" ? filterCol_name : colKey == "dist" ? filterCol_dist : colKey == "gov" ? filterCol_gov : colKey == "isactive" ? filterCol_isactive : colKey == "created" ? filterCol_created : colKey == "updated" ? filterCol_updated : null;
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"" style=""position:relative;z-index:2;"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor""><path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/><path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/></svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    @* ===== شريط الفلاتر الموحد ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث العام --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في المناطق</label>
                    <div class="d-flex flex-wrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:150px">
                            <option value="all"@Html.Raw(searchBy == "all" ? " selected" : "")>البحث في الكل</option>
                            <option value="name"@Html.Raw(searchBy == "name" ? " selected" : "")>اسم المنطقة</option>
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>كود المنطقة</option>
                            <option value="governorate"@Html.Raw(searchBy == "governorate" ? " selected" : "")>المحافظة</option>
                            <option value="district"@Html.Raw(searchBy == "district" ? " selected" : "")>الحي/المركز</option>
                            <option value="created"@Html.Raw(searchBy == "created" ? " selected" : "")>تاريخ الإنشاء</option>
                            <option value="updated"@Html.Raw(searchBy == "updated" ? " selected" : "")>آخر تعديل</option>
                        </select>
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                    @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
                    @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
                    <input type="hidden" name="dateField" value="@dateField" />
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (governorateId.HasValue) { <input type="hidden" name="governorateId" value="@governorateId" /> }
                    @if (districtId.HasValue) { <input type="hidden" name="districtId" value="@districtId" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_dist)) { <input type="hidden" name="filterCol_dist" value="@filterCol_dist" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_gov)) { <input type="hidden" name="filterCol_gov" value="@filterCol_gov" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_isactive)) { <input type="hidden" name="filterCol_isactive" value="@filterCol_isactive" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر الكود --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">فلتر الكود</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <a class="btn btn-erp btn-erp-success btn-erp-sm" asp-action="Create">إضافة منطقة</a>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalArea">اختيار الأعمدة</button>
                        <button type="button" id="btnEditArea" class="btn btn-erp btn-erp-primary btn-erp-sm" disabled>تعديل</button>
                        <button type="button" id="btnPrintArea" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnBulkDelete">حذف المحدد</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف الجميع</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="Areas" class="d-inline-flex flex-nowrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                            @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
                            @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
                            <input type="hidden" name="dateField" value="@dateField" />
                            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                            @if (governorateId.HasValue) { <input type="hidden" name="governorateId" value="@governorateId" /> }
                            @if (districtId.HasValue) { <input type="hidden" name="districtId" value="@districtId" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_dist)) { <input type="hidden" name="filterCol_dist" value="@filterCol_dist" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_gov)) { <input type="hidden" name="filterCol_gov" value="@filterCol_gov" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_isactive)) { <input type="hidden" name="filterCol_isactive" value="@filterCol_isactive" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:70px;min-width:70px;font-size:0.8rem;padding:0.25rem 0.4rem;">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                    <form id="formBulkDelete" asp-action="BulkDelete" asp-controller="Areas" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="selectedIds" id="bulkDeleteIdsInput" />
                    </form>
                    <form id="formDeleteAll" asp-action="DeleteAll" asp-controller="Areas" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>

        </div>
    </div>

    @* ===== جدول المناطق (حاوية تمرير + رأس ثابت + فلتر أعمدة + توسعة) ===== *@
    <div class="erp-table-scroll-container mt-3 ps-0 pe-0" dir="rtl">
        <div id="areaTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
        <table id="areaTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                <tr>
                    <th class="text-center no-print" data-col="select" data-col-fixed="true" style="width:42px; min-width:42px;">
                        <input type="checkbox" id="selectAll" class="form-check-input" aria-label="تحديد الكل" />
                    </th>
                    <th data-col="id">@filterableCol("id", "id", "كود المنطقة")</th>
                    <th data-col="name">@filterableCol("name", "name", "اسم المنطقة")</th>
                    <th data-col="district">@filterableCol("dist", "dist", "الحي/المركز")</th>
                    <th data-col="gov">@filterableCol("gov", "gov", "المحافظة")</th>
                    <th data-col="isactive">@filterableCol("isactive", "isactive", "الحالة")</th>
                    <th data-col="created">@filterableCol("created", "created", "تاريخ الإنشاء")</th>
                    <th data-col="updated">@filterableCol("updated", "updated", "آخر تعديل")</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var a in Model.Items)
                    {
                        var editUrl = (Url.Action("Edit", "Areas", new { id = a.AreaId }) ?? "#") + "?frame=1";
                        <tr class="erp-list-selectable-row"
                            data-area-id="@a.AreaId"
                            data-edit-url="@editUrl"
                            data-tab-title="تعديل المنطقة">
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox"
                                       class="row-select"
                                       value="@a.AreaId" />
                            </td>

                            <td data-col="id">@a.AreaId</td>
                            <td data-col="name">@a.AreaName</td>
                            <td data-col="district">@(a.District != null ? a.District.DistrictName : "— لا يوجد —")</td>
                            <td data-col="gov">@a.Governorate?.GovernorateName</td>
                            <td data-col="isactive">
                                @(a.IsActive ? "نشط" : "موقوف")
                            </td>
                            <td data-col="created">
                                @(a.CreatedAt.HasValue? a.CreatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")
                            </td>
                            <td data-col="updated">
                                @(a.UpdatedAt.HasValue? a.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        </div>
    </div>

    @* لوحة فلتر الأعمدة (شبيه إكسل) *@
    <div id="erpColumnFilterPanelArea" class="erpColumnFilterPanel shadow border rounded bg-white p-3" style="display:none; position:fixed; z-index:1050; min-width:280px; max-width:360px;">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="erp-column-filter-panel-title fw-bold"></span>
            <button type="button" class="btn btn-sm btn-outline-secondary erp-column-filter-close" aria-label="إغلاق">&times;</button>
        </div>
        <div class="mb-2 d-flex gap-1">
            <button type="button" class="btn btn-sm btn-outline-secondary erp-sort-asc">تصاعدي</button>
            <button type="button" class="btn btn-sm btn-outline-secondary erp-sort-desc">تنازلي</button>
        </div>
        <input type="text" class="form-control form-control-sm erp-column-filter-search mb-2" placeholder="بحث في القيم..." />
        <div class="erp-column-filter-list mb-2" style="max-height:220px; overflow-y:auto;"></div>
        <div class="d-flex gap-1">
            <button type="button" class="btn btn-sm btn-primary erp-column-filter-apply">تطبيق</button>
            <button type="button" class="btn btn-sm btn-outline-secondary erp-column-filter-clear">مسح الفلتر</button>
        </div>
    </div>

    @* الشريط السفلي: صف واحد محاذى لليمين *@
    <div class="d-flex flex-wrap justify-content-end align-items-center mt-2 mb-2 gap-2 no-print" dir="rtl">
        <div class="text-muted small">
            عرض @start – @end من @total
        </div>
        <form method="get" action="@Url.Action(action, controller)" class="d-inline-flex flex-nowrap align-items-center gap-2" id="pagerForm">
            <label class="form-label m-0 small text-nowrap">حجم الصفحة</label>
            <select name="pageSize" class="form-select form-select-sm" style="width:auto;" onchange="this.form.submit()">
                <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
            </select>
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="@Model.PageNumber" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
            @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
            <input type="hidden" name="dateField" value="@dateField" />
            @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
            @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
            @if (governorateId.HasValue) { <input type="hidden" name="governorateId" value="@governorateId" /> }
            @if (districtId.HasValue) { <input type="hidden" name="districtId" value="@districtId" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_dist)) { <input type="hidden" name="filterCol_dist" value="@filterCol_dist" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_gov)) { <input type="hidden" name="filterCol_gov" value="@filterCol_gov" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_isactive)) { <input type="hidden" name="filterCol_isactive" value="@filterCol_isactive" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }
        </form>
        <nav aria-label="ترقيم الصفحات">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(page == first ? "disabled" : "")"><a class="page-link" href="@Link(first)">الأول</a></li>
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")"><a class="page-link" href="@Link(prev)">السابق</a></li>
                <li class="page-item disabled"><span class="page-link">صفحة @(page) من @pages</span></li>
                <li class="page-item @(Model.HasNext ? "" : "disabled")"><a class="page-link" href="@Link(next)">التالي</a></li>
                <li class="page-item @(page == last ? "disabled" : "")"><a class="page-link" href="@Link(last)">الأخير</a></li>
            </ul>
        </nav>
    </div>
    <div class="mt-2 text-end text-muted small">
        إجمالي المناطق: @total
    </div>
</div>

@* ===== Modal فلترة التاريخ/الوقت ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ إنشاء المنطقة)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    @if (governorateId.HasValue) { <input type="hidden" name="governorateId" value="@governorateId" /> }
                    @if (districtId.HasValue) { <input type="hidden" name="districtId" value="@districtId" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_dist)) { <input type="hidden" name="filterCol_dist" value="@filterCol_dist" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_gov)) { <input type="hidden" name="filterCol_gov" value="@filterCol_gov" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_isactive)) { <input type="hidden" name="filterCol_isactive" value="@filterCol_isactive" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_created)) { <input type="hidden" name="filterCol_created" value="@filterCol_created" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_updated)) { <input type="hidden" name="filterCol_updated" value="@filterCol_updated" /> }

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(Model.UseDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">تطبيق الفلتر</button>
                    <a class="btn btn-secondary" asp-action="@action" asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="columnsModalArea"
     tabindex="-1"
     aria-labelledby="columnsModalAreaLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalAreaLabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListArea"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsArea"
                        class="btn btn-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        document.getElementById("btnPrintArea")?.addEventListener("click", function () { window.print(); });

        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanelArea',
            tableId: 'areaTable',
            wrapperId: 'areaTableScrollWrapper',
            getColumnValuesUrl: '@Url.Action("GetColumnValues", "Areas")',
            defaultSort: 'name',
            defaultDir: 'asc'
        });

        (function () {
            function scrollToRight() {
                var wrapper = document.getElementById("areaTableScrollWrapper");
                if (wrapper && wrapper.scrollWidth > wrapper.clientWidth)
                    wrapper.scrollLeft = wrapper.scrollWidth - wrapper.clientWidth;
            }
            scrollToRight();
            window.addEventListener("load", scrollToRight);
            document.addEventListener("DOMContentLoaded", function () {
                var wrapper = document.getElementById("areaTableScrollWrapper");
                if (!wrapper) return;
                var table = document.getElementById("areaTable");
                if (table) {
                    var ths = table.querySelectorAll("thead th");
                    ths.forEach(function (th) {
                        if (th.hasAttribute("data-col-fixed")) return;
                        th.style.position = "relative";
                        var handle = document.createElement("div");
                        handle.className = "erp-col-resize-handle";
                        th.appendChild(handle);
                        var startX, startWidth;
                        handle.addEventListener("mousedown", function (e) {
                            e.preventDefault();
                            startX = e.pageX;
                            startWidth = th.offsetWidth;
                            function onMouseMove(eMove) {
                                var diffX = eMove.pageX - startX;
                                var newWidth = startWidth + diffX;
                                if (newWidth < 50) newWidth = 50;
                                th.style.minWidth = newWidth + "px";
                                th.style.width = newWidth + "px";
                            }
                            function onMouseUp() {
                                document.removeEventListener("mousemove", onMouseMove);
                                document.removeEventListener("mouseup", onMouseUp);
                            }
                            document.addEventListener("mousemove", onMouseMove);
                            document.addEventListener("mouseup", onMouseUp);
                        });
                    });
                }
                scrollToRight();
            });
        })();

        if (window.ERP && typeof ERP.initListSelection === "function") {
            ERP.initListSelection({
                rowSelector: "#areaTable tbody tr.erp-list-selectable-row",
                idAttribute: "data-area-id",
                editButtonId: "btnEditArea",
                editUrlAttribute: "data-edit-url",
                tabTitleAttribute: "data-tab-title",
                editTabTitleAttribute: "data-tab-title",
                editTabId: "Areas",
                multiSelectCheckboxes: true
            });
        }

        // تحديد الكل + الحذف الجماعي + حذف الجميع
        (function () {
            const table = document.getElementById("areaTable");
            if (!table) return;

            const selectAll = document.getElementById("selectAll");
            const bulkBtn = document.getElementById("btnBulkDelete");
            const bulkForm = document.getElementById("formBulkDelete");
            const deleteAllBtn = document.getElementById("btnDeleteAll");
            const formDeleteAll = document.getElementById("formDeleteAll");
            const bulkDeleteIdsInput = document.getElementById("bulkDeleteIdsInput");

            function getRowCheckboxes() {
                return Array.from(table.querySelectorAll("tbody .row-select"));
            }

            selectAll?.addEventListener("change", function () {
                const checked = this.checked;
                getRowCheckboxes().forEach(cb => cb.checked = checked);
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select") && !target.checked && selectAll) {
                    selectAll.checked = false;
                }
            });

            bulkBtn?.addEventListener("click", function () {
                const checks = getRowCheckboxes().filter(cb => cb.checked);
                if (checks.length === 0) {
                    alert("من فضلك اختر على الأقل منطقة واحدة للحذف.");
                    return;
                }
                if (!confirm("هل أنت متأكد من حذف المناطق المحددة؟")) return;
                if (bulkDeleteIdsInput) bulkDeleteIdsInput.value = checks.map(cb => cb.value).join(",");
                bulkForm?.submit();
            });

            deleteAllBtn?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع المناطق. هل أنت متأكد؟")) return;
                formDeleteAll?.submit();
            });
        })();

        // ===== اختيار الأعمدة + حفظها في localStorage =====
        (function () {
            const table = document.getElementById("areaTable");
            if (!table) return;

            const storageKey = "area-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: (th.querySelector(".erp-col-title")?.textContent || th.textContent || "").trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListArea");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsArea")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalArea");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // ===== فلتر الكود من/إلى =====
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                // نرجع لأول صفحة مع الحفاظ على باقي الفلاتر
                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
