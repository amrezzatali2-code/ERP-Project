@using Microsoft.AspNetCore.Mvc.Rendering
@using ERP.Models
@model IEnumerable<City>

@{
    ViewData["Title"] = "المدن / المراكز";

    // قيم البحث/الترتيب الحالية (نبقيها كما يرسلها الكنترولر)
    string? search = ViewBag.Search as string;
    string? searchBy = ViewBag.SearchBy as string ?? "name";
    string? sort = ViewBag.Sort as string ?? "name";
    string? dir = ViewBag.Dir as string ?? "asc";

    // الترقيم من ViewBag (نفس النمط القائم)
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int total = ViewBag.Total ?? 0;
    int pages = (int)Math.Ceiling(total / (double)pageSize);
    if (pages < 1) pages = 1;

    int? govFilter = ViewBag.GovFilter as int?;
}

<div class="container" dir="rtl">
    <h2 class="mt-3 mb-3">@ViewData["Title"]</h2>

    @* شريط البحث/الترتيب العام *@
    <partial name="_IndexFilters" />

    @* زر إضافة مدينة/مركز *@
    <div class="mb-3 d-flex justify-content-start">
        <a class="btn btn-sm btn-success" asp-action="Create">إضافة مدينة/مركز</a>
    </div>

    @* فلتر المحافظة (يحافظ على قيم البحث/الترتيب) *@
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-12 col-md-4">
            <label class="form-label">المحافظة</label>
            @Html.DropDownList("governorateId", (SelectList)ViewBag.GovernorateId, "الكل", new { @class = "form-select" })
        </div>

        @* الحفاظ على القيم الحالية *@
        <input type="hidden" name="search" value="@search" />
        <input type="hidden" name="searchBy" value="@searchBy" />
        <input type="hidden" name="sort" value="@sort" />
        <input type="hidden" name="dir" value="@dir" />
        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="pageSize" value="@pageSize" />

        <div class="col-12 col-md-2">
            <button class="btn btn-outline-primary w-100">فلترة</button>
        </div>
    </form>

    @* الجدول — يظهر دائمًا حتى لو مفيش بيانات *@
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-light sticky-top">
                <tr>
                    <th style="width:120px;">المعرّف</th>          @* CityId *@
                    <th>اسم المدينة/المركز</th>                    @* CityName *@
                    <th>المحافظة</th>                              @* Governorate.GovernorateName *@
                    <th style="width:120px;">الحالة</th>           @* IsActive *@
                    <th style="width:200px;"></th>                  @* أزرار العمليات *@
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var c in Model)
                    {
                        <tr>
                            <td>@c.CityId</td>
                            <td>@c.CityName</td>
                            <td>@c.Governorate?.GovernorateName</td>
                            <td>
                                @if (c.IsActive)
                                {
                                    <span class="badge bg-success">نشط</span>  @* قيمة منطقية: true *@
                                }
                                else
                                {
                                    <span class="badge bg-secondary">موقوف</span>
                                }
                            </td>
                            <td class="text-nowrap">
                                @* أزرار: تفاصيل / تعديل / حذف — نفس نمط المحافظات *@
                                <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@c.CityId">تفاصيل</a>
                                <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@c.CityId">تعديل</a>
                                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@c.CityId">حذف</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    @* رسالة جدول فاضي مع الحفاظ على الهيدر *@
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            لا توجد بيانات مطابقة للفلاتر الحالية.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* الترقيم + حجم الصفحة أسفل الجدول يمين *@
    <div class="d-flex justify-content-between align-items-center">
        <div>إجمالي: <strong>@total</strong> صف</div>

        <div class="d-flex align-items-center" style="gap:.75rem;">
            @* تغيير حجم الصفحة (يرجع للصفحة 1) *@
            <form method="get" class="d-flex align-items-center" style="gap:.5rem;">
                <input type="hidden" name="search" value="@search" />
                <input type="hidden" name="searchBy" value="@searchBy" />
                <input type="hidden" name="sort" value="@sort" />
                <input type="hidden" name="dir" value="@dir" />
                <input type="hidden" name="governorateId" value="@govFilter" />

                <label class="form-label m-0">حجم الصفحة</label>
                <input type="number" name="pageSize" value="@pageSize" min="5" max="200" class="form-control" style="width:90px;" />
                <input type="hidden" name="page" value="1" />
                <button class="btn btn-outline-secondary">تطبيق</button>
            </form>

            <nav aria-label="الترقيم">
                <ul class="pagination m-0">
                    <li class="page-item @(page <= 1 ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { search, searchBy, sort, dir, governorateId = govFilter, page = Math.Max(1, page - 1), pageSize })">
                            السابق
                        </a>
                    </li>

                    <li class="page-item disabled">
                        <span class="page-link">صفحة @(page) من @(pages)</span>   @* مهم: @(page) لتجنّب التباس @page *@
                    </li>

                    <li class="page-item @(page >= pages ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { search, searchBy, sort, dir, governorateId = govFilter, page = Math.Min(pages, page + 1), pageSize })">
                            التالي
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
