@model ERP.Models.City
@{
    ViewData["Title"] = "تفاصيل المدينة/المركز";
}
<div class="container" dir="rtl">
    <h2 class="mt-3 mb-3">@ViewData["Title"]</h2>

    <dl class="row">
        <dt class="col-sm-3">المعرّف</dt>
        <dd class="col-sm-9">@Model.CityId</dd>

        <dt class="col-sm-3">اسم المدينة/المركز</dt>
        <dd class="col-sm-9">@Model.CityName</dd>

        <dt class="col-sm-3">المحافظة</dt>
        <dd class="col-sm-9">@Model.Governorate?.GovernorateName</dd>

        <dt class="col-sm-3">الحالة</dt>
        <dd class="col-sm-9">
            @(Model.IsActive ? "نشط" : "موقوف")
        </dd>

        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <dt class="col-sm-3">ملاحظات</dt>
            <dd class="col-sm-9">@Model.Notes</dd>
        }
    </dl>

    <div class="mt-3 d-flex" style="gap:.5rem;">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.CityId">تعديل</a>
        <a class="btn btn-outline-secondary" asp-action="Index">عودة</a>
    </div>
</div>
