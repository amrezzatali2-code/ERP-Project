@model ERP.Models.City
@{
    ViewData["Title"] = "حذف مدينة/مركز";
}
<div class="container" dir="rtl">
    <h2 class="mt-3 mb-3 text-danger">@ViewData["Title"]</h2>
    <p class="text-muted">هل أنت متأكد من حذف هذا السجل؟</p>

    <dl class="row">
        <dt class="col-sm-3">المعرّف</dt>
        <dd class="col-sm-9">@Model.CityId</dd>

        <dt class="col-sm-3">اسم المدينة/المركز</dt>
        <dd class="col-sm-9">@Model.CityName</dd>

        <dt class="col-sm-3">المحافظة</dt>
        <dd class="col-sm-9">@Model.Governorate?.GovernorateName</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CityId" />
        <div class="mt-3 d-flex" style="gap:.5rem;">
            <button type="submit" class="btn btn-danger">تأكيد الحذف</button>
            <a class="btn btn-outline-secondary" asp-action="Index">إلغاء</a>
        </div>
    </form>
</div>
