@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@using ERP.Models
@model PagedResult<DocumentSeries>

@{
    ViewData["Title"] = "ترقيم المستندات";

    // أسماء الأكشن/الكنترولر
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "DocumentSeries";

    // قيم البحث/الترتيب من الموديل / ViewBag (نفس فكرة District)
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "all";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "DocType";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "asc");

    int ps = Model.PageSize > 0 ? Model.PageSize : 50;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages <= 0 ? 1 : Model.TotalPages;

    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // دالة توليد لينك صفحة مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps
    })!;

    // دالة إنشاء لينك الترتيب مع السهم (نفس District بالضبط)
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps
        }) ?? "#";

        string icon;
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";
        else
            icon = "⇅";

        return new HtmlString(
            $@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>"
        );
    };
}

<div dir="rtl" class="container-fluid">
    <h2 class="mb-3">ترقيم المستندات (DocumentSeries)</h2>

    @* رسالة نجاح *@
    @if (TempData["ok"] is string ok)
    {
        <div class="alert alert-success">@ok</div>
    }

    @* شريط الفلاتر الموحّد (بحث + ترتيب) *@
    <partial name="_IndexFilters" />

    @* زر إضافة *@
    <div class="mb-2 d-flex flex-wrap gap-2 align-items-center">
        <a class="btn btn-sm btn-primary" asp-action="Create">إضافة سلسلة</a>
    </div>

    @* ===== الجدول — نفس نظام القوائم الموحد ===== *@
    <div class="erp-table-wrapper mt-3">
        <table class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    <th>@sortLink("DocType", "نوع المستند")</th>
                    <th>@sortLink("SeriesCode", "السلسلة")</th>
                    <th style="width:110px;">@sortLink("FiscalYear", "السنة")</th>
                    <th style="width:110px;" class="text-end">@sortLink("CurrentNo", "العدد الحالي")</th>
                    <th style="width:110px;" class="text-end">@sortLink("NumberWidth", "عرض الرقم")</th>
                    <th>@sortLink("Prefix", "البادئة")</th>
                    <th style="width:150px;">@sortLink("ResetPolicy", "السياسة")</th>
                    <th style="width:160px;">@sortLink("CreatedAt", "تاريخ الإنشاء")</th>
                    <th style="width:180px;">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var x in Model.Items)
                    {
                        <tr>
                            <td>@x.DocType</td>
                            <td>@x.SeriesCode</td>
                            <td>@x.FiscalYear</td>
                            <td class="text-end">@x.CurrentNo</td>
                            <td class="text-end">@x.NumberWidth</td>
                            <td>@x.Prefix</td>
                            <td>@x.ResetPolicy</td>
                            <td>@x.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                            <td class="text-nowrap">
                                <a class="btn btn-sm btn-info"
                                   asp-action="Details" asp-route-id="@x.SeriesId">تفاصيل</a>
                                <a class="btn btn-sm btn-primary"
                                   asp-action="Edit" asp-route-id="@x.SeriesId">تعديل</a>
                                <a class="btn btn-sm btn-danger"
                                   asp-action="Delete" asp-route-id="@x.SeriesId">حذف</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @* ===== شريط عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              asp-action="@action"
              asp-controller="@controller"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25" selected="@(ps == 25 ? "selected" : null)">25</option>
                <option value="50" selected="@(ps == 50 ? "selected" : null)">50</option>
                <option value="100" selected="@(ps == 100 ? "selected" : null)">100</option>
                <option value="200" selected="@(ps == 200 ? "selected" : null)">200</option>
            </select>
        </form>
    </div>

    @* ===== الترقيم ===== *@
    <nav aria-label="pagination" class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>

            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>

            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>
