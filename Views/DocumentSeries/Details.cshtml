@model ERP.Models.DocumentSeries
@{
    ViewData["Title"] = "تفاصيل سلسلة الترقيم";
}
<h3 class="mb-3">تفاصيل سلسلة الترقيم</h3>

<div class="table-responsive">
    <table class="table table-bordered w-auto" dir="rtl">
        <tr><th>المعرف</th><td>@Model.SeriesId</td></tr>
        <tr><th>نوع المستند</th><td>@Model.DocType</td></tr>
        <tr><th>السلسلة</th><td>@Model.SeriesCode</td></tr>
        <tr><th>السنة</th><td>@Model.FiscalYear</td></tr>
        <tr><th>السياسة</th><td>@Model.ResetPolicy</td></tr>
        <tr><th>العدد الحالي</th><td>@Model.CurrentNo</td></tr>
        <tr><th>عرض الرقم</th><td>@Model.NumberWidth</td></tr>
        <tr><th>البادئة</th><td>@Model.Prefix</td></tr>
        <tr><th>أُنشئت في</th><td>@Model.CreatedAt</td></tr>
        <tr><th>آخر تحديث</th><td>@Model.UpdatedAt</td></tr>
    </table>
</div>

<div class="mt-2">
    <a class="btn btn-secondary" asp-action="Index">رجوع</a>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.SeriesId">تعديل</a>
</div>
