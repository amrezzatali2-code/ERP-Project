@model ERP.Models.Category
@{
    ViewData["Title"] = "تفاصيل فئة";
}
<div class="container" dir="rtl">
    <h2 class="mb-3">تفاصيل فئة</h2>

    <dl class="row">
        <dt class="col-sm-2">المعرّف</dt>
        <dd class="col-sm-10">@Model.CategoryId</dd>

        <dt class="col-sm-2">الاسم</dt>
        <dd class="col-sm-10">@Model.CategoryName</dd>
    </dl>

    <div class="mt-3 d-flex gap-2">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.CategoryId">تعديل</a>
        <a class="btn btn-secondary" asp-action="Index">رجوع</a>
    </div>
</div>
