@model ERP.Models.Category
@{
    ViewData["Title"] = "حذف فئة";
}
<div class="container" dir="rtl">
    <h2 class="mb-3 text-danger">حذف فئة</h2>
    <p>هل أنت متأكد من حذف الفئة التالية؟</p>

    <dl class="row">
        <dt class="col-sm-2">المعرّف</dt>
        <dd class="col-sm-10">@Model.CategoryId</dd>

        <dt class="col-sm-2">الاسم</dt>
        <dd class="col-sm-10">@Model.CategoryName</dd>
    </dl>

    <form asp-action="Delete" method="post" class="mt-3 d-flex gap-2">
        <input type="hidden" asp-for="CategoryId" />
        <button class="btn btn-danger">تأكيد الحذف</button>
        <a class="btn btn-secondary" asp-action="Index">إلغاء</a>
    </form>
</div>
