            if (!panel || !listEl) return;

            const numericColumns = ['code', 'qty', 'discount', 'manualDiscount', 'sales', 'priceRetail', 'unitCost', 'cost', 'policy1', 'policy2', 'policy3', 'policy4', 'policy5', 'policy6', 'policy7', 'policy8', 'policy9', 'policy10'];
            const warehouseFilterValuesFromServer = (() => {
                try {
