@using ERP.ViewModels
@{
    ViewData["Title"] = "تقرير: أرصدة الأصناف";

    var reportData = ViewBag.ReportData as List<ProductBalanceReportDto> ?? new List<ProductBalanceReportDto>();
    var totalQty = ViewBag.TotalQty as int? ?? 0;
    var totalPriceRetail = ViewBag.TotalPriceRetail as decimal? ?? 0m;
    var totalSalesQty = ViewBag.TotalSalesQty as decimal? ?? 0m;
    var totalUnitCost = ViewBag.TotalUnitCost as decimal? ?? 0m;
    var totalCost = ViewBag.TotalCost as decimal? ?? 0m;

    // Pagination
    var page = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 200;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;

    // الفلاتر من ViewBag
    var search = ViewBag.Search as string ?? "";
    var categoryId = ViewBag.CategoryId as int?;
    var warehouseId = ViewBag.WarehouseId as int?;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var includeZeroQty = ViewBag.IncludeZeroQty as bool? ?? false;
    var sortBy = ViewBag.SortBy as string ?? "name";
    var sortDir = ViewBag.SortDir as string ?? "asc";

    // القوائم المنسدلة
    var categories = ViewBag.Categories as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var warehouses = ViewBag.Warehouses as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    // دالة إنشاء رابط الترتيب
    Func<string, string, string> sortUrl = (col, direction) =>
    {
        return Url.Action("ProductBalances", "Reports", new
        {
            search,
            categoryId,
            warehouseId,
            fromDate,
            toDate,
            includeZeroQty,
            sortBy = col,
            sortDir = direction,
            loadReport = true,
            page,
            pageSize
        }) ?? "#";
    };

    // دالة إنشاء رابط Pagination
    Func<int, string> pageUrl = (p) =>
    {
        return Url.Action("ProductBalances", "Reports", new
        {
            search,
            categoryId,
            warehouseId,
            fromDate,
            toDate,
            includeZeroQty,
            sortBy,
            sortDir,
            loadReport = true,
            page = p,
            pageSize
        }) ?? "#";
    };
}

<div dir="rtl" class="container-fluid">
    @* ===== شريط الفلاتر الموحد (هادئ للعين) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2 product-balances-report">
        <form method="get" asp-action="ProductBalances" asp-controller="Reports" id="filtersForm">
            <div class="row g-3 align-items-end">
                <input type="hidden" name="loadReport" value="true" />
                <div class="col-12 col-lg-3 erp-filter-section">
                    <label class="form-label">بحث</label>
                    <input type="text"
                           name="search"
                           list="productsList"
                           class="form-control erp-filter-input"
                           placeholder="اكتب اسم الصنف أو جزء منه..."
                           autocomplete="off"
                           value="@search" />
                    <datalist id="productsList">
                        @if (ViewBag.ProductsAuto != null)
                        {
                            foreach (var p in ViewBag.ProductsAuto)
                            {
                                <option value="@p.Name" data-id="@p.Id" data-code="@p.Id" data-generic="@p.GenericName" data-company="@p.Company" data-price="@p.PriceRetail" data-hasquota="@(p.HasQuota ? "true" : "false")"></option>
                            }
                        }
                    </datalist>
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">الفئة</label>
                    <select name="categoryId" class="form-select erp-filter-input">
                        <option value="">الكل</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Value" @(categoryId?.ToString() == cat.Value ? "selected" : null)>@cat.Text</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">المخزن</label>
                    <select name="warehouseId" class="form-select erp-filter-input">
                        <option value="">الكل</option>
                        @foreach (var wh in warehouses)
                        {
                            <option value="@wh.Value" @(warehouseId?.ToString() == wh.Value ? "selected" : null)>@wh.Text</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">من تاريخ</label>
                    <input type="date" name="fromDate" dir="ltr" class="form-control erp-filter-input" value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date" name="toDate" dir="ltr" class="form-control erp-filter-input" value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">خيارات</label>
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" name="includeZeroQty" value="true" id="includeZeroQty" @(includeZeroQty ? "checked" : "") />
                        <label class="form-check-label small" for="includeZeroQty">عرض الصفر</label>
                    </div>
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                    <div class="d-flex flex-nowrap gap-2 product-balances-btns">
                        <button type="submit" class="btn btn-erp btn-erp-sm product-balances-btn product-balances-btn-primary">
                            <span>📊</span> تجميع التقرير
                        </button>
                        <a href="@Url.Action("ProductBalances", "Reports")" class="btn btn-erp btn-erp-sm text-decoration-none product-balances-btn product-balances-btn-secondary">
                            <span>🔄</span> إعادة تعيين
                        </a>
                        @if (reportData.Any())
                        {
                            <a href="@Url.Action("ExportProductBalances", "Reports", new { search, categoryId, warehouseId, fromDate, toDate, includeZeroQty, sortBy, sortDir })"
                               class="btn btn-erp btn-erp-sm text-decoration-none product-balances-btn product-balances-btn-success">
                                <span>📥</span> تصدير Excel
                            </a>
                        }
                    </div>
                </div>
                @if (reportData.Any() && totalPages > 1)
                {
                    <div class="col-12 col-lg-2 erp-filter-section">
                        <label class="form-label">حجم الصفحة</label>
                        <select name="pageSize" class="form-select erp-filter-input" onchange="this.form.submit()">
                            <option value="200" @(pageSize == 200 ? "selected" : "")>200</option>
                            <option value="500" @(pageSize == 500 ? "selected" : "")>500</option>
                            <option value="1000" @(pageSize == 1000 ? "selected" : "")>1000</option>
                            <option value="5000" @(pageSize == 5000 ? "selected" : "")>5000</option>
                            <option value="0" @(pageSize == 0 || pageSize >= totalCount ? "selected" : "")>الكل</option>
                        </select>
                    </div>
                }
            </div>
        </form>
    </div>

    @* ===== Pagination Info ===== *@
    @if (reportData.Any() && totalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <small class="text-muted">
                عرض @((page - 1) * pageSize + 1) - @(Math.Min(page * pageSize, totalCount)) من @totalCount
            </small>
            <small class="text-muted">
                @($"صفحة {page} من {totalPages}")
            </small>
        </div>
    }

    @* ===== جدول البيانات ===== *@
    @if (reportData.Any())
    {
        <div class="erp-table-wrapper mt-3 product-balances-table">
            <div class="table-responsive">
                <table class="table table-sm table-striped table-hover mb-0 erp-table">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="min-width: 80px;">
                                    <a href="@sortUrl("code", sortBy == "code" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        الكود @if (sortBy == "code") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th style="min-width: 200px;">
                                    <a href="@sortUrl("name", sortBy == "name" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        اسم الصنف @if (sortBy == "name") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th>الفئة</th>
                                <th class="text-end" style="min-width: 100px;">
                                    <a href="@sortUrl("qty", sortBy == "qty" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        الكمية الحالية @if (sortBy == "qty") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th class="text-end" style="min-width: 120px;">الخصم المرجح %</th>
                                <th class="text-end" style="min-width: 100px;">
                                    <a href="@sortUrl("sales", sortBy == "sales" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        المبيعات @if (sortBy == "sales") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th class="text-end" style="min-width: 120px;">سعر الجمهور</th>
                                <th class="text-end" style="min-width: 120px;">تكلفة العلبة</th>
                                <th class="text-end" style="min-width: 130px;">
                                    <a href="@sortUrl("cost", sortBy == "cost" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        التكلفة الإجمالية @if (sortBy == "cost") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in reportData)
                            {
                                <tr>
                                    <td><strong>@item.ProdCode</strong></td>
                                    <td>@item.ProdName</td>
                                    <td><small class="text-muted">@item.CategoryName</small></td>
                                    <td class="text-end"><strong>@item.CurrentQty.ToString("N0")</strong></td>
                                    <td class="text-end">@item.WeightedDiscount.ToString("N2")%</td>
                                    <td class="text-end">@item.SalesQty.ToString("N2")</td>
                                    <td class="text-end">@item.PriceRetail.ToString("N2")</td>
                                    <td class="text-end">@item.UnitCost.ToString("N2")</td>
                                    <td class="text-end"><strong>@item.TotalCost.ToString("N2")</strong></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-secondary fw-bold">
                            <tr>
                                <td colspan="3" class="text-end"><strong>المجموع الإجمالي:</strong></td>
                                <td class="text-end"><strong>@totalQty.ToString("N0")</strong></td>
                                <td></td>
                                <td class="text-end"><strong>@totalSalesQty.ToString("N2")</strong></td>
                                <td class="text-end"><strong>@totalPriceRetail.ToString("N2")</strong></td>
                                <td class="text-end"><strong>@totalUnitCost.ToString("N2")</strong></td>
                                <td class="text-end">
                                    <strong class="product-balances-total-value">@totalCost.ToString("N2")</strong>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
        </div>

        @* ===== Pagination Controls ===== *@
        @if (totalPages > 1)
        {
            <nav aria-label="pagination" class="mt-3 d-print-none">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(page == 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(1)">الأول</a>
                    </li>
                    <li class="page-item @(page == 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page - 1)">السابق</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">@($"صفحة {page} من {totalPages}")</span>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page + 1)">التالي</a>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(totalPages)">الأخير</a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">لا توجد بيانات لعرضها</p>
        </div>
    }
</div>

@section Styles {
    <style>
        datalist { display: none; }

        /* ألوان هادئة للعين — أزرار بخلفية بيضاء وحدود باهتة */
        .product-balances-report .product-balances-btn {
            background-color: #fff !important;
            border-width: 1.5px !important;
            border-style: solid !important;
        }
        .product-balances-btn-primary {
            color: #5b6b7a !important;
            border-color: #94a3b8 !important;
        }
        .product-balances-btn-primary:hover {
            background-color: #f1f5f9 !important;
            color: #475569 !important;
            border-color: #64748b !important;
        }
        .product-balances-btn-secondary {
            color: #64748b !important;
            border-color: #cbd5e1 !important;
        }
        .product-balances-btn-secondary:hover {
            background-color: #f8fafc !important;
            color: #475569 !important;
        }
        .product-balances-btn-success {
            color: #4d7c5a !important;
            border-color: #86efac !important;
        }
        .product-balances-btn-success:hover {
            background-color: #f0fdf4 !important;
            color: #166534 !important;
        }

        /* جدول — ألوان هادئة */
        .product-balances-table .erp-table thead th {
            background-color: #f1f5f9 !important;
            color: #475569;
            border-bottom: 1px solid #e2e8f0;
            font-weight: 600;
        }
        .product-balances-table .erp-table tfoot {
            background-color: #f8fafc !important;
            border-top: 1px solid #e2e8f0;
        }
        .product-balances-table .erp-table tbody tr:hover {
            background-color: #f8fafc !important;
        }
        /* المجموع الإجمالي — لون هادئ بدل الأزرق القوي */
        .product-balances-total-value {
            font-size: 1.05rem;
            color: #475569 !important;
        }
        a.text-decoration-none:hover { text-decoration: underline !important; }
    </style>
}

@section Scripts {
    <script>
        // ضمان إرسال includeZeroQty حتى لو كان checkbox غير مفعّل
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('filtersForm');
            const checkbox = document.getElementById('includeZeroQty');
            
            if (form && checkbox) {
                form.addEventListener('submit', function (e) {
                    // إزالة أي hidden input سابق
                    const existingHidden = form.querySelector('input[name="includeZeroQty"][type="hidden"]');
                    if (existingHidden) {
                        existingHidden.remove();
                    }
                    
                    // إذا كان checkbox غير مفعّل، أضف hidden input
                    if (!checkbox.checked) {
                        const hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = 'includeZeroQty';
                        hidden.value = 'false';
                        form.appendChild(hidden);
                    }
                });
            }
        });
    </script>
}
