@using ERP.ViewModels
@{
    ViewData["Title"] = "تقرير: أرصدة الأصناف";

    var reportData = ViewBag.ReportData as List<ProductBalanceReportDto> ?? new List<ProductBalanceReportDto>();
    var totalQty = ViewBag.TotalQty as int? ?? 0;
    var totalPriceRetail = ViewBag.TotalPriceRetail as decimal? ?? 0m;
    var totalSalesQty = ViewBag.TotalSalesQty as decimal? ?? 0m;
    var totalUnitCost = ViewBag.TotalUnitCost as decimal? ?? 0m;
    var totalCost = ViewBag.TotalCost as decimal? ?? 0m;
    var weightedAvgDiscount = ViewBag.WeightedAvgDiscount as decimal? ?? 0m;
    var averagePriceRetail = ViewBag.AveragePriceRetail as decimal? ?? 0m;
    var averageUnitCost = ViewBag.AverageUnitCost as decimal? ?? 0m;

    // Pagination
    var page = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 10;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;

    // الفلاتر من ViewBag
    var search = ViewBag.Search as string ?? "";
    var categoryId = ViewBag.CategoryId as int?;
    var productGroupId = ViewBag.ProductGroupId as int?;
    var hasBonus = ViewBag.HasBonus as bool?;
    var warehouseId = ViewBag.WarehouseId as int?;
    var whStr = Context.Request.Query["warehouseId"].FirstOrDefault();
    if (!string.IsNullOrEmpty(whStr) && int.TryParse(whStr, out var whParsed))
        warehouseId = whParsed;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var includeZeroQty = ViewBag.IncludeZeroQty as bool? ?? false;
    var includeBatches = ViewBag.IncludeBatches as bool? ?? true;
    var sortBy = ViewBag.SortBy as string ?? "name";
    var sortDir = ViewBag.SortDir as string ?? "asc";
    var searchMode = ViewBag.SearchMode as string ?? "contains";
    var pbQtyGtZeroChecked = !(ViewBag.IncludeZeroQty as bool? ?? false);

    // القوائم المنسدلة
    var categories = ViewBag.Categories as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var productGroups = ViewBag.ProductGroups as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var warehouses = ViewBag.Warehouses as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    // دالة إنشاء رابط الترتيب
    Func<string, string, string> sortUrl = (col, direction) =>
    {
        return Url.Action("ProductBalances", "Reports", new
        {
            search,
            searchMode,
            categoryId,
            productGroupId,
            hasBonus,
            warehouseId,
            fromDate,
            toDate,
            pbQtyGtZero = pbQtyGtZeroChecked ? "true" : "false",
            includeBatches,
            sortBy = col,
            sortDir = direction,
            loadReport = true,
            page,
            pageSize
        }) ?? "#";
    };

    // دالة إنشاء رابط Pagination
    Func<int, string> pageUrl = (p) =>
    {
        return Url.Action("ProductBalances", "Reports", new
        {
            search,
            searchMode,
            categoryId,
            productGroupId,
            hasBonus,
            warehouseId,
            fromDate,
            toDate,
            pbQtyGtZero = pbQtyGtZeroChecked ? "true" : "false",
            includeBatches,
            sortBy,
            sortDir,
            loadReport = true,
            page = p,
            pageSize
        }) ?? "#";
    };
}

<div dir="rtl" class="container-fluid">
    @* توكن مكافحة التزوير لطلبات AJAX (حفظ الخصم اليدوي) *@
    <form id="__AntiForgeryFormProductBalances" method="post" style="display:none">@Html.AntiForgeryToken()</form>
    @* ===== شريط الفلاتر الموحد (هادئ للعين) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2 product-balances-report erp-pb-filter-dark-borders">
        <form method="get" asp-action="ProductBalances" asp-controller="Reports" id="filtersForm">
            <input type="hidden" name="loadReport" value="true" />
            <input type="hidden" name="includeBatches" value="true" />
            @* —— صف 1: بحث مضغوط + فئة + مجموعة + مخزن + كمية أكبر من صفر + إعادة تعيين —— *@
            <div class="row g-3 g-lg-3 align-items-end erp-pb-filter-row1">
                <div class="col-12 col-md-6 col-xl-4 col-lg-3 erp-filter-section erp-pb-col-search">
                    <label class="form-label small mb-1">بحث</label>
                    <div class="d-flex flex-wrap gap-2 align-items-stretch">
                        <select name="searchMode" class="form-select form-select-sm erp-filter-input erp-pb-search-mode" title="نوع البحث في اسم الصنف والباركود">
                            <option value="starts" @(searchMode == "starts" ? "selected" : null)>يبدأ بـ</option>
                            <option value="contains" @(searchMode == "contains" || string.IsNullOrEmpty(searchMode) ? "selected" : null)>يحتوي</option>
                            <option value="ends" @(searchMode == "ends" ? "selected" : null)>ينتهي بـ</option>
                        </select>
                        <input type="text"
                               name="search"
                               list="productsList"
                               class="form-control form-control-sm erp-filter-input flex-grow-1 erp-pb-search-text"
                               placeholder="نص البحث…"
                               autocomplete="off"
                               value="@search" />
                    </div>
                    <datalist id="productsList">
                        @if (ViewBag.ProductsAuto != null)
                        {
                            foreach (var p in ViewBag.ProductsAuto)
                            {
                                <option value="@p.Name" data-id="@p.Id" data-code="@p.Id" data-generic="@p.GenericName" data-company="@p.Company" data-price="@p.PriceRetail" data-hasquota="@(p.HasQuota ? "true" : "false")"></option>
                            }
                        }
                    </datalist>
                </div>
                <div class="col-6 col-md-4 col-lg-2 col-xl-2 erp-filter-section erp-pb-col-dd">
                    <label class="form-label small mb-1">الفئة</label>
                    <select name="categoryId" class="form-select form-select-sm erp-filter-input">
                        <option value="">الكل</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Value" @(categoryId?.ToString() == cat.Value ? "selected" : null)>@cat.Text</option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-4 col-lg-2 col-xl-2 erp-filter-section erp-pb-col-dd">
                    <label class="form-label small mb-1">مجموعة الصنف</label>
                    <select name="productGroupId" class="form-select form-select-sm erp-filter-input">
                        <option value="">الكل</option>
                        @foreach (var pg in productGroups)
                        {
                            <option value="@pg.Value" @(productGroupId?.ToString() == pg.Value ? "selected" : null)>@pg.Text</option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-4 col-lg-2 col-xl-2 erp-filter-section erp-pb-col-dd">
                    <label class="form-label small mb-1">المخزن</label>
                    <select name="warehouseId" id="warehouseIdSelect" class="form-select form-select-sm erp-filter-input">
                        <option value="">الكل</option>
                        @foreach (var wh in warehouses)
                        {
                            var whVal = wh.Value ?? "";
                            var isSelected = warehouseId.HasValue && !string.IsNullOrEmpty(whVal) && warehouseId.Value.ToString().Equals(whVal.Trim(), StringComparison.Ordinal);
                            <option value="@whVal" @(isSelected ? "selected" : null)>@wh.Text</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-sm-auto erp-filter-section erp-pb-col-qty">
                    <label class="form-label small mb-1 d-block" style="visibility:hidden">—</label>
                    <div class="d-flex align-items-center gap-2 erp-pb-qty-checkbox-wrap mb-0 px-2" dir="rtl">
                        <label class="form-check-label small mb-0" for="pbQtyGtZero">الكمية أكبر من صفر</label>
                        <input class="form-check-input erp-pb-qty-checkbox m-0 flex-shrink-0" type="checkbox" name="pbQtyGtZero" value="true" id="pbQtyGtZero" @(pbQtyGtZeroChecked ? "checked" : "") />
                    </div>
                </div>
                <div class="col-12 col-sm-auto erp-filter-section erp-pb-col-reset d-flex align-items-end">
                    <label class="form-label small mb-1 d-block" style="visibility:hidden">—</label>
                    <a href="@Url.Action("ProductBalances", "Reports")" class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none">
                        <span>🔄</span> إعادة تعيين
                    </a>
                </div>
            </div>
            @* —— صف 2: التواريخ + تجميع التقرير + (عند وجود بيانات) تصدير وحفظ وحركة وأعمدة ونقل المرجّح —— *@
            <div class="row g-0 align-items-end mt-3 erp-pb-filter-row2">
                <div class="col-12 erp-filter-section erp-pb-filter-row2-inner">
                    <div class="d-flex flex-wrap align-items-end gap-3 justify-content-between" dir="rtl">
                        <div class="d-flex flex-wrap flex-lg-nowrap align-items-end gap-3 erp-pb-dates-group">
                            <div class="erp-pb-date-from-wrap">
                                <label class="form-label small mb-0">من (تاريخ ووقت) <span class="text-muted small">يوم/شهر/سنة</span></label>
                                <input type="datetime-local" name="fromDate" id="pbFromDate" dir="ltr" class="form-control form-control-sm erp-filter-input erp-datetime-input" value="@(fromDate.HasValue ? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" placeholder="يوم/شهر/سنة 00:00" title="بداية المدة (يوم/شهر/سنة ووقت)" />
                            </div>
                            <div class="erp-pb-date-to-wrap">
                                <label class="form-label small mb-0">إلى (تاريخ ووقت) <span class="text-muted small">يوم/شهر/سنة</span></label>
                                <input type="datetime-local" name="toDate" id="pbToDate" dir="ltr" class="form-control form-control-sm erp-filter-input erp-datetime-input" value="@(toDate.HasValue ? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" placeholder="يوم/شهر/سنة 00:00" title="نهاية المدة (يوم/شهر/سنة ووقت)" />
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-3 justify-content-start align-items-center erp-pb-actions-row" dir="rtl">
                            <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">
                                <span>📊</span> تجميع التقرير
                            </button>
                            @if (reportData.Any())
                            {
                                <input type="hidden" name="pageSize" value="@pageSize" />
                                <a href="@Url.Action("ExportProductBalances", "Reports", new { search, searchMode, categoryId, productGroupId, hasBonus, warehouseId, fromDate, toDate, pbQtyGtZero = pbQtyGtZeroChecked ? "true" : "false", includeBatches, sortBy, sortDir })"
                                   class="btn btn-erp btn-erp-success btn-erp-sm text-decoration-none">
                                    <span>📥</span> تصدير Excel
                                </a>
                                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm d-print-none" id="erpPbSaveAllManualDiscount" title="حفظ كل تعديلات الخصم اليدوي للبيع (يشمل الخصومات في صفوف التشغيلات)">
                                    <span>💾</span> حفظ الخصم اليدوي
                                </button>
                                <span id="erpPbSaveSuccessMessage" class="d-none text-success fw-bold me-2 small align-middle" style="vertical-align: middle;">تم الحفظ</span>
                                @* ترتيب DOM: في RTL يظهر «نقل المرجّح» يمين الحزمة، ثم «حركة» و«الأعمدة» إلى يساره *@
                                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm d-print-none" id="erpPbCopyWeightedToManual" title="ينقل الخصم المرجّح (بعد التقريب لأقرب عدد صحيح) إلى خانة الخصم اليدوي لكل صف ظاهر ثم يحفظ">
                                    <span>📋</span> نقل المرجّح → يدوي (بعد التقريب)
                                </button>
                                <button type="button" id="erpPbToolbarMovement" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="اختر صفاً في الجدول أولاً">حركة الصنف</button>
                                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm d-print-none" data-bs-toggle="modal" data-bs-target="#columnsModalProductBalances" title="إظهار/إخفاء أعمدة التقرير">اختيار الأعمدة</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>

    @* ===== كروت الإجماليات (بين شريط الفلاتر والجدول) ===== *@
    @if (reportData.Any())
    {
        var n2 = System.Globalization.CultureInfo.InvariantCulture;
        <div class="row g-2 g-md-3 mb-2 mt-3 no-print" id="productBalancesSummaryCards">
            <div class="col-12 col-sm-6 col-md-4 col-lg">
                <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #0d6efd !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(13,110,253,.25); overflow: hidden;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">العدد الإجمالي</div>
                        <div class="h4 mb-0 text-info fw-bold" id="productBalancesCardCountAfterFilter">@totalCount.ToString("N0", n2)</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-4 col-lg">
                <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #198754 !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(25,135,84,.25); overflow: hidden;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">متوسط الخصم المرجح %</div>
                        <div class="h4 mb-0 text-success fw-bold">@weightedAvgDiscount.ToString("N2", n2)</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-4 col-lg">
                <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #fd7e14 !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(253,126,20,.25); overflow: hidden;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">إجمالي المبيعات</div>
                        <div class="h4 mb-0 fw-bold">@totalSalesQty.ToString("N2", n2)</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-4 col-lg">
                <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #6f42c1 !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(111,66,193,.25); overflow: hidden;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">متوسط سعر الجمهور</div>
                        <div class="h4 mb-0 fw-bold">@averagePriceRetail.ToString("N2", n2)</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-4 col-lg">
                <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #0dcaf0 !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(13,202,240,.25); overflow: hidden;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">متوسط تكلفة العلبة</div>
                        <div class="h4 mb-0 fw-bold">@averageUnitCost.ToString("N2", n2)</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-4 col-lg">
                <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #dc3545 !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(220,53,69,.25); overflow: hidden;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">إجمالي التكلفة</div>
                        <div class="h4 mb-0 text-danger fw-bold">@totalCost.ToString("N2", n2)</div>
                    </div>
                </div>
            </div>
        </div>
    }

    @* تحديث عدد الصفوف المرئية (فلترة أعمدة) — مخفي عن العرض *@
    @if (reportData.Any())
    {
        <span id="productBalancesItemCount" class="d-none" aria-hidden="true">@totalCount</span>
    }

    @* ===== جدول البيانات (نفس هيكل Index قائمة الأصناف) ===== *@
    <div class="erp-table-scroll-container mt-2">
        <div id="productBalancesScrollWrapper" class="erp-table-wrapper erp-print-area erp-list-index-table-section product-balances-table" style="position: relative; max-height: 70vh; overflow-y: auto; overflow-x: auto;">
            <table class="table table-striped table-hover mb-0 erp-table erp-table-sortable" id="productBalancesTable" data-pb-total-count="@totalCount">
                <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                    <tr>
                        <th style="width: 44px; min-width: 44px;" data-col="select" data-col-fixed="true" class="text-center no-print" title="تحديد الصف"></th>
                        <th style="min-width: 80px;" data-col="code">
                            <div class="d-flex align-items-center gap-1">
                                <span>الكود</span>
                                <button type="button" class="btn btn-sm p-0 erp-pb-col-filter-btn" data-col="code" data-sort-key="code" data-col-title="الكود" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                            </div>
                        </th>
                        <th style="min-width: 200px;" data-col="name">
                            <div class="d-flex align-items-center gap-1">
                                <span>اسم الصنف</span>
                                <button type="button" class="btn btn-sm p-0 erp-pb-col-filter-btn" data-col="name" data-sort-key="name" data-col-title="اسم الصنف" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                            </div>
                        </th>
                        <th style="min-width: 90px;" data-col="batch">التشغيلة</th>
                        <th style="min-width: 100px;" data-col="date">التاريخ</th>
                        <th style="min-width: 100px;" data-col="category">
                            <div class="d-flex align-items-center gap-1"><span>الفئة</span><button type="button" class="btn btn-sm p-0 erp-pb-col-filter-btn" data-col="category" data-col-title="الفئة" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button></div>
                        </th>
                        <th style="min-width: 120px;" data-col="productGroup">
                            <div class="d-flex align-items-center gap-1"><span>مجموعة الصنف</span><button type="button" class="btn btn-sm p-0 erp-pb-col-filter-btn" data-col="productGroup" data-col-title="مجموعة الصنف" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button></div>
                        </th>
                        <th style="min-width: 120px;" data-col="bonusGroup">
                            <div class="d-flex align-items-center gap-1"><span>مجموعة البونص</span><button type="button" class="btn btn-sm p-0 erp-pb-col-filter-btn" data-col="bonusGroup" data-col-title="مجموعة البونص" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button></div>
                        </th>
                        <th style="min-width: 100px;" data-col="company">الشركة</th>
                        <th style="min-width: 90px;" data-col="imported">محلي/مستورد</th>
                        <th style="min-width: 120px;" data-col="description">الوصف</th>
                        <th class="text-end" style="min-width: 100px;" data-col="qty">
                            <div class="d-flex align-items-center justify-content-end gap-1">
                                <span>الكمية الحالية</span>
                                <button type="button" class="btn btn-sm p-0 erp-pb-col-filter-btn" data-col="qty" data-sort-key="qty" data-col-title="الكمية الحالية" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                            </div>
                        </th>
                        <th class="text-end" style="min-width: 100px;" data-col="discount">
                            <div class="d-flex align-items-center justify-content-end gap-1"><span>الخصم المرجح %</span><button type="button" class="btn btn-sm p-0 erp-pb-col-filter-btn" data-col="discount" data-col-title="الخصم المرجح %" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button></div>
                        </th>
                        <th class="text-end d-print-none" style="min-width: 140px;" data-col="manualDiscount" title="لو الصنف ليس له خصم يدوي يُستخدم الخصم المرجّح (عمود الخصم المرجح %).">
                            <span>الخصم اليدوي للبيع %</span>
                        </th>
                        <th class="text-end" style="min-width: 100px;" data-col="sales">
                            <div class="d-flex align-items-center justify-content-end gap-1">
                                <span>المبيعات</span>
                                <button type="button" class="btn btn-sm p-0 erp-pb-col-filter-btn" data-col="sales" data-sort-key="sales" data-col-title="المبيعات" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                            </div>
                        </th>
                        <th class="text-end" style="min-width: 110px;" data-col="priceRetail">
                            <div class="d-flex align-items-center justify-content-end gap-1"><span>سعر الجمهور</span><button type="button" class="btn btn-sm p-0 erp-pb-col-filter-btn" data-col="priceRetail" data-col-title="سعر الجمهور" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button></div>
                        </th>
                        <th class="text-end" style="min-width: 110px;" data-col="unitCost">
                            <div class="d-flex align-items-center justify-content-end gap-1"><span>تكلفة العلبة</span><button type="button" class="btn btn-sm p-0 erp-pb-col-filter-btn" data-col="unitCost" data-col-title="تكلفة العلبة" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button></div>
                        </th>
                        <th class="text-end" style="min-width: 120px;" data-col="cost">
                            <div class="d-flex align-items-center justify-content-end gap-1">
                                <span>التكلفة الإجمالية</span>
                                <button type="button" class="btn btn-sm p-0 erp-pb-col-filter-btn" data-col="cost" data-sort-key="cost" data-col-title="التكلفة الإجمالية" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                            </div>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @if (!reportData.Any())
                    {
                        <tr>
                            <td colspan="18" class="text-center text-muted py-4">لا توجد بيانات.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in reportData)
                        {
                            var hasBatches = item.Batches != null && item.Batches.Count >= 2;
                            var movementUrlPb = Url.Action("Show", "Products", new { id = item.ProdId }) + "?frame=1";
                            <tr class="erp-list-selectable-row" data-pb-row data-prod-id="@item.ProdId" data-row-id="@item.ProdId" data-movement-url="@movementUrlPb" data-tab-title="حركة الصنف — @item.ProdCode" data-qty="@item.CurrentQty" data-has-batches="@(hasBatches ? "1" : "0")" data-weighted-discount="@(hasBatches ? "" : item.WeightedDiscount.ToString("G29", System.Globalization.CultureInfo.InvariantCulture))">
                                <td class="text-center align-middle no-print" data-col="select">
                                    <input type="checkbox" class="row-select" value="@item.ProdId" title="تحديد الصف" />
                                </td>
                                <td data-col="code" class="align-middle">
                                    @if (hasBatches)
                                    {
                                        <button type="button" class="btn btn-link btn-sm p-0 text-secondary erp-pb-toggle-batches" data-prod-id="@item.ProdId" tabindex="0" title="فتح/إغلاق التشغيلات — Enter: فتح والانتقال لأول تشغيلة" aria-label="فتح التشغيلات">
                                            <span class="erp-pb-chevron">▶</span>
                                        </button>
                                        <span class="me-1">@item.ProdCode</span>
                                    }
                                    else
                                    {
                                        @item.ProdCode
                                    }
                                </td>
                                <td data-col="name">@item.ProdName</td>
                                <td data-col="batch"><small class="text-muted">@(hasBatches ? "—" : (!string.IsNullOrEmpty(item.FirstBatchNo) || item.FirstBatchExpiry.HasValue ? (item.FirstBatchNo ?? "—") : "—"))</small></td>
                                <td data-col="date" class="text-nowrap"><small class="text-muted">@(hasBatches ? "—" : (item.FirstBatchExpiry.HasValue ? item.FirstBatchExpiry.Value.ToString("d/M/yyyy") : "—"))</small></td>
                                <td data-col="category"><small class="text-muted">@item.CategoryName</small></td>
                                <td data-col="productGroup"><small class="text-muted">@item.ProductGroupName</small></td>
                                <td data-col="bonusGroup"><small class="text-muted">@item.ProductBonusGroupName</small></td>
                                <td data-col="company"><small class="text-muted">@(item.Company ?? "—")</small></td>
                                <td data-col="imported"><small class="text-muted">@(item.Imported ?? "—")</small></td>
                                <td data-col="description"><small class="text-muted text-truncate d-inline-block" style="max-width:180px;" title="@item.Description">@(item.Description ?? "—")</small></td>
                                <td data-col="qty" class="text-end">@item.CurrentQty.ToString("N0")</td>
                                <td data-col="discount" class="text-end">@item.WeightedDiscount.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)</td>
                                <td data-col="manualDiscount" class="text-end d-print-none">
                                    @if (hasBatches)
                                    {
                                        <span class="text-muted small">عدّل في التشغيلات أدناه</span>
                                    }
                                    else
                                    {
                                        <input type="number" step="0.01" min="0" max="100" class="form-control form-control-sm text-end erp-pb-manual-discount-inp" style="width:70px;min-width:70px;margin-left:auto;" value="@(item.ManualDiscountPct?.ToString("N2", System.Globalization.CultureInfo.InvariantCulture) ?? "")" title="الخصم اليدوي للبيع % — Enter: حفظ والانتقال للصف التالي" data-prod-id="@item.ProdId" data-warehouse-id="@(warehouseId?.ToString() ?? "")" data-batch-id="" />
                                    }
                                </td>
                                <td data-col="sales" class="text-end">@item.SalesQty.ToString("N2")</td>
                                <td data-col="priceRetail" class="text-end">@item.PriceRetail.ToString("N2")</td>
                                <td data-col="unitCost" class="text-end">@item.UnitCost.ToString("N2")</td>
                                <td data-col="cost" class="text-end">@item.TotalCost.ToString("N2")</td>
                            </tr>
                            @if (hasBatches)
                            {
                                @foreach (var batch in item.Batches!)
                                {
                                    <tr class="erp-pb-batch-row erp-pb-batches-for" data-pb-batch-row data-prod-id="@item.ProdId" data-batch-id="@(batch.BatchId ?? 0)" data-qty="@batch.CurrentQty" data-pb-batches-for="@item.ProdId" data-weighted-discount="@batch.WeightedDiscount.ToString("G29", System.Globalization.CultureInfo.InvariantCulture)" style="display: none;">
                                        <td data-col="select" class="no-print"></td>
                                        <td data-col="code"></td>
                                        <td data-col="name" class="text-secondary" style="padding-right: 1.5rem;"><small>└ @(batch.BatchNo ?? "-")</small></td>
                                        <td data-col="batch"><small class="text-muted">@(batch.BatchNo ?? "—")</small></td>
                                        <td data-col="date"><small class="text-muted">@(batch.Expiry.HasValue ? batch.Expiry.Value.ToString("d/M/yyyy") : "—")</small></td>
                                        <td data-col="category"></td>
                                        <td data-col="productGroup"></td>
                                        <td data-col="bonusGroup"></td>
                                        <td data-col="company"></td>
                                        <td data-col="imported"></td>
                                        <td data-col="description"></td>
                                        <td data-col="qty" class="text-end">@batch.CurrentQty.ToString("N0")</td>
                                        <td data-col="discount" class="text-end">@(batch.WeightedDiscount.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) + " %")</td>
                                        <td data-col="manualDiscount" class="text-end d-print-none">
                                            <input type="number" step="0.01" min="0" max="100" class="form-control form-control-sm text-end erp-pb-manual-discount-inp" style="width:70px;min-width:70px;margin-left:auto;" value="@(batch.ManualDiscountPct?.ToString("N2", System.Globalization.CultureInfo.InvariantCulture) ?? "")" data-prod-id="@item.ProdId" data-warehouse-id="@(warehouseId?.ToString() ?? "")" data-batch-id="@(batch.BatchId?.ToString() ?? "")" />
                                        </td>
                                        <td data-col="sales" class="text-end">@batch.SalesQty.ToString("N2")</td>
                                        <td data-col="priceRetail" class="text-end">@batch.PriceRetail.ToString("N2")</td>
                                        <td data-col="unitCost" class="text-end">@batch.UnitCost.ToString("N2")</td>
                                        <td data-col="cost" class="text-end">@batch.TotalCost.ToString("N2")</td>
                                    </tr>
                                }
                            }
                        }
                    }
                </tbody>
                @if (reportData.Any())
                {
                    <tfoot class="table-secondary fw-bold" id="productBalancesFooter" data-total-qty="@totalQty" data-total-sales="@totalSalesQty.ToString("G", System.Globalization.CultureInfo.InvariantCulture)" data-total-priceretail="@totalPriceRetail.ToString("G", System.Globalization.CultureInfo.InvariantCulture)" data-total-unitcost="@totalUnitCost.ToString("G", System.Globalization.CultureInfo.InvariantCulture)" data-total-cost="@totalCost.ToString("G", System.Globalization.CultureInfo.InvariantCulture)">
                        <tr>
                            <td data-col="select" class="no-print"></td>
                            <td data-col="code" class="text-end"><strong>المجموع الإجمالي</strong></td>
                            <td data-col="name"></td>
                            <td data-col="batch"></td>
                            <td data-col="date"></td>
                            <td data-col="category"></td>
                            <td data-col="productGroup"></td>
                            <td data-col="bonusGroup"></td>
                            <td data-col="company"></td>
                            <td data-col="imported"></td>
                            <td data-col="description"></td>
                            <td data-col="qty" id="productBalancesFooterQty" class="text-end"><strong>@totalQty.ToString("N0")</strong></td>
                            <td data-col="discount" class="text-end text-muted"><small>—</small></td>
                            <td data-col="manualDiscount" class="d-print-none text-muted"><small>—</small></td>
                            <td data-col="sales" id="productBalancesFooterSales" class="text-end"><strong>@totalSalesQty.ToString("N2")</strong></td>
                            <td data-col="priceRetail" id="productBalancesFooterPriceRetail" class="text-end"><strong>@totalPriceRetail.ToString("N2")</strong></td>
                            <td data-col="unitCost" id="productBalancesFooterUnitCost" class="text-end"><strong>@totalUnitCost.ToString("N2")</strong></td>
                            <td data-col="cost" id="productBalancesFooterCost" class="text-end"><strong class="product-balances-total-value">@totalCost.ToString("N2")</strong></td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>

    @* ===== شريط الترقيم تحت الجدول (حجم الصفحة + عرض من-إلى + تنقل) — محاذاة لليمين ===== *@
    @if (reportData.Any())
    {
        var ps = pageSize;
        var startRow = totalCount == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
        var endRow = (ps == 0 || totalCount == 0) ? totalCount : Math.Min(totalCount, page * ps);
        <div class="d-flex flex-wrap justify-content-end align-items-center gap-3 mt-2 no-print" id="productBalancesPaginationBar" dir="rtl">
            <small class="text-muted" id="productBalancesPaginationText">
                عرض @startRow - @endRow من @totalCount
            </small>
            <form method="get" asp-action="ProductBalances" asp-controller="Reports" class="d-flex align-items-center gap-2">
                <input type="hidden" name="loadReport" value="true" />
                <input type="hidden" name="search" value="@search" />
                <input type="hidden" name="searchMode" value="@searchMode" />
                <input type="hidden" name="categoryId" value="@(categoryId?.ToString() ?? "")" />
                <input type="hidden" name="productGroupId" value="@(productGroupId?.ToString() ?? "")" />
                <input type="hidden" name="hasBonus" value="@(hasBonus == true ? "true" : "false")" />
                <input type="hidden" name="warehouseId" value="@(warehouseId?.ToString() ?? "")" />
                <input type="hidden" name="fromDate" value="@(fromDate.HasValue ? fromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                <input type="hidden" name="toDate" value="@(toDate.HasValue ? toDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                <input type="hidden" name="pbQtyGtZero" value="@(pbQtyGtZeroChecked ? "true" : "false")" />
                <input type="hidden" name="includeBatches" value="true" />
                <input type="hidden" name="sortBy" value="@(sortBy ?? "name")" />
                <input type="hidden" name="sortDir" value="@(sortDir ?? "asc")" />
                <input type="hidden" name="page" value="1" />
                <label class="form-label m-0 nowrap">حجم الصفحة</label>
                <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="10" @(pageSize == 10 ? "selected" : null)>10</option>
                    <option value="25" @(pageSize == 25 ? "selected" : null)>25</option>
                    <option value="50" @(pageSize == 50 ? "selected" : null)>50</option>
                    <option value="100" @(pageSize == 100 ? "selected" : null)>100</option>
                    <option value="200" @(pageSize == 200 ? "selected" : null)>200</option>
                    <option value="0" @(pageSize == 0 ? "selected" : null)>الكل</option>
                </select>
            </form>
            <nav aria-label="pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(page == 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(1)">الأول</a>
                    </li>
                    <li class="page-item @(page == 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page - 1)">السابق</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">صفحة @(page) من @(totalPages)</span>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page + 1)">التالي</a>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(totalPages)">الأخير</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@* مودال اختيار الأعمدة (نفس فكرة قائمة الأصناف) *@
<div class="modal fade no-print" id="columnsModalProductBalances" tabindex="-1" aria-labelledby="columnsModalProductBalancesLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" dir="rtl">
            <div class="modal-header text-white" style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); border-bottom: none;">
                <h5 class="modal-title flex-grow-1" id="columnsModalProductBalancesLabel">اختيار الأعمدة الظاهرة في تقرير أرصدة الأصناف</h5>
                <button type="button" class="btn-close btn-close-white ms-2" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div class="small text-muted mb-2">ضع علامة ✓ أمام الأعمدة التي تريد ظهورها في الجدول.</div>
                <div id="columnsListProductBalances"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-erp btn-erp-secondary" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" id="btnApplyColumnsProductBalances" class="btn btn-erp btn-erp-primary">تطبيق</button>
            </div>
        </div>
    </div>
</div>

@* لوحة ترتيب وفلتر العمود (مثل قائمة الأصناف — زر واحد: ترتيب + فلترة نصية أو رقمية) *@
<div id="erpPbColumnFilterPanel" class="erp-column-filter-panel d-none" dir="rtl">
    <div class="erp-column-filter-header">
        <span id="erpPbColumnFilterTitle">ترتيب وفلتر</span>
        <button type="button" class="btn-close btn-sm" id="erpPbColumnFilterClose" aria-label="إغلاق"></button>
    </div>
    <div class="erp-column-filter-body">
        <div id="erpPbSortSection" class="erp-filter-sort-section mb-3 pb-2 border-bottom">
            <label class="form-label small mb-1 fw-bold">الترتيب:</label>
            <div class="d-flex flex-column gap-1">
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-pb-sort-btn" data-sort-dir="asc"><span class="me-2">▲</span> ترتيب تصاعدي</button>
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-pb-sort-btn" data-sort-dir="desc"><span class="me-2">▼</span> ترتيب تنازلي</button>
            </div>
        </div>
        <div class="erp-filter-section">
            <div id="erpPbFilterSearchRow">
                <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                <input type="text" id="erpPbColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
            </div>
            <div id="erpPbColumnFilterList" class="erp-column-filter-list"></div>
        </div>
        <div class="erp-column-filter-actions mt-2">
            <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpPbColumnFilterOk">تطبيق</button>
            <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpPbColumnFilterClear">مسح الفلتر</button>
        </div>
    </div>
</div>

