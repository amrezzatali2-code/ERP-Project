@section Scripts {
    <script>
        // زر تصفير كميات وهمية: عرض رسالة تأكيد ثم إرسال النموذج
        (function () {
            var btn = document.getElementById('btnZeroPhantomProductBalances');
            var form = document.getElementById('formZeroPhantomProductBalances');
            if (btn && form) {
                btn.addEventListener('click', function () {
                    if (confirm('سيتم تصفير كميات المرتجعات الوهمية (التي تظهر في فاتورة المبيعات فقط). هل تريد المتابعة؟')) {
                        form.submit();
                    }
                });
            }
        })();

        // فتح حركة الصنف / تعديل الصنف في تاب (نفس نظام قائمة الأصناف)
        (function () {
            document.addEventListener('click', function (e) {
                var link = e.target.closest('a.erp-pb-open-tab');
                if (!link) return;
                e.preventDefault();
                e.stopPropagation();
                var url = (link.getAttribute('href') || link.href || '').trim();
                if (!url) return;
                url = url + (url.indexOf('?') >= 0 ? '&' : '?') + 'frame=1';
                var tabId = (link.getAttribute('data-tab-id') || '').trim();
                var title = (link.getAttribute('data-tab-title') || 'حركة الصنف').trim();
                try {
                    if (window.top && window.top !== window) {
                        window.top.postMessage({ type: 'erp-open-tab', tabId: tabId, title: title, url: url }, '*');
                        return;
                    }
                } catch (err) { console.error('erp-pb-open-tab:', err); }
                if (window.top.erpTabs && typeof window.top.erpTabs.openTab === 'function')
                    window.top.erpTabs.openTab(tabId, url, title);
                else
                    window.location.href = url;
            });
        })();

        // ضمان إرسال includeZeroQty حتى لو كان checkbox غير مفعّل + تثبيت اختيار المخزن من الـ URL
        document.addEventListener('DOMContentLoaded', function () {
            // الشريط الأفقي يكون ناحية اليمين عند فتح التقرير (إظهار أعمدة اليمين أولاً)
            var scrollWrapper = document.getElementById('productBalancesScrollWrapper');
            if (scrollWrapper) {
                function scrollHorizontalToRight() {
                    var maxScroll = scrollWrapper.scrollWidth - scrollWrapper.clientWidth;
                    if (maxScroll > 0) scrollWrapper.scrollLeft = maxScroll;
                }
                requestAnimationFrame(function () { requestAnimationFrame(scrollHorizontalToRight); });
            }

            const form = document.getElementById('filtersForm');
            const includeZeroCb = document.getElementById('includeZeroQty');
            var warehouseSelect = document.getElementById('warehouseIdSelect');
            if (warehouseSelect) {
                var url = new URL(window.location.href);
                var whFromUrl = url.searchParams.get('warehouseId');
                if (whFromUrl !== null && whFromUrl !== '') {
                    warehouseSelect.value = whFromUrl;
                }
            }
            if (form) {
                form.addEventListener('submit', function (e) {
                    var existingHidden = form.querySelector('input[name="includeZeroQty"][type="hidden"]');
                    if (existingHidden) existingHidden.remove();
                    if (includeZeroCb && !includeZeroCb.checked) {
                        var hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = 'includeZeroQty';
                        hidden.value = 'false';
                        form.appendChild(hidden);
                    }
                });
            }

            // فتح/إغلاق صفوف التشغيلات عند النقر على السهم؛ Enter على السهم المغلق يفتح التشغيلات وينقل الفوكس لأول حقل خصم
            document.querySelectorAll('.erp-pb-toggle-batches').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var prodId = this.getAttribute('data-prod-id');
                    var chevron = this.querySelector('.erp-pb-chevron');
                    var batchRows = document.querySelectorAll('tr.erp-pb-batches-for[data-pb-batches-for="' + prodId + '"]');
                    if (!batchRows.length || !chevron) return;
                    var isHidden = batchRows[0].style.display === 'none';
                    batchRows.forEach(function (tr) { tr.style.display = isHidden ? '' : 'none'; });
                    chevron.textContent = isHidden ? '▼' : '▶';
                });
                btn.addEventListener('keydown', function (e) {
                    if (e.key !== 'Enter') return;
                    var prodId = this.getAttribute('data-prod-id');
                    var batchRows = document.querySelectorAll('tr.erp-pb-batches-for[data-pb-batches-for="' + prodId + '"]');
                    if (!batchRows.length) return;
                    var isHidden = batchRows[0].style.display === 'none';
                    if (isHidden) {
                        e.preventDefault();
                        this.click();
                        var firstInp = batchRows[0].querySelector('.erp-pb-manual-discount-inp');
                        if (firstInp) {
                            setTimeout(function () { firstInp.focus(); firstInp.select(); }, 50);
                        }
                    }
                });
            });

            // حفظ الخصم اليدوي للبيع (بدون رسالة نجاح — Enter: حفظ ونقل الفوكس للصف التالي، زر عام: حفظ الكل)
            (function () {
                var tbl = document.getElementById('productBalancesTable');
                var tokenEl = document.querySelector('#__AntiForgeryFormProductBalances input[name="__RequestVerificationToken"]');
                if (!tbl || !tokenEl) return;

                function saveOneRow(inp) {
                    var productId = parseInt(inp.getAttribute('data-prod-id') || '0', 10);
                    var warehouseIdStr = (inp.getAttribute('data-warehouse-id') || '').trim();
                    var batchIdStr = (inp.getAttribute('data-batch-id') || '').trim();
                    if (productId <= 0) return Promise.resolve();
                    var rawVal = (inp.value || '').replace(/,/g, '').trim();
                    var manualDiscountPct = rawVal === '' ? null : parseFloat(rawVal);
                    if (manualDiscountPct !== null && (isNaN(manualDiscountPct) || manualDiscountPct < 0)) manualDiscountPct = null;
                    if (manualDiscountPct !== null && manualDiscountPct > 100) manualDiscountPct = 100;

                    var formData = new FormData();
                    formData.append('__RequestVerificationToken', tokenEl.value);
                    formData.append('productId', productId);
                    if (warehouseIdStr && !isNaN(parseInt(warehouseIdStr, 10))) formData.append('warehouseId', warehouseIdStr);
                    if (batchIdStr && !isNaN(parseInt(batchIdStr, 10))) formData.append('batchId', batchIdStr);
                    if (manualDiscountPct !== null) formData.append('manualDiscountPct', manualDiscountPct);

                    return fetch('@Url.Action("SaveManualDiscount", "Reports")', {
                        method: 'POST',
                        body: formData,
                        headers: { 'RequestVerificationToken': tokenEl.value }
                    }).then(function (r) { return r.json(); });
                }

                function getOrderedManualDiscountInputs() {
                    var rows = tbl.querySelectorAll('tbody tr[data-pb-row], tbody tr.erp-pb-batch-row');
                    var list = [];
                    rows.forEach(function (tr) {
                        if (tr.style.display === 'none') return;
                        var inp = tr.querySelector('.erp-pb-manual-discount-inp');
                        if (inp) list.push(inp);
                    });
                    return list;
                }

                // Enter: حفظ الصف الحالي بدون رسالة ثم نقل الفوكس للصف التالي
                tbl.querySelectorAll('.erp-pb-manual-discount-inp').forEach(function (inp) {
                    inp.addEventListener('keydown', function (e) {
                        if (e.key !== 'Enter') return;
                        e.preventDefault();
                        var currentInp = this;
                        saveOneRow(currentInp).then(function () {
                            var all = getOrderedManualDiscountInputs();
                            var idx = all.indexOf(currentInp);
                            if (idx >= 0 && idx < all.length - 1) {
                                all[idx + 1].focus();
                                all[idx + 1].select();
                            }
                        });
                    });
                });

                // زر الحفظ العام: حفظ كل الصفوف الظاهرة بدون رسالة
                var btnAll = document.getElementById('erpPbSaveAllManualDiscount');
                if (btnAll) {
                    btnAll.addEventListener('click', function () {
                        var inputs = getOrderedManualDiscountInputs();
                        if (inputs.length === 0) return;
                        btnAll.disabled = true;
                        var promises = inputs.map(function (inp) { return saveOneRow(inp); });
                        Promise.all(promises).then(function () {
                            btnAll.disabled = false;
                        }).catch(function () {
                            btnAll.disabled = false;
                        });
                    });
                }

                // زر نقل المرجّح → يدوي (بعد التقريب): يملأ خانة الخصم اليدوي من الخصم المرجّح مقرّباً ثم يحفظ
                var btnCopy = document.getElementById('erpPbCopyWeightedToManual');
                if (btnCopy) {
                    btnCopy.addEventListener('click', function () {
                        var inputs = getOrderedManualDiscountInputs();
                        if (inputs.length === 0) return;
                        btnCopy.disabled = true;
                        var rounded = function (val) {
                            var n = parseFloat(val);
                            if (isNaN(n)) return 0;
                            return Math.round(n * 100) / 100;
                        };
                        inputs.forEach(function (inp) {
                            var row = inp.closest('tr');
                            var w = (row && row.getAttribute('data-weighted-discount')) ? row.getAttribute('data-weighted-discount').trim() : '';
                            if (w !== '') {
                                var r = rounded(w);
                                inp.value = r.toFixed(2);
                            }
                        });
                        var promises = inputs.map(function (inp) { return saveOneRow(inp); });
                        Promise.all(promises).then(function () {
                            btnCopy.disabled = false;
                        }).catch(function () {
                            btnCopy.disabled = false;
                        });
                    });
                }
            })();
        });

        // ترتيب وفلتر الأعمدة (زر واحد: ترتيب + فلترة نصية أو رقمية — مثل قائمة الأصناف)
        (function () {
            const table = document.getElementById('productBalancesTable');
            const panel = document.getElementById('erpPbColumnFilterPanel');
            const titleEl = document.getElementById('erpPbColumnFilterTitle');
            const sortSection = document.getElementById('erpPbSortSection');
            const searchRow = document.getElementById('erpPbFilterSearchRow');
            const searchInp = document.getElementById('erpPbColumnFilterSearch');
            const listEl = document.getElementById('erpPbColumnFilterList');
            const btnOk = document.getElementById('erpPbColumnFilterOk');
            const btnClear = document.getElementById('erpPbColumnFilterClear');
            const btnClose = document.getElementById('erpPbColumnFilterClose');
            if (!table || !panel || !listEl) return;

            const numericColumns = ['code', 'qty', 'discount', 'manualDiscount', 'sales', 'priceRetail', 'unitCost', 'cost'];
            let currentCol = null;
            let currentSortKey = null;
            let currentFilterBtn = null;
            let selectedValues = new Set();

            function getCurrentSort() {
                var url = new URL(window.location.href);
                return { sortBy: url.searchParams.get('sortBy') || 'name', sortDir: url.searchParams.get('sortDir') || 'asc' };
            }

            function parseCellNumber(td) {
                if (!td) return NaN;
                var t = (td.textContent || '').replace(/,/g, '').trim();
                return parseFloat(t) || NaN;
            }

            function matchNumericExpr(num, expr) {
                if (expr === '' || expr == null) return true;
                expr = String(expr).trim();
                if (!expr) return true;
                if (expr.indexOf(':') !== -1) {
                    var parts = expr.split(':');
                    var a = parseFloat(String(parts[0]).trim());
                    var b = parseFloat(String(parts[1]).trim());
                    if (isNaN(a) || isNaN(b)) return true;
                    return num >= Math.min(a, b) && num <= Math.max(a, b);
                }
                if (expr.indexOf('>') === 0) {
                    var v = parseFloat(expr.substring(1).trim());
                    return !isNaN(v) && num > v;
                }
                if (expr.indexOf('<') === 0) {
                    var v = parseFloat(expr.substring(1).trim());
                    return !isNaN(v) && num < v;
                }
                var exact = parseFloat(expr);
                return !isNaN(exact) && (isNaN(num) ? false : Math.abs(num - exact) < 1e-6);
            }

            function getDistinctValues(col) {
                var cells = table.querySelectorAll('tbody tr[data-pb-row] td[data-col="' + col + '"]');
                var set = new Set();
                cells.forEach(function (td) {
                    var inp = td.querySelector('.erp-pb-manual-discount-inp');
                    var v = (col === 'manualDiscount' && inp) ? (inp.value || '').trim() : (td.textContent || '').trim();
                    if (v) set.add(v);
                });
                return Array.from(set).sort();
            }

            function getCellNumericValue(td, col) {
                if (!td) return NaN;
                if (col === 'manualDiscount') {
                    var inp = td.querySelector('.erp-pb-manual-discount-inp');
                    if (inp) { var n = parseFloat(String(inp.value).replace(/,/g, '').trim()); return isNaN(n) ? 0 : n; }
                }
                if (col === 'discount') {
                    var t = (td.textContent || '').replace(/,/g, '').trim();
                    return parseFloat(t) || NaN;
                }
                var t = (td.textContent || '').replace(/,/g, '').trim();
                return parseFloat(t) || NaN;
            }

            function updateFooterTotals() {
                var rows = table.querySelectorAll('tbody tr[data-pb-row]');
                var totalQty = 0, totalSales = 0, totalPriceRetail = 0, totalUnitCost = 0, totalCost = 0, visibleCount = 0;
                rows.forEach(function (tr) {
                    if (tr.style.display === 'none') return;
                    visibleCount++;
                    var qty = parseInt(tr.getAttribute('data-qty') || '0', 10) || 0;
                    totalQty += qty;
                    var salesTd = tr.querySelector('td[data-col="sales"]');
                    var priceTd = tr.querySelector('td[data-col="priceRetail"]');
                    var unitCostTd = tr.querySelector('td[data-col="unitCost"]');
                    var costTd = tr.querySelector('td[data-col="cost"]');
                    totalSales += parseCellNumber(salesTd);
                    totalPriceRetail += parseCellNumber(priceTd);
                    totalUnitCost += parseCellNumber(unitCostTd);
                    totalCost += parseCellNumber(costTd);
                });
                var footerQty = document.getElementById('productBalancesFooterQty');
                var footerSales = document.getElementById('productBalancesFooterSales');
                var footerPriceRetail = document.getElementById('productBalancesFooterPriceRetail');
                var footerUnitCost = document.getElementById('productBalancesFooterUnitCost');
                var footerCost = document.getElementById('productBalancesFooterCost');
                if (footerQty) footerQty.innerHTML = '<strong>' + totalQty.toLocaleString('ar-EG') + '</strong>';
                if (footerSales) footerSales.innerHTML = '<strong>' + totalSales.toFixed(2) + '</strong>';
                if (footerPriceRetail) footerPriceRetail.innerHTML = '<strong>' + totalPriceRetail.toFixed(2) + '</strong>';
                if (footerUnitCost) footerUnitCost.innerHTML = '<strong>' + totalUnitCost.toFixed(2) + '</strong>';
                if (footerCost) footerCost.innerHTML = '<strong class="product-balances-total-value">' + totalCost.toFixed(2) + '</strong>';
                var paginationText = document.getElementById('productBalancesPaginationText');
                if (paginationText) paginationText.textContent = 'عرض 1 - ' + visibleCount + ' من ' + visibleCount;
            }

            function restoreFooterTotals() {
                var footer = document.getElementById('productBalancesFooter');
                if (!footer) return;
                var totalQty = footer.getAttribute('data-total-qty') || '0';
                var totalSales = footer.getAttribute('data-total-sales') || '0';
                var totalPriceRetail = footer.getAttribute('data-total-priceretail') || '0';
                var totalUnitCost = footer.getAttribute('data-total-unitcost') || '0';
                var totalCost = footer.getAttribute('data-total-cost') || '0';
                var totalCount = table.getAttribute('data-pb-total-count') || '0';
                var pageSize = @(pageSize);
                var page = @(page);
                var from = (page - 1) * pageSize + 1;
                var toStr = Math.min(page * pageSize, parseInt(totalCount, 10));
                var footerQty = document.getElementById('productBalancesFooterQty');
                var footerSales = document.getElementById('productBalancesFooterSales');
                var footerPriceRetail = document.getElementById('productBalancesFooterPriceRetail');
                var footerUnitCost = document.getElementById('productBalancesFooterUnitCost');
                var footerCost = document.getElementById('productBalancesFooterCost');
                if (footerQty) footerQty.innerHTML = '<strong>' + parseFloat(totalQty).toLocaleString('ar-EG') + '</strong>';
                if (footerSales) footerSales.innerHTML = '<strong>' + parseFloat(totalSales).toFixed(2) + '</strong>';
                if (footerPriceRetail) footerPriceRetail.innerHTML = '<strong>' + parseFloat(totalPriceRetail).toFixed(2) + '</strong>';
                if (footerUnitCost) footerUnitCost.innerHTML = '<strong>' + parseFloat(totalUnitCost).toFixed(2) + '</strong>';
                if (footerCost) footerCost.innerHTML = '<strong class="product-balances-total-value">' + parseFloat(totalCost).toFixed(2) + '</strong>';
                var paginationText = document.getElementById('productBalancesPaginationText');
                if (paginationText) paginationText.textContent = 'عرض ' + from + ' - ' + toStr + ' من ' + totalCount;
            }

            function applySort(sortKey, sortDir) {
                var url = new URL(window.location.href);
                url.searchParams.set('sortBy', sortKey);
                url.searchParams.set('sortDir', sortDir);
                url.searchParams.set('loadReport', 'true');
                url.searchParams.set('page', '1');
                window.location.href = url.toString();
            }

            function showPanel(btn) {
                currentCol = btn.dataset.col;
                currentSortKey = btn.dataset.sortKey || null;
                currentFilterBtn = btn;
                var colTitle = btn.dataset.colTitle || currentCol;
                titleEl.textContent = 'ترتيب وفلتر: ' + colTitle;
                selectedValues = new Set();
                if (searchInp) searchInp.value = '';

                if (sortSection) {
                    sortSection.style.display = currentSortKey ? '' : 'none';
                    if (currentSortKey) {
                        var cur = getCurrentSort();
                        var isCurrent = (cur.sortBy || '').toLowerCase() === (currentSortKey || '').toLowerCase();
                        var curDir = isCurrent ? cur.sortDir : 'asc';
                        panel.querySelectorAll('.erp-pb-sort-btn').forEach(function (b) {
                            if (isCurrent && b.dataset.sortDir === curDir) {
                                b.classList.add('active', 'btn-primary');
                                b.classList.remove('btn-outline-secondary');
                            } else {
                                b.classList.remove('active', 'btn-primary');
                                b.classList.add('btn-outline-secondary');
                            }
                        });
                    }
                }

                if (numericColumns.indexOf(currentCol) !== -1) {
                    if (searchRow) searchRow.style.display = 'none';
                    listEl.innerHTML = '<div class="mb-2">' +
                        '<label class="form-label small mb-1 fw-bold">بحث رقمي:</label>' +
                        '<input type="text" id="erpPbNumericExpr" class="form-control form-control-sm" placeholder="اكتب القيمة أو استخدم: &lt;10, &gt;100, 10:100">' +
                        '<small class="text-muted d-block mt-1">مثال: 53812 أو &gt;10 أو &lt;100 أو 10:100</small></div>';
                    setTimeout(function () {
                        var exprInp = document.getElementById('erpPbNumericExpr');
                        if (exprInp) {
                            exprInp.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); applyFilter(); } });
                            exprInp.focus();
                        }
                    }, 50);
                } else {
                    if (searchRow) searchRow.style.display = '';
                    var values = getDistinctValues(currentCol);
                    var allChecked = true;
                    var html = '<div class="form-check mb-1">' +
                        '<input type="checkbox" class="form-check-input" id="erpPbFilterSelectAll" ' + (allChecked ? 'checked' : '') + '>' +
                        '<label class="form-check-label small" for="erpPbFilterSelectAll">(تحديد الكل)</label></div>' +
                        '<div class="erp-filter-items" style="max-height:320px;overflow-y:auto;">';
                    values.forEach(function (v) {
                        html += '<div class="form-check"><input type="checkbox" class="form-check-input erp-pb-filter-cb" value="' + String(v).replace(/"/g, '&quot;') + '" checked data-value="' + String(v).replace(/"/g, '&quot;') + '">' +
                            '<label class="form-check-label small">' + String(v).replace(/</g, '&lt;') + '</label></div>';
                    });
                    html += '</div>';
                    listEl.innerHTML = html;
                    var selectAllCb = listEl.querySelector('#erpPbFilterSelectAll');
                    if (selectAllCb) {
                        selectAllCb.addEventListener('change', function () {
                            var chk = this.checked;
                            listEl.querySelectorAll('.erp-pb-filter-cb').forEach(function (cb) { cb.checked = chk; });
                        });
                    }
                    listEl.querySelectorAll('.erp-pb-filter-cb').forEach(function (cb) {
                        cb.addEventListener('change', function () {
                            var list = listEl.querySelectorAll('.erp-pb-filter-cb');
                            var checked = listEl.querySelectorAll('.erp-pb-filter-cb:checked').length;
                            if (selectAllCb) { selectAllCb.checked = checked === list.length; selectAllCb.indeterminate = checked > 0 && checked < list.length; }
                        });
                    });
                }

                panel.classList.remove('d-none');
                var r = btn.getBoundingClientRect();
                panel.style.position = 'fixed';
                var panelW = 320;
                var panelH = window.innerHeight * 0.75;
                var left = r.left;
                var top = r.bottom + 4;
                if (left + panelW > window.innerWidth) left = Math.max(0, window.innerWidth - panelW);
                if (left < 0) left = 0;
                if (top + panelH > window.innerHeight) top = Math.max(4, window.innerHeight - panelH - 8);
                if (top < 0) top = 4;
                panel.style.left = left + 'px';
                panel.style.top = top + 'px';
            }

            function updateItemCount() {
                var el = document.getElementById('productBalancesItemCount');
                if (!el) return;
                var rows = table.querySelectorAll('tbody tr[data-pb-row]');
                var visible = 0;
                rows.forEach(function (tr) { if (tr.style.display !== 'none') visible++; });
                el.textContent = visible;
            }

            function applyFilter() {
                if (!currentCol) return;
                var rows = table.querySelectorAll('tbody tr[data-pb-row]');
                if (numericColumns.indexOf(currentCol) !== -1) {
                    var exprInp = document.getElementById('erpPbNumericExpr');
                    var expr = exprInp ? (exprInp.value || '').trim() : '';
                    rows.forEach(function (tr) {
                        var td = tr.querySelector('td[data-col="' + currentCol + '"]');
                        var num = getCellNumericValue(td, currentCol);
                        tr.style.display = matchNumericExpr(num, expr) ? '' : 'none';
                    });
                } else {
                    var checkboxes = listEl.querySelectorAll('.erp-pb-filter-cb:checked');
                    selectedValues = new Set();
                    checkboxes.forEach(function (cb) { selectedValues.add(cb.dataset.value); });
                    rows.forEach(function (tr) {
                        var td = tr.querySelector('td[data-col="' + currentCol + '"]');
                        var v = (td ? td.textContent : '').trim();
                        tr.style.display = selectedValues.size === 0 || selectedValues.has(v) ? '' : 'none';
                    });
                }
                document.querySelectorAll('tr.erp-pb-batches-for').forEach(function (batchRow) {
                    var pid = batchRow.getAttribute('data-pb-batches-for');
                    var productRow = table.querySelector('tr[data-pb-row][data-prod-id="' + pid + '"]');
                    if (!productRow || productRow.style.display === 'none') batchRow.style.display = 'none';
                });
                updateItemCount();
                updateFooterTotals();
                table.querySelectorAll('.erp-pb-col-filter-btn').forEach(function (b) { b.classList.remove('erp-pb-filter-active'); });
                if (currentFilterBtn) currentFilterBtn.classList.add('erp-pb-filter-active');
                panel.classList.add('d-none');
            }

            function clearFilter() {
                if (!currentCol) return;
                table.querySelectorAll('.erp-pb-col-filter-btn').forEach(function (b) { b.classList.remove('erp-pb-filter-active'); });
                table.querySelectorAll('tbody tr[data-pb-row]').forEach(function (tr) { tr.style.display = ''; });
                table.querySelectorAll('tbody tr.erp-pb-batches-for').forEach(function (tr) { /* leave expanded state as is */ });
                selectedValues = new Set();
                var totalEl = document.getElementById('productBalancesItemCount');
                var totalAttr = table.getAttribute('data-pb-total-count');
                if (totalEl && totalAttr !== null && totalAttr !== '') totalEl.textContent = totalAttr;
                restoreFooterTotals();
                panel.classList.add('d-none');
            }

            table.querySelectorAll('.erp-pb-col-filter-btn').forEach(function (btn) {
                btn.addEventListener('click', function (e) { e.preventDefault(); e.stopPropagation(); showPanel(btn); });
            });
            panel.querySelectorAll('.erp-pb-sort-btn').forEach(function (b) {
                b.addEventListener('click', function () {
                    if (currentSortKey) applySort(currentSortKey, this.dataset.sortDir);
                });
            });
            btnOk.addEventListener('click', function () { applyFilter(); });
            btnClear.addEventListener('click', clearFilter);
            btnClose.addEventListener('click', function () { panel.classList.add('d-none'); });
            if (searchInp) {
                searchInp.addEventListener('input', function () {
                    var term = (searchInp.value || '').trim().toLowerCase();
                    listEl.querySelectorAll('.form-check').forEach(function (div) {
                        if (div.querySelector('#erpPbFilterSelectAll')) return;
                        var label = div.querySelector('label');
                        var text = (label ? label.textContent : '').toLowerCase();
                        div.style.display = !term || text.indexOf(term) !== -1 ? '' : 'none';
                    });
                });
            }
            document.addEventListener('click', function (e) {
                if (panel && !panel.classList.contains('d-none') && !panel.contains(e.target) && !e.target.closest('.erp-pb-col-filter-btn'))
                    panel.classList.add('d-none');
            });

            // اختيار الأعمدة (حفظ في localStorage مثل قائمة الأصناف)
            var pbTable = document.getElementById('productBalancesTable');
            if (pbTable) {
                var storageKeyPb = 'product-balances-columns-visibility';
                var headerCellsPb = Array.from(pbTable.querySelectorAll('thead th[data-col]'));
                var columnsPb = headerCellsPb
                    .filter(function (th) { return !th.hasAttribute('data-col-fixed'); })
                    .map(function (th) {
                        var title = th.innerText.trim();
                        var col = th.getAttribute('data-col');
                        return { key: col, title: title };
                    });
                var hiddenPb = [];
                try {
                    var savedPb = localStorage.getItem(storageKeyPb);
                    if (savedPb) hiddenPb = JSON.parse(savedPb);
                } catch (e) { hiddenPb = []; }
                function applyVisibilityPb() {
                    columnsPb.forEach(function (col) {
                        var isHidden = hiddenPb.indexOf(col.key) !== -1;
                        pbTable.querySelectorAll('[data-col="' + col.key + '"]').forEach(function (cell) {
                            cell.classList.toggle('d-none', isHidden);
                        });
                    });
                }
                applyVisibilityPb();
                var listContainerPb = document.getElementById('columnsListProductBalances');
                if (listContainerPb) {
                    listContainerPb.innerHTML = '';
                    columnsPb.forEach(function (col) {
                        var wrap = document.createElement('div');
                        wrap.className = 'form-check mb-1';
                        var cb = document.createElement('input');
                        cb.type = 'checkbox';
                        cb.className = 'form-check-input ms-2';
                        cb.id = 'col_pb_' + col.key;
                        cb.checked = hiddenPb.indexOf(col.key) === -1;
                        cb.dataset.colKey = col.key;
                        var label = document.createElement('label');
                        label.className = 'form-check-label';
                        label.setAttribute('for', cb.id);
                        label.innerText = col.title;
                        wrap.appendChild(cb);
                        wrap.appendChild(label);
                        listContainerPb.appendChild(wrap);
                    });
                }
                document.getElementById('btnApplyColumnsProductBalances')?.addEventListener('click', function () {
                    var checks = listContainerPb ? listContainerPb.querySelectorAll('input[type="checkbox"][data-col-key]') : [];
                    hiddenPb = [];
                    checks.forEach(function (cb) {
                        if (!cb.checked) hiddenPb.push(cb.dataset.colKey);
                    });
                    try { localStorage.setItem(storageKeyPb, JSON.stringify(hiddenPb)); } catch (e) {}
                    applyVisibilityPb();
                    var modal = bootstrap.Modal.getInstance(document.getElementById('columnsModalProductBalances'));
                    if (modal) modal.hide();
                });
            }
        })();
    </script>
}
