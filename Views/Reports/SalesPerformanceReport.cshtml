@model ERP.ViewModels.SalesPerformanceReportViewModel
@{
    ViewData["Title"] = "تقرير أداء المبيعات";
    var fromStr = Model.FromDate?.ToString("yyyy-MM-dd") ?? "";
    var toStr = Model.ToDate?.ToString("yyyy-MM-dd") ?? "";
}

@section Styles {
    <style>
        .erp-performance-report-block .erp-filter-input,
        .erp-performance-report-block .form-control.erp-filter-input,
        .erp-performance-report-block .form-select.erp-filter-input {
            border-color: #94a3b8 !important;
            color: #1f2937;
            box-shadow: none;
        }

        .erp-performance-report-block .erp-filter-input:focus,
        .erp-performance-report-block .form-control.erp-filter-input:focus,
        .erp-performance-report-block .form-select.erp-filter-input:focus {
            border-color: #64748b !important;
            box-shadow: 0 0 0 0.18rem rgba(100, 116, 139, 0.16);
        }

        .erp-performance-report-block .card.erp-kpi-card-outline {
            border-radius: 10px;
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            box-shadow: 0 2px 7px rgba(15, 23, 42, 0.08) !important;
            transition: transform .15s ease, box-shadow .15s ease;
        }

        .erp-performance-report-block .card.erp-kpi-card-outline:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 14px rgba(15, 23, 42, 0.12) !important;
        }

        .erp-performance-report-block .card.border-primary { border-color: #7aa2e3 !important; }
        .erp-performance-report-block .card.border-info { border-color: #6ea8b8 !important; }
        .erp-performance-report-block .card.border-danger { border-color: #d98a96 !important; }
        .erp-performance-report-block .card.border-success { border-color: #7dbf90 !important; }
        .erp-performance-report-block .card.border-secondary { border-color: #98a4b3 !important; }
        .erp-performance-report-block .card.border-dark { border-color: #7a8595 !important; }
        .erp-performance-report-block .card.border-warning { border-color: #d7ad72 !important; }

        .erp-performance-report-block .text-primary { color: #2d6fcf !important; }
        .erp-performance-report-block .text-info { color: #2d7f90 !important; }
        .erp-performance-report-block .text-danger { color: #c65f6d !important; }
        .erp-performance-report-block .text-success { color: #2f8f4c !important; }
        .erp-performance-report-block .text-secondary { color: #516173 !important; }
        .erp-performance-report-block .text-dark { color: #334155 !important; }
        .erp-performance-report-block .text-warning { color: #bc7a2a !important; }
    </style>
}

<div dir="rtl" class="container-fluid py-3">
    <div class="erp-list-filter-bar erp-performance-report-block d-print-none">
        <h4 class="mb-3 fs-5 text-secondary fw-bold">تقرير أداء المبيعات</h4>
        <div class="row g-3 align-items-end flex-wrap">
            <form method="get" asp-action="SalesPerformanceReport" asp-controller="Reports" id="reportForm" class="row g-3 align-items-end flex-wrap w-100">
                <input type="hidden" name="fromDate" value="@fromStr" />
                <input type="hidden" name="toDate" value="@toStr" />
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label">من تاريخ</label>
                    <input type="date" id="fromDateInput" class="form-control form-control-sm erp-filter-input" value="@fromStr" style="min-width:140px" />
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date" id="toDateInput" class="form-control form-control-sm erp-filter-input" value="@toStr" style="min-width:140px" />
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label">المحافظة</label>
                    <div class="erp-multiselect-dropdown dropdown">
                        <button type="button" class="form-select form-select-sm erp-filter-input text-start dropdown-toggle d-flex align-items-center" style="min-width:140px" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" id="btnGovDropdown">
                            <span class="erp-multiselect-caption">الكل</span>
                        </button>
                        <div class="dropdown-menu p-2" style="max-height:280px; overflow-y:auto; min-width:200px;">
                            <input type="text" class="form-control form-control-sm mb-2 erp-dropdown-search" placeholder="بحث..." data-search-in="governorateIds" />
                            <div class="form-check mb-1">
                                <input class="form-check-input erp-select-all" type="checkbox" id="govSelectAll" data-target="governorateIds" />
                                <label class="form-check-label" for="govSelectAll">اختيار الكل</label>
                            </div>
                            <hr class="my-1" />
                            @foreach (var g in Model.Governorates)
                            {
                                <div class="form-check erp-dropdown-option" data-caption="@g.Text">
                                    <input class="form-check-input erp-multiselect-cb" type="checkbox" name="governorateIds" value="@g.Value" id="gov_@g.Value" data-caption="@g.Text" @(g.Selected ? "checked" : "") />
                                    <label class="form-check-label" for="gov_@g.Value">@g.Text</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label">الحي / المركز</label>
                    <div class="erp-multiselect-dropdown dropdown">
                        <button type="button" class="form-select form-select-sm erp-filter-input text-start dropdown-toggle d-flex align-items-center" style="min-width:140px" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" id="btnDistDropdown">
                            <span class="erp-multiselect-caption">الكل</span>
                        </button>
                        <div class="dropdown-menu p-2" style="max-height:280px; overflow-y:auto; min-width:200px;">
                            <input type="text" class="form-control form-control-sm mb-2 erp-dropdown-search" placeholder="بحث..." data-search-in="districtIds" />
                            <div class="form-check mb-1">
                                <input class="form-check-input erp-select-all" type="checkbox" id="distSelectAll" data-target="districtIds" />
                                <label class="form-check-label" for="distSelectAll">اختيار الكل</label>
                            </div>
                            <hr class="my-1" />
                            @foreach (var d in Model.Districts)
                            {
                                <div class="form-check erp-dropdown-option" data-caption="@d.Text">
                                    <input class="form-check-input erp-multiselect-cb" type="checkbox" name="districtIds" value="@d.Value" id="dist_@d.Value" data-caption="@d.Text" @(d.Selected ? "checked" : "") />
                                    <label class="form-check-label" for="dist_@d.Value">@d.Text</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label">المنطقة</label>
                    <div class="erp-multiselect-dropdown dropdown">
                        <button type="button" class="form-select form-select-sm erp-filter-input text-start dropdown-toggle d-flex align-items-center" style="min-width:140px" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" id="btnAreaDropdown">
                            <span class="erp-multiselect-caption">الكل</span>
                        </button>
                        <div class="dropdown-menu p-2" style="max-height:280px; overflow-y:auto; min-width:200px;">
                            <input type="text" class="form-control form-control-sm mb-2 erp-dropdown-search" placeholder="بحث..." data-search-in="areaIds" />
                            <div class="form-check mb-1">
                                <input class="form-check-input erp-select-all" type="checkbox" id="areaSelectAll" data-target="areaIds" />
                                <label class="form-check-label" for="areaSelectAll">اختيار الكل</label>
                            </div>
                            <hr class="my-1" />
                            @foreach (var a in Model.Areas)
                            {
                                <div class="form-check erp-dropdown-option" data-caption="@a.Text">
                                    <input class="form-check-input erp-multiselect-cb" type="checkbox" name="areaIds" value="@a.Value" id="area_@a.Value" data-caption="@a.Text" @(a.Selected ? "checked" : "") />
                                    <label class="form-check-label" for="area_@a.Value">@a.Text</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label">نوع الحساب</label>
                    <div class="erp-multiselect-dropdown dropdown">
                        <button type="button" class="form-select form-select-sm erp-filter-input text-start dropdown-toggle d-flex align-items-center" style="min-width:140px" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" id="btnAccountTypeDropdown">
                            <span class="erp-multiselect-caption">الكل</span>
                        </button>
                        <div class="dropdown-menu p-2" style="max-height:280px; overflow-y:auto; min-width:200px;">
                            <input type="text" class="form-control form-control-sm mb-2 erp-dropdown-search" placeholder="بحث..." data-search-in="accountTypes" />
                            <div class="form-check mb-1">
                                <input class="form-check-input erp-select-all" type="checkbox" id="accountTypeSelectAll" data-target="accountTypes" />
                                <label class="form-check-label" for="accountTypeSelectAll">اختيار الكل</label>
                            </div>
                            <hr class="my-1" />
                            @foreach (var pt in Model.AccountTypeOptions)
                            {
                                <div class="form-check erp-dropdown-option" data-caption="@pt.Text">
                                    <input class="form-check-input erp-multiselect-cb" type="checkbox" name="accountTypes" value="@pt.Value" id="acct_@pt.Value" data-caption="@pt.Text" @(pt.Selected ? "checked" : "") />
                                    <label class="form-check-label" for="acct_@pt.Value">@pt.Text</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label">العملاء</label>
                    <div class="erp-multiselect-dropdown dropdown">
                        <button type="button" class="form-select form-select-sm erp-filter-input text-start dropdown-toggle d-flex align-items-center" style="min-width:160px" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" id="btnCustDropdown">
                            <span class="erp-multiselect-caption">الكل</span>
                        </button>
                        <div class="dropdown-menu p-2" style="max-height:280px; overflow-y:auto; min-width:220px;">
                            <input type="text" class="form-control form-control-sm mb-2 erp-dropdown-search" placeholder="بحث..." data-search-in="customerIds" />
                            <div class="form-check mb-1">
                                <input class="form-check-input erp-select-all" type="checkbox" id="custSelectAll" data-target="customerIds" />
                                <label class="form-check-label" for="custSelectAll">اختيار الكل</label>
                            </div>
                            <hr class="my-1" />
                            @foreach (var c in Model.Customers)
                            {
                                <div class="form-check erp-dropdown-option" data-caption="@c.Text">
                                    <input class="form-check-input erp-multiselect-cb" type="checkbox" name="customerIds" value="@c.Value" id="cust_@c.Value" data-caption="@c.Text" @(c.Selected ? "checked" : "") />
                                    <label class="form-check-label" for="cust_@c.Value">@c.Text</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label">المستخدمون (الكاتب)</label>
                    <div class="erp-multiselect-dropdown dropdown">
                        <button type="button" class="form-select form-select-sm erp-filter-input text-start dropdown-toggle d-flex align-items-center" style="min-width:160px" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" id="btnUserDropdown">
                            <span class="erp-multiselect-caption">الكل</span>
                        </button>
                        <div class="dropdown-menu p-2" style="max-height:280px; overflow-y:auto; min-width:200px;">
                            <input type="text" class="form-control form-control-sm mb-2 erp-dropdown-search" placeholder="بحث..." data-search-in="userIds" />
                            <div class="form-check mb-1">
                                <input class="form-check-input erp-select-all" type="checkbox" id="userSelectAll" data-target="userIds" />
                                <label class="form-check-label" for="userSelectAll">اختيار الكل</label>
                            </div>
                            <hr class="my-1" />
                            @foreach (var u in Model.Users)
                            {
                                <div class="form-check erp-dropdown-option" data-caption="@u.Text">
                                    <input class="form-check-input erp-multiselect-cb" type="checkbox" name="userIds" value="@u.Value" id="user_@u.Value" data-caption="@u.Text" @(u.Selected ? "checked" : "") />
                                    <label class="form-check-label" for="user_@u.Value">@u.Text</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label">الأصناف</label>
                    <div class="erp-multiselect-dropdown dropdown">
                        <button type="button" class="form-select form-select-sm erp-filter-input text-start dropdown-toggle d-flex align-items-center" style="min-width:160px" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" id="btnProdDropdown">
                            <span class="erp-multiselect-caption">الكل</span>
                        </button>
                        <div class="dropdown-menu p-2" style="max-height:280px; overflow-y:auto; min-width:220px;">
                            <input type="text" class="form-control form-control-sm mb-2 erp-dropdown-search" placeholder="بحث..." data-search-in="productIds" />
                            <div class="form-check mb-1">
                                <input class="form-check-input erp-select-all" type="checkbox" id="prodSelectAll" data-target="productIds" />
                                <label class="form-check-label" for="prodSelectAll">اختيار الكل</label>
                            </div>
                            <hr class="my-1" />
                            @foreach (var p in Model.Products)
                            {
                                <div class="form-check erp-dropdown-option" data-caption="@p.Text">
                                    <input class="form-check-input erp-multiselect-cb" type="checkbox" name="productIds" value="@p.Value" id="prod_@p.Value" data-caption="@p.Text" @(p.Selected ? "checked" : "") />
                                    <label class="form-check-label" for="prod_@p.Value">@p.Text</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label d-none d-md-block" style="visibility:hidden">تنفيذ</label>
                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">تجميع التقرير</button>
                        <button type="submit" name="apply" value="1" class="btn btn-erp btn-erp-secondary btn-erp-sm">تعيين</button>
                    </div>
                </div>
            </form>
        </div>

        <div class="row g-3 mt-2 pt-3 erp-performance-report-divider">
            <div class="col-6 col-sm-4 col-md-4 col-lg-3 col-xl-2">
                <div class="card h-100 bg-white text-dark border border-2 border-primary shadow-sm erp-kpi-card-outline">
                    <div class="card-body py-3">
                        <small class="d-block text-muted">الخصم المقدم للعميل %</small>
                        <h4 class="mb-0 text-primary">@Model.DiscountPctAvg.ToString("N1")%</h4>
                    </div>
                </div>
            </div>
            <div class="col-6 col-sm-4 col-md-4 col-lg-3 col-xl-2">
                <div class="card h-100 bg-white text-dark border border-2 border-info shadow-sm erp-kpi-card-outline">
                    <div class="card-body py-3">
                        <small class="d-block text-muted">صافي المبيعات</small>
                        <h4 class="mb-0 text-info">@Model.NetSales.ToString("N0")</h4>
                        @if (Model.HasActiveFilters && Model.GrandTotalNetSales > 0) { <small class="d-block text-muted">@Model.NetSalesPctOfTotal.ToString("N1")% من إجمالي البيع</small> }
                    </div>
                </div>
            </div>
            <div class="col-6 col-sm-4 col-md-4 col-lg-3 col-xl-2">
                <div class="card h-100 bg-white text-dark border border-2 border-danger shadow-sm erp-kpi-card-outline">
                    <div class="card-body py-3">
                        <small class="d-block text-muted">المرتجعات</small>
                        <h4 class="mb-0 text-danger">@Model.TotalReturns.ToString("N0")</h4>
                        @if (Model.HasActiveFilters && Model.GrandTotalNetSales > 0) { <small class="d-block text-muted">@Model.ReturnsPctOfTotal.ToString("N1")% من إجمالي البيع</small> }
                    </div>
                </div>
            </div>
            <div class="col-6 col-sm-4 col-md-4 col-lg-3 col-xl-2">
                <div class="card h-100 bg-white text-dark border border-2 border-success shadow-sm erp-kpi-card-outline">
                    <div class="card-body py-3">
                        <small class="d-block text-muted">صافي الربح</small>
                        <h4 class="mb-0 text-success">@Model.NetProfit.ToString("N0")</h4>
                        @if (Model.HasActiveFilters && Model.GrandTotalNetSales > 0) { <small class="d-block text-muted">@Model.NetProfitPctOfTotalSales.ToString("N1")% من إجمالي البيع</small> }
                        @if (Model.HasActiveFilters && Model.GrandTotalNetProfit != 0) { <small class="d-block text-muted">@Model.NetProfitPctOfTotalProfit.ToString("N1")% من إجمالي الربح</small> }
                    </div>
                </div>
            </div>
            <div class="col-6 col-sm-4 col-md-4 col-lg-3 col-xl-2">
                <div class="card h-100 bg-white text-dark border border-2 border-secondary shadow-sm erp-kpi-card-outline">
                    <div class="card-body py-3">
                        <small class="d-block text-muted">عدد الفواتير</small>
                        <h4 class="mb-0 text-secondary">@Model.InvoiceCount.ToString("N0")</h4>
                    </div>
                </div>
            </div>
            <div class="col-6 col-sm-4 col-md-4 col-lg-3 col-xl-2">
                <div class="card h-100 bg-white text-dark border border-2 border-dark shadow-sm erp-kpi-card-outline">
                    <div class="card-body py-3">
                        <small class="d-block text-muted">متوسط سعر القطعة</small>
                        <h4 class="mb-0 text-dark">@Model.AvgItemPrice.ToString("N0")</h4>
                    </div>
                </div>
            </div>
            <div class="col-6 col-sm-4 col-md-4 col-lg-3 col-xl-2">
                <div class="card h-100 bg-white text-dark border border-2 border-warning shadow-sm erp-kpi-card-outline">
                    <div class="card-body py-3">
                        <small class="d-block text-muted">متوسط قيمة الفاتورة</small>
                        <h4 class="mb-0 text-warning">@Model.AvgInvoiceValue.ToString("N0")</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3 pt-3 erp-performance-report-divider">
            <div class="fw-semibold text-secondary small mb-2">الرسم البياني — أداء المبيعات</div>
            <div class="erp-performance-chart-wrap" style="height: 320px;">
                <canvas id="salesChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var isLineChart = @(Model.IsLineChartMode ? "true" : "false");
            var chartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData));
            var timeLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartTimeSeriesLabels));
            var timeValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartTimeSeriesValues));

            var ctx = document.getElementById('salesChart');
            if (!ctx) return;

            if (isLineChart && timeLabels && timeLabels.length > 0) {
                new Chart(ctx.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: timeLabels,
                        datasets: [{
                            label: 'صافي المبيعات',
                            data: timeValues,
                            borderColor: 'rgba(54, 162, 235, 1)',
                            backgroundColor: 'rgba(54, 162, 235, 0.1)',
                            fill: true,
                            tension: 0.2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { ticks: { maxRotation: 45, minRotation: 45 } },
                            y: {
                                beginAtZero: true,
                                ticks: { callback: function (v) { return Number(v).toLocaleString('ar-EG', { maximumFractionDigits: 0 }); } }
                            }
                        }
                    }
                });
            } else if (chartData && chartData.length > 0) {
                new Chart(ctx.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: chartData.map(function (x) { return x.writerName; }),
                        datasets: [{
                            label: 'صافي المبيعات',
                            data: chartData.map(function (x) { return x.netSales; }),
                            backgroundColor: 'rgba(54, 162, 235, 0.7)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: {
                                beginAtZero: true,
                                ticks: { callback: function (v) { return Number(v).toLocaleString('ar-EG', { maximumFractionDigits: 0 }); } }
                            }
                        }
                    }
                });
            }

            function updateMultiselectCaption(btn, name) {
                var checked = document.querySelectorAll('input.erp-multiselect-cb[name="' + name + '"]:checked');
                var cap = btn ? btn.querySelector('.erp-multiselect-caption') : null;
                if (!cap) return;
                if (checked.length === 0) cap.textContent = 'الكل';
                else if (checked.length === 1) cap.textContent = checked[0].getAttribute('data-caption') || checked[0].value;
                else cap.textContent = checked.length + ' عناصر';
            }
            document.querySelectorAll('.erp-multiselect-dropdown').forEach(function (wrap) {
                var btn = wrap.querySelector('[data-bs-toggle="dropdown"]');
                var name = wrap.querySelector('.erp-multiselect-cb');
                if (!name) return;
                name = name.getAttribute('name');
                var allCbs = wrap.querySelectorAll('input.erp-multiselect-cb[name="' + name + '"]');
                var selectAll = wrap.querySelector('.erp-select-all');
                if (selectAll) {
                    selectAll.addEventListener('change', function () {
                        allCbs.forEach(function (cb) { cb.checked = selectAll.checked; });
                        updateMultiselectCaption(btn, name);
                    });
                    allCbs.forEach(function (cb) {
                        cb.addEventListener('change', function () {
                            var n = wrap.querySelectorAll('input.erp-multiselect-cb[name="' + name + '"]:checked').length;
                            selectAll.checked = n === allCbs.length;
                            selectAll.indeterminate = n > 0 && n < allCbs.length;
                            updateMultiselectCaption(btn, name);
                        });
                    });
                }
                allCbs.forEach(function (cb) { cb.addEventListener('change', function () { updateMultiselectCaption(btn, name); }); });
                var n = wrap.querySelectorAll('input.erp-multiselect-cb:checked').length;
                if (selectAll) {
                    selectAll.checked = n === allCbs.length;
                    selectAll.indeterminate = n > 0 && n < allCbs.length;
                }
                updateMultiselectCaption(btn, name);
            });

            document.querySelectorAll('.erp-dropdown-search').forEach(function (searchInp) {
                searchInp.addEventListener('input', function () {
                    var q = (this.value || '').trim().toLowerCase().replace(/\s+/g, ' ');
                    var menu = this.closest('.dropdown-menu');
                    if (!menu) return;
                    menu.querySelectorAll('.erp-dropdown-option').forEach(function (row) {
                        var cap = (row.getAttribute('data-caption') || '').trim().toLowerCase().replace(/\s+/g, ' ');
                        row.style.display = !q || cap.indexOf(q) !== -1 ? '' : 'none';
                    });
                });
                searchInp.addEventListener('click', function (e) { e.stopPropagation(); });
            });

            document.getElementById('reportForm').addEventListener('submit', function () {
                var fromInp = document.getElementById('fromDateInput');
                var toInp = document.getElementById('toDateInput');
                if (fromInp && this.querySelector('input[name="fromDate"]')) this.querySelector('input[name="fromDate"]').value = fromInp.value;
                if (toInp && this.querySelector('input[name="toDate"]')) this.querySelector('input[name="toDate"]').value = toInp.value;
                document.querySelectorAll('.erp-multiselect-dropdown').forEach(function (wrap) {
                    var first = wrap.querySelector('input.erp-multiselect-cb');
                    if (!first) return;
                    var name = first.getAttribute('name');
                    wrap.querySelectorAll('input.erp-multiselect-cb').forEach(function (el) { el.removeAttribute('name'); });
                    wrap.querySelectorAll('input.erp-multiselect-cb:checked').forEach(function (el) { el.setAttribute('name', name); });
                });
            });
        })();
    </script>
}
