@using ERP.ViewModels
@using Microsoft.AspNetCore.Html
@{
    ViewData["Title"] = "تقرير أصناف مفصّلة";

    var reportData = ViewBag.ReportData as List<ProductDetailsReportRow> ?? new List<ProductDetailsReportRow>();
    var reportType = ViewBag.ReportType as string ?? "";
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var search = ViewBag.Search as string ?? "";
    var page = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 100;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    var totalPages = ViewBag.TotalPages as int? ?? 0;
    var reportTypes = ViewBag.ReportTypes as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    string? filterCol_date = ViewBag.FilterCol_Date as string;
    string? filterCol_docNo = ViewBag.FilterCol_DocNo as string;
    string? filterCol_productCode = ViewBag.FilterCol_ProductCode as string;
    string? filterCol_productName = ViewBag.FilterCol_ProductName as string;
    string? filterCol_party = ViewBag.FilterCol_Party as string;
    string? filterCol_warehouse = ViewBag.FilterCol_Warehouse as string;
    string? filterCol_author = ViewBag.FilterCol_Author as string;
    string? filterCol_region = ViewBag.FilterCol_Region as string;
    string? filterCol_docNameAr = ViewBag.FilterCol_DocNameAr as string;

    int startRow = totalCount == 0 ? 0 : (page - 1) * pageSize + 1;
    int endRow = Math.Min(page * pageSize, totalCount);

    Func<int, string> pageUrl = (p) =>
    {
        return Url.Action("ProductDetailsReport", "Reports", new
        {
            reportType,
            fromDate,
            toDate,
            search,
            page = p,
            pageSize,
            filterCol_date,
            filterCol_docNo,
            filterCol_productCode,
            filterCol_productName,
            filterCol_party,
            filterCol_warehouse,
            filterCol_author,
            filterCol_region,
            filterCol_docNameAr
        }) ?? "#";
    };

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = colKey == "date" ? filterCol_date : colKey == "docno" ? filterCol_docNo : colKey == "productcode" ? filterCol_productCode : colKey == "productname" ? filterCol_productName : colKey == "party" ? filterCol_party : colKey == "warehouse" ? filterCol_warehouse : colKey == "author" ? filterCol_author : colKey == "region" ? filterCol_region : colKey == "docnamear" ? filterCol_docNameAr : null;
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var btnStateClass = hasFilter ? "text-primary" : "text-muted";
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"" style=""position:relative;z-index:2;"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        @if (!string.IsNullOrEmpty(reportType) && reportData.Any())
        {
            <small class="text-muted">إجمالي السطور: @totalCount</small>
        }
    </div>

    @* شريط الفلاتر (نمط القوائم) *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <form method="get" asp-action="ProductDetailsReport" asp-controller="Reports" class="row g-3 align-items-end flex-wrap" id="productDetailsReportFilterForm">
            <div class="col-12 col-md-6 col-lg-auto">
                <label class="form-label">نوع التقرير</label>
                <select name="reportType" class="form-select erp-filter-input" style="min-width: 200px;">
                    @foreach (var item in reportTypes)
                    {
                        <option value="@(item.Value ?? "")" @(item.Selected ? "selected" : null)>@item.Text</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-6 col-lg-auto">
                <label class="form-label">من تاريخ</label>
                <input type="date" name="fromDate" class="form-control erp-filter-input" value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
            </div>
            <div class="col-12 col-md-6 col-lg-auto">
                <label class="form-label">إلى تاريخ</label>
                <input type="date" name="toDate" class="form-control erp-filter-input" value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
            </div>
            <div class="col-12 col-md-6 col-lg-auto">
                <label class="form-label">بحث باسم/كود الصنف</label>
                <input type="text" name="search" class="form-control erp-filter-input" placeholder="اسم أو كود الصنف..." value="@search" />
            </div>
            <div class="col-12 col-lg-auto d-flex flex-nowrap gap-2 align-items-end">
                <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm">عرض</button>
                <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action("ProductDetailsReport", "Reports")">إلغاء</a>
            </div>
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="pageSize" value="@pageSize" />
            @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_docNo)) { <input type="hidden" name="filterCol_docNo" value="@filterCol_docNo" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_productCode)) { <input type="hidden" name="filterCol_productCode" value="@filterCol_productCode" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_productName)) { <input type="hidden" name="filterCol_productName" value="@filterCol_productName" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_party)) { <input type="hidden" name="filterCol_party" value="@filterCol_party" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_author)) { <input type="hidden" name="filterCol_author" value="@filterCol_author" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_region)) { <input type="hidden" name="filterCol_region" value="@filterCol_region" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_docNameAr)) { <input type="hidden" name="filterCol_docNameAr" value="@filterCol_docNameAr" /> }
        </form>
    </div>

    @* جدول البيانات *@
    <div class="erp-table-scroll-container mt-3">
        <div id="productDetailsReportScrollWrapper" class="erp-table-wrapper" style="max-height: 65vh; overflow: auto;">
            <table class="table table-striped table-hover mb-0 erp-table" id="productDetailsReportTable">
                <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                    <tr>
                        <th data-col="date">@filterableCol("date", "Date", "التاريخ")</th>
                        <th data-col="docno">@filterableCol("docno", "DocNo", "رقم المستند")</th>
                        <th data-col="author">@filterableCol("author", "Author", "الكاتب")</th>
                        <th data-col="region">@filterableCol("region", "Region", "المنطقة")</th>
                        <th data-col="docnamear">@filterableCol("docnamear", "DocumentNameAr", "اسم المستند بالعربي")</th>
                        <th data-col="productcode">@filterableCol("productcode", "ProductCode", "كود الصنف")</th>
                        <th data-col="productname">@filterableCol("productname", "ProductName", "اسم الصنف")</th>
                        <th class="text-end" data-col="qty" style="min-width: 90px;">الكمية</th>
                        <th class="text-end" style="min-width: 100px;">السعر</th>
                        <th class="text-end" style="min-width: 110px;">الإجمالي</th>
                        <th data-col="party">@filterableCol("party", "PartyName", "الطرف")</th>
                        <th data-col="warehouse">@filterableCol("warehouse", "WarehouseName", "المخزن")</th>
                        <th style="min-width: 90px;">التشغيلة</th>
                        <th style="min-width: 100px;">الصلاحية</th>
                        <th style="min-width: 120px;">ملاحظات</th>
                        <th class="text-nowrap" style="width: 90px; min-width: 90px;" data-col-fixed="true" data-col="actions">إجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!reportData.Any())
                    {
                        <tr>
                            <td colspan="16" class="text-center text-muted py-4">@(string.IsNullOrEmpty(reportType) ? "اختر نوع التقرير ثم اضغط «عرض»." : "لا توجد بيانات.")</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var row in reportData)
                        {
                            var showUrl = "";
                            if (row.ReportType == "Sales") showUrl = Url.Action("Show", "SalesInvoices", new { id = row.DocId });
                            else if (row.ReportType == "Purchases") showUrl = Url.Action("Show", "PurchaseInvoices", new { id = row.DocId });
                            else if (row.ReportType == "SalesReturns") showUrl = Url.Action("Show", "SalesReturns", new { id = row.DocId });
                            else if (row.ReportType == "PurchaseReturns") showUrl = Url.Action("Show", "PurchaseReturns", new { id = row.DocId });
                            else if (row.ReportType == "Adjustments") showUrl = Url.Action("Show", "StockAdjustments", new { id = row.DocId });
                            else if (row.ReportType == "Transfers") showUrl = Url.Action("Show", "StockTransfers", new { id = row.DocId });
                            else if (row.ReportType == "PurchaseRequests") showUrl = Url.Action("Show", "PurchaseRequests", new { id = row.DocId });
                            else if (row.ReportType == "SalesOrders") showUrl = Url.Action("Show", "SalesOrders", new { id = row.DocId });

                            <tr>
                                <td data-col="date">@row.Date.ToString("d/M/yyyy")</td>
                                <td data-col="docno">@row.DocNo</td>
                                <td data-col="author">@(row.Author ?? "—")</td>
                                <td data-col="region">@(row.Region ?? "—")</td>
                                <td data-col="docnamear">@(row.DocumentNameAr ?? "—")</td>
                                <td data-col="productcode">@row.ProductCode</td>
                                <td data-col="productname">@row.ProductName</td>
                                <td class="text-end">@row.Qty.ToString("N0")</td>
                                <td class="text-end">@(row.UnitPrice.HasValue ? row.UnitPrice.Value.ToString("N2") : "—")</td>
                                <td class="text-end">@(row.Total.HasValue ? row.Total.Value.ToString("N2") : "—")</td>
                                <td data-col="party">@(row.PartyName ?? "—")</td>
                                <td data-col="warehouse">@(row.WarehouseName ?? "—")</td>
                                <td>@(row.BatchNo ?? "—")</td>
                                <td>@(row.Expiry.HasValue ? row.Expiry.Value.ToString("d/M/yyyy") : "—")</td>
                                <td>@(row.Notes ?? "—")</td>
                                <td data-col="actions">
                                    @if (!string.IsNullOrEmpty(showUrl))
                                    {
                                        <a href="@showUrl" class="btn btn-erp btn-erp-primary btn-erp-sm">عرض</a>
                                    }
                                </td>
                            </tr>
                            <tr class="erp-pdr-detail-row d-none" data-pdr-detail-for>
                                <td colspan="17" class="bg-light small py-3">
                                    <div class="row g-2 text-start">
                                        <div class="col-md-6 col-lg-4"><strong>التاريخ:</strong> @row.Date.ToString("d/M/yyyy")</div>
                                        <div class="col-md-6 col-lg-4"><strong>رقم المستند:</strong> @row.DocNo</div>
                                        <div class="col-md-6 col-lg-4"><strong>الكاتب:</strong> @(row.Author ?? "—")</div>
                                        <div class="col-md-6 col-lg-4"><strong>المنطقة:</strong> @(row.Region ?? "—")</div>
                                        <div class="col-md-6 col-lg-4"><strong>اسم المستند:</strong> @(row.DocumentNameAr ?? "—")</div>
                                        <div class="col-md-6 col-lg-4"><strong>كود الصنف:</strong> @row.ProductCode</div>
                                        <div class="col-md-6 col-lg-4"><strong>اسم الصنف:</strong> @row.ProductName</div>
                                        <div class="col-md-6 col-lg-4"><strong>الكمية:</strong> @row.Qty.ToString("N0")</div>
                                        <div class="col-md-6 col-lg-4"><strong>السعر:</strong> @(row.UnitPrice.HasValue ? row.UnitPrice.Value.ToString("N2") : "—")</div>
                                        <div class="col-md-6 col-lg-4"><strong>الإجمالي:</strong> @(row.Total.HasValue ? row.Total.Value.ToString("N2") : "—")</div>
                                        <div class="col-md-6 col-lg-4"><strong>الطرف:</strong> @(row.PartyName ?? "—")</div>
                                        <div class="col-md-6 col-lg-4"><strong>المخزن:</strong> @(row.WarehouseName ?? "—")</div>
                                        <div class="col-md-6 col-lg-4"><strong>التشغيلة:</strong> @(row.BatchNo ?? "—")</div>
                                        <div class="col-md-6 col-lg-4"><strong>الصلاحية:</strong> @(row.Expiry.HasValue ? row.Expiry.Value.ToString("d/M/yyyy") : "—")</div>
                                        <div class="col-12"><strong>ملاحظات:</strong> @(row.Notes ?? "—")</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
                @if (reportData.Any())
                {
                    <tfoot class="table-secondary fw-bold text-start">
                        <tr>
                            <td colspan="6"><strong>المجموع</strong></td>
                            <td class="text-end">@reportData.Sum(r => r.Qty).ToString("N0")</td>
                            <td></td>
                            <td class="text-end">@(reportData.Where(r => r.Total.HasValue).Sum(r => r.Total!.Value).ToString("N2"))</td>
                            <td colspan="7"></td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>

    @* لوحة فلتر الأعمدة *@
    <div id="erpColumnFilterPanelProductDetailsReport" class="erp-column-filter-panel d-none" dir="rtl">
        <div class="erp-column-filter-header">
            <span id="erpColumnFilterTitleProductDetailsReport">ترتيب وفلتر</span>
            <button type="button" class="btn-close btn-sm" id="erpColumnFilterCloseProductDetailsReport" aria-label="إغلاق"></button>
        </div>
        <div class="erp-column-filter-body">
            <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                <label class="form-label small mb-1 fw-bold">الترتيب:</label>
                <div class="d-flex flex-column gap-1">
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
                </div>
            </div>
            <div class="erp-filter-section">
                <div id="erpColumnFilterSearchRowProductDetailsReport">
                    <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                    <input type="text" id="erpColumnFilterSearchProductDetailsReport" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                </div>
                <div id="erpColumnFilterListProductDetailsReport" class="erp-column-filter-list">
                    <div class="text-muted text-center py-3">جاري التحميل...</div>
                </div>
            </div>
            <div class="erp-column-filter-actions">
                <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" data-action="apply">تطبيق</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-action="clear">مسح الفلتر</button>
            </div>
        </div>
    </div>

    @* شريط الترقيم — محاذاة لليمين *@
    @if (!string.IsNullOrEmpty(reportType) && totalCount > 0)
    {
        <div class="d-flex flex-wrap justify-content-end align-items-center gap-3 mt-2" dir="rtl">
            <small class="text-muted">عرض @startRow – @endRow من @totalCount</small>
            <form method="get" asp-action="ProductDetailsReport" asp-controller="Reports" class="d-flex align-items-center gap-2">
                <input type="hidden" name="reportType" value="@reportType" />
                <input type="hidden" name="fromDate" value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                <input type="hidden" name="toDate" value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                <input type="hidden" name="search" value="@search" />
                <input type="hidden" name="page" value="1" />
                <input type="hidden" name="pageSize" value="@pageSize" />
                @if (!string.IsNullOrWhiteSpace(filterCol_date)) { <input type="hidden" name="filterCol_date" value="@filterCol_date" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_docNo)) { <input type="hidden" name="filterCol_docNo" value="@filterCol_docNo" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_productCode)) { <input type="hidden" name="filterCol_productCode" value="@filterCol_productCode" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_productName)) { <input type="hidden" name="filterCol_productName" value="@filterCol_productName" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_party)) { <input type="hidden" name="filterCol_party" value="@filterCol_party" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_author)) { <input type="hidden" name="filterCol_author" value="@filterCol_author" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_region)) { <input type="hidden" name="filterCol_region" value="@filterCol_region" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_docNameAr)) { <input type="hidden" name="filterCol_docNameAr" value="@filterCol_docNameAr" /> }
                <label class="form-label m-0">حجم الصفحة</label>
                <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="25" @(pageSize == 25 ? "selected" : "")>25</option>
                    <option value="50" @(pageSize == 50 ? "selected" : "")>50</option>
                    <option value="100" @(pageSize == 100 ? "selected" : "")>100</option>
                    <option value="200" @(pageSize == 200 ? "selected" : "")>200</option>
                    <option value="500" @(pageSize == 500 ? "selected" : "")>500</option>
                </select>
            </form>
            <nav aria-label="ترقيم">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(page <= 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(1)">الأول</a>
                    </li>
                    <li class="page-item @(page <= 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page - 1)">السابق</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">صفحة @(page) من @(totalPages)</span>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page + 1)">التالي</a>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(totalPages)">الأخير</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
<script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
<script>
(function () {
    var wrapper = document.getElementById('productDetailsReportScrollWrapper');
    if (wrapper) {
        wrapper.scrollLeft = wrapper.scrollWidth - wrapper.clientWidth;
    }

    var reportType = '@(reportType)';
    if (reportType && typeof ERP !== 'undefined' && ERP.initListColumnFilter) {
        ERP.initListColumnFilter({
            panelId: 'erpColumnFilterPanelProductDetailsReport',
            tableId: 'productDetailsReportTable',
            wrapperId: 'productDetailsReportScrollWrapper',
            getColumnValuesUrl: '@Url.Action("GetProductDetailsReportColumnValues", "Reports")?reportType=' + encodeURIComponent(reportType),
            defaultSort: 'Date',
            defaultDir: 'desc'
        });
    }

})();
</script>
}
