@using ERP.ViewModels
@{
    ViewData["Title"] = "تقرير: أرباح الأصناف";

    var reportData = ViewBag.ReportData as List<ProductProfitReportDto> ?? new List<ProductProfitReportDto>();
    var totalSalesRevenue = ViewBag.TotalSalesRevenue as decimal? ?? 0m;
    var totalSalesCost = ViewBag.TotalSalesCost as decimal? ?? 0m;
    var totalSalesProfit = ViewBag.TotalSalesProfit as decimal? ?? 0m;
    var totalAdjustmentProfit = ViewBag.TotalAdjustmentProfit as decimal? ?? 0m;
    var totalTransferProfit = ViewBag.TotalTransferProfit as decimal? ?? 0m;
    var totalProfit = ViewBag.TotalProfit as decimal? ?? 0m;

    // Pagination
    var page = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 20;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;

    // الفلاتر من ViewBag
    var search = ViewBag.Search as string ?? "";
    var categoryId = ViewBag.CategoryId as int?;
    var warehouseId = ViewBag.WarehouseId as int?;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var profitMethod = ViewBag.ProfitMethod as string ?? "both";
    var sortBy = ViewBag.SortBy as string ?? "name";
    var sortDir = ViewBag.SortDir as string ?? "asc";

    // القوائم المنسدلة
    var categories = ViewBag.Categories as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var warehouses = ViewBag.Warehouses as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    // دالة إنشاء رابط الترتيب
    Func<string, string, string> sortUrl = (col, direction) =>
    {
        return Url.Action("ProductProfits", "Reports", new
        {
            search,
            categoryId,
            warehouseId,
            fromDate,
            toDate,
            profitMethod,
            sortBy = col,
            sortDir = direction,
            loadReport = true,
            page,
            pageSize
        }) ?? "#";
    };

    // دالة إنشاء رابط Pagination
    Func<int, string> pageUrl = (p) =>
    {
        return Url.Action("ProductProfits", "Reports", new
        {
            search,
            categoryId,
            warehouseId,
            fromDate,
            toDate,
            profitMethod,
            sortBy,
            sortDir,
            loadReport = true,
            page = p,
            pageSize
        }) ?? "#";
    };
}

<div dir="rtl" class="container-fluid" style="padding: 1rem;">
    @* عنوان الصفحة *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <small class="text-muted d-none d-md-inline">
            عدد الأصناف: @(reportData.Any() ? totalCount : 0)
        </small>
    </div>

    @* ===== كروت الفلاتر ===== *@
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <form method="get" asp-action="ProductProfits" asp-controller="Reports" id="filtersForm">
                <div class="row g-3 align-items-end">
                    @* كارت البحث *@
                    <div class="col-lg-3 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">🔍 بحث</span>
                            </div>
                            <div class="card-body py-2">
                                <input type="text"
                                       name="search"
                                       class="form-control"
                                       placeholder="اكتب اسم الصنف أو جزء منه..."
                                       autocomplete="off"
                                       value="@search" />
                            </div>
                        </div>
                    </div>

                    @* كارت الفئة *@
                    <div class="col-lg-2 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">📂 الفئة</span>
                            </div>
                            <div class="card-body py-2">
                                <select name="categoryId" class="form-select">
                                    <option value="">الكل</option>
                                    @foreach (var cat in categories)
                                    {
                                        @if (categoryId?.ToString() == cat.Value)
                                        {
                                            <option value="@cat.Value" selected>@cat.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@cat.Value">@cat.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    @* كارت المخزن *@
                    <div class="col-lg-2 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">🏪 المخزن</span>
                            </div>
                            <div class="card-body py-2">
                                <select name="warehouseId" class="form-select">
                                    <option value="">الكل</option>
                                    @foreach (var wh in warehouses)
                                    {
                                        @if (warehouseId?.ToString() == wh.Value)
                                        {
                                            <option value="@wh.Value" selected>@wh.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@wh.Value">@wh.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    @* كارت تاريخ من *@
                    <div class="col-lg-2 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">📅 من تاريخ</span>
                            </div>
                            <div class="card-body py-2">
                                <input type="date"
                                       name="fromDate"
                                       class="form-control"
                                       value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                            </div>
                        </div>
                    </div>

                    @* كارت تاريخ إلى *@
                    <div class="col-lg-2 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">📅 إلى تاريخ</span>
                            </div>
                            <div class="card-body py-2">
                                <input type="date"
                                       name="toDate"
                                       class="form-control"
                                       value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                            </div>
                        </div>
                    </div>

                    @* كارت طريقة الحساب *@
                    <div class="col-lg-1 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">📊 طريقة</span>
                            </div>
                            <div class="card-body py-2">
                                <select name="profitMethod" class="form-select">
                                    <option value="both"@Html.Raw(profitMethod == "both" ? " selected" : "")>الكل</option>
                                    <option value="sales"@Html.Raw(profitMethod == "sales" ? " selected" : "")>ربح البيع</option>
                                    <option value="balancesheet"@Html.Raw(profitMethod == "balancesheet" ? " selected" : "")>ربح الميزانية</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    @* أزرار التفعيل *@
                    <div class="col-lg-auto d-flex gap-2 align-items-end">
                        <input type="hidden" name="loadReport" value="true" />
                        <button type="submit" class="btn btn-primary">
                            <span>📊</span> تجميع التقرير
                        </button>
                        <a href="@Url.Action("ProductProfits", "Reports")" class="btn btn-secondary btn-sm">
                            <span>🔄</span> إعادة تعيين
                        </a>
                        <form method="post" asp-action="FixOrphanedPaymentEntries" asp-controller="Reports" class="d-inline" onsubmit="return confirm('هل تريد إعادة حساب أرصدة العملاء من القيود الحالية؟ (يُصلح ظهور ربح أو التزامات خاطئة بعد حذف القيود)');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-warning btn-sm" title="إعادة حساب أرصدة العملاء من القيود">
                                <span>🔧</span> إصلاح أرصدة العملاء
                            </button>
                        </form>
                        @if (reportData.Any())
                        {
                            <div class="d-flex align-items-center gap-2">
                                <label class="form-label mb-0 small">حجم الصفحة:</label>
                                <select name="pageSize" 
                                        class="form-select form-select-sm" 
                                        style="width: auto;"
                                        onchange="this.form.submit()">
                                    <option value="20"@Html.Raw(pageSize == 20 ? " selected" : "")>20</option>
                                    <option value="50"@Html.Raw(pageSize == 50 ? " selected" : "")>50</option>
                                    <option value="200"@Html.Raw(pageSize == 200 ? " selected" : "")>200</option>
                                    <option value="500"@Html.Raw(pageSize == 500 ? " selected" : "")>500</option>
                                    <option value="1000"@Html.Raw(pageSize == 1000 ? " selected" : "")>1000</option>
                                    <option value="0"@Html.Raw(pageSize == 0 || pageSize >= totalCount ? " selected" : "")>الكل</option>
                                </select>
                            </div>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    @* ===== Pagination Info ===== *@
    @if (reportData.Any() && totalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <small class="text-muted">
                عرض @((page - 1) * pageSize + 1) - @(Math.Min(page * pageSize, totalCount)) من @totalCount
            </small>
            <small class="text-muted">
                @($"صفحة {page} من {totalPages}")
            </small>
        </div>
    }

    @* ===== ملخص الربح الإجمالي (بيع + تسويات) ===== *@
    @if (reportData.Any())
    {
        <div class="alert alert-light border mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span><strong>إجمالي الربح (بيع + تسويات + تحويلات):</strong></span>
            <span class="fs-5 @(totalProfit >= 0 ? "text-success" : "text-danger")"><strong>@totalProfit.ToString("N2")</strong></span>
        </div>
    }

    @* ===== جدول البيانات ===== *@
    @if (reportData.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive product-profits-table-scroll" style="max-height: 70vh; overflow-y: auto; overflow-x: auto;">
                    <table class="table table-sm table-striped table-hover mb-0">
                        <thead class="table-light product-profits-sticky-header">
                            <tr>
                                <th style="min-width: 80px;">
                                    <a href="@sortUrl("code", sortBy == "code" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        الكود @if (sortBy == "code") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th style="min-width: 200px;">
                                    <a href="@sortUrl("name", sortBy == "name" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        اسم الصنف @if (sortBy == "name") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th>الفئة</th>
                                
                                @* ربح البيع *@
                                <th class="text-end" style="min-width: 120px;">الإيرادات (بيع)</th>
                                <th class="text-end" style="min-width: 120px;">التكلفة (بيع)</th>
                                <th class="text-end" style="min-width: 120px;">
                                    <a href="@sortUrl("salesprofit", sortBy == "salesprofit" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        الربح (بيع) @if (sortBy == "salesprofit") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th class="text-end" style="min-width: 100px;">نسبة الربح (بيع) %</th>
                                
                                @* ربح التسويات *@
                                <th class="text-end" style="min-width: 120px;">
                                    <a href="@sortUrl("adjustmentprofit", sortBy == "adjustmentprofit" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        الربح (تسويات) @if (sortBy == "adjustmentprofit") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                
                                @* ربح التحويلات *@
                                <th class="text-end" style="min-width: 120px;">
                                    <a href="@sortUrl("transferprofit", sortBy == "transferprofit" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        الربح (تحويلات) @if (sortBy == "transferprofit") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                
                                @* إحصائيات *@
                                <th class="text-end" style="min-width: 100px;">الكمية</th>
                                <th class="text-end" style="min-width: 120px;">متوسط السعر</th>
                                <th class="text-end" style="min-width: 120px;">متوسط التكلفة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in reportData)
                            {
                                <tr>
                                    <td><strong>@item.ProdCode</strong></td>
                                    <td>@item.ProdName</td>
                                    <td><small class="text-muted">@item.CategoryName</small></td>
                                    
                                    @* ربح البيع *@
                                    <td class="text-end">@item.SalesRevenue.ToString("N2")</td>
                                    <td class="text-end">@item.SalesCost.ToString("N2")</td>
                                    <td class="text-end">
                                        <strong class="@(item.SalesProfit >= 0 ? "text-success" : "text-danger")">
                                            @item.SalesProfit.ToString("N2")
                                        </strong>
                                    </td>
                                    <td class="text-end">
                                        <span class="@(item.SalesProfitPercent >= 0 ? "text-success" : "text-danger")">
                                            @item.SalesProfitPercent.ToString("N2")%
                                        </span>
                                    </td>
                                    
                                    @* ربح التسويات *@
                                    <td class="text-end">
                                        <strong class="@(item.AdjustmentProfit >= 0 ? "text-success" : "text-danger")">
                                            @item.AdjustmentProfit.ToString("N2")
                                        </strong>
                                    </td>
                                    
                                    @* ربح التحويلات *@
                                    <td class="text-end">
                                        <strong class="@(item.TransferProfit >= 0 ? "text-success" : "text-danger")">
                                            @item.TransferProfit.ToString("N2")
                                        </strong>
                                    </td>
                                    
                                    @* إحصائيات *@
                                    <td class="text-end">@item.SalesQty.ToString("N2")</td>
                                    <td class="text-end">@item.AvgUnitPrice.ToString("N2")</td>
                                    <td class="text-end">@item.AvgUnitCost.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-secondary fw-bold">
                            <tr>
                                <td colspan="3" class="text-end"><strong>المجموع الإجمالي:</strong></td>
                                
                                @* ربح البيع *@
                                <td class="text-end"><strong>@totalSalesRevenue.ToString("N2")</strong></td>
                                <td class="text-end"><strong>@totalSalesCost.ToString("N2")</strong></td>
                                <td class="text-end">
                                    <strong class="text-primary" style="font-size: 1.1rem;">
                                        @totalSalesProfit.ToString("N2")
                                    </strong>
                                </td>
                                <td class="text-end">
                                    <strong>
                                        @((totalSalesRevenue > 0 ? (totalSalesProfit / totalSalesRevenue * 100) : 0).ToString("N2"))%
                                    </strong>
                                </td>
                                
                                @* ربح التسويات *@
                                <td class="text-end">
                                    <strong class="@(totalAdjustmentProfit >= 0 ? "text-success" : "text-danger")">
                                        @totalAdjustmentProfit.ToString("N2")
                                    </strong>
                                </td>
                                
                                @* ربح التحويلات *@
                                <td class="text-end">
                                    <strong class="@(totalTransferProfit >= 0 ? "text-success" : "text-danger")">
                                        @totalTransferProfit.ToString("N2")
                                    </strong>
                                </td>
                                
                                @* إحصائيات *@
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        @* ===== Pagination Controls ===== *@
        @if (totalPages > 1)
        {
            <nav aria-label="pagination" class="mt-3 d-print-none">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(page == 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(1)">الأول</a>
                    </li>
                    <li class="page-item @(page == 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page - 1)">السابق</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">@($"صفحة {page} من {totalPages}")</span>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page + 1)">التالي</a>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(totalPages)">الأخير</a>
                    </li>
                </ul>
            </nav>
        }

        @* ===== ربح الميزانية ===== *@
        @if (ViewBag.BalanceSheetData != null)
        {
            var bs = ViewBag.BalanceSheetData;
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">📊 ربح الميزانية</h5>
                    <small>مجموع العملاء المدينين + رصيد الخزنة + تكلفة البضاعة في المخزن − مجموع العملاء الدائنين + ربح التسوية + ربح التحويل</small>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-muted mb-3">الإيرادات (أصول)</h6>
                            <table class="table table-sm table-bordered">
                                <tr>
                                    <th style="width: 50%;">مجموع العملاء المدينين</th>
                                    <td class="text-end"><strong class="text-success">@bs.CustomersDebitSum.ToString("N2")</strong></td>
                                </tr>
                                <tr>
                                    <th>رصيد الخزنة</th>
                                    <td class="text-end"><strong class="text-success">@bs.TreasuryBalance.ToString("N2")</strong></td>
                                </tr>
                                <tr>
                                    <th>تكلفة البضاعة في المخزن</th>
                                    <td class="text-end"><strong class="text-success">@bs.InventoryCostTotal.ToString("N2")</strong></td>
                                </tr>
                                <tr class="table-success">
                                    <th><strong>إجمالي الأصول</strong></th>
                                    <td class="text-end"><strong>@((bs.CustomersDebitSum + bs.TreasuryBalance + bs.InventoryCostTotal).ToString("N2"))</strong></td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted mb-3">الالتزامات</h6>
                            <table class="table table-sm table-bordered">
                                <tr>
                                    <th style="width: 50%;">مجموع العملاء الدائنين</th>
                                    <td class="text-end"><strong class="text-danger">@bs.CustomersCreditSum.ToString("N2")</strong></td>
                                </tr>
                                <tr class="table-danger">
                                    <th><strong>إجمالي الالتزامات</strong></th>
                                    <td class="text-end"><strong>@bs.CustomersCreditSum.ToString("N2")</strong></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <hr />
                    <div class="row mt-3">
                        <div class="col-12">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h5 class="card-title">حساب الربح من الميزانية:</h5>
                                    @{
                                        var profitWithAdjustAndTransfer = bs.BalanceSheetProfit + totalAdjustmentProfit + totalTransferProfit;
                                    }
                                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                        <div>
                                            <p class="mb-1"><strong>العملاء المدينون:</strong> @bs.CustomersDebitSum.ToString("N2")</p>
                                            <p class="mb-1"><strong>+ رصيد الخزنة:</strong> @bs.TreasuryBalance.ToString("N2")</p>
                                            <p class="mb-1"><strong>+ تكلفة المخزون:</strong> @bs.InventoryCostTotal.ToString("N2")</p>
                                            <p class="mb-1"><strong>− العملاء الدائنون:</strong> <span class="text-danger">@bs.CustomersCreditSum.ToString("N2")</span></p>
                                            <p class="mb-1"><strong>+ ربح التسوية:</strong> <span class="text-success">@totalAdjustmentProfit.ToString("N2")</span></p>
                                            <p class="mb-1"><strong>+ ربح التحويل:</strong> <span class="text-success">@totalTransferProfit.ToString("N2")</span></p>
                                            <hr class="my-2" />
                                            <p class="mb-0"><strong>إجمالي الربح (ميزانية + تسويات + تحويلات):</strong></p>
                                        </div>
                                        <div class="text-end">
                                            <h3 class="mb-0 @(profitWithAdjustAndTransfer >= 0 ? "text-success" : "text-danger")">
                                                @profitWithAdjustAndTransfer.ToString("N2")
                                            </h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                        <div class="alert alert-info mt-3 mb-0">
                        <small>
                            <strong>طرق حساب الربح:</strong> 
                            <ul class="mb-0">
                                <li><strong>ربح البيع:</strong> إيرادات المبيعات − تكلفة البضاعة المباعة (من فواتير المبيعات)</li>
                                <li><strong>ربح التسويات:</strong> فائض الجرد (زيادة مخزون) − عجز الجرد (نقصان مخزون) من التسويات المترحلة</li>
                                <li><strong>ربح التحويلات:</strong> ربح التحويلات بين المخازن عند التحويل بخصم أقل من الخصم المرجح</li>
                                <li><strong>ربح الميزانية:</strong> مجموع العملاء المدينين + رصيد الخزنة + تكلفة البضاعة في المخزن − مجموع العملاء الدائنين</li>
                            </ul>
                            @if (fromDate.HasValue || toDate.HasValue)
                            {
                                <text><strong>تم تطبيق فلتر التاريخ: </strong></text>
                                @if (fromDate.HasValue)
                                {
                                    <text>من @fromDate.Value.ToString("yyyy-MM-dd") </text>
                                }
                                @if (toDate.HasValue)
                                {
                                    <text>إلى @toDate.Value.ToString("yyyy-MM-dd")</text>
                                }
                            }
                        </small>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">لا توجد بيانات لعرضها</p>
        </div>
    }
</div>

