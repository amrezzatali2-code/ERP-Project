@using ERP.ViewModels
@using Microsoft.AspNetCore.Html
@using Microsoft.AspNetCore.WebUtilities
@{
    ViewData["Title"] = "تقرير: أرباح الأصناف";

    var reportData = ViewBag.ReportData as List<ProductProfitReportDto> ?? new List<ProductProfitReportDto>();
    var totalSalesRevenue = ViewBag.TotalSalesRevenue as decimal? ?? 0m;
    var totalSalesCost = ViewBag.TotalSalesCost as decimal? ?? 0m;
    var totalSalesProfit = ViewBag.TotalSalesProfit as decimal? ?? 0m;
    var totalReturnProfit = ViewBag.TotalReturnProfit as decimal? ?? 0m;
    var totalAdjustmentProfit = ViewBag.TotalAdjustmentProfit as decimal? ?? 0m;
    var totalTransferProfit = ViewBag.TotalTransferProfit as decimal? ?? 0m;
    var totalNetProfit = ViewBag.TotalNetProfit as decimal? ?? 0m;
    var totalSalesQtyAll = ViewBag.TotalSalesQty as decimal? ?? 0m;

    var page = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 10;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;

    var search = ViewBag.Search as string ?? "";
    var categoryId = ViewBag.CategoryId as int?;
    var warehouseId = ViewBag.WarehouseId as int?;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var includeZeroQty = ViewBag.IncludeZeroQty as bool? ?? false;
    var profitMethod = ViewBag.ProfitMethod as string ?? "both";
    var sort = ViewBag.Sort as string ?? "name";
    var dir = ViewBag.Dir as string ?? "asc";
    var filterCol_code = ViewBag.FilterCol_Code as string;
    var filterCol_name = ViewBag.FilterCol_Name as string;
    var filterCol_category = ViewBag.FilterCol_Category as string;
    var filterCol_salesrevenueExpr = ViewBag.FilterCol_SalesrevenueExpr as string;
    var filterCol_salescostExpr = ViewBag.FilterCol_SalescostExpr as string;
    var filterCol_salesprofitExpr = ViewBag.FilterCol_SalesprofitExpr as string;
    var filterCol_salesprofitpctExpr = ViewBag.FilterCol_SalesprofitpctExpr as string;
    var filterCol_adjustmentprofitExpr = ViewBag.FilterCol_AdjustmentprofitExpr as string;
    var filterCol_transferprofitExpr = ViewBag.FilterCol_TransferprofitExpr as string;
    var filterCol_salesqtyExpr = ViewBag.FilterCol_SalesqtyExpr as string;
    var filterCol_returnprofitExpr = ViewBag.FilterCol_ReturnprofitExpr as string;
    var filterCol_netprofitExpr = ViewBag.FilterCol_NetprofitExpr as string;

    // القوائم المنسدلة
    var categories = ViewBag.Categories as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var warehouses = ViewBag.Warehouses as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    int ps = pageSize;
    int start = totalCount == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1)) + 1;
    int end = (ps == 0 || totalCount == 0) ? totalCount : Math.Min(totalCount, page * ps);
    int first = 1, last = Math.Max(1, totalPages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    var n2 = System.Globalization.CultureInfo.InvariantCulture;

    string? FilterForCol(string colKey) =>
        colKey == "code" ? filterCol_code
        : colKey == "name" ? filterCol_name
        : colKey == "category" ? filterCol_category
        : colKey == "salesrevenue" ? filterCol_salesrevenueExpr
        : colKey == "salescost" ? filterCol_salescostExpr
        : colKey == "salesprofit" ? filterCol_salesprofitExpr
        : colKey == "salesprofitpct" ? filterCol_salesprofitpctExpr
        : colKey == "returnprofit" ? filterCol_returnprofitExpr
        : colKey == "adjustmentprofit" ? filterCol_adjustmentprofitExpr
        : colKey == "transferprofit" ? filterCol_transferprofitExpr
        : colKey == "salesqty" ? filterCol_salesqtyExpr
        : colKey == "netprofit" ? filterCol_netprofitExpr
        : null;

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };

    string Link(int p) => Url.Action("ProductProfits", "Reports", new
    {
        search,
        categoryId,
        warehouseId,
        fromDate,
        toDate,
        includeZeroQty,
        profitMethod,
        sort,
        dir,
        filterCol_code,
        filterCol_name,
        filterCol_category,
        filterCol_salesrevenueExpr,
        filterCol_salescostExpr,
        filterCol_salesprofitExpr,
        filterCol_salesprofitpctExpr,
        filterCol_returnprofitExpr,
        filterCol_adjustmentprofitExpr,
        filterCol_transferprofitExpr,
        filterCol_netprofitExpr,
        filterCol_salesqtyExpr,
        loadReport = true,
        page = p,
        pageSize = ps
    })!;

    var colValsDict = new Dictionary<string, string?>
    {
        ["loadReport"] = "true",
        ["mainSearch"] = search,
        ["categoryId"] = categoryId?.ToString(),
        ["warehouseId"] = warehouseId?.ToString(),
        ["fromDate"] = fromDate?.ToString("yyyy-MM-dd"),
        ["toDate"] = toDate?.ToString("yyyy-MM-dd"),
        ["includeZeroQty"] = includeZeroQty ? "true" : "false",
        ["profitMethod"] = profitMethod,
        ["sort"] = sort,
        ["dir"] = dir,
        ["filterCol_code"] = filterCol_code,
        ["filterCol_name"] = filterCol_name,
        ["filterCol_category"] = filterCol_category,
        ["filterCol_salesrevenueExpr"] = filterCol_salesrevenueExpr,
        ["filterCol_salescostExpr"] = filterCol_salescostExpr,
        ["filterCol_salesprofitExpr"] = filterCol_salesprofitExpr,
        ["filterCol_salesprofitpctExpr"] = filterCol_salesprofitpctExpr,
        ["filterCol_returnprofitExpr"] = filterCol_returnprofitExpr,
        ["filterCol_adjustmentprofitExpr"] = filterCol_adjustmentprofitExpr,
        ["filterCol_transferprofitExpr"] = filterCol_transferprofitExpr,
        ["filterCol_netprofitExpr"] = filterCol_netprofitExpr,
        ["filterCol_salesqtyExpr"] = filterCol_salesqtyExpr
    };
    var colValuesUrl = QueryHelpers.AddQueryString(Url.Action("GetProductProfitsColumnValues", "Reports")!, colValsDict.Where(kv => !string.IsNullOrEmpty(kv.Value)).ToDictionary(kv => kv.Key, kv => (string?)kv.Value));
}

<div dir="rtl" class="container-fluid">
    <div class="erp-list-filter-bar d-print-none mt-2">
        <form method="get" asp-action="ProductProfits" asp-controller="Reports" id="filtersForm">
            <input type="hidden" name="loadReport" value="true" />
            <input type="hidden" name="filterCol_code" value="@(filterCol_code ?? "")" />
            <input type="hidden" name="filterCol_name" value="@(filterCol_name ?? "")" />
            <input type="hidden" name="filterCol_category" value="@(filterCol_category ?? "")" />
            @if (!string.IsNullOrWhiteSpace(filterCol_salesrevenueExpr)) { <input type="hidden" name="filterCol_salesrevenueExpr" value="@filterCol_salesrevenueExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_salescostExpr)) { <input type="hidden" name="filterCol_salescostExpr" value="@filterCol_salescostExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_salesprofitExpr)) { <input type="hidden" name="filterCol_salesprofitExpr" value="@filterCol_salesprofitExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_salesprofitpctExpr)) { <input type="hidden" name="filterCol_salesprofitpctExpr" value="@filterCol_salesprofitpctExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_returnprofitExpr)) { <input type="hidden" name="filterCol_returnprofitExpr" value="@filterCol_returnprofitExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_adjustmentprofitExpr)) { <input type="hidden" name="filterCol_adjustmentprofitExpr" value="@filterCol_adjustmentprofitExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_transferprofitExpr)) { <input type="hidden" name="filterCol_transferprofitExpr" value="@filterCol_transferprofitExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_netprofitExpr)) { <input type="hidden" name="filterCol_netprofitExpr" value="@filterCol_netprofitExpr" /> }
            @if (!string.IsNullOrWhiteSpace(filterCol_salesqtyExpr)) { <input type="hidden" name="filterCol_salesqtyExpr" value="@filterCol_salesqtyExpr" /> }
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="profitMethod" value="@profitMethod" />
            <div class="row g-3 align-items-end flex-nowrap">
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">بحث</label>
                    <input type="text" name="search" class="form-control erp-filter-input" placeholder="اسم الصنف أو الباركود أو الكود..." autocomplete="off" value="@search" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">الفئة</label>
                    <select name="categoryId" class="form-select erp-filter-input">
                        <option value="">الكل</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Value" @(categoryId?.ToString() == cat.Value ? "selected" : null)>@cat.Text</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">المخزن</label>
                    <select name="warehouseId" class="form-select erp-filter-input">
                        <option value="">الكل</option>
                        @foreach (var wh in warehouses)
                        {
                            <option value="@wh.Value" @(warehouseId?.ToString() == wh.Value ? "selected" : null)>@wh.Text</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">من تاريخ</label>
                    <input type="date" name="fromDate" class="form-control erp-filter-input" value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date" name="toDate" class="form-control erp-filter-input" value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-12 col-lg-auto erp-filter-section d-flex align-items-end">
                    <div class="form-check border rounded px-2 py-1 bg-light d-flex align-items-center gap-2 flex-nowrap" style="max-width: 220px;">
                        <input class="form-check-input flex-shrink-0 m-0" type="checkbox" name="includeZeroQty" value="true" id="includeZeroQty" @(includeZeroQty ? "checked" : "") style="width: 1.05rem; height: 1.05rem;" />
                        <label class="form-check-label small mb-0 lh-sm" for="includeZeroQty">أصناف بلا حركة في الفترة</label>
                    </div>
                </div>
            </div>
        </form>
        <div class="erp-toolbar-two-rows mt-2">
            <div class="erp-toolbar-row flex-wrap gap-2 justify-content-end">
                <button type="submit" form="filtersForm" class="btn btn-erp btn-erp-primary btn-erp-sm"><span>📊</span> تجميع التقرير</button>
                <form method="get" asp-action="ProductProfits" asp-controller="Reports" class="d-inline-flex flex-nowrap gap-2 align-items-center erp-export-form">
                    <input type="hidden" name="loadReport" value="true" />
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="categoryId" value="@(categoryId?.ToString() ?? "")" />
                    <input type="hidden" name="warehouseId" value="@(warehouseId?.ToString() ?? "")" />
                    <input type="hidden" name="fromDate" value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                    <input type="hidden" name="toDate" value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                    <input type="hidden" name="includeZeroQty" value="@(includeZeroQty ? "true" : "false")" />
                    <input type="hidden" name="profitMethod" value="@profitMethod" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="filterCol_code" value="@(filterCol_code ?? "")" />
                    <input type="hidden" name="filterCol_name" value="@(filterCol_name ?? "")" />
                    <input type="hidden" name="filterCol_category" value="@(filterCol_category ?? "")" />
                    @if (!string.IsNullOrWhiteSpace(filterCol_salesrevenueExpr)) { <input type="hidden" name="filterCol_salesrevenueExpr" value="@filterCol_salesrevenueExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_salescostExpr)) { <input type="hidden" name="filterCol_salescostExpr" value="@filterCol_salescostExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_salesprofitExpr)) { <input type="hidden" name="filterCol_salesprofitExpr" value="@filterCol_salesprofitExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_salesprofitpctExpr)) { <input type="hidden" name="filterCol_salesprofitpctExpr" value="@filterCol_salesprofitpctExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_returnprofitExpr)) { <input type="hidden" name="filterCol_returnprofitExpr" value="@filterCol_returnprofitExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_adjustmentprofitExpr)) { <input type="hidden" name="filterCol_adjustmentprofitExpr" value="@filterCol_adjustmentprofitExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_transferprofitExpr)) { <input type="hidden" name="filterCol_transferprofitExpr" value="@filterCol_transferprofitExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_netprofitExpr)) { <input type="hidden" name="filterCol_netprofitExpr" value="@filterCol_netprofitExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_salesqtyExpr)) { <input type="hidden" name="filterCol_salesqtyExpr" value="@filterCol_salesqtyExpr" /> }
                    <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;" title="صيغة التصدير">
                        <option value="excel" selected>Excel</option>
                        <option value="pdf">PDF</option>
                    </select>
                    <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                </form>
                <a href="@Url.Action("ProductProfits", "Reports")" class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none"><span>🔄</span> إعادة تعيين</a>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="btnColumnsPp" data-bs-toggle="modal" data-bs-target="#columnsModalPp">اختيار الأعمدة</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="btnMovementPp" disabled title="حدد صفاً في الجدول">حركة الصنف</button>
                <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="btnPrintPp">طباعة</button>
            </div>
        </div>
    </div>

    <h5 class="mb-2 fs-6 text-secondary d-print-none">أرباح الأصناف</h5>

    @if (reportData.Any())
    {
        <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row mb-2" dir="rtl">
            <div class="col-auto">
                <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">عدد الأصناف (بعد الفلترة)</div>
                        <div class="h5 mb-0 text-primary fw-bold">@totalCount.ToString("N0", n2)</div>
                    </div>
                </div>
            </div>
            <div class="col-auto">
                <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #15803d !important; border-radius: 12px;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">إجمالي البيع</div>
                        <div class="h5 mb-0 text-success fw-bold">@totalSalesRevenue.ToString("N2", n2)</div>
                    </div>
                </div>
            </div>
            <div class="col-auto">
                <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #b45309 !important; border-radius: 12px;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">إجمالي التكلفة</div>
                        <div class="h5 mb-0 fw-bold">@totalSalesCost.ToString("N2", n2)</div>
                    </div>
                </div>
            </div>
            <div class="col-auto">
                <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #6366f1 !important; border-radius: 12px;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">صافي الربح (مجموع)</div>
                        <div class="h5 mb-0 text-primary fw-bold">@totalNetProfit.ToString("N2", n2)</div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (reportData.Any())
    {
        <div class="erp-list-selection-actions d-print-none mb-1" id="ppSelectionBar" style="display:none;">
            <span class="small text-muted">صف محدد — استخدم «حركة الصنف» أعلاه</span>
        </div>
        <div class="erp-table-scroll-container mt-2" dir="rtl">
            <div id="productProfitsTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="position: relative; max-height: 70vh; overflow-y: auto; overflow-x: auto;">
                <table id="productProfitsTable" class="table table-striped table-hover mb-0 erp-table erp-table-sortable" data-current-sort="@sort" data-current-dir="@dir" style="min-width: 1200px; table-layout: fixed;">
                    <colgroup>
                        <col style="width: 44px;" />
                        <col style="width: 80px;" />
                        <col style="width: 200px;" />
                        <col style="width: 100px;" />
                        <col style="width: 120px;" />
                        <col style="width: 120px;" />
                        <col style="width: 120px;" />
                        <col style="width: 100px;" />
                        <col style="width: 120px;" />
                        <col style="width: 120px;" />
                        <col style="width: 120px;" />
                        <col style="width: 100px;" />
                        <col style="width: 140px;" />
                    </colgroup>
                    <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                        <tr>
                            <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                                <input type="checkbox" id="chkAllRowsPp" title="تحديد الكل في الصفحة" />
                            </th>
                            <th style="min-width: 80px;" data-col="code">@filterableCol("code", "code", "الكود")</th>
                            <th style="min-width: 200px;" data-col="name">@filterableCol("name", "name", "اسم الصنف")</th>
                            <th style="min-width: 100px;" data-col="category">@filterableCol("category", "category", "الفئة")</th>
                            <th class="text-end" style="min-width: 120px;" data-col="salesrevenue">@filterableCol("salesrevenue", "salesrevenue", "البيع")</th>
                            <th class="text-end" style="min-width: 120px;" data-col="salescost">@filterableCol("salescost", "salescost", "التكلفة")</th>
                            <th class="text-end" style="min-width: 120px;" data-col="salesprofit">@filterableCol("salesprofit", "salesprofit", "الربح (بيع)")</th>
                            <th class="text-end" style="min-width: 100px;" data-col="salesprofitpct">@filterableCol("salesprofitpct", "salesprofitpct", "نسبة الربح %")</th>
                            <th class="text-end" style="min-width: 120px;" data-col="returnprofit">@filterableCol("returnprofit", "returnprofit", "ربح المرتجعات")</th>
                            <th class="text-end" style="min-width: 120px;" data-col="adjustmentprofit">@filterableCol("adjustmentprofit", "adjustmentprofit", "الربح (تسويات)")</th>
                            <th class="text-end" style="min-width: 120px;" data-col="transferprofit">@filterableCol("transferprofit", "transferprofit", "الربح (تحويلات)")</th>
                            <th class="text-end" style="min-width: 100px;" data-col="salesqty">@filterableCol("salesqty", "salesqty", "الكمية")</th>
                            <th class="text-end" style="min-width: 140px;" data-col="netprofit">@filterableCol("netprofit", "netprofit", "صافي الربح")</th>
                        </tr>
                    </thead>
                        <tbody>
                            @foreach (var item in reportData)
                            {
                                var movUrl = Url.Action("Show", "Products", new { id = item.ProdId }) + "?frame=1";
                                <tr class="erp-list-selectable-row" data-prod-id="@item.ProdId" data-movement-url="@movUrl" data-tab-title="@item.ProdName">
                                    <td class="text-center no-print" data-col="select">
                                        <input type="checkbox" class="row-select" value="@item.ProdId" />
                                    </td>
                                    <td data-col="code"><strong>@item.ProdCode</strong></td>
                                    <td data-col="name">@item.ProdName</td>
                                    <td data-col="category"><small class="text-muted">@item.CategoryName</small></td>
                                    
                                    @* ربح البيع *@
                                    <td class="text-end" data-col="salesrevenue">@item.SalesRevenue.ToString("N2")</td>
                                    <td class="text-end" data-col="salescost">@item.SalesCost.ToString("N2")</td>
                                    <td class="text-end" data-col="salesprofit">
                                        <strong class="@(item.SalesProfit >= 0 ? "text-success" : "text-danger")">
                                            @item.SalesProfit.ToString("N2")
                                        </strong>
                                    </td>
                                    <td class="text-end" data-col="salesprofitpct">
                                        <span class="@(item.SalesProfitPercent >= 0 ? "text-success" : "text-danger")">
                                            @item.SalesProfitPercent.ToString("N2")%
                                        </span>
                                    </td>

                                    @* ربح المرتجعات *@
                                    <td class="text-end" data-col="returnprofit">
                                        <strong class="@(item.ReturnProfit >= 0 ? "text-success" : "text-danger")">
                                            @item.ReturnProfit.ToString("N2")
                                        </strong>
                                    </td>
                                    
                                    @* ربح التسويات *@
                                    <td class="text-end" data-col="adjustmentprofit">
                                        <strong class="@(item.AdjustmentProfit >= 0 ? "text-success" : "text-danger")">
                                            @item.AdjustmentProfit.ToString("N2")
                                        </strong>
                                    </td>
                                    
                                    @* ربح التحويلات *@
                                    <td class="text-end" data-col="transferprofit">
                                        <strong class="@(item.TransferProfit >= 0 ? "text-success" : "text-danger")">
                                            @item.TransferProfit.ToString("N2")
                                        </strong>
                                    </td>
                                    
                                    @* إحصائيات *@
                                    <td class="text-end" data-col="salesqty">@item.SalesQty.ToString("N2")</td>
                                    <td class="text-end" data-col="netprofit">
                                        <strong class="@(item.NetProfit >= 0 ? "text-success" : "text-danger")">
                                            @item.NetProfit.ToString("N2")
                                        </strong>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold text-start erp-list-summary-tfoot">
                            <tr>
                                <td data-col="select" class="no-print"></td>
                                <td data-col="code" class="text-start"><strong>المجموع الإجمالي:</strong></td>
                                <td data-col="name"></td>
                                <td data-col="category"></td>
                                <td data-col="salesrevenue" class="text-end"><strong>@totalSalesRevenue.ToString("N2")</strong></td>
                                <td data-col="salescost" class="text-end"><strong>@totalSalesCost.ToString("N2")</strong></td>
                                <td data-col="salesprofit" class="text-end">
                                    <strong class="@(totalSalesProfit >= 0 ? "text-success" : "text-danger")">
                                        @totalSalesProfit.ToString("N2")
                                    </strong>
                                </td>
                                <td data-col="salesprofitpct" class="text-end">
                                    <strong>
                                        @((totalSalesRevenue > 0 ? (totalSalesProfit / totalSalesRevenue * 100) : 0).ToString("N2"))%
                                    </strong>
                                </td>
                                <td data-col="returnprofit" class="text-end">
                                    <strong class="@(totalReturnProfit >= 0 ? "text-success" : "text-danger")">
                                        @totalReturnProfit.ToString("N2")
                                    </strong>
                                </td>
                                <td data-col="adjustmentprofit" class="text-end">
                                    <strong class="@(totalAdjustmentProfit >= 0 ? "text-success" : "text-danger")">
                                        @totalAdjustmentProfit.ToString("N2")
                                    </strong>
                                </td>
                                <td data-col="transferprofit" class="text-end">
                                    <strong class="@(totalTransferProfit >= 0 ? "text-success" : "text-danger")">
                                        @totalTransferProfit.ToString("N2")
                                    </strong>
                                </td>
                                <td data-col="salesqty" class="text-end">@totalSalesQtyAll.ToString("N2")</td>
                                <td data-col="netprofit" class="text-end">
                                    <strong class="text-primary">
                                        @totalNetProfit.ToString("N2")
                                    </strong>
                                </td>
                            </tr>
                        </tfoot>
                </table>
            </div>
        </div>

        @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة + الترقيم ===== *@
        @if (reportData.Any())
        {
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print" dir="rtl">
                <small class="text-muted order-1">عرض @start - @end من @totalCount</small>
                <form method="get" asp-action="ProductProfits" asp-controller="Reports" class="d-flex align-items-center gap-2 order-2">
                    <input type="hidden" name="loadReport" value="true" />
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="categoryId" value="@(categoryId?.ToString() ?? "")" />
                    <input type="hidden" name="warehouseId" value="@(warehouseId?.ToString() ?? "")" />
                    <input type="hidden" name="fromDate" value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                    <input type="hidden" name="toDate" value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                    <input type="hidden" name="includeZeroQty" value="@(includeZeroQty ? "true" : "false")" />
                    <input type="hidden" name="profitMethod" value="@profitMethod" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="filterCol_code" value="@(filterCol_code ?? "")" />
                    <input type="hidden" name="filterCol_name" value="@(filterCol_name ?? "")" />
                    <input type="hidden" name="filterCol_category" value="@(filterCol_category ?? "")" />
                    @if (!string.IsNullOrWhiteSpace(filterCol_salesrevenueExpr)) { <input type="hidden" name="filterCol_salesrevenueExpr" value="@filterCol_salesrevenueExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_salescostExpr)) { <input type="hidden" name="filterCol_salescostExpr" value="@filterCol_salescostExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_salesprofitExpr)) { <input type="hidden" name="filterCol_salesprofitExpr" value="@filterCol_salesprofitExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_salesprofitpctExpr)) { <input type="hidden" name="filterCol_salesprofitpctExpr" value="@filterCol_salesprofitpctExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_returnprofitExpr)) { <input type="hidden" name="filterCol_returnprofitExpr" value="@filterCol_returnprofitExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_adjustmentprofitExpr)) { <input type="hidden" name="filterCol_adjustmentprofitExpr" value="@filterCol_adjustmentprofitExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_transferprofitExpr)) { <input type="hidden" name="filterCol_transferprofitExpr" value="@filterCol_transferprofitExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_netprofitExpr)) { <input type="hidden" name="filterCol_netprofitExpr" value="@filterCol_netprofitExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_salesqtyExpr)) { <input type="hidden" name="filterCol_salesqtyExpr" value="@filterCol_salesqtyExpr" /> }
                    <label class="form-label m-0 nowrap">حجم الصفحة</label>
                    <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="10"@Html.Raw(ps == 10 ? " selected" : "")>10</option>
                        <option value="25"@Html.Raw(ps == 25 ? " selected" : "")>25</option>
                        <option value="50"@Html.Raw(ps == 50 ? " selected" : "")>50</option>
                        <option value="100"@Html.Raw(ps == 100 ? " selected" : "")>100</option>
                        <option value="200"@Html.Raw(ps == 200 ? " selected" : "")>200</option>
                        <option value="0"@Html.Raw(ps == 0 ? " selected" : "")>الكل</option>
                    </select>
                </form>
                @if (totalPages > 1)
                {
                    <nav class="order-3" aria-label="pagination">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(page == 1 ? "disabled" : "")"><a class="page-link" href="@Link(1)">الأول</a></li>
                            <li class="page-item @(page == 1 ? "disabled" : "")"><a class="page-link" href="@Link(prev)">السابق</a></li>
                            <li class="page-item disabled"><span class="page-link">صفحة @(page) من @(totalPages)</span></li>
                            <li class="page-item @(page >= totalPages ? "disabled" : "")"><a class="page-link" href="@Link(next)">التالي</a></li>
                            <li class="page-item @(page >= totalPages ? "disabled" : "")"><a class="page-link" href="@Link(last)">الأخير</a></li>
                        </ul>
                    </nav>
                }
            </div>
        }

        @* ===== ربح الميزانية ===== *@
        @if (ViewBag.BalanceSheetData != null)
        {
            var bs = ViewBag.BalanceSheetData;
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">📊 ربح الميزانية</h5>
                    <small>مجموع العملاء المدينين + رصيد الخزنة + تكلفة البضاعة في المخزن − مجموع العملاء الدائنين</small>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-muted mb-3">الإيرادات (أصول)</h6>
                            <table class="table table-sm table-bordered">
                                <tr>
                                    <th style="width: 50%;">مجموع العملاء المدينين</th>
                                    <td class="text-end"><strong class="text-success">@bs.CustomersDebitSum.ToString("N2")</strong></td>
                                </tr>
                                <tr>
                                    <th>رصيد الخزنة</th>
                                    <td class="text-end"><strong class="text-success">@bs.TreasuryBalance.ToString("N2")</strong></td>
                                </tr>
                                <tr>
                                    <th>تكلفة البضاعة في المخزن</th>
                                    <td class="text-end"><strong class="text-success">@bs.InventoryCostTotal.ToString("N2")</strong></td>
                                </tr>
                                <tr class="table-success">
                                    <th><strong>إجمالي الأصول</strong></th>
                                    <td class="text-end"><strong>@((bs.CustomersDebitSum + bs.TreasuryBalance + bs.InventoryCostTotal).ToString("N2"))</strong></td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted mb-3">الالتزامات</h6>
                            <table class="table table-sm table-bordered">
                                <tr>
                                    <th style="width: 50%;">مجموع العملاء الدائنين</th>
                                    <td class="text-end"><strong class="text-danger">@bs.CustomersCreditSum.ToString("N2")</strong></td>
                                </tr>
                                <tr class="table-danger">
                                    <th><strong>إجمالي الالتزامات</strong></th>
                                    <td class="text-end"><strong>@bs.CustomersCreditSum.ToString("N2")</strong></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <hr />
                    <div class="row mt-3">
                        <div class="col-12">
                            <div class="card bg-light border">
                                <div class="card-body">
                                    @{
                                        var balanceProfit = bs.CustomersDebitSum + bs.TreasuryBalance + bs.InventoryCostTotal - bs.CustomersCreditSum;
                                    }
                                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                                        <div>
                                            <p class="mb-1"><strong>العملاء المدينون:</strong> @bs.CustomersDebitSum.ToString("N2")</p>
                                            <p class="mb-1"><strong>+ رصيد الخزنة:</strong> @bs.TreasuryBalance.ToString("N2")</p>
                                            <p class="mb-1"><strong>+ تكلفة المخزون:</strong> @bs.InventoryCostTotal.ToString("N2")</p>
                                            <p class="mb-1"><strong>− العملاء الدائنون:</strong> <span class="text-danger">@bs.CustomersCreditSum.ToString("N2")</span></p>
                                            <p class="mb-0"><strong>إجمالي الربح (صافي الأصول):</strong></p>
                                            <p class="small text-muted mb-0 mt-2">
                                                ربح التسوية (@totalAdjustmentProfit.ToString("N2")) وربح التحويل (@totalTransferProfit.ToString("N2")) مدمجان في تكلفة المخزون في هذا التقرير ولا يُضافان مرة ثانية إلى ربح الميزانية.
                                            </p>
                                        </div>
                                        <div class="text-end">
                                            <h3 class="mb-0 @(balanceProfit >= 0 ? "text-success" : "text-danger")">
                                                @balanceProfit.ToString("N2")
                                            </h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">لا توجد بيانات لعرضها</p>
        </div>
    }
</div>

<div id="erpColumnFilterPanelPp" class="erp-column-filter-panel d-none" dir="rtl">
    <div class="erp-column-filter-header">
        <span>ترتيب وفلتر</span>
        <button type="button" class="btn-close btn-sm" aria-label="إغلاق"></button>
    </div>
    <div class="erp-column-filter-body">
        <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
            <div class="d-flex flex-column gap-1">
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc"><span class="erp-sort-arrow">▲</span> ترتيب تصاعدي</button>
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc"><span class="erp-sort-arrow">▼</span> ترتيب تنازلي</button>
            </div>
        </div>
        <div class="erp-filter-section">
            <div id="erpColumnFilterSearchRow">
                <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                <input type="text" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
            </div>
            <div class="erp-column-filter-list">
                <div class="text-muted text-center py-3">جاري التحميل...</div>
            </div>
        </div>
        <div class="erp-column-filter-actions">
            <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
            <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح الفلتر</button>
        </div>
    </div>
</div>

<div class="modal fade no-print erp-columns-modal" id="columnsModalPp" tabindex="-1" aria-labelledby="columnsModalPpLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalPpLabel">اختيار الأعمدة الظاهرة</h5>
                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListPp" class="erp-columns-modal-list"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-erp btn-erp-secondary" data-bs-dismiss="modal">إغلاق</button>
                <button type="button" id="btnApplyColumnsPp" class="btn btn-erp btn-erp-primary">تطبيق</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        #productProfitsTable thead th { background-color: #fafbfc !important; color: #212529; border-bottom: 1px solid #dee2e6; font-weight: 600; }
        #productProfitsTable tfoot { background-color: #e9ecef !important; border-top: 1px solid #dee2e6; }
        #productProfitsTable tfoot td { box-sizing: border-box; }
        #productProfitsTable tfoot td.text-end { text-align: end !important; }
        .erp-col-filter-btn { color: #64748b; }
        .erp-col-filter-btn:hover { color: #475569; }
        #erpColumnFilterPanelPp.erp-column-filter-panel { min-width: 280px; max-width: min(380px, 92vw); z-index: 1055; }
    </style>
}

@section Scripts {
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        (function () {
            function scrollRtlStart() {
                var el = document.getElementById('productProfitsTableScrollWrapper');
                if (!el) return;
                requestAnimationFrame(function () {
                    el.scrollLeft = el.scrollWidth - el.clientWidth;
                });
            }
            scrollRtlStart();
        })();

        if (typeof ERP !== 'undefined' && ERP.initListColumnFilter) {
            ERP.initListColumnFilter({
                panelId: 'erpColumnFilterPanelPp',
                tableId: 'productProfitsTable',
                wrapperId: 'productProfitsTableScrollWrapper',
                getColumnValuesUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(colValuesUrl)),
                defaultSort: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sort ?? "name")),
                defaultDir: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dir ?? "asc")),
                numericColumns: ['salesrevenue', 'salescost', 'salesprofit', 'salesprofitpct', 'returnprofit', 'adjustmentprofit', 'transferprofit', 'salesqty', 'netprofit']
            });
        }

        if (typeof ERP !== 'undefined' && ERP.initListSelection) {
            ERP.initListSelection({
                rowSelector: '.erp-list-selectable-row',
                movementButtonId: 'btnMovementPp',
                movementUrlAttribute: 'data-movement-url',
                movementTabTitle: 'حركة الصنف',
                movementTabId: 'product-profit-move-tab',
                idAttribute: 'data-prod-id'
            });
        }

        document.getElementById('btnPrintPp')?.addEventListener('click', function () { window.print(); });

        document.addEventListener('DOMContentLoaded', function () {
            var form = document.getElementById('filtersForm');
            var includeZeroCb = document.getElementById('includeZeroQty');
            if (form && includeZeroCb) {
                form.addEventListener('submit', function () {
                    var existingHidden = form.querySelector('input[name="includeZeroQty"][type="hidden"]');
                    if (existingHidden) existingHidden.remove();
                    if (!includeZeroCb.checked) {
                        var hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = 'includeZeroQty';
                        hidden.value = 'false';
                        form.appendChild(hidden);
                    }
                });
            }

            var table = document.getElementById('productProfitsTable');
            var chkAll = document.getElementById('chkAllRowsPp');
            if (table && chkAll) {
                chkAll.addEventListener('change', function () {
                    table.querySelectorAll('tbody .row-select').forEach(function (cb) { cb.checked = chkAll.checked; });
                });
            }

            var storageKey = 'product-profits-columns-visibility';
            if (!table) return;
            var headerCells = Array.from(table.querySelectorAll('thead th[data-col]'));
            var columns = headerCells
                .filter(function (th) { return !th.hasAttribute('data-col-fixed'); })
                .map(function (th) {
                    return {
                        key: th.getAttribute('data-col'),
                        title: (th.querySelector('.erp-col-title') && th.querySelector('.erp-col-title').textContent) || th.innerText || ''
                    };
                });
            if (columns.length === 0) return;

            var hidden = [];
            try {
                var saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch (e) { hidden = []; }

            function applyVisibility() {
                columns.forEach(function (col) {
                    var isHidden = hidden.indexOf(col.key) >= 0;
                    table.querySelectorAll("[data-col='" + col.key + "']").forEach(function (cell) {
                        cell.classList.toggle('d-none', isHidden);
                    });
                });
            }
            applyVisibility();

            var listContainer = document.getElementById('columnsListPp');
            var btnApply = document.getElementById('btnApplyColumnsPp');
            if (listContainer) {
                listContainer.innerHTML = '';
                columns.forEach(function (col) {
                    var id = 'col_pp_' + col.key;
                    var wrapper = document.createElement('div');
                    wrapper.className = 'form-check mb-1';
                    var cb = document.createElement('input');
                    cb.type = 'checkbox';
                    cb.className = 'form-check-input ms-2';
                    cb.id = id;
                    cb.checked = hidden.indexOf(col.key) < 0;
                    cb.dataset.colKey = col.key;
                    var label = document.createElement('label');
                    label.className = 'form-check-label';
                    label.htmlFor = id;
                    label.textContent = col.title.trim() || col.key;
                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }
            btnApply?.addEventListener('click', function () {
                hidden = [];
                listContainer?.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
                    if (!cb.checked) hidden.push(cb.dataset.colKey || '');
                });
                try { localStorage.setItem(storageKey, JSON.stringify(hidden)); } catch (e) { }
                applyVisibility();
                var modal = document.getElementById('columnsModalPp');
                if (modal && window.bootstrap) bootstrap.Modal.getOrCreateInstance(modal).hide();
            });
        });
    </script>
}
