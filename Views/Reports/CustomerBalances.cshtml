@using Microsoft.AspNetCore.Html
@using ERP.ViewModels
@{
    ViewData["Title"] = "تقرير: أرصدة العملاء";

    var reportData = ViewBag.ReportData as List<CustomerBalanceReportDto> ?? new List<CustomerBalanceReportDto>();
    var totalBalance = ViewBag.TotalBalance as decimal? ?? 0m;
    var totalDebit = ViewBag.TotalDebit as decimal? ?? 0m;
    var totalCredit = ViewBag.TotalCredit as decimal? ?? 0m;
    var totalSales = ViewBag.TotalSales as decimal? ?? 0m;
    var totalPurchases = ViewBag.TotalPurchases as decimal? ?? 0m;
    var totalReturns = ViewBag.TotalReturns as decimal? ?? 0m;
    var totalCreditLimit = ViewBag.TotalCreditLimit as decimal? ?? 0m;
    var totalAvailableCredit = ViewBag.TotalAvailableCredit as decimal? ?? 0m;

    // Pagination
    var page = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 200;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;

    // الفلاتر من ViewBag
    var search = ViewBag.Search as string ?? "";
    var partyCategory = ViewBag.PartyCategory as string;
    var governorateId = ViewBag.GovernorateId as int?;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var includeZeroBalance = ViewBag.IncludeZeroBalance as bool? ?? false;
    var sortBy = ViewBag.SortBy as string ?? "name";
    var sortDir = ViewBag.SortDir as string ?? "asc";
    string? filterCol_code = ViewBag.FilterCol_Code as string ?? Context.Request.Query["filterCol_code"].ToString();
    string? filterCol_name = ViewBag.FilterCol_Name as string ?? Context.Request.Query["filterCol_name"].ToString();
    string? filterCol_category = ViewBag.FilterCol_Category as string ?? Context.Request.Query["filterCol_category"].ToString();
    string? filterCol_phone = ViewBag.FilterCol_Phone as string ?? Context.Request.Query["filterCol_phone"].ToString();
    string? filterCol_debit = ViewBag.FilterCol_Debit as string ?? Context.Request.Query["filterCol_debit"].ToString();
    string? filterCol_credit = ViewBag.FilterCol_Credit as string ?? Context.Request.Query["filterCol_credit"].ToString();
    string? filterCol_creditlimit = ViewBag.FilterCol_CreditLimit as string ?? Context.Request.Query["filterCol_creditlimit"].ToString();
    string? filterCol_sales = ViewBag.FilterCol_Sales as string ?? Context.Request.Query["filterCol_sales"].ToString();
    string? filterCol_purchases = ViewBag.FilterCol_Purchases as string ?? Context.Request.Query["filterCol_purchases"].ToString();
    string? filterCol_returns = ViewBag.FilterCol_Returns as string ?? Context.Request.Query["filterCol_returns"].ToString();
    string? filterCol_availablecredit = ViewBag.FilterCol_AvailableCredit as string ?? Context.Request.Query["filterCol_availablecredit"].ToString();

    // القوائم المنسدلة
    var governorates = ViewBag.Governorates as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    // دالة عمود قابل للفلترة (بنمط Excel)
    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        var currentFilter = colKey == "code" ? filterCol_code : colKey == "name" ? filterCol_name : colKey == "category" ? filterCol_category :
            colKey == "phone" ? filterCol_phone : colKey == "debit" ? filterCol_debit : colKey == "credit" ? filterCol_credit :
            colKey == "creditlimit" ? filterCol_creditlimit : colKey == "sales" ? filterCol_sales : colKey == "purchases" ? filterCol_purchases :
            colKey == "returns" ? filterCol_returns : colKey == "availablecredit" ? filterCol_availablecredit : null;
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sortBy, sortKey, StringComparison.OrdinalIgnoreCase);
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };

    // دالة إنشاء رابط Pagination (مع فلاتر الأعمدة)
    Func<int, string> pageUrl = (p) =>
    {
        return Url.Action("CustomerBalances", "Reports", new
        {
            search,
            partyCategory,
            governorateId,
            fromDate,
            toDate,
            includeZeroBalance,
            sortBy,
            sortDir,
            filterCol_code, filterCol_name, filterCol_category, filterCol_phone,
            filterCol_debit, filterCol_credit, filterCol_creditlimit, filterCol_sales,
            filterCol_purchases, filterCol_returns, filterCol_availablecredit,
            loadReport = true,
            page = p,
            pageSize
        }) ?? "#";
    };
}

<div dir="rtl" class="container-fluid">
    @* ===== شريط الفلاتر الموحد (نفس Index) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <form method="get" asp-action="CustomerBalances" asp-controller="Reports" id="filtersForm">
            <div class="row g-3 align-items-end">
                <input type="hidden" name="loadReport" value="true" />
                @if (!string.IsNullOrWhiteSpace(filterCol_code)) { <input type="hidden" name="filterCol_code" value="@filterCol_code" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_category)) { <input type="hidden" name="filterCol_category" value="@filterCol_category" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_phone)) { <input type="hidden" name="filterCol_phone" value="@filterCol_phone" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_debit)) { <input type="hidden" name="filterCol_debit" value="@filterCol_debit" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_credit)) { <input type="hidden" name="filterCol_credit" value="@filterCol_credit" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_creditlimit)) { <input type="hidden" name="filterCol_creditlimit" value="@filterCol_creditlimit" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_sales)) { <input type="hidden" name="filterCol_sales" value="@filterCol_sales" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_purchases)) { <input type="hidden" name="filterCol_purchases" value="@filterCol_purchases" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_returns)) { <input type="hidden" name="filterCol_returns" value="@filterCol_returns" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_availablecredit)) { <input type="hidden" name="filterCol_availablecredit" value="@filterCol_availablecredit" /> }
                <div class="col-12 col-lg-3 erp-filter-section">
                    <label class="form-label">بحث</label>
                    <input type="text"
                           name="search"
                           list="customersList"
                           class="form-control erp-filter-input"
                           placeholder="اكتب اسم العميل أو جزء منه..."
                           autocomplete="off"
                           value="@search" />
                    <datalist id="customersList">
                        @if (ViewBag.CustomersAuto != null)
                        {
                            foreach (var c in ViewBag.CustomersAuto)
                            {
                                <option value="@c.Name" data-id="@c.Id" data-phone="@c.Phone" data-category="@c.Category"></option>
                            }
                        }
                    </datalist>
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">فئة العميل</label>
                    <input type="text"
                           name="partyCategory"
                           class="form-control erp-filter-input"
                           placeholder="عميل / مورد..."
                           value="@partyCategory" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">المحافظة</label>
                    <select name="governorateId" class="form-select erp-filter-input">
                        <option value="">الكل</option>
                        @foreach (var gov in governorates)
                        {
                            <option value="@gov.Value" @(governorateId?.ToString() == gov.Value ? "selected" : null)>@gov.Text</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">من تاريخ</label>
                    <input type="date"
                           name="fromDate"
                           dir="ltr"
                           class="form-control erp-filter-input"
                           value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date"
                           name="toDate"
                           dir="ltr"
                           class="form-control erp-filter-input"
                           value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">خيارات</label>
                    <div class="d-flex align-items-center gap-2">
                        <div class="form-check mb-0">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="includeZeroBalance"
                                   value="true"
                                   id="includeZeroBalance"
                                   @(includeZeroBalance ? "checked" : "") />
                            <label class="form-check-label small" for="includeZeroBalance">عرض الصفر</label>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                    <div class="d-flex flex-nowrap gap-2 customer-balances-btns">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm customer-balances-btn customer-balances-btn-primary">
                            <span>📊</span> تجميع التقرير
                        </button>
                        <a href="@Url.Action("CustomerBalances", "Reports")" class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none customer-balances-btn customer-balances-btn-secondary">
                            <span>🔄</span> إعادة تعيين
                        </a>
                        @if (reportData.Any())
                        {
                            <a href="@Url.Action("ExportCustomerBalances", "Reports", new { search, partyCategory, governorateId, fromDate, toDate, includeZeroBalance, sortBy, sortDir, filterCol_code, filterCol_name, filterCol_category, filterCol_phone, filterCol_debit, filterCol_credit, filterCol_creditlimit, filterCol_sales, filterCol_purchases, filterCol_returns, filterCol_availablecredit })"
                               class="btn btn-erp btn-erp-success btn-erp-sm text-decoration-none customer-balances-btn customer-balances-btn-success">
                                <span>📥</span> تصدير Excel
                            </a>
                        }
                    </div>
                </div>
                @if (reportData.Any() && totalPages > 1)
                {
                    <div class="col-12 col-lg-2 erp-filter-section">
                        <label class="form-label">حجم الصفحة</label>
                        <select name="pageSize" class="form-select erp-filter-input" onchange="this.form.submit()">
                            <option value="200" @(pageSize == 200 ? "selected" : "")>200</option>
                            <option value="500" @(pageSize == 500 ? "selected" : "")>500</option>
                            <option value="1000" @(pageSize == 1000 ? "selected" : "")>1000</option>
                            <option value="5000" @(pageSize == 5000 ? "selected" : "")>5000</option>
                            <option value="0" @(pageSize == 0 || pageSize >= totalCount ? "selected" : "")>الكل</option>
                        </select>
                    </div>
                }
            </div>
        </form>
    </div>

    @* ===== Pagination Info ===== *@
    @if (reportData.Any() && totalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <small class="text-muted">
                عرض @((page - 1) * pageSize + 1) - @(Math.Min(page * pageSize, totalCount)) من @totalCount
            </small>
            <small class="text-muted">
                @($"صفحة {page} من {totalPages}")
            </small>
        </div>
    }

    @* ===== جدول البيانات (نفس نظام Index) ===== *@
    @if (reportData.Any())
    {
        <div class="erp-table-wrapper mt-3 erp-print-area" style="position: relative; max-height: 70vh; overflow-y: auto;">
            <table id="customerBalancesTable" class="table table-striped table-hover erp-table erp-table-sortable">
                <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #f8f9fa !important;">
                    <tr>
                        <th style="width: 80px;" data-col="code">@filterableCol("code", "code", "الكود")</th>
                        <th style="width: 200px;" data-col="name">@filterableCol("name", "name", "اسم العميل")</th>
                        <th data-col="category">@filterableCol("category", "category", "فئة العميل")</th>
                        <th data-col="phone">@filterableCol("phone", "phone", "الهاتف")</th>
                        <th class="text-end" style="width: 120px;" data-col="debit">@filterableCol("debit", "balance", "مدين")</th>
                        <th class="text-end" style="width: 120px;" data-col="credit">@filterableCol("credit", "balance", "دائن")</th>
                        <th class="text-end" style="width: 120px;" data-col="creditlimit">@filterableCol("creditlimit", "creditlimit", "الحد الائتماني")</th>
                        <th class="text-end" style="width: 120px;" data-col="sales">@filterableCol("sales", "sales", "المبيعات")</th>
                        <th class="text-end" style="width: 120px;" data-col="purchases">@filterableCol("purchases", "purchases", "المشتريات")</th>
                        <th class="text-end" style="width: 120px;" data-col="returns">@filterableCol("returns", "returns", "المرتجعات")</th>
                        <th class="text-end" style="width: 130px;" data-col="availablecredit">@filterableCol("availablecredit", "availablecredit", "الائتمان المتاح")</th>
                        <th class="text-nowrap no-print" style="width:120px;" data-col="actions" data-col-fixed="true">حجم تعامل</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in reportData)
                    {
                        <tr>
                            <td data-col="code"><strong>@item.CustomerCode</strong></td>
                            <td data-col="name">@item.CustomerName</td>
                            <td data-col="category"><small class="text-muted">@item.PartyCategory</small></td>
                            <td data-col="phone"><small>@item.Phone1</small></td>
                            <td data-col="debit" class="text-end">@(item.CurrentBalance > 0 ? item.CurrentBalance.ToString("N2") : "—")</td>
                            <td data-col="credit" class="text-end">@(item.CurrentBalance < 0 ? Math.Abs(item.CurrentBalance).ToString("N2") : "—")</td>
                            <td data-col="creditlimit" class="text-end">@item.CreditLimit.ToString("N2")</td>
                            <td data-col="sales" class="text-end">@item.TotalSales.ToString("N2")</td>
                            <td data-col="purchases" class="text-end">@item.TotalPurchases.ToString("N2")</td>
                            <td data-col="returns" class="text-end">@item.TotalReturns.ToString("N2")</td>
                            <td data-col="availablecredit" class="text-end">@item.AvailableCredit.ToString("N2")</td>
                            <td class="text-nowrap no-print" data-col="actions">
                                <a class="btn btn-erp btn-erp-secondary btn-erp-sm app-menu-link"
                                   asp-controller="Customers"
                                   asp-action="Show"
                                   asp-route-id="@item.CustomerId"
                                   data-tab-id="customer-engagement"
                                   data-tab-title="حجم تعامل — @item.CustomerName">
                                    حجم تعامل
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-secondary fw-bold">
                    <tr>
                        <td colspan="5" class="text-end"><strong>المجموع الإجمالي:</strong></td>
                        <td data-col="debit" class="text-end"><strong>@totalDebit.ToString("N2")</strong></td>
                        <td data-col="credit" class="text-end"><strong>@totalCredit.ToString("N2")</strong></td>
                        <td data-col="creditlimit" class="text-end"><strong>@totalCreditLimit.ToString("N2")</strong></td>
                        <td data-col="sales" class="text-end"><strong>@totalSales.ToString("N2")</strong></td>
                        <td data-col="purchases" class="text-end"><strong>@totalPurchases.ToString("N2")</strong></td>
                        <td data-col="returns" class="text-end"><strong>@totalReturns.ToString("N2")</strong></td>
                        <td data-col="availablecredit" class="text-end">
                            <strong class="customer-balances-total-value">@totalAvailableCredit.ToString("N2")</strong>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>

        @* لوحة فلتر العمود (بنمط Excel) *@
        <div id="erpColumnFilterPanel" class="erp-column-filter-panel d-none" dir="rtl">
            <div class="erp-column-filter-header">
                <span id="erpColumnFilterTitle">ترتيب وفلتر</span>
                <button type="button" class="btn-close btn-sm" id="erpColumnFilterClose" aria-label="إغلاق"></button>
            </div>
            <div class="erp-column-filter-body">
                <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                    <label class="form-label small mb-1 fw-bold">الترتيب:</label>
                    <div class="d-flex flex-column gap-1">
                        <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
                    </div>
                </div>
                <div class="erp-filter-section">
                    <div id="erpColumnFilterSearchRow">
                        <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                        <input type="text" id="erpColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                    </div>
                    <div id="erpColumnFilterList" class="erp-column-filter-list">
                        <div class="text-muted text-center py-3">جاري التحميل...</div>
                    </div>
                </div>
                <div class="erp-column-filter-actions">
                    <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOk">تطبيق</button>
                    <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClear">مسح الفلتر</button>
                </div>
            </div>
        </div>

        @* ===== Pagination Controls ===== *@
        @if (totalPages > 1)
        {
            <nav aria-label="pagination" class="mt-3 d-print-none">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(page == 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(1)">الأول</a>
                    </li>
                    <li class="page-item @(page == 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page - 1)">السابق</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">@($"صفحة {page} من {totalPages}")</span>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page + 1)">التالي</a>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(totalPages)">الأخير</a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">لا توجد بيانات لعرضها</p>
        </div>
    }
</div>

@section Styles {
    <style>
        datalist { display: none; }
        .erp-column-filter-panel #erpNumericFilterInput { width: 100%; min-width: 0; box-sizing: border-box; }
        .erp-table tfoot { background-color: #f8fafc !important; border-top: 1px solid #e2e8f0; }
        .erp-table tbody tr:hover { background-color: #f8fafc; }
        .customer-balances-total-value { font-size: 1.05rem; color: #475569 !important; }
        a.text-decoration-none:hover { text-decoration: underline !important; }

        /* أزرار التقرير: ألوان هادئة للعين */
        .customer-balances-btns { flex-wrap: nowrap; }
        .customer-balances-btn {
            background-color: #fff !important;
            border-width: 1.5px !important;
            border-style: solid !important;
        }
        .customer-balances-btn-primary {
            color: #5b6b7a !important;
            border-color: #94a3b8 !important;
        }
        .customer-balances-btn-primary:hover {
            background-color: #f1f5f9 !important;
            color: #475569 !important;
            border-color: #64748b !important;
        }
        .customer-balances-btn-secondary {
            color: #64748b !important;
            border-color: #cbd5e1 !important;
        }
        .customer-balances-btn-secondary:hover {
            background-color: #f8fafc !important;
            color: #475569 !important;
        }
        .customer-balances-btn-success {
            color: #4d7c5a !important;
            border-color: #86efac !important;
        }
        .customer-balances-btn-success:hover {
            background-color: #f0fdf4 !important;
            color: #166534 !important;
        }
    </style>
}

@section Scripts {
    <script>
        // فلتر الأعمدة بنمط Excel (تقرير أرصدة العملاء)
        (function () {
            var panel = document.getElementById("erpColumnFilterPanel");
            if (!panel) return;
            var titleEl = document.getElementById("erpColumnFilterTitle");
            var searchInp = document.getElementById("erpColumnFilterSearch");
            var listEl = document.getElementById("erpColumnFilterList");
            var btnOk = document.getElementById("erpColumnFilterOk");
            var btnClear = document.getElementById("erpColumnFilterClear");
            var btnClose = document.getElementById("erpColumnFilterClose");

            var currentCol = null, currentSortKey = null, allItems = [], currentSelected = new Set(), anchorRect = null;
            var filterColumns = ["code", "name", "category", "phone"];
            var numericColumns = ["debit", "credit", "creditlimit", "sales", "purchases", "returns", "availablecredit"];

            function getQueryParams() {
                var url = new URL(window.location.href);
                var o = {};
                url.searchParams.forEach(function (v, k) { o[k] = v; });
                return o;
            }
            function getCurrentFilterValue(col) {
                return new URL(window.location.href).searchParams.get("filterCol_" + col) || "";
            }
            function getCurrentSort() {
                var url = new URL(window.location.href);
                return { sort: url.searchParams.get("sortBy") || "name", dir: url.searchParams.get("sortDir") || "asc" };
            }
            function adjustPanelPosition() {
                if (!panel || !anchorRect) return;
                setTimeout(function () {
                    var r = panel.getBoundingClientRect();
                    var top = anchorRect.bottom + 4, left = anchorRect.left;
                    if (top + r.height > window.innerHeight - 8) top = Math.max(8, window.innerHeight - 8 - r.height);
                    if (left + r.width > window.innerWidth - 8) left = Math.max(8, window.innerWidth - 8 - r.width);
                    panel.style.top = top + "px";
                    panel.style.left = left + "px";
                }, 50);
            }

            function showPanel(btn) {
                currentCol = btn.dataset.col;
                currentSortKey = btn.dataset.sortKey || currentCol;
                titleEl.textContent = "ترتيب وفلتر: " + (btn.dataset.colTitle || currentCol);
                searchInp.value = "";
                currentSelected = new Set((getCurrentFilterValue(currentCol) || "").split("|").filter(Boolean));
                anchorRect = btn.getBoundingClientRect();
                panel.style.minWidth = Math.max(250, anchorRect.width) + "px";
                panel.classList.remove("d-none");

                var currentSort = getCurrentSort();
                var isCurrent = currentSort.sort.toLowerCase() === currentSortKey.toLowerCase();
                var currentDir = isCurrent ? currentSort.dir : "asc";
                panel.querySelectorAll(".erp-sort-btn").forEach(function (b) {
                    if (isCurrent && b.dataset.sortDir === currentDir) {
                        b.classList.add("active", "btn-primary");
                        b.classList.remove("btn-outline-secondary");
                    } else {
                        b.classList.remove("active", "btn-primary");
                        b.classList.add("btn-outline-secondary");
                    }
                });
                adjustPanelPosition();

                if (numericColumns.indexOf(currentCol) >= 0) {
                    document.getElementById("erpColumnFilterSearchRow").classList.add("d-none");
                    var curVal = getCurrentFilterValue(currentCol);
                    listEl.innerHTML = '<label class="form-label small mb-1">أدخل قيمة رقمية للفلترة:</label><input type="text" id="erpNumericFilterInput" class="form-control form-control-sm" value="' + (curVal ? curVal.replace(/"/g, "&quot;") : "") + '" placeholder="مثال: 1000" />';
                    return;
                }
                document.getElementById("erpColumnFilterSearchRow").classList.remove("d-none");
                var params = getQueryParams();
                var url = "/Reports/GetCustomerBalancesColumnValues?search=" + encodeURIComponent(params.search || "") + "&partyCategory=" + encodeURIComponent(params.partyCategory || "") + "&governorateId=" + encodeURIComponent(params.governorateId || "") + "&column=" + encodeURIComponent(currentCol);
                var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                if (searchVal) url += "&searchTerm=" + encodeURIComponent(searchVal);
                listEl.innerHTML = '<div class="text-muted text-center py-3">جاري التحميل...</div>';
                fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                    allItems = items;
                    renderList(searchInp ? searchInp.value : "");
                }).catch(function () { listEl.innerHTML = '<div class="text-danger text-center py-2">فشل التحميل</div>'; });
            }

            function renderList(search) {
                var term = (search || "").toLowerCase();
                var filtered = term ? allItems.filter(function (x) { return (x.display || x.value || "").toLowerCase().indexOf(term) >= 0; }) : allItems;
                var allChecked = filtered.length > 0 && filtered.every(function (x) { return currentSelected.has(String(x.value)); });
                listEl.innerHTML = '<div class="form-check mb-1"><input type="checkbox" class="form-check-input" id="erpFilterSelectAll" ' + (allChecked ? "checked" : "") + '><label class="form-check-label small" for="erpFilterSelectAll">(تحديد الكل)</label></div><div class="erp-filter-items" style="max-height:200px;overflow-y:auto;">' + filtered.map(function (x) {
                    var v = String(x.value);
                    var checked = currentSelected.has(v);
                    return '<div class="form-check"><input type="checkbox" class="form-check-input erp-filter-item" value="' + v.replace(/"/g, "&quot;") + '" ' + (checked ? "checked" : "") + '><label class="form-check-label small">' + (x.display || v).replace(/</g, "&lt;") + '</label></div>';
                }).join("") + "</div>";
                var selectAllCb = listEl.querySelector("#erpFilterSelectAll");
                if (selectAllCb) {
                    selectAllCb.indeterminate = filtered.some(function (x) { return currentSelected.has(String(x.value)); }) && !allChecked;
                    selectAllCb.onchange = function () {
                        filtered.forEach(function (x) {
                            if (this.checked) currentSelected.add(String(x.value)); else currentSelected.delete(String(x.value));
                        }.bind(this));
                        renderList(searchInp.value);
                    };
                }
                listEl.querySelectorAll(".erp-filter-item").forEach(function (cb) {
                    cb.onchange = function () {
                        if (this.checked) currentSelected.add(this.value); else currentSelected.delete(this.value);
                        renderList(searchInp.value);
                    };
                });
                adjustPanelPosition();
            }

            function applyFilter(applySort, sortDir) {
                if (!currentCol) return;
                var params = getQueryParams();
                params.loadReport = "true";
                params.page = "1";
                if (applySort !== undefined && applySort !== null && sortDir !== undefined && sortDir !== null) {
                    params.sortBy = applySort;
                    params.sortDir = sortDir;
                } else if (currentSortKey) {
                    var cur = getCurrentSort();
                    params.sortBy = cur.sort;
                    params.sortDir = cur.dir;
                }
                var val;
                if (numericColumns.indexOf(currentCol) >= 0) {
                    var numInp = document.getElementById("erpNumericFilterInput");
                    val = numInp ? numInp.value.trim() : "";
                } else {
                    val = Array.from(currentSelected).filter(Boolean).join("|");
                }
                if (val) params["filterCol_" + currentCol] = val;
                var qs = Object.keys(params).filter(function (k) { return params[k] !== undefined && params[k] !== ""; }).map(function (k) { return encodeURIComponent(k) + "=" + encodeURIComponent(params[k]); }).join("&");
                window.location.href = "/Reports/CustomerBalances?" + qs;
            }
            function clearFilter() {
                if (!currentCol) return;
                var params = getQueryParams();
                delete params["filterCol_" + currentCol];
                params.loadReport = "true";
                params.page = "1";
                var qs = Object.keys(params).filter(function (k) { return params[k] !== undefined && params[k] !== ""; }).map(function (k) { return encodeURIComponent(k) + "=" + encodeURIComponent(params[k]); }).join("&");
                window.location.href = "/Reports/CustomerBalances?" + qs;
            }

            document.querySelectorAll(".erp-col-filter-btn").forEach(function (btn) {
                btn.addEventListener("click", function (e) { e.stopPropagation(); showPanel(this); });
            });
            document.addEventListener("click", function (e) {
                if (e.target.closest(".erp-sort-btn")) {
                    var sortBtn = e.target.closest(".erp-sort-btn");
                    if (currentSortKey) applyFilter(currentSortKey, sortBtn.dataset.sortDir);
                }
            });
            var fetchDebounce = null;
            searchInp && searchInp.addEventListener("input", function () {
                renderList(this.value);
                if (fetchDebounce) clearTimeout(fetchDebounce);
                fetchDebounce = setTimeout(function () {
                    fetchDebounce = null;
                    if (!currentCol) return;
                    var params = getQueryParams();
                    var url = "/Reports/GetCustomerBalancesColumnValues?search=" + encodeURIComponent(params.search || "") + "&partyCategory=" + encodeURIComponent(params.partyCategory || "") + "&governorateId=" + encodeURIComponent(params.governorateId || "") + "&column=" + encodeURIComponent(currentCol);
                    var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                    if (searchVal) url += "&searchTerm=" + encodeURIComponent(searchVal);
                    fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                        allItems = items;
                        renderList(searchInp ? searchInp.value : "");
                    });
                }, 400);
            });
            searchInp && searchInp.addEventListener("keydown", function (e) { if (e.key === "Enter") { e.preventDefault(); applyFilter(); } });
            btnOk && btnOk.addEventListener("click", function (e) { e.preventDefault(); e.stopPropagation(); applyFilter(); });
            btnClear && btnClear.addEventListener("click", clearFilter);
            btnClose && btnClose.addEventListener("click", function () { panel.classList.add("d-none"); });
            document.addEventListener("click", function (e) {
                if (panel && !panel.classList.contains("d-none") && !panel.contains(e.target) && !e.target.closest(".erp-col-filter-btn"))
                    panel.classList.add("d-none");
            });
        })();

        // ضمان إرسال includeZeroBalance حتى لو كان checkbox غير مفعّل
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('filtersForm');
            const checkbox = document.getElementById('includeZeroBalance');
            
            if (form && checkbox) {
                form.addEventListener('submit', function (e) {
                    const existingHidden = form.querySelector('input[name="includeZeroBalance"][type="hidden"]');
                    if (existingHidden) existingHidden.remove();
                    if (!checkbox.checked) {
                        const hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = 'includeZeroBalance';
                        hidden.value = 'false';
                        form.appendChild(hidden);
                    }
                });
            }
        });

        // توسيع/تصغير عرض الأعمدة (نفس نظام Index)
        document.addEventListener('DOMContentLoaded', function () {
            var wrapper = document.querySelector('.erp-table-wrapper');
            if (!wrapper) return;
            var table = wrapper.querySelector('table.erp-table');
            if (!table) return;
            var ths = table.querySelectorAll('thead th');
            ths.forEach(function (th) {
                th.style.position = 'relative';
                var handle = document.createElement('div');
                handle.className = 'erp-col-resize-handle';
                th.appendChild(handle);
                var startX, startWidth;
                handle.addEventListener('mousedown', function (e) {
                    e.preventDefault();
                    startX = e.pageX;
                    startWidth = th.offsetWidth;
                    function onMouseMove(eMove) {
                        var diffX = eMove.pageX - startX;
                        var newWidth = startWidth + diffX;
                        if (newWidth < 50) newWidth = 50;
                        th.style.width = newWidth + 'px';
                        th.style.minWidth = newWidth + 'px';
                    }
                    function onMouseUp() {
                        document.removeEventListener('mousemove', onMouseMove);
                        document.removeEventListener('mouseup', onMouseUp);
                    }
                    document.addEventListener('mousemove', onMouseMove);
                    document.addEventListener('mouseup', onMouseUp);
                });
            });
        });
    </script>
}
