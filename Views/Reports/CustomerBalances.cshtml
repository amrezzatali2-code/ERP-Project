@section Scripts {
    <script src="~/js/erp-list-print.js" asp-append-version="true"></script>
    <script>
        // فلتر الأعمدة بنمط Excel (تقرير أرصدة العملاء)
        (function () {
            var panel = document.getElementById("erpColumnFilterPanel");
            if (!panel) return;
            var titleEl = document.getElementById("erpColumnFilterTitle");
            var searchInp = document.getElementById("erpColumnFilterSearch");
            var listEl = document.getElementById("erpColumnFilterList");
            var btnOk = document.getElementById("erpColumnFilterOk");
            var btnClear = document.getElementById("erpColumnFilterClear");
            var btnClose = document.getElementById("erpColumnFilterClose");

            var currentCol = null, currentSortKey = null, allItems = [], currentSelected = new Set(), anchorRect = null;
            // أعمدة رقمية: بحث رقمي (تعبير واحد أو عدة قيم بـ |) — نفس CustomerBalancesNumericFilter على الخادم
            var numericColumns = ["code", "debit", "credit", "creditlimit", "sales", "purchases", "returns", "availablecredit"];

            function getQueryParams() {
                var url = new URL(window.location.href);
                var o = {};
                url.searchParams.forEach(function (v, k) { o[k] = v; });
                return o;
            }
            function getCurrentFilterValue(col) {
                return new URL(window.location.href).searchParams.get("filterCol_" + col) || "";
            }
            function getCurrentSort() {
                var url = new URL(window.location.href);
                return { sort: url.searchParams.get("sortBy") || "name", dir: url.searchParams.get("sortDir") || "asc" };
            }
            function buildColumnValuesUrl(column, searchTerm) {
                var params = getQueryParams();
                var url = "/Reports/GetCustomerBalancesColumnValues?search=" + encodeURIComponent(params.search || "") + "&partyCategory=" + encodeURIComponent(params.partyCategory || "") + "&governorateId=" + encodeURIComponent(params.governorateId || "") + "&column=" + encodeURIComponent(column);
                var sv = searchTerm !== undefined && searchTerm !== null ? String(searchTerm).trim() : "";
                if (sv) url += "&searchTerm=" + encodeURIComponent(sv);
                return url;
            }
            function adjustPanelPosition() {
                if (!panel || !anchorRect) return;
                setTimeout(function () {
                    var r = panel.getBoundingClientRect();
                    var top = anchorRect.bottom + 4, left = anchorRect.left;
                    if (top + r.height > window.innerHeight - 8) top = Math.max(8, window.innerHeight - 8 - r.height);
                    if (left + r.width > window.innerWidth - 8) left = Math.max(8, window.innerWidth - 8 - r.width);
                    panel.style.top = top + "px";
                    panel.style.left = left + "px";
                }, 50);
            }

            function showPanel(btn) {
                currentCol = btn.dataset.col;
                currentSortKey = btn.dataset.sortKey || currentCol;
                titleEl.textContent = "ترتيب وفلتر: " + (btn.dataset.colTitle || currentCol);
                searchInp.value = "";
                anchorRect = btn.getBoundingClientRect();
                panel.style.minWidth = Math.max(250, anchorRect.width) + "px";
                panel.classList.remove("d-none");

                var currentSort = getCurrentSort();
                var isCurrent = currentSort.sort.toLowerCase() === currentSortKey.toLowerCase();
                var currentDir = isCurrent ? currentSort.dir : "asc";
                panel.querySelectorAll(".erp-sort-btn").forEach(function (b) {
                    if (isCurrent && b.dataset.sortDir === currentDir) {
                        b.classList.add("active", "btn-primary");
                        b.classList.remove("btn-outline-secondary");
                    } else {
                        b.classList.remove("active", "btn-primary");
                        b.classList.add("btn-outline-secondary");
                    }
                });
                adjustPanelPosition();

                if (numericColumns.indexOf(currentCol) >= 0) {
                    document.getElementById("erpColumnFilterSearchRow").classList.add("d-none");
                    document.getElementById("erpColumnFilterNumericRow").classList.remove("d-none");
                    listEl.classList.add("d-none");
                    listEl.innerHTML = "";
                    var numEl = document.getElementById("erpNumericFilterInput");
                    if (numEl) {
                        numEl.value = getCurrentFilterValue(currentCol) || "";
                        numEl.onkeydown = function (ev) { if (ev.key === "Enter") { ev.preventDefault(); applyFilter(); } };
                    }
                    panel.style.minWidth = "min(340px, 92vw)";
                    setTimeout(function () { if (numEl) numEl.focus(); adjustPanelPosition(); }, 0);
                    return;
                }

                document.getElementById("erpColumnFilterNumericRow").classList.add("d-none");
                document.getElementById("erpColumnFilterSearchRow").classList.remove("d-none");
                listEl.classList.remove("d-none");
                currentSelected = new Set((getCurrentFilterValue(currentCol) || "").split("|").filter(Boolean));
                var searchVal = (searchInp && searchInp.value) ? searchInp.value.trim() : "";
                var url = buildColumnValuesUrl(currentCol, searchVal);
                listEl.innerHTML = '<div class="text-muted text-center py-3">جاري التحميل...</div>';
                fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                    allItems = items;
                    renderList(searchInp ? searchInp.value : "");
                }).catch(function () { listEl.innerHTML = '<div class="text-danger text-center py-2">فشل التحميل</div>'; });
            }

            function renderList(search) {
                var term = (search || "").toLowerCase();
                var filtered = term ? allItems.filter(function (x) { return (x.display || x.value || "").toLowerCase().indexOf(term) >= 0; }) : allItems;
                var allChecked = filtered.length > 0 && filtered.every(function (x) { return currentSelected.has(String(x.value)); });
                listEl.innerHTML = '<div class="form-check mb-1"><input type="checkbox" class="form-check-input" id="erpFilterSelectAll" ' + (allChecked ? "checked" : "") + '><label class="form-check-label small" for="erpFilterSelectAll">(تحديد الكل)</label></div><div class="erp-filter-items" style="max-height:200px;overflow-y:auto;">' + filtered.map(function (x) {
                    var v = String(x.value);
                    var checked = currentSelected.has(v);
                    return '<div class="form-check"><input type="checkbox" class="form-check-input erp-filter-item" value="' + v.replace(/"/g, "&quot;") + '" ' + (checked ? "checked" : "") + '><label class="form-check-label small">' + (x.display || v).replace(/</g, "&lt;") + '</label></div>';
                }).join("") + "</div>";
                var selectAllCb = listEl.querySelector("#erpFilterSelectAll");
                if (selectAllCb) {
                    selectAllCb.indeterminate = filtered.some(function (x) { return currentSelected.has(String(x.value)); }) && !allChecked;
                    selectAllCb.onchange = function () {
                        filtered.forEach(function (x) {
                            if (this.checked) currentSelected.add(String(x.value)); else currentSelected.delete(String(x.value));
                        }.bind(this));
                        renderList(searchInp.value);
                    };
                }
                listEl.querySelectorAll(".erp-filter-item").forEach(function (cb) {
                    cb.onchange = function () {
                        if (this.checked) currentSelected.add(this.value); else currentSelected.delete(this.value);
                        renderList(searchInp.value);
                    };
                });
                adjustPanelPosition();
            }

            function applyFilter(applySort, sortDir) {
                if (!currentCol) return;
                var params = getQueryParams();
                params.loadReport = "true";
                params.page = "1";
                if (applySort !== undefined && applySort !== null && sortDir !== undefined && sortDir !== null) {
                    params.sortBy = applySort;
                    params.sortDir = sortDir;
                } else if (currentSortKey) {
                    var cur = getCurrentSort();
                    params.sortBy = cur.sort;
                    params.sortDir = cur.dir;
                }
                delete params["filterCol_" + currentCol];
                var val;
                if (numericColumns.indexOf(currentCol) >= 0) {
                    var numInp = document.getElementById("erpNumericFilterInput");
                    val = numInp ? numInp.value.trim() : "";
                } else {
                    val = Array.from(currentSelected).filter(Boolean).join("|");
                }
                if (val) params["filterCol_" + currentCol] = val;
                var qs = Object.keys(params).filter(function (k) { return params[k] !== undefined && params[k] !== ""; }).map(function (k) { return encodeURIComponent(k) + "=" + encodeURIComponent(params[k]); }).join("&");
                window.location.href = "/Reports/CustomerBalances?" + qs;
            }
            function clearFilter() {
                if (!currentCol) return;
                var params = getQueryParams();
                delete params["filterCol_" + currentCol];
                params.loadReport = "true";
                params.page = "1";
                var qs = Object.keys(params).filter(function (k) { return params[k] !== undefined && params[k] !== ""; }).map(function (k) { return encodeURIComponent(k) + "=" + encodeURIComponent(params[k]); }).join("&");
                window.location.href = "/Reports/CustomerBalances?" + qs;
            }

            document.querySelectorAll(".erp-col-filter-btn").forEach(function (btn) {
                btn.addEventListener("click", function (e) { e.stopPropagation(); showPanel(this); });
            });
            document.addEventListener("click", function (e) {
                if (e.target.closest(".erp-sort-btn")) {
                    var sortBtn = e.target.closest(".erp-sort-btn");
                    if (currentSortKey) applyFilter(currentSortKey, sortBtn.dataset.sortDir);
                }
            });
            var fetchDebounce = null;
            searchInp && searchInp.addEventListener("input", function () {
                if (numericColumns.indexOf(currentCol) >= 0) return;
                renderList(this.value);
                if (fetchDebounce) clearTimeout(fetchDebounce);
                fetchDebounce = setTimeout(function () {
                    fetchDebounce = null;
                    if (!currentCol) return;
                    var url = buildColumnValuesUrl(currentCol, searchInp ? searchInp.value : "");
                    fetch(url).then(function (r) { return r.json(); }).then(function (items) {
                        allItems = items;
                        renderList(searchInp ? searchInp.value : "");
                    });
                }, 400);
            });
            searchInp && searchInp.addEventListener("keydown", function (e) { if (e.key === "Enter") { e.preventDefault(); applyFilter(); } });
            btnOk && btnOk.addEventListener("click", function (e) { e.preventDefault(); e.stopPropagation(); applyFilter(); });
            btnClear && btnClear.addEventListener("click", clearFilter);
            btnClose && btnClose.addEventListener("click", function () { panel.classList.add("d-none"); });
            document.addEventListener("click", function (e) {
                if (panel && !panel.classList.contains("d-none") && !panel.contains(e.target) && !e.target.closest(".erp-col-filter-btn"))
                    panel.classList.add("d-none");
            });
        })();

        // ضمان إرسال includeZeroBalance حتى لو كان checkbox غير مفعّل
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('filtersForm');
            const checkbox = document.getElementById('includeZeroBalance');
            
            if (form && checkbox) {
                form.addEventListener('submit', function (e) {
                    const existingHidden = form.querySelector('input[name="includeZeroBalance"][type="hidden"]');
                    if (existingHidden) existingHidden.remove();
                    if (!checkbox.checked) {
                        const hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = 'includeZeroBalance';
                        hidden.value = 'false';
                        form.appendChild(hidden);
                    }
                });
            }
        });

        // توسيع/تصغير عرض الأعمدة (نفس نظام Index) — تخطّي الأعمدة الثابتة
        document.addEventListener('DOMContentLoaded', function () {
            var wrapper = document.getElementById('cbTableScrollWrapper') || document.querySelector('.erp-table-wrapper');
            if (!wrapper) return;
            var table = wrapper.querySelector('table.erp-table');
            if (!table) return;
            var ths = table.querySelectorAll('thead th');
            ths.forEach(function (th) {
                if (th.getAttribute("data-col-fixed") === "true") return;
                th.style.position = 'relative';
                var handle = document.createElement('div');
                handle.className = 'erp-col-resize-handle';
                th.appendChild(handle);
                var startX, startWidth;
                handle.addEventListener('mousedown', function (e) {
                    e.preventDefault();
                    startX = e.pageX;
                    startWidth = th.offsetWidth;
                    function onMouseMove(eMove) {
                        var diffX = eMove.pageX - startX;
                        var newWidth = startWidth + diffX;
                        if (newWidth < 50) newWidth = 50;
                        th.style.width = newWidth + 'px';
                        th.style.minWidth = newWidth + 'px';
                    }
                    function onMouseUp() {
                        document.removeEventListener('mousemove', onMouseMove);
                        document.removeEventListener('mouseup', onMouseUp);
                    }
                    document.addEventListener('mousemove', onMouseMove);
                    document.addEventListener('mouseup', onMouseUp);
                });
            });
        });

        // شريط التمرير الأفقي: يفتح من جهة اليمين (بداية الجدول في RTL)
        function customerBalancesScrollToEnd() {
            var sc = document.querySelector('.customer-balances-table-scroll');
            if (!sc) return;
            requestAnimationFrame(function () {
                sc.scrollLeft = Math.max(0, sc.scrollWidth - sc.clientWidth);
            });
        }
        document.addEventListener('DOMContentLoaded', customerBalancesScrollToEnd);
        window.addEventListener('resize', customerBalancesScrollToEnd);

        // تحديد صف (لون ثابت .selected) منفصل عن التشيك بوكس (تعدد للتحديد)
        document.addEventListener('DOMContentLoaded', function () {
            var table = document.getElementById("customerBalancesTable");
            var btnEng = document.getElementById("btnCbEngagement");
            var chkAll = document.getElementById("cbSelectAll");
            var showUrlZero = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Action("Show", "Customers", new { id = 0 })));

            function syncEngBtn() {
                if (!btnEng || !table) return;
                var checkedCount = table.querySelectorAll("tbody .row-select:checked").length;
                var selectedRow = table.querySelector("tbody tr.erp-list-selectable-row.selected");
                btnEng.disabled = !(checkedCount === 1 || (checkedCount === 0 && selectedRow));
            }

            chkAll?.addEventListener("change", function () {
                var on = this.checked;
                table?.querySelectorAll("tbody .row-select").forEach(function (cb) { cb.checked = on; });
                syncEngBtn();
            });
            table?.addEventListener("change", function (e) {
                const t = e.target;
                if (t && t.classList.contains("row-select")) {
                    if (!t.checked && chkAll) chkAll.checked = false;
                    syncEngBtn();
                }
            });
            table?.querySelectorAll("tbody tr.erp-list-selectable-row").forEach(function (row) {
                row.addEventListener("click", function (e) {
                    if (e.target.closest("input") || e.target.closest("label") || e.target.closest("a") || e.target.closest("button")) return;
                    table.querySelectorAll("tbody tr.erp-list-selectable-row").forEach(function (r) { r.classList.remove("selected"); });
                    row.classList.add("selected");
                    syncEngBtn();
                });
            });
            syncEngBtn();

            btnEng?.addEventListener("click", function () {
                if (!table) return;
                var checks = Array.from(table.querySelectorAll("tbody .row-select")).filter(function (c) { return c.checked; });
                var id = null;
                if (checks.length === 1) id = checks[0].value;
                else if (checks.length === 0) {
                    var sel = table.querySelector("tbody tr.erp-list-selectable-row.selected");
                    if (sel && sel.dataset.customerId) id = String(sel.dataset.customerId);
                }
                if (!id) {
                    alert("اختر عميلاً واحداً من الجدول (صف واحد أو تشيك بوكس واحد) لفتح حجم التعامل.");
                    return;
                }
                var href = String(showUrlZero).replace(/\/0(\?.*)?$/, "/" + id + "$1");
                var a = document.createElement("a");
                a.href = href;
                a.className = "app-menu-link";
                a.setAttribute("data-tab-id", "customer-engagement-" + id);
                a.setAttribute("data-tab-title", "حجم تعامل عميل");
                a.style.display = "none";
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
            });
        });

        // إظهار/إخفاء أعمدة (localStorage)
        document.addEventListener('DOMContentLoaded', function () {
            var table = document.getElementById("customerBalancesTable");
            var listEl = document.getElementById("columnsListCb");
            if (!table || !listEl) return;
            var storageKey = "customer-balances-columns-visibility";
            var headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            var columns = headerCells.filter(function (th) { return !th.hasAttribute("data-col-fixed"); })
                .map(function (th) {
                    var t = th.querySelector(".erp-col-title");
                    var title = (t ? t.textContent : th.innerText).trim();
                    return { key: th.getAttribute("data-col"), title: title || th.getAttribute("data-col") };
                });
            if (columns.length === 0) return;

            var hidden = [];
            try {
                var saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch (e) { hidden = []; }

            function applyVisibility() {
                columns.forEach(function (col) {
                    var isHidden = hidden.indexOf(col.key) >= 0;
                    table.querySelectorAll("[data-col='" + col.key + "']").forEach(function (cell) {
                        cell.classList.toggle("d-none", isHidden);
                    });
                });
            }
            applyVisibility();

            listEl.innerHTML = "";
            columns.forEach(function (col) {
                var id = "cb_col_" + col.key;
                var wrap = document.createElement("div");
                wrap.className = "form-check";
                var cb = document.createElement("input");
                cb.type = "checkbox";
                cb.className = "form-check-input";
                cb.id = id;
                cb.checked = hidden.indexOf(col.key) < 0;
                cb.dataset.colKey = col.key;
                var lab = document.createElement("label");
                lab.className = "form-check-label";
                lab.setAttribute("for", id);
                lab.textContent = col.title;
                wrap.appendChild(cb);
                wrap.appendChild(lab);
                listEl.appendChild(wrap);
            });

            document.getElementById("btnApplyColumnsCb")?.addEventListener("click", function () {
                hidden = [];
                listEl.querySelectorAll("input[type=checkbox][data-col-key]").forEach(function (c) {
                    if (!c.checked) hidden.push(c.dataset.colKey);
                });
                try { localStorage.setItem(storageKey, JSON.stringify(hidden)); } catch (e) { }
                applyVisibility();
                var modalEl = document.getElementById("columnsModalCb");
                var modal = bootstrap.Modal.getInstance(modalEl);
                modal?.hide();
            });
        });

        // طباعة: صفحة Print + printCols (نفس قائمة العملاء — ~/js/erp-list-print.js)
        document.addEventListener("DOMContentLoaded", function () {
            var printUrlBase = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(printUrl));
            document.getElementById("btnCustomerBalancesPrint")?.addEventListener("click", function () {
                if (!printUrlBase || printUrlBase === "#") return;
                if (window.ERP && typeof ERP.openListPrint === "function")
                    ERP.openListPrint(printUrlBase, { tableId: "customerBalancesTable", storageKey: "customer-balances-columns-visibility" });
                else
                    window.open(printUrlBase, "_blank", "noopener,noreferrer");
            });
        });
    </script>
}
