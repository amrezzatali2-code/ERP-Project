@using ERP.ViewModels
@{
    ViewData["Title"] = "تقرير: أرصدة العملاء";

    var reportData = ViewBag.ReportData as List<CustomerBalanceReportDto> ?? new List<CustomerBalanceReportDto>();
    var totalBalance = ViewBag.TotalBalance as decimal? ?? 0m;
    var totalSales = ViewBag.TotalSales as decimal? ?? 0m;
    var totalPurchases = ViewBag.TotalPurchases as decimal? ?? 0m;
    var totalReturns = ViewBag.TotalReturns as decimal? ?? 0m;
    var totalCreditLimit = ViewBag.TotalCreditLimit as decimal? ?? 0m;
    var totalAvailableCredit = ViewBag.TotalAvailableCredit as decimal? ?? 0m;

    // Pagination
    var page = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 200;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;

    // الفلاتر من ViewBag
    var search = ViewBag.Search as string ?? "";
    var partyCategory = ViewBag.PartyCategory as string;
    var governorateId = ViewBag.GovernorateId as int?;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var includeZeroBalance = ViewBag.IncludeZeroBalance as bool? ?? false;
    var sortBy = ViewBag.SortBy as string ?? "name";
    var sortDir = ViewBag.SortDir as string ?? "asc";

    // القوائم المنسدلة
    var governorates = ViewBag.Governorates as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    // دالة إنشاء رابط الترتيب
    Func<string, string, string> sortUrl = (col, direction) =>
    {
        return Url.Action("CustomerBalances", "Reports", new
        {
            search,
            partyCategory,
            governorateId,
            fromDate,
            toDate,
            includeZeroBalance,
            sortBy = col,
            sortDir = direction,
            loadReport = true,
            page,
            pageSize
        }) ?? "#";
    };

    // دالة إنشاء رابط Pagination
    Func<int, string> pageUrl = (p) =>
    {
        return Url.Action("CustomerBalances", "Reports", new
        {
            search,
            partyCategory,
            governorateId,
            fromDate,
            toDate,
            includeZeroBalance,
            sortBy,
            sortDir,
            loadReport = true,
            page = p,
            pageSize
        }) ?? "#";
    };
}

<div dir="rtl" class="container-fluid" style="padding: 1rem;">
    @* عنوان الصفحة *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <small class="text-muted d-none d-md-inline">
            عدد العملاء: @(reportData.Any() ? totalCount : 0)
        </small>
    </div>

    @* ===== كروت الفلاتر ===== *@
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <form method="get" asp-action="CustomerBalances" asp-controller="Reports" id="filtersForm">
                <div class="row g-3 align-items-end">
                    @* كارت البحث *@
                    <div class="col-lg-3 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">🔍 بحث</span>
                            </div>
                            <div class="card-body py-2">
                                <input type="text"
                                       name="search"
                                       list="customersList"
                                       class="form-control"
                                       placeholder="اكتب اسم العميل أو جزء منه..."
                                       autocomplete="off"
                                       value="@search" />
                                <datalist id="customersList">
                                    @if (ViewBag.CustomersAuto != null)
                                    {
                                        foreach (var c in ViewBag.CustomersAuto)
                                        {
                                            <option value="@c.Name"
                                                    data-id="@c.Id"
                                                    data-phone="@c.Phone"
                                                    data-category="@c.Category">
                                            </option>
                                        }
                                    }
                                </datalist>
                            </div>
                        </div>
                    </div>

                    @* كارت فئة العميل *@
                    <div class="col-lg-2 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">📂 فئة العميل</span>
                            </div>
                            <div class="card-body py-2">
                                <input type="text"
                                       name="partyCategory"
                                       class="form-control"
                                       placeholder="عميل / مورد..."
                                       value="@partyCategory" />
                            </div>
                        </div>
                    </div>

                    @* كارت المحافظة *@
                    <div class="col-lg-2 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">🏛️ المحافظة</span>
                            </div>
                            <div class="card-body py-2">
                                <select name="governorateId" class="form-select">
                                    <option value="">الكل</option>
                                    @foreach (var gov in governorates)
                                    {
                                        <option value="@gov.Value" selected="@(governorateId?.ToString() == gov.Value ? "selected" : null)">@gov.Text</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    @* كارت تاريخ من *@
                    <div class="col-lg-2 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">📅 من تاريخ</span>
                            </div>
                            <div class="card-body py-2">
                                <input type="date"
                                       name="fromDate"
                                       class="form-control"
                                       value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                            </div>
                        </div>
                    </div>

                    @* كارت تاريخ إلى *@
                    <div class="col-lg-2 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">📅 إلى تاريخ</span>
                            </div>
                            <div class="card-body py-2">
                                <input type="date"
                                       name="toDate"
                                       class="form-control"
                                       value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                            </div>
                        </div>
                    </div>

                    @* كارت الإعدادات *@
                    <div class="col-lg-1 col-md-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-header text-white py-2" style="background: linear-gradient(90deg, #4b5563, #64748b);">
                                <span class="fw-semibold">⚙️ خيارات</span>
                            </div>
                            <div class="card-body py-2">
                                <div class="form-check">
                                    <input class="form-check-input" 
                                           type="checkbox" 
                                           name="includeZeroBalance" 
                                           value="true" 
                                           id="includeZeroBalance"
                                           @(includeZeroBalance ? "checked" : "") />
                                    <label class="form-check-label small" for="includeZeroBalance">
                                        عرض الصفر
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* أزرار التفعيل *@
                    <div class="col-lg-auto d-flex gap-2 align-items-end">
                        <input type="hidden" name="loadReport" value="true" />
                        <button type="submit" class="btn btn-primary">
                            <span>📊</span> تجميع التقرير
                        </button>
                        <a href="@Url.Action("CustomerBalances", "Reports")" class="btn btn-secondary btn-sm">
                            <span>🔄</span> إعادة تعيين
                        </a>
                        @if (reportData.Any())
                        {
                            <a href="@Url.Action("ExportCustomerBalances", "Reports", new { search, partyCategory, governorateId, fromDate, toDate, includeZeroBalance, sortBy, sortDir })" 
                               class="btn btn-success btn-sm">
                                <span>📥</span> تصدير Excel
                            </a>
                        }
                        @if (reportData.Any() && totalPages > 1)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <label class="form-label mb-0 small">حجم الصفحة:</label>
                                <select name="pageSize" 
                                        class="form-select form-select-sm" 
                                        style="width: auto;"
                                        onchange="this.form.submit()">
                                    @if (pageSize == 200)
                                    {
                                        <option value="200" selected>200</option>
                                    }
                                    else
                                    {
                                        <option value="200">200</option>
                                    }
                                    @if (pageSize == 500)
                                    {
                                        <option value="500" selected>500</option>
                                    }
                                    else
                                    {
                                        <option value="500">500</option>
                                    }
                                    @if (pageSize == 1000)
                                    {
                                        <option value="1000" selected>1000</option>
                                    }
                                    else
                                    {
                                        <option value="1000">1000</option>
                                    }
                                    @if (pageSize == 5000)
                                    {
                                        <option value="5000" selected>5000</option>
                                    }
                                    else
                                    {
                                        <option value="5000">5000</option>
                                    }
                                    @if (pageSize == totalCount || pageSize <= 0 || (totalCount > 0 && pageSize >= totalCount))
                                    {
                                        <option value="0" selected>الكل</option>
                                    }
                                    else
                                    {
                                        <option value="0">الكل</option>
                                    }
                                </select>
                            </div>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    @* ===== Pagination Info ===== *@
    @if (reportData.Any() && totalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <small class="text-muted">
                عرض @((page - 1) * pageSize + 1) - @(Math.Min(page * pageSize, totalCount)) من @totalCount
            </small>
            <small class="text-muted">
                @($"صفحة {page} من {totalPages}")
            </small>
        </div>
    }

    @* ===== جدول البيانات ===== *@
    @if (reportData.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="min-width: 80px;">
                                    <a href="@sortUrl("code", sortBy == "code" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        الكود @if (sortBy == "code") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th style="min-width: 200px;">
                                    <a href="@sortUrl("name", sortBy == "name" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        اسم العميل @if (sortBy == "name") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th>فئة العميل</th>
                                <th>الهاتف</th>
                                <th class="text-end" style="min-width: 130px;">
                                    <a href="@sortUrl("balance", sortBy == "balance" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        الرصيد الحالي @if (sortBy == "balance") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th class="text-end" style="min-width: 120px;">الحد الائتماني</th>
                                <th class="text-end" style="min-width: 120px;">
                                    <a href="@sortUrl("sales", sortBy == "sales" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        المبيعات @if (sortBy == "sales") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th class="text-end" style="min-width: 120px;">
                                    <a href="@sortUrl("purchases", sortBy == "purchases" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        المشتريات @if (sortBy == "purchases") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th class="text-end" style="min-width: 120px;">
                                    <a href="@sortUrl("returns", sortBy == "returns" && sortDir == "asc" ? "desc" : "asc")" class="text-decoration-none text-dark">
                                        المرتجعات @if (sortBy == "returns") { <span>@(sortDir == "asc" ? "▲" : "▼")</span> }
                                    </a>
                                </th>
                                <th class="text-end" style="min-width: 130px;">الائتمان المتاح</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in reportData)
                            {
                                <tr>
                                    <td><strong>@item.CustomerCode</strong></td>
                                    <td>@item.CustomerName</td>
                                    <td><small class="text-muted">@item.PartyCategory</small></td>
                                    <td><small>@item.Phone1</small></td>
                                    <td class="text-end"><strong>@item.CurrentBalance.ToString("N2")</strong></td>
                                    <td class="text-end">@item.CreditLimit.ToString("N2")</td>
                                    <td class="text-end">@item.TotalSales.ToString("N2")</td>
                                    <td class="text-end">@item.TotalPurchases.ToString("N2")</td>
                                    <td class="text-end">@item.TotalReturns.ToString("N2")</td>
                                    <td class="text-end">@item.AvailableCredit.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-secondary fw-bold">
                            <tr>
                                <td colspan="4" class="text-end"><strong>المجموع الإجمالي:</strong></td>
                                <td class="text-end"><strong>@totalBalance.ToString("N2")</strong></td>
                                <td class="text-end"><strong>@totalCreditLimit.ToString("N2")</strong></td>
                                <td class="text-end"><strong>@totalSales.ToString("N2")</strong></td>
                                <td class="text-end"><strong>@totalPurchases.ToString("N2")</strong></td>
                                <td class="text-end"><strong>@totalReturns.ToString("N2")</strong></td>
                                <td class="text-end">
                                    <strong class="text-primary" style="font-size: 1.1rem;">@totalAvailableCredit.ToString("N2")</strong>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        @* ===== Pagination Controls ===== *@
        @if (totalPages > 1)
        {
            <nav aria-label="pagination" class="mt-3 d-print-none">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(page == 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(1)">الأول</a>
                    </li>
                    <li class="page-item @(page == 1 ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page - 1)">السابق</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">@($"صفحة {page} من {totalPages}")</span>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(page + 1)">التالي</a>
                    </li>
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@pageUrl(totalPages)">الأخير</a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">لا توجد بيانات لعرضها</p>
        </div>
    }
</div>

@section Styles {
    <style>
        datalist {
            display: none;
        }

        .table thead th {
            border-bottom: 2px solid #dee2e6;
            font-weight: 600;
            background-color: #f8f9fa !important;
        }
        .table tfoot {
            background-color: #e9ecef !important;
        }
        .card-header {
            font-size: 0.9rem;
        }
        .table tbody tr:hover {
            background-color: #f5f5f5;
        }
        a.text-decoration-none:hover {
            text-decoration: underline !important;
        }
    </style>
}

@section Scripts {
    <script>
        // ضمان إرسال includeZeroBalance حتى لو كان checkbox غير مفعّل
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('filtersForm');
            const checkbox = document.getElementById('includeZeroBalance');
            
            if (form && checkbox) {
                form.addEventListener('submit', function (e) {
                    // إزالة أي hidden input سابق
                    const existingHidden = form.querySelector('input[name="includeZeroBalance"][type="hidden"]');
                    if (existingHidden) {
                        existingHidden.remove();
                    }
                    
                    // إذا كان checkbox غير مفعّل، أضف hidden input
                    if (!checkbox.checked) {
                        const hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = 'includeZeroBalance';
                        hidden.value = 'false';
                        form.appendChild(hidden);
                    }
                });
            }
        });
    </script>
}
