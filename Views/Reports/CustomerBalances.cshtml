@using Microsoft.AspNetCore.Html
@using ERP.ViewModels
@using System.Globalization
@{
    // تنسيق الأرقام: فاصل الآلاف = فاصلة، العلامة العشرية = نقطة (مثل 14,304,992.81)
    var n2 = CultureInfo.InvariantCulture;
    ViewData["Title"] = "تقرير: أرصدة العملاء";

    var reportData = ViewBag.ReportData as List<CustomerBalanceReportDto> ?? new List<CustomerBalanceReportDto>();
    var totalBalance = ViewBag.TotalBalance as decimal? ?? 0m;
    var totalDebit = ViewBag.TotalDebit as decimal? ?? 0m;
    var totalCredit = ViewBag.TotalCredit as decimal? ?? 0m;
    var totalSales = ViewBag.TotalSales as decimal? ?? 0m;
    var totalPurchases = ViewBag.TotalPurchases as decimal? ?? 0m;
    var totalReturns = ViewBag.TotalReturns as decimal? ?? 0m;
    var totalCreditLimit = ViewBag.TotalCreditLimit as decimal? ?? 0m;
    var totalAvailableCredit = ViewBag.TotalAvailableCredit as decimal? ?? 0m;

    // Pagination
    var page = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 200;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    var totalCustomersUnfiltered = ViewBag.TotalCustomersUnfiltered as int? ?? 0;
    var balanceDiff = totalDebit - totalCredit; // الفرق (مدين - دائن)

    int ps = pageSize;
    int dispStart = totalCount == 0 ? 0 : ((page - 1) * (ps > 0 ? ps : 1) + 1);
    int dispEnd = (ps == 0 || totalCount == 0) ? totalCount : Math.Min(totalCount, page * ps);

    // الفلاتر من ViewBag
    var search = ViewBag.Search as string ?? "";
    var partyCategory = ViewBag.PartyCategory as string;
    var governorateId = ViewBag.GovernorateId as int?;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var includeZeroBalance = ViewBag.IncludeZeroBalance as bool? ?? false;
    var sortBy = ViewBag.SortBy as string ?? "name";
    var sortDir = ViewBag.SortDir as string ?? "asc";
    string? filterCol_code = ViewBag.FilterCol_Code as string ?? Context.Request.Query["filterCol_code"].ToString();
    string? filterCol_name = ViewBag.FilterCol_Name as string ?? Context.Request.Query["filterCol_name"].ToString();
    string? filterCol_category = ViewBag.FilterCol_Category as string ?? Context.Request.Query["filterCol_category"].ToString();
    string? filterCol_phone = ViewBag.FilterCol_Phone as string ?? Context.Request.Query["filterCol_phone"].ToString();
    string? filterCol_account = ViewBag.FilterCol_Account as string ?? Context.Request.Query["filterCol_account"].ToString();
    string? filterCol_debit = ViewBag.FilterCol_Debit as string ?? Context.Request.Query["filterCol_debit"].ToString();
    string? filterCol_credit = ViewBag.FilterCol_Credit as string ?? Context.Request.Query["filterCol_credit"].ToString();
    string? filterCol_creditlimit = ViewBag.FilterCol_CreditLimit as string ?? Context.Request.Query["filterCol_creditlimit"].ToString();
    string? filterCol_sales = ViewBag.FilterCol_Sales as string ?? Context.Request.Query["filterCol_sales"].ToString();
    string? filterCol_purchases = ViewBag.FilterCol_Purchases as string ?? Context.Request.Query["filterCol_purchases"].ToString();
    string? filterCol_returns = ViewBag.FilterCol_Returns as string ?? Context.Request.Query["filterCol_returns"].ToString();
    string? filterCol_availablecredit = ViewBag.FilterCol_AvailableCredit as string ?? Context.Request.Query["filterCol_availablecredit"].ToString();

    // القوائم المنسدلة
    var governorates = ViewBag.Governorates as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    // دالة عمود قابل للفلترة (بنمط Excel)
    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        var currentFilter = colKey == "code" ? filterCol_code : colKey == "name" ? filterCol_name : colKey == "category" ? filterCol_category :
            colKey == "phone" ? filterCol_phone : colKey == "account" ? filterCol_account : colKey == "debit" ? filterCol_debit : colKey == "credit" ? filterCol_credit :
            colKey == "creditlimit" ? filterCol_creditlimit : colKey == "sales" ? filterCol_sales : colKey == "purchases" ? filterCol_purchases :
            colKey == "returns" ? filterCol_returns : colKey == "availablecredit" ? filterCol_availablecredit : null;
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sortBy, sortKey, StringComparison.OrdinalIgnoreCase);
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };

    // دالة إنشاء رابط Pagination (مع فلاتر الأعمدة)
    Func<int, string> pageUrl = (p) =>
    {
        return Url.Action("CustomerBalances", "Reports", new
        {
            search,
            partyCategory,
            governorateId,
            fromDate,
            toDate,
            includeZeroBalance,
            sortBy,
            sortDir,
            filterCol_code, filterCol_name, filterCol_category, filterCol_phone, filterCol_account,
            filterCol_debit, filterCol_credit, filterCol_creditlimit, filterCol_sales,
            filterCol_purchases, filterCol_returns, filterCol_availablecredit,
            loadReport = true,
            page = p,
            pageSize
        }) ?? "#";
    };

    var printUrl = Url.Action("PrintCustomerBalances", "Reports", new
    {
        search,
        partyCategory,
        governorateId,
        fromDate,
        toDate,
        includeZeroBalance,
        sortBy,
        sortDir,
        filterCol_code,
        filterCol_name,
        filterCol_category,
        filterCol_phone,
        filterCol_account,
        filterCol_debit,
        filterCol_credit,
        filterCol_creditlimit,
        filterCol_sales,
        filterCol_purchases,
        filterCol_returns,
        filterCol_availablecredit
    }) ?? "#";
}

<div dir="rtl" class="container-fluid">
    @* ===== شريط الفلاتر الموحد (نفس Index) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <form method="get" asp-action="CustomerBalances" asp-controller="Reports" id="filtersForm">
            <div class="row g-3 align-items-end">
                <input type="hidden" name="loadReport" value="true" />
                @if (!string.IsNullOrWhiteSpace(filterCol_code)) { <input type="hidden" name="filterCol_code" value="@filterCol_code" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_name)) { <input type="hidden" name="filterCol_name" value="@filterCol_name" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_category)) { <input type="hidden" name="filterCol_category" value="@filterCol_category" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_phone)) { <input type="hidden" name="filterCol_phone" value="@filterCol_phone" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_account)) { <input type="hidden" name="filterCol_account" value="@filterCol_account" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_debit)) { <input type="hidden" name="filterCol_debit" value="@filterCol_debit" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_credit)) { <input type="hidden" name="filterCol_credit" value="@filterCol_credit" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_creditlimit)) { <input type="hidden" name="filterCol_creditlimit" value="@filterCol_creditlimit" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_sales)) { <input type="hidden" name="filterCol_sales" value="@filterCol_sales" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_purchases)) { <input type="hidden" name="filterCol_purchases" value="@filterCol_purchases" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_returns)) { <input type="hidden" name="filterCol_returns" value="@filterCol_returns" /> }
                @if (!string.IsNullOrWhiteSpace(filterCol_availablecredit)) { <input type="hidden" name="filterCol_availablecredit" value="@filterCol_availablecredit" /> }
                <div class="col-12 col-lg-3 erp-filter-section">
                    <label class="form-label">بحث</label>
                    <input type="text"
                           name="search"
                           list="customersList"
                           class="form-control erp-filter-input"
                           placeholder="اكتب اسم العميل أو جزء منه..."
                           autocomplete="off"
                           value="@search" />
                    <datalist id="customersList">
                        @if (ViewBag.CustomersAuto != null)
                        {
                            foreach (var c in ViewBag.CustomersAuto)
                            {
                                <option value="@c.Name" data-id="@c.Id" data-phone="@c.Phone" data-category="@c.Category"></option>
                            }
                        }
                    </datalist>
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">فئة العميل</label>
                    <input type="text"
                           name="partyCategory"
                           class="form-control erp-filter-input"
                           placeholder="عميل / مورد..."
                           value="@partyCategory" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">المحافظة</label>
                    <select name="governorateId" class="form-select erp-filter-input">
                        <option value="">الكل</option>
                        @foreach (var gov in governorates)
                        {
                            <option value="@gov.Value" selected="@(governorateId?.ToString() == gov.Value)">@gov.Text</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">من تاريخ</label>
                    <input type="date"
                           name="fromDate"
                           dir="ltr"
                           class="form-control erp-filter-input"
                           value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date"
                           name="toDate"
                           dir="ltr"
                           class="form-control erp-filter-input"
                           value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">خيارات</label>
                    <div class="d-flex align-items-center gap-2">
                        <div class="form-check mb-0">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="includeZeroBalance"
                                   value="true"
                                   id="includeZeroBalance"
                                   @(includeZeroBalance ? "checked" : "") />
                            <label class="form-check-label small" for="includeZeroBalance">عرض الصفر</label>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-auto erp-filter-section">
                    <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                    <div class="d-flex flex-nowrap gap-2 customer-balances-btns">
                        @* في RTL: أول عنصر في DOM يظهر يميناً — تجميع ← إعادة ← حجم التعامل ← اختيار الأعمدة ← تصدير Excel ← طباعة (أقصى يسار المجموعة) *@
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm customer-balances-btn customer-balances-btn-primary">
                            <span>📊</span> تجميع التقرير
                        </button>
                        <a href="@Url.Action("CustomerBalances", "Reports")" class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none customer-balances-btn customer-balances-btn-secondary">
                            <span>🔄</span> إعادة تعيين
                        </a>
                        @if (reportData.Any())
                        {
                            <button type="button" id="btnCbEngagement" class="btn btn-erp btn-erp-secondary btn-erp-sm customer-balances-btn customer-balances-btn-secondary" disabled title="حدّد صفاً أو عميلاً واحداً بالتشيك بوكس">حجم التعامل</button>
                            <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm customer-balances-btn customer-balances-btn-secondary" data-bs-toggle="modal" data-bs-target="#columnsModalCb">اختيار الأعمدة</button>
                            <a href="@Url.Action("ExportCustomerBalances", "Reports", new { search, partyCategory, governorateId, fromDate, toDate, includeZeroBalance, sortBy, sortDir, filterCol_code, filterCol_name, filterCol_category, filterCol_phone, filterCol_account, filterCol_debit, filterCol_credit, filterCol_creditlimit, filterCol_sales, filterCol_purchases, filterCol_returns, filterCol_availablecredit })"
                               class="btn btn-erp btn-erp-success btn-erp-sm text-decoration-none customer-balances-btn customer-balances-btn-success">
                                <span>📥</span> تصدير Excel
                            </a>
                            <button type="button" id="btnCustomerBalancesPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm customer-balances-btn customer-balances-btn-secondary" title="طباعة حسب الأعمدة الظاهرة">
                                <span>🖨️</span> طباعة
                            </button>
                        }
                    </div>
                </div>
            </div>
        </form>
    </div>

    @* ===== كروت الإجماليات (بين شريط الفلاتر والجدول — مثل أرصدة الأصناف) ===== *@
    @if (reportData.Any())
    {
        <div class="row g-2 g-md-3 mb-2 no-print">
            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #6366f1 !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(99,102,241,.25); overflow: hidden;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">إجمالي العملاء</div>
                        <div class="h4 mb-0 text-primary fw-bold">@totalCustomersUnfiltered</div>
                        <div class="small text-muted mt-1">قبل فلاتر الأعمدة</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #0d6efd !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(13,110,253,.25); overflow: hidden;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">بعد الفلترة</div>
                        <div class="h4 mb-0 text-info fw-bold">@totalCount</div>
                        <div class="small text-muted mt-1">عدد النتائج الحالية</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #198754 !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(25,135,84,.25); overflow: hidden;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">مجموع المدين</div>
                        <div class="h4 mb-0 text-success fw-bold">@totalDebit.ToString("N2", n2)</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #dc3545 !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(220,53,69,.25); overflow: hidden;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">مجموع الدائن</div>
                        <div class="h4 mb-0 text-danger fw-bold">@totalCredit.ToString("N2", n2)</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                <div class="card h-100 border-0 shadow-sm" style="border: 1px solid #6f42c1 !important; border-radius: 12px; box-shadow: 0 1px 3px rgba(111,66,193,.25); overflow: hidden;">
                    <div class="card-body py-3 px-3">
                        <div class="small text-muted mb-1">الفرق (مدين − دائن)</div>
                        <div class="h4 mb-0 fw-bold @(balanceDiff >= 0 ? "text-success" : "text-danger")">@balanceDiff.ToString("N2", n2)</div>
                    </div>
                </div>
            </div>
        </div>

    }

        @* ===== جدول البيانات (نفس نظام Index) ===== *@
    @if (reportData.Any())
    {
        <div class="erp-table-scroll-container customer-balances-table-scroll">
        <div id="cbTableScrollWrapper" class="erp-table-wrapper mt-2 erp-print-area" dir="rtl" style="position: relative; max-height: 70vh; overflow-y: auto;">
            <table id="customerBalancesTable" class="table table-striped table-hover erp-table erp-table-sortable">
                <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #f8f9fa !important;">
                    <tr>
                        <th class="text-center no-print" style="width:42px;" data-col="select" data-col-fixed="true">
                            <input type="checkbox" id="cbSelectAll" class="form-check-input" title="تحديد الكل في الصفحة" />
                        </th>
                        <th style="min-width: 4.5rem; width: auto;" data-col="code">@filterableCol("code", "code", "الكود")</th>
                        <th style="min-width: 5rem; width: auto;" data-col="externalcode">كود الاكسل</th>
                        <th style="min-width: 8rem; width: auto;" data-col="name">@filterableCol("name", "name", "اسم العميل")</th>
                        <th style="min-width: 12rem; width: auto;" data-col="account">@filterableCol("account", "account", "حساب العميل")</th>
                        <th data-col="category">@filterableCol("category", "category", "فئة العميل")</th>
                        <th data-col="phone">@filterableCol("phone", "phone", "الهاتف")</th>
                        <th class="text-end" style="min-width: 6.5rem; width: auto;" data-col="debit">@filterableCol("debit", "debit", "مدين")</th>
                        <th class="text-end" style="min-width: 6.5rem; width: auto;" data-col="credit">@filterableCol("credit", "credit", "دائن")</th>
                        <th class="text-end" style="min-width: 6.5rem; width: auto;" data-col="creditlimit">@filterableCol("creditlimit", "creditlimit", "الحد الائتماني")</th>
                        <th class="text-end" style="min-width: 6.5rem; width: auto;" data-col="sales">@filterableCol("sales", "sales", "المبيعات")</th>
                        <th class="text-end" style="min-width: 6.5rem; width: auto;" data-col="purchases">@filterableCol("purchases", "purchases", "المشتريات")</th>
                        <th class="text-end" style="min-width: 6.5rem; width: auto;" data-col="returns">@filterableCol("returns", "returns", "المرتجعات")</th>
                        <th class="text-end" style="min-width: 7rem; width: auto;" data-col="availablecredit">@filterableCol("availablecredit", "availablecredit", "الائتمان المتاح")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in reportData)
                    {
                        var _tabTitle = string.IsNullOrWhiteSpace(item.CustomerName) ? ("عميل " + item.CustomerId) : item.CustomerName!;
                        <tr class="erp-list-selectable-row"
                            data-customer-id="@item.CustomerId"
                            data-tab-title="@_tabTitle">
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox" class="row-select" value="@item.CustomerId" />
                            </td>
                            <td data-col="code"><strong>@item.CustomerCode</strong></td>
                            <td data-col="externalcode"><small>@(item.ExternalCode ?? "—")</small></td>
                            <td data-col="name">@item.CustomerName</td>
                            <td data-col="account"><small class="text-muted">@(string.IsNullOrEmpty(item.AccountDisplay) ? "—" : item.AccountDisplay)</small></td>
                            <td data-col="category"><small class="text-muted">@(string.IsNullOrEmpty(item.PartyCategory) ? "—" : PartyCategoryDisplay.ToArabic(item.PartyCategory))</small></td>
                            <td data-col="phone"><small>@item.Phone1</small></td>
                            <td data-col="debit" class="text-end">@(item.CurrentBalance > 0 ? item.CurrentBalance.ToString("N2", n2) : "—")</td>
                            <td data-col="credit" class="text-end">@(item.CurrentBalance < 0 ? Math.Abs(item.CurrentBalance).ToString("N2", n2) : "—")</td>
                            <td data-col="creditlimit" class="text-end">@item.CreditLimit.ToString("N2", n2)</td>
                            <td data-col="sales" class="text-end">@item.TotalSales.ToString("N2", n2)</td>
                            <td data-col="purchases" class="text-end">@item.TotalPurchases.ToString("N2", n2)</td>
                            <td data-col="returns" class="text-end">@item.TotalReturns.ToString("N2", n2)</td>
                            <td data-col="availablecredit" class="text-end">@item.AvailableCredit.ToString("N2", n2)</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-secondary fw-bold">
                    <tr>
                        <td class="no-print" data-col="select"></td>
                        <td data-col="code"></td>
                        <td data-col="externalcode"></td>
                        <td data-col="name" class="text-start"><strong>المجموع الإجمالي:</strong></td>
                        <td data-col="account"></td>
                        <td data-col="category"></td>
                        <td data-col="phone"></td>
                        <td data-col="debit" class="text-end"><strong>@totalDebit.ToString("N2", n2)</strong></td>
                        <td data-col="credit" class="text-end"><strong>@totalCredit.ToString("N2", n2)</strong></td>
                        <td data-col="creditlimit" class="text-end"><strong>@totalCreditLimit.ToString("N2", n2)</strong></td>
                        <td data-col="sales" class="text-end"><strong>@totalSales.ToString("N2", n2)</strong></td>
                        <td data-col="purchases" class="text-end"><strong>@totalPurchases.ToString("N2", n2)</strong></td>
                        <td data-col="returns" class="text-end"><strong>@totalReturns.ToString("N2", n2)</strong></td>
                        <td data-col="availablecredit" class="text-end">
                            <strong class="customer-balances-total-value">@totalAvailableCredit.ToString("N2", n2)</strong>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
        </div>

        @* ===== شريط سفلي: عرض النطاق + حجم الصفحة (نمط القوائم) ===== *@
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 mb-2 d-print-none" dir="rtl">
            <small class="text-muted text-start">
                عرض @dispStart - @dispEnd من @totalCount
            </small>
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <label class="form-label m-0 text-nowrap small mb-0">حجم الصفحة</label>
                <select class="form-select form-select-sm" style="width:auto;min-width:4.5rem;" aria-label="حجم الصفحة"
                        onchange="var u=new URL(window.location.href);u.searchParams.set('pageSize',this.value);u.searchParams.set('page','1');window.location.href=u.toString();">
                    <option value="10" @(ps == 10 ? "selected" : "")>10</option>
                    <option value="25" @(ps == 25 ? "selected" : "")>25</option>
                    <option value="50" @(ps == 50 ? "selected" : "")>50</option>
                    <option value="100" @(ps == 100 ? "selected" : "")>100</option>
                    <option value="200" @(ps == 200 ? "selected" : "")>200</option>
                    <option value="500" @(ps == 500 ? "selected" : "")>500</option>
                    <option value="1000" @(ps == 1000 ? "selected" : "")>1000</option>
                    <option value="5000" @(ps == 5000 ? "selected" : "")>5000</option>
                    <option value="0" @(ps == 0 || (totalCount > 0 && ps >= totalCount) ? "selected" : "")>الكل</option>
                </select>
            </div>
        </div>

        @* لوحة فلتر العمود (بنمط Excel) *@
        <div id="erpColumnFilterPanel" class="erp-column-filter-panel d-none" dir="rtl">
            <div class="erp-column-filter-header">
                <span id="erpColumnFilterTitle">ترتيب وفلتر</span>
                <button type="button" class="btn-close btn-sm" id="erpColumnFilterClose" aria-label="إغلاق"></button>
            </div>
            <div class="erp-column-filter-body">
                <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
                    <label class="form-label small mb-1 fw-bold">الترتيب:</label>
                    <div class="d-flex flex-column gap-1">
                        <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="asc">▲ ترتيب تصاعدي</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-sort-btn" data-sort-dir="desc">▼ ترتيب تنازلي</button>
                    </div>
                </div>
                <div class="erp-filter-section">
                    <div id="erpColumnFilterSearchRow">
                        <label class="form-label small mb-1 fw-bold">الفلترة:</label>
                        <input type="text" id="erpColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
                    </div>
                    <div id="erpColumnFilterNumericRow" class="d-none">
                        <label class="form-label small mb-1 fw-bold">بحث رقمي:</label>
                        <input type="text" id="erpNumericFilterInput" class="form-control form-control-sm mb-0" placeholder="مثال: 10 أو &gt;100 أو 10:200" autocomplete="off" />
                    </div>
                    <div id="erpColumnFilterList" class="erp-column-filter-list">
                        <div class="text-muted text-center py-3">جاري التحميل...</div>
                    </div>
                </div>
                <div class="erp-column-filter-actions">
                    <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpColumnFilterOk">تطبيق</button>
                    <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" id="erpColumnFilterClear">مسح الفلتر</button>
                </div>
            </div>
        </div>

        @* ===== Pagination (دائماً مرئي — نمط القوائم) ===== *@
        <nav aria-label="pagination" class="mt-2 mb-3 d-print-none">
            <ul class="pagination justify-content-center flex-wrap mb-0">
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@pageUrl(1)">الأول</a>
                </li>
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@pageUrl(Math.Max(1, page - 1))">السابق</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">@($"صفحة {page} من {totalPages}")</span>
                </li>
                <li class="page-item @(page >= totalPages ? "disabled" : "")">
                    <a class="page-link" href="@pageUrl(Math.Min(totalPages, page + 1))">التالي</a>
                </li>
                <li class="page-item @(page >= totalPages ? "disabled" : "")">
                    <a class="page-link" href="@pageUrl(totalPages)">الأخير</a>
                </li>
            </ul>
        </nav>

        @* ===== Modal اختيار الأعمدة ===== *@
        <div class="modal fade no-print erp-columns-modal" id="columnsModalCb" tabindex="-1" aria-labelledby="columnsModalCbLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" dir="rtl">
                    <div class="modal-header">
                        <h5 class="modal-title flex-grow-1" id="columnsModalCbLabel">اختيار الأعمدة الظاهرة</h5>
                        <button type="button" class="btn-close ms-2" data-bs-dismiss="modal" aria-label="إغلاق"></button>
                    </div>
                    <div class="modal-body">
                        <div id="columnsListCb" class="erp-columns-modal-list"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-erp btn-erp-secondary" data-bs-dismiss="modal">إغلاق</button>
                        <button type="button" id="btnApplyColumnsCb" class="btn btn-erp btn-erp-primary">تطبيق</button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">لا توجد بيانات لعرضها</p>
        </div>
    }
</div>

