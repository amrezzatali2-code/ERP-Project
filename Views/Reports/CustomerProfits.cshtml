@using ERP.ViewModels
@{
    ViewData["Title"] = "تقرير: أرباح العملاء";

    var reportData = ViewBag.ReportData as List<CustomerProfitReportDto> ?? new List<CustomerProfitReportDto>();
    var totalSalesRevenue = ViewBag.TotalSalesRevenue as decimal? ?? 0m;
    var totalSalesCost = ViewBag.TotalSalesCost as decimal? ?? 0m;
    var totalSalesProfit = ViewBag.TotalSalesProfit as decimal? ?? 0m;
    var totalReturnProfit = ViewBag.TotalReturnProfit as decimal? ?? 0m;
    var totalNetProfit = ViewBag.TotalNetProfit as decimal? ?? 0m;

    // Pagination
    var page = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 200;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalCount = ViewBag.TotalCount as int? ?? 0;

    // الفلاتر من ViewBag
    var search = ViewBag.Search as string ?? "";
    var partyCategory = ViewBag.PartyCategory as string;
    var governorateId = ViewBag.GovernorateId as int?;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var includeZeroQty = ViewBag.IncludeZeroQty as bool? ?? false;
    var profitMethod = ViewBag.ProfitMethod as string ?? "both";
    var sortBy = ViewBag.SortBy as string ?? "name";
    var sortDir = ViewBag.SortDir as string ?? "asc";

    // القوائم المنسدلة
    var governorates = ViewBag.Governorates as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();

    // دالة إنشاء رابط الترتيب
    Func<string, string, string> sortUrl = (col, direction) =>
    {
        return Url.Action("CustomerProfits", "Reports", new
        {
            search,
            partyCategory,
            governorateId,
            fromDate,
            toDate,
            includeZeroQty,
            profitMethod,
            sortBy = col,
            sortDir = direction,
            loadReport = true,
            page,
            pageSize
        }) ?? "#";
    };

    // دالة إنشاء رابط Pagination
    Func<int, string> pageUrl = (p) =>
    {
        return Url.Action("CustomerProfits", "Reports", new
        {
            search,
            partyCategory,
            governorateId,
            fromDate,
            toDate,
            includeZeroQty,
            profitMethod,
            sortBy,
            sortDir,
            loadReport = true,
            page = p,
            pageSize
        }) ?? "#";
    };
}

<div dir="rtl" class="container-fluid">
    @* ===== شريط الفلاتر (نفس تنسيق قائمة الأصناف) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <form method="get" asp-action="CustomerProfits" asp-controller="Reports" id="filtersForm">
            <input type="hidden" name="loadReport" value="true" />
            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">بحث</label>
                    <input type="text" name="search" class="form-control erp-filter-input" placeholder="اسم العميل أو جزء منه..." autocomplete="off" value="@search" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">فئة العميل</label>
                    <input type="text" name="partyCategory" class="form-control erp-filter-input" placeholder="فئة العميل..." value="@partyCategory" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">المحافظة</label>
                    <select name="governorateId" class="form-select erp-filter-input">
                        <option value="">الكل</option>
                        @foreach (var gov in governorates)
                        {
                            <option value="@gov.Value" @(governorateId?.ToString() == gov.Value ? "selected" : null)>@gov.Text</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">من تاريخ</label>
                    <input type="date" name="fromDate" class="form-control erp-filter-input" value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date" name="toDate" class="form-control erp-filter-input" value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-12 col-lg-2 erp-filter-section d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="includeZeroQty" value="true" id="includeZeroQty" @(includeZeroQty ? "checked" : "") />
                        <label class="form-check-label small" for="includeZeroQty">عرض الصفر</label>
                    </div>
                </div>
                <div class="col-12 col-lg-auto erp-filter-section ms-lg-auto d-flex flex-wrap gap-2 align-items-end">
                    <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm"><span>📊</span> تجميع التقرير</button>
                    <a href="@Url.Action("CustomerProfits", "Reports")" class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none"><span>🔄</span> إعادة تعيين</a>
                </div>
            </div>
        </form>
        <div class="row g-3 align-items-end mt-0">
            <div class="col-12 col-lg-auto erp-filter-section d-flex flex-wrap gap-2 align-items-end">
                <form method="get" asp-action="CustomerProfits" asp-controller="Reports" class="d-inline-flex flex-nowrap gap-2 align-items-center erp-export-form">
                    <input type="hidden" name="loadReport" value="true" />
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="partyCategory" value="@(partyCategory ?? "")" />
                    <input type="hidden" name="governorateId" value="@(governorateId?.ToString() ?? "")" />
                    <input type="hidden" name="fromDate" value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                    <input type="hidden" name="toDate" value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                    <input type="hidden" name="includeZeroQty" value="@(includeZeroQty ? "true" : "false")" />
                    <input type="hidden" name="profitMethod" value="@profitMethod" />
                    <input type="hidden" name="sortBy" value="@sortBy" />
                    <input type="hidden" name="sortDir" value="@sortDir" />
                    <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;" title="اختر صيغة التصدير">
                        <option value="excel" selected>Excel</option>
                        <option value="csv">CSV</option>
                    </select>
                    <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                </form>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-2 mb-1">
        <h5 class="mb-0">أرباح العملاء</h5>
        @if (reportData.Any())
        {
            <small class="text-muted">إجمالي العملاء: <span id="customerProfitsItemCount">@totalCount</span></small>
        }
    </div>

    @* ===== جدول البيانات (نفس تنسيق قائمة الأصناف + ترتيب من الهيدر) ===== *@
    @if (reportData.Any())
    {
        <div class="erp-table-scroll-container mt-2" dir="rtl">
            <div id="customerProfitsTableScrollWrapper" class="erp-table-wrapper erp-print-area" style="position: relative; max-height: 70vh; overflow-y: auto; overflow-x: auto;">
                <table id="customerProfitsTable" class="table table-striped table-hover mb-0 erp-table erp-table-sortable erp-cp-table-fixed" data-current-sort="@sortBy" data-current-dir="@sortDir">
                    <colgroup>
                        <col style="width: 80px;" />
                        <col style="width: 200px;" />
                        <col style="width: 100px;" />
                        <col style="width: 100px;" />
                        <col style="width: 120px;" />
                        <col style="width: 120px;" />
                        <col style="width: 120px;" />
                        <col style="width: 100px;" />
                        <col style="width: 140px;" />
                        <col style="width: 130px;" />
                    </colgroup>
                    <thead class="table-light" style="position: sticky; top: 0; z-index: 10; background: #fafbfc !important;">
                        <tr>
                            <th style="width: 80px; min-width: 80px;" data-col="code">
                                <div class="d-flex align-items-center gap-1">
                                    <span>الكود</span>
                                    <button type="button" class="btn btn-sm p-0 erp-cp-col-filter-btn" data-col="code" data-sort-key="code" data-col-title="الكود" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                                </div>
                            </th>
                            <th style="width: 200px; min-width: 200px;" data-col="name">
                                <div class="d-flex align-items-center gap-1">
                                    <span>اسم العميل</span>
                                    <button type="button" class="btn btn-sm p-0 erp-cp-col-filter-btn" data-col="name" data-sort-key="name" data-col-title="اسم العميل" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                                </div>
                            </th>
                            <th style="width: 100px; min-width: 100px;" data-col="category">
                                <div class="d-flex align-items-center gap-1">
                                    <span>فئة العميل</span>
                                    <button type="button" class="btn btn-sm p-0 erp-cp-col-filter-btn" data-col="category" data-sort-key="category" data-col-title="فئة العميل" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                                </div>
                            </th>
                            <th style="width: 100px; min-width: 100px;" data-col="phone">
                                <div class="d-flex align-items-center gap-1">
                                    <span>الهاتف</span>
                                    <button type="button" class="btn btn-sm p-0 erp-cp-col-filter-btn" data-col="phone" data-sort-key="phone" data-col-title="الهاتف" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                                </div>
                            </th>
                            <th class="text-end" style="width: 120px; min-width: 120px;" data-col="salesrevenue">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <span>الإيرادات</span>
                                    <button type="button" class="btn btn-sm p-0 erp-cp-col-filter-btn" data-col="salesrevenue" data-sort-key="salesrevenue" data-col-title="الإيرادات" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                                </div>
                            </th>
                            <th class="text-end" style="width: 120px; min-width: 120px;" data-col="salescost">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <span>التكلفة</span>
                                    <button type="button" class="btn btn-sm p-0 erp-cp-col-filter-btn" data-col="salescost" data-sort-key="salescost" data-col-title="التكلفة" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                                </div>
                            </th>
                            <th class="text-end" style="width: 120px; min-width: 120px;" data-col="salesprofit">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <span>الربح</span>
                                    <button type="button" class="btn btn-sm p-0 erp-cp-col-filter-btn" data-col="salesprofit" data-sort-key="salesprofit" data-col-title="الربح" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                                </div>
                            </th>
                            <th class="text-end" style="width: 100px; min-width: 100px;" data-col="salesprofitpct">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <span>نسبة الربح %</span>
                                    <button type="button" class="btn btn-sm p-0 erp-cp-col-filter-btn" data-col="salesprofitpct" data-sort-key="salesprofitpct" data-col-title="نسبة الربح %" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                                </div>
                            </th>
                            <th class="text-end" style="width: 140px; min-width: 140px;" data-col="returnprofit">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <span>ربح المرتجعات (يُخصم من ربح البيع)</span>
                                    <button type="button" class="btn btn-sm p-0 erp-cp-col-filter-btn" data-col="returnprofit" data-sort-key="returnprofit" data-col-title="ربح المرتجعات" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                                </div>
                            </th>
                            <th class="text-end" style="width: 130px; min-width: 130px;" data-col="netprofit">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <span>صافي الربح</span>
                                    <button type="button" class="btn btn-sm p-0 erp-cp-col-filter-btn" data-col="netprofit" data-sort-key="netprofit" data-col-title="صافي الربح" title="ترتيب وفلتر"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z"/></svg></button>
                                </div>
                            </th>
                        </tr>
                    </thead>
                        <tbody>
                            @foreach (var item in reportData)
                            {
                                <tr>
                                    <td><strong>@item.CustomerCode</strong></td>
                                    <td>@item.CustomerName</td>
                                    <td><small class="text-muted">@(item.PartyCategory == "Customer" ? "عميل" : item.PartyCategory == "Supplier" ? "مورد" : item.PartyCategory ?? "—")</small></td>
                                    <td><small class="text-muted">@item.Phone1</small></td>
                                    
                                    @* الربح من البيع فقط *@
                                    <td class="text-end">@item.SalesRevenue.ToString("N2")</td>
                                    <td class="text-end">@item.SalesCost.ToString("N2")</td>
                                    <td class="text-end">
                                        <strong class="@(item.SalesProfit >= 0 ? "text-success" : "text-danger")">
                                            @item.SalesProfit.ToString("N2")
                                        </strong>
                                    </td>
                                    <td class="text-end">
                                        <span class="@(item.SalesProfitPercent >= 0 ? "text-success" : "text-danger")">
                                            @item.SalesProfitPercent.ToString("N2")%
                                        </span>
                                    </td>

                                    @* ربح المرتجعات *@
                                    <td class="text-end">
                                        <strong class="@(item.ReturnProfit >= 0 ? "text-success" : "text-danger")">
                                            @item.ReturnProfit.ToString("N2")
                                        </strong>
                                    </td>

                                    @* صافي الربح *@
                                    <td class="text-end">
                                        <strong class="@(item.NetProfit >= 0 ? "text-success" : "text-danger")">
                                            @item.NetProfit.ToString("N2")
                                        </strong>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold text-start">
                            <tr>
                                <td class="text-start" data-col="code" style="width:80px;min-width:80px;"><strong>المجموع الإجمالي:</strong></td>
                                <td data-col="name" style="width:200px;min-width:200px;"></td>
                                <td data-col="category" style="width:100px;min-width:100px;"></td>
                                <td data-col="phone" style="width:100px;min-width:100px;"></td>
                                <td class="text-end" data-col="salesrevenue" style="width:120px;min-width:120px;"><strong>@totalSalesRevenue.ToString("N2")</strong></td>
                                <td class="text-end" data-col="salescost" style="width:120px;min-width:120px;"><strong>@totalSalesCost.ToString("N2")</strong></td>
                                <td class="text-end" data-col="salesprofit" style="width:120px;min-width:120px;">
                                    <strong class="@(totalSalesProfit >= 0 ? "text-success" : "text-danger")">
                                        @totalSalesProfit.ToString("N2")
                                    </strong>
                                </td>
                                <td class="text-end" data-col="salesprofitpct" style="width:100px;min-width:100px;">
                                    <strong>
                                        @((totalSalesRevenue > 0 ? (totalSalesProfit / totalSalesRevenue * 100) : 0).ToString("N2"))%
                                    </strong>
                                </td>
                                <td class="text-end" data-col="returnprofit" style="width:140px;min-width:140px;">
                                    <strong class="@(totalReturnProfit >= 0 ? "text-success" : "text-danger")">
                                        @totalReturnProfit.ToString("N2")
                                    </strong>
                                </td>
                                <td class="text-end" data-col="netprofit" style="width:130px;min-width:130px;">
                                    <strong class="text-primary">
                                        @totalNetProfit.ToString("N2")
                                    </strong>
                                </td>
                            </tr>
                        </tfoot>
                </table>
            </div>
        </div>

        @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة + الترقيم (محاذاة لليمين) ===== *@
        @if (reportData.Any())
        {
            var startRow = totalCount == 0 ? 0 : ((page - 1) * pageSize) + 1;
            var endRow = Math.Min(totalCount, page * pageSize);
            <div class="d-flex flex-wrap justify-content-end align-items-center gap-3 mt-2 no-print" dir="rtl">
                <small class="text-muted">عرض @startRow - @endRow من @totalCount</small>
                <form method="get" asp-action="CustomerProfits" asp-controller="Reports" class="d-flex align-items-center gap-2">
                    <input type="hidden" name="loadReport" value="true" />
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="partyCategory" value="@(partyCategory ?? "")" />
                    <input type="hidden" name="governorateId" value="@(governorateId?.ToString() ?? "")" />
                    <input type="hidden" name="fromDate" value="@(fromDate?.ToString("yyyy-MM-dd") ?? "")" />
                    <input type="hidden" name="toDate" value="@(toDate?.ToString("yyyy-MM-dd") ?? "")" />
                    <input type="hidden" name="includeZeroQty" value="@(includeZeroQty ? "true" : "false")" />
                    <input type="hidden" name="profitMethod" value="@profitMethod" />
                    <input type="hidden" name="sortBy" value="@sortBy" />
                    <input type="hidden" name="sortDir" value="@sortDir" />
                    <input type="hidden" name="page" value="1" />
                    <label class="form-label m-0 nowrap">حجم الصفحة</label>
                    <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="50"@Html.Raw(pageSize == 50 ? " selected" : "")>50</option>
                        <option value="200"@Html.Raw(pageSize == 200 ? " selected" : "")>200</option>
                        <option value="500"@Html.Raw(pageSize == 500 ? " selected" : "")>500</option>
                        <option value="1000"@Html.Raw(pageSize == 1000 ? " selected" : "")>1000</option>
                        <option value="5000"@Html.Raw(pageSize == 5000 ? " selected" : "")>5000</option>
                        <option value="0"@Html.Raw(pageSize == 0 || pageSize >= totalCount ? " selected" : "")>الكل</option>
                    </select>
                </form>
                @if (totalPages > 1)
                {
                    <nav aria-label="pagination">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(page == 1 ? "disabled" : "")"><a class="page-link" href="@pageUrl(1)">الأول</a></li>
                            <li class="page-item @(page == 1 ? "disabled" : "")"><a class="page-link" href="@pageUrl(Math.Max(1, page - 1))">السابق</a></li>
                            <li class="page-item disabled"><span class="page-link">صفحة @(page) من @(totalPages)</span></li>
                            <li class="page-item @(page >= totalPages ? "disabled" : "")"><a class="page-link" href="@pageUrl(page + 1)">التالي</a></li>
                            <li class="page-item @(page >= totalPages ? "disabled" : "")"><a class="page-link" href="@pageUrl(totalPages)">الأخير</a></li>
                        </ul>
                    </nav>
                }
            </div>
        }
    }
    else
    {
        <div class="alert alert-info text-center">
            <p class="mb-0">لا توجد بيانات لعرضها</p>
        </div>
    }
</div>

@* لوحة ترتيب وفلتر العمود (نفس نمط باقي الجداول: ترتيب + عناصر العمود) *@
<div id="erpCpColumnFilterPanel" class="erp-column-filter-panel d-none" dir="rtl">
    <div class="erp-column-filter-header">
        <span id="erpCpColumnFilterTitle">ترتيب وفلتر</span>
        <button type="button" class="btn-close btn-sm" id="erpCpColumnFilterClose" aria-label="إغلاق"></button>
    </div>
    <div class="erp-column-filter-body">
        <div class="erp-filter-sort-section mb-3 pb-2 border-bottom">
            <label class="form-label small mb-1 fw-bold">الترتيب:</label>
            <div class="d-flex flex-column gap-1">
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-cp-sort-btn" data-sort-dir="asc"><span class="me-2">▲</span> ترتيب تصاعدي</button>
                <button type="button" class="btn btn-sm btn-outline-secondary text-start erp-cp-sort-btn" data-sort-dir="desc"><span class="me-2">▼</span> ترتيب تنازلي</button>
            </div>
        </div>
        <div class="erp-filter-section erp-cp-filter-content">
            <div id="erpCpColumnFilterSearchRow">
                <label class="form-label small mb-1 fw-bold">عناصر العمود:</label>
                <input type="text" id="erpCpColumnFilterSearch" class="form-control form-control-sm mb-2" placeholder="بحث في العناصر..." />
            </div>
            <div id="erpCpColumnFilterList" class="erp-column-filter-list">
                <div class="text-muted text-center py-3 small">اختر العمود لعرض عناصره</div>
            </div>
        </div>
        <div class="erp-column-filter-actions mt-2 flex-shrink-0">
            <button type="button" class="btn btn-erp btn-erp-primary btn-erp-sm" id="erpCpColumnFilterOk">تطبيق</button>
        </div>
    </div>
</div>

@section Styles {
    <style>
        #customerProfitsTable thead th { background-color: #fafbfc !important; color: #212529; border-bottom: 1px solid #dee2e6; font-weight: 600; }
        #customerProfitsTable tfoot { background-color: #e9ecef !important; border-top: 1px solid #dee2e6; }
        .erp-cp-col-filter-btn { color: #64748b; }
        .erp-cp-col-filter-btn:hover { color: #475569; }
        .erp-cp-col-filter-btn.erp-cp-filter-active { color: #0d6efd !important; }
        #erpCpColumnFilterPanel.erp-column-filter-panel { min-width: 280px; max-width: min(340px, 92vw); width: auto; max-height: 90vh; display: flex; flex-direction: column; }
        #erpCpColumnFilterPanel .erp-column-filter-body { display: flex; flex-direction: column; max-height: 75vh; min-height: 0; overflow: hidden; }
        #erpCpColumnFilterPanel .erp-cp-filter-content { flex: 1; min-height: 0; overflow-y: auto; }
        #erpCpColumnFilterList .erp-filter-items { max-height: 220px; overflow-y: auto; }
        /* ضبط محاذاة صف الإجماليات مع الأعمدة */
        table.erp-cp-table-fixed { table-layout: fixed; width: 100%; }
        table.erp-cp-table-fixed thead th,
        table.erp-cp-table-fixed tbody td,
        table.erp-cp-table-fixed tfoot td { box-sizing: border-box; }
        table.erp-cp-table-fixed tfoot td { overflow: hidden; text-overflow: ellipsis; }
        table.erp-cp-table-fixed tfoot td:first-child { white-space: nowrap; }
    </style>
}

@section Scripts {
    <script>
        (function () {
            var panel = document.getElementById('erpCpColumnFilterPanel');
            var titleEl = document.getElementById('erpCpColumnFilterTitle');
            var listEl = document.getElementById('erpCpColumnFilterList');
            var searchInp = document.getElementById('erpCpColumnFilterSearch');
            var btnOk = document.getElementById('erpCpColumnFilterOk');
            var btnClose = document.getElementById('erpCpColumnFilterClose');
            var form = document.getElementById('filtersForm');
            var currentSortKey = 'name';
            var allItems = [];
            var currentSelected = new Set();

            function buildItemsForColumn(colKey) {
                allItems = [];
                var table = document.getElementById('customerProfitsTable');
                if (!table || !table.tHead || !table.tBodies.length) return;
                var headerCells = table.tHead.rows[0].cells;
                var colIndex = -1;
                for (var i = 0; i < headerCells.length; i++) {
                    if ((headerCells[i].getAttribute('data-col') || '') === colKey) {
                        colIndex = i;
                        break;
                    }
                }
                if (colIndex === -1) return;
                var rows = table.tBodies[0].rows;
                var valuesSet = new Set();
                for (var r = 0; r < rows.length; r++) {
                    var cell = rows[r].cells[colIndex];
                    if (!cell) continue;
                    var val = (cell.textContent || '').trim();
                    if (!val) continue;
                    if (!valuesSet.has(val)) {
                        valuesSet.add(val);
                        allItems.push({ value: val, display: val });
                    }
                }
            }

            function renderList(search) {
                var term = (search || '').toLowerCase();
                var filtered = term
                    ? allItems.filter(function (x) { return (x.display || x.value || '').toLowerCase().indexOf(term) >= 0; })
                    : allItems.slice();
                var allChecked = filtered.length > 0 && filtered.every(function (x) { return currentSelected.has(String(x.value)); });
                var someChecked = filtered.some(function (x) { return currentSelected.has(String(x.value)); });
                if (!listEl) return;
                listEl.innerHTML = filtered.length === 0
                    ? '<div class="small text-muted py-2">لا توجد عناصر.</div>'
                    : '<div class="form-check mb-1">' +
                        '<input type="checkbox" class="form-check-input" id="erpCpFilterSelectAll" ' + (allChecked ? 'checked' : '') + '>' +
                        '<label class="form-check-label small" for="erpCpFilterSelectAll">(تحديد الكل)</label>' +
                      '</div>' +
                      '<div class="erp-filter-items" style="max-height:200px;overflow-y:auto;">' +
                        filtered.map(function (x) {
                            var v = String(x.value);
                            var escLabel = (x.display || v).replace(/</g, '&lt;').replace(/"/g, '&quot;');
                            var escVal = v.replace(/"/g, '&quot;');
                            var checked = currentSelected.has(v);
                            return '<div class="form-check small py-1">' +
                                '<input type="checkbox" class="form-check-input erp-cp-filter-item" value="' + escVal + '" ' + (checked ? 'checked' : '') + '>' +
                                '<label class="form-check-label small">' + escLabel + '</label>' +
                                '</div>';
                        }).join('') +
                      '</div>';
                var selectAllCb = listEl.querySelector('#erpCpFilterSelectAll');
                if (selectAllCb) {
                    selectAllCb.indeterminate = someChecked && !allChecked;
                    selectAllCb.addEventListener('change', function () {
                        filtered.forEach(function (x) {
                            var v = String(x.value);
                            if (selectAllCb.checked) currentSelected.add(v);
                            else currentSelected.delete(v);
                        });
                        renderList(searchInp ? searchInp.value : '');
                    });
                }
                listEl.querySelectorAll('.erp-cp-filter-item').forEach(function (cb) {
                    cb.addEventListener('change', function () {
                        var v = cb.value;
                        if (cb.checked) currentSelected.add(v);
                        else currentSelected.delete(v);
                    });
                });
            }

            function openPanel(btn) {
                currentSortKey = btn.getAttribute('data-sort-key') || 'name';
                var currentCol = btn.getAttribute('data-col') || '';
                titleEl.textContent = btn.getAttribute('data-col-title') || 'ترتيب وفلتر';
                document.querySelectorAll('.erp-cp-col-filter-btn').forEach(function (b) { b.classList.remove('erp-cp-filter-active'); });
                btn.classList.add('erp-cp-filter-active');
                var table = document.getElementById('customerProfitsTable');
                var currentDir = (table && table.getAttribute('data-current-dir')) || 'asc';
                document.querySelectorAll('.erp-cp-sort-btn').forEach(function (b) {
                    b.classList.toggle('active', b.getAttribute('data-sort-dir') === currentDir);
                });
                currentSelected = new Set();
                buildItemsForColumn(currentCol);
                if (searchInp) searchInp.value = '';
                renderList('');
                panel.classList.remove('d-none');
                var rect = btn.getBoundingClientRect();
                panel.style.position = 'fixed';
                panel.style.left = (rect.left - (panel.offsetWidth || 280) - 4) + 'px';
                panel.style.top = Math.max(8, rect.top) + 'px';
                panel.style.zIndex = '1050';
            }
            function closePanel() {
                panel.classList.add('d-none');
                document.querySelectorAll('.erp-cp-col-filter-btn').forEach(function (b) { b.classList.remove('erp-cp-filter-active'); });
            }
            function applySort() {
                var sortDirBtn = document.querySelector('.erp-cp-sort-btn.active');
                var dir = sortDirBtn ? sortDirBtn.getAttribute('data-sort-dir') : 'asc';
                var params = new URLSearchParams(new FormData(form));
                params.set('loadReport', 'true');
                params.set('sortBy', currentSortKey);
                params.set('sortDir', dir);
                params.set('page', '1');
                window.location.href = (form.action || window.location.pathname) + '?' + params.toString();
            }
            document.querySelectorAll('.erp-cp-col-filter-btn').forEach(function (btn) {
                btn.addEventListener('click', function (e) { e.preventDefault(); e.stopPropagation(); openPanel(btn); });
            });
            document.querySelectorAll('.erp-cp-sort-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    document.querySelectorAll('.erp-cp-sort-btn').forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                });
            });
            if (searchInp) {
                searchInp.addEventListener('input', function () { renderList(searchInp.value); });
                searchInp.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') { e.preventDefault(); applySort(); }
                });
            }
            if (btnOk) btnOk.addEventListener('click', applySort);
            if (btnClose) btnClose.addEventListener('click', closePanel);
            document.addEventListener('click', function (e) {
                if (panel && !panel.classList.contains('d-none') && !panel.contains(e.target) && !e.target.closest('.erp-cp-col-filter-btn'))
                    closePanel();
            });
        })();

        // ضمان إرسال includeZeroQty عند إرسال الفورم (عرض الصفر)
        document.addEventListener('DOMContentLoaded', function () {
            var form = document.getElementById('filtersForm');
            var includeZeroCb = document.getElementById('includeZeroQty');
            if (form && includeZeroCb) {
                form.addEventListener('submit', function () {
                    var existingHidden = form.querySelector('input[name="includeZeroQty"][type="hidden"]');
                    if (existingHidden) existingHidden.remove();
                    if (!includeZeroCb.checked) {
                        var hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.name = 'includeZeroQty';
                        hidden.value = 'false';
                        form.appendChild(hidden);
                    }
                });
            }
        });
    </script>
}
