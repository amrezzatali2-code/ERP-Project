@model ERP.Models.User

@{
    ViewData["Title"] = "تعديل مستخدم";
}

<div class="container" dir="rtl">
    <h2 class="mt-3 mb-3">تعديل مستخدم — @Model.UserName</h2>

    <form asp-action="Edit" method="post" class="card p-3">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        @* اسم الدخول (هو نفس الاسم المستخدم في كل التقارير) *@
        <div class="mb-3">
            <label asp-for="UserName" class="form-label"></label>
            <input asp-for="UserName" class="form-control" />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>

     

        @* تغيير كلمة المرور (لو الحقل فاضي → لا نغيّر الباسورد فى الكنترولر) — بدون تحقق مطلوب في التعديل *@
        <div class="mb-3">
            <label class="form-label" for="PasswordHash">تغيير كلمة المرور (اتركها فارغة لو لا تريد التغيير)</label>
            <input name="PasswordHash" id="PasswordHash" class="form-control" type="password" value="" placeholder="اتركها فارغة لو لا تريد التغيير" autocomplete="new-password" />
            <span asp-validation-for="PasswordHash" class="text-danger"></span>
        </div>

        @* هل المستخدم أدمن؟ *@
        <div class="form-check mb-2">
            <input asp-for="IsAdmin" class="form-check-input ms-2" />
            <label asp-for="IsAdmin" class="form-check-label"></label>
        </div>

        @* حالة النشاط *@
        <div class="form-check mb-3">
            <input asp-for="IsActive" class="form-check-input ms-2" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">حفظ التعديلات</button>
            <a asp-action="Index" class="btn btn-secondary">رجوع للقائمة</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
