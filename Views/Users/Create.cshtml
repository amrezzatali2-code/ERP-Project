@model ERP.Models.User

@{
    ViewData["Title"] = "مستخدم جديد";
}

<div class="container" dir="rtl">
    <h2 class="mt-3 mb-3">إضافة مستخدم جديد</h2>

    <form asp-action="Create" method="post" class="card p-3">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="UserName" class="form-label"></label>
            <input asp-for="UserName" class="form-control" />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>

     

        <div class="mb-3">
            <label class="form-label">كلمة المرور</label>
            @* نستخدم PasswordHash كباسورد الآن، ممكن نغيّر لاحقاً *@
            <input asp-for="PasswordHash" class="form-control" type="password" />
            <span asp-validation-for="PasswordHash" class="text-danger"></span>
        </div>

        <div class="form-check mb-2">
            <input asp-for="IsActive" class="form-check-input ms-2" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>

       

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">حفظ</button>
            <a asp-action="Index" class="btn btn-secondary">رجوع للقائمة</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
