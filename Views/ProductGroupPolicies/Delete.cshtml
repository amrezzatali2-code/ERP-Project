@model ERP.Models.ProductGroupPolicy

@{
    ViewData["Title"] = "حذف سياسة مجموعة أصناف";
}

<div class="container" dir="rtl">
    <h2 class="mt-3 mb-3 text-danger">حذف سياسة مجموعة أصناف — @Model.Id</h2>

    <div class="alert alert-warning">
        هل أنت متأكد أنك تريد حذف هذه السياسة؟
        هذه العملية لا يمكن التراجع عنها.
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">كود القاعدة</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">كود مجموعة الأصناف</dt>
                <dd class="col-sm-9">@Model.ProductGroupId</dd>

                <dt class="col-sm-3">كود السياسة</dt>
                <dd class="col-sm-9">@Model.PolicyId</dd>

                <dt class="col-sm-3">مفعّلة؟</dt>
                <dd class="col-sm-9">@(Model.IsActive ? "نعم" : "لا")</dd>
            </dl>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-erp btn-erp-danger">
                        تأكيد الحذف
                    </button>
                    <a asp-action="Index" class="btn btn-erp btn-erp-secondary">
                        إلغاء
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
