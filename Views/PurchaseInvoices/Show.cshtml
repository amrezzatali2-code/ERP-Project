            @* ==========================================
   5) جدول سطور فاتورة المشتريات (Hybrid)
   - لو الصنف سطر واحد => Flat Row
   - لو الصنف له تشغيلات متعددة => Group Header + Batch Rows
   ========================================== *@
            <div class="card shadow-sm mb-3 invoice-lines-card">
                <div class="card-header py-2 invoice-lines-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold">سطور فاتورة المشتريات</span>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="erp-table-wrapper mb-0">
                        <table class="table table-sm table-striped table-hover mb-0 erp-table">
                            <thead>
                                <tr>
                                    <th class="text-center">#</th>
                                    <th>اسم الصنف</th>
                                    <th class="text-center">التشغيلة</th>
                                    <th class="text-center">الصلاحية</th>
                                    <th class="text-center">الكمية</th>
                                    <th class="text-center">سعر الجمهور</th>
                                    <th class="text-center">خصم الشراء %</th>
                                    <th class="text-center">قيمة السطر</th>
                                    <th class="text-center">مسح</th>
                                </tr>
                            </thead>

                            <tbody id="PILinesTbody">
                                @{
                                    // =========================
                                    // متغير: قائمة السطور مرتبة
                                    // =========================
                                    var linesList = Model.Lines?.OrderBy(l => l.LineNo).ToList()
                                    ?? new List<ERP.Models.PILine>();

                                    // =========================
                                    // متغير: تجميع حسب الصنف
                                    // =========================
                                    var groups = linesList
                                    .GroupBy(l => new
                                    {
                                        l.ProdId,
                                        ProdName = l.Product?.ProdName ?? ("صنف #" + l.ProdId)
                                    })
                                    .OrderBy(g => g.Key.ProdName);
                                }

                                @* لو مفيش سطور *@
                                @if (!groups.Any())
                                {
                                    <tr>
                                        <td colspan="9" class="text-center text-muted py-3">
                                            لا يوجد سطور داخل الفاتورة حتى الآن.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var g in groups)
                                    {
                                        // متغير: عدد تشغيلات الصنف
                                        int batchCount = g.Count();

                                        // =========================
                                        // الحالة 1: الصنف غير مكرر => سطر واحد Flat
                                        // =========================
                                        if (batchCount == 1)
                                        {
                                            var line = g.First();

                                            // متغير: قيمة السطر بعد الخصم (كمية × سعر الجمهور × (1 - الخصم%))
                                            decimal lineValue =
                                            line.Qty * line.PriceRetail * (1m - (line.PurchaseDiscountPct / 100m));

                                            <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                <td class="text-center">@line.LineNo</td>

                                                <td>
                                                    <strong>@g.Key.ProdName</strong>
                                                    <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                </td>

                                                <td class="text-center">@line.BatchNo</td>

                                                <td class="text-center">
                                                    @(line.Expiry.HasValue? line.Expiry.Value.ToString("yyyy-MM-dd") : "")
                                                </td>

                                                <td class="text-center">@line.Qty</td>

                                                <td class="text-center">@line.PriceRetail.ToString("0.00")</td>

                                                <td class="text-center">@line.PurchaseDiscountPct.ToString("0.##")</td>

                                                <td class="text-center">@lineValue.ToString("0.00")</td>

                                                <td class="text-center">
                                                    <button type="button"
                                                            class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                                            data-line-no="@line.LineNo">
                                                        مسح
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            // =========================
                                            // الحالة 2: الصنف مكرر => هيدر + سطور تشغيلات
                                            // =========================

                                            @* (أ) سطر هيدر للصنف *@
                                            <tr class="table-light pi-group-row" data-prodid="@g.Key.ProdId">
                                                <td class="text-center">—</td>

                                                <td>
                                                    <strong>@g.Key.ProdName</strong>
                                                    <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                </td>

                                                <td class="text-center text-muted small">تشغيلات: @batchCount</td>
                                                <td class="text-center"></td>
                                                <td class="text-center"></td>
                                                <td class="text-center"></td>
                                                <td class="text-center"></td>
                                                <td class="text-center"></td>
                                                <td class="text-center"></td>
                                            </tr>

                                            @* (ب) سطور التشغيلات *@
                                            foreach (var line in g.OrderBy(x => x.LineNo))
                                            {
                                                // متغير: قيمة السطر بعد الخصم
                                                decimal lineValue =
                                                line.Qty * line.PriceRetail * (1m - (line.PurchaseDiscountPct / 100m));

                                                <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                    <td class="text-center">@line.LineNo</td>

                                                    <td class="text-muted small">↳</td>

                                                    <td class="text-center">@line.BatchNo</td>

                                                    <td class="text-center">
                                                        @(line.Expiry.HasValue? line.Expiry.Value.ToString("yyyy-MM-dd") : "")
                                                    </td>

                                                    <td class="text-center">@line.Qty</td>

                                                    <td class="text-center">@line.PriceRetail.ToString("0.00")</td>

                                                    <td class="text-center">@line.PurchaseDiscountPct.ToString("0.##")</td>

                                                    <td class="text-center">@lineValue.ToString("0.00")</td>

                                                    <td class="text-center">
                                                        <button type="button"
                                                                class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                                                data-line-no="@line.LineNo">
                                                            مسح
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>


@* ====================================
   6) ملخص الفاتورة (حسابات صحيحة من السطور)
   - إجمالي سعر الجمهور = مجموع (الكمية × سعر الجمهور)
   - الإجمالي بعد الخصم = مجموع (الكمية × سعر الجمهور × (1 - الخصم%))
   ==================================== *@
@{
    var lines = Model.Lines?.ToList() ?? new List<ERP.Models.PILine>();

    int totalLines = lines.Count;                               // متغير: عدد السطور
    int totalItems = lines.Select(l => l.ProdId).Distinct().Count(); // متغير: عدد الأصناف المختلفة
    int totalQty = lines.Sum(l => l.Qty);                     // متغير: إجمالي الكمية

    // متغير: إجمالي سعر الجمهور (قبل الخصم)
    decimal totalRetail = lines.Sum(l => l.Qty * l.PriceRetail);

    // متغير: الإجمالي بعد الخصم (على مستوى السطور)
    decimal totalAfterDiscount = lines.Sum(l =>
    l.Qty * l.PriceRetail * (1m - (l.PurchaseDiscountPct / 100m))
    );

    // متغير: إجمالي الخصم (فرق الإجماليين)
    decimal discountTotal = totalRetail - totalAfterDiscount;

    // متغير: الضريبة (من الهيدر)
    decimal taxAmount = Model.TaxTotal;

    // متغير: الإجمالي بعد الخصم والضريبة
    decimal totalAfterDiscountAndTax = totalAfterDiscount + taxAmount;

    // متغير: الصافي النهائي (نفس الإجمالي بعد الخصم والضريبة حالياً)
    decimal netTotal = totalAfterDiscountAndTax;
}

            <div class="card shadow-sm invoice-totals-card">
