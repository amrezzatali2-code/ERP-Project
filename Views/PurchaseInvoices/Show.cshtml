                }

                if (searchBtn) {
                    searchBtn.removeAttribute('title');
                    try {
                        const inst = bootstrap.Tooltip.getInstance(searchBtn);
                        if (inst) inst.dispose();
                    } catch { }
                }

                // ---------- 2) تهيئة Tooltip الأسهم (Hover فقط) ----------
                const ids = ['btnFirstInvoice', 'btnPrevInvoice', 'btnNextInvoice', 'btnLastInvoice'];

                ids.forEach(function (id) {
                    const el = document.getElementById(id);
                    if (!el) return;

                    // ✅ Dispose لأي Instance قديم (عشان ما تتكرر)
                    try {
                        const oldInst = bootstrap.Tooltip.getInstance(el);
                        if (oldInst) oldInst.dispose();
                    } catch { }

                    // ✅ إنشاء Tooltip جديد بسلوك ثابت
                    // trigger: 'hover' => يظهر على الوقوف فقط (مش بالضغط)
                    // container: 'body' => يمنع “النزول لتحت” الغريب
                    try {
                        new bootstrap.Tooltip(el, {
                            trigger: 'hover',
                            container: 'body',
                            boundary: 'viewport'
                        });
                    } catch { }
                });
            }

            // ✅ إخفاء Tooltip بسرعة + إزالة فوكس الزر بعد الضغط
            function hideTooltipAndBlur(el) {
                if (!el) return;

                // 1) Blur لمنع Focus-trigger
                try { el.blur(); } catch { }

                // 2) Hide tooltip لو موجود
                if (window.bootstrap && bootstrap.Tooltip) {
                    try {
                        const inst = bootstrap.Tooltip.getInstance(el);
                        if (inst) inst.hide();
                    } catch { }
                }
            }

            // =========================
            // تحديث أزرار السايد بار بعد تحميل body
            // =========================
            function refreshSideNavButtons() {

                // القيم الجديدة داخل PI_BodyHost (تتغير مع كل فاتورة)
                const navFirst = getInt('NavFirstId');
                const navLast = getInt('NavLastId');
                const navPrev = getInt('NavPrevId');
                const navNext = getInt('NavNextId');
                const currentId = getInt('NavCurrentId'); // 0 = فاتورة جديدة

                const hasAny = (navFirst > 0 && navLast > 0);

                // في الفاتورة الجديدة: السابق=آخر، التالي=أول
                const prevEffective = (currentId === 0) ? navLast : navPrev;
                const nextEffective = (currentId === 0) ? navFirst : navNext;

                const canFirst = hasAny && navFirst > 0 && navFirst !== currentId;
                const canLast = hasAny && navLast > 0 && navLast !== currentId;
                const canPrev = hasAny && prevEffective > 0 && prevEffective !== currentId;
                const canNext = hasAny && nextEffective > 0 && nextEffective !== currentId;

                // الأزرار
                const btnFirst = document.getElementById('btnFirstInvoice');
                const btnPrev = document.getElementById('btnPrevInvoice');
                const btnNext = document.getElementById('btnNextInvoice');
                const btnLast = document.getElementById('btnLastInvoice');

                // base URL للعرض
                const base = document.getElementById('btnNavInvoiceSearch')?.getAttribute('data-base-url')
                    || '@Url.Action("Show", "PurchaseInvoices", new { frame = 1 })';

                // نجهز URLs
                const urlFirst = setOrReplaceParam(base, 'id', navFirst);
                const urlLast = setOrReplaceParam(base, 'id', navLast);
                const urlPrev = setOrReplaceParam(base, 'id', prevEffective);
                const urlNext = setOrReplaceParam(base, 'id', nextEffective);

                if (btnFirst) { btnFirst.setAttribute('data-url', urlFirst); btnFirst.setAttribute('data-id', navFirst); }
                if (btnLast) { btnLast.setAttribute('data-url', urlLast); btnLast.setAttribute('data-id', navLast); }
                if (btnPrev) { btnPrev.setAttribute('data-url', urlPrev); btnPrev.setAttribute('data-id', prevEffective); }
                if (btnNext) { btnNext.setAttribute('data-url', urlNext); btnNext.setAttribute('data-id', nextEffective); }

                // Disabled
                setBtnState(btnFirst, canFirst);
                setBtnState(btnLast, canLast);
                setBtnState(btnPrev, canPrev);
                setBtnState(btnNext, canNext);
            }

            // =========================
            // تحميل Body فقط وتبديل المحتوى
            // =========================
            async function loadInvoiceBody(url) {

                const host = document.getElementById('PI_BodyHost');
                if (!host) return;

                url = setOrReplaceParam(url, 'frag', 'body');

                if (host.dataset.loading === "1") return;
                host.dataset.loading = "1";

                console.log('🔄 تحميل body الفاتورة:', url);

                try {
                    const res = await fetch(url, {
                        method: 'GET',
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    const html = await res.text();

                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newHost = doc.getElementById('PI_BodyHost');

                    if (newHost) {
                        host.innerHTML = newHost.innerHTML;
                    } else {
                        host.innerHTML = html;
                    }

                    // ✅ بعد تبديل الـ body: حدّث الشريط الجانبي (حالة الفاتورة + زر المرتجع)
                    const bodyIsPosted = document.getElementById("BodyHostIsPosted")?.value === "1";
                    const bodyStatus = (document.getElementById("BodyHostInvoiceStatus")?.value || "").trim();
                    const bodyInvoiceId = parseInt((document.getElementById("NavCurrentId")?.value || "0"), 10) || 0;
                    const invIdEl = document.getElementById("InvoiceId");
                    if (invIdEl) invIdEl.value = bodyInvoiceId;
                    const invFlagEl = document.getElementById("InvoiceIsPostedFlag");
                    if (invFlagEl) invFlagEl.value = bodyIsPosted ? "1" : "0";
                    const fullRetWrap = document.getElementById("fullReturnBtnWrapper");
                    if (fullRetWrap) {
                        const canShow = bodyInvoiceId > 0 && (bodyIsPosted || bodyStatus === "مفتوحة للتعديل" || (bodyStatus && bodyStatus.startsWith("مرحلة")));
                        if (canShow) fullRetWrap.classList.remove("d-none");
                        else fullRetWrap.classList.add("d-none");
                    }
                    if (typeof setInvoicePosted === "function") setInvoicePosted(bodyIsPosted);
                    if (typeof applyPostedUiLock === "function") applyPostedUiLock();
                    const isPostedDisplay = document.getElementById("InvoiceIsPostedDisplay");
                    if (isPostedDisplay && bodyStatus) isPostedDisplay.value = bodyStatus;
                    const statusHidden = document.getElementById("InvoiceStatusHidden");
                    if (statusHidden && bodyStatus) statusHidden.value = bodyStatus;
                    const btnPost = document.getElementById("btnPostInvoice");
                    if (btnPost) {
                        btnPost.innerHTML = bodyIsPosted ? "✅ تم ترحيل الفاتورة" : "📤 ترحيل الفاتورة";
                        btnPost.disabled = !!bodyIsPosted;
                    }
                    const btnOpen = document.getElementById("btnOpenInvoice");
                    if (btnOpen) btnOpen.disabled = !bodyIsPosted;

                    // ✅ بعد تبديل الـ body: حدّث زر حجم تعامل المورد مثل طلب الشراء (رابط بصيغة الاستعلام + data-url لتمكين البحث عن عميل آخر داخل الصفحة)
                    const customerIdEl = document.getElementById("CustomerId");
                    const customerId = parseInt((customerIdEl?.value || "0"), 10) || 0;
                    const btnVolume = document.getElementById("btnSupplierVolume");
                    if (btnVolume) {
                        var volBase = btnVolume.getAttribute("data-base-url") || "";
                        var volUrl = customerId > 0 ? (volBase + (volBase.indexOf("?") >= 0 ? "&" : "?") + "id=" + customerId) : "#";
                        btnVolume.href = volUrl;
                        btnVolume.setAttribute("data-url", volUrl);
                    }

                    // ✅ بعد تبديل الـ body: حدّث أزرار السايد بار
                    refreshSideNavButtons();

                    // ✅ بعد التبديل: أعد تهيئة tooltips للأسهم مرة واحدة وبشكل سليم
                    setupTooltips();

                    // ✅ نظام ثابت: بعد تبديل الـ Body لازم نعيد تهيئة الصفحة
                    if (typeof window.__ERP_INIT__ === 'function') {
                        window.__ERP_INIT__();
                    }

                    // ✅ مهم جداً: إعادة تهيئة event listeners للأصناف بعد إعادة تحميل الـ body
                    console.log('🔄 إعادة تهيئة event listeners للأصناف بعد حذف السطر...');
                    setTimeout(() => {
                        // إعادة تهيئة البحث عن الأصناف
                        if (typeof window.__initProductSearch === 'function') {
                            window.__initProductSearch();
                        }
                    }, 100);

                    // ✅ مهم جداً: إعادة تهيئة event listeners لزر الترحيل بعد إعادة تحميل الـ body
                    console.log('🔄 إعادة تهيئة event listeners لزر الترحيل...');
                    setTimeout(() => {
                        if (typeof window.__initPostInvoice === 'function') {
                            window.__initPostInvoice();
                        }
                    }, 150);


                } catch (e) {
                    console.error(e);
                    alert('حدث خطأ أثناء تحميل الفاتورة.');
                } finally {
                    host.dataset.loading = "0";
                }
            }

            // زر التحديث في الناف بار: إعادة جلب body نفس الفاتورة (سياسة مورد، أصناف، إلخ)
            window.__ERP_REFRESH__ = function () {
                const currentId = parseInt((document.getElementById('NavCurrentId')?.value || '0'), 10) || 0;
                const baseUrl = document.getElementById('btnNavInvoiceSearch')?.getAttribute('data-base-url')
                    || '@Url.Action("Show", "PurchaseInvoices", new { frame = 1 })';
                if (currentId > 0 && typeof loadInvoiceBody === 'function') {
                    try {
                        const u = new URL(baseUrl, window.location.origin);
                        u.searchParams.set('id', currentId);
                        const chk = document.getElementById('chkIncludeZeroQty');
                        if (chk && chk.checked) u.searchParams.set('includeZeroQty', 'true');
                        loadInvoiceBody(u.toString());
                    } catch (e) { console.warn('__ERP_REFRESH__ (PurchaseInvoices):', e); }
                }
            };

            // =========================
            // اعتراض الضغط على الأسهم/بحث الفاتورة على مستوى document (Capture)
            // =========================
            async function docCaptureHandler(ev) {

                // متغير: العنصر الذي تم الضغط عليه
                const t = ev.target;

                // حماية: لو target مش Element (نادرًا) نخرج
                if (!(t instanceof Element)) return;



                            // ✅ ثابت البرنامج: الأسهم + البحث يتم التعامل معهم من site.js (open-same-tab + btnNavInvoiceSearch)
            // ✅ ممنوع اعتراضهم هنا لأن تبديل الـ Body الجزئي يبوّظ السعر والفوكس
            const navBtn = t.closest('#btnFirstInvoice, #btnPrevInvoice, #btnNextInvoice, #btnLastInvoice, #btnNavInvoiceSearch');



            if (navBtn) return;





             // =========================
            // (0) زر مسح سطر من الفاتورة
            // =========================
            const removeBtn = t.closest('.btnRemoveLineFromInvoice');
            if (removeBtn) {

                ev.preventDefault();
                ev.stopPropagation();
                ev.stopImmediatePropagation();

                // متغير: رقم السطر داخل الفاتورة
                const lineNo = parseInt(removeBtn.getAttribute('data-line-no') || '0', 10);

                              // ✅ رقم الفاتورة (لازم يتقري وقت الضغط من الـ DOM لأنه بيتغير مع الـ Reload الجزئي)
            const piId = parseInt((document.getElementById('InvoiceId')?.value || '0'), 10) || 0;


                if (!piId || piId <= 0) { alert('لا يمكن مسح سطر: رقم الفاتورة غير معروف.'); return; }
                if (!lineNo || lineNo <= 0) { alert('لا يمكن مسح سطر: رقم السطر غير صحيح.'); return; }

                // تأكيد بسيط
                if (!confirm(`هل تريد مسح السطر رقم (${lineNo})؟`)) return;

                // منع الضغط المتكرر أثناء التنفيذ
                removeBtn.disabled = true;

                // ✅ متغير: توكن AntiForgery (من الدالة المثبتة عندك في Show)
                const antiToken = (window.getAntiForgeryToken ? window.getAntiForgeryToken() : '');

                // متغير: تايم آوت علشان ما يفضلش معلق
                const controller = new AbortController();
                const timeoutId = setTimeout(() => controller.abort(), 30000); // 30 ثانية

                try {
                    // ✅ استدعاء الأكشن الصحيح: RemoveLineJson
                    const res = await fetch('@Url.Action("RemoveLineJson", "PurchaseInvoices")', {
                        method: 'POST',
                        credentials: 'same-origin',
                        signal: controller.signal,
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest',
                            ...(antiToken ? { 'RequestVerificationToken': antiToken } : {})
                        },
                        // ✅ لازم نفس أسماء الـ DTO
                        body: JSON.stringify({ PIId: piId, LineNo: lineNo })
                    });

                    // متغير: نحاول نفهم الرد سواء JSON أو نص
                    let data = null;
                    const contentType = (res.headers.get('content-type') || '').toLowerCase();

                    if (contentType.includes('application/json')) {
                        data = await res.json().catch(() => null);
                    } else {
                        const txt = await res.text().catch(() => '');
                        data = { ok: false, message: txt ? 'فشل مسح السطر (رد غير متوقع من السيرفر).' : 'فشل مسح السطر.' };
                    }

                    if (!res.ok || !data || data.ok !== true) {
                        const msg = (data && data.message) ? data.message : 'فشل مسح السطر.';
                        alert(msg);
                        return;
                    }


                    // =========================================================
// ✅ إظهار رسالة "تم الحذف" بدل ما تضيع
// =========================================================
showToast(data.message || 'تم حذف السطر.', 'success');


                    // ✅ بعد المسح: Reload جزئي للفاتورة (frag=body)
                    const baseUrl =
                        document.getElementById('btnNavInvoiceSearch')?.getAttribute('data-base-url')
                        || '@Url.Action("Show", "PurchaseInvoices", new { frame = 1 })';

                    const url = setOrReplaceParam(baseUrl, 'id', piId);


                    // =========================================================
                    // ✅ حفظ حالة الفاتورة الحالية قبل Reload
                    // =========================================================
                        const statusBox = document.getElementById('InvoiceIsPostedDisplay');      // متغير: بوكس حالة الفاتورة الظاهر
                        const statusHidden = document.getElementById('InvoiceStatusHidden');      // متغير: الحالة المخفية (لـ JS)
                        const prevStatus = statusBox ? statusBox.value : '';                      // متغير: الحالة قبل المسح


                    // ✅ مهم: ننتظر التحميل قبل إعادة تفعيل الزر
                    await loadInvoiceBody(url);


             // =========================================================
            // ✅ بعد Reload: رجّع نفس الحالة كما كانت (المسح لا يغير الحالة)
            // =========================================================
            const statusBox2 = document.getElementById('InvoiceIsPostedDisplay');     // متغير: بوكس الحالة بعد Reload
            const statusHidden2 = document.getElementById('InvoiceStatusHidden');     // متغير: hidden بعد Reload

            if (statusBox2) statusBox2.value = prevStatus || statusBox2.value;        // تعليق: لا نسمح لـ OPEN أن يحل محل الحالة القديمة
            if (statusHidden2) statusHidden2.value = prevStatus || statusHidden2.value;


                } catch (e) {
                    console.error(e);

                    if (e && e.name === 'AbortError') {
                        alert('التنفيذ أخذ وقت طويل. حاول مرة أخرى.');
                    } else {
                        alert('حدث خطأ أثناء مسح السطر.');
                    }
                } finally {
                    clearTimeout(timeoutId);

                    if (document.contains(removeBtn)) {
                        removeBtn.disabled = false;
                    }
                }

                return; // مهم: منع استمرار التعامل كأنه زر أسهم
            }






                // =========================
                // (1) الأسهم + البحث
                // =========================
                const btn = t.closest('#btnFirstInvoice, #btnPrevInvoice, #btnNextInvoice, #btnLastInvoice, #btnNavInvoiceSearch');
                if (!btn) return;

                if (btn.hasAttribute('disabled')) return;

                // ✅ امنع أي نظام تابات/لينكات
                ev.preventDefault();
                ev.stopPropagation();
                ev.stopImmediatePropagation();

                // ✅ مهم: اقفل Tooltip + شيل فوكس بعد الضغط
                hideTooltipAndBlur(btn);

                if (btn.id === 'btnNavInvoiceSearch') {
                    const input = document.getElementById('NavInvoiceSearchInput');
                    const val = input ? parseInt(input.value || '0', 10) : 0;
                    if (!val || val <= 0) return;

                    const baseUrl = btn.getAttribute('data-base-url');
                    if (!baseUrl) return;

                    const url = setOrReplaceParam(baseUrl, 'id', val);
                    loadInvoiceBody(url);
                    return;
                }

                const baseUrl = btn.getAttribute('data-base-url');
                if (!url) return;

                loadInvoiceBody(url);
            }








            // =========================================================
// ERP — زر طباعة الفاتورة (Purchase Invoice) [ثابت معتمد]
// - ممنوع الطباعة إلا لو الفاتورة مُرحّلة (مغلقة)
// - نقرأ InvoiceId وقت الضغط
// - نطبع فقط .erp-print-area (حسب site.css)
// - نجهز (الهيدر + السطور + الإجماليات) قبل الطباعة
// =========================================================
document.addEventListener("DOMContentLoaded", function () {

    const btnPrint = document.getElementById("btnPrintInvoice"); // متغير: زر طباعة الفاتورة

    if (!btnPrint) return;

    // ✅ ربط مرة واحدة
    if (btnPrint.dataset.boundPrint) return;
    btnPrint.dataset.boundPrint = "1";

    // ✅ عند فتح الصفحة: لو الفاتورة مش مُرحّلة نقفل زر الطباعة
    if (typeof isInvoicePosted === "function" && !isInvoicePosted()) {
        btnPrint.disabled = true;
    }

    // متغير: منع فتح نافذة الطباعة مرتين
    let printing = false;

    // =========================================================
    // دالة: تجهيز منطقة الطباعة من القيم الظاهرة في الشاشة
    // =========================================================
    function preparePurchaseInvoicePrint() {

        // متغير: منطقة الطباعة
        const printArea = document.getElementById("piPrintArea");
        if (!printArea) return false;

        // =========================
        // (1) هيدر الطباعة
        // =========================

        // متغير: رقم الفاتورة
        const invoiceId = (document.getElementById("InvoiceId")?.value || "").trim();

        // متغير: تاريخ الفاتورة (لو عندك input اسمه PIDate)
        const invoiceDate =
            (document.getElementById("PIDate")?.value || "").trim() ||
            "";

        // متغير: اسم المورد من الـ Select (CustomerId)
        let supplierName = "";
        const customerSel = document.getElementById("CustomerId");
        if (customerSel && customerSel.options && customerSel.selectedIndex >= 0) {
            supplierName = (customerSel.options[customerSel.selectedIndex].text || "").trim();
        }

        // متغير: اسم المخزن من الـ Select (WarehouseId)
        let warehouseName = "";
        const whSel = document.getElementById("WarehouseId");
        if (whSel && whSel.options && whSel.selectedIndex >= 0) {
            warehouseName = (whSel.options[whSel.selectedIndex].text || "").trim();
        }

        // تعبئة عناصر الهيدر
        document.getElementById("piPrintNow").textContent = new Date().toLocaleString();
        document.getElementById("piPrintTitle").textContent = `ERP — فاتورة مشتريات رقم ${invoiceId || ""}`;
        document.getElementById("piPrintInvoiceNo").textContent = invoiceId || "";
        document.getElementById("piPrintInvoiceDate").textContent = invoiceDate || "";
        document.getElementById("piPrintSupplier").textContent = supplierName || "";
        document.getElementById("piPrintWarehouse").textContent = warehouseName || "";

        // =========================
        // (2) السطور: ننسخ جدول السطور الموجود
        // =========================
        const linesWrap = document.getElementById("piPrintLinesWrap");
        if (!linesWrap) return false;

        linesWrap.innerHTML = "";

        const tbody = document.getElementById("PILinesTbody"); // متغير: tbody الخاص بسطور الفاتورة
        if (!tbody) {
            linesWrap.innerHTML = `<div class="text-muted small">لا توجد سطور للطباعة.</div>`;
        } else {
            const table = tbody.closest("table");
            if (!table) {
                linesWrap.innerHTML = `<div class="text-muted small">تعذر العثور على جدول السطور.</div>`;
            } else {
                // استنساخ الجدول
                const clone = table.cloneNode(true);

                // إزالة أي أزرار داخل الجدول (مسح/تعديل)
                clone.querySelectorAll("button, a").forEach(x => x.remove());

                linesWrap.appendChild(clone);
            }
        }

        // =========================
        // (3) الإجماليات: نقرأها من IDs التي عندك
        // =========================
        const totalsWrap = document.getElementById("piPrintTotalsWrap");
        if (!totalsWrap) return false;

        const totalLines = document.getElementById("TotalLinesValue")?.textContent?.trim() || "0";
        const totalItems = document.getElementById("TotalItemsValue")?.textContent?.trim() || "0";
        const totalQty = document.getElementById("TotalQtyValue")?.textContent?.trim() || "0";
        const totalRetail = document.getElementById("TotalRetailValue")?.textContent?.trim() || "0";
        const totalAfterDiscount = document.getElementById("TotalAfterDiscountValue")?.textContent?.trim() || "0";
        const tax = (document.getElementById("TaxAmountInput")?.value || "").trim() || "0";
        const totalAfterDiscountAndTax = document.getElementById("TotalAfterDiscountAndTaxValue")?.textContent?.trim() || "0";
        const netTotal = document.getElementById("NetTotalValue")?.textContent?.trim() || "0";

        totalsWrap.innerHTML = `
            <table>
                <thead><tr><th colspan="4">الإجماليات</th></tr></thead>
                <tbody>
                    <tr>
                        <td>عدد السطور</td><td><strong>${totalLines}</strong></td>
                        <td>عدد الأصناف</td><td><strong>${totalItems}</strong></td>
                    </tr>
                    <tr>
                        <td>إجمالي الكمية</td><td><strong>${totalQty}</strong></td>
                        <td>إجمالي سعر الجمهور</td><td><strong>${totalRetail}</strong></td>
                    </tr>
                    <tr>
                        <td>الإجمالي بعد الخصم</td><td><strong>${totalAfterDiscount}</strong></td>
                        <td>قيمة الضريبة</td><td><strong>${tax}</strong></td>
                    </tr>
                    <tr>
                        <td>الإجمالي بعد الخصم والضريبة</td><td><strong>${totalAfterDiscountAndTax}</strong></td>
                        <td>الصافي النهائي</td><td><strong>${netTotal}</strong></td>
                    </tr>
                </tbody>
            </table>
        `;

        return true;
    }

    btnPrint.addEventListener("click", function () {

        // ✅ اقرأ رقم الفاتورة وقت الضغط
        const invoiceId = parseInt((document.getElementById("InvoiceId")?.value || "0"), 10) || 0;

        if (invoiceId <= 0) {
            showToast("⚠️ لا يمكن طباعة فاتورة قبل حفظها.", "warning");
            return;
        }

        // ✅ شرط البرنامج: لا طباعة إلا بعد الترحيل
        if (typeof isInvoicePosted === "function" && !isInvoicePosted()) {
            showToast("❌ لا يمكن طباعة الفاتورة إلا بعد الترحيل (إغلاق الفاتورة).", "danger");
            document.getElementById("btnPostInvoice")?.focus();
            return;
        }

        // منع تكرار الطباعة
        if (printing) return;
        printing = true;

        // ✅ تجهيز منطقة الطباعة
        const ok = preparePurchaseInvoicePrint();
        if (!ok) {
            printing = false;
            showToast("تعذر تجهيز الطباعة. تأكد من وجود منطقة الطباعة piPrintArea.", "danger");
            return;
        }

                    // =========================
            // (ERP ثابت) تجهيز بيانات الهيدر داخل منطقة الطباعة قبل التنفيذ
            // =========================

            // متغير: اسم المورد من نفس Input في الهيدر
            const supplierName = (document.getElementById("CustomerNameInput")?.value || "").trim();

            // متغير: تاريخ الفاتورة من نفس Input في الهيدر
            const invoiceDate = (document.getElementById("InvoiceDateDisplay")?.value || "").trim();

            // دالة صغيرة: تكتب نص في عنصر طباعة لو موجود
            function setPrintText(id, text) {
                const el = document.getElementById(id);
                if (el) el.textContent = text || "";
            }

            // ✅ املأ القيم داخل الطباعة
            setPrintText("piPrintSupplier", supplierName);
            setPrintText("piPrintInvoiceDate", invoiceDate);


        // ✅ اطبع مرة واحدة
        setTimeout(() => window.print(), 50);
    });

    // بعد إغلاق نافذة الطباعة
    window.addEventListener("afterprint", function () {
        printing = false;
    });
});










            // =========================
            // تشغيل
            // =========================
            document.addEventListener('click', docCaptureHandler, true);

            document.addEventListener('DOMContentLoaded', function () {

                // ✅ أول ما الصفحة تفتح: نضبط الأزرار
                refreshSideNavButtons();

                // ✅ أول ما الصفحة تفتح: نضبط Tooltips (الأسهم فقط)
                setupTooltips();

                // ✅ إزالة Tooltip من البحث نهائيًا (Placeholder فقط)
                const input = document.getElementById('NavInvoiceSearchInput');
                if (input) {
                    input.removeAttribute('title');
                    // تعليق: placeholder هو اللي هيوضح وظيفة البحث
                    if (!input.getAttribute('placeholder')) input.setAttribute('placeholder', 'بحث برقم الفاتورة');
                }

                const btn = document.getElementById('btnNavInvoiceSearch');
                if (btn) btn.removeAttribute('title');
            });

        })();





                   



    </script>
