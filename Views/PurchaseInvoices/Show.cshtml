                    @* <div class="card shadow-sm mb-3 invoice-lines-card"> *@
                        @* <div class="card-header py-2 invoice-lines-header">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">سطور فاتورة المشتريات</span>
