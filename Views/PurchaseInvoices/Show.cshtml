@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.PurchaseInvoice

@{
    // عنوان التاب
    ViewData["Title"] = Model.PIId == 0
        ? "فاتورة مشتريات جديدة"
        : $"فاتورة مشتريات — رقم {Model.PIId}";
}

@section Styles {
    <style>

/* =========================================================
   إخفاء أسهم الـ Number Inputs (علشان الشكل ما يتلخبطش)
   - مهم عند فك readonly لأن الأسهم بتظهر وتغيّر شكل السطر
   ========================================================= */
.pi-input[type="number"]::-webkit-outer-spin-button,
.pi-input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}
.pi-input[type="number"] {
    -moz-appearance: textfield;
}


        /* خلفية عامة للصفحة */
        .invoice-page {
            background-color: #f3f6fb; /* لون خفيف مريح للعين */
            min-height: 100vh;
            padding-bottom: 2rem;
        }

        /* الكروت الرئيسية (الهيدر + تفاصيل + إدخال صنف + بيانات الصنف + السطور + الإجماليات + الكارت الجانبي) */
        .invoice-header-card,
        .invoice-details-card,
        .invoice-lines-card,
        .invoice-totals-card,
        .invoice-side-card,
        .invoice-Add-card,
        .invoice-product-card {
            border-radius: 1rem;
            overflow: hidden;
        }

        /* شريط الأزرار: يفضل ظاهر ومثبت */
        .invoice-actions-sticky {
            position: sticky;
            top: 58px; /* عدّلها حسب ارتفاع الـ Navbar عندك */
            z-index: 3000; /* أعلى من أي كروت/هيدر */

            background: #ffffff; /* ✅ أفتح لون (بدل الرمادي) */
            border: 1px solid rgba(13,110,253,.12); /* ✅ بوردر خفيف */
            padding: 10px 10px;
            border-radius: 14px;
            box-shadow: 0 10px 24px rgba(0,0,0,.05); /* ✅ ظل أخف */
        }
/* لو عندك تبويب/هيدر ثابت أعلى من النافبار زوّد top */
@@media (max-width: 992px){
    .invoice-actions-sticky{
        top: 56px;
    }
}



     


        /* شريط الهيدر الملون للهيدر الرئيسي */
        .invoice-header-bar {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.75rem 1.25rem;
        }

            .invoice-header-bar h5 {
                margin-bottom: 0.1rem;
            }

        /* نفس لون الهيدر لباقي الكروت */
        .invoice-details-card .card-header,
        .invoice-Add-card .card-header,
        .invoice-product-card .card-header,
        .invoice-lines-card .card-header,
        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.55rem 1rem;
        }

        .invoice-status-badge {
            font-size: 0.8rem;
            padding: 0.3rem 0.7rem;
        }

        .badge-status-draft {
            background-color: #6f42c1; /* بنفسجي لمسودة */
        }

        .badge-status-notposted {
            background-color: #343a40; /* غامق لعدم الترحيل */
        }

        .form-label-sm {
            font-size: 0.85rem;
        }

        .invoice-small-input {
            max-width: 150px;
        }

        .customer-summary-line {
            font-size: 0.82rem;
        }

        /* كارت الإجراءات الجانبية: أزرار أرفع شوية */
        .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
        }

            .invoice-side-card .btn-erp + .btn-erp {
                margin-top: 0.25rem;
            }

        /* هيدر جدول السطور */
        .invoice-lines-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #fff;
        }

            .invoice-lines-header th {
                border-color: #0b5ed7 !important;
            }

        .erp-table-wrapper {
            max-height: 360px;
            overflow: auto;
        }

        .summary-badge {
            min-width: 80px;
            text-align: center;
        }

        /* =========================================================
           ERP — Print Template (Purchase Invoice)
           محلي داخل Show فقط
        ========================================================= */

        /* مخفي في الشاشة */
        .print-only {
            display: none;
        }

        @@media print {
            /* يظهر في الطباعة فقط */
            .print-only {
                display: block !important;
            }
            /* مهم: فك أي Scroll أثناء الطباعة */
            .erp-table-wrapper {
                max-height: none !important;
                overflow: visible !important;
            }
            /* تنسيق جدول الطباعة لو اتنسخ */
            #piPrintArea table {
                width: 100%;
                border-collapse: collapse;
                font-size: 12px;
            }

            #piPrintArea th, #piPrintArea td {
                border: 1px solid #d0d0d0;
                padding: 6px;
                vertical-align: middle;
                white-space: nowrap;
            }

            #piPrintArea thead {
                display: table-header-group;
            }

            #piPrintArea tr {
                break-inside: avoid;
            }
        }



        /* =========================================================
   اختيار سطر من جدول السطور (Click Row)
   - عند الضغط على أي سطر في جدول السطور: يتم تمييزه
   - وتعبئة بياناته في جزء (إضافة صنف للفاتورة) أعلى الصفحة
   ========================================================= */
#PILinesTbody tr[data-prodid] {
    cursor: pointer; /* تعليق: السطر قابل للضغط */
}

#PILinesTbody tr.pi-row-selected td {
    outline: 2px solid rgba(13, 110, 253, 0.35);
    outline-offset: -2px;
    background: rgba(13, 110, 253, 0.06);
}

@@media print {
    #PILinesTbody tr.pi-row-selected td {
        outline: none !important;
        background: transparent !important;
    }
}



    </style>
}




<div class="invoice-page" dir="rtl">
    <div class="container-fluid pt-3">

        @* فورم مخفي لتوليد Anti-Forgery Token لاستخدامه في نداءات AJAX *@
        <form id="__AntiForgeryForm" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>

        <div class="row g-3">



            @* =========================
               العمود الجانبي (أزرار الحركة) — ثابت برا الـ BodyHost
               ========================= *@
            <div class="col-12 col-lg-2 order-1 order-lg-2">

                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="card-header py-2 text-center">
                        <h6 class="mb-0">إجراءات فاتورة المشتريات</h6>
                    </div>


                    <!-- =========================================================
                    ثابت: رقم الفاتورة + علم الترحيل (Flag)
                    - InvoiceId: رقم الفاتورة الحالي (0 لو جديدة)
                    - InvoiceIsPostedFlag: 1 لو مترحّلة / 0 لو مفتوحة
                    ========================================================= -->
                    <input type="hidden" id="InvoiceId" value="@Model.PIId" />
                    <input type="hidden" id="InvoiceIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />



                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">

                        @{
                            int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
                            int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
                            int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
                            int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;

                            int currentId = Model?.PIId ?? 0;

                            bool hasAnyInvoices =
                            navFirst.HasValue && navLast.HasValue &&
                            navFirst.Value > 0 && navLast.Value > 0;

                            int? prevEffective = (currentId == 0) ? navLast : navPrev;
                            int? nextEffective = (currentId == 0) ? navFirst : navNext;

                            bool canFirst = hasAnyInvoices && navFirst.HasValue && navFirst.Value > 0 && navFirst.Value != currentId;
                            bool canLast = hasAnyInvoices && navLast.HasValue && navLast.Value > 0 && navLast.Value != currentId;
                            bool canPrev = hasAnyInvoices && prevEffective.HasValue && prevEffective.Value > 0 && prevEffective.Value != currentId;
                            bool canNext = hasAnyInvoices && nextEffective.HasValue && nextEffective.Value > 0 && nextEffective.Value != currentId;
                        }

                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button"
                                    id="btnFirstInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pi-show-tab"
                                    data-tab-title="فاتورة المشتريات"
                                    data-base-url="@Url.Action("Show", "PurchaseInvoices", new { id = (navFirst ?? 0), frame = 1 })"
                                    data-id="@(navFirst ?? 0)"
                                    title="أول فاتورة"
                                    @(canFirst ? "" : "disabled")>
                                ⏮
                            </button>

                            <button type="button"
                                    id="btnPrevInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pi-show-tab"
                                    data-tab-title="فاتورة المشتريات"
                                    data-base-url="@Url.Action("Show", "PurchaseInvoices", new { id = (prevEffective ?? 0), frame = 1 })"
                                    data-id="@(prevEffective ?? 0)"
                                    title="الفاتورة السابقة"
                                    @(canPrev ? "" : "disabled")>
                                ◀
                            </button>

                            <button type="button"
                                    id="btnNextInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pi-show-tab"
                                    data-tab-title="فاتورة المشتريات"
                                    data-base-url="@Url.Action("Show", "PurchaseInvoices", new { id = (nextEffective ?? 0), frame = 1 })"
                                    data-id="@(nextEffective ?? 0)"
                                    title="الفاتورة التالية"
                                    @(canNext ? "" : "disabled")>
                                ▶
                            </button>

                            <button type="button"
                                    id="btnLastInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pi-show-tab"
                                    data-tab-title="فاتورة المشتريات"
                                    data-base-url="@Url.Action("Show", "PurchaseInvoices", new { id = (navLast ?? 0), frame = 1 })"
                                    data-id="@(navLast ?? 0)"
                                    title="آخر فاتورة"
                                    @(canLast ? "" : "disabled")>
                                ⏭
                            </button>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <input type="number"
                                   id="NavInvoiceSearchInput"
                                   class="form-control form-control-sm"
                                   placeholder="بحث برقم الفاتورة" />


                            <button type="button"
                                    id="btnNavInvoiceSearch"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-tab-id="pi-show-tab"
                                    data-tab-title="فاتورة المشتريات"
                                    data-base-url="@Url.Action("Show", "PurchaseInvoices", new { frame = 1 })">
                                بحث
                            </button>
                        </div>

                        <hr class="my-1" />

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           data-tab-id="pi-show-tab"
                           data-tab-title="فاتورة المشتريات"
                           data-url="@Url.Action("Create", "PurchaseInvoices", new { frame = 1 })">
                            ➕ فاتورة جديدة
                        </a>

                        <button type="button" 
                            class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" 
                            id="btnSaveInvoiceHeader" 
                            data-lock-posted="1">
                            💾 حفظ الفاتورة
                        </button>

                        <button type="button" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" id="btnPostInvoice" data-lock-posted="1">
                            📤 ترحيل الفاتورة
                        </button>

                        <div id="postInvoiceMsg" class="small mt-2"></div>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnOpenInvoice">
                            ⏪ فتح الفاتورة
                        </button>

                        <!-- نفس بوكس الرسائل المستخدم في الترحيل -->
                        <div id="postInvoiceMsg" class="small mt-2"></div>


                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnClearInvoiceLines"
                                data-invoice-id="@(Model?.PIId ?? 0)" 
                                data-lock-posted="1">
                            🗑️ مسح كل أصناف الفاتورة
                        </button>

                      

                       <button type="button"
        id="btnPrintInvoice"
        class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
        >
    🖨️ طباعة الفاتورة
</button>



                    </div>
                </div>

            </div> @* نهاية العمود الجانبي *@





            @* =========================
               العمود الرئيسي (الهيدر + المورد + الأصناف + السطور + الإجماليات)
               ========================= *@
            <div class="col-12 col-lg-10 order-2 order-lg-1">

                @* ✅ ده الجزء الوحيد اللي هيتبدّل عند التنقل *@
                <div id="PI_BodyHost">

                    @* =========================
                       قيم التنقل (لازم تكون داخل الـ BodyHost عشان تتحدّث مع frag=body)
                       ========================= *@
                    <input type="hidden" id="NavFirstId" value="@(ViewBag.NavFirstId ?? 0)" />
                    <input type="hidden" id="NavLastId" value="@(ViewBag.NavLastId ?? 0)" />
                    <input type="hidden" id="NavPrevId" value="@(ViewBag.NavPrevId ?? 0)" />
                    <input type="hidden" id="NavNextId" value="@(ViewBag.NavNextId ?? 0)" />
                    <input type="hidden" id="NavCurrentId" value="@(Model?.PIId ?? 0)" />

                    @* ====================================================
                       1) كارت بيانات فاتورة المشتريات + المورد + المخزن
                       ==================================================== *@
                    <div class="card shadow-sm mb-2 invoice-header-card">

                        @{
                            bool isNewInvoice = Model == null || Model.PIId == 0;
                            bool hasInvoice = !isNewInvoice;

                            string invoiceDateText = hasInvoice
                            ? Model.PIDate.ToString("yyyy/MM/dd")
                            : "";

                            string invoiceTimeText = hasInvoice
                            ? Model.CreatedAt.ToLocalTime().ToString("HH:mm")
                            : "";
                        }

                        <div class="invoice-header-bar d-flex justify-content-between align-items-center flex-wrap gap-2">

                            <div>
                                <h5 class="mb-1">فاتورة مشتريات</h5>
                            </div>

                            <div class="d-flex align-items-center gap-2">

                                <div class="text-end">
                                    @if (!isNewInvoice)
                                    {
                                        @* مكان رسائل الحالة إن وجدت *@
                                    }
                                </div>

                                <button type="button"
                                        class="btn btn-sm btn-light"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#InvoiceHeaderCardCollapse"
                                        aria-expanded="true"
                                        aria-controls="InvoiceHeaderCardCollapse">
                                    <span id="InvoiceHeaderCardArrow">▾</span>
                                </button>

                            </div>
                        </div>

                        <div id="InvoiceHeaderCardCollapse" class="collapse show">
                            <div class="card-body">

                                <div class="row g-3 align-items-end">

                                    <div class="col-lg-1 col-md-2">
                                        <label class="form-label form-label-sm">كود المورد</label>

                                        <input id="CustomerCodeDisplay"
                                               class="form-control form-control-sm text-center invoice-small-input"
                                               type="number" data-lock-posted="1"  />

                                        <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                                    </div>

                                    <div class="col-lg-3 col-md-3">
                                        <label for="CustomerNameInput" class="form-label form-label-sm">اسم المورد</label>

                                        <input id="CustomerNameInput"
                                               name="CustomerNameInput"
                                               class="form-control form-control-sm"
                                               placeholder="اكتب اسم المورد ثم اختره من القائمة"
                                               list="customersList"
                                               autocomplete="off"
                                               value="@ViewBag.SelectedCustomerName" 
                                               data-lock-posted="1" 
                                                />

                                        <datalist id="customersList">
                                            @if (ViewBag.Customers != null)
                                            {
                                                foreach (var c in ViewBag.Customers)
                                                {
                                                    <option value="@c.Name"
                                                            data-id="@c.Id"
                                                            data-phone="@c.Phone"
                                                            data-address="@c.Address"
                                                            data-gov="@c.Gov"
                                                            data-district="@c.District"
                                                            data-area="@c.Area"
                                                            data-credit="@c.Credit">
                                                    </option>
                                                }
                                            }
                                        </datalist>
                                    </div>

                                    <div class="col-lg-3 col-md-2">
                                        <label class="form-label form-label-sm">رقم الفاتورة</label>

                                        <input type="hidden"
                                               id="InvoiceId"
                                               value="@(Model?.PIId ?? 0)" />

                                        <input id="InvoiceNumberDisplay"
                                               class="form-control form-control-sm text-center"
                                               value="@(Model != null && Model.PIId > 0 ? Model.PIId.ToString() : "")"
                                               readonly 
                                               />
                                    </div>

                                    <div class="col-lg-3 col-md-6">
                                        <div class="row g-2">
                                            <div class="col-6">
                                                <label class="form-label form-label-sm">تاريخ الفاتورة</label>
                                                <input id="InvoiceDateDisplay"
                                                       class="form-control form-control-sm text-center"
                                                       value="@invoiceDateText"
                                                       readonly />
                                            </div>
                                            <div class="col-6">
                                                <label class="form-label form-label-sm">وقت الإنشاء</label>
                                                <input id="InvoiceTimeDisplay"
                                                       class="form-control form-control-sm text-center"
                                                       value="@invoiceTimeText"
                                                       readonly />
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <br />

                                <input type="hidden" asp-for="Status" id="InvoiceStatusHidden" />

                                <div class="row g-3">

                                    <div class="col-lg-3 col-md-6 col-sm-12">
                                        <label class="form-label form-label-sm">حالة الفاتورة</label>
                                        <input id="InvoiceIsPostedDisplay"
                                               class="form-control form-control-sm text-center"
                                               value="@(string.IsNullOrWhiteSpace(Model.Status) ? "غير مرحلة" : Model.Status)"
                                               readonly />
                                    </div>

                                    <div class="col-lg-3 col-md-6 col-sm-12">
                                        <label class="form-label form-label-sm">طلب الشراء المرجعي</label>
                                        <input class="form-control form-control-sm text-center"
                                               value="@(Model.RefPRId?.ToString() ?? "")"
                                               readonly />
                                    </div>

                                    <div class="col-lg-3 col-md-6 col-sm-12">
                                        <label class="form-label form-label-sm" for="WarehouseId">المخزن</label>
                                        <select asp-for="WarehouseId"
                                                asp-items="ViewBag.Warehouses"
                                                class="form-select form-select-sm" 
                                                data-is-posted="@(Model.IsPosted ? "1" : "0")">
                                            <option value="">اختر المخزن</option>
                                        </select>
                                    </div>

                                    <div class="col-lg-3 col-md-6 col-sm-12">
                                        <label class="form-label form-label-sm">كاتب الفاتورة</label>
                                        <input id="InvoiceCreatedByDisplay"
                                               class="form-control form-control-sm text-center"
                                               value="@Model.CreatedBy"
                                               readonly 
                                               />
                                    </div>

                                </div>

                                <div class="row g-4">
                                    <div class="col-lg-3 col-md-3">
                                        <label class="form-label form-label-sm">الهاتف</label>
                                        <input id="CustomerPhone"
                                               class="form-control form-control-sm"
                                               value="@(
                                               Model?.Customer?.Phone1
                                               ?? Model?.Customer?.Phone2
                                               ?? Model?.Customer?.Whatsapp
                                               ?? ""
                                                              )"
                                               readonly 
                                               />
                                    </div>

                                    <div class="col-lg-3 col-md-3">
                                        <label class="form-label form-label-sm">المحافظة</label>
                                        <input id="CustomerGovernorate"
                                               class="form-control form-control-sm"
                                               value="@(Model?.Customer?.Governorate?.GovernorateName ?? "")"
                                               readonly 
                                               />
                                    </div>

                                    <div class="col-lg-3 col-md-3">
                                        <label class="form-label form-label-sm">الحي</label>
                                        <input id="CustomerDistrict"
                                               class="form-control form-control-sm"
                                               value="@(Model?.Customer?.District?.DistrictName ?? "")"
                                               readonly 
                                               />
                                    </div>

                                    <div class="col-lg-3 col-md-3">
                                        <label class="form-label form-label-sm">المنطقة</label>
                                        <input id="CustomerArea"
                                               class="form-control form-control-sm"
                                               value="@(Model?.Customer?.Area?.AreaName ?? "")"
                                               readonly 
                                               />
                                    </div>

                                </div>

                                <div class="row g-3">

                                    <div class="col-lg-8 col-md-6">
                                        <label class="form-label form-label-sm">العنوان</label>
                                        <input id="CustomerAddress"
                                               class="form-control form-control-sm"
                                               value="@(Model?.Customer?.Address ?? "")"
                                               readonly 
                                               data-lock-posted="1"/>
                                    </div>

                                    <div class="col-lg-4 col-md-2">
                                        <label class="form-label form-label-sm">الحد الإتماني</label>
                                        <input id="CustomerCredit"
                                               class="form-control form-control-sm"
                                               value="@((Model?.Customer?.CreditLimit ?? 0m).ToString("0.##"))"
                                               readonly 
                                               data-lock-posted="1" />
                                    </div>



                            </div>
                        </div>
                    </div>

                    @* =====================================================
                       2) كارت بيانات الصنف
                       ===================================================== *@
                    <div class="card shadow-sm mb-3 invoice-product-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">بيانات الصنف</h6>
                            <button type="button"
                                    class="btn btn-sm btn-light"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#ProductCardCollapse"
                                    aria-expanded="true"
                                    aria-controls="ProductCardCollapse">
                                <span id="ProductCardArrow">▾</span>
                            </button>
                        </div>

                        <div id="ProductCardCollapse" class="collapse show">
                            <div class="card-body">

                                <div class="row g-2 mb-3">
                                    <div class="col-md-3 col-sm-6">
                                        <label class="form-label form-label-sm">الكمية في هذا المخزن</label>
                                        <input type="text" id="ProdQtyCurrentWarehouse"
                                               class="form-control form-control-sm text-center" value="0" readonly />
                                    </div>

                                    <div class="col-md-3 col-sm-6">
                                        <label class="form-label form-label-sm">إجمالي الكمية في كل المخازن</label>
