             // =========================================================
            // اختيار سطر من جدول السطور (Click Row)
            // - عند الضغط على أي سطر: تعبئة بياناته في الحقول العلوية
            // - لازم يكون الصف فيه data-prodid
            // =========================================================
            document.addEventListener('click', function (e) {

                // متغير: الصف الذي تم الضغط عليه داخل tbody
                const row = e.target.closest('#PILinesTbody tr[data-prodid]');
                if (!row) return;

                // حماية: لو الضغط على زر (مسح) أو أي زر داخل السطر لا نختار السطر
                if (e.target.closest('.btnRemoveProductFromInvoice') ||
                    e.target.closest('.btnRemoveLineFromInvoice') ||
                    e.target.closest('button') ||
                    e.target.closest('a')) {
                    return;
                }

                // 1) تمييز الصف المختار
                const tbody = document.getElementById('PILinesTbody');
                if (tbody) {
                    tbody.querySelectorAll('tr.pi-row-selected')
                        .forEach(r => r.classList.remove('pi-row-selected'));
                }
                row.classList.add('pi-row-selected');

                // 2) قراءة ProdId من data-prodid
                const prodId = (row.getAttribute('data-prodid') || '').trim();
                if (!prodId) return;




                        // =========================================================
            // (3) ✅ تعبئة بيانات السطر في الحقول العلوية (باستخدام IDs الحقيقية من Show.cshtml)
            // =========================================================

            // متغيرات: الحقول العلوية
            const ProdIdEl       = document.getElementById('ProdId');         // متغير: hidden ProdId
            const ProdNameEl     = document.getElementById('ProdNameInput');  // متغير: اسم الصنف (بحث)
            const ProdCodeEl     = document.getElementById('ProdCodeInput');  // متغير: كود الصنف
            const ProdBatchEl    = document.getElementById('ProdBatchInput'); // متغير: التشغيلة
            const ProdExpiryEl   = document.getElementById('ProdExpiryInput');// متغير: الصلاحية (MM/YYYY)
            const ProdQtyEl      = document.getElementById('ProdQtyInput');   // متغير: الكمية
            const ProdPriceEl    = document.getElementById('ProdPriceInput'); // متغير: سعر الجمهور
            const ProdDiscEl     = document.getElementById('ProdDisc1Input'); // متغير: الخصم

            // دالة صغيرة: تكتب قيمة وتطلق input/change (علشان أي كود مرتبط بالحسابات يشتغل)
            function setVal(el, value) {
                if (!el) return;
                el.value = value ?? '';
                el.dispatchEvent(new Event('input', { bubbles: true }));
                el.dispatchEvent(new Event('change', { bubbles: true }));
            }

            // 1) تعبئة الـ ProdId + الكود
            setVal(ProdIdEl, prodId);
            setVal(ProdCodeEl, prodId);

            // 2) جلب اسم الصنف من الخلية الثانية (فيها strong)
            let prodName = '';
            const nameStrong = row.querySelector('td:nth-child(2) strong');
            if (nameStrong) prodName = (nameStrong.innerText || '').trim();
            if (!prodName) prodName = (row.cells[1]?.innerText || '').trim(); // fallback

            setVal(ProdNameEl, prodName);

            // 3) لو السطر "تجميعي" (Multi-Batch) => نملأ الاسم/الكود فقط ونفضي باقي الحقول
            const isGroupRow = row.classList.contains('pi-group-row');
            if (isGroupRow) {
                setVal(ProdBatchEl, '');
                setVal(ProdExpiryEl, '');
                setVal(ProdQtyEl, '');
                setVal(ProdDiscEl, '');
                // السعر ممكن نسيبه كما هو أو نفضيه، أنا سيبته كما هو حفاظًا على المدخلات
                if (ProdNameEl) ProdNameEl.focus();
                return;
            }

            // 4) قراءة بقية القيم من أعمدة الجدول (حسب ترتيب Show.cshtml عندك)
            // الأعمدة: 0 رقم السطر، 1 الاسم، 2 التشغيلة، 3 الصلاحية yyyy-MM-dd، 4 الكمية، 5 السعر، 6 الخصم
            const batchText = (row.cells[2]?.innerText || '').trim();
            const expRaw    = (row.cells[3]?.innerText || '').trim();
            const qtyText   = (row.cells[4]?.innerText || '').trim();
            const priceText = (row.cells[5]?.innerText || '').trim();
            const discText  = (row.cells[6]?.innerText || '').trim();

            // 5) تحويل الصلاحية من yyyy-MM-dd إلى MM/YYYY
            let expMMYYYY = expRaw;
            if (expRaw && expRaw.includes('-')) {
                const parts = expRaw.split('-'); // [yyyy, MM, dd]
                if (parts.length >= 2) expMMYYYY = `${parts[1]}/${parts[0]}`;
            }

            // 6) تعبئة باقي الحقول
            setVal(ProdBatchEl, batchText);
            setVal(ProdExpiryEl, expMMYYYY);
            setVal(ProdQtyEl, qtyText);
            setVal(ProdPriceEl, priceText);
            setVal(ProdDiscEl, discText);

            // 7) فوكس سريع على الكمية لسهولة التعديل
                        if (prodName) prodName.focus();

            });













            // =========================================================
            // سكربت زر: مسح جميع أصناف الفاتورة (AJAX)
            // - نفس منطق RemoveLineJson: Token + Guard + رسالة
            // =========================================================
            document.addEventListener("DOMContentLoaded", function () {

                            const btnClearAll = document.getElementById("btnClearInvoiceLines"); // متغير: زر مسح كل الأصناف (غيّر الـ id لو مختلف عندك)
                const msg = document.getElementById("postInvoiceMsg");           // متغير: صندوق الرسائل

                if (!btnClearAll) return;

                // ✅ ربط مرة واحدة
                if (btnClearAll.dataset.boundClearAll) return;
                btnClearAll.dataset.boundClearAll = "1";

                btnClearAll.type = "button";

                let busy = false; // متغير: منع الضغط المتكرر

                // دالة: جلب AntiForgeryToken من الصفحة
                function getAntiForgeryToken() {
                    return document.querySelector('input[name="__RequestVerificationToken"]')?.value || "";
                }

                // دالة: قراءة رسالة خطأ مرة واحدة
                async function readErrorMessage(res) {
                    const raw = await res.text();
                    try {
                        const obj = JSON.parse(raw);
                        if (obj && obj.message) return obj.message;
                    } catch { }
                    return raw || "حدث خطأ غير معروف.";
                }

                btnClearAll.addEventListener("click", async function () {

                    if (busy) return;
                    if (btnClearAll.disabled) return;

                    // ✅ اقرأ رقم الفاتورة وقت الضغط
                    const invoiceId = parseInt((document.getElementById("InvoiceId")?.value || "0"), 10) || 0;

                    if (invoiceId <= 0) {
                        if (msg) {
                            msg.textContent = "⚠️ لا يمكن مسح الأصناف قبل حفظ الفاتورة.";
                            msg.className = "small mt-2 text-warning";
                        }
                        return;
                    }

                    // ✅ منع المسح لو الفاتورة مُرحّلة (نفس سياسة البرنامج)
                    if (typeof isInvoicePosted === "function" && isInvoicePosted()) {
                        if (msg) {
                            msg.textContent = "الفاتورة مُرحّلة ومقفولة. استخدم زر (فتح الفاتورة) أولاً.";
                            msg.className = "small mt-2 text-danger";
                        }
                        return;
                    }

                    const ok = confirm("هل تريد مسح جميع الأصناف من الفاتورة؟");
                    if (!ok) return;

                    busy = true;
                    const oldHtml = btnClearAll.innerHTML;
                    btnClearAll.disabled = true;
                    btnClearAll.innerHTML = "⏳ جاري المسح...";

                    if (msg) {
                        msg.textContent = "جاري مسح جميع الأصناف...";
                        msg.className = "small mt-2 text-muted";
                    }

                    try {

                        const dto = { PIId: invoiceId }; // ✅ نفس اسم الخاصية في DTO

                        const res = await fetch(`/PurchaseInvoices/ClearAllLinesJson`, {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                                "RequestVerificationToken": getAntiForgeryToken(), // ✅ نفس ValidateAntiForgeryToken
                                "X-Requested-With": "XMLHttpRequest"
                            },
                            body: JSON.stringify(dto),
                            credentials: "same-origin"
                        });

                        if (!res.ok) {
                            const errText = await readErrorMessage(res);
                            throw new Error(errText);
                        }

                        const data = await res.json();

                        if (!data || !data.ok) {
                            throw new Error((data && data.message) ? data.message : "تعذر مسح الأصناف.");
                        }

                        // ✅ إعادة رسم السطور (بنفس فلسفة RemoveLineJson)
                        if (typeof renderGroupedLines === "function") {
                            renderGroupedLines(data.lines || []);
                        } else {
                            // لو مفيش ريندر موجود عندك: Reload كحل مضمون
                            location.reload();
                            return;
                        }

                        // ✅ تحديث الإجماليات لو عندك دالة (اختياري)
                        // لو عندك نفس دالة تحديث totals المستخدمة بعد حذف سطر واحد، نادِيها هنا
                        // مثال:
                        // if (typeof applyTotals === "function" && data.totals) applyTotals(data.totals);

                        if (msg) {
                            msg.textContent = data.message || "تم مسح جميع الأصناف.";
                            msg.className = "small mt-2 text-success";
                        }

                    } catch (err) {

                        btnClearAll.disabled = false;
                        btnClearAll.innerHTML = oldHtml;

                        if (msg) {
                            msg.textContent = "فشل مسح الأصناف: " + (err.message || "خطأ غير معروف");
                            msg.className = "small mt-2 text-danger";
                        }

                    } finally {
                        busy = false;
                        btnClearAll.disabled = false;
                        btnClearAll.innerHTML = oldHtml;
                    }
                });
            });







