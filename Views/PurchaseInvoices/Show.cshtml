                                                        <td class="text-center">@line.PriceRetail.ToString("0.00")</td>

                                                        <td class="text-center">@line.PurchaseDiscountPct.ToString("0.##")</td>

                                                        <td class="text-center">@lineValue.ToString("0.00")</td>

                                                    <td class="text-center no-print">
                                                            <button type="button"
                                                                    class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                                                        data-line-no="@line.LineNo" data-lock-posted="1">
                                                                مسح
                                                            </button>
                                                     </td>
                                                 </tr>
                                                }
                                                else
                                                {
                                                    <tr class="table-light pi-group-row" data-prodid="@g.Key.ProdId">
                                                        <td class="text-center">—</td>

                                                        <td>
                                                            <strong>@g.Key.ProdName</strong>
                                                            <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                        </td>

                                                        <td class="text-center text-muted small">تشغيلات: @batchCount</td>
                                                        <td class="text-center"></td>
                                                        <td class="text-center"></td>
                                                        <td class="text-center"></td>
                                                        <td class="text-center"></td>
                                                        <td class="text-center"></td>
                                                        <td class="text-center"></td>
                                                    </tr>

                                                    foreach (var line in g.OrderBy(x => x.LineNo))
                                                    {
                                                        decimal lineValue =
                                                        line.Qty * line.PriceRetail * (1m - (line.PurchaseDiscountPct / 100m));

                                                        <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                            <td class="text-center">@line.LineNo</td>
                                                            <td class="text-muted small">↳</td>
                                                            <td class="text-center">@line.BatchNo</td>
                                                            <td class="text-center">
                                                                @(line.Expiry.HasValue? line.Expiry.Value.ToString("yyyy-MM-dd") : "")
                                                            </td>
                                                            <td class="text-center">@line.Qty</td>
                                                            <td class="text-center">@line.PriceRetail.ToString("0.00")</td>
                                                            <td class="text-center">@line.PurchaseDiscountPct.ToString("0.##")</td>
                                                            <td class="text-center">@lineValue.ToString("0.00")</td>
                                                        <td class="text-center no-print" ">
                                                                <button type="button"
                                                                        class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                                                        data-line-no="@line.LineNo">
                                                                    مسح
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
