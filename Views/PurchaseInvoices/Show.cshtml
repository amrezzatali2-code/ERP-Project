@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.PurchaseInvoice

@{
    // عنوان التاب
    ViewData["Title"] = Model.PIId == 0
        ? "فاتورة مشتريات جديدة"
        : $"فاتورة مشتريات — رقم {Model.PIId}";
}

@section Styles {
    <style>

/* =========================================================
   إخفاء أسهم الـ Number Inputs (علشان الشكل ما يتلخبطش)
   - مهم عند فك readonly لأن الأسهم بتظهر وتغيّر شكل السطر
   ========================================================= */
.pi-input[type="number"]::-webkit-outer-spin-button,
.pi-input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}
.pi-input[type="number"] {
    -moz-appearance: textfield;
}


        /* خلفية عامة للصفحة */
        .invoice-page {
            background-color: #f3f6fb; /* لون خفيف مريح للعين */
            min-height: 100vh;
            padding-bottom: 2rem;
        }

        /* الكروت الرئيسية (الهيدر + تفاصيل + إدخال صنف + بيانات الصنف + السطور + الإجماليات + الكارت الجانبي) */
        .invoice-header-card,
        .invoice-details-card,
        .invoice-lines-card,
        .invoice-totals-card,
        .invoice-side-card,
        .invoice-Add-card,
        .invoice-product-card {
            border-radius: 1rem;
            overflow: hidden;
        }


        /* =========================================================
           تثبيت شريط الأزرار أعلى الشاشة أثناء التمرير (Sticky)
           - سريع: لا يغير أي منطق، مجرد CSS
           - frame=1 داخل التابات: يثبت أعلى الـ iframe (top:0)
           - بدون frame: يترك مسافة بسيطة لتفادي تغطية أي شريط علوي
           ========================================================= */
        .invoice-actions-bar {
            position: sticky;
            top: 0; /* داخل التاب/iframe ممتاز */
            z-index: 1050; /* فوق الجداول والكروت */
            background: rgba(243, 246, 251, 0.96);
            backdrop-filter: blur(6px);
            padding: .5rem;
            border-radius: .75rem;
            border: 1px solid rgba(0,0,0,.06);
            box-shadow: 0 6px 18px rgba(0,0,0,.08);
        }

     


        /* شريط الهيدر الملون للهيدر الرئيسي */
        .invoice-header-bar {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.75rem 1.25rem;
        }

            .invoice-header-bar h5 {
                margin-bottom: 0.1rem;
            }

        /* نفس لون الهيدر لباقي الكروت */
        .invoice-details-card .card-header,
        .invoice-Add-card .card-header,
        .invoice-product-card .card-header,
        .invoice-lines-card .card-header,
        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.55rem 1rem;
        }

        .invoice-status-badge {
            font-size: 0.8rem;
            padding: 0.3rem 0.7rem;
        }

        .badge-status-draft {
            background-color: #6f42c1; /* بنفسجي لمسودة */
        }

        .badge-status-notposted {
            background-color: #343a40; /* غامق لعدم الترحيل */
        }

        .form-label-sm {
            font-size: 0.85rem;
        }

        .invoice-small-input {
            max-width: 150px;
        }

        .customer-summary-line {
            font-size: 0.82rem;
        }

        /* كارت الإجراءات الجانبية: أزرار أرفع شوية */
        .invoice-side-card .btn-erp {
            font-size: 0.85rem;
            padding: 0.35rem 0.6rem;
        }

            .invoice-side-card .btn-erp + .btn-erp {
                margin-top: 0.25rem;
            }

        /* هيدر جدول السطور */
        .invoice-lines-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #fff;
        }

            .invoice-lines-header th {
                border-color: #0b5ed7 !important;
            }

        .erp-table-wrapper {
            max-height: 360px;
            overflow: auto;
        }

        .summary-badge {
            min-width: 80px;
            text-align: center;
        }
    </style>
}

<div class="invoice-page" dir="rtl">
    <div class="container-fluid pt-3">
        @* فورم مخفي لتوليد Anti-Forgery Token لاستخدامه في نداءات AJAX *@
        <form id="__AntiForgeryForm" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>



             @* =========================
               العمود الجانبي (أزرار الحركة)
               ========================= *@
        <div class="invoice-actions-bar d-flex flex-wrap gap-2 justify-content-end mb-3">



            @{
    // متغيرات: أرقام التنقل (قد تكون null)
    int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
    int? navLast  = ViewBag.NavLastId  == null ? (int?)null : (int)ViewBag.NavLastId;
    int? navPrev  = ViewBag.NavPrevId  == null ? (int?)null : (int)ViewBag.NavPrevId;
    int? navNext  = ViewBag.NavNextId  == null ? (int?)null : (int)ViewBag.NavNextId;

    // متغير: رقم الفاتورة الحالية
    int currentId = Model.PIId;
}

@* =========================================================
   شريط تنقل سريع (أسهم + بحث برقم الفاتورة)
   - يعمل فقط إذا كانت الفاتورة محفوظة (PIId > 0)
   - لا يفتح تابات جديدة، فقط ينتقل داخل نفس شاشة Show
   ========================================================= *@
<div class="d-flex flex-wrap align-items-center gap-1 me-auto">

    @* أول فاتورة *@
    @if (currentId > 0 && navFirst.HasValue && navFirst.Value != currentId)
    {
        <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
           asp-action="Show"
           asp-route-id="@navFirst.Value"
           asp-route-frame="1">⏮</a>
    }
    else
    {
        <button class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>⏮</button>
    }

    @* الفاتورة السابقة *@
    @if (currentId > 0 && navPrev.HasValue)
    {
        <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
           asp-action="Show"
           asp-route-id="@navPrev.Value"
           asp-route-frame="1">◀</a>
    }
    else
    {
        <button class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>◀</button>
    }

    @* الفاتورة التالية *@
    @if (currentId > 0 && navNext.HasValue)
    {
        <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
           asp-action="Show"
           asp-route-id="@navNext.Value"
           asp-route-frame="1">▶</a>
    }
    else
    {
        <button class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>▶</button>
    }

    @* آخر فاتورة *@
    @if (currentId > 0 && navLast.HasValue && navLast.Value != currentId)
    {
        <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
           asp-action="Show"
           asp-route-id="@navLast.Value"
           asp-route-frame="1">⏭</a>
    }
    else
    {
        <button class="btn btn-erp btn-erp-outline-primary btn-erp-sm" disabled>⏭</button>
    }

    @* بحث برقم الفاتورة *@
   <form method="get"
      asp-action="Show"
      class="d-flex align-items-center gap-1 open-tab"
      data-tab-id="pi-show-tab"
      data-tab-title="فاتورة المشتريات">

    <input type="hidden" name="frame" value="1" />

    <input type="number"
           name="id"
           class="form-control form-control-sm"
           placeholder="رقم فاتورة..." />

    <button type="submit"
            class="btn btn-erp btn-erp-outline-primary btn-erp-sm">
        بحث
    </button>
</form>

</div>

            

<a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab"
   data-tab-id="pi-show-tab"
   data-tab-title="فاتورة المشتريات"
   data-url="@Url.Action("Create", "PurchaseInvoices", new { frame = 1 })">
    ➕ فاتورة جديدة
</a>


                    @* زر حفظ الفاتورة في جدول الهيدر *@
                    <button type="button"
                            class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                            id="btnSaveInvoiceHeader">
                        💾 حفظ الفاتورة
                    </button>


                    <button type="button"
                            class="btn btn-erp btn-erp-outline-danger btn-erp-sm"
                            id="btnClearInvoiceLines"
                            data-invoice-id="@Model.PIId">
                        🗑️ مسح كل أصناف الفاتورة
                    </button>

                    <button type="button"
                            class="btn btn-erp btn-erp-outline-primary btn-erp-sm">
                        ⏪ فتح الفاتورة
                    </button>

                    <a class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                       asp-action="Edit"
                       asp-route-id="@Model.PIId">
                        ✏️ تعديل الفاتورة
                    </a>

                    <button type="button"
                            class="btn btn-erp btn-erp-outline-primary btn-erp-sm">
                        📤 ترحيل الفاتورة
                    </button>

                    <button type="button"
                            class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                            onclick="window.print();">
                        🖨️ طباعة الفاتورة
                    </button>

                </div>   @* card-body *@


            </div>   @* col-lg-2 *@

        <div class="row g-3">


          


                        @* =========================
                         العمود الرئيسي (الهيدر + المورد + الأصناف + الإجماليات)
                             ========================= *@
            <div class="col-lg-12">



            <div class="row g-3">
                @* الكارت الأول: بيانات الفاتورة *@
                <div class="col-12 col-lg-6">
                    <div class="card shadow-sm">
                        <!-- هنا محتوى الكارت الأول بالكامل كما هو بدون تغيير -->
                    </div>
                </div>

                  @* الكارت الثاني: بيانات الصنف *@
                <div class="col-12 col-lg-6">
                     <div class="card shadow-sm">
                    <!-- هنا محتوى الكارت الثاني بالكامل كما هو بدون تغيير -->
                     </div>
                </div>


            </div>


                         @* ====================================================
                          1) كارت بيانات فاتورة المشتريات + المورد + المخزن
                             ==================================================== *@
               <div class="card shadow-sm mb-2 invoice-header-card">

    @{
        bool isNewInvoice = Model == null || Model.PIId == 0;
        bool hasInvoice = !isNewInvoice;

        string invoiceDateText = hasInvoice
        ? Model.PIDate.ToString("yyyy/MM/dd")
        : "";

        // نستخدم CreatedAt لعرض وقت إنشاء الفاتورة
        string invoiceTimeText = hasInvoice
        ? Model.CreatedAt.ToLocalTime().ToString("HH:mm")
        : "";
    }

    <div class="invoice-header-bar d-flex justify-content-between align-items-center flex-wrap gap-2">

        @* الجزء الأيسر: عنوان الفاتورة + كاتب الفاتورة *@
        <div>
            <h5 class="mb-1">فاتورة مشتريات</h5>

            <div class="small opacity-100">
                كاتب الفاتورة:
                <span class="fw-semibold">
                    @(
                        !string.IsNullOrWhiteSpace(Model.CreatedBy)
                        ? Model.CreatedBy
                        : "غير محدد"
                    )
                </span>
            </div>
        </div>

        @* الجزء الأيمن: رسالة بسيطة حسب الحالة + زر الطي *@
        <div class="d-flex align-items-center gap-2">

            <div class="text-end">
                @if (isNewInvoice)
                {
                    @* فاضي كما هو *@
                }
                else
                {
                    <span class="text-white fw-semibold">
                        فاتورة مشتريات مسجَّلة
                    </span>
                }
            </div>

            @* زر سهم: طي/فتح جسم الكارت (نفس ستايل الزر الأول) *@
            <button type="button"
                    class="btn btn-sm btn-light"
                    data-bs-toggle="collapse"
                    data-bs-target="#InvoiceHeaderCardCollapse"
                    aria-expanded="true"
                    aria-controls="InvoiceHeaderCardCollapse"
                    title="طي/فتح">
                <span id="InvoiceHeaderCardArrow">▾</span>
            </button>

        </div>
    </div>

    @* جسم الكارت الذي سيتم طيه *@
    <div id="InvoiceHeaderCardCollapse" class="collapse show">

        <div class="card-body">

            <div class="row g-3 align-items-end">

                @* كود المورد *@
                <div class="col-lg-2 col-md-3">
                    <label class="form-label form-label-sm">كود المورد</label>

                    @* ملاحظة: هذا البوكس للعرض/البحث فقط (نملأه من الـ datalist).
                       الكود الحقيقي الذي يُحفظ في الفاتورة موجود في الحقل المخفي CustomerId *@
                    <input id="CustomerCodeDisplay"
                           class="form-control form-control-sm text-center invoice-small-input"
                           type="number" />

                    @* هذا هو الحقل الفعلي الذي يُحفظ في الفاتورة *@
                    <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                </div>

                @* اسم المورد + أوتوكومبليت *@
                <div class="col-lg-4 col-md-6">
                    <label for="CustomerNameInput" class="form-label form-label-sm">اسم المورد</label>

                    @* بوكس اسم المورد مع أوتوكومبليت من الـ datalist *@
                    <input id="CustomerNameInput"
                           name="CustomerNameInput" @* متغير: يستخدمه الجافاسكربت فقط، غير مربوط بالموديل *@
                           class="form-control form-control-sm"
                           placeholder="اكتب اسم المورد ثم اختره من القائمة"
                           list="customersList"
                           autocomplete="off"
                           value="@ViewBag.SelectedCustomerName" />

                    @* قائمة العملاء/الموردين لأوتوكومبليت اسم المورد *@
                    <datalist id="customersList">
                        @if (ViewBag.Customers != null)
                        {
                            foreach (var c in ViewBag.Customers)
                            {
                                <option value="@c.Name"
                                        data-id="@c.Id"
                                        data-phone="@c.Phone"
                                        data-address="@c.Address"
                                        data-gov="@c.Gov"
                                        data-district="@c.District"
                                        data-area="@c.Area"
                                        data-credit="@c.Credit">
                                </option>
                            }
                        }
                    </datalist>
                </div>

                @* رقم الفاتورة - يظهر في الصف الأول بدلاً من المخزن *@
                <div class="col-lg-3 col-md-2">
                    <label class="form-label form-label-sm">رقم الفاتورة</label>

                    @* حقل مخفي يحتفظ برقم الفاتورة لاستخدامه لاحقاً في الجافاسكربت *@
                    <input type="hidden"
                           id="InvoiceId" @* متغير: رقم الفاتورة الداخلي (0 = فاتورة جديدة) *@
                           value="@(Model?.PIId ?? 0)" />

                    @* بوكس للعرض فقط (ReadOnly) لرقم الفاتورة *@
                    <input id="InvoiceNumberDisplay" @* متغير: يعرض رقم الفاتورة للمستخدم *@
                           class="form-control form-control-sm text-center"
                           value="@(Model != null && Model.PIId > 0 ? Model.PIId.ToString() : "")"
                           readonly />
                </div>

                @* التاريخ والوقت *@
                <div class="col-lg-3 col-md-6">
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label form-label-sm">تاريخ الفاتورة</label>
                            <input id="InvoiceDateDisplay" @* متغير: يعرض تاريخ الفاتورة *@
                                   class="form-control form-control-sm text-center"
                                   value="@invoiceDateText"
                                   readonly />
                        </div>
                        <div class="col-6">
                            <label class="form-label form-label-sm">وقت الإنشاء</label>
                            <input id="InvoiceTimeDisplay" @* متغير: يعرض وقت إنشاء الفاتورة *@
                                   class="form-control form-control-sm text-center"
                                   value="@invoiceTimeText"
                                   readonly />
                        </div>
                    </div>
                </div>

            </div>

            <br />

            @* حقل مخفي: حالة الفاتورة النصية (Draft / Posted / Cancelled ...)
               يخص منطق الموديل فقط ولا يظهر للمستخدم *@
            <input type="hidden"
                   asp-for="Status"
                   id="InvoiceStatusHidden" />

            <div class="row g-3">

                @* بوكس واحد فقط لعرض هل الفاتورة مُرحَّلة أم لا *@
                <div class="col-lg-3 col-md-6 col-sm-12">
                    <label class="form-label form-label-sm">مُرحَّلة؟</label>
                    <input id="InvoiceIsPostedDisplay" @* متغير: يعرض نعم/لا حسب الترحيل *@
                           class="form-control form-control-sm text-center"
                           value="@(Model.IsPosted ? "نعم" : "لا")"
                           readonly />
                </div>

                @* طلب الشراء المرجعي *@
                <div class="col-lg-3 col-md-6 col-sm-12">
                    <label class="form-label form-label-sm">طلب الشراء المرجعي</label>
                    <input class="form-control form-control-sm text-center"
                           value="@(Model.RefPRId?.ToString() ?? "")"
                           readonly />
                </div>

                @* المخزن *@
                <div class="col-lg-3 col-md-6 col-sm-12">
                    <label class="form-label form-label-sm" for="WarehouseId">المخزن</label>
                    <select asp-for="WarehouseId"
                            asp-items="ViewBag.Warehouses"
                            class="form-select form-select-sm">
                        <option value="">اختر المخزن</option>
                    </select>
                </div>

                @* كاتب الفاتورة *@
                <div class="col-lg-3 col-md-6 col-sm-12">
                    <label class="form-label form-label-sm">كاتب الفاتورة</label>
                    <input id="InvoiceCreatedByDisplay"
                           class="form-control form-control-sm text-center"
                           value="@Model.CreatedBy"
                           readonly />
                </div>

            </div>

            <div class="row g-4">
                <div class="col-lg-3 col-md-3">
                    <label class="form-label form-label-sm">الهاتف</label>
                    <input id="CustomerPhone"
                           class="form-control form-control-sm"
                           readonly />
                </div>

                <div class="col-lg-3 col-md-3">
                    <label class="form-label form-label-sm">المحافظة</label>
                    <input id="CustomerGovernorate"
                           class="form-control form-control-sm"
                           readonly />
                </div>

                <div class="col-lg-3 col-md-3">
                    <label class="form-label form-label-sm">الحي</label>
                    <input id="CustomerDistrict"
                           class="form-control form-control-sm"
                           readonly />
                </div>

                <div class="col-lg-3 col-md-3">
                    <label class="form-label form-label-sm">المنطقة</label>
                    <input id="CustomerArea"
                           class="form-control form-control-sm"
                           readonly />
                </div>
            </div>

            <div class="row g-3">

                <div class="col-lg-8 col-md-6">
                    <label class="form-label form-label-sm">العنوان</label>
                    <input id="CustomerAddress"
                           class="form-control form-control-sm"
                           readonly />
                </div>

                <div class="col-lg-4 col-md-2">
                    <label class="form-label form-label-sm">الحد الإتماني</label>
                    <input id="CustomerCredit"
                           class="form-control form-control-sm"
                           readonly />
                </div>
            </div>

        </div> @* نهاية card-body *@

    </div> @* نهاية collapse *@

</div>




                             @* =====================================================
                                 2) كارت بيانات الصنف من المخزون + سياسة شراء
                             ===================================================== *@
            <div class="card shadow-sm mb-3 invoice-product-card">

                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">بيانات الصنف</h6>

                    @* زر سهم: طي/فتح جسم الكارت *@
                    <button type="button"
                            class="btn btn-sm btn-light"
                            data-bs-toggle="collapse"
                            data-bs-target="#ProductCardCollapse"
                            aria-expanded="true"
                            aria-controls="ProductCardCollapse"
                            title="طي/فتح">
                        <span id="ProductCardArrow">▾</span>
                    </button>
                </div>

                @* جسم الكارت الذي سيتم طيه *@
                <div id="ProductCardCollapse" class="collapse show">
                    <div class="card-body">

                        @* الصف العلوي: أرقام سريعة عن مخزون الصنف *@
                        <div class="row g-2 mb-3">

                            @* الكمية المتاحة في المخزن المختار في الفاتورة *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الكمية في هذا المخزن</label>
                                <input type="text"
                                       id="ProdQtyCurrentWarehouse" @* متغير: كمية الصنف في المخزن الحالي *@
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            @* إجمالي الكمية في كل المخازن *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">إجمالي الكمية في كل المخازن</label>
                                <input type="text"
                                       id="ProdQtyAllWarehouses" @* متغير: مجموع الكميات في جميع المخازن *@
                                       class="form-control form-control-sm text-center"
                                       value="0"
                                       readonly />
                            </div>

                            @* هل الصنف عليه كوتة؟ *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الصنف عليه كوتة؟</label>
                                <input type="text"
                                       id="ProdQuotaText" @* متغير: نص يوضح حالة الكوتة *@
                                       class="form-control form-control-sm text-center"
                                       value="بدون كوتة"
                                       readonly />
                            </div>

                            @* الخصم المرجّح للصنف (من سياسة الشراء / حركة المخزون) *@
                            <div class="col-md-3 col-sm-6">
                                <label class="form-label form-label-sm">الخصم المرجّح للصنف %</label>
                                <input type="text"
