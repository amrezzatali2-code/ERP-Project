        // ===============================
        // رسم جدول السطور (هجين)
        // - لو الصنف غير مكرر: سطر واحد + بيانات + زر مسح
        // - لو الصنف مكرر (تشغيلات): سطر عنوان للصنف + سطور تشغيلات (بيانات + مسح لكل تشغيلة)
        // ===============================
        function renderGroupedLines(lines) {

            // متغير: tbody الخاص بجدول السطور
            const tbody = document.getElementById('PILinesTbody');
            if (!tbody) return;

            // تفريغ الجدول قبل الرسم
            tbody.innerHTML = '';

            // لو مفيش بيانات
            if (!Array.isArray(lines) || lines.length === 0) {
                tbody.innerHTML = `<tr><td colspan="9" class="text-center text-muted py-3">لا توجد سطور</td></tr>`;
                return;
            }

            // ===============================
            // 1) تجميع السطور حسب prodId + prodName
            // ===============================
            const map = new Map(); // متغير: Map لتجميع السطور

            lines.forEach(l => {
                const prodId = Number(l.prodId || 0); // متغير: كود الصنف
                const prodName = (l.prodName || (`صنف #${prodId}`)).toString(); // متغير: اسم الصنف
                const key = `${prodId}||${prodName}`; // متغير: مفتاح التجميع

                if (!map.has(key)) {
                    map.set(key, { prodId, prodName, lines: [] });
                }
                map.get(key).lines.push(l);
            });

            // ترتيب المجموعات بالاسم
            const groups = Array.from(map.values())
                .sort((a, b) => (a.prodName || '').localeCompare(b.prodName || '', 'ar'));

            // ===============================
            // 2) رسم كل مجموعة حسب عدد التشغيلات
            // ===============================
            groups.forEach(g => {

                // ترتيب تشغيلات الصنف حسب lineNo
                const sortedLines = (g.lines || [])
                    .slice()
                    .sort((x, y) => (Number(x.lineNo || 0) - Number(y.lineNo || 0)));

                const isMultiBatch = sortedLines.length > 1; // متغير: هل الصنف له أكثر من تشغيلة؟

                // =========================================================
                // الحالة (1): الصنف غير مكرر => سطر واحد فقط (اسم + بيانات + مسح)
                // =========================================================
                if (!isMultiBatch) {

                    const line = sortedLines[0];

                    const lineNo = line.lineNo ?? ''; // متغير: رقم السطر
                    const batchNo = line.batchNo ?? ''; // متغير: التشغيلة

                    const expiryText = line.expiryText
                        ? line.expiryText
                        : (line.expiry ? formatDateYMD(line.expiry) : ''); // متغير: الصلاحية

                    const qty = Number(line.qty || 0); // متغير: الكمية
                    const priceRetail = Number(line.priceRetail || 0); // متغير: سعر الجمهور

                    const discPct = (line.purchaseDiscountPct != null)
                        ? Number(line.purchaseDiscountPct)
                        : Number(line.discPct || 0); // متغير: الخصم %

                    const lineValue = (line.lineValue != null)
                        ? Number(line.lineValue)
                        : (qty * priceRetail * (1 - (discPct / 100))); // متغير: قيمة السطر

                    const tr = document.createElement('tr');
                    tr.setAttribute('data-line-no', lineNo);
                    tr.setAttribute('data-prodid', g.prodId);

                    tr.innerHTML = `
                        <td class="text-center">${lineNo}</td>

                        <td>
                            <strong>${escapeHtml(g.prodName)}</strong>
                            <span class="text-muted small"> | كود: ${g.prodId}</span>
                        </td>

                        <td class="text-center">${escapeHtml(batchNo)}</td>
                        <td class="text-center">${escapeHtml(expiryText)}</td>
                        <td class="text-center">${qty}</td>
                        <td class="text-center">${fmt2(priceRetail)}</td>
                        <td class="text-center">${fmt2(discPct)}</td>

                        <td class="text-center">${fmt2(lineValue)}</td>

                        <td class="text-center">
                            <button type="button"
                                    class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                    data-line-no="${lineNo}">
                                مسح
                            </button>
                        </td>
                    `;

                    tbody.appendChild(tr);
                    return;
                }

                // =========================================================
                // الحالة (2): الصنف مكرر => سطر عنوان للصنف + سطور تشغيلات تحته
                // =========================================================

                // (أ) سطر عنوان الصنف فقط (بدون بيانات وبدون زر مسح)
                const grpRow = document.createElement('tr');
                grpRow.className = 'table-light pi-group-row';
                grpRow.setAttribute('data-prodid', g.prodId);

                grpRow.innerHTML = `
                    <td class="text-center">—</td>

                    <td>
                        <strong>${escapeHtml(g.prodName)}</strong>
                        <span class="text-muted small"> | كود: ${g.prodId}</span>
                    </td>

                    <td class="text-center text-muted small">تشغيلات: ${sortedLines.length}</td>
                    <td class="text-center"></td>
                    <td class="text-center"></td>
                    <td class="text-center"></td>
                    <td class="text-center"></td>
                    <td class="text-center"></td>
                    <td class="text-center"></td>
                `;

                tbody.appendChild(grpRow);

                // (ب) سطور التشغيلات (كل تشغيلة = سطر بيانات + زر مسح)
                sortedLines.forEach(line => {

                    const lineNo = line.lineNo ?? ''; // متغير: رقم السطر
                    const batchNo = line.batchNo ?? ''; // متغير: التشغيلة

                    const expiryText = line.expiryText
                        ? line.expiryText
                        : (line.expiry ? formatDateYMD(line.expiry) : ''); // متغير: الصلاحية

                    const qty = Number(line.qty || 0); // متغير: الكمية
                    const priceRetail = Number(line.priceRetail || 0); // متغير: سعر الجمهور

                    const discPct = (line.purchaseDiscountPct != null)
                        ? Number(line.purchaseDiscountPct)
                        : Number(line.discPct || 0); // متغير: الخصم %

                    const lineValue = (line.lineValue != null)
                        ? Number(line.lineValue)
                        : (qty * priceRetail * (1 - (discPct / 100))); // متغير: قيمة السطر

                    const tr = document.createElement('tr');
                    tr.setAttribute('data-line-no', lineNo);
                    tr.setAttribute('data-prodid', g.prodId);

                    tr.innerHTML = `
                        <td class="text-center">${lineNo}</td>

                        <td class="text-muted small">↳</td>

                        <td class="text-center">${escapeHtml(batchNo)}</td>
                        <td class="text-center">${escapeHtml(expiryText)}</td>
                        <td class="text-center">${qty}</td>
                        <td class="text-center">${fmt2(priceRetail)}</td>
                        <td class="text-center">${fmt2(discPct)}</td>

                        <td class="text-center">${fmt2(lineValue)}</td>

                        <td class="text-center">
                            <button type="button"
                                    class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                    data-line-no="${lineNo}">
                                مسح
                            </button>
                        </td>
                    `;

                    tbody.appendChild(tr);

                    // ✅ نخلي الدالة Global عشان أي جزء في الصفحة يقدر ينادي عليها
                    window.renderGroupedLines = renderGroupedLines;
                });
            });
        }



        // ===============================
        // Helper: تنسيق تاريخ yyyy-MM-dd
        // ===============================
        function formatDateYMD(value) {
            try {
                const d = new Date(value);
                if (isNaN(d.getTime())) return '';
                const yyyy = d.getFullYear();
                const mm = String(d.getMonth() + 1).padStart(2, '0');
                const dd = String(d.getDate()).padStart(2, '0');
                return `${yyyy}-${mm}-${dd}`;
            } catch {
                return '';
            }
        }


                // ===============================
        // دالة: تحديث ملخص الفاتورة (البادجات)
        // ===============================
        function updateSummaryBadges(totals) {

            if (!totals) return;

            // دالة صغيرة: كتابة نص داخل عنصر لو موجود
            const setText = (id, value) => {
                const el = document.getElementById(id);
                if (el) el.textContent = value;
            };

            // =====================================
            // 1) قراءات مرنة من totals (اختلاف أسماء مفاتيح)
            // =====================================
            const totalLines = totals.totalLines ?? totals.linesCount ?? 0;     // متغير: عدد السطور
            const totalItems = totals.totalItems ?? totals.itemsCount ?? 0;     // متغير: عدد الأصناف
            const totalQty = totals.totalQty ?? totals.qtyTotal ?? 0;           // متغير: إجمالي الكمية
            const totalRetail = totals.totalRetail ?? totals.retailTotal ?? 0;  // متغير: إجمالي سعر الجمهور

            // متغير: إجمالي الخصم (لو السيرفر بيرجعه totalDiscount)
            const totalDiscount = totals.totalDiscount ?? totals.discountTotal ?? 0;

            // =====================================
            // 2) حساب الإجمالي بعد الخصم لو مش موجود
            // =====================================
            let totalAfterDiscount = totals.totalAfterDiscount;
            if (totalAfterDiscount == null) {
                totalAfterDiscount = Number(totalRetail || 0) - Number(totalDiscount || 0);
            }

            // =====================================
            // 3) الضريبة لو مش موجودة نخليها 0 (لحين ربطها لاحقاً)
            // =====================================
            let taxAmount = totals.taxAmount;
            if (taxAmount == null) taxAmount = 0;

            // =====================================
            // 4) الإجمالي بعد الخصم والضريبة + الصافي
            // =====================================
            let totalAfterDiscountAndTax = totals.totalAfterDiscountAndTax;
            if (totalAfterDiscountAndTax == null) {
                totalAfterDiscountAndTax = Number(totalAfterDiscount || 0) + Number(taxAmount || 0);
            }

            let netTotal = totals.netTotal;
            if (netTotal == null) {
                // حالياً الصافي = الإجمالي بعد الخصم والضريبة
                netTotal = Number(totalAfterDiscountAndTax || 0);
            }

            // =====================================
            // 5) تحديث العناصر على الصفحة (IDs كما هي)
            // =====================================
            setText('TotalLinesValue', totalLines);
            setText('TotalItemsValue', totalItems);
            setText('TotalQtyValue', totalQty);

            setText('TotalRetailValue', fmt2(totalRetail));
            setText('TotalAfterDiscountValue', fmt2(totalAfterDiscount));
            const taxInp = document.getElementById('TaxAmountInput');
if (taxInp) taxInp.value = fmt2(taxAmount);

            setText('TotalAfterDiscountAndTaxValue', fmt2(totalAfterDiscountAndTax));
            setText('NetTotalValue', fmt2(netTotal));
        }




                // =========================================================
        // Helpers عامة (Global) — علشان أي دالة تقدر تستخدمها بدون Errors
        // =========================================================

        // متغير/دالة: تحويل النص لرقم Decimal بأمان
        window.parseDecimalSafe = window.parseDecimalSafe || function (val) {
            const s = (val || '').toString().trim().replace(',', '.');
            const n = parseFloat(s);
            return isNaN(n) ? 0 : n;
        };

        // متغير/دالة: تنسيق رقم لرقمين عشريين
        window.fmt2 = window.fmt2 || function (val) {
            return window.parseDecimalSafe(val).toFixed(2);
        };

        // متغير/دالة: حماية النص قبل إدخاله في innerHTML
        window.escapeHtml = window.escapeHtml || function (text) {
            return (text ?? '').toString()
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        };






                // =========================================================
        // تثبيت الدالة في الـ Global Scope (حل نهائي لخطأ not defined)
        // =========================================================
        window.getAntiForgeryToken = window.getAntiForgeryToken || function () {

            // متغير: input الخاص بتوكن الحماية لو موجود في الصفحة
            const inp1 = document.querySelector('input[name="__RequestVerificationToken"]');
            if (inp1 && inp1.value) return inp1.value;

            // متغير: فورم التوكن المخفي (لو انت عامل فورم مخصص)
            const frm = document.getElementById('__AntiForgeryForm');
            if (!frm) return '';

            // متغير: input داخل الفورم المخفي
            const inp2 = frm.querySelector('input[name="__RequestVerificationToken"]');
            return inp2 ? (inp2.value || '') : '';
        };

        // =========================================================
        // Cache بسيط للسطور (علشان لو السيرفر رجّع line فقط)
        // =========================================================
        window.__piLinesCache = window.__piLinesCache || []; // متغير: آخر سطور مرسومة

        // =========================================================
        // دالة: فوكس بعد الإضافة على "اسم الصنف" (المطلوب منك)
        // =========================================================
        function focusOnProductName() {
            // متغير: حقل اسم الصنف
            const inp = document.getElementById('ProdNameInput');
            if (!inp) return;

            inp.focus();
            if (typeof inp.select === 'function') inp.select();
        }

             // =========================================================
        // إضافة سطر (AJAX) — مع حماية من أخطاء الدوال غير المعرفة
        // =========================================================
        async function addLineAjax() {

            // 1) لازم يكون عندنا رقم فاتورة محفوظ
            const invoiceIdInput = document.getElementById('InvoiceId'); // متغير: Hidden رقم الفاتورة
            const invoiceId = invoiceIdInput ? parseInt(invoiceIdInput.value || '0', 10) : 0;

            if (!invoiceId || invoiceId <= 0) {
                alert('لا يمكن إضافة أصناف قبل حفظ الفاتورة. اضغط "حفظ الفاتورة" أولاً.');
                document.getElementById('btnSaveInvoiceHeader')?.focus(); // متغير: زر حفظ الهيدر
                return;
            }

            // 2) قراءة بيانات السطر
            const prodId = prodHiddenId ? parseInt(prodHiddenId.value || '0', 10) : 0; // متغير: ProdId
            const qty = prodQtyInput ? parseInt(prodQtyInput.value || '0', 10) : 0;     // متغير: الكمية

            const priceRetail = prodPriceInput ? parseDecimalSafe(prodPriceInput.value) : 0; // متغير: سعر الجمهور
            const purchaseDiscountPct = prodDisc1Input ? parseDecimalSafe(prodDisc1Input.value) : 0; // متغير: خصم الشراء %

            const batchNo = prodBatchInput ? (prodBatchInput.value || '').trim() : '';       // متغير: التشغيلة
            const expiryText = prodExpiryInput ? (prodExpiryInput.value || '').trim() : '';  // متغير: الصلاحية

            // 3) تحقق قبل الإرسال
            if (!prodId || prodId <= 0) {
                alert('من فضلك اختر صنفاً صحيحاً من القائمة.');
                prodNameInput?.focus();
                prodNameInput?.select?.();
                return;
            }

            if (!qty || qty <= 0) {
                alert('الكمية يجب أن تكون أكبر من صفر.');
                prodQtyInput?.focus();
                prodQtyInput?.select?.();
                return;
            }

            // 4) تجهيز DTO
            const dto = {
                id: invoiceId,
                piId: invoiceId,
                invoiceId: invoiceId,

                prodId: prodId,
                qty: qty,

                unitCost: 0,
                priceRetail: priceRetail,
                purchaseDiscountPct: purchaseDiscountPct,

                batchNo: batchNo,
                expiryText: expiryText
            };

            // 5) استدعاء السيرفر
            const token = getAntiForgeryToken();

            if (btnAddLine) btnAddLine.disabled = true; // تعليق: منع الضغط المتكرر

            try {

                const resp = await fetch('@Url.Action("AddLineJson", "PurchaseInvoices")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(dto)
                });

                // لو السيرفر رجّع خطأ HTTP
                if (!resp.ok) {
                    const errTxt = await resp.text().catch(() => '');
                    console.error('AddLineJson HTTP Error:', resp.status, errTxt);
                    alert('حدث خطأ أثناء إضافة السطر (HTTP). راجع Console لمعرفة السبب.');
                    return;
                }

                // نقرأ الرد كنص ثم JSON (أكثر أماناً)
                const raw = await resp.text();
                const rawTrim = (raw || '').trim();

                if (rawTrim.startsWith('<')) {
                    console.error('AddLineJson رجّع HTML بدل JSON:', rawTrim.substring(0, 300));
                    alert('السيرفر رجّع HTML بدل JSON. راجع AddLineJson في الكنترولر.');
                    return;
                }

                let data = null; // متغير: بيانات الرد
                try {
                    data = rawTrim ? JSON.parse(rawTrim) : null;
                } catch (e) {
                    console.error('فشل تحويل الرد إلى JSON:', e, rawTrim.substring(0, 300));
                    alert('الرد من السيرفر ليس JSON.');
                    return;
                }

                // نجاح قد يكون ok أو success حسب السيرفر
                const isOk = !!(data && (data.ok === true || data.success === true));
                if (!isOk) {
                    alert((data && data.message) ? data.message : 'تعذر إضافة السطر.');
                    return;
                }

                // =========================================================
                // 6) تحديث الجدول + الملخص (بدون ما نكسر الكود لو دالة ناقصة)
                // =========================================================
                try {

                    // السيرفر عندك بيرجع lines غالباً
                    if (Array.isArray(data.lines)) {
                        window.__piLinesCache = data.lines; // متغير: حفظ آخر سطور
                        if (typeof renderGroupedLines === 'function') {
                            renderGroupedLines(data.lines);
                        } else {
                            console.warn('renderGroupedLines غير معرفة وقت التنفيذ.');
                        }
                    } else if (data.line) {
                        window.__piLinesCache = window.__piLinesCache || [];
                        window.__piLinesCache.push(data.line);
                        if (typeof renderGroupedLines === 'function') {
                            renderGroupedLines(window.__piLinesCache);
                        }
                    }

                    if (data.totals && typeof updateSummaryBadges === 'function') {
                        updateSummaryBadges(data.totals);
                    }

                } catch (uiErr) {
                    // تعليق: لو حصل خطأ في تحديث الواجهة، ما نعتبره مشكلة سيرفر
                    console.error('UI Update Error after AddLineJson:', uiErr);
                    alert('تمت الإضافة في السيرفر، لكن حدث خطأ أثناء تحديث الجدول في الصفحة. راجع Console.');
                }

                // =========================================================
                // 7) تنظيف الخانات + فوكس على اسم الصنف
                // =========================================================
                if (prodQtyInput) prodQtyInput.value = '';
                if (prodBatchInput) prodBatchInput.value = '';
                if (prodExpiryInput) prodExpiryInput.value = '';

                // فوكس على اسم الصنف (مش الكود)
                document.getElementById('ProdNameInput')?.focus();
                document.getElementById('ProdNameInput')?.select?.();

            } catch (err) {
                // ✅ هنا هنطلع السبب الحقيقي بدل رسالة عامة
                console.error('AddLineAjax Exception:', err);
                alert('حدث خطأ داخل الجافاسكربت أثناء الإضافة: ' + (err?.message || err));
            } finally {
                if (btnAddLine) btnAddLine.disabled = false;
            }
        }

        // ✅ ربط زر "إضافة" مرة واحدة فقط
        if (btnAddLine && !btnAddLine.dataset.boundAddLine) {
            btnAddLine.dataset.boundAddLine = '1';
            btnAddLine.type = 'button';
            btnAddLine.addEventListener('click', function (e) {
                e.preventDefault();
                addLineAjax();
            });
        }




            // =========================================================
            // التابات: حركة الصنف + تعديل بياناته
            // =========================================================
            const btnProdMovement = document.getElementById('btnOpenProductMovement'); // متغير: زر حركة الصنف
            const btnProdEdit     = document.getElementById('btnOpenProductEdit');     // متغير: زر تعديل بيانات الصنف

            function getCurrentProdId() {
                if (prodHiddenId && prodHiddenId.value.trim() !== '') return prodHiddenId.value.trim();
                if (prodCodeInput && prodCodeInput.value.trim() !== '') return prodCodeInput.value.trim();
                return '';
            }

            function openTabFromFrame(url, tabId, title) {
                try {
                    if (window.top && window.top !== window) {
                        window.top.postMessage({
                            type: 'erp-open-tab',
                            tabId: tabId || '',
                            title: title || '',
                            url: url
                        }, '*');
                        return;
                    }
                } catch (e) {
                    console.error('خطأ أثناء استخدام postMessage:', e);
                }

                if (window.erpTabs && typeof window.erpTabs.openTab === 'function') {
                    window.erpTabs.openTab(tabId, url, title);
                } else {
                    window.location.href = url;
                }
            }

            const editBaseUrl     = '@Url.Action("Edit", "Products")'; // متغير: /Products/Edit
            const movementBaseUrl = '@Url.Action("Show", "Products")'; // متغير: /Products/Show

            function buildEditUrl(id) {
                const base = editBaseUrl.replace(/\/$/, '');
                const params = new URLSearchParams();
                params.set('frame', '1');
                return base + '/' + encodeURIComponent(id) + '?' + params.toString();
            }

            function buildMovementUrl(id) {
                const base = movementBaseUrl;
                const params = new URLSearchParams();
                params.set('prodId', id);
                params.set('frame', '1');
                const sep = base.includes('?') ? '&' : '?';
                return base + sep + params.toString();
            }

            if (btnProdEdit && !btnProdEdit.dataset.boundProdEdit) {
                btnProdEdit.dataset.boundProdEdit = '1';
                btnProdEdit.addEventListener('click', function (e) {
                    e.preventDefault();

                    const id = getCurrentProdId();
                    if (!id) {
                        alert('من فضلك اختر صنفاً أولاً.');
                        prodNameInput?.focus();
                        prodNameInput?.select?.();
                        return;
                    }

                    openTabFromFrame(buildEditUrl(id), 'prod-edit-' + id, 'تعديل الصنف');
                });
            }

            if (btnProdMovement && !btnProdMovement.dataset.boundProdMove) {
                btnProdMovement.dataset.boundProdMove = '1';
                btnProdMovement.addEventListener('click', function (e) {
                    e.preventDefault();

                    const id = getCurrentProdId();
                    if (!id) {
                        alert('من فضلك اختر صنفاً أولاً.');
                        prodNameInput?.focus();
                        prodNameInput?.select?.();
                        return;
                    }

                    openTabFromFrame(buildMovementUrl(id), 'prod-move-' + id, 'حركة الصنف');
                });
            }

            // تهيئة: لو في صنف موجود بالفعل في الهيدر (نادر)
            if (prodHiddenId && prodHiddenId.value) {
                const opt = findProductByCode(prodHiddenId.value);
                if (opt) fillProductFromOption(opt);
            }

        })(); // نهاية IIFE الأصناف

        // =========================================================
        // (C) فوكس + حفظ الهيدر (AJAX) — بدون تكرار
        // =========================================================
        document.addEventListener('DOMContentLoaded', () => {

            // ==========================
            // 1) فوكس على المورد لو فاتورة جديدة
            // ==========================
            const isNewInvoice = @(Model == null || Model.PIId == 0 ? "true" : "false"); // متغير: هل فاتورة جديدة؟
            if (isNewInvoice) {
                const custNameInput = document.getElementById('CustomerNameInput'); // متغير: اسم المورد
                setTimeout(() => {
                    custNameInput?.focus();
                    custNameInput?.select?.();
                }, 250);
            }

            // ==========================
            // 2) زر حفظ الهيدر (SaveHeader)
            // ==========================
            const saveBtn = document.getElementById('btnSaveInvoiceHeader'); // متغير: زر حفظ الفاتورة
            if (!saveBtn) return;

            // ✅ ربط مرة واحدة
            if (saveBtn.dataset.boundSaveHeader) return;
            saveBtn.dataset.boundSaveHeader = '1';

            saveBtn.type = 'button'; // تعليق: منع submit الافتراضي

            let busy = false; // متغير: يمنع الضغط المتكرر

            saveBtn.addEventListener('click', async (e) => {
                e.preventDefault();
                if (busy) return;
                busy = true;
                saveBtn.disabled = true;

                // متغير: رقم الفاتورة الحالي (0 لو جديدة)
                const invoiceId = parseInt((document.getElementById('InvoiceId')?.value || '0'), 10) || 0;

                // متغير: كود المورد
                const customerId = parseInt((document.getElementById('CustomerId')?.value || '0'), 10) || 0;

                // متغير: كود المخزن
                const warehouseId = parseInt((document.getElementById('WarehouseId')?.value || '0'), 10) || 0;

                // متغير: طلب شراء مرجعي (اختياري)
                let refPrId = null;
                const refPrInput = document.getElementById('RefPRId'); // متغير: حقل طلب الشراء
                if (refPrInput && refPrInput.value.trim() !== '') {
                    const parsed = parseInt(refPrInput.value.trim(), 10);
                    if (!isNaN(parsed)) refPrId = parsed;
                }

                // تحقق: لازم المورد والمخزن
                if (!customerId || !warehouseId) {
                    alert('من فضلك اختر المورد والمخزن أولاً قبل حفظ الفاتورة.');
                    busy = false;
                    saveBtn.disabled = false;
                    return;
                }

                const dto = {
                    piId: invoiceId,          // متغير: رقم الفاتورة
                    customerId: customerId,   // متغير: رقم المورد
                    warehouseId: warehouseId, // متغير: رقم المخزن
                    refPrId: refPrId          // متغير: طلب شراء مرجعي
                };

                try {

                    const response = await fetch('@Url.Action("SaveHeader", "PurchaseInvoices")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(dto)
                    });

                    if (!response.ok) {
                        const txt = await response.text().catch(() => '');
                        console.error('SaveHeader HTTP Error:', response.status, txt);
                        alert('حدث خطأ غير متوقع أثناء حفظ الفاتورة.');
                        return;
                    }

                    const data = await response.json().catch(() => null);

                    if (!data || !data.success) {
                        alert((data && data.message) ? data.message : 'تعذر حفظ الفاتورة.');
                        return;
                    }

                    // تحديث رقم الفاتورة في hidden + display
                    const newId = data.piId || 0; // متغير: رقم الفاتورة بعد الحفظ
                    const invoiceIdInput = document.getElementById('InvoiceId');
                    if (newId > 0 && invoiceIdInput) invoiceIdInput.value = newId.toString();

                    const invoiceNumberDisplay = document.getElementById('InvoiceNumberDisplay');
                    if (invoiceNumberDisplay) {
                        invoiceNumberDisplay.value = data.invoiceNumber || (newId > 0 ? newId.toString() : invoiceNumberDisplay.value);
                    }

                    // تحديث التاريخ/الوقت
                    const invoiceDateDisplay = document.getElementById('InvoiceDateDisplay');
                    if (invoiceDateDisplay && data.invoiceDate) invoiceDateDisplay.value = data.invoiceDate;

                    const invoiceTimeDisplay = document.getElementById('InvoiceTimeDisplay');
                    if (invoiceTimeDisplay && data.invoiceTime) invoiceTimeDisplay.value = data.invoiceTime;

                    // تحديث حالة الفاتورة
                    const statusHidden = document.getElementById('InvoiceStatusHidden');
                    if (statusHidden && data.status) statusHidden.value = data.status;

                    const isPostedDisplay = document.getElementById('InvoiceIsPostedDisplay');
                    if (isPostedDisplay && typeof data.isPosted === 'boolean') {
                        isPostedDisplay.value = data.isPosted ? 'نعم' : 'لا';
                    }

                    const createdByDisplay = document.getElementById('InvoiceCreatedByDisplay');
                    if (createdByDisplay && data.createdBy) createdByDisplay.value = data.createdBy;

                    // ✅ المطلوب: بعد الحفظ فوكس على الصنف
                                            const ProdNameInput = document.getElementById('ProdNameInput');
                    ProdNameInput?.focus();
                    ProdNameInput?.select?.();

                } catch (err) {
                    console.error(err);
                    alert('تعذر الاتصال بالخادم لحفظ الفاتورة.');
                } finally {
                    busy = false;
                    saveBtn.disabled = false;
                }
            });

        });



        //زر “مسح الصنف

        document.addEventListener('click', async function (e) {

    const btn = e.target.closest('.btnRemoveProductFromInvoice');
    if (!btn) return;

    const prodId = parseInt(btn.getAttribute('data-prodid') || '0', 10);
    if (!prodId) return;

    if (!confirm('هل تريد مسح هذا الصنف بكل تشغيلاته من الفاتورة؟')) return;

    const token = getAntiForgeryToken();
    const invoiceId = parseInt('@(Model.PIId)', 10);

    const res = await fetch('@Url.Action("RemoveProductLinesJson", "PurchaseInvoices")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': token
        },
        body: JSON.stringify({ PIId: invoiceId, prodId: prodId })
    });

    const data = await res.json();

    if (!data.ok) {
        alert(data.message || 'حدث خطأ أثناء مسح الصنف.');
        return;
    }

    if (data.lines) renderGroupedLines(data.lines);
    if (data.totals) updateSummaryBadges(data.totals);
});



//حفظ الضريبة (Enter أو Blur)

async function saveTaxAjax() {

    const token = getAntiForgeryToken();
    const invoiceId = parseInt('@(Model.PIId)', 10);

    const taxInput = document.getElementById('TaxAmountInput');
    const taxVal = parseFloat(taxInput?.value || '0') || 0;

    const res = await fetch('@Url.Action("SaveTaxJson", "PurchaseInvoices")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': token
        },
        body: JSON.stringify({ PIId: invoiceId, taxTotal: taxVal })
    });

    const data = await res.json();

    if (!data.ok) {
        alert(data.message || 'تعذر حفظ الضريبة.');
        return;
    }

    if (data.totals) updateSummaryBadges(data.totals);
}

document.getElementById('TaxAmountInput')?.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') {
        e.preventDefault();
        saveTaxAjax();
    }
});

document.getElementById('TaxAmountInput')?.addEventListener('blur', function () {
    saveTaxAjax();
});





