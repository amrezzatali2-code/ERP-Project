@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Models.PurchaseInvoice

@{
    // عنوان التاب
    ViewData["Title"] = Model.PIId == 0
        ? "فاتورة مشتريات جديدة"
        : $"فاتورة مشتريات — رقم {Model.PIId}";
}

@section Styles {
    <style>
        /* ===== فاتورة المشتريات بدون invoice-cards.css (مثل فاتورة المبيعات) لتجنب حد/خلفية على PI_BodyHost ===== */
        .pi-input[type="number"]::-webkit-outer-spin-button,
        .pi-input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        .pi-input[type="number"] { -moz-appearance: textfield; }

        /* خلفية الصفحة والعمود — مثل فاتورة المبيعات */
        .invoice-page {
            background-color: #f3f6fb !important;
            min-height: 0;
            padding-bottom: 1rem;
            border: none !important;
            box-shadow: none !important;
        }
        .invoice-page .container-fluid { padding: 0; max-width: 100%; }
        .invoice-page .col-lg-2.order-1 { padding: 0.5rem 0.5rem; }

        /* كارت الأزرار الجانبي — حدود مطابقة لطلب الشراء (#6366f1) */
        .invoice-page div.card.invoice-side-card {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
            background: #ffffff !important;
            overflow: hidden;
        }
        .invoice-page .invoice-side-card {
            border-inline-start: none !important;
            min-width: 220px;
        }
        .invoice-side-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            border-bottom: none;
            padding: 0.55rem 1rem;
        }
        .invoice-side-card .invoice-actions-bar hr { display: none !important; }
        .invoice-side-card .btn-erp { font-size: 0.85rem; padding: 0.35rem 0.6rem; border: 1px solid #64748b !important; }
        .invoice-side-card .btn-erp + .btn-erp { margin-top: 0.25rem; }
        .invoice-actions-sticky {
            position: sticky;
            top: 58px;
            z-index: 3000;
            background: #ffffff !important;
            border: 1px solid #6366f1 !important;
            padding: 10px 10px !important;
            border-radius: 12px;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
        }
        @@media (max-width: 992px) { .invoice-actions-sticky { top: 56px; } }
        .invoice-page .invoice-side-card .form-control { background: #fff; border-color: #64748b; color: #0f172a; }
        .invoice-page .invoice-side-card .form-control::placeholder { color: #6c757d; }

        /* حاوية الرسائل العابرة (Toast) — خارج كارت الإجراءات، مثل طلب الشراء */
        #piToastContainer {
            position: fixed;
            top: 70px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.35rem;
            pointer-events: none;
        }
        #piToastContainer .pi-toast {
            padding: 0.6rem 1.2rem;
            border-radius: 8px;
            font-size: 0.9rem;
            box-shadow: 0 2px 8px rgba(0,0,0,.12);
            transition: opacity 0.25s ease;
        }
        #piToastContainer .pi-toast.text-success { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
        #piToastContainer .pi-toast.text-warning { background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; }
        #piToastContainer .pi-toast.text-danger { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
        #piToastContainer .pi-toast.text-muted { background: #f1f5f9; color: #334155; border: 1px solid #64748b; }

        /* شريط الهيدر الملون + هيدر الكروت الداخلية */
        .invoice-header-bar,
        .invoice-page .invoice-header-bar {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            padding: 0.5rem 1rem;
            font-weight: 600;
        }
        .invoice-header-bar {
            position: relative;
        }
        .invoice-header-bar h5, .invoice-header-bar h6 {
            margin-bottom: 0;
            font-size: 1rem;
            color: #fff !important;
            text-align: center;
        }

        /* طي كروت فاتورة المشتريات — زر أعلى اليسار (مثل فاتورة المبيعات) */
        .invoice-card-collapse-btn {
            position: absolute;
            left: 0.4rem;
            top: 50%;
            transform: translateY(-50%);
            width: 1.75rem;
            height: 1.75rem;
            line-height: 1;
            border-radius: 6px;
            background: rgba(255, 255, 255, 0.18);
            border: none;
            color: #fff;
            padding: 0;
            cursor: pointer;
            z-index: 2;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .invoice-card-collapse-btn:hover {
            background: rgba(255, 255, 255, 0.3);
        }
        .invoice-card-collapse-btn:focus-visible {
            outline: 2px solid rgba(255, 255, 255, 0.85);
            outline-offset: 1px;
        }
        .invoice-card-collapse-icon {
            display: inline-block;
            font-size: 0.7rem;
            line-height: 1;
            transition: transform 0.2s ease;
        }
        .invoice-header-card.invoice-card-collapsed .invoice-card-collapse-icon,
        .invoice-product-card.invoice-card-collapsed .invoice-card-collapse-icon,
        .invoice-Add-card.invoice-card-collapsed .invoice-card-collapse-icon {
            transform: rotate(-90deg);
        }
        .invoice-header-card.invoice-card-collapsed > .invoice-header-collapse-wrap {
            display: none !important;
        }
        .invoice-product-card.invoice-card-collapsed > .card-body,
        .invoice-Add-card.invoice-card-collapsed > .card-body {
            display: none !important;
        }
        .invoice-product-card-bar,
        .invoice-add-card-bar {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%);
            color: #ffffff;
            padding: 0.3rem 0.5rem;
            min-height: 2rem;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .invoice-product-card-bar .invoice-mini-bar-title,
        .invoice-add-card-bar .invoice-mini-bar-title {
            font-size: 0.9rem;
            font-weight: 600;
            margin: 0;
        }

        .invoice-product-card .card-header,
        .invoice-Add-card .card-header {
            background: linear-gradient(90deg, #374151 0%, #0ea5e9 100%) !important;
            color: #ffffff !important;
            padding: 0.55rem 1rem;
        }
        .invoice-product-card .card-header h6, .invoice-side-card .card-header h6 { color: #fff !important; margin-bottom: 0; }

        /* العمود الرئيسي — شفاف وبدون أي حد (إزالة الخط العمودي المحيط بكل الكروت) */
        .invoice-page .col-12.col-lg-10.order-2.order-lg-1,
        .invoice-page .col-lg-10.order-2 {
            background: transparent !important;
            padding: 0.5rem 1rem;
            border: none !important;
            box-shadow: none !important;
        }

        /* حاوية المحتوى — ليست كارت: بدون حد وبدون خلفية (حتى يظهر الحد السفلي لكل كارت لوحده) */
        #PI_BodyHost,
        div#PI_BodyHost,
        .invoice-page div#PI_BodyHost {
            display: block !important;
            background: transparent !important;
            background-color: transparent !important;
            border: none !important;
            box-shadow: none !important;
            outline: none !important;
            padding: 0 !important;
        }

        /* الصف والحاوية العامة — بدون حدود */
        .invoice-page .container-fluid,
        .invoice-page .row {
            border: none !important;
            box-shadow: none !important;
        }

        /* حدود الكروت وخلفية بيضاء — مطابق لطلب الشراء (لون أغمق #6366f1) */
        .invoice-page div.card.invoice-header-card,
        .invoice-page div.card.invoice-product-card,
        .invoice-page div.card.invoice-Add-card,
        .invoice-page div.card.invoice-totals-card {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
            background: #ffffff !important;
            overflow: hidden;
        }

        /* الكارت الأول (الهيدر) — حدود مطابقة لطلب الشراء */
        #PI_BodyHost > .invoice-header-card,
        .invoice-page #PI_BodyHost > .invoice-header-card {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
            background: #ffffff !important;
        }
        .invoice-page .invoice-lines-container {
            border: 1px solid #6366f1 !important;
            border-radius: 12px !important;
            box-shadow: 0 1px 3px rgba(99,102,241,.25) !important;
            background: #fff !important;
            overflow: hidden;
        }

        /* مسافات بين الكروت — مثل فاتورة المبيعات (0.85rem) */
        .invoice-page #PI_BodyHost .invoice-header-card,
        .invoice-page #PI_BodyHost .invoice-product-card,
        .invoice-page #PI_BodyHost .invoice-Add-card,
        .invoice-page .invoice-lines-container,
        .invoice-page #PI_BodyHost .invoice-totals-card {
            margin-bottom: 0.85rem !important;
        }
        .invoice-page #PI_BodyHost .invoice-header-card { margin-top: 0 !important; }
        .invoice-page .invoice-lines-container { margin-top: 0.85rem; }
        .invoice-page .card { margin-bottom: 0.85rem; }

        /* إزالة الخط الفاصل السميك بين الكروت (مثل طلب الشراء) */
        .invoice-card-line { display: none; }

        /* حدود الانبوتات أغمق (#64748b) مثل طلب الشراء */
        #PI_BodyHost .invoice-header-card .form-control,
        #PI_BodyHost .invoice-header-card .form-select,
        #PI_BodyHost .invoice-product-card .form-control,
        #PI_BodyHost .invoice-product-card .form-select,
        #PI_BodyHost .invoice-Add-card .form-control,
        #PI_BodyHost .invoice-Add-card .form-select,
        #PI_BodyHost .invoice-totals-card .form-control,
        #PI_BodyHost .invoice-totals-card .form-select {
            border-color: #64748b !important;
        }

        /* لون النص والتسميات أغمق مثل طلب الشراء */
        .invoice-header-card .card-body .form-label,
        .invoice-header-card .card-body .form-label-sm,
        .invoice-header-card .card-body label {
            color: #0f172a !important;
            font-weight: 500;
            font-size: 0.8rem;
            margin-bottom: 0.25rem;
        }

        /* ===== إبراز بوكس اسم الصنف (أوضح للعين) ===== */
        #PI_BodyHost .invoice-Add-card #productDropdownWrap {
            border: 2px solid #4f46e5 !important;
            border-radius: 0.55rem !important;
            padding: 3px !important;
        }
        #PI_BodyHost .invoice-Add-card .product-dropdown-onebox {
            border: 0 !important; /* نستخدم حد الـ wrap بدلًا من حد الكارت الداخلي */
            border-radius: 0.45rem !important;
        }

        /* ===== إبراز بوكس اسم المورد ===== */
        #PI_BodyHost .invoice-header-card #supplierDropdownWrap {
            border: 2px solid #4f46e5 !important;
            border-radius: 0.55rem !important;
            padding: 3px !important;
        }
        #PI_BodyHost .invoice-header-card #supplierDropdownWrap:focus-within {
            border-color: #4338ca !important;
            box-shadow: none !important;
        }
        #PI_BodyHost .invoice-header-card #supplierDropdownWrap .product-dropdown-onebox {
            border: 0 !important;
            background: transparent !important;
            border-radius: 0.45rem !important;
        }
        #PI_BodyHost .invoice-header-card #supplierDropdownWrap .product-dropdown-onebox:focus-within {
            box-shadow: none !important;
            border-color: transparent !important;
        }
        .invoice-header-card .card-body .form-control,
        .invoice-header-card .card-body .form-control-sm,
        .invoice-header-card .card-body .form-select,
        .invoice-header-card .card-body .form-select-sm {
            color: #020617 !important;
        }
        .invoice-product-card .card-body .form-label,
        .invoice-product-card .card-body .form-label-sm,
        .invoice-product-card .card-body label,
        .invoice-product-card .pr-card-field label {
            color: #0f172a !important;
            font-weight: 500;
            font-size: 0.8rem;
            margin-bottom: 0.25rem;
        }
        .invoice-product-card .card-body .form-control,
        .invoice-product-card .card-body .form-control-sm,
        .invoice-product-card .card-body .form-select,
        .invoice-product-card .pr-card-field .form-control-sm,
        .invoice-product-card .pr-card-field .form-select-sm {
            color: #020617 !important;
        }
        .invoice-Add-card .card-body .form-label,
        .invoice-Add-card .card-body .form-label-sm,
        .invoice-Add-card .card-body label {
            color: #0f172a !important;
            font-weight: 500;
            font-size: 0.8rem;
            margin-bottom: 0.25rem;
        }
        .invoice-Add-card .card-body .form-control,
        .invoice-Add-card .card-body .form-control-sm,
        .invoice-Add-card .card-body .form-select,
        .invoice-Add-card .card-body .form-select-sm {
            color: #020617 !important;
        }
        .invoice-totals-card .card-body .form-label,
        .invoice-totals-card .card-body label,
        .invoice-totals-card .invoice-summary-item label {
            color: #0f172a !important;
            font-weight: 500;
        }

        /* تسميات الكارتين 2 و 3 — مطابقة الهيدر؛ #PI_BodyHost + !important تثبت الحجم بعد تحميل frag=body */
        #PI_BodyHost .invoice-product-card .card-body .form-label,
        #PI_BodyHost .invoice-product-card .card-body .form-label-sm,
        #PI_BodyHost .invoice-product-card .card-body label,
        #PI_BodyHost .invoice-product-card .pr-card-field label,
        #PI_BodyHost .invoice-Add-card .card-body .form-label,
        #PI_BodyHost .invoice-Add-card .card-body .form-label-sm,
        #PI_BodyHost .invoice-Add-card .card-body label {
            font-size: 0.8rem !important;
            margin-bottom: 0.25rem !important;
        }

        /* انبوتات الكارت الأول (الهيدر): حجم مثل طلب الشراء (0.875rem، padding 0.3rem 0.5rem) */
        #PI_BodyHost .invoice-header-card .form-control,
        #PI_BodyHost .invoice-header-card .form-select,
        #PI_BodyHost .invoice-header-card .card-body .form-control,
        #PI_BodyHost .invoice-header-card .card-body .form-control-sm,
        #PI_BodyHost .invoice-header-card .card-body .form-select,
        #PI_BodyHost .invoice-header-card .card-body .form-select-sm {
            border-radius: 0.375rem;
            padding: 0.3rem 0.5rem;
            min-height: 2rem;
            font-size: 0.875rem;
        }
        /* محاذاة النص في المنتصف لكل بوكسات الكارت الأول ما عدا اسم المورد */
        #PI_BodyHost .invoice-header-card .card-body .form-control,
        #PI_BodyHost .invoice-header-card .card-body .form-select {
            text-align: center;
        }
        #PI_BodyHost .invoice-header-card #CustomerNameInput {
            text-align: right !important;
        }
        #PI_BodyHost .invoice-header-card .form-control:focus,
        #PI_BodyHost .invoice-header-card .form-select:focus {
            border-color: #64748b !important;
            box-shadow: 0 0 0 0.2rem rgba(100,116,139,.2);
        }

        /* انبوتات الكارت الثاني والثالث — نفس حجم الكارت الأول (0.875rem / padding الهيدر)؛ !important يمنع اختلافاً بعد frag=body */
        #PI_BodyHost .invoice-product-card .card-body .form-control,
        #PI_BodyHost .invoice-product-card .card-body .form-control-sm,
        #PI_BodyHost .invoice-product-card .card-body .form-select,
        #PI_BodyHost .invoice-product-card .card-body .form-select-sm,
        #PI_BodyHost .invoice-product-card .pr-card-field .form-control-sm,
        #PI_BodyHost .invoice-Add-card .card-body .form-control,
        #PI_BodyHost .invoice-Add-card .card-body .form-control-sm,
        #PI_BodyHost .invoice-Add-card .card-body .form-select,
        #PI_BodyHost .invoice-Add-card .card-body .form-select-sm,
        #PI_BodyHost .invoice-Add-card .pi-input {
            padding: 0.3rem 0.5rem !important;
            min-height: 2rem !important;
            font-size: 0.875rem !important;
            border-radius: 0.375rem;
        }
        #PI_BodyHost .invoice-product-card .form-control,
        #PI_BodyHost .invoice-product-card .form-select,
        #PI_BodyHost .invoice-Add-card .form-control,
        #PI_BodyHost .invoice-Add-card .form-select,
        #PI_BodyHost .invoice-totals-card .form-control,
        #PI_BodyHost .invoice-totals-card .form-select {
            border-radius: 0.375rem;
        }
        /* بوكس اسم الصنف (داخل product-dropdown): نفس حجم خط الحقول */
        #PI_BodyHost .invoice-Add-card .product-dropdown-onebox .product-dropdown-input {
            font-size: 0.875rem !important;
            padding-top: 0.3rem !important;
            padding-bottom: 0.3rem !important;
            padding-right: 0.5rem !important;
            padding-left: 2.25rem !important;
            min-height: 2rem !important;
        }
        #PI_BodyHost .invoice-Add-card #btnAddInvoiceLine {
            font-size: 0.875rem !important;
        }
        #PI_BodyHost .invoice-product-card .form-control:focus,
        #PI_BodyHost .invoice-product-card .form-select:focus,
        #PI_BodyHost .invoice-Add-card .form-control:focus,
        #PI_BodyHost .invoice-Add-card .form-select:focus,
        #PI_BodyHost .invoice-totals-card .form-control:focus,
        #PI_BodyHost .invoice-totals-card .form-select:focus {
            border-color: #64748b !important;
            box-shadow: 0 0 0 0.2rem rgba(100,116,139,.2);
        }

        /* هيدر جدول السطور — أرضية رمادي عادي ونص أسود (مثل طلب الشراء) */
        .invoice-lines-container .erp-table-wrapper thead.invoice-lines-header th {
            background-color: #e9ecef !important;
            color: #212529 !important;
            font-weight: 600;
            padding: 0.5rem 0.55rem;
            border: 1px solid #dee2e6 !important;
        }
        .invoice-page .invoice-lines-container .erp-table-wrapper {
            max-height: 420px;
            border: none;
        }

        /* كارت الإجماليات — نفس درجة طلب الشراء: حجم البوكسات والكلام وغمقان الحدود والنص */
        .invoice-totals-card .card-body { padding: 0.9rem 1rem !important; }
        .invoice-totals-card .invoice-summary-row.invoice-summary-row-boxes {
            flex-wrap: wrap;
            gap: 0.35rem 0.5rem;
            align-items: stretch;
        }
        .invoice-totals-card .invoice-summary-item.invoice-summary-box {
            flex: 1 1 0;
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
            align-items: center;
            padding: 0.25rem 0.35rem;
            background: #f8fafc;
            border: 1px solid #94a3b8;
            border-radius: 6px;
        }
        .invoice-totals-card .invoice-summary-label { font-size: 0.65rem; line-height: 1.2; color: #64748b; margin-bottom: 0; }
        .invoice-totals-card .invoice-summary-value { font-size: 0.8rem; font-weight: 500; color: #0f172a; }
        .invoice-summary-box-main {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%) !important;
            border-color: #0284c7 !important;
        }
        .invoice-totals-card .invoice-summary-box-main .invoice-summary-label { color: rgba(255,255,255,.9); }
        .invoice-totals-card .invoice-summary-value-main { font-size: 0.85rem; color: #fff !important; }

        .badge-status-draft { background-color: #6f42c1; }
        .badge-status-notposted { background-color: #343a40; }

        /* =========================================================
           ERP — Print Template (Purchase Invoice)
           محلي داخل Show فقط
        ========================================================= */

        /* مخفي في الشاشة */
        .print-only {
            display: none;
        }

        @@media print {
            /* يظهر في الطباعة فقط */
            .print-only {
                display: block !important;
            }
            /* مهم: فك أي Scroll أثناء الطباعة */
            .erp-table-wrapper {
                max-height: none !important;
                overflow: visible !important;
            }
            /* تنسيق جدول الطباعة لو اتنسخ */
            #piPrintArea table {
                width: 100%;
                border-collapse: collapse;
                font-size: 12px;
            }

            #piPrintArea th, #piPrintArea td {
                border: 1px solid #d0d0d0;
                padding: 6px;
                vertical-align: middle;
                white-space: nowrap;
            }

            #piPrintArea thead {
                display: table-header-group;
            }

            #piPrintArea tr {
                break-inside: avoid;
            }
        }



        /* ===== قائمة الأصناف المنسدلة (زي فاتورة المبيعات) ===== */
        /* بوكس واحد: السهم داخل البوكس على اليسار (حد واحد حول الكل) */
        .product-dropdown-onebox {
            position: relative;
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
            background: #fff;
        }
        .product-dropdown-arrow-inside {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #495057;
            cursor: pointer;
            user-select: none;
            font-size: 0.6rem;
            z-index: 1;
        }
        .product-dropdown-arrow-inside:hover {
            background-color: #e9ecef;
        }
        .product-dropdown-onebox .product-dropdown-input {
            width: 100%;
            border: none !important;
            background: transparent !important;
            padding-left: 2.25rem !important;
        }
        .product-dropdown-onebox .product-dropdown-input:focus {
            box-shadow: none !important;
            outline: none !important;
        }
        .product-dropdown-onebox:focus-within {
            border-color: #0d6efd !important;
            box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
        }
        /* القائمة المنسدلة — تظهر تحت البوكس (position fixed لعدم القص) */
        .product-dropdown-list {
            position: fixed;
            max-height: 220px;
            min-height: 40px;
            overflow-y: auto;
            z-index: 9999;
            margin-top: 2px;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            background: #fff;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        }
        .product-dropdown-list[data-open="false"] {
            display: none !important;
        }
        .product-dropdown-list[data-open="true"] {
            display: block !important;
        }
        #productDropdownWrap {
            overflow: visible !important;
        }
        .invoice-Add-card .card-body {
            overflow: visible !important;
        }
        .product-dropdown-item {
            cursor: pointer;
            border-bottom: 1px solid #f0f0f0;
        }
        .product-dropdown-item:hover {
            background-color: #f8f9fa;
        }
        .product-dropdown-item:last-child {
            border-bottom: none;
        }
        .product-dropdown-item-active {
            background-color: #0d6efd !important;
            color: #fff !important;
        }

        /* =========================================================
   اختيار سطر من جدول السطور (Click Row)
   - عند الضغط على أي سطر في جدول السطور: يتم تمييزه
   - وتعبئة بياناته في جزء (إضافة صنف للفاتورة) أعلى الصفحة
   ========================================================= */
#PILinesTbody tr[data-prodid] {
    cursor: pointer; /* تعليق: السطر قابل للضغط */
}

#PILinesTbody tr.pi-row-selected td {
    outline: 2px solid rgba(13, 110, 253, 0.35);
    outline-offset: -2px;
    background: rgba(13, 110, 253, 0.06);
}

@@media print {
    #PILinesTbody tr.pi-row-selected td {
        outline: none !important;
        background: transparent !important;
    }
}



    </style>
}




<div class="invoice-page" dir="rtl">
    <div id="piToastContainer" aria-live="polite"></div>
    <div class="container-fluid pt-0">

        @* فورم مخفي لتوليد Anti-Forgery Token لاستخدامه في نداءات AJAX *@
        <form id="__AntiForgeryForm" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>

        <div class="row g-0 align-items-start">



            @* =========================
               العمود الجانبي (أزرار الحركة) — على اليسار مثل فاتورة المبيعات
               ========================= *@
            <div class="col-12 col-lg-2 order-1 order-lg-2">

                <div class="card shadow-sm invoice-side-card sticky-top" style="top: 40px;">
                    <div class="invoice-header-bar d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h6 class="mb-0">إجراءات فاتورة المشتريات</h6>
                        </div>
                    </div>


                    <!-- =========================================================
                    ثابت: رقم الفاتورة + علم الترحيل (Flag)
                    - InvoiceId: رقم الفاتورة الحالي (0 لو جديدة)
                    - InvoiceIsPostedFlag: 1 لو مترحّلة / 0 لو مفتوحة
                    ========================================================= -->
                    <input type="hidden" id="InvoiceId" value="@Model.PIId" />
                    <input type="hidden" id="InvoiceIsPostedFlag" value="@(Model.IsPosted ? "1" : "0")" />



                    <div class="invoice-actions-bar invoice-actions-sticky d-flex flex-column gap-2">

                        @{
                            int? navFirst = ViewBag.NavFirstId == null ? (int?)null : (int)ViewBag.NavFirstId;
                            int? navLast = ViewBag.NavLastId == null ? (int?)null : (int)ViewBag.NavLastId;
                            int? navPrev = ViewBag.NavPrevId == null ? (int?)null : (int)ViewBag.NavPrevId;
                            int? navNext = ViewBag.NavNextId == null ? (int?)null : (int)ViewBag.NavNextId;

                            int currentId = Model?.PIId ?? 0;

                            bool hasAnyInvoices =
                            navFirst.HasValue && navLast.HasValue &&
                            navFirst.Value > 0 && navLast.Value > 0;

                            int? prevEffective = (currentId == 0) ? navLast : navPrev;
                            int? nextEffective = (currentId == 0) ? navFirst : navNext;

                            bool canFirst = hasAnyInvoices && navFirst.HasValue && navFirst.Value > 0 && navFirst.Value != currentId;
                            bool canLast = hasAnyInvoices && navLast.HasValue && navLast.Value > 0 && navLast.Value != currentId;
                            bool canPrev = hasAnyInvoices && prevEffective.HasValue && prevEffective.Value > 0 && prevEffective.Value != currentId;
                            bool canNext = hasAnyInvoices && nextEffective.HasValue && nextEffective.Value > 0 && nextEffective.Value != currentId;
                        }

                        <div class="d-flex flex-wrap align-items-center gap-1 justify-content-center">
                            <button type="button"
                                    id="btnFirstInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pi-show-tab"
                                    data-tab-title="فاتورة المشتريات"
                                    data-base-url="@Url.Action("Show", "PurchaseInvoices", new { id = (navFirst ?? 0), frame = 1 })"
                                    data-id="@(navFirst ?? 0)"
                                    title="أول فاتورة"
                                    @(canFirst ? "" : "disabled")>
                                ⏮
                            </button>

                            <button type="button"
                                    id="btnPrevInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pi-show-tab"
                                    data-tab-title="فاتورة المشتريات"
                                    data-base-url="@Url.Action("Show", "PurchaseInvoices", new { id = (prevEffective ?? 0), frame = 1 })"
                                    data-id="@(prevEffective ?? 0)"
                                    title="الفاتورة السابقة"
                                    @(canPrev ? "" : "disabled")>
                                ◀
                            </button>

                            <button type="button"
                                    id="btnNextInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pi-show-tab"
                                    data-tab-title="فاتورة المشتريات"
                                    data-base-url="@Url.Action("Show", "PurchaseInvoices", new { id = (nextEffective ?? 0), frame = 1 })"
                                    data-id="@(nextEffective ?? 0)"
                                    title="الفاتورة التالية"
                                    @(canNext ? "" : "disabled")>
                                ▶
                            </button>

                            <button type="button"
                                    id="btnLastInvoice"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm open-same-tab"
                                    data-tab-id="pi-show-tab"
                                    data-tab-title="فاتورة المشتريات"
                                    data-base-url="@Url.Action("Show", "PurchaseInvoices", new { id = (navLast ?? 0), frame = 1 })"
                                    data-id="@(navLast ?? 0)"
                                    title="آخر فاتورة"
                                    @(canLast ? "" : "disabled")>
                                ⏭
                            </button>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <input type="number"
                                   id="NavInvoiceSearchInput"
                                   class="form-control form-control-sm"
                                   placeholder="بحث برقم الفاتورة" />


                            <button type="button"
                                    id="btnNavInvoiceSearch"
                                    class="btn btn-erp btn-erp-outline-primary btn-erp-sm"
                                    data-tab-id="pi-show-tab"
                                    data-tab-title="فاتورة المشتريات"
                                    data-base-url="@Url.Action("Show", "PurchaseInvoices", new { frame = 1 })">
                                بحث
                            </button>
                        </div>

                        <a class="btn btn-erp btn-erp-outline-success btn-erp-sm open-same-tab w-100"
                           data-tab-id="pi-show-tab"
                           data-tab-title="فاتورة المشتريات"
                           data-url="@Url.Action("Create", "PurchaseInvoices", new { frame = 1 })">
                            ➕ فاتورة جديدة
                        </a>

                        <button type="button" 
                            class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" 
                            id="btnSaveInvoiceHeader" 
                            data-lock-posted="1">
                            💾 حفظ الفاتورة
                        </button>

                        <button type="button" class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100" id="btnPostInvoice" data-lock-posted="1">
                            📤 ترحيل الفاتورة
                        </button>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100"
                                id="btnOpenInvoice">
                            ⏪ فتح الفاتورة
                        </button>

                        @{
                            var canShowFullReturnBtnPI = Model?.PIId > 0 && (Model.IsPosted || Model.Status == "مفتوحة للتعديل" || (Model.Status != null && Model.Status.StartsWith("مرحلة")));
                        }
                        @* الزر يُعرض دائماً في DOM ليتحدّث عند التنقل (loadInvoiceBody) *@
                        <div id="fullReturnBtnWrapper" class="@(canShowFullReturnBtnPI ? "" : "d-none")">
                            <button type="button" class="btn btn-erp btn-erp-outline-warning btn-erp-sm w-100" id="btnCreateFullReturn" data-lock-posted="1">
                                ↩️ مرتجع فاتورة مشتريات بالكامل
                            </button>
                        </div>

                        <button type="button"
                                class="btn btn-erp btn-erp-outline-danger btn-erp-sm w-100"
                                id="btnClearInvoiceLines"
                                data-invoice-id="@(Model?.PIId ?? 0)" 
                                data-lock-posted="1">
                            🗑️ مسح كل أصناف الفاتورة
                        </button>

                        @* <div class="col-lg-6 col-md-12"> *@
                        <div>
                                <button type="button" id="btnOpenProductMovement"
                                        class="btn btn-erp btn-erp-outline-secondary btn-erp-sm w-100">
                                    📊 حركة الصنف
                                </button>
                         </div>

                        <div>
                                <button type="button" id="btnOpenProductEdit"
                                        class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100">
                                    ✏️ تعديل بيانات الصنف
                                </button>
                        </div>

                        <a href="@(Model?.CustomerId > 0 ? Url.Action("Show", "Customers", new { id = Model.CustomerId, frame = 1 }) : "#")" id="btnSupplierVolume" class="btn btn-erp btn-erp-outline-secondary btn-erp-sm open-same-tab w-100 text-decoration-none"
                           data-tab-id="customer-engagement"
                           data-tab-title="حجم تعامل عميل"
                           data-base-url="@Url.Action("Show", "Customers", new { frame = 1 })"
                           data-keep-active-posted="1">
                            📊 حجم تعامل
                        </a>

                        @if (Model?.PIId > 0)
                        {
                            <a href="@Url.Action("ExportShowExcel", "PurchaseInvoices", new { id = Model.PIId })" target="_blank" rel="noopener" class="btn btn-erp btn-erp-success btn-erp-sm w-100 text-decoration-none">📥 تصدير Excel</a>
                        }

                        <button type="button"
                                id="btnPrintInvoice"
                                class="btn btn-erp btn-erp-outline-primary btn-erp-sm w-100">
                            🖨️ طباعة الفاتورة
                        </button>



                    </div>
                </div>

            </div> @* نهاية العمود الجانبي *@





            @* =========================
               العمود الرئيسي (الهيدر + المورد + الأصناف + السطور + الإجماليات)
               ========================= *@
            <div class="col-12 col-lg-10 order-2 order-lg-1">

                @* ✅ ده الجزء الوحيد اللي هيتبدّل عند التنقل *@
                <div id="PI_BodyHost">

                    @* =========================
                       قيم التنقل + حالة الفاتورة (لازم تكون داخل الـ BodyHost عشان تتحدّث مع frag=body)
                       ========================= *@
                    <input type="hidden" id="BodyHostIsPosted" value="@(Model?.IsPosted == true ? "1" : "0")" />
                    <input type="hidden" id="BodyHostInvoiceStatus" value="@(Model?.Status ?? "")" />
                    <input type="hidden" id="NavFirstId" value="@(ViewBag.NavFirstId ?? 0)" />
                    <input type="hidden" id="NavLastId" value="@(ViewBag.NavLastId ?? 0)" />
                    <input type="hidden" id="NavPrevId" value="@(ViewBag.NavPrevId ?? 0)" />
                    <input type="hidden" id="NavNextId" value="@(ViewBag.NavNextId ?? 0)" />
                    <input type="hidden" id="NavCurrentId" value="@(Model?.PIId ?? 0)" />

                    @* ====================================================
                       1) كارت بيانات فاتورة المشتريات + المورد + المخزن
                       ==================================================== *@
                    <div class="card shadow-sm mb-2 invoice-header-card">

                        @{
                            bool isNewInvoice = Model == null || Model.PIId == 0;
                            bool hasInvoice = !isNewInvoice;

                            string invoiceDateText = hasInvoice
                            ? Model.PIDate.ToString("d/M/yyyy")
                            : "";

                            string invoiceTimeText = hasInvoice
                            ? (Model.CreatedAt.Kind == DateTimeKind.Utc ? Model.CreatedAt.ToLocalTime().ToString("HH:mm") : Model.CreatedAt.ToString("HH:mm"))
                            : "";
                        }

                        <div class="invoice-header-bar">
                            <button type="button" class="invoice-card-collapse-btn" title="طي أو إظهار بيانات الفاتورة" aria-expanded="true" aria-controls="piInvoiceHeaderCardBody">
                                <span class="invoice-card-collapse-icon" aria-hidden="true">▼</span>
                            </button>
                            <h5 class="mb-0" id="piInvoiceHeaderTitle">فاتورة مشتريات</h5>
                        </div>

                        <div class="invoice-header-collapse-wrap" id="piInvoiceHeaderCardBody">
                            <div class="card-body">

                                <div class="row g-3 align-items-end">

                                    <div class="col-lg-1 col-md-2">
                                        <label class="form-label form-label-sm">كود المورد</label>

                                        <input id="CustomerCodeDisplay"
                                               class="form-control form-control-sm text-center invoice-small-input"
                                               type="number" data-lock-posted="1"  />

                                        <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                                    </div>

                                    <div class="col-lg-3">
                                        <label for="CustomerNameInput" class="form-label form-label-sm">اسم المورد</label>

                                        <div class="position-relative" id="supplierDropdownWrap">
                                            <div class="product-dropdown-onebox" id="supplierDropdownInputGroup">
                                                <span class="product-dropdown-arrow-inside" id="supplierDropdownArrow" title="افتح القائمة">▼</span>
                                                <input id="CustomerNameInput"
                                                       name="CustomerNameInput"
                                                       type="text"
                                                       class="form-control form-control-sm product-dropdown-input"
                                                       placeholder="اكتب اسم المورد"
                                                       autocomplete="off"
                                                       value="@ViewBag.SelectedCustomerName"
                                                       data-lock-posted="1" />
                                            </div>
                                            <div id="supplierDropdownList" class="product-dropdown-list" role="listbox" data-open="false"></div>
                                        </div>
                                    </div>

                                    <div class="col-lg-1 col-md-6">
                                        <label class="form-label form-label-sm">رقم الفاتورة</label>

                                        <input type="hidden"
                                               id="InvoiceId"
                                               value="@(Model?.PIId ?? 0)" />

                                        <input id="InvoiceNumberDisplay"
                                               class="form-control form-control-sm text-center"
                                               value="@(Model != null && Model.PIId > 0 ? Model.PIId.ToString() : "")"
                                               readonly 
                                               />
                                    </div>

                                    <div class="col-lg-2">
                                        
                                            
                                                <label class="form-label form-label-sm">تاريخ الفاتورة</label>
                                                <input id="InvoiceDateDisplay"
                                                       class="form-control form-control-sm text-center"
                                                       value="@invoiceDateText"
                                                       readonly />
                                            </div>
                                            <div class="col-lg-1">
                                                <label class="form-label form-label-sm">وقت الإنشاء</label>
                                                <input id="InvoiceTimeDisplay"
                                                       class="form-control form-control-sm text-center"
                                                       value="@invoiceTimeText"
                                                       readonly />
                                            </div>
                                        
                                    




                                    <input type="hidden" asp-for="Status" id="InvoiceStatusHidden" />

                                    

                                    <div class="col-lg-1 col-md-6 col-sm-12">
                                        <label class="form-label form-label-sm">حالة الفاتورة</label>
                                        <input id="InvoiceIsPostedDisplay"
                                               class="form-control form-control-sm text-center"
                                               value="@(string.IsNullOrWhiteSpace(Model.Status) ? "غير مرحلة" : Model.Status)"
                                               readonly />
                                    </div>

                                    <div class="col-lg-2 col-md-6 col-sm-12">
                                        <label class="form-label form-label-sm" for="WarehouseId">المخزن</label>
                                        <select asp-for="WarehouseId"
                                                asp-items="ViewBag.Warehouses"
                                                class="form-select form-select-sm"
                                                data-is-posted="@(Model.IsPosted ? "1" : "0")">
                                            <option value="">اختر المخزن</option>
                                        </select>
                                    </div>

                                    <div class="col-lg-1 col-md-6 col-sm-12">
                                        <label class="form-label form-label-sm">كاتب الفاتورة</label>
                                        <input id="InvoiceCreatedByDisplay"
                                               class="form-control form-control-sm text-center"
                                               value="@Model.CreatedBy"
                                               readonly />
                                    </div>

                                    



                                </div>

                               


                                <div class="row g-4">
                                    <div class="col-lg-2 col-md-3">
                                        <label class="form-label form-label-sm">الهاتف</label>
                                        <input id="CustomerPhone"
                                               class="form-control form-control-sm"
                                               value="@(
                                               Model?.Customer?.Phone1
                                               ?? Model?.Customer?.Phone2
                                               ?? Model?.Customer?.Whatsapp
                                               ?? ""
                                                              )"
                                               readonly 
                                               />
                                    </div>

                                    <div class="col-lg-2 col-md-3">
                                        <label class="form-label form-label-sm">المحافظة</label>
                                        <input id="CustomerGovernorate"
                                               class="form-control form-control-sm"
                                               value="@(Model?.Customer?.Governorate?.GovernorateName ?? "")"
                                               readonly 
                                               />
                                    </div>

                                    <div class="col-lg-2 col-md-4 col-sm-6">
                                        <label class="form-label form-label-sm" for="RefPRId">رقم الطلب المحول</label>
                                        <input id="RefPRId"
                                               name="RefPRId"
                                               type="text"
                                               inputmode="numeric"
                                               class="form-control form-control-sm text-center"
                                               value="@(Model.RefPRId?.ToString() ?? Model.RefPurchaseRequest?.PRId.ToString() ?? "")"
                                               @(Model.IsPosted ? "readonly" : "") />
                                    </div>

                                    <div class="col-lg-6 col-md-8">
                                        <label class="form-label form-label-sm">العنوان</label>
                                        <input id="CustomerAddress"
                                               class="form-control form-control-sm"
                                               value="@(Model?.Customer?.Address ?? "")"
                                               readonly
                                               data-lock-posted="1" />
                                    </div>

                                </div>

                           
                        </div>
                    </div>
                    </div>

                    @* =====================================================
                       2) كارت بيانات الصنف
                       ===================================================== *@
                    <div id="piProductDataCard" class="card shadow-sm mb-2 invoice-product-card">
                            <div class="invoice-product-card-bar">
                                <button type="button" class="invoice-card-collapse-btn" title="طي أو إظهار بيانات الصنف" aria-expanded="true" aria-controls="piProductDataCardBody">
                                    <span class="invoice-card-collapse-icon" aria-hidden="true">▼</span>
                                </button>
                                <span class="invoice-mini-bar-title">بيانات الصنف</span>
                            </div>
                            <div class="card-body pt-0 pb-0" id="piProductDataCardBody">
                                <div class="invoice-card-line"></div>

                                <div class="row g-2 mb-3">
                                    <div class="col-lg-2 col-sm-6">
                                        <label class="form-label form-label-sm">كمية المخزن</label>
                                        <input type="text" id="ProdQtyCurrentWarehouse"
                                               class="form-control form-control-sm text-center" value="0" readonly />
                                    </div>

                                    <div class="col-lg-2 col-sm-6">
                                        <label class="form-label form-label-sm">إجمالي كمية المخازن</label>
                                        <input type="text" id="ProdQtyAllWarehouses"
                                               class="form-control form-control-sm text-center" value="0" readonly />
                                    </div>

                                    <div class="col-lg-1 col-sm-6">
                                        <label class="form-label form-label-sm">الكوتة</label>
                                        <input type="text" id="ProdQuotaText"
                                               class="form-control form-control-sm text-center" value="بدون كوتة" readonly />
                                    </div>

                                    <div class="col-lg-2 col-sm-6">
                                        <label class="form-label form-label-sm">الخصم المرجّح</label>
                                        <input type="text" id="ProdWeightedDiscount"
                                               class="form-control form-control-sm text-center" value="0" readonly />
                                    </div>

                                    <div class="col-lg-5 col-md-6">
                                        <label class="form-label form-label-sm">بدائل الصنف</label>
                                        <select id="AlternativeProducts" class="form-select form-select-sm"></select>
                                    </div>
                                </div>

                                

                            </div>
                        
                    </div>

                    @* =====================================================
                       4) كارت إدخال الصنف
                       ===================================================== *@
                    <div id="piAddProductCard" class="card shadow-sm mb-2 invoice-Add-card">
                        <div class="invoice-add-card-bar">
                            <button type="button" class="invoice-card-collapse-btn" title="طي أو إظهار إضافة الصنف" aria-expanded="true" aria-controls="piAddProductCardBody">
                                <span class="invoice-card-collapse-icon" aria-hidden="true">▼</span>
                            </button>
                            <span class="invoice-mini-bar-title">إضافة صنف للفاتورة</span>
                        </div>
                        <div class="card-body pt-0" id="piAddProductCardBody">
                            <div class="invoice-card-line"></div>

                            <div class="row g-2 align-items-end mb-2">

                                <div class="col-lg-1 col-md-4">
                                    <label class="form-label form-label-sm">كود الصنف</label>
                                    <input type="number" id="ProdCodeInput"
                                           class="form-control form-control-sm text-center pi-input"
                                               placeholder="بحث بالكود..." 
                                               data-lock-posted="1" 
                                             />
                                </div>

                                <div class="col-lg-4 col-md-8">
                                    <label class="form-label form-label-sm">اسم الصنف</label>

                                    <div class="position-relative" id="productDropdownWrap">
                                        <div class="product-dropdown-onebox" id="productDropdownInputGroup">
                                            <span class="product-dropdown-arrow-inside" id="productDropdownArrow" title="افتح القائمة">▼</span>
                                            <input id="ProdNameInput"
                                                   type="text"
                                                   class="form-control form-control-sm pi-input pi-product-name-input product-dropdown-input"
                                                   placeholder="اختر صنف..."
                                                   autocomplete="off"
                                                   data-lock-posted="1" />
                                        </div>
                                        <div id="productDropdownList" class="product-dropdown-list" role="listbox" data-open="false"></div>
                                    </div>

                                    <input type="hidden" id="ProdId" />
                                </div>

                                


                                <div class="col-lg-1 col-md-4">
                                    <label id="ProdPriceLabel" class="form-label form-label-sm">
                                        سعر الجمهور
                                        <small id="ProdPriceLockState" class="text-muted"></small>
                                    </label>

                                    <input type="number" id="ProdPriceInput"
                                           class="form-control form-control-sm text-center pi-input bg-light text-muted"
                                           readonly />
                                </div>

                                <div class="col-lg-1 col-md-4">
                                    <label class="form-label form-label-sm">الكمية</label>
                                    <input type="number" id="ProdQtyInput"
                                           class="form-control form-control-sm text-center pi-input"
                                           placeholder="0"                                              data-lock-posted="1" />
                                </div>

                                <div class="col-lg-1 col-md-4">
                                    <label id="ProdDisc1Label" class="form-label form-label-sm">الخصم</label>
                                    <input type="number" id="ProdDisc1Input"
                                           class="form-control form-control-sm text-center pi-input"
                                           value="0" data-lock-posted="1"/>
                                </div>

                                <div class="col-lg-1 col-md-4">
                                    <label class="form-label form-label-sm">التشغيلة</label>
                                    <input type="text" id="ProdBatchInput"
                                           class="form-control form-control-sm text-center pi-input"
                                           placeholder="باتش" data-lock-posted="1" data-is-posted="@(Model.IsPosted ? "1" : "0")"/>
                                </div>

                                <div class="col-lg-1 col-md-4">
                                    <label class="form-label form-label-sm">الصلاحية</label>
                                    <input type="text" id="ProdExpiryInput"
                                           class="form-control form-control-sm text-center pi-input"
                                               placeholder="MM/YYYY" data-lock-posted="1" data-is-posted="@(Model.IsPosted ? "1" : "0")" />
                                </div>

                                <div class="col-lg-1 col-md-4 d-grid">
                                    <label class="form-label form-label-sm">&nbsp;</label>
                                    <button type="button" id="btnAddInvoiceLine"
                                                class="btn btn-primary btn-sm w-100" data-lock-posted="1">
                                        إضافة
                                    </button>
                                </div>

                            </div>
                        </div>
                    </div>

                    @* =====================================================
                       5) جدول السطور — حاوية مباشرة مثل فاتورة المبيعات (بدون كارت خارجي)
                       ===================================================== *@
                    <div class="invoice-lines-container">
                            <div class="erp-table-wrapper mb-0">
                                <table class="table table-sm table-striped table-hover mb-0 erp-table">
                                    <thead class="invoice-lines-header">
                                        <tr>
                                            <th class="text-center">#</th>
                                            <th>اسم الصنف</th>
                                            <th class="text-center">التشغيلة</th>
                                            <th class="text-center">الصلاحية</th>
                                            <th class="text-center">الكمية</th>
                                            <th class="text-center">سعر الجمهور</th>
                                            <th class="text-center">خصم الشراء %</th>
                                            <th class="text-center">قيمة السطر</th>
                                        <th class="text-center no-print">مسح</th>
                                        </tr>
                                    </thead>

                                    <tbody id="PILinesTbody">
                                        @{
                                            var linesList = Model.Lines?.OrderBy(l => l.LineNo).ToList()
                                            ?? new List<ERP.Models.PILine>();

                                            var groups = linesList
                                            .GroupBy(l => new
                                            {
                                                l.ProdId,
                                                ProdName = l.Product?.ProdName ?? ("صنف #" + l.ProdId)
                                            })
                                            .OrderBy(g => g.Key.ProdName);
                                        }

                                        @if (!groups.Any())
                                        {
                                            <tr>
                                                <td colspan="9" class="text-center text-muted py-3">
                                                    لا يوجد سطور داخل الفاتورة حتى الآن.
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            foreach (var g in groups)
                                            {
                                                int batchCount = g.Count();

                                                if (batchCount == 1)
                                                {
                                                    var line = g.First();
                                                    decimal lineValue =
                                                    line.Qty * line.PriceRetail * (1m - (line.PurchaseDiscountPct / 100m));

                                                    <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                        <td class="text-center">@line.LineNo</td>

                                                        <td>
                                                            <strong>@g.Key.ProdName</strong>
                                                            <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                        </td>

                                                        <td class="text-center">@line.BatchNo</td>

                                                        <td class="text-center">
                                                            @(line.Expiry.HasValue? line.Expiry.Value.ToString("yyyy-MM-dd") : "")
                                                        </td>

                                                        <td class="text-center">@line.Qty</td>

                                                        <td class="text-center">@line.PriceRetail.ToString("0.00")</td>

                                                        <td class="text-center">@line.PurchaseDiscountPct.ToString("0.##")</td>

                                                        <td class="text-center">@lineValue.ToString("0.00")</td>

                                                    <td class="text-center no-print">
                                                            <button type="button"
                                                                    class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                                                        data-line-no="@line.LineNo" data-lock-posted="1">
                                                                مسح
                                                            </button>
                                                     </td>
                                                 </tr>
                                                }
                                                else
                                                {
                                                    <tr class="table-light pi-group-row" data-prodid="@g.Key.ProdId">
                                                        <td class="text-center">—</td>

                                                        <td>
                                                            <strong>@g.Key.ProdName</strong>
                                                            <span class="text-muted small"> | كود: @g.Key.ProdId</span>
                                                        </td>

                                                        <td class="text-center text-muted small">تشغيلات: @batchCount</td>
                                                        <td class="text-center"></td>
                                                        <td class="text-center"></td>
                                                        <td class="text-center"></td>
                                                        <td class="text-center"></td>
                                                        <td class="text-center"></td>
                                                        <td class="text-center"></td>
                                                    </tr>

                                                    foreach (var line in g.OrderBy(x => x.LineNo))
                                                    {
                                                        decimal lineValue =
                                                        line.Qty * line.PriceRetail * (1m - (line.PurchaseDiscountPct / 100m));

                                                        <tr data-line-no="@line.LineNo" data-prodid="@line.ProdId">
                                                            <td class="text-center">@line.LineNo</td>
                                                            <td class="text-muted small">↳</td>
                                                            <td class="text-center">@line.BatchNo</td>
                                                            <td class="text-center">
                                                                @(line.Expiry.HasValue? line.Expiry.Value.ToString("yyyy-MM-dd") : "")
                                                            </td>
                                                            <td class="text-center">@line.Qty</td>
                                                            <td class="text-center">@line.PriceRetail.ToString("0.00")</td>
                                                            <td class="text-center">@line.PurchaseDiscountPct.ToString("0.##")</td>
                                                            <td class="text-center">@lineValue.ToString("0.00")</td>
                                                        <td class="text-center no-print">
                                                                <button type="button"
                                                                        class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                                                        data-line-no="@line.LineNo">
                                                                    مسح
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                    </div>

                    @* =====================================================
                       6) ملخص الفاتورة
                       ===================================================== *@
                    @{
                        var lines = Model.Lines?.ToList() ?? new List<ERP.Models.PILine>();

                        int totalLines = lines.Count;
                        int totalItems = lines.Select(l => l.ProdId).Distinct().Count();
                        int totalQty = lines.Sum(l => l.Qty);

                        decimal totalRetail = lines.Sum(l => l.Qty * l.PriceRetail);
                        decimal totalAfterDiscount = lines.Sum(l =>
                        l.Qty * l.PriceRetail * (1m - (l.PurchaseDiscountPct / 100m))
                        );

                        decimal taxAmount = Model.TaxTotal;
                        decimal totalAfterDiscountAndTax = totalAfterDiscount + taxAmount;
                        decimal netTotal = totalAfterDiscountAndTax;
                    }

                    <div class="card shadow-sm mb-2 invoice-totals-card">
                        <div class="card-body">
                            <div class="d-flex flex-wrap align-items-stretch gap-2 invoice-summary-row invoice-summary-row-boxes">
                                <div class="invoice-summary-item invoice-summary-box">
                                    <span class="invoice-summary-label">عدد السطور</span>
                                    <span id="TotalLinesValue" class="invoice-summary-value">@totalLines</span>
                                </div>
                                <div class="invoice-summary-item invoice-summary-box">
                                    <span class="invoice-summary-label">عدد الأصناف</span>
                                    <span id="TotalItemsValue" class="invoice-summary-value">@totalItems</span>
                                </div>
                                <div class="invoice-summary-item invoice-summary-box">
                                    <span class="invoice-summary-label">إجمالي الكمية</span>
                                    <span id="TotalQtyValue" class="invoice-summary-value">@totalQty</span>
                                </div>
                                <div class="invoice-summary-item invoice-summary-box">
                                    <span class="invoice-summary-label">إجمالي سعر الجمهور</span>
                                    <span id="TotalRetailValue" class="invoice-summary-value">@totalRetail.ToString("0.00")</span>
                                </div>
                                <div class="invoice-summary-item invoice-summary-box invoice-summary-box-main">
                                    <span class="invoice-summary-label">الإجمالي بعد الخصم</span>
                                    <span id="TotalAfterDiscountValue" class="invoice-summary-value invoice-summary-value-main fw-bold">@totalAfterDiscount.ToString("0.00")</span>
                                    <span id="TotalAfterDiscountAndTaxValue" class="visually-hidden">@totalAfterDiscount.ToString("0.00")</span>
                                    <span id="NetTotalValue" class="visually-hidden">@netTotal.ToString("0.00")</span>
                                </div>
                            </div>
                            <input type="hidden" id="TaxAmountInput" value="0" />
                        </div>
                    </div>

                    @* مصادر أوتوكومبليت الثقيلة — آخر PI_BodyHost حتى يُبنى هيكل الكروت أولاً (docs/فتح الفواتير ككتلة واحدة.md) *@
                    <datalist id="customersList" hidden aria-hidden="true">
                        @if (ViewBag.Customers != null)
                        {
                            foreach (var c in ViewBag.Customers)
                            {
                                <option value="@c.Name"
                                        data-id="@c.Id"
                                        data-phone="@c.Phone"
                                        data-address="@c.Address"
                                        data-gov="@c.Gov"
                                        data-district="@c.District"
                                        data-area="@c.Area"
                                        data-credit="@c.Credit">
                                </option>
                            }
                        }
                    </datalist>
                    <datalist id="productsList" hidden aria-hidden="true">
                        @if (ViewBag.ProductsAuto != null)
                        {
                            foreach (var p in ViewBag.ProductsAuto)
                            {
                                <option value="@p.Name"
                                        data-id="@p.Id"
                                        data-code="@p.Id"
                                        data-generic="@p.GenericName"
                                        data-company="@p.Company"
                                        data-price="@p.PriceRetail"
                                        data-hasquota="@(p.HasQuota ? "true" : "false")">
                                </option>
                            }
                        }
                    </datalist>

                </div> @* ✅ نهاية PI_BodyHost *@

            </div> @* نهاية العمود الرئيسي *@


          

        </div> @* نهاية row *@
    </div> @* نهاية container *@
</div> @* نهاية invoice-page *@









    <!-- =========================================================
         ERP — منطقة طباعة فاتورة المشتريات (ثابت معتمد)
         ملاحظة: الـ site.css عندك بيطبع فقط .erp-print-area
    ========================================================= -->
    <div id="piPrintArea" class="erp-print-area print-only erp-print-page-portrait">

        <!-- ===== هيدر الطباعة (قابل للتخصيص لاحقاً: لوجو/بيانات شركة) ===== -->
        <div class="mb-3">
            <div class="d-flex justify-content-between align-items-start">
                <div class="small text-muted" id="piPrintNow"></div>

                <div class="text-center">
                    @* <div class="fw-bold">فاتورة مشتريات</div> *@
                    <div class="small text-muted" id="piPrintTitle"></div>
                </div>

                <div class="text-end">
                    <div class="fw-bold">شركة الهدى</div>
                    <div class="small text-muted">العنوان / الهاتف</div>
                </div>
            </div>

            <hr class="my-2" />

            <div class="row g-2 small">
                <div class="col-6">رقم الفاتورة: <strong id="piPrintInvoiceNo"></strong></div>
                <div class="col-6 text-end">التاريخ: <strong id="piPrintInvoiceDate"></strong></div>

                <div class="col-6">المورد: <strong id="piPrintSupplier"></strong></div>
                <div class="col-6 text-end">المخزن: <strong id="piPrintWarehouse"></strong></div>
            </div>
        </div>

        <!-- ===== السطور ===== -->
        <div id="piPrintLinesWrap"></div>

        @* <hr class="my-3" /> *@

        <!-- ===== الإجماليات ===== -->
        <div id="piPrintTotalsWrap"></div>

    </div>
</div>












@section Scripts {
    <script>
        // =========================================================
        // رسائل عابرة (Toast) — خارج كارت الإجراءات، مثل طلب الشراء
        // =========================================================
        function showToast(text, type, durationMs) {
            if (!text) return;
            if (typeof ERP !== 'undefined' && typeof ERP.showToast === 'function') {
                ERP.showToast(text, type, durationMs);
                return;
            }
            var container = document.getElementById('piToastContainer');
            if (!container) return;
            type = type || 'muted';
            var ms = typeof durationMs === 'number' && durationMs >= 0 ? durationMs : 4000;
            var el = document.createElement('div');
            el.className = 'pi-toast text-' + type;
            el.textContent = text;
            container.appendChild(el);
            setTimeout(function () {
                el.style.opacity = '0';
                el.style.transition = 'opacity 0.25s ease';
                setTimeout(function () {
                    if (el.parentNode) el.parentNode.removeChild(el);
                }, 250);
            }, ms);
        }

        // =========================================================
        // (A) أوتوكومبليت المورد (اسم ⇐⇒ كود + بيانات)
        // =========================================================
        (function () {

            // بوكسات بيانات المورد
            const custNameInput      = document.getElementById('CustomerNameInput');    // متغير: اسم المورد
            const custCodeInput      = document.getElementById('CustomerCodeDisplay');  // متغير: كود المورد الظاهر
            const custPhoneInput     = document.getElementById('CustomerPhone');        // متغير: الهاتف
            const custGovInput       = document.getElementById('CustomerGovernorate');  // متغير: المحافظة
            const custDistrictInput  = document.getElementById('CustomerDistrict');     // متغير: الحي
            const custAreaInput      = document.getElementById('CustomerArea');         // متغير: المنطقة
            const custAddressInput   = document.getElementById('CustomerAddress');      // متغير: العنوان
            const custCreditInput    = document.getElementById('CustomerCredit');       // متغير: الحد الائتماني
            const custHiddenId       = document.getElementById('CustomerId');           // متغير: CustomerId (مخفي)

            // الـ datalist الخاصة بالموردين (مخفي كمصدر بيانات فقط)
            const custDataList = document.getElementById('customersList');

            if (!custDataList) {
                console.warn('⚠️ Supplier datalist not found for CustomerNameInput');
                return; // نخرج من جزء المورد فقط
            }

            // =========================================================
            // حد أقصى لعرض اقتراحات الأسماء (حتى 10) — مثل فاتورة المبيعات
            // =========================================================
            const CUSTOMER_LIST_MAX = 10;
            const allSupplierOptions = Array.from(custDataList.options || []);

            function getFilteredSupplierOptions(search) {
                const q = normalizeSupplierText(search);
                if (!q) return allSupplierOptions.slice(0, CUSTOMER_LIST_MAX);

                // نفس منطق البوكس في المبيعات: نركّز على أول كلمة
                const q1 = q.indexOf(' ') !== -1 ? (q.split(/\s+/)[0] || q) : q;

                const out = [];
                for (let i = 0; i < allSupplierOptions.length && out.length < CUSTOMER_LIST_MAX; i++) {
                    const name = normalizeSupplierText(allSupplierOptions[i].value);
                    if (!name) continue;
                    if (name.indexOf(q1) !== -1) out.push(allSupplierOptions[i]);
                }
                return out;
            }

            // =========================================================
            // دروب داون مخصص لاسم المورد (محدود حتى 10)
            // =========================================================
            const supplierDropdownWrap = document.getElementById('supplierDropdownWrap');
            const supplierDropdownList = document.getElementById('supplierDropdownList');
            const supplierDropdownArrow = document.getElementById('supplierDropdownArrow');

            let supplierDropdownHighlightedIndex = -1;
            let supplierDropdownSelectableSuppliers = [];
            let isSelectingSupplier = false;

            function positionSupplierDropdownList() {
                if (!supplierDropdownList || !supplierDropdownWrap) return;
                if (supplierDropdownList.getAttribute('data-open') !== 'true') return;

                const r = supplierDropdownWrap.getBoundingClientRect();
                supplierDropdownList.style.width = r.width + 'px';
                supplierDropdownList.style.top = r.bottom + 'px';
                supplierDropdownList.style.left = r.left + 'px';
            }

            function closeSupplierDropdown() {
                if (supplierDropdownList) {
                    supplierDropdownList.setAttribute('data-open', 'false');
                    supplierDropdownList.innerHTML = '';
                }
                supplierDropdownHighlightedIndex = -1;
                supplierDropdownSelectableSuppliers = [];
            }

            function setSupplierDropdownHighlight(idx) {
                if (!supplierDropdownList) return;
                if (idx < 0 || idx >= supplierDropdownSelectableSuppliers.length) return;

                const children = supplierDropdownList.querySelectorAll('.product-dropdown-item');
                children.forEach(function (el, i) {
                    el.classList.toggle('product-dropdown-item-active', i === idx);
                });
                supplierDropdownHighlightedIndex = idx;

                try {
                    children[idx]?.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                } catch { }
            }

            function openSupplierDropdown() {
                if (!supplierDropdownList || !supplierDropdownWrap || !custNameInput) return;

                const searchTermRaw = (custNameInput.value || '').trim();
                let searchTerm = searchTermRaw;
                if (searchTerm.indexOf(' ') !== -1) searchTerm = searchTerm.split(/\s+/)[0] || searchTerm;

                const list = getFilteredSupplierOptions(searchTerm);

                supplierDropdownList.innerHTML = '';
                supplierDropdownSelectableSuppliers = [];

                let highlightIdx = -1;
                const currentVal = (custNameInput.value || '').trim();
                const currentNorm = normalizeSupplierText(currentVal);

                if (list.length > 0) {
                    for (let i = 0; i < list.length; i++) {
                        if (normalizeSupplierText(list[i].value || '').trim() === currentNorm) {
                            highlightIdx = i;
                            break;
                        }
                    }
                    if (highlightIdx === -1) highlightIdx = 0;
                }

                if (list.length === 0) {
                    const empty = document.createElement('div');
                    empty.className = 'product-dropdown-item text-muted py-2 px-3 small';
                    empty.textContent = searchTermRaw ? 'لا توجد نتائج' : 'اكتب للبحث ثم انزل بالسهم ▼ واختر (10 كحد أقصى)';
                    supplierDropdownList.appendChild(empty);
                    supplierDropdownHighlightedIndex = -1;
                } else {
                    list.forEach(function (opt, idx) {
                        const it = document.createElement('div');
                        it.className = 'product-dropdown-item py-2 px-3' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                        it.setAttribute('role', 'option');
                        it.textContent = (opt.value || '').trim();
                        // منع تغيير الفوكس عند الضغط (عشان سهم لأسفل بعد الاختيار يفتح القائمة)
                        it.addEventListener('mousedown', function (ev) {
                            ev.preventDefault();
                        });
                        it.addEventListener('click', function (e) {
                            e.preventDefault();
                            isSelectingSupplier = true;
                            fillSupplierFromOption(opt);
                            custNameInput.value = (opt.value || '').trim();
                            closeSupplierDropdown();
                            setTimeout(function () {
                                custNameInput?.focus();
                                try { custNameInput?.setSelectionRange?.(custNameInput.value.length, custNameInput.value.length); } catch { }
                                isSelectingSupplier = false;
                            }, 0);
                        });
                        supplierDropdownList.appendChild(it);
                        supplierDropdownSelectableSuppliers.push(opt);
                    });
                    supplierDropdownHighlightedIndex = highlightIdx;
                }

                supplierDropdownList.setAttribute('data-open', 'true');
                positionSupplierDropdownList();
            }

            function selectHighlightedSupplier(keepOpen) {
                if (!supplierDropdownSelectableSuppliers.length) return false;
                if (supplierDropdownHighlightedIndex < 0 || supplierDropdownHighlightedIndex >= supplierDropdownSelectableSuppliers.length) return false;

                const selected = supplierDropdownSelectableSuppliers[supplierDropdownHighlightedIndex];
                isSelectingSupplier = true;
                fillSupplierFromOption(selected);
                custNameInput.value = (selected.value || '').trim();

                if (!keepOpen) closeSupplierDropdown();
                setTimeout(function () {
                    custNameInput?.focus();
                    try { custNameInput?.setSelectionRange?.(custNameInput.value.length, custNameInput.value.length); } catch { }
                    isSelectingSupplier = false;
                }, 0);
                return true;
            }

            // فتح الدروب مع الكتابة فقط
            if (custNameInput && !custNameInput.dataset.suppliersDropdownBound) {
                custNameInput.dataset.suppliersDropdownBound = '1';
                custNameInput.addEventListener('input', function () {
                    if (isSelectingSupplier) return;
                    openSupplierDropdown();
                });
            }

            // فتح الدروب مع زر ▼
            if (supplierDropdownArrow) {
                supplierDropdownArrow.addEventListener('click', function (ev) {
                    ev.preventDefault();
                    custNameInput?.focus();
                    openSupplierDropdown();
                });
            }

            // إغلاق عند الضغط خارج البوكس
            if (supplierDropdownWrap) {
                document.body.addEventListener('click', function (ev) {
                    if (!supplierDropdownWrap.contains(ev.target)) closeSupplierDropdown();
                });
            }

            // دالة: توحيد نص المورد (وتجاهل الألف في أول الكلمة)
            function normalizeSupplierText(txt) {
                return (txt || '')
                    .trim()
                    .toLowerCase()
                    .replace(/^[اأإآ]/, '')
                    .replace(/\s+/g, ' ');
            }

            // دالة: البحث عن مورد بالاسم (تطابق كامل)
            function findSupplierByName(name) {
                const search = normalizeSupplierText(name);
                if (!search) return null;

                const opts = allSupplierOptions;
                for (let i = 0; i < opts.length; i++) {
                    if (normalizeSupplierText(opts[i].value) === search) return opts[i];
                }
                return null;
            }

            // دالة: البحث عن مورد بالكود (data-id)
            function findSupplierByCode(code) {
                const search = (code || '').toString().trim();
                if (!search) return null;

                const opts = allSupplierOptions;
                for (let i = 0; i < opts.length; i++) {
                    const optId = (opts[i].getAttribute('data-id') || '').toString();
                    if (optId === search) return opts[i];
                }
                return null;
            }

            // دالة: تعبئة كل بوكسات المورد من <option> واحد
            function fillSupplierFromOption(opt) {

                // لو مفيش مورد مطابق → نفرّغ
                if (!opt) {
                    if (custHiddenId)      custHiddenId.value      = '';
                    if (custCodeInput)     custCodeInput.value     = '';
                    if (custNameInput)     custNameInput.value     = '';
                    if (custPhoneInput)    custPhoneInput.value    = '';
                    if (custGovInput)      custGovInput.value      = '';
                    if (custDistrictInput) custDistrictInput.value = '';
                    if (custAreaInput)     custAreaInput.value     = '';
                    if (custAddressInput)  custAddressInput.value  = '';
                    if (custCreditInput)   custCreditInput.value   = '';
                    return;
                }

                // قراءة البيانات من الـ option
                const id       = opt.getAttribute('data-id')       || ''; // متغير: كود المورد الحقيقي
                const name     = opt.value                         || ''; // متغير: اسم المورد
                const phone    = opt.getAttribute('data-phone')    || ''; // متغير: الهاتف
                const address  = opt.getAttribute('data-address')  || ''; // متغير: العنوان
                const gov      = opt.getAttribute('data-gov')      || ''; // متغير: المحافظة
                const district = opt.getAttribute('data-district') || opt.getAttribute('data-District') || ''; // متغير: الحي
                const area     = opt.getAttribute('data-area')     || opt.getAttribute('data-Area')     || ''; // متغير: المنطقة
                const credit   = opt.getAttribute('data-credit')   || opt.getAttribute('data-Credit')   || ''; // متغير: الحد الائتماني

                if (custHiddenId)  custHiddenId.value  = id;
                if (custCodeInput) custCodeInput.value = id;

                if (custNameInput)     custNameInput.value     = name;
                if (custPhoneInput)    custPhoneInput.value    = phone;
                if (custGovInput)      custGovInput.value      = gov;
                if (custDistrictInput) custDistrictInput.value = district;
                if (custAreaInput)     custAreaInput.value     = area;
                if (custAddressInput)  custAddressInput.value  = address;
                if (custCreditInput)   custCreditInput.value   = credit;
            }

            // اسم المورد: change + Enter
            if (custNameInput) {
                custNameInput.addEventListener('change', () => {
                    fillSupplierFromOption(findSupplierByName(custNameInput.value));
                });
            }

            // كود المورد: change + Enter
            if (custCodeInput) {
                custCodeInput.addEventListener('change', () => {
                    fillSupplierFromOption(findSupplierByCode(custCodeInput.value));
                });

                custCodeInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        fillSupplierFromOption(findSupplierByCode(custCodeInput.value));
                    }
                });
            }

            // عند فتح فاتورة قديمة: CustomerId موجود → املأ البيانات
            if (custHiddenId && custHiddenId.value) {
                fillSupplierFromOption(findSupplierByCode(custHiddenId.value));
            }

            // =========================================================
            // Enter على اسم المورد: الانتقال إلى زر الحفظ ثم الضغط عليه
            // =========================================================
            let isSaveButtonFocused = false; // متغير: هل زر الحفظ في حالة focus

            custNameInput?.addEventListener('keydown', function(e) {
                const isOpen = supplierDropdownList && supplierDropdownList.getAttribute('data-open') === 'true';

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    isSaveButtonFocused = false;

                    if (!isOpen) {
                        openSupplierDropdown();
                    }

                    const len = supplierDropdownSelectableSuppliers.length || 0;
                    if (len > 0) {
                        const next = Math.min(supplierDropdownHighlightedIndex + 1, len - 1);
                        setSupplierDropdownHighlight(next);
                    }
                    return;
                }

                if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    isSaveButtonFocused = false;

                    if (!isOpen) {
                        openSupplierDropdown();
                    }

                    const len = supplierDropdownSelectableSuppliers.length || 0;
                    if (len > 0) {
                        const prev = Math.max(supplierDropdownHighlightedIndex - 1, 0);
                        setSupplierDropdownHighlight(prev);
                    }
                    return;
                }

                if (e.key === 'Enter') {
                    e.preventDefault();

                    // Enter داخل الدروب = اختيار عميل + غلق الدروب
                    if (isOpen && supplierDropdownHighlightedIndex >= 0 && supplierDropdownSelectableSuppliers.length > 0) {
                        selectHighlightedSupplier(false);
                        isSaveButtonFocused = false;
                        return;
                    }

                    // لو الدروب مقفول: حاول تعبئة من النص
                    fillSupplierFromOption(findSupplierByName(custNameInput.value));

                    const saveBtn = document.getElementById('btnSaveInvoiceHeader');
                    if (!saveBtn) return;

                    if (!isSaveButtonFocused) {
                        // المرة الأولى: الانتقال إلى زر الحفظ
                        isSaveButtonFocused = true;
                        saveBtn.focus();
                    } else {
                        // المرة الثانية: الضغط على زر الحفظ
                        isSaveButtonFocused = false;
                        saveBtn.click();
                    }
                    return;
                }

                // أي مفتاح آخر: إعادة تعيين الحالة
                isSaveButtonFocused = false;
            });

            // إعادة تعيين الحالة عند blur من حقل اسم المورد
            custNameInput?.addEventListener('blur', function() {
                isSaveButtonFocused = false;
                try { closeSupplierDropdown(); } catch { }
            });

        })();

        // =========================================================
        // (B) أوتوكومبليت الصنف + كارت بياناته + التابات + إضافة سطر
        // =========================================================
        function initProductSearch() {
            console.log('🚀 بدء تحميل/إعادة تحميل كود الأصناف...');

            // 1) عناصر سطر الصنف في الفاتورة
            const prodCodeInput   = document.getElementById('ProdCodeInput');     // متغير: كود الصنف للبحث
            const prodNameInput   = document.getElementById('ProdNameInput');     // متغير: اسم الصنف (أوتوكومبليت)
            const prodPriceInput  = document.getElementById('ProdPriceInput');    // متغير: سعر الجمهور
            const prodQtyInput    = document.getElementById('ProdQtyInput');      // متغير: الكمية
            const prodDisc1Input  = document.getElementById('ProdDisc1Input');    // متغير: خصم الشراء %
            const prodBatchInput  = document.getElementById('ProdBatchInput');    // متغير: الباتش
            const prodExpiryInput = document.getElementById('ProdExpiryInput');   // متغير: تاريخ الصلاحية
            const prodHiddenId    = document.getElementById('ProdId');            // متغير: المعرّف الداخلي للصنف
            const btnAddLine      = document.getElementById('btnAddInvoiceLine'); // متغير: زر إضافة السطر

            // تنسيق الصلاحية عند الخروج من الحقل (شهر+سنة بدون شرطة -> شهر/سنة) — مثل طلب الشراء
            if (prodExpiryInput && typeof formatExpiryWithSlash === 'function') {
                prodExpiryInput.addEventListener('blur', function () {
                    if (this.value) this.value = formatExpiryWithSlash(this.value);
                });
            }

            console.log('📋 العناصر:', {
                prodCodeInput: !!prodCodeInput,
                prodNameInput: !!prodNameInput,
                prodPriceInput: !!prodPriceInput,
                prodQtyInput: !!prodQtyInput,
                prodHiddenId: !!prodHiddenId,
                btnAddLine: !!btnAddLine
            });

            // 2) عناصر كارت بيانات الصنف
            const prodQtyWarehouse = document.getElementById('ProdQtyCurrentWarehouse'); // متغير: كمية هذا المخزن
            const prodQtyAll       = document.getElementById('ProdQtyAllWarehouses');   // متغير: إجمالي الكمية
            const prodQuotaText    = document.getElementById('ProdQuotaText');          // متغير: هل له كوتة؟
            const prodWeightedDisc = document.getElementById('ProdWeightedDiscount');   // متغير: الخصم المرجّح
            const prodAltSelect    = document.getElementById('AlternativeProducts');    // متغير: قائمة البدائل

            // 3) datalist الخاصة بالأصناف (مخفي — مصدر بيانات القائمة المخصصة)
            const prodDataList = document.getElementById('productsList');

            if (!prodDataList) {
                console.error('❌ لم يتم العثور على قائمة الأصناف (productsList) في صفحة فاتورة المشتريات.');
            } else {
                console.log('✅ تم العثور على datalist، عدد الأصناف:', prodDataList.options.length);
            }

            // =========================================================
            // دوال مساعدة (أرقام + توحيد نص)
            // =========================================================

            // دالة: توحيد النص (تجاهل الألف + إزالة مسافات مكررة + توحيد الأرقام)
            function normalizeText(txt) {
                if (!txt) return '';
                return txt
                    .trim()
                    .toLowerCase()
                    // توحيد الألف (أ، إ، آ، ا)
                    .replace(/[أإآ]/g, 'ا')
                    // إزالة مسافات مكررة
                    .replace(/\s+/g, ' ')
                    // إزالة مسافات في البداية والنهاية
                    .trim();
            }

            // دالة: تحويل النص لرقم (decimal) بأمان
            function parseDecimalSafe(val) {
                const s = (val || '').toString().trim().replace(',', '.');
                const n = parseFloat(s);
                return isNaN(n) ? 0 : n;
            }

            // دالة: تنسيق رقم (رقمين عشريين)
            function fmt2(val) {
                return parseDecimalSafe(val).toFixed(2);
            }

            // =========================================================
            // البحث عن صنف بالاسم / بالكود داخل datalist
            // =========================================================

            function findProductByName(name) {
                const search = normalizeText(name);
                if (!search) return null;

                const opts = prodDataList.options;
                if (!opts || opts.length === 0) return null;

                // 1) تطابق تام
                for (let i = 0; i < opts.length; i++) {
                    const optText = normalizeText(opts[i].value);
                    if (optText === search) return opts[i];
                }

                // 2) يبدأ بـ (StartsWith فقط — لا Contains)
                for (let i = 0; i < opts.length; i++) {
                    const optText = normalizeText(opts[i].value);
                    if (optText.startsWith(search)) return opts[i];
                }

                return null;
            }

            function findProductByCode(code) {
                const search = (code || '').toString().trim();
                if (!search) return null;

                const opts = prodDataList.options;
                for (let i = 0; i < opts.length; i++) {
                    const idAttr   = (opts[i].getAttribute('data-id')   || '').toString();
                    const codeAttr = (opts[i].getAttribute('data-code') || '').toString();
                    if (idAttr === search || codeAttr === search) return opts[i];
                }
                return null;
            }

            // =========================================================
            // تعبئة بيانات الصنف من <option>
            // =========================================================
            function fillProductFromOption(opt) {
                console.log('🔄 fillProductFromOption called with:', opt ? opt.value : 'null');

                // لو مفيش صنف مطابق → نفرّغ
                if (!opt) {
                    console.warn('⚠️ fillProductFromOption: لم يتم العثور على صنف مطابق');
                    if (prodHiddenId)    prodHiddenId.value    = '';
                    if (prodCodeInput)   prodCodeInput.value   = '';
                    // لا نمسح اسم الصنف المكتوب (نتركه للمستخدم)
                    // if (prodNameInput)   prodNameInput.value   = '';
                    if (prodPriceInput)  {
                        prodPriceInput.value = '';
                        console.log('🧹 تم مسح السعر');
                    }

                    if (prodQuotaText)    prodQuotaText.value    = 'بدون كوتة';
                    if (prodWeightedDisc) prodWeightedDisc.value = '0';

                    if (prodQtyWarehouse) prodQtyWarehouse.value = '0';
                    if (prodQtyAll)       prodQtyAll.value       = '0';

                    if (prodAltSelect) {
                        prodAltSelect.innerHTML = '<option value="">لا توجد بدائل</option>';
                    }
                    return;
                }

                console.log('✅ fillProductFromOption: تم العثور على صنف', opt.value);

                // قراءة البيانات من data-*
                const id       = opt.getAttribute('data-id')      || ''; // متغير: ProdId
                const code     = opt.getAttribute('data-code')    || id; // متغير: كود ظاهر (قد يساوي id)
                const name     = opt.value                        || ''; // متغير: اسم الصنف
                const generic  = opt.getAttribute('data-generic') || ''; // متغير: الاسم العلمي
                const hasQuota = (opt.getAttribute('data-hasquota') === 'true'); // متغير: هل له كوتة؟
                let priceRaw   = opt.getAttribute('data-price')   || '0'; // متغير: السعر كنص

                // معالجة السعر
                priceRaw = priceRaw.toString().replace(',', '.');
                let price = parseFloat(priceRaw);
                if (isNaN(price)) price = 0;

                if (prodHiddenId)  prodHiddenId.value  = id;
                if (prodCodeInput) prodCodeInput.value = code;
                if (prodNameInput) prodNameInput.value = name;
                if (prodPriceInput) {
                    prodPriceInput.value = price.toFixed(2);
                    // ✅ إطلاق event للتأكد من تحديث القيمة حتى لو كان الحقل readOnly
                    prodPriceInput.dispatchEvent(new Event('input', { bubbles: true }));
                    prodPriceInput.dispatchEvent(new Event('change', { bubbles: true }));
                }

                if (prodQuotaText) {
                    prodQuotaText.value = hasQuota ? 'له كوتة' : 'بدون كوتة';
                }

                // حالياً: الخصم المرجّح = 0 (هنربطه بالسياسات لاحقاً)
                if (prodWeightedDisc) {
                    prodWeightedDisc.value = '0';
                }

                // بدائل الصنف حسب الاسم العلمي
                if (prodAltSelect && generic) {
                    loadAlternativeProducts(id);
                } else if (prodAltSelect) {
                    prodAltSelect.innerHTML = '<option value="">لا توجد بدائل</option>';
                }
            }

            // =========================================================
            // تحميل البدائل من الكنترولر
            // =========================================================
            function loadAlternativeProducts(prodId) {
                if (!prodId || !prodAltSelect) return;

                const url = '@Url.Action("GetAlternativeProducts", "PurchaseInvoices")'
                    + '?prodId=' + encodeURIComponent(prodId);

                prodAltSelect.innerHTML = '<option value="">... جاري تحميل البدائل</option>';

                fetch(url)
                    .then(r => r.ok ? r.json() : [])
                    .then(data => {
                        prodAltSelect.innerHTML = '<option value="">اختر بديلاً (للمشاهدة فقط)</option>';

                        if (!data || !data.length) {
                            prodAltSelect.innerHTML += '<option value="">لا توجد بدائل</option>';
                            return;
                        }

                        data.forEach(p => {
                            const op = document.createElement('option');
                            op.value = p.id;
                            op.textContent = `${p.name || ''} — ${p.company || ''} — ${p.price || 0}`;
                            op.setAttribute('data-id', p.id);
                            op.setAttribute('data-price', p.price || 0);
                            prodAltSelect.appendChild(op);
                        });
                    })
                    .catch(err => {
                        console.error('❌ خطأ في تحميل بدائل الصنف:', err);
                        prodAltSelect.innerHTML = '<option value="">خطأ في تحميل البدائل</option>';
                    });
            }

            // =========================================================
            // Events: اسم الصنف / كود الصنف
            // =========================================================
            if (prodNameInput) {
                const productDropdownWrap = document.getElementById('productDropdownWrap');
                const productDropdownList = document.getElementById('productDropdownList');
                const productDropdownArrow = document.getElementById('productDropdownArrow');

                const PRODUCT_LIST_MAX = 10;
                var productDropdownHighlightedIndex = -1;
                var productDropdownSelectableItems = [];
                var productDropdownSelectableOptions = [];
                var productDropdownPendingMoveToQuantity = false;

                function getFilteredProductOptions(search, max) {
                    if (!prodDataList || !prodDataList.options) return [];
                    var q = normalizeText(search);
                    if (!q) return Array.from(prodDataList.options || []).slice(0, (max || PRODUCT_LIST_MAX));

                    if (q.indexOf(' ') !== -1) q = q.split(/\s+/)[0] || q;

                    var opts = prodDataList.options;
                    var out = [];
                    for (var i = 0; i < opts.length && out.length < (max || PRODUCT_LIST_MAX); i++) {
                        var opt = opts[i];
                        var name = normalizeText(opt.value || '');
                        var code = (opt.getAttribute('data-code') || opt.getAttribute('data-id') || '').toString().trim();
                        if (!q || name.indexOf(q) !== -1 || (code && code.indexOf(q) !== -1)) out.push(opt);
                    }
                    return out;
                }

                function positionProductDropdownList() {
                    if (!productDropdownList || !productDropdownWrap) return;
                    if (productDropdownList.getAttribute('data-open') !== 'true') return;

                    var r = productDropdownWrap.getBoundingClientRect();
                    productDropdownList.style.width = r.width + 'px';
                    productDropdownList.style.top = r.bottom + 'px';
                    productDropdownList.style.left = r.left + 'px';
                }

                function closeProductDropdown() {
                    if (productDropdownList) {
                        productDropdownList.setAttribute('data-open', 'false');
                        productDropdownList.innerHTML = '';
                    }
                    productDropdownHighlightedIndex = -1;
                    productDropdownSelectableItems = [];
                    productDropdownSelectableOptions = [];
                    productDropdownPendingMoveToQuantity = false;
                }

                function openProductDropdown() {
                    if (!productDropdownList || !productDropdownWrap) return;

                    var searchTerm = (prodNameInput.value || '').trim();
                    if (searchTerm.indexOf(' ') !== -1) searchTerm = searchTerm.split(/\s+/)[0] || searchTerm;

                    var list = getFilteredProductOptions(searchTerm, PRODUCT_LIST_MAX);
                    productDropdownList.innerHTML = '';
                    productDropdownSelectableItems = [];
                    productDropdownSelectableOptions = [];

                    var currentVal = (prodNameInput.value || '').trim();
                    var highlightIdx = 0;
                    if (list.length > 0) {
                        for (var i = 0; i < list.length; i++) {
                            if (normalizeText((list[i].value || '').trim()) === normalizeText(currentVal)) { highlightIdx = i; break; }
                        }
                    }

                    if (list.length === 0) {
                        var empty = document.createElement('div');
                        empty.className = 'product-dropdown-item text-muted py-2 px-3 small';
                        empty.textContent = prodNameInput.value ? 'لا توجد نتائج' : 'اكتب للبحث ثم انزل بالسهم ▼ واختر (10 كحد أقصى)';
                        productDropdownList.appendChild(empty);
                        productDropdownHighlightedIndex = -1;
                    } else {
                        list.forEach(function (opt, idx) {
                            var id = (opt.getAttribute('data-id') || opt.getAttribute('data-code') || '').toString();
                            var name = (opt.value || '').trim();

                            var it = document.createElement('div');
                            it.className = 'product-dropdown-item py-2 px-3' + (idx === highlightIdx ? ' product-dropdown-item-active' : '');
                            it.setAttribute('role', 'option');
                            it.setAttribute('data-id', id);
                            it.textContent = name;

                            it.addEventListener('click', function (e) {
                                e.preventDefault();
                                fillProductFromOption(opt);
                                prodNameInput.value = name;
                                closeProductDropdown();
                            });

                            productDropdownList.appendChild(it);
                            productDropdownSelectableItems.push(it);
                            productDropdownSelectableOptions.push(opt);
                        });

                        productDropdownHighlightedIndex = highlightIdx;
                    }

                    productDropdownList.setAttribute('data-open', 'true');
                    positionProductDropdownList();
                }

                function setProductDropdownHighlight(idx) {
                    if (idx < 0 || idx >= productDropdownSelectableItems.length) return;
                    productDropdownSelectableItems.forEach(function (el, i) {
                        el.classList.toggle('product-dropdown-item-active', i === idx);
                    });
                    productDropdownHighlightedIndex = idx;
                    try {
                        productDropdownSelectableItems[idx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                    } catch { }
                }

                function selectHighlightedProduct(keepOpen) {
                    if (productDropdownHighlightedIndex < 0 || productDropdownHighlightedIndex >= productDropdownSelectableOptions.length) return false;
                    var opt = productDropdownSelectableOptions[productDropdownHighlightedIndex];
                    if (!opt) return false;

                    fillProductFromOption(opt);
                    prodNameInput.value = (opt.value || '').trim();

                    if (!keepOpen) closeProductDropdown();
                    return true;
                }

                // فتح القائمة: فقط مع الكتابة (input) أو مع السهم لتحت (ArrowDown) / زر ▼
                // - لتجنب فتح القائمة بمجرد الفوكس عند (حفظ/إضافة سطر) أو عند النقر داخل الحقل.
                prodNameInput.addEventListener('input', function () { openProductDropdown(); });

                // إغلاق + تعبئة عند الخروج
                prodNameInput.addEventListener('blur', function () {
                    setTimeout(function () {
                        closeProductDropdown();
                        fillProductFromOption(findProductByName(prodNameInput.value));
                    }, 180);
                });

                // أسهم/إنتر
                prodNameInput.addEventListener('keydown', function (e) {
                    var isOpen = productDropdownList && productDropdownList.getAttribute('data-open') === 'true';

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        productDropdownPendingMoveToQuantity = false;
                        if (isOpen && productDropdownSelectableItems.length > 0) {
                            var next = Math.min(productDropdownHighlightedIndex + 1, productDropdownSelectableItems.length - 1);
                            setProductDropdownHighlight(next);
                        } else {
                            openProductDropdown();
                        }
                        return;
                    }

                    if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        productDropdownPendingMoveToQuantity = false;
                        if (isOpen && productDropdownSelectableItems.length > 0) {
                            var prev = Math.max(productDropdownHighlightedIndex - 1, 0);
                            setProductDropdownHighlight(prev);
                        }
                        return;
                    }

                    if (e.key === 'Enter') {
                        // Enter الثاني بعد اختيار الصنف: نقل للكمية مباشرة (حتى لو القائمة قفلت)
                        if (productDropdownPendingMoveToQuantity) {
                            e.preventDefault();
                            closeProductDropdown();
                            productDropdownPendingMoveToQuantity = false;
                            if (prodQtyInput) { prodQtyInput.focus(); prodQtyInput.select && prodQtyInput.select(); }
                            return;
                        }

                        // Enter الأول: اختيار الصنف + قفل القائمة فوراً
                        if (isOpen && productDropdownSelectableItems.length > 0) {
                            e.preventDefault();
                            selectHighlightedProduct(false); // close
                            productDropdownPendingMoveToQuantity = true;
                            return;
                        }
                    }
                });

                // إغلاق عند الضغط خارج الـ wrap
                if (productDropdownWrap && !productDropdownWrap.dataset.boundProductDropdown) {
                    productDropdownWrap.dataset.boundProductDropdown = '1';
                    document.body.addEventListener('click', function (ev) {
                        if (!productDropdownWrap.contains(ev.target)) closeProductDropdown();
                    });
                }

                // فتح عند الضغط على الـ wrap أو السهم
                if (productDropdownWrap) {
                    productDropdownWrap.addEventListener('click', function (ev) {
                        if (!ev.target.closest('#productDropdownList')) {
                            prodNameInput.focus();
                            // لا نفتح القائمة هنا؛ تفتح بالكتابة أو ArrowDown أو زر ▼
                        }
                    });
                }

                if (productDropdownArrow) {
                    productDropdownArrow.addEventListener('click', function (ev) {
                        ev.preventDefault();
                        prodNameInput.focus();
                        openProductDropdown();
                    });
                }
            } else {
                console.error('❌ prodNameInput غير موجود!');
            }

            if (prodCodeInput) {
                prodCodeInput.addEventListener('change', function () {
                    const found = findProductByCode(this.value);
                    fillProductFromOption(found);
                });

                prodCodeInput.addEventListener('blur', function () {
                    const found = findProductByCode(this.value);
                    fillProductFromOption(found);
                });
            }

            // =========================================================
            // قفل / فتح سعر الجمهور (بالضغط على اللابل)
            // =========================================================
            const priceLabel     = document.getElementById('ProdPriceLabel');       // متغير: Label السعر
            const priceLockState = document.getElementById('ProdPriceLockState');   // متغير: (مغلق/مفتوح)
            let priceLocked = true; // متغير: حالة قفل السعر

            function applyPriceLockUI() {
                if (!prodPriceInput) return;

                prodPriceInput.readOnly = priceLocked;

                if (priceLocked) {
                    prodPriceInput.classList.add('bg-light', 'text-muted');
                    if (priceLockState) priceLockState.textContent = '(مغلق)';
                } else {
                    prodPriceInput.classList.remove('bg-light', 'text-muted');
                    if (priceLockState) priceLockState.textContent = '(مفتوح)';
                }
            }

            applyPriceLockUI();

            if (priceLabel) {
                priceLabel.style.cursor = 'pointer';
                priceLabel.addEventListener('click', function () {
                    priceLocked = !priceLocked;
                    applyPriceLockUI();
                });
            }

            // =========================================================
            // قفل / فتح خصم الشراء (بالضغط على اللابل)
            // =========================================================
            const disc1Label     = document.getElementById('ProdDisc1Label');      // متغير: Label الخصم
            const disc1LockState = document.getElementById('ProdDisc1LockState');  // متغير: (مغلق/مفتوح)
            let disc1Locked = false; // متغير: حالة قفل الخصم

            function applyDisc1LockUI() {
                if (!prodDisc1Input) return;

                prodDisc1Input.readOnly = disc1Locked;

                if (disc1Locked) {
                    prodDisc1Input.classList.add('bg-light', 'text-muted');
                    if (disc1LockState) disc1LockState.textContent = '(مغلق)';
                } else {
                    prodDisc1Input.classList.remove('bg-light', 'text-muted');
                    if (disc1LockState) disc1LockState.textContent = '(مفتوح)';
                }
            }

            applyDisc1LockUI();

            if (disc1Label) {
                disc1Label.style.cursor = 'pointer';
                disc1Label.addEventListener('click', function () {
                    disc1Locked = !disc1Locked;
                    applyDisc1LockUI();
                });
            }

            // عند الانتقال لحقل الخصم → تحديد النص بالكامل (ليستبدل الصفر عند الكتابة)
            if (prodDisc1Input) {
                prodDisc1Input.addEventListener('focus', function () {
                    if (!this.readOnly && typeof this.select === 'function') {
                        setTimeout(() => this.select(), 0);
                    }
                });
            }

            // =========================================================
            // التنقل بالإنتر (داخل كارت إضافة الصنف)
            // =========================================================
            const lineInputs = [
                prodCodeInput,
                prodNameInput,
                prodPriceInput,
                prodQtyInput,
                prodDisc1Input,
                prodBatchInput,
                prodExpiryInput
            ].filter(Boolean);

            lineInputs.forEach((input, index) => {
                // لا نحدد النص تلقائياً عند الفوكس — يسبب قفز المؤشر بين الحقول
                // Enter → يروح للحقل اللي بعده
                input.addEventListener('keydown', function (e) {
                    // لو نحن تعاملنا مع Enter داخل أوتوكومبليت الصنف — ما نكملش تنقل الحقول
                    if (e.defaultPrevented) return;
                    if (e.key !== 'Enter') return;

                    e.preventDefault();

                    try {
                        if (input === prodNameInput) {
                            fillProductFromOption(findProductByName(prodNameInput.value));
                        }
                        if (input === prodCodeInput) {
                            fillProductFromOption(findProductByCode(prodCodeInput.value));
                        }

                        // البحث عن الحقل التالي القابل للتحرير (ليس readOnly)
                        let nextIndex = index + 1;
                        let next = null;
                        
                        while (nextIndex < lineInputs.length) {
                            next = lineInputs[nextIndex];
                            // ✅ التحقق من أن الحقل قابل للتحرير (ليس readOnly)
                            if (next && !next.readOnly) {
                                break;
                            }
                            nextIndex++;
                        }

                        if (next && !next.readOnly) {
                            next.focus();
                        } else if (btnAddLine) {
                            btnAddLine.focus();
                        }
                    } catch (err) {
                        console.error('❌ خطأ في معالجة Enter:', err);
                    }
                });
            });

            // زر الإضافة: Enter يعمل Click
            if (btnAddLine) {
                btnAddLine.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        btnAddLine.click();
                    }
                });
            }








        // ===============================
        // رسم جدول السطور (هجين)
        // - لو الصنف غير مكرر: سطر واحد + بيانات + زر مسح
        // - لو الصنف مكرر (تشغيلات): سطر عنوان للصنف + سطور تشغيلات (بيانات + مسح لكل تشغيلة)
        // ===============================
        function renderGroupedLines(lines) {

            // متغير: tbody الخاص بجدول السطور
            const tbody = document.getElementById('PILinesTbody');
            if (!tbody) return;

            // تفريغ الجدول قبل الرسم
            tbody.innerHTML = '';

            // لو مفيش بيانات
            if (!Array.isArray(lines) || lines.length === 0) {
                tbody.innerHTML = `<tr><td colspan="9" class="text-center text-muted py-3">لا توجد سطور</td></tr>`;
                return;
            }

            // ===============================
            // 1) تجميع السطور حسب prodId + prodName
            // ===============================
            const map = new Map(); // متغير: Map لتجميع السطور

            lines.forEach(l => {
                const prodId = Number(l.prodId || 0); // متغير: كود الصنف
                const prodName = (l.prodName || (`صنف #${prodId}`)).toString(); // متغير: اسم الصنف
                const key = `${prodId}||${prodName}`; // متغير: مفتاح التجميع

                if (!map.has(key)) {
                    map.set(key, { prodId, prodName, lines: [] });
                }
                map.get(key).lines.push(l);
            });

            // ترتيب المجموعات بالاسم
            const groups = Array.from(map.values())
                .sort((a, b) => (a.prodName || '').localeCompare(b.prodName || '', 'ar'));

            // ===============================
            // 2) رسم كل مجموعة حسب عدد التشغيلات
            // ===============================
            groups.forEach(g => {

                // ترتيب تشغيلات الصنف حسب lineNo
                const sortedLines = (g.lines || [])
                    .slice()
                    .sort((x, y) => (Number(x.lineNo || 0) - Number(y.lineNo || 0)));

                const isMultiBatch = sortedLines.length > 1; // متغير: هل الصنف له أكثر من تشغيلة؟

                // =========================================================
                // الحالة (1): الصنف غير مكرر => سطر واحد فقط (اسم + بيانات + مسح)
                // =========================================================
                if (!isMultiBatch) {

                    const line = sortedLines[0];

                    const lineNo = line.lineNo ?? ''; // متغير: رقم السطر
                    const batchNo = line.batchNo ?? ''; // متغير: التشغيلة

                    const expiryText = line.expiryText
                        ? line.expiryText
                        : (line.expiry ? formatDateYMD(line.expiry) : ''); // متغير: الصلاحية

                    const qty = Number(line.qty || 0); // متغير: الكمية
                    const priceRetail = Number(line.priceRetail || 0); // متغير: سعر الجمهور

                    const discPct = (line.purchaseDiscountPct != null)
                        ? Number(line.purchaseDiscountPct)
                        : Number(line.discPct || 0); // متغير: الخصم %

                    const lineValue = (line.lineValue != null)
                        ? Number(line.lineValue)
                        : (qty * priceRetail * (1 - (discPct / 100))); // متغير: قيمة السطر

                    const tr = document.createElement('tr');
                    tr.setAttribute('data-line-no', lineNo);
                    tr.setAttribute('data-prodid', g.prodId);

                    tr.innerHTML = `
                        <td class="text-center">${lineNo}</td>

                        <td>
                            <strong>${escapeHtml(g.prodName)}</strong>
                            <span class="text-muted small"> | كود: ${g.prodId}</span>
                        </td>

                        <td class="text-center">${escapeHtml(batchNo)}</td>
                        <td class="text-center">${escapeHtml(expiryText)}</td>
                        <td class="text-center">${qty}</td>
                        <td class="text-center">${fmt2(priceRetail)}</td>
                        <td class="text-center">${fmt2(discPct)}</td>

                        <td class="text-center">${fmt2(lineValue)}</td>

                        <td class="text-center">
                            <button type="button"
                                    class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                    data-line-no="${lineNo}">
                                مسح
                            </button>
                        </td>
                    `;

                    tbody.appendChild(tr);
                    return;
                }

                // =========================================================
                // الحالة (2): الصنف مكرر => سطر عنوان للصنف + سطور تشغيلات تحته
                // =========================================================

                // (أ) سطر عنوان الصنف فقط (بدون بيانات وبدون زر مسح)
                const grpRow = document.createElement('tr');
                grpRow.className = 'table-light pi-group-row';
                grpRow.setAttribute('data-prodid', g.prodId);

                grpRow.innerHTML = `
                    <td class="text-center">—</td>

                    <td>
                        <strong>${escapeHtml(g.prodName)}</strong>
                        <span class="text-muted small"> | كود: ${g.prodId}</span>
                    </td>

                    <td class="text-center text-muted small">تشغيلات: ${sortedLines.length}</td>
                    <td class="text-center"></td>
                    <td class="text-center"></td>
                    <td class="text-center"></td>
                    <td class="text-center"></td>
                    <td class="text-center"></td>
                    <td class="text-center"></td>
                `;

                tbody.appendChild(grpRow);

                // (ب) سطور التشغيلات (كل تشغيلة = سطر بيانات + زر مسح)
                sortedLines.forEach(line => {

                    const lineNo = line.lineNo ?? ''; // متغير: رقم السطر
                    const batchNo = line.batchNo ?? ''; // متغير: التشغيلة

                    const expiryText = line.expiryText
                        ? line.expiryText
                        : (line.expiry ? formatDateYMD(line.expiry) : ''); // متغير: الصلاحية

                    const qty = Number(line.qty || 0); // متغير: الكمية
                    const priceRetail = Number(line.priceRetail || 0); // متغير: سعر الجمهور

                    const discPct = (line.purchaseDiscountPct != null)
                        ? Number(line.purchaseDiscountPct)
                        : Number(line.discPct || 0); // متغير: الخصم %

                    const lineValue = (line.lineValue != null)
                        ? Number(line.lineValue)
                        : (qty * priceRetail * (1 - (discPct / 100))); // متغير: قيمة السطر

                    const tr = document.createElement('tr');
                    tr.setAttribute('data-line-no', lineNo);
                    tr.setAttribute('data-prodid', g.prodId);

                    tr.innerHTML = `
                        <td class="text-center">${lineNo}</td>

                        <td class="text-muted small">↳</td>

                        <td class="text-center">${escapeHtml(batchNo)}</td>
                        <td class="text-center">${escapeHtml(expiryText)}</td>
                        <td class="text-center">${qty}</td>
                        <td class="text-center">${fmt2(priceRetail)}</td>
                        <td class="text-center">${fmt2(discPct)}</td>

                        <td class="text-center">${fmt2(lineValue)}</td>

                        <td class="text-center">
                            <button type="button"
                                    class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                    data-line-no="${lineNo}">
                                مسح
                            </button>
                        </td>
                    `;

                    tbody.appendChild(tr);

                    // ✅ نخلي الدالة Global عشان أي جزء في الصفحة يقدر ينادي عليها
                    window.renderGroupedLines = renderGroupedLines;
                });
            });
        }



        // ===============================
        // Helper: تنسيق تاريخ yyyy-MM-dd
        // ===============================
        function formatDateYMD(value) {
            try {
                const d = new Date(value);
                if (isNaN(d.getTime())) return '';
                const yyyy = d.getFullYear();
                const mm = String(d.getMonth() + 1).padStart(2, '0');
                const dd = String(d.getDate()).padStart(2, '0');
                return `${yyyy}-${mm}-${dd}`;
            } catch {
                return '';
            }
        }


                // ===============================
        // دالة: تحديث ملخص الفاتورة (البادجات)
        // ===============================
        function updateSummaryBadges(totals) {

            if (!totals) return;

            // دالة صغيرة: كتابة نص داخل عنصر لو موجود
            const setText = (id, value) => {
                const el = document.getElementById(id);
                if (el) el.textContent = value;
            };

            // =====================================
            // 1) قراءات مرنة من totals (اختلاف أسماء مفاتيح)
            // =====================================
            const totalLines = totals.totalLines ?? totals.linesCount ?? 0;     // متغير: عدد السطور
            const totalItems = totals.totalItems ?? totals.itemsCount ?? 0;     // متغير: عدد الأصناف
            const totalQty = totals.totalQty ?? totals.qtyTotal ?? 0;           // متغير: إجمالي الكمية
            const totalRetail = totals.totalRetail ?? totals.retailTotal ?? 0;  // متغير: إجمالي سعر الجمهور

            // متغير: إجمالي الخصم (لو السيرفر بيرجعه totalDiscount)
            const totalDiscount = totals.totalDiscount ?? totals.discountTotal ?? 0;

            // =====================================
            // 2) حساب الإجمالي بعد الخصم لو مش موجود
            // =====================================
            let totalAfterDiscount = totals.totalAfterDiscount;
            if (totalAfterDiscount == null) {
                totalAfterDiscount = Number(totalRetail || 0) - Number(totalDiscount || 0);
            }

            // =====================================
            // 3) الضريبة لو مش موجودة نخليها 0 (لحين ربطها لاحقاً)
            // =====================================
            let taxAmount = totals.taxAmount;
            if (taxAmount == null) taxAmount = 0;

            // =====================================
            // 4) الإجمالي بعد الخصم والضريبة + الصافي
            // =====================================
            let totalAfterDiscountAndTax = totals.totalAfterDiscountAndTax;
            if (totalAfterDiscountAndTax == null) {
                totalAfterDiscountAndTax = Number(totalAfterDiscount || 0) + Number(taxAmount || 0);
            }

            let netTotal = totals.netTotal;
            if (netTotal == null) {
                // حالياً الصافي = الإجمالي بعد الخصم والضريبة
                netTotal = Number(totalAfterDiscountAndTax || 0);
            }

            // =====================================
            // 5) تحديث العناصر على الصفحة (IDs كما هي)
            // =====================================
            setText('TotalLinesValue', totalLines);
            setText('TotalItemsValue', totalItems);
            setText('TotalQtyValue', totalQty);

            setText('TotalRetailValue', fmt2(totalRetail));
            setText('TotalAfterDiscountValue', fmt2(totalAfterDiscount));
            const taxInp = document.getElementById('TaxAmountInput');
if (taxInp) taxInp.value = fmt2(taxAmount);

            setText('TotalAfterDiscountAndTaxValue', fmt2(totalAfterDiscountAndTax));
            setText('NetTotalValue', fmt2(netTotal));
        }




                // =========================================================
        // Helpers عامة (Global) — علشان أي دالة تقدر تستخدمها بدون Errors
        // =========================================================

        // متغير/دالة: تحويل النص لرقم Decimal بأمان
        window.parseDecimalSafe = window.parseDecimalSafe || function (val) {
            const s = (val || '').toString().trim().replace(',', '.');
            const n = parseFloat(s);
            return isNaN(n) ? 0 : n;
        };

        // متغير/دالة: تنسيق رقم لرقمين عشريين
        window.fmt2 = window.fmt2 || function (val) {
            return window.parseDecimalSafe(val).toFixed(2);
        };

        // دالة: إضافة الشرطة تلقائياً لتاريخ الصلاحية (شهر+سنة بدون شرطة -> شهر/سنة) — مثل طلب الشراء
        window.formatExpiryWithSlash = window.formatExpiryWithSlash || function (val) {
            const s = (val || '').toString().trim().replace(/\s/g, '');
            if (!s) return '';
            const digits = s.replace(/\D/g, '');
            if (digits.length === 3) { const m = digits[0]; const yy = digits.slice(1, 3); return ('0' + m).slice(-2) + '/' + '20' + yy; }
            if (digits.length === 4) { const mm = digits.slice(0, 2); const yy = digits.slice(2, 4); return mm + '/' + '20' + yy; }
            if (digits.length === 5) { const m = digits[0]; const yyyy = digits.slice(1, 5); return ('0' + m).slice(-2) + '/' + yyyy; }
            if (digits.length >= 6) { const mm = digits.slice(0, 2); const yyyy = digits.slice(2, 6); return mm + '/' + yyyy; }
            return s;
        };

        // متغير/دالة: حماية النص قبل إدخاله في innerHTML
        window.escapeHtml = window.escapeHtml || function (text) {
            return (text ?? '').toString()
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        };






                // =========================================================
        // تثبيت الدالة في الـ Global Scope (حل نهائي لخطأ not defined)
        // =========================================================
        window.getAntiForgeryToken = window.getAntiForgeryToken || function () {

            // متغير: input الخاص بتوكن الحماية لو موجود في الصفحة
            const inp1 = document.querySelector('input[name="__RequestVerificationToken"]');
            if (inp1 && inp1.value) return inp1.value;

            // متغير: فورم التوكن المخفي (لو انت عامل فورم مخصص)
            const frm = document.getElementById('__AntiForgeryForm');
            if (!frm) return '';

            // متغير: input داخل الفورم المخفي
            const inp2 = frm.querySelector('input[name="__RequestVerificationToken"]');
            return inp2 ? (inp2.value || '') : '';
        };

        // =========================================================
        // Cache بسيط للسطور (علشان لو السيرفر رجّع line فقط)
        // =========================================================
        window.__piLinesCache = window.__piLinesCache || []; // متغير: آخر سطور مرسومة

        // =========================================================
        // دالة: فوكس بعد الإضافة على "اسم الصنف" (المطلوب منك)
        // =========================================================
        function focusOnProductName() {
            // متغير: حقل اسم الصنف
            const inp = document.getElementById('ProdNameInput');
            if (!inp) return;

            inp.focus();
            if (typeof inp.select === 'function') inp.select();
        }





             // =========================================================
        // إضافة سطر (AJAX) — مع حماية من أخطاء الدوال غير المعرفة
        // =========================================================
        async function addLineAjax() {

            // 1) لازم يكون عندنا رقم فاتورة محفوظ
            const invoiceIdInput = document.getElementById('InvoiceId'); // متغير: Hidden رقم الفاتورة
            const invoiceId = invoiceIdInput ? parseInt(invoiceIdInput.value || '0', 10) : 0;

            if (!invoiceId || invoiceId <= 0) {
                alert('لا يمكن إضافة أصناف قبل حفظ الفاتورة. اضغط "حفظ الفاتورة" أولاً.');
                document.getElementById('btnSaveInvoiceHeader')?.focus(); // متغير: زر حفظ الهيدر
                return;
            }

            // 2) قراءة بيانات السطر
            const prodId = prodHiddenId ? parseInt(prodHiddenId.value || '0', 10) : 0; // متغير: ProdId
            const qty = prodQtyInput ? parseInt(prodQtyInput.value || '0', 10) : 0;     // متغير: الكمية

            const priceRetail = prodPriceInput ? parseDecimalSafe(prodPriceInput.value) : 0; // متغير: سعر الجمهور
            const purchaseDiscountPct = prodDisc1Input ? parseDecimalSafe(prodDisc1Input.value) : 0; // متغير: خصم الشراء %

            const batchNo = prodBatchInput ? (prodBatchInput.value || '').trim() : '';       // متغير: التشغيلة
            let expiryText = prodExpiryInput ? (prodExpiryInput.value || '').trim() : '';  // متغير: الصلاحية
            if (expiryText && typeof formatExpiryWithSlash === 'function') {
                expiryText = formatExpiryWithSlash(expiryText);
                if (prodExpiryInput) prodExpiryInput.value = expiryText;
            }

            // 3) تحقق قبل الإرسال
            if (!prodId || prodId <= 0) {
                alert('من فضلك اختر صنفاً صحيحاً من القائمة.');
                prodNameInput?.focus();
                prodNameInput?.select?.();
                return;
            }

            if (!qty || qty <= 0) {
                alert('الكمية يجب أن تكون أكبر من صفر.');
                prodQtyInput?.focus();
                prodQtyInput?.select?.();
                return;
            }

            // 4) تجهيز DTO
            const dto = {
                id: invoiceId,
                piId: invoiceId,
                invoiceId: invoiceId,

                prodId: prodId,
                qty: qty,

                unitCost: 0,
                priceRetail: priceRetail,
                purchaseDiscountPct: purchaseDiscountPct,

                batchNo: batchNo,
                expiryText: expiryText
            };

            // 5) استدعاء السيرفر
            const token = getAntiForgeryToken();

            if (btnAddLine) btnAddLine.disabled = true; // تعليق: منع الضغط المتكرر

            try {

                const resp = await fetch('@Url.Action("AddLineJson", "PurchaseInvoices")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(dto)
                });

                // لو السيرفر رجّع خطأ HTTP
                if (!resp.ok) {
                    const errTxt = await resp.text().catch(() => '');
                    console.error('AddLineJson HTTP Error:', resp.status, errTxt);
                    alert('حدث خطأ أثناء إضافة السطر (HTTP). راجع Console لمعرفة السبب.');
                    return;
                }

                // نقرأ الرد كنص ثم JSON (أكثر أماناً)
                const raw = await resp.text();
                const rawTrim = (raw || '').trim();

                if (rawTrim.startsWith('<')) {
                    console.error('AddLineJson رجّع HTML بدل JSON:', rawTrim.substring(0, 300));
                    alert('السيرفر رجّع HTML بدل JSON. راجع AddLineJson في الكنترولر.');
                    return;
                }

                let data = null; // متغير: بيانات الرد
                try {
                    data = rawTrim ? JSON.parse(rawTrim) : null;
                } catch (e) {
                    console.error('فشل تحويل الرد إلى JSON:', e, rawTrim.substring(0, 300));
                    alert('الرد من السيرفر ليس JSON.');
                    return;
                }

                // نجاح قد يكون ok أو success حسب السيرفر
                const isOk = !!(data && (data.ok === true || data.success === true));
                if (!isOk) {
                    alert((data && data.message) ? data.message : 'تعذر إضافة السطر.');
                    return;
                }

                // =========================================================
                // 6) تحديث الجدول + الملخص (بدون ما نكسر الكود لو دالة ناقصة)
                // =========================================================
                try {

                    // السيرفر عندك بيرجع lines غالباً
                    if (Array.isArray(data.lines)) {
                        window.__piLinesCache = data.lines; // متغير: حفظ آخر سطور
                        if (typeof renderGroupedLines === 'function') {
                            renderGroupedLines(data.lines);
                        } else {
                            console.warn('renderGroupedLines غير معرفة وقت التنفيذ.');
                        }
                    } else if (data.line) {
                        window.__piLinesCache = window.__piLinesCache || [];
                        window.__piLinesCache.push(data.line);
                        if (typeof renderGroupedLines === 'function') {
                            renderGroupedLines(window.__piLinesCache);
                        }
                    }

                    if (data.totals && typeof updateSummaryBadges === 'function') {
                        updateSummaryBadges(data.totals);
                    }

                } catch (uiErr) {
