            // =========================================================
            // التنقل بالإنتر (داخل كارت إضافة الصنف)
            // =========================================================
            const lineInputs = [
                prodCodeInput,
                prodNameInput,
                prodPriceInput,
                prodQtyInput,
                prodDisc1Input,
                prodBatchInput,
