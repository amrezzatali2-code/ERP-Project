document.addEventListener('DOMContentLoaded', () => {

    // ==============================
    // (1) Tooltips (Bootstrap) لو موجود
    // ==============================
    try {
        if (window.bootstrap && typeof bootstrap.Tooltip === 'function') {
            document.querySelectorAll('[title]').forEach(el => new bootstrap.Tooltip(el));
        }
    } catch (e) { }

    // ==============================
    // (2) رابط Show الصحيح
    // ==============================
    const showBaseUrl = '@Url.Action("Show", "PurchaseInvoices")'; // مثال: /PurchaseInvoices/Show

    function openInvoice(id) {
        id = parseInt(id || '0', 10);
        if (!id || id <= 0) return;

        // ✅ مهم: Show عندك غالباً بالمسار /Show/{id}
        const base = showBaseUrl.replace(/\/$/, '');
        const url = base + '/' + encodeURIComponent(id) + '?frame=1';
        window.location.href = url;
    }

    function bindNavButton(btnId) {
        const btn = document.getElementById(btnId);
        if (!btn) return;

        btn.addEventListener('click', (e) => {
            e.preventDefault();
            if (btn.disabled) return;

            const id = btn.getAttribute('data-id');
            openInvoice(id);
        });
    }

    bindNavButton('btnFirstInvoice');
    bindNavButton('btnPrevInvoice');
    bindNavButton('btnNextInvoice');
    bindNavButton('btnLastInvoice');

    // ==============================
    // (3) البحث برقم الفاتورة
    // ==============================
    const searchInput = document.getElementById('NavInvoiceSearchInput');
    const searchBtn   = document.getElementById('btnNavInvoiceSearch');

    function doSearch() {
        const v = (searchInput?.value || '').trim();
        if (!v) return;
        openInvoice(v);
    }

    searchBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        doSearch();
    });

    searchInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            e.preventDefault();
            doSearch();
        }
    });

});



