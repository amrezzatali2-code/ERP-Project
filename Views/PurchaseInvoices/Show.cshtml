@section Scripts {
    <script>
        // =========================================================
        // (A) أوتوكومبليت المورد (اسم ⇐⇒ كود + بيانات)
        // =========================================================
        (function () {

            // بوكسات بيانات المورد
            const custNameInput      = document.getElementById('CustomerNameInput');    // متغير: اسم المورد
            const custCodeInput      = document.getElementById('CustomerCodeDisplay');  // متغير: كود المورد الظاهر
            const custPhoneInput     = document.getElementById('CustomerPhone');        // متغير: الهاتف
            const custGovInput       = document.getElementById('CustomerGovernorate');  // متغير: المحافظة
            const custDistrictInput  = document.getElementById('CustomerDistrict');     // متغير: الحي
            const custAreaInput      = document.getElementById('CustomerArea');         // متغير: المنطقة
            const custAddressInput   = document.getElementById('CustomerAddress');      // متغير: العنوان
            const custCreditInput    = document.getElementById('CustomerCredit');       // متغير: الحد الائتماني
            const custHiddenId       = document.getElementById('CustomerId');           // متغير: CustomerId (مخفي)

            // الـ datalist الخاصة بالموردين
            const custDataList = custNameInput && custNameInput.list ? custNameInput.list : null;

            if (!custDataList) {
                console.warn('⚠️ Supplier datalist not found for CustomerNameInput');
                return; // نخرج من جزء المورد فقط
            }

            // دالة: توحيد نص المورد (وتجاهل الألف في أول الكلمة)
            function normalizeSupplierText(txt) {
                return (txt || '')
                    .trim()
                    .toLowerCase()
                    .replace(/^[اأإآ]/, '')
                    .replace(/\s+/g, ' ');
            }

            // دالة: البحث عن مورد بالاسم (تطابق كامل)
            function findSupplierByName(name) {
                const search = normalizeSupplierText(name);
                if (!search) return null;

                const opts = custDataList.options;
                for (let i = 0; i < opts.length; i++) {
                    if (normalizeSupplierText(opts[i].value) === search) return opts[i];
                }
                return null;
            }

            // دالة: البحث عن مورد بالكود (data-id)
            function findSupplierByCode(code) {
                const search = (code || '').toString().trim();
                if (!search) return null;

                const opts = custDataList.options;
                for (let i = 0; i < opts.length; i++) {
                    const optId = (opts[i].getAttribute('data-id') || '').toString();
                    if (optId === search) return opts[i];
                }
                return null;
            }

            // دالة: تعبئة كل بوكسات المورد من <option> واحد
            function fillSupplierFromOption(opt) {

                // لو مفيش مورد مطابق → نفرّغ
                if (!opt) {
                    if (custHiddenId)      custHiddenId.value      = '';
                    if (custCodeInput)     custCodeInput.value     = '';
                    if (custNameInput)     custNameInput.value     = '';
                    if (custPhoneInput)    custPhoneInput.value    = '';
                    if (custGovInput)      custGovInput.value      = '';
                    if (custDistrictInput) custDistrictInput.value = '';
                    if (custAreaInput)     custAreaInput.value     = '';
                    if (custAddressInput)  custAddressInput.value  = '';
                    if (custCreditInput)   custCreditInput.value   = '';
                    return;
                }

                // قراءة البيانات من الـ option
                const id       = opt.getAttribute('data-id')       || ''; // متغير: كود المورد الحقيقي
                const name     = opt.value                         || ''; // متغير: اسم المورد
                const phone    = opt.getAttribute('data-phone')    || ''; // متغير: الهاتف
                const address  = opt.getAttribute('data-address')  || ''; // متغير: العنوان
                const gov      = opt.getAttribute('data-gov')      || ''; // متغير: المحافظة
                const district = opt.getAttribute('data-district') || opt.getAttribute('data-District') || ''; // متغير: الحي
                const area     = opt.getAttribute('data-area')     || opt.getAttribute('data-Area')     || ''; // متغير: المنطقة
                const credit   = opt.getAttribute('data-credit')   || opt.getAttribute('data-Credit')   || ''; // متغير: الحد الائتماني

                if (custHiddenId)  custHiddenId.value  = id;
                if (custCodeInput) custCodeInput.value = id;

                if (custNameInput)     custNameInput.value     = name;
                if (custPhoneInput)    custPhoneInput.value    = phone;
                if (custGovInput)      custGovInput.value      = gov;
                if (custDistrictInput) custDistrictInput.value = district;
                if (custAreaInput)     custAreaInput.value     = area;
                if (custAddressInput)  custAddressInput.value  = address;
                if (custCreditInput)   custCreditInput.value   = credit;
            }

            // اسم المورد: change + Enter
            if (custNameInput) {
                custNameInput.addEventListener('change', () => {
                    fillSupplierFromOption(findSupplierByName(custNameInput.value));
                });

                custNameInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        fillSupplierFromOption(findSupplierByName(custNameInput.value));
                    }
                });
            }

            // كود المورد: change + Enter
            if (custCodeInput) {
                custCodeInput.addEventListener('change', () => {
                    fillSupplierFromOption(findSupplierByCode(custCodeInput.value));
                });

                custCodeInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        fillSupplierFromOption(findSupplierByCode(custCodeInput.value));
                    }
                });
            }

            // عند فتح فاتورة قديمة: CustomerId موجود → املأ البيانات
            if (custHiddenId && custHiddenId.value) {
                fillSupplierFromOption(findSupplierByCode(custHiddenId.value));
            }

        })();

        // =========================================================
        // (B) أوتوكومبليت الصنف + كارت بياناته + التابات + إضافة سطر
        // =========================================================
        function initProductSearch() {
            console.log('🚀 بدء تحميل/إعادة تحميل كود الأصناف...');

            // 1) عناصر سطر الصنف في الفاتورة
            const prodCodeInput   = document.getElementById('ProdCodeInput');     // متغير: كود الصنف للبحث
            const prodNameInput   = document.getElementById('ProdNameInput');     // متغير: اسم الصنف (أوتوكومبليت)
            const prodPriceInput  = document.getElementById('ProdPriceInput');    // متغير: سعر الجمهور
            const prodQtyInput    = document.getElementById('ProdQtyInput');      // متغير: الكمية
            const prodDisc1Input  = document.getElementById('ProdDisc1Input');    // متغير: خصم الشراء %
            const prodBatchInput  = document.getElementById('ProdBatchInput');    // متغير: الباتش
            const prodExpiryInput = document.getElementById('ProdExpiryInput');   // متغير: تاريخ الصلاحية
            const prodHiddenId    = document.getElementById('ProdId');            // متغير: المعرّف الداخلي للصنف
            const btnAddLine      = document.getElementById('btnAddInvoiceLine'); // متغير: زر إضافة السطر

            console.log('📋 العناصر:', {
                prodCodeInput: !!prodCodeInput,
                prodNameInput: !!prodNameInput,
                prodPriceInput: !!prodPriceInput,
                prodQtyInput: !!prodQtyInput,
                prodHiddenId: !!prodHiddenId,
                btnAddLine: !!btnAddLine
            });

            // 2) عناصر كارت بيانات الصنف
            const prodQtyWarehouse = document.getElementById('ProdQtyCurrentWarehouse'); // متغير: كمية هذا المخزن
            const prodQtyAll       = document.getElementById('ProdQtyAllWarehouses');   // متغير: إجمالي الكمية
            const prodQuotaText    = document.getElementById('ProdQuotaText');          // متغير: هل له كوتة؟
            const prodWeightedDisc = document.getElementById('ProdWeightedDiscount');   // متغير: الخصم المرجّح
            const prodAltSelect    = document.getElementById('AlternativeProducts');    // متغير: قائمة البدائل

            // 3) datalist الخاصة بالأصناف
            const prodDataList = (prodNameInput && prodNameInput.list) ? prodNameInput.list : null;

            if (!prodDataList) {
                console.error('❌ لم يتم العثور على قائمة الأصناف (datalist) المرتبطة بـ ProdNameInput.');
                console.log('prodNameInput:', prodNameInput);
                console.log('prodNameInput.list:', prodNameInput?.list);
                // لا نخرج - نستمر في محاولة العمل بدون datalist
            } else {
                console.log('✅ تم العثور على datalist، عدد الأصناف:', prodDataList.options.length);
            }

            // =========================================================
            // دوال مساعدة (أرقام + توحيد نص)
            // =========================================================

            // دالة: توحيد النص (تجاهل الألف + إزالة مسافات مكررة + توحيد الأرقام)
            function normalizeText(txt) {
                if (!txt) return '';
                return txt
                    .trim()
                    .toLowerCase()
                    // توحيد الألف (أ، إ، آ، ا)
                    .replace(/[أإآ]/g, 'ا')
                    // إزالة مسافات مكررة
                    .replace(/\s+/g, ' ')
                    // إزالة مسافات في البداية والنهاية
                    .trim();
            }

            // دالة: تحويل النص لرقم (decimal) بأمان
            function parseDecimalSafe(val) {
                const s = (val || '').toString().trim().replace(',', '.');
                const n = parseFloat(s);
                return isNaN(n) ? 0 : n;
            }

            // دالة: تنسيق رقم (رقمين عشريين)
            function fmt2(val) {
                return parseDecimalSafe(val).toFixed(2);
            }

            // =========================================================
            // البحث عن صنف بالاسم / بالكود داخل datalist
            // =========================================================

            function findProductByName(name) {
                const search = normalizeText(name);
                if (!search) {
                    console.warn('⚠️ findProductByName: نص البحث فارغ');
                    return null;
                }

                const opts = prodDataList.options;
                if (!opts || opts.length === 0) {
                    console.warn('⚠️ findProductByName: قائمة الأصناف فارغة');
                    return null;
                }

                console.log('🔍 البحث عن:', search, 'من', opts.length, 'صنف');

                // 1) تطابق تام
                for (let i = 0; i < opts.length; i++) {
                    const optText = normalizeText(opts[i].value);
                    if (optText === search) {
                        console.log('✅ تطابق تام:', opts[i].value);
                        return opts[i];
                    }
                }

                // 2) يبدأ بـ (أول تطابق)
                for (let i = 0; i < opts.length; i++) {
                    const optText = normalizeText(opts[i].value);
                    if (optText.startsWith(search)) {
                        console.log('✅ يبدأ بـ:', opts[i].value);
                        return opts[i];
                    }
                }

                // 3) يحتوي على (أول تطابق)
                for (let i = 0; i < opts.length; i++) {
                    const optText = normalizeText(opts[i].value);
                    if (optText.includes(search)) {
                        console.log('✅ يحتوي على:', opts[i].value);
                        return opts[i];
                    }
                }

                // 4) البحث العكسي: هل النص المدخل يحتوي على اسم الصنف
                for (let i = 0; i < opts.length; i++) {
                    const optText = normalizeText(opts[i].value);
                    if (optText.length > 3 && search.includes(optText)) {
                        console.log('✅ بحث عكسي:', opts[i].value);
                        return opts[i];
                    }
                }

                // 5) البحث بكلمات منفصلة (إذا كان البحث يحتوي على عدة كلمات)
                const searchWords = search.split(' ').filter(w => w.length > 2);
                if (searchWords.length > 0) {
                    for (let i = 0; i < opts.length; i++) {
                        const optText = normalizeText(opts[i].value);
                        // التحقق من أن جميع كلمات البحث موجودة في اسم الصنف
                        const allWordsMatch = searchWords.every(word => optText.includes(word));
                        if (allWordsMatch) {
                            console.log('✅ تطابق كلمات:', opts[i].value);
                            return opts[i];
                        }
                    }
                }

                console.warn('❌ لم يتم العثور على الصنف:', search);
                return null;
            }

            function findProductByCode(code) {
                const search = (code || '').toString().trim();
                if (!search) return null;

                const opts = prodDataList.options;
                for (let i = 0; i < opts.length; i++) {
                    const idAttr   = (opts[i].getAttribute('data-id')   || '').toString();
                    const codeAttr = (opts[i].getAttribute('data-code') || '').toString();
                    if (idAttr === search || codeAttr === search) return opts[i];
                }
                return null;
            }

            // =========================================================
            // تعبئة بيانات الصنف من <option>
            // =========================================================
            function fillProductFromOption(opt) {
                console.log('🔄 fillProductFromOption called with:', opt ? opt.value : 'null');

                // لو مفيش صنف مطابق → نفرّغ
                if (!opt) {
                    console.warn('⚠️ fillProductFromOption: لم يتم العثور على صنف مطابق');
                    if (prodHiddenId)    prodHiddenId.value    = '';
                    if (prodCodeInput)   prodCodeInput.value   = '';
                    // لا نمسح اسم الصنف المكتوب (نتركه للمستخدم)
                    // if (prodNameInput)   prodNameInput.value   = '';
                    if (prodPriceInput)  {
                        prodPriceInput.value = '';
                        console.log('🧹 تم مسح السعر');
                    }

                    if (prodQuotaText)    prodQuotaText.value    = 'بدون كوتة';
                    if (prodWeightedDisc) prodWeightedDisc.value = '0';

                    if (prodQtyWarehouse) prodQtyWarehouse.value = '0';
                    if (prodQtyAll)       prodQtyAll.value       = '0';

                    if (prodAltSelect) {
                        prodAltSelect.innerHTML = '<option value="">لا توجد بدائل</option>';
                    }
                    return;
                }

                console.log('✅ fillProductFromOption: تم العثور على صنف', opt.value);

                // قراءة البيانات من data-*
                const id       = opt.getAttribute('data-id')      || ''; // متغير: ProdId
                const code     = opt.getAttribute('data-code')    || id; // متغير: كود ظاهر (قد يساوي id)
                const name     = opt.value                        || ''; // متغير: اسم الصنف
                const generic  = opt.getAttribute('data-generic') || ''; // متغير: الاسم العلمي
                const hasQuota = (opt.getAttribute('data-hasquota') === 'true'); // متغير: هل له كوتة؟
                let priceRaw   = opt.getAttribute('data-price')   || '0'; // متغير: السعر كنص

                // معالجة السعر
                priceRaw = priceRaw.toString().replace(',', '.');
                let price = parseFloat(priceRaw);
                if (isNaN(price)) price = 0;

                if (prodHiddenId)  prodHiddenId.value  = id;
                if (prodCodeInput) prodCodeInput.value = code;
                if (prodNameInput) prodNameInput.value = name;
                if (prodPriceInput) {
                    prodPriceInput.value = price.toFixed(2);
                    // ✅ إطلاق event للتأكد من تحديث القيمة حتى لو كان الحقل readOnly
                    prodPriceInput.dispatchEvent(new Event('input', { bubbles: true }));
                    prodPriceInput.dispatchEvent(new Event('change', { bubbles: true }));
                }

                if (prodQuotaText) {
                    prodQuotaText.value = hasQuota ? 'له كوتة' : 'بدون كوتة';
                }

                // حالياً: الخصم المرجّح = 0 (هنربطه بالسياسات لاحقاً)
                if (prodWeightedDisc) {
                    prodWeightedDisc.value = '0';
                }

                // بدائل الصنف حسب الاسم العلمي
                if (prodAltSelect && generic) {
                    loadAlternativeProducts(id);
                } else if (prodAltSelect) {
                    prodAltSelect.innerHTML = '<option value="">لا توجد بدائل</option>';
                }
            }

            // =========================================================
            // تحميل البدائل من الكنترولر
            // =========================================================
            function loadAlternativeProducts(prodId) {
                if (!prodId || !prodAltSelect) return;

                const url = '@Url.Action("GetAlternativeProducts", "PurchaseInvoices")'
                    + '?prodId=' + encodeURIComponent(prodId);

                prodAltSelect.innerHTML = '<option value="">... جاري تحميل البدائل</option>';

                fetch(url)
                    .then(r => r.ok ? r.json() : [])
                    .then(data => {
                        prodAltSelect.innerHTML = '<option value="">اختر بديلاً (للمشاهدة فقط)</option>';

                        if (!data || !data.length) {
                            prodAltSelect.innerHTML += '<option value="">لا توجد بدائل</option>';
                            return;
                        }

                        data.forEach(p => {
                            const op = document.createElement('option');
                            op.value = p.id;
                            op.textContent = `${p.name || ''} — ${p.company || ''} — ${p.price || 0}`;
                            op.setAttribute('data-id', p.id);
                            op.setAttribute('data-price', p.price || 0);
                            prodAltSelect.appendChild(op);
                        });
                    })
                    .catch(err => {
                        console.error('❌ خطأ في تحميل بدائل الصنف:', err);
                        prodAltSelect.innerHTML = '<option value="">خطأ في تحميل البدائل</option>';
                    });
            }

            // =========================================================
            // Events: اسم الصنف / كود الصنف
            // =========================================================
            if (prodNameInput) {
                console.log('✅ تم ربط event listeners لحقل اسم الصنف');

                prodNameInput.addEventListener('change', function (e) {
                    console.log('📝 change event:', this.value);
                    try {
                        const found = findProductByName(this.value);
                        fillProductFromOption(found);
                    } catch (err) {
                        console.error('❌ خطأ في change event:', err);
                    }
                });

                prodNameInput.addEventListener('blur', function (e) {
                    console.log('👋 blur event:', this.value);
                    try {
                        // عند الخروج من الحقل، نحاول البحث مرة أخرى
                        const found = findProductByName(this.value);
                        if (found) {
                            fillProductFromOption(found);
                        } else if (this.value.trim()) {
                            // لو لم نجد صنفاً لكن المستخدم كتب شيئاً، نعرض رسالة
                            console.warn('⚠️ لم يتم العثور على صنف بهذا الاسم:', this.value);
                        }
                    } catch (err) {
                        console.error('❌ خطأ في blur event:', err);
                    }
                });

                // عند الكتابة، نحاول البحث تلقائياً بعد تأخير قصير
                let searchTimeout = null;
                prodNameInput.addEventListener('input', function (e) {
                    clearTimeout(searchTimeout);
                    const value = this.value.trim();
                    if (value.length >= 3) {
                        searchTimeout = setTimeout(() => {
                            try {
                                console.log('🔍 البحث التلقائي عن:', value);
                                const found = findProductByName(value);
                                if (found) {
                                    console.log('✅ تم العثور على صنف أثناء الكتابة');
                                    fillProductFromOption(found);
                                }
                            } catch (err) {
                                console.error('❌ خطأ في البحث التلقائي:', err);
                            }
                        }, 300); // تأخير 300ms بعد توقف الكتابة
                    }
                });
            } else {
                console.error('❌ prodNameInput غير موجود!');
            }

            if (prodCodeInput) {
                prodCodeInput.addEventListener('change', function () {
                    const found = findProductByCode(this.value);
                    fillProductFromOption(found);
                });

                prodCodeInput.addEventListener('blur', function () {
                    const found = findProductByCode(this.value);
                    fillProductFromOption(found);
                });
            }

            // =========================================================
            // قفل / فتح سعر الجمهور (بالضغط على اللابل)
            // =========================================================
            const priceLabel     = document.getElementById('ProdPriceLabel');       // متغير: Label السعر
            const priceLockState = document.getElementById('ProdPriceLockState');   // متغير: (مغلق/مفتوح)
            let priceLocked = true; // متغير: حالة قفل السعر

            function applyPriceLockUI() {
                if (!prodPriceInput) return;

                prodPriceInput.readOnly = priceLocked;

                if (priceLocked) {
                    prodPriceInput.classList.add('bg-light', 'text-muted');
                    if (priceLockState) priceLockState.textContent = '(مغلق)';
                } else {
                    prodPriceInput.classList.remove('bg-light', 'text-muted');
                    if (priceLockState) priceLockState.textContent = '(مفتوح)';
                }
            }

            applyPriceLockUI();

            if (priceLabel) {
                priceLabel.style.cursor = 'pointer';
                priceLabel.addEventListener('click', function () {
                    priceLocked = !priceLocked;
                    applyPriceLockUI();
                });
            }

            // =========================================================
            // قفل / فتح خصم الشراء (بالضغط على اللابل)
            // =========================================================
            const disc1Label     = document.getElementById('ProdDisc1Label');      // متغير: Label الخصم
            const disc1LockState = document.getElementById('ProdDisc1LockState');  // متغير: (مغلق/مفتوح)
            let disc1Locked = false; // متغير: حالة قفل الخصم

            function applyDisc1LockUI() {
                if (!prodDisc1Input) return;

                prodDisc1Input.readOnly = disc1Locked;

                if (disc1Locked) {
                    prodDisc1Input.classList.add('bg-light', 'text-muted');
                    if (disc1LockState) disc1LockState.textContent = '(مغلق)';
                } else {
                    prodDisc1Input.classList.remove('bg-light', 'text-muted');
                    if (disc1LockState) disc1LockState.textContent = '(مفتوح)';
                }
            }

            applyDisc1LockUI();

            if (disc1Label) {
                disc1Label.style.cursor = 'pointer';
                disc1Label.addEventListener('click', function () {
                    disc1Locked = !disc1Locked;
                    applyDisc1LockUI();
                });
            }

            // =========================================================
            // التنقل بالإنتر (داخل كارت إضافة الصنف)
            // =========================================================
            const lineInputs = [
                prodCodeInput,
                prodNameInput,
                prodPriceInput,
                prodQtyInput,
                prodDisc1Input,
                prodBatchInput,
                prodExpiryInput
            ].filter(Boolean);

            lineInputs.forEach((input, index) => {

                // أول ما يدخل الفوكس → تحديد النص
                input.addEventListener('focus', function () {
                    if (typeof this.select === 'function') {
                        setTimeout(() => this.select(), 0);
                    }
                });

                // Enter → يروح للحقل اللي بعده
                input.addEventListener('keydown', function (e) {
                    if (e.key !== 'Enter') return;

                    e.preventDefault();
                    console.log('⌨️ Enter pressed on:', input.id || input.className);

                    try {
                        // لو المستخدم داخل اسم الصنف → نحاول نثبّت الصنف
                        if (input === prodNameInput) {
                            console.log('🔍 البحث عن صنف قبل الانتقال:', prodNameInput.value);
                            const found = findProductByName(prodNameInput.value);
                            fillProductFromOption(found);
                        }

                        // لو المستخدم داخل كود الصنف → نحاول نثبّت الصنف
                        if (input === prodCodeInput) {
                            console.log('🔍 البحث عن صنف بالكود قبل الانتقال:', prodCodeInput.value);
                            const found = findProductByCode(prodCodeInput.value);
                            fillProductFromOption(found);
                        }

                        // البحث عن الحقل التالي القابل للتحرير (ليس readOnly)
                        let nextIndex = index + 1;
                        let next = null;
                        
                        while (nextIndex < lineInputs.length) {
                            next = lineInputs[nextIndex];
                            // ✅ التحقق من أن الحقل قابل للتحرير (ليس readOnly)
                            if (next && !next.readOnly) {
                                break;
                            }
                            nextIndex++;
                        }

                        if (next && !next.readOnly) {
                            console.log('➡️ الانتقال إلى:', next.id || next.className);
                            next.focus();
                            if (typeof next.select === 'function') {
                                next.select();
                            }
                        } else if (btnAddLine) {
                            console.log('➡️ الانتقال إلى زر الإضافة');
                            btnAddLine.focus();
                        } else {
                            console.warn('⚠️ لا يوجد حقل تالي للانتقال إليه');
                        }
                    } catch (err) {
                        console.error('❌ خطأ في معالجة Enter:', err);
                    }
                });
            });

            // زر الإضافة: Enter يعمل Click
            if (btnAddLine) {
                btnAddLine.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        btnAddLine.click();
                    }
                });
            }








        // ===============================
        // رسم جدول السطور (هجين)
        // - لو الصنف غير مكرر: سطر واحد + بيانات + زر مسح
        // - لو الصنف مكرر (تشغيلات): سطر عنوان للصنف + سطور تشغيلات (بيانات + مسح لكل تشغيلة)
        // ===============================
        function renderGroupedLines(lines) {

            // متغير: tbody الخاص بجدول السطور
            const tbody = document.getElementById('PILinesTbody');
            if (!tbody) return;

            // تفريغ الجدول قبل الرسم
            tbody.innerHTML = '';

            // لو مفيش بيانات
            if (!Array.isArray(lines) || lines.length === 0) {
                tbody.innerHTML = `<tr><td colspan="9" class="text-center text-muted py-3">لا توجد سطور</td></tr>`;
                return;
            }

            // ===============================
            // 1) تجميع السطور حسب prodId + prodName
            // ===============================
            const map = new Map(); // متغير: Map لتجميع السطور

            lines.forEach(l => {
                const prodId = Number(l.prodId || 0); // متغير: كود الصنف
                const prodName = (l.prodName || (`صنف #${prodId}`)).toString(); // متغير: اسم الصنف
                const key = `${prodId}||${prodName}`; // متغير: مفتاح التجميع

                if (!map.has(key)) {
                    map.set(key, { prodId, prodName, lines: [] });
                }
                map.get(key).lines.push(l);
            });

            // ترتيب المجموعات بالاسم
            const groups = Array.from(map.values())
                .sort((a, b) => (a.prodName || '').localeCompare(b.prodName || '', 'ar'));

            // ===============================
            // 2) رسم كل مجموعة حسب عدد التشغيلات
            // ===============================
            groups.forEach(g => {

                // ترتيب تشغيلات الصنف حسب lineNo
                const sortedLines = (g.lines || [])
                    .slice()
                    .sort((x, y) => (Number(x.lineNo || 0) - Number(y.lineNo || 0)));

                const isMultiBatch = sortedLines.length > 1; // متغير: هل الصنف له أكثر من تشغيلة؟

                // =========================================================
                // الحالة (1): الصنف غير مكرر => سطر واحد فقط (اسم + بيانات + مسح)
                // =========================================================
                if (!isMultiBatch) {

                    const line = sortedLines[0];

                    const lineNo = line.lineNo ?? ''; // متغير: رقم السطر
                    const batchNo = line.batchNo ?? ''; // متغير: التشغيلة

                    const expiryText = line.expiryText
                        ? line.expiryText
                        : (line.expiry ? formatDateYMD(line.expiry) : ''); // متغير: الصلاحية

                    const qty = Number(line.qty || 0); // متغير: الكمية
                    const priceRetail = Number(line.priceRetail || 0); // متغير: سعر الجمهور

                    const discPct = (line.purchaseDiscountPct != null)
                        ? Number(line.purchaseDiscountPct)
                        : Number(line.discPct || 0); // متغير: الخصم %

                    const lineValue = (line.lineValue != null)
                        ? Number(line.lineValue)
                        : (qty * priceRetail * (1 - (discPct / 100))); // متغير: قيمة السطر

                    const tr = document.createElement('tr');
                    tr.setAttribute('data-line-no', lineNo);
                    tr.setAttribute('data-prodid', g.prodId);

                    tr.innerHTML = `
                        <td class="text-center">${lineNo}</td>

                        <td>
                            <strong>${escapeHtml(g.prodName)}</strong>
                            <span class="text-muted small"> | كود: ${g.prodId}</span>
                        </td>

                        <td class="text-center">${escapeHtml(batchNo)}</td>
                        <td class="text-center">${escapeHtml(expiryText)}</td>
                        <td class="text-center">${qty}</td>
                        <td class="text-center">${fmt2(priceRetail)}</td>
                        <td class="text-center">${fmt2(discPct)}</td>

                        <td class="text-center">${fmt2(lineValue)}</td>

                        <td class="text-center">
                            <button type="button"
                                    class="btn btn-danger btn-sm btnRemoveLineFromInvoice"
                                    data-line-no="${lineNo}">
                                مسح
                            </button>
                        </td>
                    `;

                    tbody.appendChild(tr);
                    return;
                }

                // =========================================================
                // الحالة (2): الصنف مكرر => سطر عنوان للصنف + سطور تشغيلات تحته
                // =========================================================

                // (أ) سطر عنوان الصنف فقط (بدون بيانات وبدون زر مسح)
                const grpRow = document.createElement('tr');
                grpRow.className = 'table-light pi-group-row';
                grpRow.setAttribute('data-prodid', g.prodId);

                grpRow.innerHTML = `
                    <td class="text-center">—</td>

                    <td>
                        <strong>${escapeHtml(g.prodName)}</strong>
                        <span class="text-muted small"> | كود: ${g.prodId}</span>
                    </td>

                    <td class="text-center text-muted small">تشغيلات: ${sortedLines.length}</td>
