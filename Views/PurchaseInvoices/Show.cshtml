                // Enter → يروح للحقل اللي بعده
                input.addEventListener('keydown', function (e) {
                    if (e.key !== 'Enter') return;

                    e.preventDefault();

                    // لو المستخدم داخل اسم الصنف → نحاول نثبّت الصنف
                    if (input === prodNameInput) {
                        fillProductFromOption(findProductByName(prodNameInput.value));
                    }

                    // لو المستخدم داخل كود الصنف → نحاول نثبّت الصنف
                    if (input === prodCodeInput) {
                        fillProductFromOption(findProductByCode(prodCodeInput.value));
