            // ثابت: قراءة حالة "مُرحّلة؟" من Flag (0/1)
            // =========================================================
            function isInvoicePosted() {
                const flag = document.getElementById("InvoiceIsPostedFlag"); // متغير: علم الترحيل
                return flag && flag.value === "1";
            }

            // =========================================================
            // ثابت: تحديث Flag بعد الترحيل/الفتح (بدون Reload)
            // =========================================================
            function setInvoicePosted(posted) {
