@* Views/PurchaseInvoices/Index.cshtml — قائمة فواتير المشتريات بنفس نموذج فواتير المبيعات *@
@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.PurchaseInvoice>

@{
    ViewData["Title"] = "قائمة فواتير المشتريات";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "PurchaseInvoices";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "id";          // البحث الافتراضي برقم الفاتورة
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "PIDate";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "desc");

    // بيانات الترقيم
    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    // نطاق العرض السفلي
    int start = total == 0 ? 0 : ((page - 1) * ps) + 1;
    int end = Math.Min(total, page * ps);

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلتر كود من/إلى (مثلاً رقم الفاتورة من/إلى)
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    // حقل التاريخ المستخدم في الفلترة (هنا تاريخ الفاتورة)
    var dateField = (string?)ViewBag.DateField ?? "PIDate";

    // دالة توليد لينكات الترقيم مع الحفاظ على الفلاتر
    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField = dateField,
        fromCode,
        toCode
    })!;

    // دالة إنشاء لينك الترتيب في رأس الجدول + أيقونة السهم
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";

        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange = Model.UseDateRange,
            fromDate = Model.FromDate,
            toDate = Model.ToDate,
            dateField,
            fromCode,
            toCode
        }) ?? "#";

        string icon = "⇅";
        if (isCurrent)
            icon = dir == "asc" ? "▲" : "▼";

        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };
}

<div dir="rtl" class="container-fluid">

    @* ===== الكارت العلوي: بحث + فلتر رقم + أزرار التحكم ===== *@
    <div class="card mb-3 d-print-none">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                @* العمود الأول: البحث *@
                <div class="col-lg-4">
                    <form method="get"
                          action="@Url.Action(action, controller)"
                          class="row g-2 align-items-end">

                        <div class="col-12">
                            <label class="form-label fw-semibold">بحث</label>
                        </div>

                        <div class="col-sm-4">
                            <input type="text"
                                   name="search"
                                   class="form-control form-control-sm"
                                   placeholder="اكتب نص البحث..."
                                   value="@search" />
                        </div>

                        <div class="col-sm-4">
                            <select name="searchBy"
                                    class="form-select form-select-sm">
                                @* البحث برقم الفاتورة *@
                                <option value="id"
                                        selected="@(searchBy == "id" ? "selected" : null)">
                                    رقم الفاتورة
                                </option>

                                @* البحث بالمورد (CustomerId في الموديل) *@
                                <option value="vendor"
                                        selected="@(searchBy == "vendor" ? "selected" : null)">
                                    المورد / الكود
                                </option>

                                @* البحث بالمخزن *@
                                <option value="warehouse"
                                        selected="@(searchBy == "warehouse" ? "selected" : null)">
                                    المخزن
                                </option>

                                @* البحث بتاريخ الفاتورة *@
                                <option value="date"
                                        selected="@(searchBy == "date" ? "selected" : null)">
                                    تاريخ الفاتورة
                                </option>

                                @* البحث بالحالة *@
                                <option value="status"
                                        selected="@(searchBy == "status" ? "selected" : null)">
                                    حالة الفاتورة
                                </option>
                            </select>
                        </div>

                        @* الحفاظ على باقي الفلاتر *@
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@ps" />
                        <input type="hidden" name="dateField" value="@dateField" />
                        <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                        @if (Model.FromDate.HasValue)
                        {
                            <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                        }
                        @if (Model.ToDate.HasValue)
                        {
                            <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                        }
                        @if (fromCode.HasValue)
                        {
                            <input type="hidden" name="fromCode" value="@fromCode" />
                        }
                        @if (toCode.HasValue)
                        {
                            <input type="hidden" name="toCode" value="@toCode" />
                        }

                        <div class="col-auto mt-1">
                            <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">
                                بحث
                            </button>
                        </div>
                        <div class="col-auto mt-1">
                            <a class="btn btn-erp btn-erp-ghost btn-erp-sm"
                               href="@Url.Action(action, controller)">
                                إلغاء
                            </a>
                        </div>
                    </form>
                </div>

                @* العمود الثاني: فلتر كود من/إلى (رقم فاتورة من / إلى) *@
                <div class="col-lg-4">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-semibold">من رقم</span>
                        <input id="codeFromInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(ViewBag.CodeFrom?.ToString() ?? "")" />

                        <span class="fw-semibold">إلى رقم</span>
                        <input id="codeToInput"
                               type="number"
                               class="form-control form-control-sm"
                               style="width:110px"
                               value="@(ViewBag.CodeTo?.ToString() ?? "")" />

                        <button type="button"
                                id="btnApplyCodeFilter"
                                class="btn btn-erp btn-erp-primary btn-erp-sm">
                            تطبيق فلتر الرقم
                        </button>

                        <button type="button"
                                id="btnClearCodeFilter"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            مسح
                        </button>
                    </div>
                </div>

                @* العمود الثالث: الفلاتر / الحذف / الطباعة / التصدير *@
                <div class="col-lg-4">
                    <div class="erp-toolbar justify-content-lg-end">

                        @* فلترة بالتاريخ/الوقت *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#dateFilterModal">
                            فلترة بالتاريخ/الوقت
                        </button>

                        @* اختيار الأعمدة *@
                        <button type="button"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#columnsModalPI">
                            اختيار الأعمدة
                        </button>

                        @* حذف المحدد *@
                        <form id="bulkDeleteForm"
                              asp-action="BulkDelete"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="selectedIds" id="selectedIdsInput" />
                            <button type="button"
                                    id="btnDeleteSelected"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف فواتير المشتريات المحددة
                            </button>
                        </form>

                        @* (اختياري) حذف كل الفواتير – خطير، راعي استخدامه في الكنترولر *@
                        <form id="deleteAllForm"
                              asp-action="DeleteAll"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="button"
                                    id="btnDeleteAll"
                                    class="btn btn-erp btn-erp-danger btn-erp-sm">
                                حذف جميع فواتير المشتريات
                            </button>
                        </form>

                        @* طباعة (الجدول فقط) *@
                        <button type="button"
                                id="btnPrint"
                                class="btn btn-erp btn-erp-secondary btn-erp-sm">
                            🖨️ طباعة
                        </button>

                        @* تصدير *@
                        <form method="get"
                              asp-action="Export"
                              asp-controller="PurchaseInvoices"
                              class="d-flex flex-wrap gap-2 align-items-center">

                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                            @if (Model.FromDate.HasValue)
                            {
                                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
                            }
                            @if (Model.ToDate.HasValue)
                            {
                                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
                            }
                            @if (ViewBag.CodeFrom != null)
                            {
                                <input type="hidden" name="codeFrom" value="@ViewBag.CodeFrom" />
                            }
                            @if (ViewBag.CodeTo != null)
                            {
                                <input type="hidden" name="codeTo" value="@ViewBag.CodeTo" />
                            }

                            <select name="format"
                                    class="form-select form-select-sm"
                                    style="width:95px">
                                <option value="excel" selected>Excel</option>
                                <option value="csv">CSV</option>
                            </select>

                            <button type="submit"
                                    class="btn btn-erp btn-erp-primary btn-erp-sm">
                                تصدير
                            </button>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>

    @* ===== جدول فواتير المشتريات (هو الوحيد اللي يتطبع) ===== *@
    <div class="erp-table-wrapper mt-3 erp-print-area">
        <table id="piTable" class="table table-striped table-hover erp-table erp-table-sortable">
            <thead class="table-light">
                <tr>
                    @* اختيار الصف *@
                    <th class="text-center no-print" style="width:40px;" data-col="select" data-col-fixed="true">
                        <input type="checkbox" id="chkAllRows" />
                    </th>

                    @* ===== أعمدة PurchaseInvoice الأساسية ===== *@
                    <th data-col="piid">@sortLink("id", "رقم الفاتورة")</th>
                    <th data-col="pidate">@sortLink("date", "تاريخ الفاتورة")</th>

                    <th data-col="customerid">@sortLink("customerid", "كود المورد")</th>
                    <th data-col="customername">@sortLink("vendor", "المورد")</th>

                    <th data-col="warehouseid">@sortLink("warehouse", "كود المخزن")</th>

                    <th data-col="refprid">@sortLink("refprid", "طلب شراء مرجعي")</th>

                    <th data-col="itemstotal">@sortLink("itemstotal", "إجمالي قبل الخصم")</th>
                    <th data-col="discounttotal">@sortLink("discounttotal", "إجمالي الخصم")</th>
                    <th data-col="taxtotal">@sortLink("taxtotal", "إجمالي الضريبة")</th>
                    <th data-col="nettotal">@sortLink("net", "صافي الفاتورة")</th>

                    <th data-col="status">@sortLink("status", "الحالة")</th>
                    <th data-col="isposted">@sortLink("posted", "مرحل؟")</th>

                    <th data-col="postedat">@sortLink("postedat", "تاريخ الترحيل")</th>
                    <th data-col="postedby">@sortLink("postedby", "مرحل بواسطة")</th>

                    <th data-col="createdby">@sortLink("createdby", "أنشأها")</th>
                    <th data-col="createdat">@sortLink("createdat", "تاريخ الإنشاء")</th>
                    <th data-col="updatedat">@sortLink("updatedat", "آخر تعديل")</th>

                    @* ===== أعمدة محسوبة (ليست أعمدة مباشرة في الموديل كقيمة بسيطة) ===== *@
                    <th data-col="linescount">@sortLink("linescount", "عدد السطور")</th>

                    <th class="text-nowrap no-print" data-col="actions" data-col-fixed="true" style="width:220px;"></th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="20" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var pi in Model.Items)
                    {
                        @* متغيرات مساعدة للعرض *@
                        var vendorName = pi.Customer != null ? pi.Customer.CustomerName : "";  @* اسم المورد *@
                        var linesCount = pi.Lines != null ? pi.Lines.Count : 0;               @* عدد السطور *@

                        <tr>
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox" class="row-select" value="@pi.PIId" />
                            </td>

                            <td data-col="piid">@pi.PIId</td>
                            <td data-col="pidate">@pi.PIDate.ToString("yyyy-MM-dd")</td>

                            <td data-col="customerid">@pi.CustomerId</td>
                            <td data-col="customername">@vendorName</td>

                            <td data-col="warehouseid">@pi.WarehouseId</td>

                            <td data-col="refprid">@(pi.RefPRId.HasValue? pi.RefPRId.Value.ToString() : "")</td>

                            <td data-col="itemstotal">@pi.ItemsTotal.ToString("0.00")</td>
                            <td data-col="discounttotal">@pi.DiscountTotal.ToString("0.00")</td>
                            <td data-col="taxtotal">@pi.TaxTotal.ToString("0.00")</td>
                            <td data-col="nettotal">@pi.NetTotal.ToString("0.00")</td>

                            <td data-col="status">@pi.Status</td>
                            <td data-col="isposted">@(pi.IsPosted ? "نعم" : "لا")</td>

                            <td data-col="postedat">@(pi.PostedAt.HasValue? pi.PostedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                            <td data-col="postedby">@pi.PostedBy</td>

                            <td data-col="createdby">@pi.CreatedBy</td>
                            <td data-col="createdat">@pi.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td data-col="updatedat">@(pi.UpdatedAt.HasValue? pi.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>

                            <td data-col="linescount">@linesCount</td>

                            <td class="text-nowrap no-print" data-col="actions">
                                <a class="btn btn-primary btn-sm open-same-tab"
                                   href="/PurchaseInvoices/Show?id=@pi.PIId&frame=1"
                                   data-tab-id="pi-invoice-show-tab"
                                   data-tab-title="فاتورة المشتريات"
                                   data-url="/PurchaseInvoices/Show?id=@pi.PIId&frame=1">
                                    عرض
                                </a>




                                <form asp-action="Delete"
                                      asp-route-id="@pi.PIId"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('تأكيد حذف الفاتورة رقم @pi.PIId ؟');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        حذف
                                    </button>
                                </form>

                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="table-light">
                <tr class="fw-bold">
                    <td class="text-center no-print" data-col="select"></td>
                    <td data-col="piid" class="text-muted">إجمالي</td>
                    <td data-col="pidate"></td>
                    <td data-col="customerid"></td>
                    <td data-col="customername"></td>
                    <td data-col="warehouseid"></td>
                    <td data-col="refprid"></td>
                    <td data-col="itemstotal"></td>
                    <td data-col="discounttotal"></td>
                    <td data-col="taxtotal"></td>
                    <td data-col="nettotal">@((ViewBag.TotalNet != null ? (decimal)ViewBag.TotalNet : 0m).ToString("0.00"))</td>
                    <td data-col="status"></td>
                    <td data-col="isposted"></td>
                    <td data-col="postedat"></td>
                    <td data-col="postedby"></td>
                    <td data-col="createdby"></td>
                    <td data-col="createdat"></td>
                    <td data-col="updatedat"></td>
                    <td data-col="linescount"></td>
                    <td class="text-nowrap no-print" data-col="actions"></td>
                </tr>
            </tfoot>
        </table>

    </div>

    @* ===== الشريط السفلي: عرض X–Y من Z + حجم الصفحة ===== *@
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-2 no-print">
        <small class="text-muted">
            عرض @start - @end من @total
        </small>

        <form method="get"
              action="@Url.Action(action, controller)"
              class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="@search" />
            <input type="hidden" name="searchBy" value="@searchBy" />
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="dir" value="@dir" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="dateField" value="@dateField" />
            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
            @if (Model.FromDate.HasValue)
            {
                <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" />
            }
            @if (Model.ToDate.HasValue)
            {
                <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" />
            }
            @if (fromCode.HasValue)
            {
                <input type="hidden" name="fromCode" value="@fromCode" />
            }
            @if (toCode.HasValue)
            {
                <input type="hidden" name="toCode" value="@toCode" />
            }

            <label class="form-label m-0 nowrap">حجم الصفحة</label>
            <select name="pageSize"
                    class="form-select form-select-sm"
                    onchange="this.form.submit()">
                <option value="25" selected="@(ps == 25 ? "selected" : null)">25</option>
                <option value="50" selected="@(ps == 50 ? "selected" : null)">50</option>
                <option value="100" selected="@(ps == 100 ? "selected" : null)">100</option>
                <option value="200" selected="@(ps == 200 ? "selected" : null)">200</option>
            </select>
        </form>
    </div>

    <div>
        <small class="text-muted d-none d-md-inline">
            إجمالي فواتير المشتريات: @total
        </small>
    </div>

    @* ===== الترقيم (Pagination) بنفس شكل المحافظات/المبيعات ===== *@
    <nav aria-label="pagination" class="mt-3 no-print">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == first ? "disabled" : "")">
                <a class="page-link" href="@Link(first)">الأول</a>
            </li>
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link" href="@Link(prev)">السابق</a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    صفحة @(page) من @(pages)
                </span>
            </li>
            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link" href="@Link(next)">التالي</a>
            </li>
            <li class="page-item @(page == last ? "disabled" : "")">
                <a class="page-link" href="@Link(last)">الأخير</a>
            </li>
        </ul>
    </nav>
</div>

@* ===== Modal فلترة التاريخ/الوقت ===== *@
<div class="modal fade no-print"
     id="dateFilterModal"
     tabindex="-1"
     aria-labelledby="dateFilterModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="dateFilterModalLabel">
                    فلترة بالتاريخ والوقت (تاريخ فاتورة المشتريات)
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>

            <form method="get" asp-action="@action" asp-controller="@controller">
                <div class="modal-body">
                    <input type="hidden" name="search" value="@search" />
                    <input type="hidden" name="searchBy" value="@searchBy" />
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="fromCode" value="@(fromCode?.ToString() ?? "")" />
                    <input type="hidden" name="toCode" value="@(toCode?.ToString() ?? "")" />
                    <input type="hidden" name="dateField" value="@dateField" />

                    <div class="mb-3">
                        <div class="form-check d-flex align-items-center">
                            <input class="form-check-input ms-2"
                                   type="checkbox"
                                   id="useDateRange"
                                   name="useDateRange"
                                   value="true"
                                   @(Model.UseDateRange ? "checked" : "") />
                            <label class="form-check-label" for="useDateRange">
                                تفعيل فلترة التاريخ/الوقت
                            </label>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label">من (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="fromDate"
                                   value="@(Model.FromDate.HasValue? Model.FromDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">إلى (تاريخ + وقت)</label>
                            <input type="datetime-local"
                                   class="form-control"
                                   name="toDate"
                                   value="@(Model.ToDate.HasValue? Model.ToDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-erp btn-erp-primary">
                        تطبيق الفلتر
                    </button>
                    <a class="btn btn-erp btn-erp-secondary"
                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print"
     id="columnsModalPI"
     tabindex="-1"
     aria-labelledby="columnsModalPILabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalPILabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListPI"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsPI"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // =========================
        // زر الطباعة — يطبع الجدول فقط (CSS: no-print / erp-print-area)
        // =========================
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table = document.getElementById("piTable");
            if (!table) return;

            const chkAll  = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected");
            const bulkForm          = document.getElementById("bulkDeleteForm");
            const selectedInput     = document.getElementById("selectedIdsInput");

            btnDeleteSelected?.addEventListener("click", function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    alert("من فضلك اختر على الأقل فاتورة واحدة للحذف.");
                    return;
                }

                if (!confirm("هل أنت متأكد من حذف فواتير المشتريات المحددة؟ سيتم حذف السطور التابعة لها أيضاً.")) return;

                selectedInput.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("deleteAllForm");

            btnDeleteAll?.addEventListener("click", function () {
                if (!confirm("تحذير: سيتم حذف جميع فواتير المشتريات وسطورها. هل أنت متأكد؟")) return;
                deleteAllForm.submit();
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("piTable");
            if (!table) return;

            const storageKey = "pi-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListPI");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsPI")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalPI");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر الكود من/إلى (رقم الفاتورة)
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else          url.searchParams.delete("fromCode");

                if (codeTo)   url.searchParams.set("toCode", codeTo);
                else          url.searchParams.delete("toCode");

                // نرجع لأول صفحة مع الحفاظ على باقي الفلاتر
                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();
    </script>
}
