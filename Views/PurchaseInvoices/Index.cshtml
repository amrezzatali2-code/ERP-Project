                       asp-action="@action"
                       asp-controller="@controller">
                        مسح الفلتر
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@* ===== Modal اختيار الأعمدة ===== *@
<div class="modal fade no-print erp-columns-modal"
     id="columnsModalPI"
     tabindex="-1"
     aria-labelledby="columnsModalPILabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" dir="rtl">
            <div class="modal-header">
                <h5 class="modal-title flex-grow-1" id="columnsModalPILabel">
                    اختيار الأعمدة الظاهرة
                </h5>
                <button type="button"
                        class="btn-close ms-2"
                        data-bs-dismiss="modal"
                        aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div id="columnsListPI" class="erp-columns-modal-list"></div>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-erp btn-erp-secondary"
                        data-bs-dismiss="modal">
                    إغلاق
                </button>
                <button type="button"
                        id="btnApplyColumnsPI"
                        class="btn btn-erp btn-erp-primary">
                    تطبيق
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/erp-list-selectable.js" asp-append-version="true"></script>
    <script src="~/js/erp-list-column-filter.js" asp-append-version="true"></script>
    <script>
        // =========================
        // التمرير الأفقي: عند فتح الصفحة يكون الشريط في أقصى اليمين (RTL)
        // =========================
        (function () {
            var wrapper = document.getElementById("piTableScrollWrapper");
            if (wrapper) {
                function scrollToRtlStart() {
                    var maxScroll = wrapper.scrollWidth - wrapper.clientWidth;
                    wrapper.scrollLeft = maxScroll > 0 ? maxScroll : 0;
                }
                scrollToRtlStart();
                window.addEventListener("load", function () { setTimeout(scrollToRtlStart, 50); });
            }
        })();

        // =========================
        // زر الطباعة — يطبع الجدول فقط
        // =========================
        document.getElementById("btnPrint")?.addEventListener("click", function () {
            window.print();
        });

        // =========================
        // تحديد الصفوف / حذف المحدد / حذف الكل
        // =========================
        (function () {
            const table = document.getElementById("piTable");
            if (!table) return;

            const chkAll  = document.getElementById("chkAllRows");
            const rowsChk = () => table.querySelectorAll("tbody .row-select");

            chkAll?.addEventListener("change", function () {
                rowsChk().forEach(cb => cb.checked = chkAll.checked);
            });

            table.addEventListener("change", function (e) {
                const target = e.target;
                if (target && target.classList.contains("row-select")) {
                    if (!target.checked && chkAll) chkAll.checked = false;
                }
            });

            const btnDeleteSelected = document.getElementById("btnDeleteSelected");
            const bulkForm          = document.getElementById("bulkDeleteForm");
            const selectedInput     = document.getElementById("selectedIdsInput");

            btnDeleteSelected?.addEventListener("click", async function () {
                const ids = Array.from(rowsChk())
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (ids.length === 0) {
                    if (typeof ERP !== "undefined" && ERP.showAlertModal) {
                        await ERP.showAlertModal({
                            title: "حذف فواتير",
                            message: "من فضلك اختر على الأقل فاتورة واحدة للحذف.",
                            okText: "حسناً"
                        });
                    } else {
                        alert("من فضلك اختر على الأقل فاتورة واحدة للحذف.");
                    }
                    return;
                }

                let ok = true;
                if (typeof ERP !== "undefined" && ERP.showConfirmModal) {
                    ok = await ERP.showConfirmModal({
                        title: "حذف فواتير المشتريات",
                        message: "هل أنت متأكد من حذف فواتير المشتريات المحددة؟ سيتم حذف السطور التابعة لها أيضاً.",
                        confirmText: "حذف",
                        cancelText: "إلغاء"
                    });
                } else {
                    ok = confirm("هل أنت متأكد من حذف فواتير المشتريات المحددة؟ سيتم حذف السطور التابعة لها أيضاً.");
                }
                if (!ok) return;

                selectedInput.value = ids.join(",");
                bulkForm.submit();
            });

            const btnDeleteAll  = document.getElementById("btnDeleteAll");
            const deleteAllForm = document.getElementById("deleteAllForm");

            btnDeleteAll?.addEventListener("click", async function () {
                let ok = true;
                if (typeof ERP !== "undefined" && ERP.showConfirmModal) {
                    ok = await ERP.showConfirmModal({
                        title: "حذف كل فواتير المشتريات",
                        message: "تحذير: سيتم حذف جميع فواتير المشتريات وسطورها. هل أنت متأكد؟",
                        confirmText: "حذف الكل",
                        cancelText: "إلغاء"
                    });
                } else {
                    ok = confirm("تحذير: سيتم حذف جميع فواتير المشتريات وسطورها. هل أنت متأكد؟");
                }
                if (!ok) return;
                deleteAllForm.submit();
            });

            // =========================
            // زر ترحيل الفاتورة من الجدول (نفس وظيفة الترحيل داخل الفاتورة)
            // =========================
            table.addEventListener("click", async function (e) {
                const btn = e.target.closest(".btn-post-invoice");
                if (!btn || btn.disabled) return;
                const piId = btn.getAttribute("data-pi-id");
                if (!piId) return;
                if (typeof ERP === "undefined" || !ERP.showConfirmModal) {
                    if (!confirm("ترحيل فاتورة المشتريات رقم " + piId + "؟")) return;
                } else {
                    const ok = await ERP.showConfirmModal({
                        title: "ترحيل فاتورة مشتريات",
                        message: "هل تريد ترحيل فاتورة المشتريات رقم " + piId + "؟ بعد الترحيل تُقفَل الفاتورة.",
                        confirmText: "ترحيل",
                        cancelText: "إلغاء"
                    });
                    if (!ok) return;
                }
                btn.disabled = true;
                try {
                    const resp = await fetch("@Url.Action("PostInvoice", "PurchaseInvoices")/" + piId, {
                        method: "POST",
                        headers: { "X-Requested-With": "XMLHttpRequest", "Accept": "application/json" }
                    });
                    const data = await resp.json().catch(() => ({}));
                    if (resp.ok && data.ok) {
                        const row = table.querySelector("tr[data-pi-id='" + piId + "']");
                        if (row) {
                            const statusCell = row.querySelector("td[data-col='status']");
                            const ispostedCell = row.querySelector("td[data-col='isposted']");
                            const postedatCell = row.querySelector("td[data-col='postedat']");
                            const postedbyCell = row.querySelector("td[data-col='postedby']");
                            if (statusCell) statusCell.textContent = data.status || data.postedLabel || "مرحلة 1";
                            if (ispostedCell) ispostedCell.textContent = "نعم";
                            if (postedatCell && data.postedAt) {
                                const d = data.postedAt;
                                postedatCell.textContent = (typeof d === 'string' && d.indexOf('T') !== -1) ? d.replace('T', ' ').substring(0, 16) : d;
                            }
                            if (postedbyCell && data.postedBy) postedbyCell.textContent = data.postedBy;
                            btn.remove();
                        }
                        if (typeof ERP !== "undefined" && ERP.showToast) {
                            ERP.showToast(data.message || "تم ترحيل الفاتورة بنجاح.", "success", 1000);
                        } else if (typeof alert === "function") {
                            alert(data.message || "تم ترحيل الفاتورة بنجاح.");
                        }
                    } else {
                        btn.disabled = false;
                        const msg = (data && data.message) || "فشل الترحيل.";
                        if (typeof ERP !== "undefined" && ERP.showToast) ERP.showToast(msg, "danger");
                        else alert(msg);
                    }
                } catch (err) {
                    btn.disabled = false;
                    if (typeof ERP !== "undefined" && ERP.showToast) ERP.showToast("حدث خطأ أثناء الترحيل.", "danger");
                    else alert("حدث خطأ أثناء الترحيل.");
                }
            });
        })();

        // =========================
        // اختيار الأعمدة + حفظها في localStorage
        // =========================
        (function () {
            const table = document.getElementById("piTable");
            if (!table) return;

            const storageKey = "pi-columns-visibility";

            const headerCells = Array.from(table.querySelectorAll("thead th[data-col]"));
            const columns = headerCells
                .filter(th => !th.hasAttribute("data-col-fixed"))
                .map(th => ({
                    key: th.getAttribute("data-col"),
                    title: th.innerText.trim()
                }));

            if (columns.length === 0) return;

            let hidden = [];
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) hidden = JSON.parse(saved);
            } catch { hidden = []; }

            function applyVisibility() {
                columns.forEach(col => {
                    const isHidden = hidden.includes(col.key);
                    table.querySelectorAll("[data-col='" + col.key + "']")
                        .forEach(cell => {
                            cell.classList.toggle("d-none", isHidden);
                        });
                });
            }

            applyVisibility();

            const listContainer = document.getElementById("columnsListPI");
            if (listContainer) {
                listContainer.innerHTML = "";
                columns.forEach(col => {
                    const id = "col_" + col.key;
                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check mb-1";

                    const cb = document.createElement("input");
                    cb.type = "checkbox";
                    cb.className = "form-check-input ms-2";
                    cb.id = id;
                    cb.checked = !hidden.includes(col.key);
                    cb.dataset.colKey = col.key;

                    const label = document.createElement("label");
                    label.className = "form-check-label";
                    label.setAttribute("for", id);
                    label.innerText = col.title;

                    wrapper.appendChild(cb);
                    wrapper.appendChild(label);
                    listContainer.appendChild(wrapper);
                });
            }

            document.getElementById("btnApplyColumnsPI")
                ?.addEventListener("click", function () {
                    const checks = listContainer.querySelectorAll("input[type='checkbox'][data-col-key]");
                    hidden = [];
                    checks.forEach(cb => {
                        const key = cb.dataset.colKey;
                        if (!cb.checked) hidden.push(key);
                    });

                    try {
                        localStorage.setItem(storageKey, JSON.stringify(hidden));
                    } catch { }

                    applyVisibility();

                    const modalEl = document.getElementById("columnsModalPI");
                    const modal   = bootstrap.Modal.getInstance(modalEl);
                    modal?.hide();
                });
        })();

        // =========================
        // فلتر الكود من/إلى (رقم الفاتورة)
        // =========================
        (function () {
            const btnApply = document.getElementById("btnApplyCodeFilter");
            const btnClear = document.getElementById("btnClearCodeFilter");
            const fromInp  = document.getElementById("codeFromInput");
            const toInp    = document.getElementById("codeToInput");

            function buildUrl(codeFrom, codeTo) {
                const url = new URL(window.location.href);
                if (codeFrom) url.searchParams.set("fromCode", codeFrom);
                else url.searchParams.delete("fromCode");
                if (codeTo) url.searchParams.set("toCode", codeTo);
                else url.searchParams.delete("toCode");
                url.searchParams.set("page", "1");
                return url.toString();
            }

            btnApply?.addEventListener("click", function () {
                const cf = fromInp.value.trim();
                const ct = toInp.value.trim();
                window.location.href = buildUrl(cf, ct);
            });

            btnClear?.addEventListener("click", function () {
                fromInp.value = "";
                toInp.value   = "";
                window.location.href = buildUrl("", "");
            });
        })();

        if (typeof ERP !== "undefined" && ERP.initListColumnFilter) {
            ERP.initListColumnFilter({
                panelId: "erpColumnFilterPanel",
                tableId: "piTable",
                wrapperId: "piTableScrollWrapper",
                getColumnValuesUrl: "@Url.Action("GetColumnValues", "PurchaseInvoices")",
                defaultSort: "PIDate",
                defaultDir: "desc",
                numericColumns: ["id", "warehouse", "refprid", "customerid", "itemstotal", "discounttotal", "nettotal"]
            });
        }

        if (typeof ERP !== "undefined" && ERP.initListSelection) {
            ERP.initListSelection({
                rowSelector: ".erp-list-selectable-row",
                showButtonId: "btnShowPI",
                idAttribute: "data-pi-id",
                showUrlAttribute: "data-show-url",
                tabTitleAttribute: "data-tab-title",
                showTabId: "pi-show-tab",
                movementButtonId: "btnCustomerVolumePI",
                movementUrlAttribute: "data-customer-volume-url",
                movementTabTitle: "حجم تعامل عميل",
                movementTabId: "customer-engagement",
                multiSelectCheckboxes: true
            });
        }
    </script>
}
