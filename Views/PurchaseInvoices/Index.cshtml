                    </th>
                    <th data-col="piid">@filterableCol("id", "id", "رقم الفاتورة")</th>
                    <th data-col="pidate">@filterableCol("pidate", "date", "تاريخ الفاتورة")</th>
                    <th data-col="customerid">@filterableCol("customerid", "customerid", "كود المورد")</th>
                    <th data-col="customername">@filterableCol("vendor", "vendor", "المورد")</th>
                    <th data-col="warehouseid">@filterableCol("warehouse", "warehouse", "المخزن")</th>
                    <th data-col="refprid">@filterableCol("refprid", "refprid", "طلب شراء مرجعي")</th>
                    <th data-col="itemstotal">@filterableCol("itemstotal", "itemstotal", "إجمالي قبل الخصم")</th>
                    <th data-col="discounttotal">@filterableCol("discounttotal", "discounttotal", "إجمالي الخصم")</th>
                    <th data-col="taxtotal">@sortLink("taxtotal", "إجمالي الضريبة")</th>
                    <th data-col="nettotal">@filterableCol("nettotal", "net", "صافي الفاتورة")</th>
                    <th data-col="status">@filterableCol("status", "status", "الحالة")</th>
                    <th data-col="isposted">@filterableCol("isposted", "posted", "مرحل؟")</th>
                    <th data-col="postedat">@sortLink("postedat", "تاريخ الترحيل")</th>
                    <th data-col="postedby">@filterableCol("postedby", "postedby", "مرحل بواسطة")</th>
                    <th data-col="createdby">@filterableCol("createdby", "createdby", "أنشأها")</th>
                    <th data-col="createdat">@sortLink("createdat", "تاريخ الإنشاء")</th>
                    <th data-col="updatedat">@sortLink("updatedat", "آخر تعديل")</th>
                    <th data-col="linescount">@sortLink("linescount", "عدد السطور")</th>
                    <th class="text-center no-print" data-col="post" data-col-fixed="true" style="width:80px;">ترحيل</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="20" class="text-center text-muted py-4">
                            لا توجد بيانات.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var pi in Model.Items)
                    {
                        var vendorName = pi.Customer != null ? pi.Customer.CustomerName : "";
                        var linesCount = pi.Lines != null ? pi.Lines.Count : 0;
                        var showUrl = Url.Action("Show", "PurchaseInvoices", new { id = pi.PIId }) + "?frame=1";
                        var volUrl = pi.CustomerId > 0 ? Url.Action("Show", "Customers", new { id = pi.CustomerId, frame = 1 }) : "";

                        <tr class="erp-list-selectable-row" data-pi-id="@pi.PIId"
                            data-show-url="@showUrl"
                            data-tab-title="فاتورة مشتريات"
                            data-customer-volume-url="@volUrl">
                            <td class="text-center no-print" data-col="select">
                                <input type="checkbox" class="row-select" value="@pi.PIId" />
                            </td>

                            <td data-col="piid">@pi.PIId</td>
                            <td data-col="pidate">@pi.PIDate.ToString("d/M/yyyy")</td>

                            <td data-col="customerid">@pi.CustomerId</td>
                            <td data-col="customername">@vendorName</td>

                            <td data-col="warehouseid">@pi.WarehouseId</td>

                            <td data-col="refprid">@(pi.RefPRId.HasValue? pi.RefPRId.Value.ToString() : "")</td>

                            <td data-col="itemstotal">@pi.ItemsTotal.ToString("0.00")</td>
                            <td data-col="discounttotal">@pi.DiscountTotal.ToString("0.00")</td>
                            <td data-col="taxtotal">@pi.TaxTotal.ToString("0.00")</td>
                            <td data-col="nettotal">@pi.NetTotal.ToString("0.00")</td>

                            <td data-col="status">@pi.Status</td>
                            <td data-col="isposted">@(pi.IsPosted ? "نعم" : "لا")</td>

                            <td data-col="postedat">@(pi.PostedAt.HasValue? pi.PostedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>
                            <td data-col="postedby">@pi.PostedBy</td>

                            <td data-col="createdby">@pi.CreatedBy</td>
                            <td data-col="createdat">@pi.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td data-col="updatedat">@(pi.UpdatedAt.HasValue? pi.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm") : "")</td>

                            <td data-col="linescount">@linesCount</td>

                            <td class="text-center no-print" data-col="post">
                                @if (!pi.IsPosted)
                                {
                                    <button type="button" class="btn btn-erp btn-erp-success btn-erp-sm btn-post-invoice" data-pi-id="@pi.PIId" title="ترحيل الفاتورة">
                                        ترحيل
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="table-light">
                <tr class="fw-bold text-start">
                    <td class="text-center no-print" data-col="select"></td>
                    <td data-col="piid" class="text-muted">إجمالي</td>
                    <td data-col="pidate"></td>
                    <td data-col="customerid"></td>
                    <td data-col="customername"></td>
                    <td data-col="warehouseid"></td>
                    <td data-col="refprid"></td>
                    <td data-col="itemstotal"></td>
                    <td data-col="discounttotal"></td>
                    <td data-col="taxtotal"></td>
                    <td data-col="nettotal">@totalNet.ToString("0.00")</td>
                    <td data-col="status"></td>
                    <td data-col="isposted"></td>
                    <td data-col="postedat"></td>
                    <td data-col="postedby"></td>
                    <td data-col="createdby"></td>
                    <td data-col="createdat"></td>
                    <td data-col="updatedat"></td>
                    <td data-col="linescount"></td>
                    <td class="text-center no-print" data-col="post"></td>
                </tr>
            </tfoot>
        </table>
        </div>
    </div>

