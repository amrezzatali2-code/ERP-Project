@* Views/PurchaseInvoices/Index.cshtml — قائمة فواتير المشتريات بنفس نموذج فواتير المبيعات *@
@using Microsoft.AspNetCore.Html
@using ERP.Infrastructure
@model PagedResult<ERP.Models.PurchaseInvoice>

@{
    ViewData["Title"] = "قائمة فواتير المشتريات";

    // أسماء الأكشن/الكنترولر الحالية
    var action = Convert.ToString(ViewContext.RouteData.Values["action"]) ?? "Index";
    var controller = Convert.ToString(ViewContext.RouteData.Values["controller"]) ?? "PurchaseInvoices";

    // قيم البحث/الترتيب الحالية
    var search = Model.Search ?? (string?)ViewBag.Search ?? "";
    var searchBy = (string?)ViewBag.SearchBy ?? "id";
    var searchMode = (string?)ViewBag.SearchMode ?? "contains";
    var sort = Model.SortColumn ?? (string?)ViewBag.Sort ?? "PIDate";
    var dir = Model.SortDescending ? "desc" : ((string?)ViewBag.Dir ?? "desc");

    // بيانات الترقيم
    int ps = Model.PageSize;
    int total = Model.TotalCount;
    int page = Model.PageNumber;
    int pages = Model.TotalPages;

    int start = Model.StartIndex;
    int end = Model.EndIndex;

    decimal totalNet = ViewBag.TotalNet != null ? (decimal)ViewBag.TotalNet : 0m;
    decimal totalItemsSum = ViewBag.TotalItemsSum != null ? (decimal)ViewBag.TotalItemsSum : 0m;

    int first = 1, last = Math.Max(1, pages);
    int prev = Math.Max(first, page - 1);
    int next = Math.Min(last, page + 1);

    // فلتر كود من/إلى (رقم الفاتورة من/إلى)
    int? fromCode = ViewBag.FromCode as int?;
    int? toCode = ViewBag.ToCode as int?;

    // حقل التاريخ المستخدم في الفلترة
    var dateField = (string?)ViewBag.DateField ?? "PIDate";

    string? filterCol_id = ViewBag.FilterCol_Id as string;
    string? filterCol_idExpr = ViewBag.FilterCol_IdExpr as string;
    string? filterCol_status = ViewBag.FilterCol_Status as string;
    string? filterCol_vendor = ViewBag.FilterCol_Vendor as string;
    string? filterCol_warehouse = ViewBag.FilterCol_Warehouse as string;
    string? filterCol_warehouseExpr = ViewBag.FilterCol_WarehouseExpr as string;
    string? filterCol_refprid = ViewBag.FilterCol_Refprid as string;
    string? filterCol_refpridExpr = ViewBag.FilterCol_RefpridExpr as string;
    string? filterCol_pidate = ViewBag.FilterCol_Pidate as string;
    string? filterCol_customerid = ViewBag.FilterCol_Customerid as string;
    string? filterCol_customeridExpr = ViewBag.FilterCol_CustomeridExpr as string;
    string? filterCol_itemstotal = ViewBag.FilterCol_Itemstotal as string;
    string? filterCol_itemstotalExpr = ViewBag.FilterCol_ItemstotalExpr as string;
    string? filterCol_discounttotal = ViewBag.FilterCol_Discounttotal as string;
    string? filterCol_discounttotalExpr = ViewBag.FilterCol_DiscounttotalExpr as string;
    string? filterCol_nettotal = ViewBag.FilterCol_Nettotal as string;
    string? filterCol_nettotalExpr = ViewBag.FilterCol_NettotalExpr as string;
    string? filterCol_isposted = ViewBag.FilterCol_Isposted as string;
    string? filterCol_postedby = ViewBag.FilterCol_Postedby as string;
    string? filterCol_createdby = ViewBag.FilterCol_Createdby as string;

    string? FilterForCol(string colKey) =>
        colKey == "id" ? (!string.IsNullOrWhiteSpace(filterCol_idExpr) ? filterCol_idExpr : filterCol_id)
        : colKey == "warehouse" ? (!string.IsNullOrWhiteSpace(filterCol_warehouseExpr) ? filterCol_warehouseExpr : filterCol_warehouse)
        : colKey == "refprid" ? (!string.IsNullOrWhiteSpace(filterCol_refpridExpr) ? filterCol_refpridExpr : filterCol_refprid)
        : colKey == "customerid" ? (!string.IsNullOrWhiteSpace(filterCol_customeridExpr) ? filterCol_customeridExpr : filterCol_customerid)
        : colKey == "itemstotal" ? (!string.IsNullOrWhiteSpace(filterCol_itemstotalExpr) ? filterCol_itemstotalExpr : filterCol_itemstotal)
        : colKey == "discounttotal" ? (!string.IsNullOrWhiteSpace(filterCol_discounttotalExpr) ? filterCol_discounttotalExpr : filterCol_discounttotal)
        : colKey == "nettotal" ? (!string.IsNullOrWhiteSpace(filterCol_nettotalExpr) ? filterCol_nettotalExpr : filterCol_nettotal)
        : colKey == "status" ? filterCol_status
        : colKey == "vendor" ? filterCol_vendor
        : colKey == "pidate" ? filterCol_pidate
        : colKey == "isposted" ? filterCol_isposted
        : colKey == "postedby" ? filterCol_postedby
        : colKey == "createdby" ? filterCol_createdby
        : null;

    string Link(int p) => Url.Action(action, controller, new
    {
        search,
        searchBy,
        searchMode,
        sort,
        dir,
        page = p,
        pageSize = ps,
        useDateRange = Model.UseDateRange,
        fromDate = Model.FromDate,
        toDate = Model.ToDate,
        dateField = dateField,
        fromCode,
        toCode,
        filterCol_id,
        filterCol_idExpr,
        filterCol_status,
        filterCol_vendor,
        filterCol_warehouse,
        filterCol_warehouseExpr,
        filterCol_refprid,
        filterCol_refpridExpr,
        filterCol_pidate,
        filterCol_customerid,
        filterCol_customeridExpr,
        filterCol_itemstotal,
        filterCol_itemstotalExpr,
        filterCol_discounttotal,
        filterCol_discounttotalExpr,
        filterCol_nettotal,
        filterCol_nettotalExpr,
        filterCol_isposted,
        filterCol_postedby,
        filterCol_createdby
    })!;

    // دالة إنشاء لينك الترتيب في رأس الجدول
    Func<string, string, IHtmlContent> sortLink = (col, caption) =>
    {
        var isCurrent = string.Equals(sort, col, StringComparison.OrdinalIgnoreCase);
        var newDir = (isCurrent && dir == "asc") ? "desc" : "asc";
        var url = Url.Action(action, controller, new
        {
            search,
            searchBy,
            searchMode,
            sort = col,
            dir = newDir,
            page = 1,
            pageSize = ps,
            useDateRange = Model.UseDateRange,
            fromDate = Model.FromDate,
            toDate = Model.ToDate,
            dateField,
            fromCode,
            toCode,
            filterCol_id,
            filterCol_idExpr,
            filterCol_status,
            filterCol_vendor,
            filterCol_warehouse,
            filterCol_warehouseExpr,
            filterCol_refprid,
            filterCol_refpridExpr,
            filterCol_pidate,
            filterCol_customerid,
            filterCol_customeridExpr,
            filterCol_itemstotal,
            filterCol_itemstotalExpr,
            filterCol_discounttotal,
            filterCol_discounttotalExpr,
            filterCol_nettotal,
            filterCol_nettotalExpr,
            filterCol_isposted,
            filterCol_postedby,
            filterCol_createdby
        }) ?? "#";
        string icon = "⇅";
        if (isCurrent) icon = dir == "asc" ? "▲" : "▼";
        return new HtmlString($@"<a href=""{url}"">{caption}<span class=""erp-sort-icon"">{icon}</span></a>");
    };

    Func<string, string, string, IHtmlContent> filterableCol = (colKey, sortKey, caption) =>
    {
        string? currentFilter = FilterForCol(colKey);
        bool hasFilter = !string.IsNullOrWhiteSpace(currentFilter);
        var isCurrentSort = string.Equals(sort, sortKey, StringComparison.OrdinalIgnoreCase);
        var sortDir = isCurrentSort ? dir : "asc";
        var btnStateClass = hasFilter ? "text-primary" : (isCurrentSort ? "text-info" : "text-muted");
        return new HtmlString($@"
            <div class=""d-flex align-items-center gap-1 erp-col-header-filterable"">
                <span class=""erp-col-title"">{caption}</span>
                <button type=""button"" class=""btn btn-sm p-0 erp-col-filter-btn {btnStateClass}""
                        data-col=""{colKey}"" data-sort-key=""{sortKey}"" data-col-title=""{caption}""
                        data-current-sort=""{sortKey}"" data-current-dir=""{sortDir}""
                        title=""ترتيب وفلتر العمود"" style=""min-width:22px;"">
                    <svg xmlns=""http://www.w3.org/2000/svg"" width=""16"" height=""16"" viewBox=""0 0 24 24"" fill=""currentColor"">
                        <path d=""M3 18h6v-2H3v2zM3 6v2h18V6H3zm0 7h12v-2H3v2z""/>
                        <path d=""M7 8l4-4 4 4H7zm0 8l4 4 4-4H7z"" opacity=""0.3""/>
                    </svg>
                </button>
            </div>");
    };
}

<div dir="rtl" class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0 fs-6 text-secondary">@ViewData["Title"]</h5>
    </div>

    @* ===== شريط الفلاتر الموحد (نمط القوائم) ===== *@
    <div class="erp-list-filter-bar d-print-none mt-2">
        <div class="row g-3 align-items-center flex-wrap justify-content-center">

            @* --- القسم الأول: البحث --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <form method="get" action="@Url.Action(action, controller)" class="erp-list-search-form d-flex flex-column align-items-center w-100">
                    <label class="form-label w-100 text-center">بحث في فواتير المشتريات</label>
                    <div class="d-flex flex-wrap align-items-center gap-2 erp-list-search-row justify-content-center w-100">
                        <input type="text" name="search" class="form-control erp-filter-input" placeholder="اكتب نص البحث..." value="@search" style="min-width:120px" />
                        <select name="searchBy" class="form-select form-select-arrow erp-filter-input" style="max-width:150px;min-width:100px">
                            <option value="id"@Html.Raw(searchBy == "id" ? " selected" : "")>رقم الفاتورة</option>
                            <option value="vendor"@Html.Raw(searchBy == "vendor" ? " selected" : "")>المورد / الكود</option>
                            <option value="warehouse"@Html.Raw(searchBy == "warehouse" ? " selected" : "")>المخزن</option>
                            <option value="date"@Html.Raw(searchBy == "date" ? " selected" : "")>تاريخ الفاتورة</option>
                            <option value="status"@Html.Raw(searchBy == "status" ? " selected" : "")>حالة الفاتورة</option>
                        </select>
                        <select name="searchMode" class="form-select form-select-arrow erp-filter-input" style="max-width:130px;min-width:100px" title="طريقة المطابقة">
                            <option value="contains"@Html.Raw(searchMode == "contains" ? " selected" : "")>يحتوي على</option>
                            <option value="startswith"@Html.Raw(searchMode == "startswith" ? " selected" : "")>يبدأ بـ</option>
                            <option value="endswith"@Html.Raw(searchMode == "endswith" ? " selected" : "")>ينتهي بـ</option>
                        </select>
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-2 justify-content-center w-100 mt-2">
                        <button type="submit" class="btn btn-erp btn-erp-primary btn-erp-sm px-3">عرض</button>
                        <a class="btn btn-erp btn-erp-secondary btn-erp-sm text-decoration-none" href="@Url.Action(action, controller)">إلغاء</a>
                    </div>
                    <input type="hidden" name="sort" value="@sort" />
                    <input type="hidden" name="dir" value="@dir" />
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@ps" />
                    <input type="hidden" name="dateField" value="@dateField" />
                    <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                    @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
                    @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
                    @if (fromCode.HasValue) { <input type="hidden" name="fromCode" value="@fromCode" /> }
                    @if (toCode.HasValue) { <input type="hidden" name="toCode" value="@toCode" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_status)) { <input type="hidden" name="filterCol_status" value="@filterCol_status" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_vendor)) { <input type="hidden" name="filterCol_vendor" value="@filterCol_vendor" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_warehouseExpr)) { <input type="hidden" name="filterCol_warehouseExpr" value="@filterCol_warehouseExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_refprid)) { <input type="hidden" name="filterCol_refprid" value="@filterCol_refprid" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_refpridExpr)) { <input type="hidden" name="filterCol_refpridExpr" value="@filterCol_refpridExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_pidate)) { <input type="hidden" name="filterCol_pidate" value="@filterCol_pidate" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_customerid)) { <input type="hidden" name="filterCol_customerid" value="@filterCol_customerid" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_customeridExpr)) { <input type="hidden" name="filterCol_customeridExpr" value="@filterCol_customeridExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_itemstotal)) { <input type="hidden" name="filterCol_itemstotal" value="@filterCol_itemstotal" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_itemstotalExpr)) { <input type="hidden" name="filterCol_itemstotalExpr" value="@filterCol_itemstotalExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_discounttotal)) { <input type="hidden" name="filterCol_discounttotal" value="@filterCol_discounttotal" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_discounttotalExpr)) { <input type="hidden" name="filterCol_discounttotalExpr" value="@filterCol_discounttotalExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_nettotal)) { <input type="hidden" name="filterCol_nettotal" value="@filterCol_nettotal" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_nettotalExpr)) { <input type="hidden" name="filterCol_nettotalExpr" value="@filterCol_nettotalExpr" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_isposted)) { <input type="hidden" name="filterCol_isposted" value="@filterCol_isposted" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_postedby)) { <input type="hidden" name="filterCol_postedby" value="@filterCol_postedby" /> }
                    @if (!string.IsNullOrWhiteSpace(filterCol_createdby)) { <input type="hidden" name="filterCol_createdby" value="@filterCol_createdby" /> }
                </form>
            </div>

            @* --- القسم الثاني: فلتر رقم الفاتورة من/إلى --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label w-100 text-center">من رقم – إلى رقم</label>
                <div class="erp-list-code-filter justify-content-center">
                    <input id="codeFromInput" type="number" class="form-control erp-filter-input" placeholder="من" value="@(fromCode?.ToString() ?? "")" />
                    <input id="codeToInput" type="number" class="form-control erp-filter-input" placeholder="إلى" value="@(toCode?.ToString() ?? "")" />
                    <button type="button" id="btnApplyCodeFilter" class="btn btn-erp btn-erp-primary btn-erp-sm">تطبيق</button>
                    <button type="button" id="btnClearCodeFilter" class="btn btn-erp btn-erp-secondary btn-erp-sm">مسح</button>
                </div>
            </div>

            @* --- القسم الثالث: أزرار التحكم --- *@
            <div class="col-12 col-lg-4 erp-filter-section d-flex flex-column align-items-center">
                <label class="form-label d-none d-md-block" style="visibility:hidden">أوامر</label>
                <div class="erp-toolbar-two-rows w-100 d-flex flex-column align-items-center gap-1">
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#dateFilterModal">فلترة بالتاريخ/الوقت</button>
                        <button type="button" class="btn btn-erp btn-erp-secondary btn-erp-sm" data-bs-toggle="modal" data-bs-target="#columnsModalPI">اختيار الأعمدة</button>
                        <button type="button" id="btnPrint" class="btn btn-erp btn-erp-secondary btn-erp-sm">🖨️ طباعة</button>
                        <span class="erp-list-toolbar-selected-actions d-inline-flex flex-wrap gap-2 align-items-center" role="group" aria-label="إجراءات الفاتورة المحددة">
                            <button type="button" id="btnShowPI" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="عرض الفاتورة">عرض</button>
                            <button type="button" id="btnCustomerVolumePI" class="btn btn-erp btn-erp-secondary btn-erp-sm" disabled title="حجم تعامل المورد">حجم التعامل</button>
                        </span>
                    </div>
                    <div class="erp-toolbar-row d-flex flex-wrap gap-2 justify-content-center align-items-center">
                        <div class="dropdown d-inline">
                            <button class="btn btn-erp btn-erp-danger btn-erp-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">حذف</button>
                            <ul class="dropdown-menu dropdown-menu-end" dir="rtl">
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteSelected">حذف المحدد</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button type="button" class="dropdown-item text-danger" id="btnDeleteAll">حذف جميع فواتير المشتريات</button></li>
                            </ul>
                        </div>
                        <form method="get" asp-action="Export" asp-controller="PurchaseInvoices" class="d-inline-flex flex-wrap gap-2 align-items-center erp-export-form">
                            <input type="hidden" name="search" value="@search" />
                            <input type="hidden" name="searchBy" value="@searchBy" />
                            <input type="hidden" name="searchMode" value="@searchMode" />
                            <input type="hidden" name="sort" value="@sort" />
                            <input type="hidden" name="dir" value="@dir" />
                            <input type="hidden" name="useDateRange" value="@(Model.UseDateRange ? "true" : "false")" />
                            @if (Model.FromDate.HasValue) { <input type="hidden" name="fromDate" value="@Model.FromDate.Value.ToString("o")" /> }
                            @if (Model.ToDate.HasValue) { <input type="hidden" name="toDate" value="@Model.ToDate.Value.ToString("o")" /> }
                            @if (fromCode.HasValue) { <input type="hidden" name="codeFrom" value="@fromCode" /> }
                            @if (toCode.HasValue) { <input type="hidden" name="codeTo" value="@toCode" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_id)) { <input type="hidden" name="filterCol_id" value="@filterCol_id" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_idExpr)) { <input type="hidden" name="filterCol_idExpr" value="@filterCol_idExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_status)) { <input type="hidden" name="filterCol_status" value="@filterCol_status" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_vendor)) { <input type="hidden" name="filterCol_vendor" value="@filterCol_vendor" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_warehouse)) { <input type="hidden" name="filterCol_warehouse" value="@filterCol_warehouse" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_warehouseExpr)) { <input type="hidden" name="filterCol_warehouseExpr" value="@filterCol_warehouseExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_refprid)) { <input type="hidden" name="filterCol_refprid" value="@filterCol_refprid" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_refpridExpr)) { <input type="hidden" name="filterCol_refpridExpr" value="@filterCol_refpridExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_pidate)) { <input type="hidden" name="filterCol_pidate" value="@filterCol_pidate" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_customerid)) { <input type="hidden" name="filterCol_customerid" value="@filterCol_customerid" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_customeridExpr)) { <input type="hidden" name="filterCol_customeridExpr" value="@filterCol_customeridExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_itemstotal)) { <input type="hidden" name="filterCol_itemstotal" value="@filterCol_itemstotal" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_itemstotalExpr)) { <input type="hidden" name="filterCol_itemstotalExpr" value="@filterCol_itemstotalExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_discounttotal)) { <input type="hidden" name="filterCol_discounttotal" value="@filterCol_discounttotal" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_discounttotalExpr)) { <input type="hidden" name="filterCol_discounttotalExpr" value="@filterCol_discounttotalExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_nettotal)) { <input type="hidden" name="filterCol_nettotal" value="@filterCol_nettotal" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_nettotalExpr)) { <input type="hidden" name="filterCol_nettotalExpr" value="@filterCol_nettotalExpr" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_createdby)) { <input type="hidden" name="filterCol_createdby" value="@filterCol_createdby" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_isposted)) { <input type="hidden" name="filterCol_isposted" value="@filterCol_isposted" /> }
                            @if (!string.IsNullOrWhiteSpace(filterCol_postedby)) { <input type="hidden" name="filterCol_postedby" value="@filterCol_postedby" /> }
                            <select name="format" class="form-select form-select-arrow erp-filter-input" style="width:85px;min-width:85px;font-size:0.95rem;font-weight:500;padding:0.3rem 0.5rem;" title="اختر صيغة التصدير">
                                <option value="excel" selected>Excel</option>
                                <option value="pdf">PDF</option>
                            </select>
                            <button type="submit" class="btn btn-erp btn-erp-success btn-erp-sm">تصدير</button>
                        </form>
                    </div>
                    <form id="bulkDeleteForm" asp-action="BulkDelete" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="selectedIds" id="selectedIdsInput" />
                    </form>
                    <form id="deleteAllForm" asp-action="DeleteAll" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                    </form>
                </div>
            </div>

        </div>
    </div>

    @{
        var n2 = System.Globalization.CultureInfo.InvariantCulture;
    }
    <div class="row g-2 g-md-3 justify-content-start no-print erp-list-summary-row mt-2" dir="rtl">
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #4338ca !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي العدد (بعد الفلترة)</div>
                    <div class="h4 mb-0 text-primary fw-bold">@total.ToString("N0", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #0369a1 !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي قبل الخصم</div>
                    <div class="h4 mb-0 fw-bold" style="color:#0369a1;">@totalItemsSum.ToString("N2", n2)</div>
                </div>
            </div>
        </div>
        <div class="col-auto">
            <div class="card h-100 border-0 erp-list-summary-card" style="border: 1px solid #15803d !important; border-radius: 12px; box-shadow: none !important; overflow: hidden;">
                <div class="card-body py-3 px-3">
                    <div class="small text-muted mb-1">إجمالي الصافي</div>
                    <div class="h4 mb-0 text-success fw-bold">@totalNet.ToString("N2", n2)</div>
                </div>
            </div>
        </div>
    </div>

    @* فورم خفي لتطبيق فلتر الأعمدة *@
